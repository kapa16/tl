# Реальные выгрузки обработок (примеры, не для версионирования)
upload/

# Результаты сборки
build/
base/
*.epf
*.log

# Родительские конфигурации (CF-архивы, часто >100 МБ — не для GitHub)
src/cf/Ext/ParentConfigurations/
src/cf/Ext/ParentConfigurations.bin

# Временные файлы тестов
test-tmp/

# Локальные артефакты отладки расширения (bisect, partial load, права)
_bisect/
_load-test-cfe*/
_partial-*.txt
_rights-*/
_test-goskey-queue.js

# Локальные настройки Claude Code
.claude/settings.local.json

# Инструменты (portable Apache, portable Go и т.д.)
tools/*
!tools/fuel-statement-ocr/
tools/fuel-statement-ocr/dist/

# Отладка навыков (eval, trigger-test, run_loop результаты)
debug/

# Кэш тестов навыков
tests/skills/.cache/

# Скриншоты и видео web-test (артефакты прогона, не исходники)
tests/**/*.png
tests/**/*.jpg
tests/**/*.jpeg
tests/**/*.webp
tests/**/*.mp4

# Python кэш
__pycache__/

# Локальный реестр баз данных 1С
.v8-project.json

# Локальные параметры проекта (шаблон — .dev.env.example)
.dev.env

# web-test: Node.js зависимости и runtime-артефакты
.claude/skills/web-test/scripts/node_modules/
.claude/skills/web-test/.browser-session.json
.cursor/skills/web-test/scripts/node_modules/
.cursor/skills/web-test/.browser-session.json

# Скриншоты и видео — только артефакты web-test (не глобально по репозиторию)
.cursor/skills/web-test/**/*.png
.cursor/skills/web-test/**/*.mp4

# Навыки, скопированные для других AI-платформ (генерируются scripts/switch.py)
