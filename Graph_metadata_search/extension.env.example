# Скопируйте в extension.env и заполните перед загрузкой расширения:
#   copy extension.env.example extension.env
#
# Предварительно: база уже загружена (mcp-app), PROJECT_NAME совпадает с EXTENSION_BASE_PROJECT.
# Запуск: .\load-extension.ps1

# Имя расширения в 1С (как в конфигураторе)
EXTENSION_NAME=bp_gmg

# Должно совпадать с PROJECT_NAME из .env базовой конфигурации
EXTENSION_BASE_PROJECT=БП КОРП

# Папка с отчётом по расширению (Конфигуратор → Отчёт из конфигурации → .txt)
EXTENSION_METADATA_HOST_PATH=E:/bp_gmg/metadata_report_ext

# Папка с выгрузкой расширения в файлы (Конфигуратор → Выгрузить конфигурацию в файлы)
EXTENSION_METADATA_FILES_HOST_PATH=E:/bp_gmg/src_ext/cf

# true при первой загрузке расширения; false при повторной переиндексации того же расширения
EXTENSION_RESET_DATABASE=true

# true — перезаписать только данные текущего PROJECT_NAME (базы), не трогая другие проекты в Neo4j
EXTENSION_FULL_METADATA_RELOAD=false
