#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем ПутьКУтилитеQR; // путь к извлечённой из макета утилите ZXing (gozxing)
Перем ПутьКУтилитеOCR; // путь к утилите FuelStatementOCR.exe

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает таблицу входящих писем для формы обработки.
//
// Возвращаемое значение:
//  ТаблицаЗначений - колонки: Письмо, Тема, Дата, Отправитель.
//
Функция СписокПисемДяОбработки() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЭлектронноеПисьмоВходящее.Ссылка КАК Письмо,
	|	ЭлектронноеПисьмоВходящее.Тема КАК Тема,
	|	ЭлектронноеПисьмоВходящее.ДатаПолучения КАК Дата,
	|	ЭлектронноеПисьмоВходящее.ОтправительПредставление КАК Отправитель
	|ИЗ
	|	Документ.ЭлектронноеПисьмоВходящее КАК ЭлектронноеПисьмоВходящее
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_СоответсвиеДокументовПисьмам КАК GDS_СоответсвиеДокументовПисьмам
	|		ПО ЭлектронноеПисьмоВходящее.Ссылка = GDS_СоответсвиеДокументовПисьмам.Письмо
	|ГДЕ
	|	НЕ ЭлектронноеПисьмоВходящее.ПометкаУдаления
	|	И GDS_СоответсвиеДокументовПисьмам.Документ ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭлектронноеПисьмоВходящее.ДатаПолучения УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Обрабатывает одно входящее письмо: QR → ведомость → файл.
//
// Параметры:
//  Письмо - ДокументСсылка.ЭлектронноеПисьмоВходящее
//
// Возвращаемое значение:
//  Структура - Успех, Ведомость, Вложение, ТекстОшибки, ЛогOCR, ПредупреждениеOCR.
//
Функция ОбработатьПисьмо(Письмо) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ведомость", Неопределено);
	Результат.Вставить("Вложение", "");
	Результат.Вставить("ТекстОшибки", "");
	Результат.Вставить("ЛогOCR", "");
	Результат.Вставить("ПредупреждениеOCR", Ложь);
	
	Попытка
		
		//СуществующаяВедомость = НайтиВедомостьПоПисьму(Письмо);
		//Если ЗначениеЗаполнено(СуществующаяВедомость) Тогда
		//	Результат.Успех = Истина;
		//	Результат.Ведомость = СуществующаяВедомость;
		//	Возврат Результат;
		//КонецЕсли;
		
		ДанныеВложения = НайтиQRВоВложениях(Письмо);
		Если ДанныеВложения = Неопределено Тогда
			Результат.ТекстОшибки = НСтр("ru = 'QR-код не найден ни в одном вложении (JPG/PNG/PDF).'");
			Возврат Результат;
		КонецЕсли;
		
		Результат.Вложение = ДанныеВложения.ИмяФайла;
		
		ДанныеQR = РазобратьДанныеQR(ДанныеВложения.QRСтрока);
		РезультатОбработки = ВедомостьПоДаннымQR(
			ДанныеQR,
			Письмо,
			ДанныеВложения.ДвоичныеДанные,
			ДанныеВложения.ИмяФайла,
			РасширениеФайла(ДанныеВложения.ИмяФайла));
		
		Результат.Успех = Истина;
		Результат.Ведомость = РезультатОбработки.Ведомость;
		Результат.ЛогOCR = РезультатОбработки.ЛогOCR;
		Результат.ПредупреждениеOCR = РезультатОбработки.ПредупреждениеOCR;
		
	Исключение
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
		Комментарий = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("Обработка писем заправочных ведомостей", УровеньЖурналаРегистрации.Ошибка,
			, Письмо, Комментарий);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Проверяет доступность утилиты распознавания QR (макет КомпонентаQR).
//
// Возвращаемое значение:
//  Структура - Доступна (Булево), ТекстОшибки (Строка).
//
Функция ПроверитьКомпонентуРаспознаванияQR() Экспорт
	
	Результат = Новый Структура("Доступна, ТекстОшибки", Ложь, "");
	
	Попытка
		ПолучитьПутьКУтилитеQR();
		Результат.Доступна = Истина;
	Исключение
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Проверяет доступность утилиты распознавания OCR (макет КомпонентаOCR).
//
// Возвращаемое значение:
//  Структура - Доступна (Булево), ТекстОшибки (Строка).
//
Функция ПроверитьКомпонентуРаспознаванияOCR() Экспорт
	
	Результат = Новый Структура("Доступна, ТекстОшибки", Ложь, "");
	
	Попытка
		ПолучитьПутьКУтилитеOCR();
		Результат.Доступна = Истина;
	Исключение
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НайтиВедомостьПоПисьму(Письмо)
	
	Возврат GDS_РаспознаваниеВходящихПисем.ДокументПоПисьму(Письмо);
	
КонецФункции

Функция НайтиQRВоВложениях(Письмо)
	
	Вложения = УправлениеЭлектроннойПочтой.ПолучитьВложенияЭлектронногоПисьма(Письмо, Ложь);
	
	Для Каждого СтрокаВложения Из Вложения Цикл
		
		Расширение = НРег(РасширениеФайла(СтрокаВложения.ИмяФайла));
		Если Не ДопустимоеРасширениеВложения(Расширение) Тогда
			Продолжить;
		КонецЕсли;
		
		ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(СтрокаВложения.Ссылка);
		QRСтрока = РаспознатьQRИзДвоичныхДанных(ДвоичныеДанные, Расширение);
		
		Если ЗначениеЗаполнено(QRСтрока) Тогда
			Возврат Новый Структура("QRСтрока, ДвоичныеДанные, ИмяФайла", QRСтрока, ДвоичныеДанные, СтрокаВложения.ИмяФайла);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция РаспознатьQRИзДвоичныхДанных(ДвоичныеДанные, Расширение)
	
	РасширениеКартинки = Расширение;
	Если Расширение = "pdf" Тогда
		ДвоичныеДанные = ПреобразоватьPDFВPNG(ДвоичныеДанные);
		РасширениеКартинки = "png";
	КонецЕсли;
	
	Возврат ВызватьРаспознаваниеQR(ДвоичныеДанные, РасширениеКартинки);
	
КонецФункции

Функция РазобратьДанныеQR(QRСтрока)
	
	Данные = ОбщегоНазначения.JSONВЗначение(QRСтрока, , Ложь);
	
	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		ВызватьИсключение НСтр("ru = 'QR-код не содержит JSON-структуру.'");
	КонецЕсли;
	
	Если Не Данные.Свойство("ВедомостьУИН") Или Не ЗначениеЗаполнено(Данные.ВедомостьУИН) Тогда
		ВызватьИсключение НСтр("ru = 'В QR-коде отсутствует УИН ведомости.'");
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ВедомостьУИН", Данные.ВедомостьУИН);
	
	Возврат Результат;
	
КонецФункции

Функция ВедомостьПоДаннымQR(ДанныеQR, Письмо, ДвоичныеДанныеВложения, ИмяФайла, РасширениеВложения)
	
	Результат = Новый Структура("Ведомость, ЛогOCR, ПредупреждениеOCR", Неопределено, "", Ложь);
	РеквизитыПисьма = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Письмо, "ДатаПолучения");
	
	УИН = Новый УникальныйИдентификатор(ДанныеQR.ВедомостьУИН);
	Документ = Документы.GDS_ЗаправочнаяВедомость.ПолучитьСсылку(УИН);
	
	Если Не ОбщегоНазначения.СсылкаСуществует(Документ) Тогда
		Текст = СтрШаблон(НСтр("ru = 'Нет документа по УИН ведомости %1.
			|Письмо %2'"), ДанныеQR.ВедомостьУИН, ПолучитьНавигационнуюСсылку(Письмо));
		ВызватьИсключение Текст;
	КонецЕсли;
	
	ДокументОбъект = Документ.ПолучитьОбъект();
	
	ДокументОбъект.Дата = РеквизитыПисьма.ДатаПолучения;
	ДокументОбъект.Основание = Письмо;
	ДокументОбъект.ОбменДанными.Загрузка = Истина;
	
	ЛогOCR = "";
	Попытка
		ДанныеOCR = РаспознатьOCRИзДвоичныхДанных(
			ДвоичныеДанныеВложения,
			РасширениеВложения,
			ДокументОбъект.ТипВедомости);
		Если ДанныеOCR <> Неопределено Тогда
			ЗаполнитьДокументПоOCR(ДокументОбъект, ДанныеOCR, РеквизитыПисьма.ДатаПолучения);
			ЛогOCR = СформироватьКомментарийOCR(ДанныеOCR);
			Результат.ПредупреждениеOCR = ЕстьПредупрежденияOCR(ДанныеOCR);
		КонецЕсли;
	Исключение
		ЛогOCR = НСтр("ru = 'OCR: '") + ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Результат.ПредупреждениеOCR = Истина;
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ЛогOCR) Тогда
		ДополнитьКомментарийДокумента(ДокументОбъект, ЛогOCR);
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		ДокументОбъект.Записать();
		
		GDS_РаспознаваниеВходящихПисем.ЗаписатьСоответсвие(ДокументОбъект.Ссылка, Письмо);
		
		ПрикрепитьФайлКВедомости(ДокументОбъект.Ссылка, ДвоичныеДанныеВложения, ИмяФайла);
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	Результат.Ведомость = ДокументОбъект.Ссылка;
	Результат.ЛогOCR = ЛогOCR;
	Возврат Результат;
	
КонецФункции

Функция ТипВедомостиПоСтроке(СтрокаТипа)
	
	Для Каждого ЗначениеПеречисления Из Метаданные.Перечисления.GDS_ТипыЗаправочныхВедомостей.ЗначенияПеречисления Цикл
		
		СсылкаНаЗначение = Перечисления.GDS_ТипыЗаправочныхВедомостей[ЗначениеПеречисления.Имя];
		Если Строка(СсылкаНаЗначение) = СтрокаТипа Тогда
			Возврат СсылкаНаЗначение;
		КонецЕсли;
		
	КонецЦикла;
	
	ВызватьИсключение СтрШаблон(
		НСтр("ru = 'Неизвестный тип ведомости в QR: %1'"),
		СтрокаТипа);
	
КонецФункции

Процедура ПрикрепитьФайлКВедомости(Ведомость, ДвоичныеДанные, ИмяФайла)
	
	СоставИмени = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ИмяФайла);
	
	ПрисоединенныеФайлы = Новый Массив;
	РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(Ведомость, ПрисоединенныеФайлы);
	Для Каждого Файл Из ПрисоединенныеФайлы Цикл
		ИмяПрисоединенного = СтрШаблон("%1.%2", Файл.Наименование, Файл.Расширение);
		Если ИмяПрисоединенного = ИмяФайла Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
	ПараметрыФайла.ВладелецФайлов = Ведомость;
	ПараметрыФайла.ИмяБезРасширения = СоставИмени.ИмяБезРасширения;
	ПараметрыФайла.РасширениеБезТочки = СтрЗаменить(СоставИмени.Расширение, ".", "");
	ПараметрыФайла.ВремяИзмененияУниверсальное = ТекущаяУниверсальнаяДата();
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	НоваяСсылкаНаФайл = РаботаСФайлами.НоваяСсылкаНаФайл(Ведомость);
	РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВХранилище, , , НоваяСсылкаНаФайл);
	
КонецПроцедуры

Функция ПолучитьПутьКУтилитеQR()
	
	Если ЗначениеЗаполнено(ПутьКУтилитеQR) Тогда
		ФайлКомпоненты = Новый Файл(ПутьКУтилитеQR);
		Если ФайлКомпоненты.Существует() Тогда
			Возврат ПутьКУтилитеQR;
		КонецЕсли;
	КонецЕсли;
	
	
	ДвоичныеДанныеУтилиты = ПолучитьМакет("КомпонентаQR");
	Если ДвоичныеДанныеУтилиты = Неопределено Или ДвоичныеДанныеУтилиты.Размер() = 0 Тогда
		ВызватьИсключение НСтр(
			"ru = 'Макет ""КомпонентаQR"" пуст. Поместите утилиту QRCodeRecognizer (ZXing/gozxing) в макет обработки.'");
	КонецЕсли;
	
	ПутьКУтилитеQR = ПолучитьИмяВременногоФайла("exe");
	ДвоичныеДанныеУтилиты.Записать(ПутьКУтилитеQR);
	
	Возврат ПутьКУтилитеQR;
	
КонецФункции

Функция ВызватьРаспознаваниеQR(ДвоичныеДанные, РасширениеКартинки)
	
	ИмяКартинки = "";
	QRСтрока = "";
	
	Попытка
		
		ИмяКартинки = ПолучитьИмяВременногоФайла(РасширениеКартинки);
		ДвоичныеДанные.Записать(ИмяКартинки);
		
		КомандаЗапуска = Новый Массив;
		КомандаЗапуска.Добавить(ПолучитьПутьКУтилитеQR());
		КомандаЗапуска.Добавить(ИмяКартинки);
		
		ПараметрыЗапуска = ФайловаяСистема.ПараметрыЗапускаПрограммы();
		ПараметрыЗапуска.ДождатьсяЗавершения = Истина;
		ПараметрыЗапуска.ПолучитьПотокВывода = Истина;
		// QRCodeRecognizer (gozxing) пишет stdout в UTF-8; на Windows по умолчанию — CP866.
		ПараметрыЗапуска.КодировкаПотоков = КодировкаТекста.UTF8;
		ПараметрыЗапуска.КодировкаИсполнения = "UTF8";
		
		РезультатЗапуска = ФайловаяСистема.ЗапуститьПрограмму(КомандаЗапуска, ПараметрыЗапуска);
		
		Если РезультатЗапуска.КодВозврата = 0 Тогда
			QRСтрока = СокрП(РезультатЗапуска.ПотокВывода);
		КонецЕсли;
		
	Исключение
		
		Если ИмяКартинки <> "" Тогда
			УдалитьФайлы(ИмяКартинки);
		КонецЕсли;
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Если ИмяКартинки <> "" Тогда
		УдалитьФайлы(ИмяКартинки);
	КонецЕсли;
	
	Возврат QRСтрока;
	
КонецФункции

Функция ПреобразоватьPDFВPNG(ДвоичныеДанныеPDF)
	
	ИмяPDF = "";
	ИмяPNG = "";
	
	Попытка
		
		ИмяPDF = ПолучитьИмяВременногоФайла("pdf");
		ИмяPNG = ПолучитьИмяВременногоФайла("png");
		ДвоичныеДанныеPDF.Записать(ИмяPDF);
		
		ПутьКImageMagick = ПутьКImageMagick();
		Команда = СтрШаблон("""%1"" -density 200 ""%2[0]"" ""%3""", ПутьКImageMagick, ИмяPDF, ИмяPNG);
		
		КодВозврата = Неопределено;
		ЗапуститьПриложение(Команда, , Истина, КодВозврата);
		
		Если КодВозврата <> 0 Тогда
			Файл = Новый Файл(ИмяPNG);
			Если Не Файл.Существует() Тогда
				ВызватьИсключение НСтр(
					"ru = 'Не удалось преобразовать PDF в изображение. Установите ImageMagick на сервере 1С.'");
			КонецЕсли;
		КонецЕсли;
		
		ДвоичныеДанныеPNG = Новый ДвоичныеДанные(ИмяPNG);
		
		УдалитьФайлы(ИмяPDF);
		УдалитьФайлы(ИмяPNG);
		
		Возврат ДвоичныеДанныеPNG;
		
	Исключение
		
		Если ИмяPDF <> "" Тогда
			УдалитьФайлы(ИмяPDF);
		КонецЕсли;
		
		Если ИмяPNG <> "" Тогда
			УдалитьФайлы(ИмяPNG);
		КонецЕсли;
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецФункции

Функция ПутьКImageMagick()
	
	НастройкиСканирования = РаботаСФайлами.ПолучитьНастройкиСканированияПользователя("");
	ПутьКПрограмме = НастройкиСканирования.ПутьКПрограммеКонвертации;
	
	Если ЗначениеЗаполнено(ПутьКПрограмме) Тогда
		Возврат ПутьКПрограмме;
	КонецЕсли;
	
	Возврат "magick";
	
КонецФункции

Функция ДопустимоеРасширениеВложения(Расширение)
	
	Возврат Расширение = "jpg"
		Или Расширение = "jpeg"
		Или Расширение = "png"
		Или Расширение = "pdf";
	
КонецФункции

Функция РасширениеФайла(ИмяФайла)
	
	ПозицияТочки = СтрНайти(ИмяФайла, ".", НаправлениеПоиска.СКонца);
	Если ПозицияТочки = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Сред(ИмяФайла, ПозицияТочки + 1);
	
КонецФункции

Функция ПолучитьПутьКУтилитеOCR()
	
	Если ЗначениеЗаполнено(ПутьКУтилитеOCR) Тогда
		ФайлКомпоненты = Новый Файл(ПутьКУтилитеOCR);
		Если ФайлКомпоненты.Существует() Тогда
			Возврат ПутьКУтилитеOCR;
		КонецЕсли;
	КонецЕсли;
	
	ДвоичныеДанныеУтилиты = ПолучитьМакет("КомпонентаOCR");
	Если ДвоичныеДанныеУтилиты = Неопределено Или ДвоичныеДанныеУтилиты.Размер() = 0 Тогда
		ВызватьИсключение НСтр(
			"ru = 'Макет ""КомпонентаOCR"" пуст. Поместите утилиту FuelStatementOCR.exe в макет обработки.'");
	КонецЕсли;
	
	ПутьКУтилитеOCR = ПолучитьИмяВременногоФайла("exe");
	ДвоичныеДанныеУтилиты.Записать(ПутьКУтилитеOCR);
	
	Возврат ПутьКУтилитеOCR;
	
КонецФункции

Функция ИмяТипаДляOCR(ТипВедомости)
	
	Если ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Заправочная Тогда
		Возврат "zapravka";
	ИначеЕсли ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Приходная Тогда
		Возврат "prihodnaya";
	ИначеЕсли ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Переливная Тогда
		Возврат "perelivnaya";
	КонецЕсли;
	
	ВызватьИсключение СтрШаблон(
		НСтр("ru = 'Тип ведомости %1 не поддерживается OCR.'"),
		ТипВедомости);
	
КонецФункции

Функция РаспознатьOCRИзДвоичныхДанных(ДвоичныеДанные, Расширение, ТипВедомости)
	
	РасширениеКартинки = НРег(Расширение);
	ДвоичныеДанныеКартинки = ДвоичныеДанные;
	Если РасширениеКартинки = "pdf" Тогда
		ДвоичныеДанныеКартинки = ПреобразоватьPDFВPNG(ДвоичныеДанные);
		РасширениеКартинки = "png";
	КонецЕсли;
	
	Возврат ВызватьРаспознаваниеOCR(ДвоичныеДанныеКартинки, РасширениеКартинки, ИмяТипаДляOCR(ТипВедомости));
	
КонецФункции

Функция ВызватьРаспознаваниеOCR(ДвоичныеДанные, РасширениеКартинки, ИмяТипа)
	
	ИмяКартинки = "";
	JSONСтрока = "";
	
	Попытка
		
		ИмяКартинки = ПолучитьИмяВременногоФайла(РасширениеКартинки);
		ДвоичныеДанные.Записать(ИмяКартинки);
		
		КомандаЗапуска = Новый Массив;
		КомандаЗапуска.Добавить(ПолучитьПутьКУтилитеOCR());
		КомандаЗапуска.Добавить(СтрШаблон("--type=%1", ИмяТипа));
		КомандаЗапуска.Добавить(ИмяКартинки);
		
		ПараметрыЗапуска = ФайловаяСистема.ПараметрыЗапускаПрограммы();
		ПараметрыЗапуска.ДождатьсяЗавершения = Истина;
		ПараметрыЗапуска.ПолучитьПотокВывода = Истина;
		ПараметрыЗапуска.КодировкаПотоков = КодировкаТекста.UTF8;
		ПараметрыЗапуска.КодировкаИсполнения = "UTF8";
		
		РезультатЗапуска = ФайловаяСистема.ЗапуститьПрограмму(КомандаЗапуска, ПараметрыЗапуска);
		
		Если РезультатЗапуска.КодВозврата = 0 Тогда
			JSONСтрока = СокрП(РезультатЗапуска.ПотокВывода);
		Иначе
			Возврат Неопределено;
		КонецЕсли;
		
	Исключение
		
		Если ИмяКартинки <> "" Тогда
			УдалитьФайлы(ИмяКартинки);
		КонецЕсли;
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Если ИмяКартинки <> "" Тогда
		УдалитьФайлы(ИмяКартинки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(JSONСтрока) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.JSONВЗначение(JSONСтрока, , Ложь);
	
КонецФункции

Процедура ЗаполнитьДокументПоOCR(ДокументОбъект, ДанныеOCR, ДатаПисьма)
	
	ЗаполнитьДатуДокументаПоOCR(ДокументОбъект, ДанныеOCR, ДатаПисьма);
	ЗаполнитьИтогПоOCR(ДокументОбъект, ДанныеOCR);
	ЗаполнитьСтрокиЗаправокПоOCR(ДокументОбъект, ДанныеOCR);
	
КонецПроцедуры

Процедура ЗаполнитьДатуДокументаПоOCR(ДокументОбъект, ДанныеOCR, ДатаПисьма)
	
	Если ТипЗнч(ДанныеOCR) <> Тип("Структура") Или Не ДанныеOCR.Свойство("header") Тогда
		Возврат;
	КонецЕсли;
	
	Шапка = ДанныеOCR.header;
	Если ТипЗнч(Шапка) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	День = ЗначениеПоляOCR(Шапка, "date_day");
	Месяц = ЗначениеПоляOCR(Шапка, "date_month");
	Если День = 0 Или Месяц = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Год = Год(ДокументОбъект.Дата);
	Если Год < 2000 Тогда
		Год = Год(ДатаПисьма);
	КонецЕсли;
	
	Попытка
		ДокументОбъект.Дата = Дата(Год, Месяц, День);
	Исключение
		// Некорректная дата на бланке — оставляем дату письма.
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьИтогПоOCR(ДокументОбъект, ДанныеOCR)
	
	Если ТипЗнч(ДанныеOCR) <> Тип("Структура") Или Не ДанныеOCR.Свойство("footer") Тогда
		Возврат;
	КонецЕсли;
	
	Подвал = ДанныеOCR.footer;
	Если ТипЗнч(Подвал) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Итого = ЗначениеПоляOCR(Подвал, "total_liters");
	Если Итого > 0 Тогда
		ДокументОбъект.КоличествоВсего = Итого;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСтрокиЗаправокПоOCR(ДокументОбъект, ДанныеOCR)
	
	Если ТипЗнч(ДанныеOCR) <> Тип("Структура") Или Не ДанныеOCR.Свойство("rows") Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиOCR = ДанныеOCR.rows;
	Если ТипЗнч(СтрокиOCR) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	СуммаЛитров = 0;
	
	Для Каждого СтрокаOCR Из СтрокиOCR Цикл
		
		Если ТипЗнч(СтрокаOCR) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		НомерСтрокиБланка = 0;
		Если СтрокаOCR.Свойство("rowIndex") Тогда
			НомерСтрокиБланка = СтрокаOCR.rowIndex;
		КонецЕсли;
		
		СтрокаТЧ = НайтиИлиДобавитьСтрокуЗаправки(ДокументОбъект, НомерСтрокиБланка);
		ПоляСтроки = Неопределено;
		Если СтрокаOCR.Свойство("fields") Тогда
			ПоляСтроки = СтрокаOCR.fields;
		КонецЕсли;
		
		Если ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		КоличествоЛитров = ЗначениеПоляOCR(ПоляСтроки, "quantity_liters");
		Если КоличествоЛитров > 0 И ПолеOCRДопустимоКЗаписи(ПоляСтроки, "quantity_liters") Тогда
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Количество) Или СтрокаТЧ.Количество = 0 Тогда
				СтрокаТЧ.Количество = КоличествоЛитров;
			КонецЕсли;
			СуммаЛитров = СуммаЛитров + КоличествоЛитров;
		КонецЕсли;
		
		Плотность = ЗначениеПоляOCR(ПоляСтроки, "density");
		Если Плотность > 0 И ПолеOCRДопустимоКЗаписи(ПоляСтроки, "density") Тогда
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Плотность) Или СтрокаТЧ.Плотность = 0 Тогда
				СтрокаТЧ.Плотность = Плотность;
			КонецЕсли;
		КонецЕсли;
		
		НомерПЛ = СтрокаПоляOCR(ПоляСтроки, "waybill_number");
		Если ЗначениеЗаполнено(НомерПЛ) И ПолеOCRДопустимоКЗаписи(ПоляСтроки, "waybill_number") Тогда
			Если Не ЗначениеЗаполнено(СтрокаТЧ.НомерПЛ) Тогда
				СтрокаТЧ.НомерПЛ = НомерПЛ;
			КонецЕсли;
		КонецЕсли;
		
		ГаражныйНомер = СтрокаПоляOCR(ПоляСтроки, "garage_number");
		Если ЗначениеЗаполнено(ГаражныйНомер) И ПолеOCRДопустимоКЗаписи(ПоляСтроки, "garage_number") Тогда
			ТС = НайтиТСПоГаражномуНомеру(ГаражныйНомер);
			Если ЗначениеЗаполнено(ТС) И Не ЗначениеЗаполнено(СтрокаТЧ.ТС) Тогда
				СтрокаТЧ.ТС = ТС;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если (Не ЗначениеЗаполнено(ДокументОбъект.КоличествоВсего) Или ДокументОбъект.КоличествоВсего = 0)
		И СуммаЛитров > 0 Тогда
		ДокументОбъект.КоличествоВсего = СуммаЛитров;
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиИлиДобавитьСтрокуЗаправки(ДокументОбъект, НомерСтрокиБланка)
	
	Если НомерСтрокиБланка > 0 И НомерСтрокиБланка <= ДокументОбъект.Заправки.Количество() Тогда
		Возврат ДокументОбъект.Заправки[НомерСтрокиБланка - 1];
	КонецЕсли;
	
	Возврат ДокументОбъект.Заправки.Добавить();
	
КонецФункции

Функция НайтиТСПоГаражномуНомеру(ГаражныйНомер)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	уатТС.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатТС КАК уатТС
	|ГДЕ
	|	уатТС.ГаражныйНомер = &ГаражныйНомер
	|	И НЕ уатТС.ПометкаУдаления";
	Запрос.УстановитьПараметр("ГаражныйНомер", ГаражныйНомер);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Справочники.уатТС.ПустаяСсылка();
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
	
КонецФункции

Функция ЗначениеПоляOCR(КоллекцияПолей, ИмяПоля)
	
	Поле = ПолеOCR(КоллекцияПолей, ИмяПоля);
	Если Поле = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если Поле.Свойство("value") И Поле.value <> Неопределено Тогда
		Возврат Поле.value;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция СтрокаПоляOCR(КоллекцияПолей, ИмяПоля)
	
	Поле = ПолеOCR(КоллекцияПолей, ИмяПоля);
	Если Поле = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если Поле.Свойство("valueString") И ЗначениеЗаполнено(Поле.valueString) Тогда
		Возврат Поле.valueString;
	КонецЕсли;
	
	Если Поле.Свойство("value") И Поле.value <> Неопределено Тогда
		Возврат Формат(Поле.value, "ЧГ=0");
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ПолеOCR(КоллекцияПолей, ИмяПоля)
	
	Если ТипЗнч(КоллекцияПолей) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если КоллекцияПолей.Свойство(ИмяПоля) Тогда
		Возврат КоллекцияПолей[ИмяПоля];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПолеOCRДопустимоКЗаписи(КоллекцияПолей, ИмяПоля)
	
	Поле = ПолеOCR(КоллекцияПолей, ИмяПоля);
	Если Поле = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не Поле.Свойство("status") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Поле.status = "ok" Или Поле.status = "partial";
	
КонецФункции

Функция ЕстьПредупрежденияOCR(ДанныеOCR)
	
	Если ТипЗнч(ДанныеOCR) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ДанныеOCR.Свойство("warnings") И ТипЗнч(ДанныеOCR.warnings) = Тип("Массив")
		И ДанныеOCR.warnings.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДанныеOCR.Свойство("anchorsFound") И ДанныеOCR.anchorsFound = Ложь Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция СформироватьКомментарийOCR(ДанныеOCR)
	
	Если ТипЗнч(ДанныеOCR) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Части = Новый Массив;
	Части.Добавить(СтрШаблон(
		НСтр("ru = 'OCR %1: тип %2'"),
		Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy"),
		?(ДанныеOCR.Свойство("templateType"), ДанныеOCR.templateType, "")));
	
	Если ДанныеOCR.Свойство("warnings") И ТипЗнч(ДанныеOCR.warnings) = Тип("Массив") Тогда
		Для Каждого Предупреждение Из ДанныеOCR.warnings Цикл
			Если ТипЗнч(Предупреждение) = Тип("Структура") И Предупреждение.Свойство("message") Тогда
				Части.Добавить(Предупреждение.message);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтрСоединить(Части, "; ");
	
КонецФункции

Процедура ДополнитьКомментарийДокумента(ДокументОбъект, ТекстOCR)
	
	Если Не ЗначениеЗаполнено(ТекстOCR) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументОбъект.Комментарий) Тогда
		ДокументОбъект.Комментарий = ДокументОбъект.Комментарий + Символы.ПС + ТекстOCR;
	Иначе
		ДокументОбъект.Комментарий = ТекстOCR;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

