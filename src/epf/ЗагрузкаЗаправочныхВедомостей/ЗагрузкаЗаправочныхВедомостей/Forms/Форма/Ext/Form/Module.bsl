#Область ОписаниеПеременных

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбновитьПредупреждениеОКомпоненте();
	ОбновитьПредупреждениеОКомпонентеOCR();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПисьма

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРезультат

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	
	ЗаполнитьНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура Обработать(Команда)
	
	ОбработатьНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	
	Для Каждого СтрокаПисьма Из Письма Цикл
		СтрокаПисьма.Обработать = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьФлажки(Команда)
	
	Для Каждого СтрокаПисьма Из Письма Цикл
		СтрокаПисьма.Обработать = Ложь;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	Письма.Очистить();
	
	ТаблицаПисем = РеквизитФормыВЗначение("Объект").ПолучитьСписокПисем();
	
	Для Каждого СтрокаПисьма Из ТаблицаПисем Цикл
		
		НоваяСтрока = Письма.Добавить();
		НоваяСтрока.Обработать = Истина;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПисьма);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьНаСервере()
	
	Результат.Очистить();
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	
	Для Каждого СтрокаПисьма Из Письма Цикл
		
		Если Не СтрокаПисьма.Обработать Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаПисьма.Статус = НСтр("ru = 'Обработка...'");
		
		РезультатОбработки = ОбъектОбработки.ОбработатьПисьмо(СтрокаПисьма.Письмо);
		
		СтрокаРезультата = Результат.Добавить();
		СтрокаРезультата.Письмо = СтрокаПисьма.Письмо;
		СтрокаРезультата.Успех = РезультатОбработки.Успех;
		СтрокаРезультата.Вложение = РезультатОбработки.Вложение;
		СтрокаРезультата.Ведомость = РезультатОбработки.Ведомость;
		СтрокаРезультата.ТекстОшибки = РезультатОбработки.ТекстОшибки;
		СтрокаРезультата.ЛогOCR = РезультатОбработки.ЛогOCR;
		
		Если РезультатОбработки.Успех Тогда
			Если РезультатОбработки.ПредупреждениеOCR Тогда
				СтрокаПисьма.Статус = НСтр("ru = 'Обработано с предупреждениями OCR'");
			Иначе
				СтрокаПисьма.Статус = НСтр("ru = 'Создана ведомость'");
			КонецЕсли;
		Иначе
			СтрокаПисьма.Статус = НСтр("ru = 'Ошибка'");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредупреждениеОКомпоненте()
	
	Проверка = РеквизитФормыВЗначение("Объект").ПроверитьКомпонентуРаспознаванияQR();
	
	Если Проверка.Доступна Тогда
		Элементы.ПредупреждениеКомпонента.Видимость = Ложь;
	Иначе
		Элементы.ПредупреждениеКомпонента.Видимость = Истина;
		Элементы.ПредупреждениеКомпонента.Заголовок = СтрШаблон(
			НСтр("ru = 'Компонента распознавания QR недоступна: %1'"),
			Проверка.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредупреждениеОКомпонентеOCR()
	
	Проверка = РеквизитФормыВЗначение("Объект").ПроверитьКомпонентуРаспознаванияOCR();
	
	Если Проверка.Доступна Тогда
		Элементы.ПредупреждениеКомпонентаOCR.Видимость = Ложь;
	Иначе
		Элементы.ПредупреждениеКомпонентаOCR.Видимость = Истина;
		Элементы.ПредупреждениеКомпонентаOCR.Заголовок = СтрШаблон(
			НСтр("ru = 'Компонента распознавания OCR недоступна: %1'"),
			Проверка.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
