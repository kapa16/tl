#Область ПромптыVLMРаспознаванияВедомостей

// Возвращает пару промптов (системный и пользовательский) для вызова VLM.
//
// Параметры:
//  ИмяТипа - Строка - zapravka | prihodnaya | perelivnaya
//
// Возвращаемое значение:
//  Структура - Системный (Строка), Пользовательский (Строка)
//
Функция ПромптVLMРаспознаванияВедомости(ИмяТипа) Экспорт
	
	Возврат СоздатьПромптVLM(ИмяТипа, "полный");
	
КонецФункции

// Создаёт структуру промпта VLM с метаданными для постобработки.
// При БезПостобработки (кроме проверки ориентации) — полный промпт со схемой JSON.
//
Функция СоздатьПромптVLM(ИмяТипа, Область)
	
	ОбластьНр = НРег(СокрЛП(Область));
	ИспользоватьПолныйПромпт = ОбластьНр <> "проверка_ориентации" И БезПостобработкиИзНастроек();
	
	Результат = Новый Структура;
	
	Если ИспользоватьПолныйПромпт Тогда
		Результат.Вставить("Системный", ПолныйПромптVLMСистемный(ИмяТипа, Область));
		Результат.Вставить("Пользовательский", ПолныйПромптVLMПользовательский(ИмяТипа, Область));
	Иначе
		Результат.Вставить("Системный", МинимальныйПромптVLMСистемный());
		Результат.Вставить("Пользовательский", МинимальныйПромптVLMПользовательский(ИмяТипа, Область));
	КонецЕсли;
	
	Результат.Вставить("ИмяТипа", НРег(СокрЛП(ИмяТипа)));
	Результат.Вставить("Область", ОбластьНр);
	
	Возврат Результат;
	
КонецФункции

Функция ПолныйПромптVLMСистемный(ИмяТипа, Область)
	
	Возврат БазовыйПромптСхемыСистемный()
		+ ПромптСхемыПоТипу(ИмяТипа)
		+ ПромптСхемыПоОбласти(Область, ИмяТипа);
	
КонецФункции

Функция ПолныйПромптVLMПользовательский(ИмяТипа, Область)
	
	ИмяТипа = НРег(СокрЛП(ИмяТипа));
	Область = НРег(СокрЛП(Область));
	СуффиксJSON = "
	|Верни ТОЛЬКО валидный JSON UTF-8 по схеме из системного промпта, без markdown и комментариев.";
	
	Если Область = "шапка_подвал" Тогда
		Возврат СтрШаблон(
			"Распознай на приложенном изображении ТОЛЬКО шапку (верх) и подвал (низ) бланка ведомости типа %1.
			|Таблицу в центре не читай. rows должен быть пустым массивом [].
			|%2",
			ИмяТипа,
			СуффиксJSON);
	ИначеЕсли Область = "таблица" Тогда
		Возврат СтрШаблон(
			"Распознай на приложенном изображении ТОЛЬКО таблицу (строки 1..16) бланка ведомости типа %1.
			|Шапку и подвал игнорируй. header = {}, footer = {}.
			|Обойди каждую строку и каждую колонку отдельно. Одна физическая строка — отдельный элемент rows.
			|%2",
			ИмяТипа,
			СуффиксJSON);
	ИначеЕсли Область = "таблица_анти_схлопывание" Тогда
		Возврат ПолныйПромптVLMПользовательский(ИмяТипа, "таблица")
			+ "
			|ВАЖНО: не объединяй несколько физических строк в одну запись.
			|Если видишь 2 и более заполненных строк — верни минимум 2 отдельные записи в rows.";
	КонецЕсли;
	
	Возврат СтрШаблон(
		"Распознай на приложенном изображении весь бланк ведомости типа %1: шапку, таблицу (строки 1..16) и подвал.
		|%2",
		ИмяТипа,
		СуффиксJSON);
	
КонецФункции

Процедура ИзвлечьМетаданныеПромптаVLM(ПромптVLM, ИмяТипа, Область)
	
	ИмяТипа = "";
	Область = "полный";
	
	Если ТипЗнч(ПромптVLM) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ПромптVLM.Свойство("ИмяТипа", ИмяТипа);
	ПромптVLM.Свойство("Область", Область);
	
	Если Не ЗначениеЗаполнено(ИмяТипа) Тогда
		ИмяТипа = "zapravka";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Область) Тогда
		Область = "полный";
	КонецЕсли;
	
КонецПроцедуры

Функция МинимальныйПромптVLMСистемный()
	
	Возврат
	"Ты — OCR-ассистент для сканов бланков учёта ГСМ (заправочные, приходные, переливные ведомости).
	|
	|Задача: прочитай ВСЁ видимое на изображении точно как есть.
	|Правила:
	|1. Не интерпретируй и не нормализуй значения — переписывай символ в символ.
	|2. Различай печатный и рукописный текст; пустые клетки и прочерки отмечай как пустые.
	|3. Сохраняй структуру документа: шапка, таблица построчно, подвал.
	|4. Полосу «1234567890» (гребёнка) — не копируй в данные.
	|5. QR не декодируй.
	|6. Не выдумывай данные, которых нет на изображении.
	|7. Ответ — текст или простой JSON с увиденным содержимым; без markdown-обёртки.";
	
КонецФункции

Функция МинимальныйПромптVLMПользовательский(ИмяТипа, Область)
	
	ИмяТипа = НРег(СокрЛП(ИмяТипа));
	Область = НРег(СокрЛП(Область));
	
	Если Область = "проверка_ориентации" Тогда
		Возврат
		"Посмотри на изображение ведомости ГСМ.
		|Есть ли таблица с хотя бы одной заполненной рукописной строкой данных?
		|Верни только JSON: {""hasFilledRows"": true} или {""hasFilledRows"": false}.";
	ИначеЕсли Область = "шапка_подвал" Тогда
		Возврат СтрШаблон(
			"Прочитай ТОЛЬКО шапку (верх) и подвал (низ) бланка ведомости типа %1.
			|Таблицу в центре не читай.
			|Перепиши весь видимый текст как есть, без интерпретации.
			|Верни увиденное в свободной форме (текст или простой JSON).",
			ИмяТипа);
	ИначеЕсли Область = "таблица" Тогда
		Возврат СтрШаблон(
			"Прочитай ТОЛЬКО таблицу (строки 1..16) бланка ведомости типа %1.
			|Шапку и подвал игнорируй.
			|Обойди каждую строку и каждую колонку отдельно.
			|Одна физическая строка таблицы — отдельная запись.
			|Перепиши текст как есть, без интерпретации.
			|Верни увиденное в свободной форме (текст или простой JSON).",
			ИмяТипа);
	ИначеЕсли Область = "таблица_анти_схлопывание" Тогда
		Возврат МинимальныйПромптVLMПользовательский(ИмяТипа, "таблица")
			+ "
			|ВАЖНО: не объединяй несколько физических строк в одну запись.
			|Если видишь 2 и более заполненных строк — верни минимум 2 отдельные записи.";
	КонецЕсли;
	
	Возврат СтрШаблон(
		"Прочитай весь бланк ведомости типа %1: шапку, таблицу (строки 1..16) и подвал.
		|Перепиши весь видимый текст как есть, без интерпретации и нормализации.
		|Верни увиденное в свободной форме (текст или простой JSON).",
		ИмяТипа);
	
КонецФункции

Функция ПромптСхемыПоТипу(ИмяТипа)
	
	ИмяТипа = НРег(СокрЛП(ИмяТипа));
	
	Если ИмяТипа = "zapravka" Тогда
		Возврат ПромптСхемыЗаправочная();
	ИначеЕсли ИмяТипа = "prihodnaya" Тогда
		Возврат ПромптСхемыПриходная();
	ИначеЕсли ИмяТипа = "perelivnaya" Тогда
		Возврат ПромптСхемыПереливная();
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ПромптСхемыПоОбласти(Область, ИмяТипа)
	
	Область = НРег(СокрЛП(Область));
	ИмяТипа = НРег(СокрЛП(ИмяТипа));
	
	Если Область = "шапка_подвал" Тогда
		Возврат
		"Область распознавания: ТОЛЬКО header и footer.
		|rows должен быть пустым массивом [].
		|Верни JSON: version ""2"", templateType, header, footer, rows=[], warnings=[], errors=[].";
	ИначеЕсли Область = "таблица" Тогда
		Возврат СтрШаблон(
			"Область распознавания: ТОЛЬКО rows таблицы ведомости %1.
			|header = {}, footer = {}.
			|Обойди строки №1..№16. Формат строки: {rowIndex, isEmpty, fields}.
			|ЗАПРЕЩЁН плоский JSON-массив; только rows с вложенным fields.
			|Колонки заправочной: garage_number (цифры), vehicle_plate (госномер с буквами),
			|quantity_liters (литры), temperature (температура, не литры).
			|quantity_liters и quantity_kg — из разных колонок.",
			ИмяТипа);
	ИначеЕсли Область = "таблица_анти_схлопывание" Тогда
		Возврат ПромптСхемыПоОбласти("таблица", ИмяТипа)
			+ "
			|КРИТИЧЕСКОЕ ПРАВИЛО АНТИ-СХЛОПЫВАНИЯ:
			|- Запрещено объединять данные нескольких физических строк в одну строку JSON.
			|- Сначала определи горизонтальные полосы строк 1..16 по сетке таблицы.
			|- Заполняй fields только значениями, лежащими внутри полосы этой строки.
			|- Если визуально есть 2 и более заполненных строки, rows должно содержать минимум 2 элемента.";
	КонецЕсли;
	
	Возврат
	"Область распознавания: полный документ — header, rows, footer.
	|Верни JSON version ""2"" с templateType, header, rows, footer, warnings, errors.";
	
КонецФункции

// Имя типа для VLM по перечислению GDS_ТипыЗаправочныхВедомостей.
//
// Параметры:
//  ТипВедомости - ПеречислениеСсылка.GDS_ТипыЗаправочныхВедомостей
//
// Возвращаемое значение:
//  Строка - zapravka | prihodnaya | perelivnaya
//
Функция ИмяТипаВедомостиДляПромптаVLM(ТипВедомости) Экспорт
	
	Если ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Заправочная Тогда
		Возврат "zapravka";
	ИначеЕсли ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Приходная Тогда
		Возврат "prihodnaya";
	ИначеЕсли ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Переливная Тогда
		Возврат "perelivnaya";
	КонецЕсли;
	
	ВызватьИсключение СтрШаблон(
		НСтр("ru = 'Тип ведомости %1 не поддерживается VLM-промптом.'"),
		ТипВедомости);
	
КонецФункции

Функция БазовыйПромптСхемыСистемный()
	
	Возврат
	"Ты — OCR/VLM-ассистент для сканов бланков учёта ГСМ (заправочные, приходные, переливные ведомости).
	|
	|Общие правила:
	|1. Сначала мысленно выровняй изображение: заголовок читается горизонтально. Скан может быть повёрнут на 90°/180°/270°; QR — в углу бланка.
	|2. Определи поворот (0/90/180/270). При сомнении — warning ORIENTATION_UNCERTAIN.
	|3. Различай printed / handwritten / empty. Прочерк без рукописного текста = empty.
	|4. Не выдумывай данные: value = null, status = ""unreadable"", confidence < 0.4.
	|5. Полоса «1234567890» — эталон гребёнки; НЕ копируй в таблицу, шапку, итоги. referenceDigitsStripVisible = true если полоса видна.
	|6. Подписи: signature_present | signature_absent; текст подписи не угадывать.
	|7. QR не декодируй — только qrVisible.
	|8. Ответ — ТОЛЬКО валидный JSON UTF-8, без markdown.
	|9. ЗАПРЕЩЕНО копировать одно значение в несколько полей.
	|10. Пустая таблица — rows = []. Не создавай строки с выдуманными данными.
	|11. ФИО не может состоять только из цифр.
	|12. Светло-серые контуры гребёнки без рукописи — empty.
	|13. Номер ведомости — из «Ведомость № …», не из госномера АТЗ.
	|14. СТРОГО соблюдай схему: header — объект полей; rows — [{rowIndex, isEmpty, fields}]; footer — объект полей. НЕ упрощай в плоский JSON.
	|15. Каждое поле — {id, label, source, status, confidence, value, valueString?, cells?}.
	|16. Обойди строки таблицы №1..№16; для каждой строки читай каждую колонку отдельно.
	|17. value — только вписанный/напечатанный ТЕКСТ ЗНАЧЕНИЯ. НЕ возвращай название метки поля («Ф.И.О. водителя», «ПУ:») как value.
	|18. source поля — только ""printed"" | ""handwritten"" | ""mixed"" | ""comb"" | ""signature_present""; не подставляй распознанный текст в source.
	|19. Обязательные корневые ключи: version, templateType, imageWidth, imageHeight, orientationApplied, qrVisible, referenceDigitsStripVisible, header, rows, footer, warnings, errors.
	|20. Печатные реквизиты шапки (organization, statement_number, fuel_truck_plate, fuel_name, date_year) — если текст чётко виден, status = ""ok"", confidence >= 0.9. Не помечай их unreadable без причины.
	|
	|Статусы: ""ok"" | ""partial"" | ""empty"" | ""unreadable"" | ""printed_only""
	|confidence: 0..1
	|
	|Гребёнки: cells[], valueString, value (число или null).
	|Текст: value (строка или null).
	|
	|";
	
КонецФункции

Функция ПромптСхемыЗаправочная()
	
	Возврат
	"Тип документа: zapravka (Заправочная ведомость учёта ГСМ).
	|Маркер: «ЗАПРАВОЧНАЯ ведомость».
	|
	|Шапка (header):
	|organization — организация (printed, вверху формы)
	|statement_number — «Ведомость № …» (printed)
	|date_day, date_month, date_year — дата (handwritten; год может быть printed)
	|production_unit — ПУ (handwritten после метки «ПУ:»; прочерк = empty)
	|field_name — Месторождение (handwritten после «Месторождение:»; прочерк = empty)
	|cluster_number — Куст № (handwritten; прочерк = empty)
	|driver_name — Ф.И.О. водителя (handwritten; прочерк = empty; НЕ копируй метку «Ф.И.О. водителя»)
	|fuel_truck_plate — Гос.№ АТЗ (printed/handwritten)
	|fuel_name — Наименование ГСМ (printed, напр. «Дизельное топливо»; НЕ путать с field_name)
	|
	|Таблица (rows, 1..16). Включай строку ТОЛЬКО если хотя бы одно поле реально заполнено:
	|row_number, vehicle_make_model, vehicle_plate, garage_number, waybill_number, engine_hours,
	|density, temperature, quantity_liters, time, row_date, driver_signature, signature_decoded.
	|Формат строки: {""rowIndex"": 1, ""isEmpty"": false, ""fields"": {...}}.
	|
	|Порядок колонок заправочной ведомости (слева направо):
	|1 № | 2 Марка, модель | 3 Гос.№ (госномер ТС: буквы+цифры) | 4 Гаражный номер (только цифры)
	|5 Номер путевого листа | 6 Моточасы | 7 Плотность | 8 Температура | 9 кол-во Д/Т (литр)
	|10 Время | 11 Дата | 12 Подпись водителя | 13 Расшифровка подписи.
	|
	|Критично:
	| - garage_number — ТОЛЬКО колонка «Гаражный номер» (цифры: 4185, 7170).
	| - vehicle_plate — ТОЛЬКО колонка «Гос.№» (госномер с буквами).
	| - quantity_liters — ТОЛЬКО колонка «кол-во Д/Т (литр)»; ЗАПРЕЩЕНО писать литры в temperature.
	| - temperature — колонка «Температура»; обычно пусто или дробное значение.
	| - Не копируй cluster_number, fuel_truck_plate из шапки в строки.
	| - row_date только из колонки даты строки.
	| - Пустая таблица — rows = [].
	| - НЕ возвращай плоский массив объектов; только rows с полем fields.
	|
	|Подвал (footer): total_liters, total_kg, responsible_person_name, responsible_person_signature.
	|
	|JSON: version ""2"", templateType ""zapravka"", header, rows, footer, warnings, errors.
	|";
	
КонецФункции

Функция ПромптСхемыПриходная()
	
	Возврат
	"Тип документа: prihodnaya (Приходная ведомость учёта ГСМ).
	|Маркер: «ПРИХОДНАЯ ведомость».
	|
	|Шапка (header):
