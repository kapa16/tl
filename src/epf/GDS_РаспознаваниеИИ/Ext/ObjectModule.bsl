Функция ЕстьПредупрежденияVLM(ДанныеVLM)
	
	Если ТипЗнч(ДанныеVLM) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ДанныеVLM.Свойство("warnings") И ТипЗнч(ДанныеVLM.warnings) = Тип("Массив")
		И ДанныеVLM.warnings.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция СформироватьКомментарийVLM(ДанныеVLM)
	
	Если ТипЗнч(ДанныеVLM) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Части = Новый Массив;
	Части.Добавить(СтрШаблон(
		НСтр("ru = 'VLM %1: тип %2'"),
		Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy"),
		?(ДанныеVLM.Свойство("templateType"), ДанныеVLM.templateType, "")));
	
	Если ДанныеVLM.Свойство("warnings") И ТипЗнч(ДанныеVLM.warnings) = Тип("Массив") Тогда
		Для Каждого Предупреждение Из ДанныеVLM.warnings Цикл
			Если ТипЗнч(Предупреждение) = Тип("Структура") И Предупреждение.Свойство("message") Тогда
				ТекстПредупреждения = Предупреждение.message;
				Если Предупреждение.Свойство("code") И ЗначениеЗаполнено(Предупреждение.code) Тогда
					ТекстПредупреждения = СтрШаблон("[%1] %2", Предупреждение.code, ТекстПредупреждения);
				КонецЕсли;
				Части.Добавить(ТекстПредупреждения);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтрСоединить(Части, "; ");
	
КонецФункции

Процедура ДополнитьКомментарийДокумента(ДокументОбъект, ТекстКомментария)
	
	Если Не ЗначениеЗаполнено(ТекстКомментария) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументОбъект.Комментарий) Тогда
		ДокументОбъект.Комментарий = ДокументОбъект.Комментарий + Символы.ПС + ТекстКомментария;
	Иначе
		ДокументОбъект.Комментарий = ТекстКомментария;
	КонецЕсли;
	
КонецПроцедуры

