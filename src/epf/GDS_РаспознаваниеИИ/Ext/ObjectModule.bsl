	Имена.Добавить("date_month");
	Имена.Добавить("date_year");
	Имена.Добавить("production_unit");
	Имена.Добавить("field_name");
	Имена.Добавить("cluster_number");
	Имена.Добавить("driver_name");
	Имена.Добавить("fuel_truck_plate");
