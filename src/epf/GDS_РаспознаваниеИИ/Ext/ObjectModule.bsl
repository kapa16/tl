	Возврат
	"Ты преобразуешь сырой OCR/VLM результат в строгий JSON для 1С.
	|Правила преобразования:
	|1. Верни только JSON без markdown и комментариев.
	|2. Не выдумывай значения; если нет данных - оставляй пустые строки или null.
	|3. Сохраняй только данные, которые есть в исходном тексте ответа VLM.
	|4. Не меняй смысл чисел, дат и номеров.
	|5. Структура ответа должна быть пригодна для последующей локальной нормализации.
	|"
	+ БазовыйПромптСхемыСистемный()
	+ ПромптСхемыПоТипу(ИмяТипа)
	+ ПромптСхемыПоОбласти(Область, ИмяТипа);
	
КонецФункции

Функция ПромптПостобработкиПользовательский(СыройКонтентVLM, ПромптVLM)
	
	СистемныйПромптVLM = "";
	ПользовательскийПромптVLM = "";
	
	Если ТипЗнч(ПромптVLM) = Тип("Структура") Тогда
		Если ПромптVLM.Свойство("Системный", СистемныйПромптVLM) = Ложь Тогда
			СистемныйПромптVLM = "";
		КонецЕсли;
		Если ПромптVLM.Свойство("Пользовательский", ПользовательскийПромптVLM) = Ложь Тогда
			ПользовательскийПромптVLM = "";
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрШаблон(
		"Сырой ответ VLM (OCR, без нормализации):
		|%1
		|
		|Контекст: VLM читала изображение по минимальному промпту (только переписать увиденное).
		|Системный промпт VLM: %2
		|Пользовательский промпт VLM: %3
		|
		|Преобразуй сырой ответ в канонический JSON по схеме из системного промпта. Верни только JSON.",
		СыройКонтентVLM,
		СистемныйПромптVLM,
		ПользовательскийПромптVLM);
	
КонецФункции

Функция ИзвлечьДанныеИзОтветаVLM(ОтветAPI)
	
	Если ОтветAPI = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Choices = ПолучитьСвойствоJSON(ОтветAPI, "choices");
	Если Choices = Неопределено Или ТипЗнч(Choices) <> Тип("Массив") Или Choices.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Message = ПолучитьСвойствоJSON(Choices[0], "message");
	Content = ПолучитьСвойствоJSON(Message, "content");
	
	Если Content = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ЭтоОбъектJSON(Content) Тогда
		Возврат ПреобразоватьJSONВСтруктуру(Content);
	КонецЕсли;
	
	ТекстJSON = СокрЛП(Строка(Content));
	
	Если ПустаяСтрока(ТекстJSON) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат РазобратьJSONСтроку(ТекстJSON);
	
КонецФункции

Функция ИзвлечьТекстКонтентаИзОтветаИИ(ОтветAPI)
	
	Если ОтветAPI = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Choices = ПолучитьСвойствоJSON(ОтветAPI, "choices");
	Если Choices = Неопределено Или ТипЗнч(Choices) <> Тип("Массив") Или Choices.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Message = ПолучитьСвойствоJSON(Choices[0], "message");
	Content = ПолучитьСвойствоJSON(Message, "content");
	
	Если Content = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(Content) = Тип("Массив") Тогда
		Части = Новый Массив;
		Для Каждого БлокКонтента Из Content Цикл
			Если Не ЭтоОбъектJSON(БлокКонтента) Тогда
				Продолжить;
			КонецЕсли;
			ТипБлока = ПолучитьСвойствоJSON(БлокКонтента, "type");
			Если ТипБлока = "text" Тогда
				ТекстБлока = ПолучитьСвойствоJSON(БлокКонтента, "text");
				Если ЗначениеЗаполнено(ТекстБлока) Тогда
					Части.Добавить(Строка(ТекстБлока));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Возврат СокрЛП(СтрСоединить(Части, Символы.ПС));
	КонецЕсли;
	
	Возврат СокрЛП(Строка(Content));
	
КонецФункции

// Проверяет, что значение — объект JSON (Структура или Соответствие из GDS_HTTPКоннектор.КакJson).
//
Функция ЭтоОбъектJSON(ОбъектJSON)
	
	ТипОбъекта = ТипЗнч(ОбъектJSON);
	Возврат ТипОбъекта = Тип("Структура") Или ТипОбъекта = Тип("Соответствие");
	
КонецФункции

// Универсальное чтение свойства из Структуры или Соответствия (ответ GDS_HTTPКоннектор.КакJson).
//
Функция ПолучитьСвойствоJSON(ОбъектJSON, ИмяСвойства)
	
	Если ОбъектJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ОбъектJSON) = Тип("Структура") Тогда
		Значение = Неопределено;
		Если ОбъектJSON.Свойство(ИмяСвойства, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
		Возврат Неопределено;
	ИначеЕсли ТипЗнч(ОбъектJSON) = Тип("Соответствие") Тогда
		Возврат ОбъектJSON.Получить(ИмяСвойства);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПодготовитьТекстJSON(ТекстJSON)
	
	ТекстJSON = СокрЛП(ТекстJSON);
	ТекстJSON = УбратьBOMИзТекста(ТекстJSON);
	ТекстJSON = УбратьОбрамлениеMarkdownJSON(ТекстJSON);
	ТекстJSON = ИзвлечьТелоJSONИзТекста(ТекстJSON);
	ТекстJSON = УбратьЗавершающиеЗапятыеJSON(ТекстJSON);
	
	Возврат СокрЛП(ТекстJSON);
	
КонецФункции

Функция УбратьBOMИзТекста(Текст)
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Если Лев(Текст, 1) = Символ(65279) Тогда
		Возврат Сред(Текст, 2);
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Функция УбратьОбрамлениеMarkdownJSON(ТекстJSON)
	
	ТекстJSON = СокрЛП(ТекстJSON);
	
	Если СтрНачинаетсяС(ТекстJSON, "```") Тогда
		ПозицияПеревода = СтрНайти(ТекстJSON, Символы.ПС);
		Если ПозицияПеревода > 0 Тогда
			ТекстJSON = Сред(ТекстJSON, ПозицияПеревода + 1);
		Иначе
			ТекстJSON = СтрЗаменить(ТекстJSON, "```", "");
		КонецЕсли;
	КонецЕсли;
	
	ПозицияЗакрытия = СтрНайти(ТекстJSON, "```", НаправлениеПоиска.СКонца);
	Если ПозицияЗакрытия > 0 Тогда
		ТекстJSON = Лев(ТекстJSON, ПозицияЗакрытия - 1);
	КонецЕсли;
	
	Возврат СокрЛП(ТекстJSON);
	
КонецФункции

// Выделяет первый сбалансированный JSON-объект или массив из произвольного текста ответа ИИ.
//
Функция ИзвлечьТелоJSONИзТекста(Текст)
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	ПозицияОбъекта = СтрНайти(Текст, "{");
	ПозицияМассива = СтрНайти(Текст, "[");
	
	Если ПозицияОбъекта = 0 И ПозицияМассива = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	
	Если ПозицияОбъекта = 0 Тогда
		ПозицияНачала = ПозицияМассива;
		ОткрывающийСимвол = "[";
		ЗакрывающийСимвол = "]";
	ИначеЕсли ПозицияМассива = 0 Или ПозицияОбъекта <= ПозицияМассива Тогда
		ПозицияНачала = ПозицияОбъекта;
		ОткрывающийСимвол = "{";
		ЗакрывающийСимвол = "}";
	Иначе
		ПозицияНачала = ПозицияМассива;
		ОткрывающийСимвол = "[";
		ЗакрывающийСимвол = "]";
	КонецЕсли;
	
	Глубина = 0;
	ВСтроке = Ложь;
	Экранирование = Ложь;
	ДлинаТекста = СтрДлина(Текст);
	
	Для Позиция = ПозицияНачала По ДлинаТекста Цикл
		Символ = Сред(Текст, Позиция, 1);
		
		Если ВСтроке Тогда
			Если Экранирование Тогда
				Экранирование = Ложь;
			ИначеЕсли Символ = "\" Тогда
				Экранирование = Истина;
			ИначеЕсли Символ = """" Тогда
				ВСтроке = Ложь;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если Символ = """" Тогда
			ВСтроке = Истина;
			Продолжить;
		КонецЕсли;
		
		Если Символ = ОткрывающийСимвол Тогда
			Глубина = Глубина + 1;
		ИначеЕсли Символ = ЗакрывающийСимвол Тогда
			Глубина = Глубина - 1;
			Если Глубина = 0 Тогда
				Возврат Сред(Текст, ПозицияНачала, Позиция - ПозицияНачала + 1);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Сред(Текст, ПозицияНачала);
	
КонецФункции

Функция УбратьЗавершающиеЗапятыеJSON(ТекстJSON)
	
	Результат = ТекстJSON;
	
	Пока Истина Цикл
		Предыдущий = Результат;
		Результат = СтрЗаменить(Результат, ",}", "}");
		Результат = СтрЗаменить(Результат, ",]", "]");
		Результат = СтрЗаменить(Результат, ", }", " }");
		Результат = СтрЗаменить(Результат, ", ]", " ]");
		Если Результат = Предыдущий Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция РазобратьJSONСтроку(СтрокаJSON)
	
	Если Не ЗначениеЗаполнено(СтрокаJSON) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВариантыТекста = Новый Массив;
	ПодготовленныйТекст = ПодготовитьТекстJSON(СтрокаJSON);
	ВариантыТекста.Добавить(ПодготовленныйТекст);
	
	Если ПодготовленныйТекст <> СтрокаJSON Тогда
		ВариантыТекста.Добавить(СтрокаJSON);
	КонецЕсли;
	
	ИзвлеченныйТекст = ИзвлечьТелоJSONИзТекста(ПодготовленныйТекст);
	Если ЗначениеЗаполнено(ИзвлеченныйТекст) И ИзвлеченныйТекст <> ПодготовленныйТекст Тогда
		ВариантыТекста.Добавить(ИзвлеченныйТекст);
		ВариантыТекста.Добавить(УбратьЗавершающиеЗапятыеJSON(ИзвлеченныйТекст));
	КонецЕсли;
	
	Для Каждого ТекстJSON Из ВариантыТекста Цикл
		ОбъектJSON = ПопытатьсяПрочитатьJSONВСоответствие(ТекстJSON);
		Если ОбъектJSON <> Неопределено Тогда
			Возврат ПреобразоватьJSONВСтруктуру(ОбъектJSON);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПопытатьсяПрочитатьJSONВСоответствие(СтрокаJSON)
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
		Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
	Исключение
		ИсправленныйТекст = УбратьЗавершающиеЗапятыеJSON(СтрокаJSON);
		Если ИсправленныйТекст = СтрокаJSON Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ИсправленныйТекст);
			Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

// Рекурсивно преобразует JSON (Соответствие/Массив) в Структуру с допустимыми именами свойств.
//
Функция ПреобразоватьJSONВСтруктуру(ОбъектJSON)
	
	Если ОбъектJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипОбъекта = ТипЗнч(ОбъектJSON);
	
	Если ТипОбъекта = Тип("Структура") Или ТипОбъекта = Тип("Соответствие") Тогда
		Результат = Новый Структура;
		Для Каждого КлючЗначение Из ОбъектJSON Цикл
			ИмяКлюча = ИмяКлючаJSONДляСтруктуры(КлючЗначение.Ключ);
			Если Результат.Свойство(ИмяКлюча) Тогда
				Продолжить;
			КонецЕсли;
			Результат.Вставить(ИмяКлюча, ПреобразоватьJSONВСтруктуру(КлючЗначение.Значение));
		КонецЦикла;
		Возврат Результат;
	ИначеЕсли ТипОбъекта = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из ОбъектJSON Цикл
			Результат.Добавить(ПреобразоватьJSONВСтруктуру(Элемент));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	
	Возврат ОбъектJSON;
	
КонецФункции

// Приводит ответ VLM (Структура, Соответствие или корневой Массив строк) к канонической Структуре.
//
Функция ПривестиДанныеVLMКСтруктуре(Данные)
	
	Если Данные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипДанных = ТипЗнч(Данные);
	
	Если ТипДанных = Тип("Структура") Тогда
		Возврат Данные;
	ИначеЕсли ТипДанных = Тип("Соответствие") Тогда
		Возврат ПреобразоватьJSONВСтруктуру(Данные);
	ИначеЕсли ТипДанных = Тип("Массив") Тогда
		Результат = Новый Структура;
		Результат.Вставить("rows", ПреобразоватьJSONВСтруктуру(Данные));
		Возврат Результат;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Алиасы и санитизация имён свойств JSON для вставки в Структуру (VLM иногда возвращает «№» и др.).
//
Функция ИмяКлючаJSONДляСтруктуры(ИсходноеИмя)
	
	Алиас = АлиасыИменПолейJSONVLM().Получить(ИсходноеИмя);
	Если Алиас <> Неопределено Тогда
		Возврат Алиас;
	КонецЕсли;
	
	Если ДопустимоеИмяСвойстваСтруктуры(ИсходноеИмя) Тогда
		Возврат ИсходноеИмя;
	КонецЕсли;
	
	Возврат СанитизироватьИмяСвойстваСтруктуры(ИсходноеИмя);
	
КонецФункции

Функция АлиасыИменПолейJSONVLM()
	
	Алиасы = Новый Соответствие;
	Алиасы.Вставить("№", "row_number");
	Алиасы.Вставить("N", "row_number");
	Алиасы.Вставить("No", "row_number");
	Алиасы.Вставить("no", "row_number");
	
	// Русские и ошибочные имена колонок таблицы заправочной ведомости.
	Алиасы.Вставить("Гос", "garage_number");
	Алиасы.Вставить("Гос_№", "garage_number");
	Алиасы.Вставить("Гос__", "garage_number");
	Алиасы.Вставить("Гарантийный_номер", "garage_number");
	Алиасы.Вставить("Гаражный_номер", "garage_number");
	Алиасы.Вставить("кол_во_ДТ_литр", "quantity_liters");
	Алиасы.Вставить("кол_во_ДТ__литр_", "quantity_liters");
	Алиасы.Вставить("кол_во_ДТ", "quantity_liters");
	Алиасы.Вставить("Дата", "row_date");
	Алиасы.Вставить("Время", "time");
	Алиасы.Вставить("Температура", "temperature");
	Алиасы.Вставить("Плотность", "density");
	Алиасы.Вставить("Моточасы", "engine_hours");
	Алиасы.Вставить("Номер_путевого_листа", "waybill_number");
	Алиасы.Вставить("Марка_модель", "vehicle_make_model");
	Алиасы.Вставить("Полись_водителя", "driver_signature");
	Алиасы.Вставить("Расшифровка_подписи", "signature_decoded");
	Алиасы.Вставить("Гос.№", "garage_number");
	Алиасы.Вставить("кол-во ДТ (литр)", "quantity_liters");
	Алиасы.Вставить("Номер путевого листа", "waybill_number");
	Алиасы.Вставить("Марка, модель", "vehicle_make_model");
	Алиасы.Вставить("Полись водителя", "driver_signature");
	Алиасы.Вставить("Расшифровка подписи", "signature_decoded");
	Алиасы.Вставить("Гарантийный номер", "garage_number");
	
	Возврат Алиасы;
	
КонецФункции

Функция КаноническоеИмяПоляVLM(ИсходноеИмя)
	
	Возврат ИмяКлючаJSONДляСтруктуры(ИсходноеИмя);
	
КонецФункции

// Имя ключа для Свойство/Вставить/Удалить секции полей: алиас + проверка допустимости для Структуры.
// Без этого вызов Свойство("Гос_№", …) падает — «№» недопустим в имени свойства структуры.
//
Функция ИмяКлючаДоступаКСекции(ИсходноеИмя)
	
	ИмяКлюча = КаноническоеИмяПоляVLM(ИсходноеИмя);
	Если ДопустимоеИмяСвойстваСтруктуры(ИмяКлюча) Тогда
		Возврат ИмяКлюча;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ДопустимоеИмяСвойстваСтруктуры(Имя)
	
	Если Не ЗначениеЗаполнено(Имя) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Проверка = Новый Структура;
	Попытка
		Проверка.Вставить(Имя, Неопределено);
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция СанитизироватьИмяСвойстваСтруктуры(ИсходноеИмя)
	
	Результат = СтрЗаменить(ИсходноеИмя, ".", "_");
	Результат = СтрЗаменить(Результат, " ", "_");
	Результат = СтрЗаменить(Результат, ":", "_");
	Результат = СтрЗаменить(Результат, "/", "_");
	Результат = СтрЗаменить(Результат, "(", "_");
	Результат = СтрЗаменить(Результат, ")", "_");
	Результат = СтрЗаменить(Результат, "№", "_");
	Результат = СтрЗаменить(Результат, "-", "_");
	
	Пока СтрНайти(Результат, "__") > 0 Цикл
		Результат = СтрЗаменить(Результат, "__", "_");
	КонецЦикла;
	
	Пока СтрНачинаетсяС(Результат, "_") Цикл
		Результат = Сред(Результат, 2);
	КонецЦикла;
	
	Пока СтрЗаканчиваетсяНа(Результат, "_") Цикл
		Результат = Лев(Результат, СтрДлина(Результат) - 1);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Результат = "field";
	ИначеЕсли ДопустимоеИмяСвойстваСтруктуры(Результат) Тогда
		Возврат Результат;
	Иначе
		Результат = "field_" + Результат;
	КонецЕсли;
	
	Если ДопустимоеИмяСвойстваСтруктуры(Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Возврат "field_" + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=");
	
КонецФункции

Функция ЗаписатьСтруктуруВJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ОбъединитьРезультатыПроходов(ДанныеШапка, ДанныеТаблица, ИмяТипа)
	
	ДанныеШапка = ПривестиДанныеVLMКСтруктуре(ДанныеШапка);
	ДанныеТаблица = ПривестиДанныеVLMКСтруктуре(ДанныеТаблица);
	
	Результат = ПустойКаркасОтветаVLM(ИмяТипа);
	
	Если ДанныеШапка <> Неопределено Тогда
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "imageWidth");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "imageHeight");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "orientationApplied");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "qrVisible");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "referenceDigitsStripVisible");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "header");
		СкопироватьСвойствоЕслиЕсть(ДанныеШапка, Результат, "footer");
	КонецЕсли;
	
	Если ДанныеТаблица <> Неопределено Тогда
		СкопироватьСвойствоЕслиЕсть(ДанныеТаблица, Результат, "rows");
		Ориентация = Неопределено;
		Если Не (Результат.Свойство("orientationApplied", Ориентация) И ЗначениеЗаполнено(Ориентация)) Тогда
			СкопироватьСвойствоЕслиЕсть(ДанныеТаблица, Результат, "orientationApplied");
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НуженПовторныйЗапросТаблицы(ДанныеТаблица)
	
	Если ТипЗнч(ДанныеТаблица) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Строки = Неопределено;
	Если Не ДанныеТаблица.Свойство("rows", Строки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Строки) <> Тип("Массив") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Строки.Количество() <> 1 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СтрокаТаблицы = Строки[0];
	Если ТипЗнч(СтрокаТаблицы) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПоляСтроки = ПоляСтрокиДляОценки(СтрокаТаблицы);
	Если ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗаполненоПолей = КоличествоНепустыхПолейСтрокиТаблицы(ПоляСтроки);
	Если ЗаполненоПолей >= 5 Тогда
		Возврат Истина;
	КонецЕсли;
	
	КоличествоЛитров = СтрокаПоляVLMИзСекции(ПоляСтроки, "quantity_liters");
	ГаражныйНомер = СтрокаПоляVLMИзСекции(ПоляСтроки, "garage_number");
	НомерПЛ = СтрокаПоляVLMИзСекции(ПоляСтроки, "waybill_number");
	
	Если ЗначениеЗаполнено(КоличествоЛитров)
		И ЗначениеЗаполнено(ГаражныйНомер)
		И ЗначениеЗаполнено(НомерПЛ) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ОценкаКачестваТаблицы(ДанныеТаблицы)
	
	Если ТипЗнч(ДанныеТаблицы) <> Тип("Структура") Тогда
		Возврат 0;
	КонецЕсли;
	
	Строки = Неопределено;
	Если Не ДанныеТаблицы.Свойство("rows", Строки) Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(Строки) <> Тип("Массив") Тогда
		Возврат 0;
	КонецЕсли;
	
	Оценка = Строки.Количество() * 100;
	Для Каждого СтрокаТаблицы Из Строки Цикл
		Если ТипЗнч(СтрокаТаблицы) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		ПоляСтроки = ПоляСтрокиДляОценки(СтрокаТаблицы);
		Если ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Оценка = Оценка + КоличествоНепустыхПолейСтрокиТаблицы(ПоляСтроки) * 10;
		
		ЗначениеДатыСтроки = СтрокаПоляVLMИзСекции(ПоляСтроки, "row_date");
		Если СтрДлина(ЗначениеДатыСтроки) = 4 Тогда
			Оценка = Оценка - 10;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Оценка;
	
КонецФункции

Функция КоличествоНепустыхПолейСтрокиТаблицы(ПоляСтроки)
	
	Результат = 0;
	Для Каждого КлючЗначение Из ПоляСтроки Цикл
		Если КлючЗначение.Ключ = "row_number"
			Или КлючЗначение.Ключ = "driver_signature"
			Или КлючЗначение.Ключ = "operator_signature"
			Или КлючЗначение.Ключ = "signature_decoded" Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЗначениеПоляVLM(КлючЗначение.Значение)) Тогда
			Результат = Результат + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПоляСтрокиДляОценки(СтрокаТаблицы)
	
	ПоляСтроки = Неопределено;
	Если СтрокаТаблицы.Свойство("fields", ПоляСтроки) И ТипЗнч(ПоляСтроки) = Тип("Структура") Тогда
		Возврат ПоляСтроки;
	КонецЕсли;
	
	ПоляСтроки = Новый Структура;
	Для Каждого КлючЗначение Из СтрокаТаблицы Цикл
		Если КлючЗначение.Ключ = "rowIndex" Или КлючЗначение.Ключ = "isEmpty" Тогда
			Продолжить;
		КонецЕсли;
		ПоляСтроки.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	
	Возврат ПоляСтроки;
	
КонецФункции

Процедура СкопироватьСвойствоЕслиЕсть(Источник, Приемник, ИмяСвойства)
	
	ИсточникСтруктура = ПривестиДанныеVLMКСтруктуре(Источник);
	Если ИсточникСтруктура = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеСвойства = Неопределено;
	Если ИсточникСтруктура.Свойство(ИмяСвойства, ЗначениеСвойства) Тогда
		Приемник.Вставить(ИмяСвойства, ЗначениеСвойства);
	КонецЕсли;
	
КонецПроцедуры

#Область ПостобработкаVLM

Функция НормализоватьОтветVLM(Данные, ИмяТипа)
	
	Если Данные = Неопределено Тогда
		Возврат ПустойКаркасОтветаVLM(ИмяТипа);
	КонецЕсли;
	
	ПривестиTemplateType(Данные, ИмяТипа);
	ПривестиПлоскуюСхемуККанонической(Данные, ИмяТипа);
	НормализоватьСекциюПолей(Данные, "header");
	НормализоватьСекциюПолей(Данные, "footer");
	НормализоватьСтрокиТаблицы(Данные);
	ОбеспечитьСлужебныеМассивы(Данные);
	
	Возврат Данные;
	
КонецФункции

Функция ПустойКаркасОтветаVLM(ИмяТипа)
	
	Результат = Новый Структура;
	Результат.Вставить("version", "2");
	Результат.Вставить("templateType", ИмяТипа);
	Результат.Вставить("header", Новый Структура);
	Результат.Вставить("rows", Новый Массив);
	Результат.Вставить("footer", Новый Структура);
	Результат.Вставить("warnings", Новый Массив);
	Результат.Вставить("errors", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

Процедура ПривестиTemplateType(Данные, ИмяТипа)
	
	Если Не Данные.Свойство("templateType") Или Не ЗначениеЗаполнено(Данные.templateType) Тогда
		ТипДокумента = Неопределено;
		Если Данные.Свойство("type", ТипДокумента) И ЗначениеЗаполнено(ТипДокумента) Тогда
			Данные.Вставить("templateType", ТипДокумента);
		Иначе
			Данные.Вставить("templateType", ИмяТипа);
		КонецЕсли;
	КонецЕсли;
	
	Если Не Данные.Свойство("version") Тогда
		Данные.Вставить("version", "2");
	КонецЕсли;
	
	Поворот = Неопределено;
	Если Не Данные.Свойство("orientationApplied") И Данные.Свойство("orientation", Поворот) Тогда
		Данные.Вставить("orientationApplied", Поворот);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПривестиПлоскуюСхемуККанонической(Данные, ИмяТипа)
	
	ИменаПолейШапки = ИменаПолейШапкиVLM();
	ИменаПолейПодвала = ИменаПолейПодвалаVLM(ИмяТипа);
	
	Если Не Данные.Свойство("header") Тогда
		Данные.Вставить("header", Новый Структура);
	КонецЕсли;
	
	Если Не Данные.Свойство("footer") Тогда
		Данные.Вставить("footer", Новый Структура);
	КонецЕсли;
	
	Если Не Данные.Свойство("rows") Тогда
		Данные.Вставить("rows", Новый Массив);
	КонецЕсли;
	
	Для Каждого ИмяПоля Из ИменаПолейШапки Цикл
		ПеренестиКорневоеПолеВСекцию(Данные, ИмяПоля, "header");
	КонецЦикла;
	
	Для Каждого ИмяПоля Из ИменаПолейПодвала Цикл
		ПеренестиКорневоеПолеВСекцию(Данные, ИмяПоля, "footer");
	КонецЦикла;
	
КонецПроцедуры

Процедура ПеренестиКорневоеПолеВСекцию(Данные, ИмяПоля, ИмяСекции)
	
	ЗначениеПоля = Неопределено;
	Если Не Данные.Свойство(ИмяПоля, ЗначениеПоля) Тогда
		Возврат;
	КонецЕсли;
	
	Секция = Данные[ИмяСекции];
	Если Не Секция.Свойство(ИмяПоля) Тогда
		Секция.Вставить(ИмяПоля, ОбернутьЗначениеВПолеVLM(ИмяПоля, ЗначениеПоля));
	КонецЕсли;
	
	Данные.Удалить(ИмяПоля);
	
КонецПроцедуры

Функция ОбернутьЗначениеВПолеVLM(ИдПоля, Значение)
	
	Поле = Новый Структура;
	Поле.Вставить("id", ИдПоля);
	Поле.Вставить("label", ИдПоля);
	Поле.Вставить("source", "");
	Поле.Вставить("status", ?(ЗначениеЗаполнено(Значение), "ok", "empty"));
	Поле.Вставить("confidence", ?(ЗначениеЗаполнено(Значение), 0.9, 0.1));
	Поле.Вставить("value", Значение);
	
	Возврат Поле;
	
КонецФункции

Процедура НормализоватьСекциюПолей(Данные, ИмяСекции)
	
	Если Не Данные.Свойство(ИмяСекции) Тогда
		Возврат;
	КонецЕсли;
	
	Секция = Данные[ИмяСекции];
	
	Если ТипЗнч(Секция) <> Тип("Структура") Тогда
		Данные.Вставить(ИмяСекции, Новый Структура);
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из Секция Цикл
		Если ТипЗнч(КлючЗначение.Значение) <> Тип("Структура") Тогда
			Секция.Вставить(КлючЗначение.Ключ, ОбернутьЗначениеВПолеVLM(КлючЗначение.Ключ, КлючЗначение.Значение));
		Иначе
			ИсправитьSourceПоля(КлючЗначение.Значение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ИсправитьSourceПоля(Поле)
	
	ДопустимыеИсточники = Новый Соответствие;
	ДопустимыеИсточники.Вставить("printed", Истина);
	ДопустимыеИсточники.Вставить("handwritten", Истина);
	ДопустимыеИсточники.Вставить("mixed", Истина);
	ДопустимыеИсточники.Вставить("comb", Истина);
	ДопустимыеИсточники.Вставить("signature_present", Истина);
	
	Источник = "";
	Если Поле.Свойство("source", Источник) И ДопустимыеИсточники.Получить(НРег(Источник)) = Неопределено Тогда
		ЗначениеПоля = ЗначениеПоляVLM(Поле);
		Если Не ЗначениеЗаполнено(ЗначениеПоля) И ЗначениеЗаполнено(Источник) Тогда
			Поле.value = Источник;
		КонецЕсли;
		Поле.source = "printed";
	КонецЕсли;
	
КонецПроцедуры

Процедура НормализоватьСтрокиТаблицы(Данные)
	
	Если Не Данные.Свойство("rows") Или ТипЗнч(Данные.rows) <> Тип("Массив") Тогда
		Данные.Вставить("rows", Новый Массив);
		Возврат;
	КонецЕсли;
	
	Индекс = 0;
	Пока Индекс < Данные.rows.Количество() Цикл
		СтрокаТаблицы = Данные.rows[Индекс];
		Если ТипЗнч(СтрокаТаблицы) <> Тип("Структура") Тогда
			Данные.rows.Удалить(Индекс);
			Продолжить;
		КонецЕсли;
		
		Если Не СтрокаТаблицы.Свойство("rowIndex") Тогда
			СтрокаТаблицы.Вставить("rowIndex", Индекс + 1);
		КонецЕсли;
		
		Если Не СтрокаТаблицы.Свойство("fields") Тогда
			ПоляСтроки = Новый Структура;
			КлючиПереноса = Новый Массив;
			Для Каждого КлючЗначение Из СтрокаТаблицы Цикл
				Если КлючЗначение.Ключ = "rowIndex" Или КлючЗначение.Ключ = "isEmpty" Тогда
					Продолжить;
				КонецЕсли;
				ПоляСтроки.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
				КлючиПереноса.Добавить(КлючЗначение.Ключ);
			КонецЦикла;
			Для Каждого ИмяКлюча Из КлючиПереноса Цикл
				СтрокаТаблицы.Удалить(ИмяКлюча);
			КонецЦикла;
			СтрокаТаблицы.Вставить("fields", ПоляСтроки);
		Иначе
			ПривестиПоляСтрокиИзМассиваВСтруктуру(СтрокаТаблицы);
		КонецЕсли;
		
		НормализоватьСекциюПолей(СтрокаТаблицы, "fields");
		ПрименитьАлиасыПолейСтроки(СтрокаТаблицы.fields);
		Индекс = Индекс + 1;
	КонецЦикла;
	
КонецПроцедуры

// VLM иногда возвращает fields как массив объектов полей вместо структуры.
//
Процедура ПривестиПоляСтрокиИзМассиваВСтруктуру(СтрокаТаблицы)
	
	Поля = СтрокаТаблицы.fields;
	Если ТипЗнч(Поля) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураПолей = Новый Структура;
	
	Для Каждого ЭлементПоля Из Поля Цикл
		Если ТипЗнч(ЭлементПоля) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		ИдПоля = Неопределено;
		Если ЭлементПоля.Свойство("id", ИдПоля) И ЗначениеЗаполнено(ИдПоля) Тогда
			ИмяКлюча = ИмяКлючаДоступаКСекции(ИдПоля);
			Если ЗначениеЗаполнено(ИмяКлюча) И Не СтруктураПолей.Свойство(ИмяКлюча) Тогда
				СтруктураПолей.Вставить(ИмяКлюча, ЭлементПоля);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	СтрокаТаблицы.fields = СтруктураПолей;
	
КонецПроцедуры

Процедура ПрименитьАлиасыПолейСтроки(ПоляСтроки)
	
	Если ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Переименования = Новый Соответствие;
	
	Для Каждого КлючЗначение Из ПоляСтроки Цикл
		КаноническоеИмя = КаноническоеИмяПоляVLM(КлючЗначение.Ключ);
		Если КаноническоеИмя = КлючЗначение.Ключ Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПоляСтроки.Свойство(КаноническоеИмя) Тогда
			Если Не ЗначениеЗаполнено(ЗначениеПоляVLM(ПоляСтроки[КаноническоеИмя]))
				И ЗначениеЗаполнено(ЗначениеПоляVLM(КлючЗначение.Значение)) Тогда
				ПоляСтроки[КаноническоеИмя] = КлючЗначение.Значение;
			КонецЕсли;
			Переименования.Вставить(КлючЗначение.Ключ, "");
		Иначе
			Переименования.Вставить(КлючЗначение.Ключ, КаноническоеИмя);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючЗначение Из Переименования Цикл
		Если Не ЗначениеЗаполнено(КлючЗначение.Значение) Тогда
			ПоляСтроки.Удалить(КлючЗначение.Ключ);
		Иначе
			ПоляСтроки.Вставить(КлючЗначение.Значение, ПоляСтроки[КлючЗначение.Ключ]);
			ПоляСтроки.Удалить(КлючЗначение.Ключ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбеспечитьСлужебныеМассивы(Данные)
	
	Если Не Данные.Свойство("warnings") Тогда
		Данные.Вставить("warnings", Новый Массив);
	КонецЕсли;
	
	Если Не Данные.Свойство("errors") Тогда
		Данные.Вставить("errors", Новый Массив);
	КонецЕсли;
	
КонецПроцедуры

Функция СуммаЛитровПоСтрокамVLM(Данные)
	
	Результат = 0;
	
	Если Не Данные.Свойство("rows") Или ТипЗнч(Данные.rows) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из Данные.rows Цикл
		Если Не СтрокаТаблицы.Свойство("fields") Тогда
			Продолжить;
		КонецЕсли;
		Результат = Результат + ЧислоПоляVLM(СтрокаТаблицы.fields, "quantity_liters");
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СтрокаТаблицыПустая(СтрокаТаблицы)
	
	Если Не СтрокаТаблицы.Свойство("fields") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из СтрокаТаблицы.fields Цикл
		Если КлючЗначение.Ключ = "row_number" Тогда
			Продолжить;
		КонецЕсли;
		Если ЗначениеЗаполнено(ЗначениеПоляVLM(КлючЗначение.Значение)) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ЗначениеПоляVLM(Поле)
	
	Возврат GDS_ЗаполнениеВедомостиПоРаспознаванию.ЗначениеОбъектаПоляРаспознавания(Поле);
	
