#Область ОписаниеПеременных

Перем НастройкиИИ; // параметры подключения к ИИ-сервису и модели распознавания

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает текущие настройки ИИ. При первом вызове инициализирует значения по умолчанию.
//
// Возвращаемое значение:
//  Структура - АдресСервиса, ТокенДоступа, МодельVLM, МодельПостобработки и др.
//
Функция ПолучитьНастройкиИИ() Экспорт
	
	ОбеспечитьНастройкиИИ();
	Возврат НастройкиИИ;
	
КонецФункции

// Обновляет настройки ИИ (частично или полностью).
//
// Параметры:
//  НовыеНастройки - Структура - поля для замены в текущих настройках
//
Процедура УстановитьНастройкиИИ(НовыеНастройки) Экспорт
	
	ОбеспечитьНастройкиИИ();
	
	Если ТипЗнч(НовыеНастройки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из НовыеНастройки Цикл
		НастройкиИИ.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	
КонецПроцедуры

// Распознаёт ведомость по присоединённому файлу с постобработкой ответа VLM.
//
// Параметры:
//  Ведомость - ДокументСсылка.GDS_ЗаправочнаяВедомость
//
// Возвращаемое значение:
//  Структура - Данные, ДанныеJSON, Предупреждения, Двухпроходно
//
Функция РаспознатьВедомость(Ведомость) Экспорт
	
	ИмяТипа = ИмяТипаВедомостиДляПромптаVLM(Ведомость.ТипВедомости);
	
	Файлы = Новый Массив;
	РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(Ведомость, Файлы);
	
	Если Файлы.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Нет присоединённых файлов у ведомости.'");
	КонецЕсли;
	
	РезультатРаспознавания = "";
	Попытка
		РезультатРаспознавания = РаспознатьВедомостьПоФайлу(Файлы[0], ИмяТипа);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецПопытки;
	
	Возврат РезультатРаспознавания;
	
КонецФункции

// Распознаёт скан ведомости по ссылке на присоединённый файл.
//
// Параметры:
//  Файл - СправочникСсылка.Файлы
//  ИмяТипа - Строка - zapravka | prihodnaya | perelivnaya
//
// Возвращаемое значение:
//  Структура - Данные, ДанныеJSON, Предупреждения, Двухпроходно
//
Функция РаспознатьВедомостьПоФайлу(Файл, ИмяТипа) Экспорт
	
	ОтветыVLM.Очистить();
	Настройки = ПолучитьНастройкиИИ();
	
	Если Настройки.ДвухпроходноеРаспознавание Тогда
		ДанныеVLM = РаспознатьДвухпроходно(Файл, ИмяТипа);
	Иначе
		ДанныеVLM = РаспознатьОднопроходно(Файл, ИмяТипа);
	КонецЕсли;
	
	ДанныеVLM = НормализоватьОтветVLM(ДанныеVLM, ИмяТипа);
	
	Результат = Новый Структура;
	Результат.Вставить("Данные", ДанныеVLM);
	Результат.Вставить("ДанныеJSON", ЗаписатьСтруктуруВJSON(ДанныеVLM));
	Результат.Вставить("Двухпроходно", Настройки.ДвухпроходноеРаспознавание);
	
	Возврат Результат;
	
КонецФункции

// Выполняет запрос к VLM по двоичным данным изображения с постобработкой ответа.
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные
//  Промпт - Структура - Системный, Пользовательский
//  МаксТокенов - Число - лимит токенов; 0 — из настроек
//  БезПостобработки - Булево - Истина: только VLM с полным промптом (без второго прохода LLM)
//
// Возвращаемое значение:
//  Структура - ОтветAPI, ОтветПостобработки, Данные
//
Функция ЗапросРазспознаванияИИПоДвоичнымДанным(ДвоичныеДанные, Промпт, МаксТокенов = 0, БезПостобработки = Ложь) Экспорт
	
	Base64Изображения = Base64Строка(ДвоичныеДанные);
	ЛимитТокенов = ОпределитьМаксТокенов(МаксТокенов);
	
	Если БезПостобработки И МаксТокенов = 0 Тогда
		ЛимитТокенов = ОпределитьМаксТокеновПостобработки(Промпт, 0);
	КонецЕсли;
	
	ОтветAPI = ВыполнитьЗапросVLM(Base64Изображения, Промпт, ЛимитТокенов);
	Данные = ИзвлечьДанныеИзОтветаVLM(ОтветAPI);
	ОтветПостобработки = Неопределено;
	
	Если Не БезПостобработки Тогда
		СыройКонтентVLM = ИзвлечьТекстКонтентаИзОтветаИИ(ОтветAPI);
		Если ЗначениеЗаполнено(СыройКонтентVLM) Тогда
			ЛимитПостобработки = ОпределитьМаксТокеновПостобработки(Промпт, ЛимитТокенов);
			ОтветПостобработки = ВыполнитьЗапросПостобработки(СыройКонтентVLM, Промпт, ЛимитПостобработки);
			ДанныеПостобработки = ПривестиДанныеVLMКСтруктуре(ИзвлечьДанныеИзОтветаVLM(ОтветПостобработки));
			Если ДанныеПостобработки <> Неопределено И Не ОтветИИОбрезан(ОтветПостобработки) Тогда
				Данные = ДанныеПостобработки;
			ИначеЕсли Данные = Неопределено Тогда
				Данные = ПривестиДанныеVLMКСтруктуре(РазобратьJSONСтроку(СыройКонтентVLM));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Данные = ПривестиДанныеVLMКСтруктуре(Данные);
	
	Результат = Новый Структура;
	Результат.Вставить("ОтветAPI", ОтветAPI);
	Результат.Вставить("ОтветПостобработки", ОтветПостобработки);
	Результат.Вставить("Данные", Данные);
	
	Возврат Результат;
	
КонецФункции

// Заполняет документ GDS_ЗаправочнаяВедомость по нормализованным данным VLM.
//
// Параметры:
//  Ведомость - ДокументСсылка.GDS_ЗаправочнаяВедомость
//  ДанныеVLM - Структура - результат распознавания (секции header, rows, footer)
//  ЗаписатьДокумент - Булево - записать документ после заполнения
//
// Возвращаемое значение:
//  Структура - Ведомость, Лог, Предупреждение
//
Функция ЗаполнитьВедомостьПоДаннымVLM(Ведомость, ДанныеVLM, ЗаписатьДокумент = Истина) Экспорт
	
	Если Не ЗначениеЗаполнено(Ведомость) Тогда
		ВызватьИсключение НСтр("ru = 'Не указана ведомость для заполнения.'");
	КонецЕсли;
	
	Если ДанныеVLM = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Нет данных распознавания для заполнения ведомости.'");
	КонецЕсли;
	
	ДокументОбъект = Ведомость.ПолучитьОбъект();
	Если ДокументОбъект = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось получить объект ведомости.'");
	КонецЕсли;
	
	ДокументОбъект.ОбменДанными.Загрузка = Истина;
	СвязиСтрокVLM = Новый Массив;
	ЗаполнитьДокументПоДаннымVLM(ДокументОбъект, ДанныеVLM, СвязиСтрокVLM);
	
	Лог = СформироватьКомментарийVLM(ДанныеVLM);
	ДополнитьКомментарийДокумента(ДокументОбъект, Лог);
	Предупреждение = ЕстьПредупрежденияVLM(ДанныеVLM);
	
	Если ЗаписатьДокумент Тогда
		ДокументОбъект.Записать();
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ведомость", ДокументОбъект.Ссылка);
	Результат.Вставить("Лог", Лог);
	Результат.Вставить("Предупреждение", Предупреждение);
	Результат.Вставить("СвязиСтрокVLM", СвязиСтрокVLM);
	Результат.Вставить("ДокументОбъект", ДокументОбъект);
	
	Возврат Результат;
	
КонецФункции

// Распознаёт скан ведомости и заполняет документ распознанными данными.
//
// Параметры:
//  Ведомость - ДокументСсылка.GDS_ЗаправочнаяВедомость
//  ЗаписатьДокумент - Булево
//
// Возвращаемое значение:
//  Структура - поля РаспознатьВедомость + Заполнение, ЛогЗаполнения, ПредупреждениеЗаполнения
//
Функция РаспознатьИЗаполнитьВедомость(Ведомость, ЗаписатьДокумент = Истина) Экспорт
	
	РезультатРаспознавания = РаспознатьВедомость(Ведомость);
	РезультатЗаполнения = ЗаполнитьВедомостьПоДаннымVLM(
		Ведомость,
		РезультатРаспознавания.Данные,
		ЗаписатьДокумент);
	
	РезультатРаспознавания.Вставить("Заполнение", РезультатЗаполнения);
	РезультатРаспознавания.Вставить("ЛогЗаполнения", РезультатЗаполнения.Лог);
	РезультатРаспознавания.Вставить("ПредупреждениеЗаполнения", РезультатЗаполнения.Предупреждение);
	
	Возврат РезультатРаспознавания;
	
КонецФункции

// Формирует таблицу визуального контроля по алгоритму заполнения документа.
//
// Параметры:
//  ДанныеVLM - Структура - результат распознавания
//  Ведомость - ДокументСсылка.GDS_ЗаправочнаяВедомость - документ для моделирования заполнения
//  СвязиСтрокVLM - Массив из Структура(СтрокаVLM, СтрокаТЧ) - связи после фактического заполнения
//
// Возвращаемое значение:
//  ТаблицаЗначений - колонки для формы проверки заполнения
//
Функция СформироватьТаблицуВизуальногоКонтроля(ДанныеVLM, Ведомость = Неопределено, СвязиСтрокVLM = Неопределено) Экспорт
	
	Таблица = НоваяТаблицаВизуальногоКонтроля();
	
	Если ТипЗнч(ДанныеVLM) <> Тип("Структура") Тогда
		Возврат Таблица;
	КонецЕсли;
	
	Если Не ДанныеVLM.Свойство("rows") Или ТипЗнч(ДанныеVLM.rows) <> Тип("Массив") Тогда
		Возврат Таблица;
	КонецЕсли;
	
	ПредупрежденияПоСтрокам = ПредупрежденияПоСтрокамVLM(ДанныеVLM);
	СвязиДляКонтроля = СвязиСтрокVLM;
	ДокументОбъект = Неопределено;
	ИмяТипа = "zapravka";
	
	Если СвязиДляКонтроля = Неопределено И ЗначениеЗаполнено(Ведомость) Тогда
		МодельЗаполнения = СмоделироватьЗаполнениеВедомостиДляКонтроля(Ведомость, ДанныеVLM);
		СвязиДляКонтроля = МодельЗаполнения.СвязиСтрокVLM;
		ДокументОбъект = МодельЗаполнения.ДокументОбъект;
	ИначеЕсли ЗначениеЗаполнено(Ведомость) Тогда
		ДокументОбъект = Ведомость.ПолучитьОбъект();
	КонецЕсли;
	
	Если ДокументОбъект <> Неопределено Тогда
		ИмяТипа = ИмяТипаШаблонаVLM(ДанныеVLM, ДокументОбъект.ТипВедомости);
	КонецЕсли;
	
	Если СвязиДляКонтроля <> Неопределено Тогда
		ЗаполнитьТаблицуВизуальногоКонтроляПоСвязям(
			Таблица,
			СвязиДляКонтроля,
			ПредупрежденияПоСтрокам,
			ИмяТипа);
	Иначе
		ЗаполнитьТаблицуВизуальногоКонтроляИзVLM(Таблица, ДанныеVLM, ПредупрежденияПоСтрокам, ИмяТипа);
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

// Формирует сводку итогов для визуального контроля.
//
// Параметры:
//  ДанныеVLM - Структура - результат распознавания
//  Ведомость - ДокументСсылка.GDS_ЗаправочнаяВедомость
//  СвязиСтрокVLM - Массив - связи после фактического заполнения
//  ДокументОбъект - ДокументОбъект.GDS_ЗаправочнаяВедомость - документ после заполнения
//
// Возвращаемое значение:
//  Структура - ИтогоЛитров, СуммаПоСтрокам, Расхождение, ТекстСводки
//
Функция СформироватьСводкуВизуальногоКонтроля(ДанныеVLM, Ведомость = Неопределено, СвязиСтрокVLM = Неопределено, ДокументОбъект = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ИтогоЛитров", 0);
	Результат.Вставить("СуммаПоСтрокам", 0);
	Результат.Вставить("Расхождение", 0);
	Результат.Вставить("ТекстСводки", "");
	
	Если ТипЗнч(ДанныеVLM) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ДокументОбъект = Неопределено И ЗначениеЗаполнено(Ведомость) Тогда
		Если СвязиСтрокVLM <> Неопределено Тогда
			ДокументОбъект = Ведомость.ПолучитьОбъект();
		Иначе
			МодельЗаполнения = СмоделироватьЗаполнениеВедомостиДляКонтроля(Ведомость, ДанныеVLM);
			ДокументОбъект = МодельЗаполнения.ДокументОбъект;
		КонецЕсли;
	КонецЕсли;
	
	СуммаПоСтрокамVLM = СуммаЛитровПоСтрокамVLM(ДанныеVLM);
	ИтогоЛитровVLM = 0;
	Если ДанныеVLM.Свойство("footer") Тогда
		ИтогоЛитровVLM = ЧислоПоляVLM(ДанныеVLM.footer, "total_liters");
	КонецЕсли;
	
	СуммаПоДокументу = 0;
	ИтогоПоДокументу = 0;
	Если ДокументОбъект <> Неопределено Тогда
		Для Каждого СтрокаТЧ Из ДокументОбъект.Заправки Цикл
			СуммаПоДокументу = СуммаПоДокументу + СтрокаТЧ.Количество;
		КонецЦикла;
		ИтогоПоДокументу = ДокументОбъект.КоличествоВсего;
	КонецЕсли;
	
	СуммаПоСтрокам = ?(СуммаПоДокументу > 0, СуммаПоДокументу, СуммаПоСтрокамVLM);
	ИтогоЛитров = ?(ИтогоПоДокументу > 0, ИтогоПоДокументу, ИтогоЛитровVLM);
	
	Расхождение = 0;
	Если ИтогоЛитров > 0 И СуммаПоСтрокам > 0 Тогда
		Расхождение = ИтогоЛитров - СуммаПоСтрокам;
	КонецЕсли;
	
	Результат.ИтогоЛитров = ИтогоЛитров;
	Результат.СуммаПоСтрокам = СуммаПоСтрокам;
	Результат.Расхождение = Расхождение;
	
	Если ДокументОбъект <> Неопределено Тогда
		Результат.ТекстСводки = СтрШаблон(
			НСтр("ru = 'Документ: итого %1 л, сумма строк %2 л, расхождение %3 л; VLM подвал: %4 л'"),
			ИтогоПоДокументу,
			СуммаПоДокументу,
			ИтогоПоДокументу - СуммаПоДокументу,
			ИтогоЛитровVLM);
	Иначе
		Результат.ТекстСводки = СтрШаблон(
			НСтр("ru = 'Итого по подвалу: %1 л; сумма строк: %2 л; расхождение: %3 л'"),
			ИтогоЛитров,
			СуммаПоСтрокам,
			Расхождение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Прогоняет постобработку на эталонных промежуточных данных ведомости 6_1.
//
// Возвращаемое значение:
//  Структура - Успех, Ошибки, Предупреждения, Данные
//
Функция ПроверитьРаспознаваниеНаЭталоне() Экспорт
	
	ДанныеЭталона = ЭталонныеДанныеВедомости6_1();
	Данные = ОбъединитьРезультатыПроходов(
		ДанныеЭталона.Шапка,
		ДанныеЭталона.Таблица,
		"zapravka");
	Данные.Вставить("_rawHeaderFooterText", ДанныеЭталона.СыройТекстШапки);
	
	Данные = НормализоватьОтветVLM(Данные, "zapravka");
	ОшибкиПроверки = СравнитьСЭталономВедомости6_1(Данные);
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", ОшибкиПроверки.Количество() = 0);
	Результат.Вставить("Ошибки", ОшибкиПроверки);
	Результат.Вставить("Данные", Данные);
	
	Возврат Результат;
	
КонецФункции

// Формирует поле VLM с явным статусом для эталонных промежуточных данных.
//
// Параметры:
//  Значение - Произвольный
//  Статус - Строка - ok | empty | unreadable | partial
//
// Возвращаемое значение:
//  Структура - value, status
//
Функция ПолеЭталонаVLM(Значение, Статус)
	
	Поле = Новый Структура;
	Поле.Вставить("value", Значение);
	Поле.Вставить("status", Статус);
	
	Возврат Поле;
	
КонецФункции

Функция ЭталонныеДанныеВедомости6_1()
	
	Результат = Новый Структура;
	Результат.Вставить("СыройТекстШапки",
		"Заправочная" + Символы.ПС
		+ "Ведомость № 570007 учета ГСМ от ""26"" ""07"" 2026 года" + Символы.ПС
		+ "ПУ" + Символы.ПС
		+ "ДЕЛЬТА-ОЙЛ ЛИЗИНГ ООО" + Символы.ПС
		+ "Ф.И.О. водителя" + Символы.ПС
		+ "Гос.№ АТ3 А 570 НВ 186" + Символы.ПС
		+ "Наименование ГСМ Дизельное топливо" + Символы.ПС
		+ "Куст №" + Символы.ПС
		+ "ВСЕГО выдано по ведомости: (л) 727");
	
