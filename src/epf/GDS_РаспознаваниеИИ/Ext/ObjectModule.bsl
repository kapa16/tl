КонецФункции

Функция СмоделироватьЗаполнениеВедомостиДляКонтроля(Ведомость, ДанныеVLM)
	
	Результат = Новый Структура;
	Результат.Вставить("ДокументОбъект", Неопределено);
	Результат.Вставить("СвязиСтрокVLM", Новый Массив);
	
	Если Не ЗначениеЗаполнено(Ведомость) Или ДанныеVLM = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДокументОбъект = Ведомость.ПолучитьОбъект();
	Если ДокументОбъект = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	СвязиСтрокVLM = Новый Массив;
	ДокументОбъект.ОбменДанными.Загрузка = Истина;
	ЗаполнитьДокументПоДаннымVLM(ДокументОбъект, ДанныеVLM, СвязиСтрокVLM);
	
	Результат.ДокументОбъект = ДокументОбъект;
	Результат.СвязиСтрокVLM = СвязиСтрокVLM;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьТаблицуВизуальногоКонтроляПоСвязям(Таблица, СвязиСтрокVLM, ПредупрежденияПоСтрокам, ИмяТипа)
	
	ИменаПолейТС = ИменаПолейТССтрокиVLM(ИмяТипа);
	
	Для Каждого Связь Из СвязиСтрокVLM Цикл
		
		Если ТипЗнч(Связь) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаVLM = Неопределено;
		СтрокаТЧ = Неопределено;
		Если Не Связь.Свойство("СтрокаVLM", СтрокаVLM) Или Не Связь.Свойство("СтрокаТЧ", СтрокаТЧ) Тогда
			Продолжить;
		КонецЕсли;
		
		ПоляСтроки = Неопределено;
		Если ТипЗнч(СтрокаVLM) <> Тип("Структура")
			Или Не СтрокаVLM.Свойство("fields", ПоляСтроки)
			Или ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		НомерСтроки = 0;
		Если СтрокаVLM.Свойство("rowIndex") Тогда
			НомерСтроки = СтрокаVLM.rowIndex;
		КонецЕсли;
		
		НоваяСтрока = Таблица.Добавить();
		НоваяСтрока.НомерСтроки = НомерСтроки;
		НоваяСтрока.ДатаЗаправки = ПредставлениеДатыЗаправкиСтроки(СтрокаТЧ.ДатаЗаправки);
		НоваяСтрока.НомерПЛ = Строка(СтрокаТЧ.НомерПЛ);
		НоваяСтрока.ГаражныйНомер = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гаражный);
		НоваяСтрока.ГосНомер = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гос);
		НоваяСтрока.ТС = ПредставлениеТССтрокиДокумента(СтрокаТЧ);
		НоваяСтрока.Количество = СтрокаТЧ.Количество;
		НоваяСтрока.Плотность = СтрокаТЧ.Плотность;
		НоваяСтрока.Кг = СтрокаТЧ.Количество * СтрокаТЧ.Плотность;
		НоваяСтрока.МинУверенность = МинимальнаяУверенностьПоляСтроки(ПоляСтроки);
		НоваяСтрока.Предупреждение = СформироватьПредупреждениеЗаполненияСтроки(
			ПоляСтроки,
			СтрокаТЧ,
			ИменаПолейТС,
			ПредупрежденияПоСтрокам,
			НомерСтроки);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуВизуальногоКонтроляИзVLM(Таблица, ДанныеVLM, ПредупрежденияПоСтрокам, ИмяТипа)
	
	ИменаПолейТС = ИменаПолейТССтрокиVLM(ИмяТипа);
	
	Для Каждого СтрокаVLM Из ДанныеVLM.rows Цикл
		
		Если ТипЗнч(СтрокаVLM) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		ПоляСтроки = Неопределено;
		Если Не СтрокаVLM.Свойство("fields", ПоляСтроки) Или ТипЗнч(ПоляСтроки) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		НомерСтроки = 0;
		Если СтрокаVLM.Свойство("rowIndex") Тогда
			НомерСтроки = СтрокаVLM.rowIndex;
		КонецЕсли;
		
		Количество = ЧислоПоляVLM(ПоляСтроки, "quantity_liters");
		Плотность = НормализоватьПлотностьVLM(ЧислоПоляVLM(ПоляСтроки, "density"));
		
		НоваяСтрока = Таблица.Добавить();
		НоваяСтрока.НомерСтроки = НомерСтроки;
		НоваяСтрока.ДатаЗаправки = СтрокаПоляVLMИзСекции(ПоляСтроки, "row_date");
		НоваяСтрока.НомерПЛ = СтрокаПоляVLMИзСекции(ПоляСтроки, "waybill_number");
		НоваяСтрока.ГаражныйНомер = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гаражный);
		НоваяСтрока.ГосНомер = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гос);
		НоваяСтрока.ТС = "";
		НоваяСтрока.Количество = Количество;
		НоваяСтрока.Плотность = Плотность;
		НоваяСтрока.Кг = Количество * Плотность;
		НоваяСтрока.МинУверенность = МинимальнаяУверенностьПоляСтроки(ПоляСтроки);
		
		ТекстПредупреждения = "";
		Если ПредупрежденияПоСтрокам.Получить(НомерСтроки) <> Неопределено Тогда
			ТекстПредупреждения = ПредупрежденияПоСтрокам.Получить(НомерСтроки);
		КонецЕсли;
		НоваяСтрока.Предупреждение = ТекстПредупреждения;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИменаПолейТССтрокиVLM(ИмяТипа)
	
	Результат = Новый Структура("Гаражный, Гос", "garage_number", "vehicle_plate");
	
	Если ИмяТипа = "prihodnaya" Тогда
		Результат.Гаражный = "vehicle_or_org";
		Результат.Гос = "";
	ИначеЕсли ИмяТипа = "perelivnaya" Тогда
		Результат.Гаражный = "vehicle_or_org";
		Результат.Гос = "receiver_plate";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеДатыЗаправкиСтроки(ДатаЗаправки)
	
	Если Не ЗначениеЗаполнено(ДатаЗаправки) Или ДатаЗаправки = '00010101' Тогда
		Возврат "";
	КонецЕсли;
	
	Если Час(ДатаЗаправки) <> 0 Или Минута(ДатаЗаправки) <> 0 Тогда
		Возврат Формат(ДатаЗаправки, "ДЛФ=DT");
	КонецЕсли;
	
	Возврат Формат(ДатаЗаправки, "ДЛФ=D");
	
КонецФункции

Функция ПредставлениеТССтрокиДокумента(СтрокаТЧ)
	
	Если СтрокаТЧ = Неопределено Или Не ЗначениеЗаполнено(СтрокаТЧ.ТС) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка(СтрокаТЧ.ТС);
	
КонецФункции

Функция СформироватьПредупреждениеЗаполненияСтроки(ПоляСтроки, СтрокаТЧ, ИменаПолейТС, ПредупрежденияПоСтрокам, НомерСтроки)
	
	Части = Новый Массив;
	
	ТекстVLM = ПредупрежденияПоСтрокам.Получить(НомерСтроки);
	Если ЗначениеЗаполнено(ТекстVLM) Тогда
		Части.Добавить(ТекстVLM);
	КонецЕсли;
	
	КоличествоVLM = ЧислоПоляVLM(ПоляСтроки, "quantity_liters");
	Если КоличествоVLM > 0 И (Не ЗначениеЗаполнено(СтрокаТЧ.Количество) Или СтрокаТЧ.Количество = 0) Тогда
		Части.Добавить(НСтр("ru = 'литры не записаны'"));
	КонецЕсли;
	
	ПлотностьVLM = НормализоватьПлотностьVLM(ЧислоПоляVLM(ПоляСтроки, "density"));
	Если ПлотностьVLM > 0 И (Не ЗначениеЗаполнено(СтрокаТЧ.Плотность) Или СтрокаТЧ.Плотность = 0) Тогда
		Части.Добавить(НСтр("ru = 'плотность не записана'"));
	КонецЕсли;
	
	НомерПЛVLM = СтрокаПоляVLMИзСекции(ПоляСтроки, "waybill_number");
	Если ЗначениеЗаполнено(НомерПЛVLM) И Не ЗначениеЗаполнено(СтрокаТЧ.НомерПЛ) Тогда
		Части.Добавить(НСтр("ru = 'номер ПЛ не записан'"));
	КонецЕсли;
	
	ТекстДатыVLM = СтрокаПоляVLMИзСекции(ПоляСтроки, "row_date");
	ТекстВремениVLM = СтрокаПоляVLMИзСекции(ПоляСтроки, "time");
	Если (ЗначениеЗаполнено(ТекстДатыVLM) Или ЗначениеЗаполнено(ТекстВремениVLM))
		И Не ЗначениеЗаполнено(СтрокаТЧ.ДатаЗаправки) Тогда
		Части.Добавить(НСтр("ru = 'дата не записана'"));
	КонецЕсли;
	
	ГаражныйVLM = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гаражный);
	ГосVLM = "";
	Если ЗначениеЗаполнено(ИменаПолейТС.Гос) Тогда
		ГосVLM = СтрокаПоляVLMИзСекции(ПоляСтроки, ИменаПолейТС.Гос);
	КонецЕсли;
	
	Если (ЗначениеЗаполнено(ГаражныйVLM) Или ЗначениеЗаполнено(ГосVLM))
		И Не ЗначениеЗаполнено(СтрокаТЧ.ТС) Тогда
		Части.Добавить(НСтр("ru = 'ТС не найдено'"));
	КонецЕсли;
	
	Возврат СтрСоединить(Части, "; ");
	
КонецФункции

