Функция ПолеVLM(Секция, ИмяПоля)
	
	ИмяКлюча = ИмяКлючаДоступаКСекции(ИмяПоля);
	Если Не ЗначениеЗаполнено(ИмяКлюча) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Поле = Неопределено;
	Если ТипЗнч(Секция) = Тип("Структура") И Секция.Свойство(ИмяКлюча, Поле) Тогда
		Возврат Поле;
	КонецЕсли;
	
	Возврат Неопределено;
	
