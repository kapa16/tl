Функция РаспознатьОднопроходно(Файл, ИмяТипа)
	
	ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(Файл);
	ПодготовленноеИзображение = ПодготовитьИзображениеДляVLM(ДвоичныеДанные, ИмяТипа);
	
	БезПостобработки = БезПостобработкиИзНастроек();
	РезультатЗапроса = ЗапросРазспознаванияИИПоДвоичнымДанным(
		ПодготовленноеИзображение.ДвоичныеДанные,
		СоздатьПромптVLM(ИмяТипа, "полный"),
		0,
		БезПостобработки);
	
	Возврат УстановитьОриентациюВДанныхVLM(РезультатЗапроса.Данные, ПодготовленноеИзображение.УголПоворота);
	
КонецФункции

Функция РаспознатьДвухпроходно(Файл, ИмяТипа)
	
	ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(Файл);
	ПодготовленноеИзображение = ПодготовитьИзображениеДляVLM(ДвоичныеДанные, ИмяТипа);
	ДвоичныеДанные = ПодготовленноеИзображение.ДвоичныеДанные;
	
	БезПостобработки = БезПостобработкиИзНастроек();
	
	РезультатШапка = ЗапросРазспознаванияИИПоДвоичнымДанным(
		ДвоичныеДанные,
		СоздатьПромптVLM(ИмяТипа, "шапка_подвал"),
		0,
		БезПостобработки);
	
	РезультатТаблица = ЗапросРазспознаванияИИПоДвоичнымДанным(
		ДвоичныеДанные,
		СоздатьПромптVLM(ИмяТипа, "таблица"),
		0,
		БезПостобработки);
	
	ДанныеТаблицы = РезультатТаблица.Данные;
	Если НуженПовторныйЗапросТаблицы(ДанныеТаблицы) Тогда
		РезультатТаблицаАнтиСхлопывание = ЗапросРазспознаванияИИПоДвоичнымДанным(
			ДвоичныеДанные,
			СоздатьПромптVLM(ИмяТипа, "таблица_анти_схлопывание"),
			0,
			БезПостобработки);
		
		Если ОценкаКачестваТаблицы(РезультатТаблицаАнтиСхлопывание.Данные) > ОценкаКачестваТаблицы(ДанныеТаблицы) Тогда
			ДанныеТаблицы = РезультатТаблицаАнтиСхлопывание.Данные;
		КонецЕсли;
	КонецЕсли;
	
	Результат = ОбъединитьРезультатыПроходов(РезультатШапка.Данные, ДанныеТаблицы, ИмяТипа);
	СыройТекстШапки = ИзвлечьТекстКонтентаИзОтветаИИ(РезультатШапка.ОтветAPI);
	Если ЗначениеЗаполнено(СыройТекстШапки) Тогда
		Результат.Вставить("_rawHeaderFooterText", СыройТекстШапки);
	КонецЕсли;
	Возврат УстановитьОриентациюВДанныхVLM(Результат, ПодготовленноеИзображение.УголПоворота);
	
КонецФункции

// Выравнивает ориентацию скана до вызова VLM: перебор углов с пробной проверкой таблицы.
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные
//  ИмяТипа - Строка
//
// Возвращаемое значение:
//  Структура - ДвоичныеДанные, УголПоворота
//
Функция ПодготовитьИзображениеДляVLM(ДвоичныеДанные, ИмяТипа)
	
	УглыКандидаты = Новый Массив;
	УглыКандидаты.Добавить(0);
	УглыКандидаты.Добавить(180);
	УглыКандидаты.Добавить(90);
	УглыКандидаты.Добавить(270);
	
	Для Каждого Угол Из УглыКандидаты Цикл
		
		ПодготовленныеДанные = ?(Угол = 0, ДвоичныеДанные, ПовернутьИзображение(ДвоичныеДанные, Угол));
		
		Если ИзображениеСодержитСтрокиТаблицыVLM(ПодготовленныеДанные, ИмяТипа) Тогда
			Возврат Новый Структура("ДвоичныеДанные, УголПоворота", ПодготовленныеДанные, Угол);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый Структура("ДвоичныеДанные, УголПоворота", ДвоичныеДанные, 0);
	
КонецФункции

// Пробный запрос VLM: есть ли в таблице хотя бы одна заполненная строка.
//
Функция ИзображениеСодержитСтрокиТаблицыVLM(ДвоичныеДанные, ИмяТипа)
	
	Настройки = ПолучитьНастройкиИИ();
	Результат = ЗапросРазспознаванияИИПоДвоичнымДанным(
		ДвоичныеДанные,
		СоздатьПромптVLM(ИмяТипа, "проверка_ориентации"),
		Настройки.МаксТокеновПроверкиОриентации,
		Истина);
	
	Данные = Результат.Данные;
	Если Данные <> Неопределено Тогда
		НормализоватьСтрокиТаблицы(Данные);
	КонецЕсли;
	
	Возврат ОтветVLMСодержитНепустыеСтрокиТаблицы(Данные);
	
КонецФункции

Функция УстановитьОриентациюВДанныхVLM(Данные, УголПоворота)
	
	Если Данные = Неопределено Или УголПоворота = 0 Тогда
		Возврат Данные;
	КонецЕсли;
	
	Данные.Вставить("orientationApplied", УголПоворота);
	Возврат Данные;
	
КонецФункции

Функция ОтветVLMСодержитСтрокиТаблицы(Данные)
	
	Если Данные = Неопределено Или Не Данные.Свойство("rows") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Данные.rows) <> Тип("Массив") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Данные.rows.Количество() > 0;
	
КонецФункции

// Строка считается найденной только если в ней есть хотя бы одно непустое поле (кроме № строки).
//
Функция ОтветVLMСодержитНепустыеСтрокиТаблицы(Данные)
	
	Если Данные = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПризнакЗаполненныхСтрок = Неопределено;
	Если Данные.Свойство("hasFilledRows", ПризнакЗаполненныхСтрок) И ПризнакЗаполненныхСтрок = Истина Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Не ОтветVLMСодержитСтрокиТаблицы(Данные) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из Данные.rows Цикл
		Если Не СтрокаТаблицыПустая(СтрокаТаблицы) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Поворачивает JPEG/PNG через ImageMagick (magick).
//
Функция ПовернутьИзображение(ДвоичныеДанные, УголГрадусов)
	
	ИмяВход = "";
	ИмяВыход = "";
	Результат = Неопределено;
	
	Попытка
		
		ИмяВход = ПолучитьИмяВременногоФайла("jpg");
		ИмяВыход = ПолучитьИмяВременногоФайла("jpg");
		ДвоичныеДанные.Записать(ИмяВход);
		
		ПутьКПрограмме = ПутьКImageMagick();
		Команда = СтрШаблон("""%1"" ""%2"" -rotate %3 ""%4""", ПутьКПрограмме, ИмяВход, УголГрадусов, ИмяВыход);
		
		КодВозврата = Неопределено;
		ЗапуститьПриложение(Команда, , Истина, КодВозврата);
		
		ФайлВыход = Новый Файл(ИмяВыход);
		Если КодВозврата <> 0 Или Не ФайлВыход.Существует() Тогда
			ВызватьИсключение НСтр(
				"ru = 'Не удалось повернуть изображение. Установите ImageMagick (magick) на сервере 1С.'");
		КонецЕсли;
		
		Результат = Новый ДвоичныеДанные(ИмяВыход);
		
	Исключение
		
		Если ИмяВход <> "" Тогда
			УдалитьФайлы(ИмяВход);
		КонецЕсли;
		
		Если ИмяВыход <> "" Тогда
			УдалитьФайлы(ИмяВыход);
		КонецЕсли;
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Если ИмяВход <> "" Тогда
		УдалитьФайлы(ИмяВход);
	КонецЕсли;
	
	Если ИмяВыход <> "" Тогда
		УдалитьФайлы(ИмяВыход);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПутьКImageMagick()
	
	НастройкиСканирования = РаботаСФайлами.ПолучитьНастройкиСканированияПользователя("");
	ПутьКПрограмме = НастройкиСканирования.ПутьКПрограммеКонвертации;
	
	Если ЗначениеЗаполнено(ПутьКПрограмме) Тогда
		Возврат ПутьКПрограмме;
	КонецЕсли;
	
	Возврат "magick";
	
КонецФункции

Функция ВыполнитьЗапросVLM(Base64Изображения, Промпт, МаксТокенов = 0)
	
	Настройки = ПолучитьНастройкиИИ();
	МассивСообщений = Новый Массив;
	
	СообщениеСистемы = Новый Структура("role, content", "system", Промпт.Системный);
	МассивСообщений.Добавить(СообщениеСистемы);
	
	МассивContent = Новый Массив;
	
	ТекстовыйБлок = Новый Структура;
	ТекстовыйБлок.Вставить("type", "text");
	ТекстовыйБлок.Вставить("text", Промпт.Пользовательский);
	МассивContent.Добавить(ТекстовыйБлок);
	
	БлокИзображения = Новый Структура;
	БлокИзображения.Вставить("type", "image_url");
	СтруктураURL = Новый Структура;
	СтруктураURL.Вставить("url", "data:image/jpeg;base64," + Base64Изображения);
	БлокИзображения.Вставить("image_url", СтруктураURL);
	МассивContent.Добавить(БлокИзображения);
	
	СообщениеПользователя = Новый Структура("role, content", "user", МассивContent);
	МассивСообщений.Добавить(СообщениеПользователя);
	
	СтруктураЗапроса = Новый Структура;
	СтруктураЗапроса.Вставить("model", Настройки.МодельVLM);
	СтруктураЗапроса.Вставить("messages", МассивСообщений);
	СтруктураЗапроса.Вставить("max_tokens", ОпределитьМаксТокенов(МаксТокенов));
	СтруктураЗапроса.Вставить("temperature", Настройки.Температура);
	СтруктураЗапроса.Вставить("top_p", Настройки.TopP);
	
	Возврат ВыполнитьЗапросИИ(
		СтруктураЗапроса,
		НСтр("ru = 'Ошибка HTTP %1 при запросе к VLM: %2'"));
	
КонецФункции

Функция ВыполнитьЗапросПостобработки(СыройКонтентVLM, ПромптVLM, МаксТокенов = 0)
	
	Настройки = ПолучитьНастройкиИИ();
	МассивСообщений = Новый Массив;
	МассивСообщений.Добавить(Новый Структура("role, content", "system", ПромптПостобработкиСистемный(ПромптVLM)));
	МассивСообщений.Добавить(Новый Структура(
		"role, content",
		"user",
		ПромптПостобработкиПользовательский(СыройКонтентVLM, ПромптVLM)));
	
	СтруктураЗапроса = Новый Структура;
	СтруктураЗапроса.Вставить("model", Настройки.МодельПостобработки);
	СтруктураЗапроса.Вставить("messages", МассивСообщений);
	СтруктураЗапроса.Вставить("max_tokens", ОпределитьМаксТокеновПостобработки(ПромптVLM, МаксТокенов));
	СтруктураЗапроса.Вставить("temperature", Настройки.Температура);
	СтруктураЗапроса.Вставить("top_p", Настройки.TopP);
	
	Возврат ВыполнитьЗапросИИ(
		СтруктураЗапроса,
		НСтр("ru = 'Ошибка HTTP %1 при постобработке ответа VLM: %2'"));
	
КонецФункции

Функция ОтветИИОбрезан(ОтветAPI)
	
	Если ОтветAPI = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Choices = ПолучитьСвойствоJSON(ОтветAPI, "choices");
	Если Choices = Неопределено Или ТипЗнч(Choices) <> Тип("Массив") Или Choices.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПричинаЗавершения = ПолучитьСвойствоJSON(Choices[0], "finish_reason");
	Возврат НРег(Строка(ПричинаЗавершения)) = "length";
	
КонецФункции

Функция ВыполнитьЗапросИИ(СтруктураЗапроса, ТекстШаблонаОшибки)
	
	Настройки = ПолучитьНастройкиИИ();
	ДополнительныеПараметры = GDS_HTTPКоннектор.НовыеПараметры();
	ДополнительныеПараметры.Заголовки.Вставить("Content-Type", "application/json");
	ДополнительныеПараметры.Заголовки.Вставить("Authorization", "Bearer " + Настройки.ТокенДоступа);
	ДополнительныеПараметры.Json = СтруктураЗапроса;
	ДополнительныеПараметры.Таймаут = Настройки.ТаймаутHTTP;
	
	HTTPОтвет = GDS_HTTPКоннектор.Post(Настройки.АдресСервиса, , ДополнительныеПараметры);
	
	Если HTTPОтвет.КодСостояния <> 200 Тогда
		ТелоОшибки = GDS_HTTPКоннектор.КакТекст(HTTPОтвет);
		ВызватьИсключение СтрШаблон(ТекстШаблонаОшибки, HTTPОтвет.КодСостояния, ТелоОшибки);
	КонецЕсли;
	
	ДобавитьОтветИИВЖурнал(GDS_HTTPКоннектор.КакТекст(HTTPОтвет));
	
	Возврат GDS_HTTPКоннектор.КакJson(HTTPОтвет);
	
КонецФункции

