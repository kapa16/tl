Процедура ПроверитьЭталонноеЗначение(Ошибки, Данные, ПутьПоля, ОжидаемоеЗначение)
	
	Фактическое = ЗначениеПоляVLMПоПути(Данные, ПутьПоля);
	ТекстФакт = ?(Фактическое = Неопределено, "", СокрЛП(Строка(Фактическое)));
	ТекстОжидание = СокрЛП(Строка(ОжидаемоеЗначение));
	
	Если ТекстФакт <> ТекстОжидание Тогда
		Ошибки.Добавить(СтрШаблон("%1: ожидалось '%2', получено '%3'", ПутьПоля, ТекстОжидание, ТекстФакт));
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЭталоннуюСтроку(Ошибки, Данные, НомерСтроки, ГаражныйНомер, Литры)
	
	СтрокаТаблицы = НайтиСтрокуVLMПоИндексу(Данные, НомерСтроки);
	Если СтрокаТаблицы = Неопределено Тогда
		Ошибки.Добавить(СтрШаблон("rows[%1]: строка не найдена", НомерСтроки));
		Возврат;
	КонецЕсли;
	
	ПроверитьЭталонноеЗначениеПоля(Ошибки, СтрокаТаблицы.fields, "garage_number", ГаражныйНомер);
	ПроверитьЭталонноеЗначениеПоля(Ошибки, СтрокаТаблицы.fields, "quantity_liters", Литры);
	
КонецПроцедуры

Процедура ПроверитьЭталонноеЗначениеПоля(Ошибки, ПоляСтроки, ИмяПоля, ОжидаемоеЗначение)
	
	Фактическое = ЗначениеПоляСекции(ПоляСтроки, ИмяПоля);
	ТекстФакт = ?(Фактическое = Неопределено, "", СокрЛП(Строка(Фактическое)));
	ТекстОжидание = СокрЛП(Строка(ОжидаемоеЗначение));
	
	Если ТекстФакт <> ТекстОжидание Тогда
		Ошибки.Добавить(СтрШаблон("%1: ожидалось '%2', получено '%3'", ИмяПоля, ТекстОжидание, ТекстФакт));
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиСтрокуVLMПоИндексу(Данные, НомерСтроки)
	
	Если Не Данные.Свойство("rows") Или ТипЗнч(Данные.rows) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из Данные.rows Цикл
		Если СтрокаТаблицы.Свойство("rowIndex") И СтрокаТаблицы.rowIndex = НомерСтроки Тогда
			Возврат СтрокаТаблицы;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция ЗначениеПоляVLMПоПути(Данные, ПутьПоля)
	
	Части = СтрРазделить(ПутьПоля, ".");
	Если Части.Количество() < 2 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Части[0] = "header" И Данные.Свойство("header") Тогда
		Возврат ЗначениеПоляСекции(Данные.header, Части[1]);
	ИначеЕсли Части[0] = "footer" И Данные.Свойство("footer") Тогда
		Возврат ЗначениеПоляСекции(Данные.footer, Части[1]);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПредупрежденияПоСтрокамVLM(ДанныеVLM)
	
	Результат = Новый Соответствие;
	
	Если ТипЗнч(ДанныеVLM) <> Тип("Структура") Или Не ДанныеVLM.Свойство("warnings") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Предупреждение Из ДанныеVLM.warnings Цикл
		Если ТипЗнч(Предупреждение) <> Тип("Структура") Или Не Предупреждение.Свойство("field") Тогда
			Продолжить;
		КонецЕсли;
		Если Не СтрНачинаетсяС(Предупреждение.field, "rows[") Тогда
			Продолжить;
		КонецЕсли;
		Начало = СтрНайти(Предупреждение.field, "[") + 1;
		Конец = СтрНайти(Предупреждение.field, "]") - 1;
		Если Начало <= 0 Или Конец < Начало Тогда
			Продолжить;
		КонецЕсли;
		НомерСтроки = Число(Сред(Предупреждение.field, Начало, Конец - Начало + 1));
		Код = ?(Предупреждение.Свойство("code"), Предупреждение.code, "");
		Текущий = Результат.Получить(НомерСтроки);
		Если Текущий = Неопределено Тогда
			Текущий = Код;
		Иначе
			Текущий = Текущий + "; " + Код;
		КонецЕсли;
		Результат.Вставить(НомерСтроки, Текущий);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МинимальнаяУверенностьПоляСтроки(ПоляСтроки)
	
	Минимум = 1;
	
	Для Каждого КлючЗначение Из ПоляСтроки Цикл
		Если ТипЗнч(КлючЗначение.Значение) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		Уверенность = 1;
		Если КлючЗначение.Значение.Свойство("confidence") Тогда
			Уверенность = КлючЗначение.Значение.confidence;
		КонецЕсли;
		Если ЗначениеЗаполнено(ЗначениеПоляVLM(КлючЗначение.Значение)) И Уверенность < Минимум Тогда
			Минимум = Уверенность;
		КонецЕсли;
	КонецЦикла;
	
	Если Минимум = 1 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Минимум;
	
КонецФункции

