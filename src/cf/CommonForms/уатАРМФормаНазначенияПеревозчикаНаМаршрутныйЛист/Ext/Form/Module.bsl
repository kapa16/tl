КонецФункции

&НаКлиенте
Процедура ЗакрытьФормуСВыбором(ВыбраннаяСтрока)
	Если ВыбиратьТС Тогда
		Результат = Новый Структура("Перевозчик, Договор, ТС", ВыбраннаяСтрока.Перевозчик, ВыбраннаяСтрока.Договор,
			ВыбраннаяСтрока.ТС);
	Иначе
		Результат = Новый Структура("Перевозчик, Договор", ВыбраннаяСтрока.Перевозчик, ВыбраннаяСтрока.Договор,);
	КонецЕсли;
	Закрыть(Результат);
КонецПроцедуры

&НаСервере
Функция НазначитьПеревозчиковНаСервере()
	
	Результат = Неопределено;
	
	ТекущиеМаршрутныеЛисты = МаршрутныеЛисты.ВыгрузитьЗначения();
	ДанныеПеревозчиков = ПолучитьДанныеПеревозчиков(ТекущиеМаршрутныеЛисты);
	
	Если Элементы.ФормаАлгоритмОптимизацииПолныйПеребор.Пометка Тогда
		ОптимальнаяТаблицаНазначенныхПеревозчиков = НазначитьПеревозчиковПолнымПеребором(ДанныеПеревозчиков,
			ПланированиеРаботыТС.Сценарий.ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
	Иначе
		ОптимальнаяТаблицаНазначенныхПеревозчиков = НазначитьПеревозчиковЖаднымАлгоритмом(ДанныеПеревозчиков,
			ПланированиеРаботыТС.Сценарий.ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
	КонецЕсли;
	
	Если ТипЗнч(ОптимальнаяТаблицаНазначенныхПеревозчиков) = Тип("ТаблицаЗначений") Тогда
		Если НазначитьПеревозчикаВОдинМЛ Тогда
			Результат = Новый Структура("Перевозчик, Договор");
			Если ОптимальнаяТаблицаНазначенныхПеревозчиков.Количество() > 0 Тогда
				ЗаполнитьЗначенияСвойств(Результат, ОптимальнаяТаблицаНазначенныхПеревозчиков[0]);
			КонецЕсли;
		Иначе
			ВсегоМаршрутныхЛистов = НазначенныеПеревозчики.Количество();
			ЗаполненоПеревозчиков = 0;
			
			Для Каждого ТекСтрока Из ОптимальнаяТаблицаНазначенныхПеревозчиков Цикл
				НайденныеСтроки = НазначенныеПеревозчики.НайтиСтроки(Новый Структура("МаршрутныйЛист", ТекСтрока.МаршрутныйЛист));
				Если НайденныеСтроки.Количество() > 0 Тогда
					НайденныеСтроки[0].Перевозчик = ТекСтрока.Перевозчик;
					НайденныеСтроки[0].Договор = ТекСтрока.Договор;
					Если ЗначениеЗаполнено(ТекСтрока.Перевозчик) Тогда
						ЗаполненоПеревозчиков = ЗаполненоПеревозчиков + 1;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			Если ЗаполненоПеревозчиков > 1 Тогда
				ТекстНСтр = НСтр("ru = 'Оптимальные перевозчики назначены в %1 маршрутных листах из %2'; en = 'Optimal carriers are assigned in %1 route sheets out of %2'");
			Иначе
				ТекстНСтр = НСтр("ru = 'Оптимальные перевозчики назначены в %1 маршрутном листе из %2'; en = 'Optimal carriers are assigned in %1 route sheet from %2'");
			КонецЕсли;
			Если ЗаполненоПеревозчиков < ВсегоМаршрутныхЛистов Тогда
				ТекстНСтр = ТекстНСтр + НСтр("ru = '. Возможно, запрещено превышение объемов перевозок или в некоторых маршрутных листах не заполнена плановая выработка.'; en = 'Perhaps exceeding transportation volumes is prohibited, or some route sheets do not have planned output.'");
			КонецЕсли;
			ТекстНСтр = СтрШаблон(ТекстНСтр, ЗаполненоПеревозчиков, ВсегоМаршрутныхЛистов);
			ОбщегоНазначения.СообщитьПользователю(ТекстНСтр);
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Оптимальные перевозчики не назначены. Возможно, запрещено превышение объемов перевозок или в некоторых маршрутных листах не заполнена плановая выработка.'; en = 'Optimal carriers have not been assigned. Exceeding transportation volumes may be prohibited, or some route sheets may not have planned throughput.'"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция НазначитьПеревозчиковПолнымПеребором(ДанныеПеревозчиков, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок)
	
	НеНазначенныеМаршрутныеЛисты = Новый Массив;
	Для Каждого ТекСтрока ИЗ ДанныеПеревозчиков Цикл
		Если ЗначениеЗаполнено(ТекСтрока.МаршрутныйЛист)
			И НеНазначенныеМаршрутныеЛисты.Найти(ТекСтрока.МаршрутныйЛист) = Неопределено Тогда
			// Строки с пустыми МЛ - те, по которым нулевая выработка, то есть не рассчитаны итоги.
			// На них нельзя назначить перевозчика автоматически.
			НеНазначенныеМаршрутныеЛисты.Добавить(ТекСтрока.МаршрутныйЛист);
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаНазначенныхПеревозчиков = Новый ТаблицаЗначений;
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("МаршрутныйЛист", Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист"));
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("Перевозчик", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("Договор", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	
	ОптимальнаяТаблицаНазначенныхПеревозчиков = ВыполнитьРекурсию(НеНазначенныеМаршрутныеЛисты, ДанныеПеревозчиков,
		ТаблицаНазначенныхПеревозчиков, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
	
	Возврат ОптимальнаяТаблицаНазначенныхПеревозчиков;
	
КонецФункции

&НаСервереБезКонтекста
Функция ВыполнитьРекурсию(НеНазначенныеМаршрутныеЛисты, ТаблицаМаршрутныхЛистовСПланами, ТаблицаНазначенныхПеревозчиков,
	ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок,
	Знач МаршрутныйЛист = Неопределено, Знач Договор = Неопределено, Знач Перевозчик = Неопределено);
	
	Если ЗначениеЗаполнено(МаршрутныйЛист) Тогда
		НоваяСтрока = ТаблицаНазначенныхПеревозчиков.Добавить();
		НоваяСтрока.МаршрутныйЛист = МаршрутныйЛист;
		НоваяСтрока.Перевозчик = Перевозчик;
		НоваяСтрока.Договор = Договор;
	КонецЕсли;
	
	Если НеНазначенныеМаршрутныеЛисты.Количество() > 0 Тогда
		МаршрутныйЛист = НеНазначенныеМаршрутныеЛисты[0];
		НовыеНеназначенныеМаршрутныеЛисты = Новый Массив;
		Для Сч = 1 По НеНазначенныеМаршрутныеЛисты.Количество()-1 Цикл
			НовыеНеназначенныеМаршрутныеЛисты.Добавить(НеНазначенныеМаршрутныеЛисты[Сч]);
		КонецЦикла;
		НайденныеСтроки = ТаблицаМаршрутныхЛистовСПланами.НайтиСтроки(Новый Структура("МаршрутныйЛист", МаршрутныйЛист));
		ОптимальноеЗначение = Неопределено;
		ОптимальнаяТаблицаНазначенныхПеревозчиков = Неопределено;
		Для Каждого ТекСтрока Из НайденныеСтроки Цикл
			Перевозчик = ТекСтрока.Перевозчик;
			Договор = ТекСтрока.Договор;
			
			НоваяТаблицаНазначенныхПеревозчиков = ТаблицаНазначенныхПеревозчиков.Скопировать();
			ВременнаяТаблицаНазначенныхПеревозчиков = ВыполнитьРекурсию(НовыеНеназначенныеМаршрутныеЛисты,
				ТаблицаМаршрутныхЛистовСПланами, НоваяТаблицаНазначенныхПеревозчиков, ЗапрещатьПревышениеОбъемовПеревозок,
				МаршрутныйЛист, Договор, Перевозчик);
			ТекущееОптимальноеЗначение = РассчитатьЗначениеОптимизируемойФункции(ВременнаяТаблицаНазначенныхПеревозчиков,
				ТаблицаМаршрутныхЛистовСПланами, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
			Если ТекущееОптимальноеЗначение <> Неопределено
				И (ОптимальноеЗначение = Неопределено
				Или ТекущееОптимальноеЗначение < ОптимальноеЗначение) Тогда
				ОптимальнаяТаблицаНазначенныхПеревозчиков = ВременнаяТаблицаНазначенныхПеревозчиков;
				ОптимальноеЗначение = ТекущееОптимальноеЗначение;
			КонецЕсли;
		КонецЦикла;
		
		Возврат ОптимальнаяТаблицаНазначенныхПеревозчиков;
		
	Иначе
		Возврат ТаблицаНазначенныхПеревозчиков;
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция НазначитьПеревозчиковЖаднымАлгоритмом(ДанныеПеревозчиков, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок)
	
	ТаблицаНазначенныхПеревозчиков = Новый ТаблицаЗначений;
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("МаршрутныйЛист", Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист"));
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("Перевозчик", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("Договор", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ТаблицаНазначенныхПеревозчиков.Колонки.Добавить("КоличествоВыработки", Новый ОписаниеТипов("Число"));
	
	Для Каждого ТекСтрока Из ДанныеПеревозчиков Цикл
		СтруктураОтбора = Новый Структура("МаршрутныйЛист", ТекСтрока.МаршрутныйЛист);
		НайденныеСтроки = ТаблицаНазначенныхПеревозчиков.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = ТаблицаНазначенныхПеревозчиков.Добавить();
			НоваяСтрока.МаршрутныйЛист = ТекСтрока.МаршрутныйЛист;
			НоваяСтрока.КоличествоВыработки = ТекСтрока.КоличествоПоМЛ;
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаНазначенныхПеревозчиков.Сортировать("КоличествоВыработки Убыв");
	
	Для Каждого ТекСтрока Из ТаблицаНазначенныхПеревозчиков Цикл
		Если ТекСтрока.КоличествоВыработки = 0 Тогда
			// Выработка нулевая - скорее всего, МЛ не рассчитан.
			Продолжить;
		КонецЕсли;
		СтруктураОтбора = Новый Структура("МаршрутныйЛист", ТекСтрока.МаршрутныйЛист);
		НайденныеСтроки = ДанныеПеревозчиков.НайтиСтроки(СтруктураОтбора);
		ОптимальноеЗначение = Неопределено;
		ОптимальнаяСтрокаТаблицы = Неопределено;
		Для Каждого ТекСтрокаПеревозчика Из НайденныеСтроки Цикл
			ТекСтрока.Перевозчик = ТекСтрокаПеревозчика.Перевозчик;
			ТекСтрока.Договор = ТекСтрокаПеревозчика.Договор;
			
			ТекущееОптимальноеЗначение = РассчитатьЗначениеОптимизируемойФункции(ТаблицаНазначенныхПеревозчиков,
				ДанныеПеревозчиков, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
			Если ТекущееОптимальноеЗначение <> Неопределено
				И (ОптимальноеЗначение = Неопределено
				Или ТекущееОптимальноеЗначение < ОптимальноеЗначение) Тогда
				ОптимальноеЗначение = ТекущееОптимальноеЗначение;
				ОптимальнаяСтрокаТаблицы = ТекСтрокаПеревозчика;
			КонецЕсли;
		КонецЦикла;
		
		Если ОптимальнаяСтрокаТаблицы <> Неопределено Тогда
			ТекСтрока.Перевозчик = ОптимальнаяСтрокаТаблицы.Перевозчик;
			ТекСтрока.Договор = ОптимальнаяСтрокаТаблицы.Договор;
		Иначе
			ТекСтрока.Перевозчик = Справочники.Контрагенты.ПустаяСсылка();
			ТекСтрока.Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаНазначенныхПеревозчиков;
	
КонецФункции

&НаСервереБезКонтекста
Функция РассчитатьЗначениеОптимизируемойФункции(ТаблицаНазначенныхПеревозчиков, ТаблицаМаршрутныхЛистовСПланами,
	ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок)
	
	Результат = уатЗащищенныеФункцииСервер_уэ.РассчитатьЗначениеОптимизируемойФункции(ТаблицаНазначенныхПеревозчиков,
		ТаблицаМаршрутныхЛистовСПланами, ПланированиеОбъемовВПроцентах, ЗапрещатьПревышениеОбъемовПеревозок);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаписатьНаСервере()
	
	ТаблицаНазначенныеПеревозчики = Новый ТаблицаЗначений;
	ТаблицаНазначенныеПеревозчики.Колонки.Добавить("МаршрутныйЛист", Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист"));
	ТаблицаНазначенныеПеревозчики.Колонки.Добавить("Перевозчик", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	
	Для Каждого ТекСтрока Из НазначенныеПеревозчики Цикл
		Если ЗначениеЗаполнено(ТекСтрока.Перевозчик)
			И (ТекСтрока.МаршрутныйЛист.Контрагент <> ТекСтрока.Перевозчик
			Или ТекСтрока.МаршрутныйЛист.ДоговорКонтрагента <> ТекСтрока.Договор) Тогда
			
			ДокМЛОбъект = ТекСтрока.МаршрутныйЛист.ПолучитьОбъект();
			
			Если ДокМЛОбъект.ПринадлежностьПеревозки = Перечисления.уатПринадлежностьТС.Виртуальное Тогда
				// Сохранение информации о виртуальном ТС, чтобы ей мог воспользоваться, например, перевозчик.
				Документы.уатМаршрутныйЛист.ЗакрепитьПеревозчикаЗаМаршрутнымЛистом(ДокМЛОбъект);
			КонецЕсли;
			
			ДокМЛОбъект.Контрагент = ТекСтрока.Перевозчик;
			ДокМЛОбъект.ДоговорКонтрагента = ТекСтрока.Договор;
			
			ДокМЛОбъект.ПринадлежностьПеревозки = Перечисления.уатПринадлежностьТС.Привлеченное;
			Если ДокМЛОбъект.ТС.ВладелецТС <> ТекСтрока.Перевозчик Тогда
				ДокМЛОбъект.ТС = Справочники.уатТС.ПустаяСсылка();
			КонецЕсли;
			
			ДокМЛОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Документы.уатМаршрутныйЛист.ЗакрепитьПеревозчикаЗаМаршрутнымЛистом(ДокМЛОбъект);
			
			НоваяСтрока = ТаблицаНазначенныеПеревозчики.Добавить();
			НоваяСтрока.МаршрутныйЛист = ТекСтрока.МаршрутныйЛист;
			НоваяСтрока.Перевозчик = ТекСтрока.Перевозчик;
		КонецЕсли;
	КонецЦикла;
	
	Если ПолучитьФункциональнуюОпцию("уатИспользоватьУведомления_уэ") Тогда
		Перевозчики = ТаблицаНазначенныеПеревозчики.Скопировать(, "Перевозчик");
		Перевозчики.Свернуть("Перевозчик");
		Для Каждого ТекПеревозчик Из Перевозчики Цикл
			НайденныеСтроки = ТаблицаНазначенныеПеревозчики.НайтиСтроки(Новый Структура("Перевозчик", ТекПеревозчик.Перевозчик));
			Если НайденныеСтроки.Количество() > 0 Тогда
				МассивМаршрутныхЛистов = Новый Массив;
				Для Каждого ТекСтрока Из НайденныеСтроки Цикл
					МассивМаршрутныхЛистов.Добавить(ТекСтрока.МаршрутныйЛист);
				КонецЦикла;
				ХранилищеМаршрутныхЛистов = Новый ХранилищеЗначения(МассивМаршрутныхЛистов);
				ДополнительныеПараметрыУведомления = Новый Структура("НазначенныеМаршрутныеЛисты", ХранилищеМаршрутныхЛистов);
				уатОбщегоНазначения_уэ.СформироватьУведомление(НайденныеСтроки[0].МаршрутныйЛист,
					Перечисления.уатТипыСобытийДляУведомления_уэ.НазначениеПеревозчиковНаМаршрутныеЛисты,
					ДополнительныеПараметрыУведомления);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НазначитьПеревозчиковЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтруктураОтбора = Новый Структура("Перевозчик, Договор");
	ЗаполнитьЗначенияСвойств(СтруктураОтбора, ДополнительныеПараметры);
	НайденныеСтроки = ТаблицаПеревозчиков.НайтиСтроки(СтруктураОтбора);
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗакрытьФормуСВыбором(НайденныеСтроки[0]);
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		
		НайденныеСтроки = ТаблицаПеревозчиков.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Элементы.ТаблицаПеревозчиков.ТекущаяСтрока = НайденныеСтроки[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЕдиницуИзмеренияКоличестваВыработки(МассивПараметровВыработки)
	Если МассивПараметровВыработки.Количество() <> 1 Тогда
		Возврат "";
	Иначе
		Возврат МассивПараметровВыработки[0].ЕдиницаИзмерения;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ОшибкаПриОткрытииФормыПослеЗавершения(Результат) Экспорт
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти
