#КонецОбласти

#Область ОбработчикиСобытийТаблицыФормы_НазначенныеПеревозчики

&НаКлиенте
Процедура НазначенныеПеревозчикиПриАктивизацииСтроки(Элемент)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьПеревозчика(Команда)
	
	ТекСтрока = Элементы.ТаблицаПеревозчиков.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ЗакрытьФормуСВыбором(ТекСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПеревозчикаДляМаршрутногоЛиста(Команда)
	ТекущиеДанныеМЛ = Элементы.НазначенныеПеревозчики.ТекущиеДанные;
	ТекущиеДанныеПеревозчика = Элементы.ТаблицаПеревозчиков.ТекущиеДанные;
	Если ТекущиеДанныеМЛ <> Неопределено И ТекущиеДанныеПеревозчика <> Неопределено Тогда
		ТекущиеДанныеМЛ.Перевозчик = ТекущиеДанныеПеревозчика.Перевозчик;
		ТекущиеДанныеМЛ.Договор = ТекущиеДанныеПеревозчика.Договор;
		Для Каждого ТекСтрока Из ТаблицаПеревозчиков Цикл
			Если ТекСтрока.Перевозчик = ТекущиеДанныеМЛ.Перевозчик
				И ТекСтрока.Договор = ТекущиеДанныеМЛ.Договор Тогда
				ТекСтрока.Выбран = 0;
			Иначе
				ТекСтрока.Выбран = 2;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТаблицуПеревозчиков(Команда)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура НазначитьПеревозчиков(Команда)
	
	РезультатОптимизации = НазначитьПеревозчиковНаСервере();
	
	Если НазначитьПеревозчикаВОдинМЛ Тогда
		Если ЗначениеЗаполнено(РезультатОптимизации.Перевозчик) Тогда
			ТекстВопроса = НСтр("ru = 'Оптимальный перевозчик найден. Подставить в документ?'; en = 'The optimal carrier has been found. Should I add it to the document?'");
			ОповещениеОЗавершении = Новый ОписаниеОповещения("НазначитьПеревозчиковЗавершение",
				ЭтотОбъект, РезультатОптимизации);
			ПоказатьВопрос(ОповещениеОЗавершении, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		Иначе
			ТекстНСтр = НСтр("ru = 'Оптимальный перевозчик не найден. Возможно, запрещено превышение объемов перевозок или не заполнена плановая выработка.'; en = 'The optimal carrier was not found. Exceeding the transportation volume may be prohibited, or the planned capacity may not be met.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		КонецЕсли;
	Иначе
		ТекущиеДанныеМЛ = Элементы.НазначенныеПеревозчики.ТекущиеДанные;
		Если ТекущиеДанныеМЛ <> Неопределено Тогда
			Для Каждого ТекСтрока Из ТаблицаПеревозчиков Цикл
				Если ТекСтрока.Перевозчик = ТекущиеДанныеМЛ.Перевозчик
					И ТекСтрока.Договор = ТекущиеДанныеМЛ.Договор Тогда
					ТекСтрока.Выбран = 0;
				Иначе
					ТекСтрока.Выбран = 2;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Записать(Команда)
	ЗаписатьНаСервере();
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура АлгоритмОптимизацииПолныйПеребор(Команда)
	Элементы.ФормаАлгоритмОптимизацииПолныйПеребор.Пометка = Истина;
	Элементы.ФормаАлгортимОптимизацииЖадныйАлгоритм.Пометка = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура АлгортимОптимизацииЖадныйАлгоритм(Команда)
	Элементы.ФормаАлгоритмОптимизацииПолныйПеребор.Пометка = Ложь;
	Элементы.ФормаАлгортимОптимизацииЖадныйАлгоритм.Пометка = Истина;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьВидимость();
	
	СценарийПланирования = ПланированиеРаботыТС.Сценарий;
	ХарактеристикиСценария = уатОбщегоНазначения_проф.ЗаполнитьХарактеристикиСценария(СценарийПланирования);
	
	Элементы.ОтборПоВидуПеревозки.Видимость        = ХарактеристикиСценария.флВидПеревозки;
	Элементы.ОтборПоМаршруту.Видимость             = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиМаршрут = Перечисления.уатВариантыАналитик.Маршрут;
	Элементы.ОтборПоМоделиТС.Видимость             = ХарактеристикиСценария.флТС
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.МодельТС;
	Элементы.ОтборПоНаправлениюПеревозки.Видимость = ХарактеристикиСценария.флНаправлениеПеревозки;
	Элементы.ОтборПоОбъектуСтроительства.Видимость = ХарактеристикиСценария.флОбъектСтроительства;
	Элементы.ОтборПоПунктуНазначения.Видимость     = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ПунктНазначения;
	Элементы.ОтборПоПунктуОтправления.Видимость    = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ПунктОтправления;
	Элементы.ОтборПоТипуТС.Видимость               = ХарактеристикиСценария.флТС
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ТипТС;
	
	Элементы.ТаблицаПеревозчиковТС.Видимость = ВыбиратьТС;
	Элементы.ТаблицаПеревозчиковВидПеревозки.Видимость = ХарактеристикиСценария.флВидПеревозки;
	Элементы.ТаблицаПеревозчиковМаршрут.Видимость = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиМаршрут = Перечисления.уатВариантыАналитик.Маршрут;
	Элементы.ТаблицаПеревозчиковМодельТС.Видимость = ХарактеристикиСценария.флТС
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.МодельТС;
	Элементы.ТаблицаПеревозчиковНаправлениеПеревозки.Видимость = ХарактеристикиСценария.флНаправлениеПеревозки;
	Элементы.ТаблицаПеревозчиковОбъектСтроительства.Видимость = ХарактеристикиСценария.флОбъектСтроительства;
	Элементы.ТаблицаПеревозчиковПунктНазначения.Видимость = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ПунктНазначения;
	Элементы.ТаблицаПеревозчиковПунктОтправления.Видимость = ХарактеристикиСценария.флМаршрут
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ПунктОтправления;
	Элементы.ТаблицаПеревозчиковТипТС.Видимость = ХарактеристикиСценария.флТС
		И ХарактеристикиСценария.ВариантАналитикиТС = Перечисления.уатВариантыАналитик.ТипТС;
	
	Элементы.ТаблицаПеревозчиковКоличествоПоПлану.Видимость = Не ХарактеристикиСценария.ПланированиеОбъемовВПроцентах;
	Элементы.ТаблицаПеревозчиковКоличествоПоПлануПроцент.Видимость = ХарактеристикиСценария.ПланированиеОбъемовВПроцентах;
	
	ЕдиницаИзмерения = ПолучитьЕдиницуИзмеренияКоличестваВыработки(ХарактеристикиСценария.МассивПараметровВыработки);
	Элементы.ТаблицаПеревозчиковКоличествоПоПлану.Заголовок = НСтр("ru = 'По плану, '; en = 'According to plan,'") + Строка(ЕдиницаИзмерения);
	Элементы.ТаблицаПеревозчиковКоличествоПоФакту.Заголовок = НСтр("ru = 'По факту, '; en = 'In fact,'") + Строка(ЕдиницаИзмерения);
	Элементы.ТаблицаПеревозчиковКоличествоПоМЛ.Заголовок = НСтр("ru = 'По Маршрутному листу, '; en = 'According to the route sheet, '") + Строка(ЕдиницаИзмерения);
	
	
	Элементы.ТаблицаПеревозчиковВыбран.Видимость             = Не НазначитьПеревозчикаВОдинМЛ;
	Элементы.ФормаЗаписать.Видимость                         = Не НазначитьПеревозчикаВОдинМЛ;
	Элементы.ВыбратьПеревозчикаДляМаршрутногоЛиста.Видимость = Не НазначитьПеревозчикаВОдинМЛ;
	Элементы.НазначенныеПеревозчики.Видимость                = Не НазначитьПеревозчикаВОдинМЛ;
	Элементы.ФормаВыбратьПеревозчика.Видимость               = НазначитьПеревозчикаВОдинМЛ;
	Элементы.ФормаНазначитьПеревозчиков.Видимость            = Не НазначитьПеревозчикаВОдинМЛ;
	Элементы.НазначитьПеревозчика.Видимость                  = НазначитьПеревозчикаВОдинМЛ;
	Если НазначитьПеревозчикаВОдинМЛ Тогда
		Элементы.ФормаВыбратьПеревозчика.КнопкаПоУмолчанию = Истина;
	Иначе
		Элементы.ФормаЗаписать.КнопкаПоУмолчанию = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТаблицуПеревозчиковНаКлиенте()
	
	ТекущийМаршрутныйЛист = Неопределено;
	ТекущийПеревозчик     = Неопределено;
	ТекущийДоговор        = Неопределено;
	
	Если НазначитьПеревозчикаВОдинМЛ Тогда
		ТекущийМаршрутныйЛист = МаршрутныеЛисты[0].Значение;
	Иначе
		ТекущиеДанные = Элементы.НазначенныеПеревозчики.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено И МаршрутныеЛисты.Количество() > 0 Тогда
			ТекущийМаршрутныйЛист = МаршрутныеЛисты[0].Значение;
		ИначеЕсли ТекущиеДанные = Неопределено Тогда
			ТаблицаПеревозчиков.Очистить();
			Возврат;
		Иначе
			ТекущийМаршрутныйЛист = ТекущиеДанные.МаршрутныйЛист;
			ТекущийПеревозчик     = ТекущиеДанные.Перевозчик;
			ТекущийДоговор        = ТекущиеДанные.Договор;
		КонецЕсли;
	КонецЕсли;
	
	ОбновитьТаблицуПеревозчиковНаСервере(ТекущийМаршрутныйЛист, ТекущийПеревозчик, ТекущийДоговор);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицуПеревозчиковНаСервере(ТекущийМаршрутныйЛист, ТекущийПеревозчик, ТекущийДоговор)
	
	ТекущиеМаршрутныеЛисты = Новый Массив;
	ТекущиеМаршрутныеЛисты.Добавить(ТекущийМаршрутныйЛист);
	ДанныеЗапроса = ПолучитьДанныеПеревозчиков(ТекущиеМаршрутныеЛисты, ТекущийПеревозчик, ТекущийДоговор);
	
	ТаблицаПеревозчиков.Очистить();
	Для Каждого ТекСтрока Из ДанныеЗапроса Цикл
		НоваяСтрока = ТаблицаПеревозчиков.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.Выбран = ТекСтрока.ФлагВыбран;
	КонецЦикла;
	
КонецПроцедуры

