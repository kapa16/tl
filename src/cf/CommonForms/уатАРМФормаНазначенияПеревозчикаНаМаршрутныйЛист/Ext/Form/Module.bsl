
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("МаршрутныеЛисты") Тогда
		ВыбиратьТС = Ложь;
		НазначитьПеревозчикаВОдинМЛ = Ложь;
		Для Каждого ТекМаршрутныйЛист Из Параметры.МаршрутныеЛисты Цикл
			МаршрутныеЛисты.Добавить(ТекМаршрутныйЛист);
			НоваяСтрока = НазначенныеПеревозчики.Добавить();
			НоваяСтрока.МаршрутныйЛист = ТекМаршрутныйЛист;
			НоваяСтрока.Перевозчик = ТекМаршрутныйЛист.Контрагент;
			НоваяСтрока.Договор = ТекМаршрутныйЛист.ДоговорКонтрагента;
		КонецЦикла;
	ИначеЕсли Параметры.Свойство("МаршрутныйЛист") Тогда
		ВыбиратьТС = Истина;
		НазначитьПеревозчикаВОдинМЛ = Истина;
		МаршрутныеЛисты.Добавить(Параметры.МаршрутныйЛист);
	КонецЕсли;
	
	ОтборПоВидуПеревозки        = Истина;
	ОтборПоМаршруту             = Истина;
	ОтборПоМоделиТС             = Истина;
	ОтборПоНаправлениюПеревозки = Истина;
	ОтборПоОбъектуСтроительства = Истина;
	ОтборПоПунктуНазначения     = Истина;
	ОтборПоПунктуОтправления    = Истина;
	ОтборПоТипуТС               = Истина;
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатМаршрутныйЛист.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА уатМаршрутныйЛист.ДатаЗакрытия <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА уатМаршрутныйЛист.ДатаЗакрытия
	|		КОГДА уатМаршрутныйЛист.ДатаИВремяОтправления <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА уатМаршрутныйЛист.ДатаИВремяОтправления
	|		КОГДА уатМаршрутныйЛист.ДатаИВремяОтправленияПлан <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА уатМаршрутныйЛист.ДатаИВремяОтправленияПлан
	|		ИНАЧЕ уатМаршрутныйЛист.Дата
	|	КОНЕЦ КАК ДатаЗакрытия
	|ПОМЕСТИТЬ втМаршрутныеЛисты
	|ИЗ
	|	Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	|ГДЕ
	|	уатМаршрутныйЛист.Ссылка В(&МаршрутныеЛисты)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатМаршрутныйЛист.Ссылка КАК Ссылка,
	|	уатМаршрутныйЛист.Маршрут КАК Маршрут,
	|	уатМаршрутныйЛист.АдресОтправления КАК АдресОтправления,
	|	уатМаршрутныйЛист.АдресНазначения КАК АдресНазначения,
	|	уатМаршрутныйЛист.ОбъектСтроительства КАК ОбъектСтроительства,
	|	уатСценарииПланирования.Ссылка КАК Сценарий,
	|	уатМаршрутныйЛист.ВидПеревозки КАК ВидПеревозки,
	|	уатМаршрутныйЛист.НаправлениеПеревозки КАК НаправлениеПеревозки,
	|	уатМаршрутныйЛист.Организация КАК Организация,
	|	уатМаршрутныйЛист.Подразделение КАК Подразделение,
	|	уатПланированиеРаботыТС.Ссылка КАК ПланированиеРаботыТС,
	|	уатМаршрутныйЛист.ТС.Модель КАК МодельТС,
	|	уатМаршрутныйЛист.ТС.ТипТС КАК ТипТС,
	|	уатСценарииПланирования.ПараметрВыработки КАК ПараметрВыработки
	|ПОМЕСТИТЬ втДанныеМаршрутныхЛистов
	|ИЗ
	|	втМаршрутныеЛисты КАК втМаршрутныеЛисты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатПланированиеРаботыТС КАК уатПланированиеРаботыТС
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.уатСценарииПланирования КАК уатСценарииПланирования
	|				ПО уатПланированиеРаботыТС.Сценарий = уатСценарииПланирования.Ссылка
	|			ПО уатМаршрутныйЛист.Организация = уатПланированиеРаботыТС.Организация
	|				И уатМаршрутныйЛист.Подразделение = уатПланированиеРаботыТС.Подразделение
	|		ПО втМаршрутныеЛисты.Ссылка = уатМаршрутныйЛист.Ссылка
	|ГДЕ
	|	уатСценарииПланирования.Раздел = ЗНАЧЕНИЕ(Перечисление.уатРазделыПланирования.ОбъемыПеревозок)
	|	И уатПланированиеРаботыТС.Проведен = ИСТИНА
	|	И втМаршрутныеЛисты.ДатаЗакрытия МЕЖДУ уатПланированиеРаботыТС.ДатаПланирования И ВЫБОР
	|			КОГДА уатСценарииПланирования.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Декада)
	|				ТОГДА КОНЕЦПЕРИОДА(уатПланированиеРаботыТС.ДатаПланирования, ДЕКАДА)
	|			КОГДА уатСценарииПланирования.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|				ТОГДА КОНЕЦПЕРИОДА(уатПланированиеРаботыТС.ДатаПланирования, МЕСЯЦ)
	|			КОГДА уатСценарииПланирования.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
	|				ТОГДА КОНЕЦПЕРИОДА(уатПланированиеРаботыТС.ДатаПланирования, КВАРТАЛ)
	|			КОГДА уатСценарииПланирования.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие)
	|				ТОГДА КОНЕЦПЕРИОДА(уатПланированиеРаботыТС.ДатаПланирования, ПОЛУГОДИЕ)
	|			КОГДА уатСценарииПланирования.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.год)
	|				ТОГДА КОНЕЦПЕРИОДА(уатПланированиеРаботыТС.ДатаПланирования, ГОД)
	|			ИНАЧЕ уатПланированиеРаботыТС.ДатаПланирования
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанныеМаршрутныхЛистов.ПланированиеРаботыТС КАК ПланированиеРаботыТС
	|ИЗ
	|	втДанныеМаршрутныхЛистов КАК втДанныеМаршрутныхЛистов
	|
	|СГРУППИРОВАТЬ ПО
	|	втДанныеМаршрутныхЛистов.ПланированиеРаботыТС");
	Запрос.УстановитьПараметр("МаршрутныеЛисты", МаршрутныеЛисты);
	Выборка = Запрос.Выполнить().Выбрать();
	
	КоличествоДокументовПланирования = 0;
	ТекстОшибки = "";
	Пока Выборка.Следующий() Цикл
		КоличествоДокументовПланирования = КоличествоДокументовПланирования + 1;
		ПланированиеРаботыТС = Выборка.ПланированиеРаботыТС;
	КонецЦикла;
	Если КоличествоДокументовПланирования = 0 Тогда
		ТекстОшибки = НСтр("ru = 'Документ планирования работы ТС не найден. Не найден план по организации или дата отправления не попадает в период планирования.'; en = 'The vehicle work planning document was not found. The organization plan was not found, or the departure date does not fall within the planning period.'");
	ИначеЕсли КоличествоДокументовПланирования > 1 И НазначитьПеревозчикаВОдинМЛ Тогда
		ТекстОшибки = НСтр("ru = 'Документ планирования работы ТС не найден. Выбранные Маршрутные листы должны принадлежать к одной организации и иметь дату отправления в одном периоде планирования'; en = 'The vehicle work planning document was not found. The selected Route Sheets must belong to the same organization and have a departure date within the same planning period.'");
	КонецЕсли;
	
	СтруктураОбъектовНастроек = Новый Структура("Организация, Подразделение, Пользователь", 
		ПланированиеРаботыТС.Организация, ПланированиеРаботыТС.Подразделение, ПользователиКлиентСервер.АвторизованныйПользователь());
	ВидКонтроля = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
		СтруктураОбъектовНастроек, "КонтрольЗакрепленияОбъемовЗаПеревозчиками");
	Если ВидКонтроля = Перечисления.уатВидыКонтроля.Запрещать Тогда
		ЗапрещатьПревышениеОбъемовПеревозок = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ТекстОшибки <> "" Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОшибкаПриОткрытииФормыПослеЗавершения", ЭтотОбъект);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстОшибки);
	КонецЕсли;
	
	ОбновитьТаблицуПеревозчиковНаКлиенте();
	УстановитьВидимость();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтборПоВидуПеревозкиПриИзменении(Элемент)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоМаршрутуПриИзменении(Элемент)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоПунктуОтправленияПриИзменении(Элемент)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоПунктуНазначенияПриИзменении(Элемент)
	ОбновитьТаблицуПеревозчиковНаКлиенте();
КонецПроцедуры

&НаКлиенте
