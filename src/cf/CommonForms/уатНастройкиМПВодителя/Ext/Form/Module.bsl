&НаКлиенте
Процедура ВебСокет_ОбработчикОткрытия(СокетСоединение) Экспорт
	
	Параметры = уатМобильноеПриложениеВодителяКлиентREST.ПараметрыСоединения(СокетСоединение); 
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог("ПриОткрытииСоединения", СокетСоединение.Ключ,, Параметры);

КонецПроцедуры

&НаКлиенте
Процедура ВебСокет_ОбработчикПолученияСообщения(СокетСоединение, СокетСообщение) Экспорт
	
	Если НЕ ЭтотОбъект.Открыта() Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ApiKey.КартинкаКнопкиВыбора = Новый Картинка;
		
	ЭтоОшибка = Ложь;
	СписокКлючей = уатМобильноеПриложениеВодителяКлиентREST.ПриПолученииСообщенияАвторизации(СокетСоединение, СокетСообщение, ЭтоОшибка);
	Если ЭтоОшибка Тогда 
		Если СтрНайти(СокетСообщение, "status 40") <> 0 Тогда // Ошибка 
			КодОшибки      = Сред(СокетСообщение, СтрНайти(СокетСообщение, "400"), 4);
			ОписаниеОшибки = уатМобильноеПриложениеВодителяСерверREST.ПолучитьОписаниеКодаОшибкиПодключенияWebSocket(КодОшибки);
			Если ОписаниеОшибки = Неопределено Тогда 
				ОписаниеОшибки = СокетСообщение; // Неопределенная ошибка
			КонецЕсли; 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СокетСообщение);
		КонецЕсли;
	Иначе 
		уатМобильноеПриложениеВодителяКлиентREST.ЗакрытьСоединение();  
		
	    СоединениеЗакрыто = Ложь;
		Оповещение = Новый ОписаниеОповещения("ПослеВебСокет_ОбработчикПолученияСообщения", ЭтотОбъект);
		ПоказатьВыборИзСписка(Оповещение, СписокКлючей, Элементы.ApiKey);
	КонецЕсли; 
	
КонецПроцедуры 

&НаКлиенте
Процедура ПослеВебСокет_ОбработчикПолученияСообщения(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Элементы.ApiKey.КартинкаКнопкиВыбора = Новый Картинка;;
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ApiKey             = ВыбранныйЭлемент.Значение;
	Модифицированность = Истина;  
	
КонецПроцедуры


&НаКлиенте
Процедура ВебСокет_ОбработчикОшибки(СокетСоединение, КодОшибки, Описание) Экспорт 
	
	Если НЕ ЭтотОбъект.Открыта() Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ApiKey.КартинкаКнопкиВыбора = Новый Картинка;
	
	Если СписокКлючей.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КодОшибки + " " + Описание);
	КонецЕсли;	
	
	Параметры = уатМобильноеПриложениеВодителяКлиентREST.ПараметрыСоединения(СокетСоединение); 
	Параметры.Вставить("Код",КодОшибки);
	Параметры.Вставить("Описание",Описание);
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог("ПриОшибке",СокетСоединение.Ключ,,Параметры); 

КонецПроцедуры 

&НаКлиенте
Процедура ВебСокет_ОбработчикЗакрытия(СокетСоединение, КодЗакрытия) Экспорт    
	
	Элементы.ApiKey.КартинкаКнопкиВыбора = Новый Картинка;
	
	СоединениеЗакрыто = Истина;
	
	Параметры = уатМобильноеПриложениеВодителяКлиентREST.ПараметрыСоединения(СокетСоединение); 
	Параметры.Вставить("Код", КодЗакрытия);
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог("ПриЗакрытииСоединения",СокетСоединение.Ключ,,Параметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьИЗакрыть(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	ЗаписатьНастройки();
	Модифицированность = Ложь;
	Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВариантыИсточниковМестоположения()
	
	Элементы.positionSources.СписокВыбора.Добавить("gps", НСтр("en='Sensor data monitoring system';ru='Данные датчиков системы мониторинга'"));
	Элементы.positionSources.СписокВыбора.Добавить("all", НСтр("en='All possible sources';ru='Все возможные источники'"));
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВариантыХраненияИсторииМестоположения()
	
	Элементы.РежимХраненияИсторииМестоположения.СписокВыбора.Добавить(0, НСтр("en='not save';ru='не сохранять'"));
	Элементы.РежимХраненияИсторииМестоположения.СписокВыбора.Добавить(1, НСтр("en='in an external database';ru='во внешней базе данных'"));
	Элементы.РежимХраненияИсторииМестоположения.СписокВыбора.Добавить(2, НСтр("en='in the database';ru='в информационной базе'"));

КонецПроцедуры

&НаСервере
Процедура УстановитьЗначенияНастроек()

	Если ИспользоватьОблачныйВриантРаботы Тогда
		уатМобильноеПриложениеВодителяСерверREST.СохранитьСообщенияОбОшибках(""); 
	КонецЕсли;   
	
	стрНастроек = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьНастройкиМобильногоПриложения();
	
	ИспользоватьПутевыеЛисты    = стрНастроек.useWaybills;
	ИспользоватьМаршрутныеЛисты = стрНастроек.useRouteLists;
	ИспользоватьЗаявкиНаРемонт  = стрНастроек.useOrdersForRepair;
	ИспользоватьЗаказыТакси     = стрНастроек.useTaxiOrders И уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси();
	ИспользоватьЧат             = стрНастроек.useChat;
	
	ИспользоватьСопроводительныеДокументы       = стрНастроек.useShippingDocuments;
	РазрешитьСозданиеСопроводительныхДокументов = стрНастроек.useAddingShippingDocuments;
	
	gpsDataDensity              = стрНастроек.gpsDataDensity;
	gpsDataSendInterval         = стрНастроек.gpsDataSendInterval;
	logging                     = стрНастроек.logging;
	ВидПериодаОчистикиЛогов     = стрНастроек.ВидПериодаОчистикиЛогов;
	messagesCheckInterval       = стрНастроек.messagesCheckInterval;
	positionSources             = стрНастроек.positionSources;
	routeListsCheckInterval     = стрНастроек.routeListsCheckInterval; 
	waybillsCheckInterval       = стрНастроек.waybillsCheckInterval;
	repairsCheckInterval        = стрНастроек.repairsCheckInterval;
	useBackgroundProcess        = стрНастроек.useBackgroundProcess;
	ОценкаУровняСервиса         = стрНастроек.useMarksAndSignatures;
	
	такtaxiOrdersCheckInterval  = стрНастроек.taxiOrdersCheckInterval;
	
	SearchRadiusType = стрНастроек.SearchRadiusType;
	Если SearchRadiusType = 1 Тогда
		НастройкаИспользованиеРадиуса = "Радиус из пунктов";
	Иначе
		НастройкаИспользованиеРадиуса = "Единый радиус";
	КонецЕсли;

	НастройкаAutomaticDetectionOfArrival = стрНастроек.AutomaticDetectionOfArrival;
	Если НастройкаAutomaticDetectionOfArrival = 1 Тогда
		AutomaticDetectionOfArrival = 1;
	ИначеЕсли НастройкаAutomaticDetectionOfArrival = 2 Тогда
		AutomaticDetectionOfArrival = 2;
	Иначе
		AutomaticDetectionOfArrival   = 2;
		НастройкаИспользованиеРадиуса = "Радиус из пунктов";
	КонецЕсли;

	ЗапретНарушенияПорядкаПунктов     = стрНастроек.ControlItemsOrder;
	ЗапретЗапускаБезОтправкиГеоданных = стрНастроек.ControlGeodata;
	ЗапретПосещенияПунктовВнеРадиуса  = стрНастроек.ControlRadius;

	SearchRadius                         = стрНастроек.SearchRadius;
