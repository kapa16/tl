	Иначе
		ОбработкаФактическогоВремениСтрока = "по часовому поясу базы";
	КонецЕсли;
	
	Если ИспользоватьОблачныйВриантРаботы Тогда
		ВариантРаботыВебСервиса = стрНастроек.ВариантРаботыВебСервиса; 
