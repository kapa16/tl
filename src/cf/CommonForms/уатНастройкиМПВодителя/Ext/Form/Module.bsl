
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	ИспользоватьОблачныйВриантРаботы = ОбщегоНазначенияКлиентСервер.СравнитьВерсии("8.3.27.0", СистемнаяИнформация.ВерсияПриложения) < 0;

	ЗаполнитьВариантыИсточниковМестоположения();
	ЗаполнитьВариантыХраненияИсторииМестоположения();
	УстановитьЗначенияНастроек();
	Элементы.ГруппаСопроводительныеДокументы.Видимость = ПолучитьФункциональнуюОпцию("уатИспользоватьДокументооборот");
	УчетПланФактаПоМаршрутуВМаршрутныхЛистах = Константы.уатУчетПланФактаПоМаршрутуВМаршрутныхЛистах.Получить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбработчикОжидания = Ложь;
	СоединениеЗакрыто  = Истина;
	УстановитьВидимостьИДоступность();
	ОбновитьДанныеРеглЗаданий(); 
	Если ИспользоватьМаршрутныеЛисты
		И НЕ УчетПланФактаПоМаршрутуВМаршрутныхЛистах Тогда
		ТекстОшибки = НСтр("ru = 'Для корректной работы с Маршрутными листами необходимо включить настройку ""Учет плана и факта по маршруту в Маршрутных листах"". Администрирование - Настройки функциональности - Транспорт.'; en = 'To work correctly with Route Sheets, you must enable the ""Consider Planned and Actual Routes in Route Sheets"" setting. Go to Administration - Functionality Settings - Transport.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;  
	ПолучитьСостояниеСоединенияОбработчикОжидания();


КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	Оповещение = Новый ОписаниеОповещения("ВыбратьИЗакрыть", ЭтотОбъект);
	ОбщегоНазначенияКлиент.ПоказатьПодтверждениеЗакрытияФормы(Оповещение, Отказ, ЗавершениеРаботы);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИспользоватьПутевыеЛистыПриИзменении(Элемент)
	Если ИспользоватьПутевыеЛисты = Ложь
		И ИспользоватьМаршрутныеЛисты = Ложь
		И ИспользоватьЗаявкиНаРемонт = Ложь
		И ИспользоватьЗаказыТакси = Ложь
		И ИспользоватьЧат = Ложь Тогда
		ИспользоватьПутевыеЛисты = Истина;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьЗаявкиНаРемонтПриИзменении(Элемент)
	Если ИспользоватьПутевыеЛисты = Ложь
		И ИспользоватьМаршрутныеЛисты = Ложь
		И ИспользоватьЗаявкиНаРемонт = Ложь 
		И ИспользоватьЗаказыТакси = Ложь
		И ИспользоватьЧат = Ложь Тогда
		ИспользоватьЗаявкиНаРемонт = Истина;
	КонецЕсли;
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьЗаказыТаксиПриИзменении(Элемент)
	Если ИспользоватьПутевыеЛисты = Ложь
		И ИспользоватьМаршрутныеЛисты = Ложь
		И ИспользоватьЗаявкиНаРемонт = Ложь
		И ИспользоватьЗаказыТакси = Ложь
		И ИспользоватьЧат = Ложь Тогда
		ИспользоватьЗаказыТакси = Истина;
	КонецЕсли;
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьЧатПриИзменении(Элемент)
	Если ИспользоватьПутевыеЛисты = Ложь
		И ИспользоватьМаршрутныеЛисты = Ложь
		И ИспользоватьЗаявкиНаРемонт = Ложь
		И ИспользоватьЗаказыТакси = Ложь
		И ИспользоватьЧат = Ложь Тогда
		ИспользоватьЧат = Истина;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьСопроводительныеДокументыПриИзменении(Элемент)
	Если НЕ ИспользоватьСопроводительныеДокументы Тогда
		РазрешитьСозданиеСопроводительныхДокументов = Ложь;
	КонецЕсли;
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьМаршрутныеЛистыПриИзменении(Элемент)
	Если ИспользоватьПутевыеЛисты = Ложь
		И ИспользоватьМаршрутныеЛисты = Ложь
		И ИспользоватьЗаявкиНаРемонт = Ложь
		И ИспользоватьЗаказыТакси = Ложь
		И ИспользоватьЧат = Ложь Тогда
		ИспользоватьМаршрутныеЛисты = Истина;
	КонецЕсли;   
	Если ИспользоватьМаршрутныеЛисты
		И НЕ УчетПланФактаПоМаршрутуВМаршрутныхЛистах Тогда
		ТекстОшибки = НСтр("ru = 'Для корректной работы с Маршрутными листами необходимо включить настройку ""Учет плана и факта по маршруту в Маршрутных листах"". Администрирование - Настройки функциональности - Транспорт.'; en = 'To work correctly with Route Sheets, you must enable the ""Consider Planned and Actual Routes in Route Sheets"" setting. Go to Administration - Functionality Settings - Transport.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;

	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура РежимХраненияИсторииМестоположенияПриИзменении(Элемент)
	
	Если НЕ РежимХраненияИсторииМестоположения = 1 Тогда 
		АдресСервераБазыМестоположения       = "";
		ИмяБазыМестоположения                = "";
		ЛогинПользователяБазыМестоположения  = "";
		ПарольПользователяБазыМестоположения = "";
	КонецЕсли;
	
	УстановитьВидимостьИДоступность();
	
КонецПроцедуры

&НаКлиенте
Процедура АвтоматическоеОпределениеПрибытияВПунктПриИзменении(Элемент)
	
	УстановитьВидимостьИДоступность();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаИспользованиеРадиусаПриИзменении(Элемент)
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ЗапретПосещенияПунктовВнеРадиусаПриИзменении(Элемент)
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ГруппаДиспетчеровДляИнформированияОСрокеДействияЛицензийПриИзменении(Элемент)
	ГруппаДиспетчеровДляИнформированияОСрокеДействияЛицензийИзменена = Истина;
КонецПроцедуры

&НаКлиенте
Процедура такИспользоватьАвтоматическоеРаспределениеЗаказовПриИзменении(Элемент)
	Если НЕ такИспользоватьАвтоматическоеРаспределениеЗаказов Тогда
		такСпособОграниченияПриемаЗаявок                 = Неопределено;
		такВремяОграниченияПриемаЗаявок                  = Неопределено;
		такДопускПоРасстояниюПриАвтораспределенииЗаказов = Неопределено;
	КонецЕсли;
	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ЛогинСервераМПАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ДанныеВыбора = ПолучитьПользователейИБ(Текст);
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантРаботыВебСервисаПриИзменении(Элемент)
	Элементы.СтраницыВариантыРаботы.ТекущаяСтраница = ?(ВариантРаботыВебСервиса = "Облачный", Элементы.СтраницаОблачныйВариантРаботы,
		Элементы.СтраницаКорпоративныйВариантРаботы);
	Если НЕ ВариантРаботыВебСервиса = "Облачный"
		И Элементы.ПодключитьЗакрытьСоединение.Заголовок = Нстр("ru = 'Отключить'; en = 'Disable'") Тогда
		уатМобильноеПриложениеВодителяСерверREST.ПодключитьЗакрытьСоединениеСервер(,ApiKey, ИмяПользователяИнформационнойБазы);
		ПолучитьСостояниеСоединенияОбработчикОжидания();	
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ApiKeyНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)  
	СтандартнаяОбработка = Ложь;
	Если НЕ ЗначениеЗаполнено(ЛогинОблачногоСервера) Тогда 
		ТекстОшибки = НСтр("ru='Невозможно подключиться к облачному серверу. Для подключения заполните логин.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки,,"ЛогинОблачногоСервера");
		Возврат;
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ПарольОблачногоСервера) Тогда 
		ТекстОшибки = НСтр("ru='Невозможно подключиться к облачному серверу. Для подключения заполните пароль.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки,,"ПарольОблачногоСервера");
		Возврат;
	КонецЕсли;
	
	Если СоединениеЗакрыто
		И НЕ Элементы.ApiKey.КартинкаКнопкиВыбора = БиблиотекаКартинок.НезавершившаясяПроверка Тогда  
		Элементы.ApiKey.КартинкаКнопкиВыбора = БиблиотекаКартинок.НезавершившаясяПроверка;
		уатМобильноеПриложениеВодителяКлиентREST.СоздатьСоединение(ЛогинОблачногоСервера, ПарольОблачногоСервера, ЭтотОбъект); 
	Иначе
		Если СписокКлючей.Количество() <> 0 Тогда
			Оповещение = Новый ОписаниеОповещения("ПослеВебСокет_ОбработчикПолученияСообщения", ЭтотОбъект);
			ПоказатьВыборИзСписка(Оповещение, СписокКлючей, Элементы.ApiKey);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	
	Если Не НастройкиЗаполнены() Тогда 
		Возврат;
	КонецЕсли;
	
	ЗаписатьНастройки();
	ЗаписатьНастройкиСервер();
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если Не НастройкиЗаполнены() Тогда 
		Возврат;
	КонецЕсли;
	
	ЗаписатьНастройки();
	ЗаписатьНастройкиСервер(Истина);
	
	Модифицированность = Ложь;
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключениеСерверМП(Команда)
	
	ТекстСтатуса = "";
	ПроверитьПодключениеСерверМПСервер(АдресСервераМП, ЛогинСервераМП, ПарольСервераМП, ТекстСтатуса);
	
	ПоказатьПредупреждение(,ТекстСтатуса);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокПользователейМП(Команда)
	
	стрПараметрыПодключения = Новый Структура();
	стрПараметрыПодключения.Вставить("АдресСервераМП",  АдресСервераМП);
	стрПараметрыПодключения.Вставить("ЛогинСервераМП",  ЛогинСервераМП);
	стрПараметрыПодключения.Вставить("ПарольСервераМП", ПарольСервераМП);
	
	ТекстОшибки = "";
	стрДанныеОтвета = Неопределено;
	Если уатМобильноеПриложениеВодителяСервер.ВыполнитьМетодСервераМП(стрПараметрыПодключения, "updateUsers",, стрДанныеОтвета, ТекстОшибки) Тогда 
		Если стрДанныеОтвета.Свойство("resultCode") И стрДанныеОтвета.resultCode = "0" Тогда 
			ПоказатьПредупреждение(, НСтр("en='List of users updated successfully.';ru='Список пользователей обновлен успешно.'"));
		ИначеЕсли стрДанныеОтвета.Свойство("resultDescription") Тогда
			ПоказатьПредупреждение(, НСтр("en='When updating the user list the error occurred."
"Description of the error:';ru='При обновлении списка пользователей возникла ошибка."
"Описание ошибки:'") + " " + стрДанныеОтвета.resultDescription);
		Иначе 
			ПоказатьПредупреждение(, НСтр("en='When updating the user list the error occurred.';ru='При обновлении списка пользователей возникла ошибка.'"));
		КонецЕсли;
	Иначе 
		ПоказатьПредупреждение(, ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОсвободитьЛицензииМП(Команда)

	стрПараметрыПодключения = Новый Структура();
	стрПараметрыПодключения.Вставить("АдресСервераМП",  АдресСервераМП);
	стрПараметрыПодключения.Вставить("ЛогинСервераМП",  ЛогинСервераМП);
	стрПараметрыПодключения.Вставить("ПарольСервераМП", ПарольСервераМП);
	
	ТекстОшибки = "";
	стрДанныеОтвета = Неопределено;
	Если уатМобильноеПриложениеВодителяСервер.ВыполнитьМетодСервераМП(стрПараметрыПодключения, "resetLicences",, стрДанныеОтвета, ТекстОшибки) Тогда 
		Если стрДанныеОтвета.Свойство("resultCode") И стрДанныеОтвета.resultCode = "0" Тогда 
			ПоказатьПредупреждение(, НСтр("en='Licenses released successfully.';ru='Лицензии освобождены успешно.'"));
		ИначеЕсли стрДанныеОтвета.Свойство("resultDescription") Тогда
			ПоказатьПредупреждение(, НСтр("en='Error occurred when releasing licenses."
"Description of error:';ru='При освобождении лицензий возникла ошибка."
"Описание ошибки:'") + " " + стрДанныеОтвета.resultDescription);
		Иначе 
			ПоказатьПредупреждение(, НСтр("en='While release of licenses error occured.';ru='При освобождении лицензий возникла ошибка.'"));
		КонецЕсли;
	Иначе 
		ПоказатьПредупреждение(, ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьНастройкиСервераМП(Команда)

	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("АдресСервераМП",  АдресСервераМП);
	ПараметрыФормы.Вставить("ЛогинСервераМП",  ЛогинСервераМП);
	ПараметрыФормы.Вставить("ПарольСервераМП", ПарольСервераМП);
	
	ОткрытьФорму("ОбщаяФорма.уатНастройкиСервераМПВодителя", ПараметрыФормы, ЭтотОбъект); 
	
КонецПроцедуры

&НаКлиенте
Процедура АнонимныйДоступПриИзменении(Элемент)
	
	Если АнонимныйДоступ Тогда
		ЛогинСервераМП  = "mobile_test";
		ПарольСервераМП = "mobile_test";
	Иначе
		ЛогинСервераМП  = "";
		ПарольСервераМП = "";
	КонецЕсли;
	Элементы.ГруппаСерверМПЛогинПароль.Видимость = НЕ АнонимныйДоступ;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаПодключенияКБД(Команда)
	
	ТекстОшибки = ПроверкаПодключенияКБДСервер();
	Если ТекстОшибки = "" Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("en='Connection is successful.';ru='Подключение выполнено успешно.'"));
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СозданиеТаблицы(Команда)
	
	РезультатПроверкиПодключения = ПроверкаПодключенияКБДСервер();
	Результат = НСтр("en='Connection to the database was successful. The table ""GPSData"" was not found in the database. To create it, use the ""Create Table"" button.';ru='Соединение с базой прошло успешно. В базе не найдена таблица ""GPSData"". Для её создания воспользуейтесь кнопкой ""Создать таблицу"".'");
	Если РезультатПроверкиПодключения = Результат Тогда
		ТекстОшибки = СозданиеТаблицыСервер();
		Если ТекстОшибки = "" Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("en='Table is created successfully.';ru='Таблица создана успешно.'"));
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
	ИначеЕсли РезультатПроверкиПодключения = "" Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("en='Table has already been created earlier.';ru='Таблица уже была создана ранее.'"));
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатПроверкиПодключения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьРегламентноеЗадание(Команда)

	ТекущаяСтраница = Элементы.Страницы.ТекущаяСтраница;
	Если ТекущаяСтраница = Элементы.СтраницаСлужебныеНастройки Тогда
		ИдентификаторРеглЗадания = ОбновлениеПользователейМобильногоПриложения; 
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаЗаказыТакси Тогда 
		ИдентификаторРеглЗадания = АвтоматическоеРаспределениеЗаказов;
	Иначе 
		ИдентификаторРеглЗадания = ИнформированиеОСрокеДействияЛицензий;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Идентификатор", ИдентификаторРеглЗадания);
	ПараметрыФормы.Вставить("Действие",      "Изменить");
	
	ОткрытьФорму("Обработка.РегламентныеИФоновыеЗадания.Форма.РегламентноеЗадание", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьРегламентноеЗаданиеОчисткиСообщенийВодителей(Команда)

	ИдентификаторРеглЗадания = ОчисткаСообщенийВодителей;

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Идентификатор", ИдентификаторРеглЗадания);
	ПараметрыФормы.Вставить("Действие",      "Изменить");
	
	ОткрытьФорму("Обработка.РегламентныеИФоновыеЗадания.Форма.РегламентноеЗадание", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусРегламентногоЗадания(Команда)
	
	ОбновитьДанныеРеглЗаданий();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьРегламентноеЗадание(Команда)
	
	Если Модифицированность Тогда 
		ТекстНСТР = НСтр("ru = 'Необходимо записать изменения.'; en = 'It is necessary to record the changes.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР);
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	
	ТекущаяСтраница = Элементы.Страницы.ТекущаяСтраница;
	Если ТекущаяСтраница = Элементы.СтраницаСлужебныеНастройки Тогда
		РеглЗадание             = ОбновлениеПользователейМобильногоПриложения;
		РеглЗаданиеНаименование = Нстр("ru = 'Обновление пользователей Мобильного приложения'; en = 'Updating Mobile App Users'");
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаЗаказыТакси Тогда 
		РеглЗадание             = АвтоматическоеРаспределениеЗаказов;
		РеглЗаданиеНаименование = Нстр("ru = 'Автоматическое распределение заказов'; en = 'Automatic order distribution'");
	Иначе
		РеглЗадание             = ИнформированиеОСрокеДействияЛицензий;
		РеглЗаданиеНаименование = Нстр("ru = 'Контроль срока действия лицензий мобильного приложения'; en = 'Monitoring the validity period of mobile application licenses'");
	КонецЕсли;

	ВыполнитьРегламентноеЗаданиеВручную(РеглЗадание, РеглЗаданиеНаименование);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьРегламентноеЗаданиеОчисткиСообщенийВодителей(Команда)
	
	Если Модифицированность Тогда 
		ТекстНСТР = НСтр("ru = 'Необходимо записать изменения.'; en = 'It is necessary to record the changes.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР);
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	
	РеглЗадание             = ОчисткаСообщенийВодителей;
	РеглЗаданиеНаименование = Нстр("ru = 'Очистка сообщений водителей'; en = 'Clearing of drivers messages'");

	ВыполнитьРегламентноеЗаданиеВручную(РеглЗадание, РеглЗаданиеНаименование);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключитьЗакрытьСоединение(Команда)
	Если НЕ ЗначениеЗаполнено(ЛогинОблачногоСервера) Тогда 
		ТекстОшибки = НСтр("ru='Невозможно подключиться к облачному серверу. Для подключения заполните логин.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки,,"ЛогинОблачногоСервера");
		Возврат;
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ПарольОблачногоСервера) Тогда 
		ТекстОшибки = НСтр("ru='Невозможно подключиться к облачному серверу. Для подключения заполните пароль.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки,,"ПарольОблачногоСервера");
		Возврат;
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ApiKey) Тогда 
		ТекстОшибки = НСтр("ru='Невозможно подключиться к облачному серверу. Для подключения заполните API-ключ.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки,,"ApiKey");
		Возврат;
	КонецЕсли;
	Если Элементы.ПодключитьЗакрытьСоединение.Заголовок = Нстр("ru = 'Подключить'; en = 'Connect'")
		И Модифицированность Тогда
		ТекстНСТР = НСтр("ru = 'Перед открытием соединения необходимо записать настройки. Продолжить?'; en = 'Before opening a connection, you need to write down the settings. Continue?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ПодключитьЗакрытьСоединениеЗавершение", ЭтотОбъект), ТекстНСТР, РежимДиалогаВопрос.ОКОтмена);
	Иначе
		Если Элементы.ПодключитьЗакрытьСоединение.Заголовок = Нстр("ru = 'Подключить'; en = 'Connect'") Тогда
			Записать(Неопределено);
		КонецЕсли;
		уатМобильноеПриложениеВодителяСерверREST.ПодключитьЗакрытьСоединениеСервер(,ApiKey, ИмяПользователяИнформационнойБазы);
		ПолучитьСостояниеСоединенияОбработчикОжидания(); 
		ChangeApiKey = Ложь; 
		Записать(Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПривязатьНовыйAPIключ(Команда)   
	ТекстНСТР = НСтр("ru = 'Вы собираетесь привязать новый API-ключ к этой базе. 
                          |Последствия: если этот ключ уже используется в другой информационной базе — работа мобильного приложения в той базе будет заблокирована для всех водителей. Лицензии останутся привязаны к вашей организации и не пропадут. После успешной привязки водители смогут работать только с этой базой по этому ключу. 
                          |Продолжить?'");
	ПоказатьВопрос(Новый ОписаниеОповещения("ПривязатьНовыйAPIключЗавершение", ЭтотОбъект), ТекстНСТР, РежимДиалогаВопрос.ОКОтмена);
КонецПроцедуры

&НаКлиенте
Процедура ПривязатьНовыйAPIключЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт  
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.ОК Тогда
		ChangeApiKey = Истина; 
		ПодключитьЗакрытьСоединение(Неопределено);
	КонецЕсли;
КонецПроцедуры   

&НаКлиенте
Процедура ПодключитьЗакрытьСоединениеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт  
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.ОК Тогда
		Попытка
			Записать(Неопределено);
		Исключение
			Возврат;
		КонецПопытки;
		уатМобильноеПриложениеВодителяСерверREST.ПодключитьЗакрытьСоединениеСервер(,ApiKey, ИмяПользователяИнформационнойБазы);
		ПолучитьСостояниеСоединенияОбработчикОжидания(); 
		ChangeApiKey = Ложь; 
		Записать(Неопределено);
	КонецЕсли;
КонецПроцедуры   

&НаСервере
Процедура ПолучитьСостояниеСоединения() 
	Если НЕ ИспользоватьОблачныйВриантРаботы Тогда
		Возврат;
	КонецЕсли;
	
	ТекСостояниеСоединения = уатМобильноеПриложениеВодителяСерверREST.ПолучитьСостояниеСоединения();
	Если ТекСостояниеСоединения = "Открыто"
		ИЛИ ТекСостояниеСоединения = "Открывается" Тогда
		Элементы.ПодключитьЗакрытьСоединение.Заголовок = Нстр("ru = 'Отключить'; en = 'Disable'");
	Иначе
		Элементы.ПодключитьЗакрытьСоединение.Заголовок = Нстр("ru = 'Подключить'; en = 'Connect'");
	КонецЕсли; 
	ОбработчикОжидания = Ложь;
	Элементы.WebSocket.Доступность = Ложь;
	Элементы.ДекорацияОписаниеWebSocket.Видимость = Истина;

	СообщенияОбОшибках = "";
	Если ТекСостояниеСоединения = "Открыто" Тогда
		СостояниеСоединения = "Открыто";
	ИначеЕсли ТекСостояниеСоединения = "Открывается" Тогда
		СообщенияОбОшибках = ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекЗагрузить("уатВодительУАТ", "СообщенияОбОшибках", "",, "уатВодительУАТ");
		СостояниеСоединения = "Открывается";  
        ОбработчикОжидания = Истина;
	ИначеЕсли ТекСостояниеСоединения = "Закрыто" Тогда
		СообщенияОбОшибках = ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекЗагрузить("уатВодительУАТ", "СообщенияОбОшибках", "",, "уатВодительУАТ");
		СостояниеСоединения = "Закрыто";
		Элементы.WebSocket.Доступность = Истина;
		Элементы.ДекорацияОписаниеWebSocket.Видимость = Ложь;
	ИначеЕсли ТекСостояниеСоединения = "Закрывается" Тогда
		СообщенияОбОшибках = ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекЗагрузить("уатВодительУАТ", "СообщенияОбОшибках", "",, "уатВодительУАТ");
		СостояниеСоединения = "Закрывается";
		ОбработчикОжидания = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(СообщенияОбОшибках) Тогда
		уатМобильноеПриложениеВодителяСерверREST.СохранитьСообщенияОбОшибках(""); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщенияОбОшибках); 
		
		Если ТекСостояниеСоединения = "Открывается" Тогда
			уатМобильноеПриложениеВодителяСерверREST.ПодключитьЗакрытьСоединениеСервер(,ApiKey, ИмяПользователяИнформационнойБазы);
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСостояниеСоединенияОбработчикОжидания()
	Попытка
		ОтключитьОбработчикОжидания("ПолучитьСостояниеСоединенияОбработчикОжидания");
	Исключение
	КонецПопытки;
	ПолучитьСостояниеСоединения();
	Если ОбработчикОжидания Тогда
		ПодключитьОбработчикОжидания("ПолучитьСостояниеСоединенияОбработчикОжидания", 1);
	КонецЕсли;
КонецПроцедуры

