&НаСервереБезКонтекста
Функция _ИдентификаторСеанса() 

	Адрес = НРег(ПоместитьВоВременноеХранилище(Неопределено));	
	Разделитель = НРег("seanceId=");
	Позиция = Найти(Адрес, Разделитель);
	Длина = 36;
	
	Если Разделитель <> 0 Тогда
		Идентификатор = Сред(Адрес, Позиция + СтрДлина(Разделитель), Длина);
	Иначе
		Идентификатор = Неопределено;
	КонецЕсли;
	
	Возврат Идентификатор; 
	
КонецФункции

