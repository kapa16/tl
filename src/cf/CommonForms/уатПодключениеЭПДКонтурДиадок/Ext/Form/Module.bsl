&НаКлиенте
Функция _ТипКлиента()
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	
	#Если ТолстыйКлиентОбычноеПриложение Тогда
		Результат = "ordinary";		
	#ИначеЕсли ТолстыйКлиентУправляемоеПриложение Тогда
		Результат = "thick";	
	#ИначеЕсли ТонкийКлиент Тогда
		Результат = "thin";
	#ИначеЕсли ВебКлиент Тогда
		Результат = "web";
	#ИначеЕсли МобильныйКлиент ИЛИ МобильноеПриложениеКлиент Тогда
		Результат = "mobClient";	
	#Иначе
		Возврат Неопределено;	
	#КонецЕсли
	
	Если Найти(Строка(СистемнаяИнформация.ТипПлатформы), "64") Тогда
		Результат = Результат + "64";	
	Иначе
		Результат = Результат + "32";	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция _РежимСоединения()
	
	СтрокаСоединения = НРег(СтрокаСоединенияИнформационнойБазы());
	
	Разделитель = Найти(СтрокаСоединения, "=");
	Если Разделитель <> 0 Тогда
		Режим = Лев(СтрокаСоединения, Разделитель - 1);
	Иначе
		Режим = Неопределено;
	КонецЕсли;
	
	Возврат Режим;
	
КонецФункции

