	НаборКонстант.уатАдресСервисаRarusVRP_уэ = СокрЛП(НаборКонстант.уатАдресСервисаRarusVRP_уэ);
	НаборКонстант.уатКлючСервисаRarusVRP_уэ = СокрЛП(НаборКонстант.уатКлючСервисаRarusVRP_уэ);
	
