
#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатЗаявкаГУ12") Тогда
		Организация = ДанныеЗаполнения.Организация;
		СтанцияОтправления = ДанныеЗаполнения.СтанцияОтправления;
		Грузоотправитель = ДанныеЗаполнения.Грузоотправитель;
		ЗаявкаГУ12 = ДанныеЗаполнения.Ссылка;
		Для каждого ТекГруз Из ДанныеЗаполнения.Груз Цикл
			НоваяСтрока = Груз.Добавить();
			НоваяСтрока.Заказ                   = ТекГруз.Заказ;
			НоваяСтрока.КоличествоВагонов       = ТекГруз.КоличествоВагонов;
			НоваяСтрока.ГрузовоеМесто           = ТекГруз.ГрузовоеМесто;
			НоваяСтрока.КодГруза                = ТекГруз.КодГруза;
			НоваяСтрока.Вес                     = ТекГруз.Вес;
			НоваяСтрока.ВидТранспортнойУпаковки = ТекГруз.ВидТранспортнойУпаковки;
			НоваяСтрока.КоличествоМест          = 1;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти