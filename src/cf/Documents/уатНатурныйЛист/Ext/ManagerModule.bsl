#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.Печать

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.уатНатурныйЛист";
	КомандаПечати.Идентификатор = "НатурныйЛист";
	КомандаПечати.Представление = НСтр("en='Routing list';ru='Натурный лист'");
	КомандаПечати.Порядок = 1;
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.уатПровеска";
	КомандаПечати.Идентификатор = "АктПеревески";
	КомандаПечати.Представление = НСтр("ru = 'Акт перевески'; en = 'Reweighing Act'");
	КомандаПечати.Порядок = 2;
	
КонецПроцедуры

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//  ПараметрыПечати - Структура - дополнительные настройки печати;
//  КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы (выходной параметр).
//  ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                            представление - имя области в которой был выведен объект (выходной
//                                                            параметр);
//  ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов (выходной
//                                            параметр).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если НЕ уатОбщегоНазначенияСервер.РазрешениеПечатиНепроведенногоДокумента(МассивОбъектов) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "НатурныйЛист") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "НатурныйЛист",
			"Натурный лист", ПечатьНатруныйЛист(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
	КонецЕсли;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.Печать

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область Печать

Функция ПечатьНатруныйЛист(МассивОбъектов, ОбъектыПечати, ПараметрыПечати=Неопределено)
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_НатурныйЛист";
	ТабличныйДокумент.ОриентацияСтраницы   = ОриентацияСтраницы.Ландшафт;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	уатНатурныйЛист.Ссылка КАК Ссылка,
	|	уатНатурныйЛист.Номер КАК Номер,
	|	уатНатурныйЛист.Дата КАК Дата,
	|	уатНатурныйЛист.СтанцияОтправления.Код КАК СтанцияФормирования,
	|	уатНатурныйЛист.СтанцияНазначения.Код КАК Станция,
	|	уатНатурныйЛист.НомерСостава КАК НомерСостава,
	|	уатНатурныйЛист.ГоловаХвост КАК ГоловаХвост,
	|	ДЕНЬ(уатНатурныйЛист.ДатаОтправления) КАК Число,
	|	МЕСЯЦ(уатНатурныйЛист.ДатаОтправления) КАК Месяц,
	|	ЧАС(уатНатурныйЛист.ДатаОтправления) КАК Часы,
	|	МИНУТА(уатНатурныйЛист.ДатаОтправления) КАК Минуты,
	|	уатНатурныйЛист.УсловнаяДлина КАК УсловнаяДлина,
	|	уатНатурныйЛист.МассаБрутто КАК МассаБрутто,
	|	уатНатурныйЛист.КодПрикрытия КАК КодПрикрытия,
	|	уатНатурныйЛист.ИндексНегабаритности КАК ИндексНегабаритности,
	|	ВЫБОР
	|		КОГДА уатНатурныйЛист.Живность
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Живность,
	|	уатНатурныйЛист.Маршрут КАК Маршрут,
	|	уатНатурныйЛистВагоны.НомерСтроки КАК НомерСтроки,
	|	уатНатурныйЛистВагоны.НомерВагона КАК НомерВагона,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.КодСобственника, """") КАК КодСобственника,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.МассаГруза, 0) КАК МассаГруза,
	|	уатНатурныйЛистВагоны.СтанцияНазначенияВагона.Код КАК СтанцияНазначения,
	|	уатНатурныйЛистВагоны.КодГруза КАК КодГруза,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.КодПолучателя, """") КАК КодПолучателя,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.ОсобыеОтметки, """") КАК ОсобыеОтметки,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.КоличествоЗПУ, 0) КАК КоличествоЗПУ,
	|	ЕСТЬNULL(уатНатурныйЛистВагоны.КоличествоКонтейнеров, """") КАК КоличествоКонтейнеров,
	|	уатНатурныйЛистВагоны.ВыходнаяПограничнаяСтанция.Код КАК ВыходнаяПограничнаяСтанция,
	|	уатНатурныйЛистВагоны.ТараВагона КАК ТараВагона,
	|	уатНатурныйЛистВагоны.Примечание КАК Примечание,
	|	уатНатурныйЛист.ДатаОтправления КАК ДатаОтправления,
	|	уатНатурныйЛист.Организация КАК Организация,
	|	уатНатурныйЛист.Подразделение.Наименование КАК ПодразделениеНаименование,
	|	уатНатурныйЛист.НомерПоезда КАК НомерПоезда
	|ИЗ
	|	Документ.уатНатурныйЛист КАК уатНатурныйЛист
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатНатурныйЛист.Вагоны КАК уатНатурныйЛистВагоны
	|		ПО уатНатурныйЛист.Ссылка = уатНатурныйЛистВагоны.Ссылка
	|ГДЕ
	|	уатНатурныйЛист.Ссылка В(&МассивОбъектов)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(НомерСостава),
	|	МАКСИМУМ(ГоловаХвост),
	|	МАКСИМУМ(Число),
	|	МАКСИМУМ(Месяц),
	|	МАКСИМУМ(Часы),
	|	МАКСИМУМ(Минуты),
	|	МАКСИМУМ(УсловнаяДлина),
	|	МАКСИМУМ(МассаБрутто),
	|	МАКСИМУМ(КодПрикрытия),
	|	МАКСИМУМ(ИндексНегабаритности),
	|	МАКСИМУМ(Живность),
	|	МАКСИМУМ(ДатаОтправления),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(ПодразделениеНаименование),
	|	МАКСИМУМ(НомерПоезда)
	|ПО
	|	Ссылка";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ДопНомер = 1;
	ПервыйДокумент = Истина;
	Пока Выборка.Следующий() Цикл
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.уатНатурныйЛист.НатурныйЛист");
		
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьЗаголовок");
		
		НаименованиеОрагнизации = уатОбщегоНазначенияТиповыеСервер.ОписаниеОрганизации(
		уатОбщегоНазначенияСервер.СведенияОЮрФизЛице(Выборка.Организация),
		"НаименованиеДляПечатныхФорм");
		
		
		Заголовок = НСтр("ru = 'Натурный лист поезда №%1 от %2'; en = 'Detailed list of train No.%1 from %2'");
		Заголовок = СтрЗаменить(Заголовок,"%1", Выборка.Номер);
		ПредставлениеДаты = Формат(Выборка.Дата, "ДФ='dd MMMM yyyy ""г.""'");
		Заголовок = СтрЗаменить(Заголовок, "%2", ПредставлениеДаты);
		ОбластьМакета.Параметры.НомерПоезда = Выборка.НомерПоезда;
		//ОбластьМакета.Параметры.Организация = НаименованиеОрагнизации;
		//ОбластьМакета.Параметры.Подразделение = Выборка.ПодразделениеНаименование;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьТаблицаШапка");
		
		ЗаполнитьЗначенияСвойств(ОбластьМакета.Параметры, Выборка);
		ПредставлениеМесяца = Формат(Выборка.ДатаОтправления,"ДФ=MMMM");
		ОбластьМакета.Параметры.Месяц = ПредставлениеМесяца;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьСтрокаТаблицы");
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ОбластьМакета.Параметры, ВыборкаДетальныеЗаписи);
			ТабличныйДокумент.Вывести(ОбластьМакета);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли