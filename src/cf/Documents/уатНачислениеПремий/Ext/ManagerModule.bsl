// Формирует печатную форму Т-11
//
// Параметры:
//  ИмяМакета - табличный документ
Функция уатПечать_Т11(МассивОбъектов, ОбъектыПечати) Экспорт
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_НачислениеПремий";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.уатНачислениеПремий.ПФ_MXL_Т11");
	
	мВалютаУпрУчета = Константы.ВалютаУправленческогоУчета.Получить();
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		Если НЕ ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Приказ");
		
		СписокТребуемыхПараметров = "НаименованиеДляПечатныхФорм, ОКПО";
		СведенияОбОрганизации     = уатОбщегоНазначенияСервер.СведенияОЮрФизЛице(ТекущийДокумент.Организация);
		ОбластьМакета.Параметры.РаботаОрганизацияНаименованиеСокращенное =
			уатОбщегоНазначенияТиповыеСервер.ОписаниеОрганизации(СведенияОбОрганизации, СписокТребуемыхПараметров);
		ОбластьМакета.Параметры.РаботаОрганизацияКодПоОКПО = СведенияОбОрганизации.КодПоОКПО;
		
		ПечатьПрефиксовВключена = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(ТекущийДокумент.Организация,
			ПредопределенноеЗначение("ПланВидовХарактеристик.уатПраваИНастройки.ВыводитьПрефиксПриПечати"));
		Если ПечатьПрефиксовВключена Тогда
			ОбластьМакета.Параметры.СсылкаНаОбъектНомерНаПечать = ТекущийДокумент.Номер;
		Иначе
			ОбластьМакета.Параметры.СсылкаНаОбъектНомерНаПечать = уатОбщегоНазначенияКлиентСервер.НомерДокументаНаПечать(
				ТекущийДокумент.Номер, Истина, Истина);
		КонецЕсли;
		
		ОбластьМакета.Параметры.СсылкаНаОбъектДатаНаПечать = ТекущийДокумент.Дата;
		
		РеквизитыВодителя = уатОбщегоНазначения.уатПрочитатьРеквизитыВодителя(
			ТекущийДокумент.Сотрудник, ТекущийДокумент.Дата, ТекущийДокумент.Организация);
		ДолжностьВодителя = СокрЛП(РеквизитыВодителя.Должность);
		
		Если ЗначениеЗаполнено(ТекущийДокумент.Сотрудник.ФизическоеЛицо) Тогда
			ФИОФизЛица = уатОбщегоНазначения.уатФИОФизЛица(ТекущийДокумент.Сотрудник.ФизическоеЛицо, ТекущийДокумент.Дата);
			
			Если ФИОФизЛица = Неопределено ИЛИ НЕ ЗначениеЗаполнено(ФИОФизЛица.Фамилия) Тогда
				ФИОПолные = ТекущийДокумент.Сотрудник.Наименование;
			Иначе
				ФИОПолные = ФИОФизЛица.Фамилия + " " + ФИОФизЛица.Имя + " " + ФИОФизЛица.Отчество;
			КонецЕсли;
			Если ТекущийДокумент.Сотрудник.ФизическоеЛицо.Пол = Перечисления.ПолФизическогоЛица.Мужской Тогда
				мПол = 1;
			ИначеЕсли ТекущийДокумент.Сотрудник.ФизическоеЛицо.Пол = Перечисления.ПолФизическогоЛица.Женский Тогда
				мПол = 2;
			Иначе
				мПол = Неопределено;
			КонецЕсли;

			ФИОВодителя = СклонениеПредставленийОбъектов.ПросклонятьФИО(СокрЛП(ФИОПолные), 2,, мПол);
		Иначе
			ФИОВодителя = СклонениеПредставленийОбъектов.ПросклонятьФИО(СокрЛП(ТекущийДокумент.Сотрудник.Наименование), 2,, Неопределено);
		КонецЕсли;
		ОбластьМакета.Параметры.ЛичныеДанныеФИОФамилияИмяОтчествоВВинительномПадеже = ФИОВодителя;
		ОбластьМакета.Параметры.РаботаДолжность = ДолжностьВодителя;
		ОбластьМакета.Параметры.РаботаСотрудникТабельныйНомерНаПечать = ТекущийДокумент.Сотрудник.Код;
		ОбластьМакета.Параметры.РаботаПодразделениеНаПечать = ТекущийДокумент.Подразделение;
		ОбластьМакета.Параметры.СсылкаНаОбъектМотивПоощрения = ТекущийДокумент.МотивПоощрения;
		ОбластьМакета.Параметры.СсылкаНаОбъектВидПоощренияНаПечать = ТекущийДокумент.ВидПоощрения;
		ОбластьМакета.Параметры.ДанныеПоощренияСуммаПоощренияПрописью =
			уатОбщегоНазначенияТиповые.уатСформироватьСуммуПрописью(ТекущийДокумент.СуммаДокумента, мВалютаУпрУчета);
		ОбластьМакета.Параметры.ДанныеПоощренияРезультатНаПечать = уатОбщегоНазначенияТиповые.уатФорматСумм(
			ТекущийДокумент.СуммаДокумента, мВалютаУпрУчета);
		
		Руководители = уатОбщегоНазначенияТиповые.уатОтветственныеЛицаОрганизаций(
			ТекущийДокумент.Организация, ТекущийДокумент.Дата);
		ОбластьМакета.Параметры.СсылкаНаОбъектДолжностьРуководителя          = Руководители.РуководительДолжность;
		ОбластьМакета.Параметры.СсылкаНаОбъектРуководительРасшифровкаПодписи =
			уатОбщегоНазначенияТиповые.уатФамилияИнициалыФизЛица(Руководители.Руководитель);
		
		ТабДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура СформироватьТаблицаОсновныеНачисления(ДокументСсылка, СтруктураДополнительныеСвойства)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатПремияНачисления.Ссылка КАК Ссылка,
	|	уатПремияНачисления.Ссылка.ПериодНачисления КАК Период,
	|	уатПремияНачисления.Ссылка.ПериодНачисления КАК ПериодРегистрации,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	уатПремияНачисления.Ссылка.ПериодНачисления КАК БазовыйПериодНачало,
	|	уатПремияНачисления.Ссылка.ПериодНачисления КАК БазовыйПериодКонец,
	|	уатПремияНачисления.Ссылка.Организация КАК Организация,
	|	уатПремияНачисления.Ссылка.Подразделение КАК Подразделение,
	|	уатПремияНачисления.Ссылка.Сотрудник КАК Сотрудник,
	|	уатПремияНачисления.Начисление КАК ВидРасчета,
	|	СУММА(уатПремияНачисления.Сумма) КАК Результат,
	|	уатПремияНачисления.Тариф КАК Тариф,
	|	уатПремияНачисления.ТС КАК ТС
	|ИЗ
	|	Документ.уатНачислениеПремий.Начисления КАК уатПремияНачисления
	|ГДЕ
	|	уатПремияНачисления.Ссылка = &Док
	|
	|СГРУППИРОВАТЬ ПО
	|	уатПремияНачисления.Ссылка,
	|	уатПремияНачисления.Начисление,
	|	уатПремияНачисления.Ссылка.ПериодНачисления,
	|	уатПремияНачисления.Ссылка.Организация,
	|	уатПремияНачисления.Ссылка.Подразделение,
	|	уатПремияНачисления.Ссылка.Сотрудник,
	|	уатПремияНачисления.Тариф,
	|	уатПремияНачисления.Ссылка.ПериодНачисления,
	|	уатПремияНачисления.Ссылка.ПериодНачисления,
	|	уатПремияНачисления.Ссылка.ПериодНачисления,
	|	уатПремияНачисления.ТС");
	Запрос.УстановитьПараметр("Док", ДокументСсылка);
	мТаблица = Запрос.Выполнить().Выгрузить();
	
	флНачислятьПоПодразделениюСотрудника = НЕ уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(ДокументСсылка.Организация,
		ПланыВидовХарактеристик.уатПраваИНастройки.НачислятьЗарплатуПоПодразделениюДокумента);
	Если флНачислятьПоПодразделениюСотрудника Тогда
		РеквизитыВодителя = уатОбщегоНазначения.уатПрочитатьРеквизитыВодителя(
			ДокументСсылка.Сотрудник, ДокументСсылка.ПериодНачисления, ДокументСсылка.Организация);
		Для Каждого ТекСтрока Из мТаблица Цикл
			ТекСтрока.Подразделение = РеквизитыВодителя.ПодразделениеОрганизации;
		КонецЦикла;
	КонецЕсли;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОсновныхНачислений", мТаблица);
КонецПроцедуры

Процедура СформироватьТаблицаРасходы(ДокументСсылка, СтруктураДополнительныеСвойства)
	Если ПолучитьФункциональнуюОпцию("уатИспользоватьУчетДоходовИРасходов") = ЛОЖЬ Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатПремияНачисления.Ссылка КАК Регистратор,
	|	уатПремияНачисления.Ссылка.ПериодНачисления КАК Период,
	|	&СтатьяРасходовЗП КАК СтатьяРасходов,
	|	уатПремияНачисления.Ссылка.Организация КАК Организация,
	|	уатПремияНачисления.Ссылка.Подразделение КАК Подразделение,
	|	уатПремияНачисления.Ссылка.Сотрудник КАК Сотрудник,
	|	уатПремияНачисления.ТС КАК ТС,
	|	уатПремияНачисления.Сумма КАК СуммаУпр,
	|	0 КАК СуммаРегл
	|ИЗ
	|	Документ.уатНачислениеПремий.Начисления КАК уатПремияНачисления
	|ГДЕ
	|	уатПремияНачисления.Ссылка = &Док");
	Запрос.УстановитьПараметр("Док", ДокументСсылка);
	Запрос.УстановитьПараметр("СтатьяРасходовЗП", уатОбщегоНазначения.НайтиСтатьюЗатрат(ДокументСсылка.ПланЗатрат,
		Перечисления.уатВидыЗатрат.ОплатаТруда));
	ТаблицаРасходы = Запрос.Выполнить().Выгрузить();
	
	Для Каждого ТекСтрока Из ТаблицаРасходы Цикл
		ТекСтрока.СуммаРегл = уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(ТекСтрока.СуммаУпр,
			СтруктураДополнительныеСвойства.ВалютаУпрУчета, СтруктураДополнительныеСвойства.ВалютаРеглУчета,
			СтруктураДополнительныеСвойства.КурсУпр,        СтруктураДополнительныеСвойства.КурсРегл,
			СтруктураДополнительныеСвойства.КратностьУпр,   СтруктураДополнительныеСвойства.КратностьРегл,,
			ДокументСсылка);
	КонецЦикла;
		
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасходы", ТаблицаРасходы);
КонецПроцедуры

