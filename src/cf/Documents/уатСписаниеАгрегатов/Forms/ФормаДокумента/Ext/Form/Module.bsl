КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ДействиеПодбор(ИмяТабличнойЧасти)
	
	Если ИмяТабличнойЧасти = "Шины" Тогда
		Команда = "ПодборВТабличнуюЧастьШины";
	ИначеЕсли ИмяТабличнойЧасти = "Аккумуляторы" Тогда
		Команда = "ПодборВТабличнуюЧастьАккумуляторы";
	ИначеЕсли ИмяТабличнойЧасти =  "ПрочиеАгрегаты" Тогда
		Команда = "ПодборВТабличнуюЧастьПрочиеАгрегаты";
	КонецЕсли;
	СтруктураПараметровПодбора = Новый Структура();
	СтруктураПараметровПодбора.Вставить("Организация", Объект.Организация);
	СтруктураПараметровПодбора.Вставить("Команда", Команда);
	
	//СтруктураПараметровПодбора.Вставить("ПодбиратьУслуги", ЕстьУслуги);
	//СтруктураПараметровПодбора.Вставить("ОтборУслугПоСправочнику", Истина);
	
	ВременнаяДатаРасчетов = ?(НачалоДня(Объект.Дата) = НачалоДня(ТекущаяДата()), Неопределено, Объект.Дата);
	СтруктураПараметровПодбора.Вставить("ДатаРасчетов", ВременнаяДатаРасчетов);
	СтруктураПараметровПодбора.Вставить("Склад", Объект.Склад);
	
	уатОбщегоНазначенияТиповыеКлиент.уатОткрытьПодборАгрегатов(ЭтотОбъект, СтруктураПараметровПодбора);
	
КонецПроцедуры //

// Производит заполнение документа переданными из формы подбора данными.
//
// Параметры:
//  ТабличнаяЧасть    - табличная часть, в которую надо добавлять подобранную позицию агрегата;
//  ЗначениеВыбора    - структура, содержащая параметры подбора.
//
&НаКлиенте
Процедура ОбработкаПодбора(ИмяТабличнойЧасти, ЗначениеВыбора)
	
	Перем МассивАгрегатов, Модель;
	
	// Получим параметры подбора из структуры подбора.
	ЗначениеВыбора.Свойство("МассивАгрегатов",МассивАгрегатов);
	
	Для каждого Агрегат Из МассивАгрегатов Цикл
		
		// Ищем выбранную позицию в таблице подобранных агрегатов.
		// Если найдем - выдаем сообщение; не найдем - добавим новую строку.
		СтруктураОтбора = Новый Структура("СерияНоменклатуры", Агрегат);
		
		МассивСтрок = Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураОтбора);
		Если МассивСтрок.Количество() = 0 Тогда
			СтрокаТабличнойЧасти = Неопределено;
		Иначе
			СтрокаТабличнойЧасти = МассивСтрок[0];
		КонецЕсли;
		
		Если СтрокаТабличнойЧасти <> Неопределено Тогда
			// Нашли, сообщаем.
			ТекстНСТР = СтрШаблон(НСтр("en='Сar part %1 was added earlier!';ru='Агрегат ""%1"" был добавлен ранее!'"), Строка(Агрегат));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР);
		Иначе
			// Не нашли - добавляем новую строку.
			СтрокаТабличнойЧасти = Объект[ИмяТабличнойЧасти].Добавить();
			СтрокаТабличнойЧасти.СерияНоменклатуры	  = Агрегат;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры //

&НаКлиенте
Процедура УстановитьВидимость()
	
	Элементы.ПланЗатрат.Видимость = ИспользоватьУчетЗатрат();
	Элементы.СкладТоваров.Доступность = ВозвратНаСклад;
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИспользоватьУчетЗатрат()
	Возврат ПолучитьФункциональнуюОпцию("уатИспользоватьУчетДоходовИРасходов");
КонецФункции

&НаСервере
Процедура КонтрольОприходованияТоваров()
	
	ДокументОприходование = НайтиОприходованиеТоваровНаОснованииСписанияАгрегатов(Объект.Ссылка);
	Если НЕ ЗначениеЗаполнено(ДокументОприходование) Тогда
		Возврат;
	КонецЕсли;
	
	КорректировкаОприходованиеМатериалов = Неопределено;
	
	// Проверка соответствия номенклатуры в текущем документе и документе-основании
	СписаниеАгрегатовОбъект = РеквизитФормыВЗначение("Объект");
	тблСписанияСвернутая = Документы.уатСписаниеАгрегатов.ПолучитьМатериалыДляОприходованияНаСклад(СписаниеАгрегатовОбъект);
	тблСписанияСвернутая.Свернуть("Номенклатура, ЕдиницаИзмерения", "Количество");
	тблОприходованияСвернутая = ДокументОприходование.Товары.Выгрузить();
	тблОприходованияСвернутая.Свернуть("Номенклатура, ЕдиницаИзмерения", "Количество");
	Если НЕ ОбщегоНазначения.КоллекцииИдентичны(тблСписанияСвернутая, тблОприходованияСвернутая) Тогда
		КорректировкаОприходованиеМатериалов = ДокументОприходование;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиОприходованиеТоваровНаОснованииСписанияАгрегатов(СписаниеАгрегатов)
	Если НЕ ЗначениеЗаполнено(СписаниеАгрегатов) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Рез = Неопределено;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	уатОприходованиеТоваров.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.уатОприходованиеТоваров КАК уатОприходованиеТоваров
	|ГДЕ
	|	НЕ уатОприходованиеТоваров.ПометкаУдаления
	|	И уатОприходованиеТоваров.ДокументОснование = &ДокументОснование");
	Запрос.УстановитьПараметр("ДокументОснование", СписаниеАгрегатов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Рез = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

&НаКлиенте
Процедура СоздатьОприходованиеТоваров(ПараметрыЗаписи)
	
	Если НЕ ЗначениеЗаполнено(Объект.СкладТоваров) ИЛИ НЕ Объект.Проведен
		ИЛИ ЗначениеЗаполнено(НайтиОприходованиеТоваровНаОснованииСписанияАгрегатов(Объект.Ссылка)) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Основание", Объект.Ссылка);
	ОткрытьФорму("Документ.уатОприходованиеТоваров.ФормаОбъекта", ПараметрыФормы);
		
КонецПроцедуры

&НаСервере
Процедура СкорректироватьОприходованиеТоваров()
	
	Если НЕ ЗначениеЗаполнено(КорректировкаОприходованиеМатериалов) Тогда
		Возврат;
	КонецЕсли;
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ОприходованиеМатериаловОбъект = КорректировкаОприходованиеМатериалов.ПолучитьОбъект();
	ОприходованиеМатериаловОбъект.Заполнить(ДокументОбъект);
	Попытка
		ОприходованиеМатериаловОбъект.Записать(?(ОприходованиеМатериаловОбъект.Проведен,
			РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		КорректировкаОприходованиеМатериалов = Неопределено;
	Исключение
		уатОбщегоНазначенияТиповые.СообщитьОбОшибке("Не удалось записать документ " + ОприходованиеМатериаловОбъект.Ссылка
			+ ": " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти
