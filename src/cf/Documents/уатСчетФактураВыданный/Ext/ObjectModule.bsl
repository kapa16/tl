#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

	
#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	уатОбщегоНазначенияСервер.Заполнить(ЭтотОбъект, ДанныеЗаполнения);
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатРеализацияУслуг") Тогда
		// Заполнение шапки
		Контрагент         = ДанныеЗаполнения.Контрагент;
		ДоговорКонтрагента = ДанныеЗаполнения.ДоговорКонтрагента;
		ВалютаДокумента    = ДанныеЗаполнения.ВалютаДокумента;
		Комментарий        = ДанныеЗаполнения.Комментарий;
		Организация        = ДанныеЗаполнения.Организация;
		Подразделение      = ДанныеЗаполнения.Подразделение;
		Ответственный      = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
			ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнойОтветственный");
		
		ДокументОснование  = ДанныеЗаполнения.Ссылка;
		ВидСчетаФактуры    = Перечисления.ВидСчетаФактурыВыставленного.НаРеализацию;
		Выставлен          = Истина;
		ДатаВыставления    = Дата;
		
		Дата = ДокументОснование.Дата; // дата СФ равна дате документа-основания
		
		СуммаНДС           = ДанныеЗаполнения.Услуги.Итог("СуммаНДС");
		СуммаДокумента     = ДанныеЗаполнения.СуммаДокумента;
		
		ДокументыОснования.Очистить();
		НоваяСтрокаОснования = ДокументыОснования.Добавить();
		НоваяСтрокаОснования.ДокументОснование = ДокументОснование;
		
		МассивОснований	= Новый Массив;
		МассивОснований.Добавить(ДокументОснование);
		ПлатежноРасчетныеДокументы.Загрузить(
			Документы.уатСчетФактураВыданный.ДатыНомераПлатежноРасчетныхДокументов(МассивОснований));
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	МассивНепроверяемыхРеквизитов = Новый Массив;
	Если ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.НаРеализацию
		ИЛИ ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.Корректировочный Тогда
        МассивНепроверяемыхРеквизитов.Добавить("ДокументОснование");
		МассивНепроверяемыхРеквизитов.Добавить("ДоговорКонтрагента");
	КонецЕсли;
		
	Если НЕ Выставлен Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ДатаВыставления");
		МассивНепроверяемыхРеквизитов.Добавить("КодСпособаВыставления");
	КонецЕсли;
	
	Если ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.НаРеализацию
		ИЛИ ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.Корректировочный Тогда

		Если ДокументыОснования.Количество() = 0 Тогда
			ТекстСообщения = НСтр("ru = 'Не введено ни одной строки в список ""Документы-основания"" Счета-фактуры'; en = 'No lines have been entered into the ""Supporting Documents"" list of the Invoice'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "НадписьВыбор",, Отказ);			
		КонецЕсли;
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	// Взято из БП, для СФ по Реализации первый символ префикса = "0"
	Префикс = "0";
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Заголовок = уатОбщегоНазначенияТиповые.уатПредставлениеДокументаПриПроведении(ЭтотОбъект);
	
	// проверка на существование уже созданного документа
	мсвСозданныеСФ = НайтиСозданныеРанееСФ();
	Для Каждого Соотв Из мсвСозданныеСФ Цикл
		ТекстНСТР = СтрШаблон("На основании документа %1 уже был введен %2!",
			Соотв.Реализация, Соотв.СФ);
		уатОбщегоНазначенияТиповые.СообщитьОбОшибке(ТекстНСТР, Отказ, Заголовок);
	КонецЦикла;
	
	Если НЕ Отказ Тогда
		РассчитатьСуммуДокумента();
	КонецЕсли;		
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ДокументОснование = Неопределено;
	ДокументыОснования.Очистить();
	ПлатежноРасчетныеДокументы.Очистить();
	Выставлен = Ложь;
	ДатаВыставления = '00010101';
	ЗагруженИзТиповойКонфигурации = Ложь;
	СуммаДокумента = 0;
	СуммаНДС = 0;
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция НайтиСозданныеРанееСФ()
	Рез = Новый Массив;
	
	мсвРеализации = Новый Массив;
	Для Каждого ТекСтрока Из ДокументыОснования Цикл
		Если ЗначениеЗаполнено(ТекСтрока.ДокументОснование) И мсвРеализации.Найти(ТекСтрока.ДокументОснование) = Неопределено Тогда
			мсвРеализации.Добавить(ТекСтрока.ДокументОснование);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекРеализация Из мсвРеализации Цикл
		ТекСФ = Документы.уатРеализацияУслуг.НайтиСчетФактуруРеализации(ТекРеализация);
		Если ЗначениеЗаполнено(ТекСФ) И ТекСФ <> Ссылка Тогда
			Рез.Добавить(Новый Структура("Реализация, СФ", ТекРеализация, ТекСФ));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Рез;
КонецФункции

Процедура РассчитатьСуммуДокумента()
	мСуммаДокумента = 0;
	мСуммаНДС       = 0;
	Для Каждого ТекОснование Из ДокументыОснования Цикл
		Если НЕ ЗначениеЗаполнено(ТекОснование.ДокументОснование) Тогда
			Продолжить;
		КонецЕсли; 
			
		мСуммаДокумента = мСуммаДокумента + ТекОснование.ДокументОснование.СуммаДокумента;
		мСуммаНДС       = мСуммаНДС       + ТекОснование.ДокументОснование.Услуги.Итог("СуммаНДС");
	КонецЦикла;
		
	СуммаДокумента = мСуммаДокумента;
	СуммаНДС       = мСуммаНДС;
КонецПроцедуры

#КонецОбласти


#КонецЕсли