&НаКлиенте
Процедура УстановитьВидимость()
	
	КоличествоОснований = Объект.ДокументыОснования.Количество();
	флЕстьНесопоставленныеОснования = Ложь;
	Для Каждого ТекОснование Из Объект.ДокументыОснования Цикл
		Если НЕ ЗначениеЗаполнено(ТекОснование.ДокументОснование)
			И ЗначениеЗаполнено(ТекОснование.ДокументОснованиеТиповаяКонфигурация) Тогда
			флЕстьНесопоставленныеОснования = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если Объект.ЗагруженИзТиповойКонфигурации И флЕстьНесопоставленныеОснования Тогда
		Если КоличествоОснований = 0 Тогда
			НадписьДокументыОснования = "Не указаны";
		Иначе
			Предмет = "документ,документа,документов,м,,,,0";
			НадписьДокументыОснования = ОбщегоНазначенияБПКлиентСервер.ПредставлениеСсылкиПредмета(
				Предмет, "док", Объект.ДокументыОснования[0].ДокументОснованиеТиповаяКонфигурация, КоличествоОснований);
		КонецЕсли;
		
		Элементы.НадписьВыбор.Видимость               = Ложь;
		Элементы.ГруппаНадписьОдноОснование.Видимость = Ложь;
		Элементы.НадписьДокументыОснования.Видимость  = Истина;
		Элементы.ГруппаЗагруженИзТиповой.Видимость    = Истина;
		
		ТолькоПросмотр = Истина;
	Иначе
		Если КоличествоОснований = 0 Тогда
			НадписьВыбор = НСтр("ru = 'Выбор'; en = 'Choice'");
		ИначеЕсли КоличествоОснований > 1 Тогда
			Предмет = "документ,документа,документов,м,,,,0";
			НадписьДокументыОснования = ОбщегоНазначенияБПКлиентСервер.ПредставлениеСсылкиПредмета(
				Предмет, "док", Объект.ДокументыОснования[0].ДокументОснование, КоличествоОснований);
		КонецЕсли;
		
		Элементы.НадписьВыбор.Видимость               = КоличествоОснований = 0;
		Элементы.ГруппаНадписьОдноОснование.Видимость = КоличествоОснований = 1;
		Элементы.НадписьДокументыОснования.Видимость  = КоличествоОснований > 1;
		Элементы.ГруппаЗагруженИзТиповой.Видимость    = Ложь;
	КонецЕсли;
	
	Элементы.ДатаВыставления.Доступность = Объект.Выставлен;
	Элементы.НомерИсправления.Видимость = ЗначениеЗаполнено(Объект.НомерИсправления);
	
	Элементы.ПлатежноРасчетныеДокументыНомерСчетаФактурыНаАванс.Видимость = (Объект.Дата >= Дата(2026, 01, 01));
	Элементы.ПлатежноРасчетныеДокументыДатаСчетаФактурыНаАванс.Видимость  = (Объект.Дата >= Дата(2026, 01, 01));
			
	ОтобразитьИтоги();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОснование()
	
	ЕстьОшибкиЗаполнения = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда 
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
			"Поле", "Заполнение", НСтр("ru = 'Организация'; en = 'Organization'"));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Организация", "Объект" , ЕстьОшибкиЗаполнения);
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
			"Поле", "Заполнение", НСтр("ru = 'Контрагент'; en = 'Counterparty'"));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Контрагент", "Объект" , ЕстьОшибкиЗаполнения);
	КонецЕсли;
	
	Если ЕстьОшибкиЗаполнения Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = ПолучитьСтруктуруПараметровФормы();
	ОткрытьФорму("Документ.уатСчетФактураВыданный.Форма.ФормаДокументыОснования",
		ПараметрыФормы,	ЭтаФорма);

КонецПроцедуры

&НаКлиенте
Функция ПолучитьСтруктуруПараметровФормы()
		
	ЗначенияЗаполнения 	= Новый Структура;
	Если Объект.ДокументыОснования.Количество() > 0 Тогда 
		ЗначенияЗаполнения.Вставить("СписокДокументовОснований", Новый СписокЗначений);
		Для Каждого СтрокаТаблицы Из Объект.ДокументыОснования Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы.ДокументОснование) Тогда
				ЗначенияЗаполнения.СписокДокументовОснований.Добавить(СтрокаТаблицы.ДокументОснование);
			Иначе
				ЗначенияЗаполнения.СписокДокументовОснований.Добавить(СтрокаТаблицы.ДокументОснованиеТиповаяКонфигурация);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	ЗначенияЗаполнения.Вставить("ТипСчетаФактуры", "Выданный");
	ЗначенияЗаполнения.Вставить("ВидСчетаФактуры", Объект.ВидСчетаФактуры);
	ЗначенияЗаполнения.Вставить("Исправление", ЗначениеЗаполнено(Объект.НомерИсправления));
	ЗначенияЗаполнения.Вставить("СчетФактура", Объект.Ссылка);
	
	ЗначениеОтбора = Новый Структура;
	ЗначениеОтбора.Вставить("Организация", Объект.Организация);
	ЗначениеОтбора.Вставить("Контрагент",  Объект.Контрагент);
	ЗначениеОтбора.Вставить("Договор",     Объект.ДоговорКонтрагента);
	ЗначениеОтбора.Вставить("Валюта",      Объект.ВалютаДокумента);
		
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения); 
	СтруктураПараметров.Вставить("Отбор", ЗначениеОтбора);
	
	Возврат СтруктураПараметров;
	
КонецФункции

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение)

	Объект.ДокументыОснования.Очистить();
	Объект.ДокументОснование = Неопределено;

	Объект.СуммаДокумента = 0;
	Объект.СуммаНДС       = 0;
	Если ВыбранноеЗначение.Количество() = 0 Тогда
		Объект.ПлатежноРасчетныеДокументы.Очистить();
	Иначе
		Для Каждого СтрокаСписка Из ВыбранноеЗначение Цикл
			Если СтрокаСписка.Значение.Пустая() Тогда
				Продолжить;
			КонецЕсли; 
			СтрокаТаблицы = Объект.ДокументыОснования.Добавить();
			СтрокаТаблицы.ДокументОснование = СтрокаСписка.Значение;
			
			Объект.СуммаДокумента = Объект.СуммаДокумента + СтрокаТаблицы.ДокументОснование.СуммаДокумента;
			Объект.СуммаНДС = Объект.СуммаНДС + СтрокаТаблицы.ДокументОснование.Услуги.Итог("СуммаНДС");
		КонецЦикла;
		
		Если Объект.ДокументыОснования.Количество() > 0 Тогда
			Объект.ДокументОснование = Объект.ДокументыОснования[0].ДокументОснование;
		КонецЕсли;
	
		ЗаполнитьДатыНомераПлатежноРасчетныхДокументов();
	КонецЕсли;
	
	УстановитьКодВидаОперацииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДатыНомераПлатежноРасчетныхДокументов()
	МассивОснований	= ОбщегоНазначения.ВыгрузитьКолонку(Объект.ДокументыОснования, "ДокументОснование", Истина);
	Объект.ПлатежноРасчетныеДокументы.Загрузить(
		Документы.уатСчетФактураВыданный.ДатыНомераПлатежноРасчетныхДокументов(МассивОснований));
КонецПроцедуры
	
&НаСервере
Процедура УстановитьКодВидаОперацииНаСервере(КодВидаОперацииОснования = Неопределено)
	СтруктураПараметров	= Новый Структура;
	СтруктураПараметров.Вставить("Дата",						Объект.Дата);
	СтруктураПараметров.Вставить("ВидСчетаФактуры",				Объект.ВидСчетаФактуры);
	СтруктураПараметров.Вставить("Исправление",					ЗначениеЗаполнено(Объект.НомерИсправления));
	СтруктураПараметров.Вставить("Контрагент",					Объект.Контрагент);
	СтруктураПараметров.Вставить("ДоговорКонтрагента",			Объект.ДоговорКонтрагента);
	СтруктураПараметров.Вставить("КодВидаОперации",				Объект.КодВидаОперации);
	СтруктураПараметров.Вставить("ДокументыОснования",			Объект.ДокументыОснования.Выгрузить(,"ДокументОснование"));
	
	Объект.КодВидаОперации	= Документы.уатСчетФактураВыданный.ПолучитьКодВидаОперации(СтруктураПараметров, КодВидаОперацииОснования);
КонецПроцедуры

// Формирует список кодов видов операций, актуальный на переданную дату.
//
// Параметры:
//   ЧастьЖурнала        - Перечисления.ЧастиЖурналаУчетаСчетовФактур - список различается
//                         для полученных и выставленных счетов-фактур.
//   СписокКодовОпераций - СписокЗначений - список выбора элемента формы, в который помещается
//                         формируемый список кодов видов операций.
//   Дата                - Дата - дата, на которую требуется получить список кодов видов операций.
//
&НаСервере
Процедура ЗаполнитьСписокКодовОпераций()
	
	Если Объект.Дата >= '20240401' Тогда
		// С 1 апреля 2024 года используется дополнительный код, рекомендованный в письме ФНС от 06.06.2024 № ЕА-4-3/6295@.
		ВерсияКодовВидовОпераций = 5;
	ИначеЕсли Объект.Дата >= '20180101' Тогда
		// С 1 января 2018 года используются дополнительные коды, рекомендованные в письмах ФНС:
		// N СД-4-3/10@ от 09.01.2018;
		// N СД-4-3/532@ от 16.01.2018;
		// N СД-4-3/480@ от 16.01.2018.
		ВерсияКодовВидовОпераций = 4;
	ИначеЕсли Объект.Дата >= '20160701' Тогда
		// С 1 июля 2016 года действует перечень, 
		// утвержденный приказом ФНС от 14.03.2016 N ММВ-7-3/136@.
		ВерсияКодовВидовОпераций = 3;
	ИначеЕсли Объект.Дата >= '20150101' Тогда
		// С 1 января 2015 года действует перечень,
		// утвержденный письмом ФНС от 22.01.2015 N ГД-4-3/794@.
		ВерсияКодовВидовОпераций = 2;
	Иначе
		// До 1 января 2015 года действует перечень,
		// утвержденный приказом ФНС 14.02.2012 N ММВ-7-3/83@.
		ВерсияКодовВидовОпераций = 1;
	КонецЕсли;
	
	СписокКодовОпераций = Новый СписокЗначений;
	Если ВерсияКодовВидовОпераций = 1 Тогда
		СписокКодовОпераций.Добавить("01", НСтр("ru = '01 - Реализованные товары, работы, услуги'; en = '01 - Sold goods, works, services'"));
		СписокКодовОпераций.Добавить("02", НСтр("ru = '02 - Авансы полученные'; en = '02 - Received advances'"));
		СписокКодовОпераций.Добавить("03", НСтр("ru = '03 - Возврат поставщику'; en = '03 - Return to the supplier'"));
		СписокКодовОпераций.Добавить("04", НСтр("ru = '04 - Товары, работы, услуги комитента'; en = '04 - Consignor goods, works, services'"));
		СписокКодовОпераций.Добавить("05", НСтр("ru = '05 - Авансы за товары, работы, услуги комитента'; en = '05 - Advances for consignor goods, works, services'"));
		СписокКодовОпераций.Добавить("06", НСтр("ru = '06 - Налоговый агент, ст. 161 НК'; en = '06 - Tax agent, art. 161 of the Tax Code'"));
		СписокКодовОпераций.Добавить("07", НСтр("ru = '07 - Списание за счет прибыли, пп.2 п.1 ст. 146 НК'; en = '07 - Debiting out of profit, subcl. 2, cl. 1, art. 146 of the Tax Code'"));
		СписокКодовОпераций.Добавить("08", НСтр("ru = '08 - Строительно-монтажные работы, пп.3 п.1 ст. 146 НК'; en = '08 - Construction and installation works, subcl. 3, cl. 1, art. 146 of the Tax Code'"));
		СписокКодовОпераций.Добавить("09", НСтр("ru = '09 - Суммы, связанные с расчетами по оплате, ст. 162 НК'; en = '09 - Amounts related to payment settlements, art. 162 of TC'"));
		СписокКодовОпераций.Добавить("10", НСтр("ru = '10 - Безвозмездная передача товаров, работ, услуг'; en = '10 - Donation of goods, works, services'"));
		СписокКодовОпераций.Добавить("11", НСтр("ru = '11 - Реализованные товары, права, п.3,4,5.1 ст. 154, пп.1-4 ст. 155 НК'; en = '11 - Sold goods, rights, cl.3, 4, 5.1, art. 154, subcl. 1-4, art. 155 of TC'"));
		СписокКодовОпераций.Добавить("12", НСтр("ru = '12 - Авансы полученные за товары, права, п.3,4,5.1 ст. 154, пп.1-4 ст. 155 НК'; en = '12 - Advances received for goods, rights, cl.3,4,5.1, art. 154, subcl. 1-4, art. 155 of TC'"));
		СписокКодовОпераций.Добавить("13", НСтр("ru = '13 - Капитальное строительство, модернизация (реконструкция) объектов недвижимости'; en = '13 - Capital construction, modernization (reconstruction) of real estate'"));
	ИначеЕсли ВерсияКодовВидовОпераций = 2 Тогда
		СписокКодовОпераций.Добавить("01", НСтр("ru = '01 - Реализованные товары, работы, услуги'; en = '01 - Sold goods, works, services'"));
