		СписокКодовОпераций.Добавить("03", НСтр("ru = '03 - Возврат поставщику'; en = '03 - Return to the supplier'"));
		СписокКодовОпераций.Добавить("04", НСтр("ru = '04 - Товары, работы, услуги комитента'; en = '04 - Consignor goods, works, services'"));
		СписокКодовОпераций.Добавить("05", НСтр("ru = '05 - Авансы за товары, работы, услуги комитента'; en = '05 - Advances for consignor goods, works, services'"));
		СписокКодовОпераций.Добавить("06", НСтр("ru = '06 - Налоговый агент, ст. 161 НК'; en = '06 - Tax agent, art. 161 of the Tax Code'"));
