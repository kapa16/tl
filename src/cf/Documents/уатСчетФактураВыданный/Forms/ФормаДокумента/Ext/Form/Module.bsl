&НаКлиенте
Процедура ОтобразитьНадписьКодВидаОперации()
	ТекущийКод = Элементы.КодВидаОперации.СписокВыбора.НайтиПоЗначению(Объект.КодВидаОперации);
	НадписьВидОперации = ?(ТекущийКод = Неопределено, "", Сред(ТекущийКод.Представление, 5));
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьИтоги()
	Если Объект.СуммаНДС = 0 Тогда
		Элементы.ДекорацияБезНДС.Видимость = Истина;
		Элементы.СуммаНДС.Видимость = Ложь;
		Элементы.СуммаДокумента.Заголовок = "Всего";
	Иначе
		Элементы.ДекорацияБезНДС.Видимость = Ложь;
		Элементы.СуммаНДС.Видимость = Истина;
	    Элементы.СуммаДокумента.Заголовок = "Всего с НДС";
	КонецЕсли;
КонецПроцедуры

