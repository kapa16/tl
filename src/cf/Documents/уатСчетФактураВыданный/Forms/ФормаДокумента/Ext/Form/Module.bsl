&НаКлиенте
Процедура ИзменитьОснование(Команда)
	
	ВыбратьОснование();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПлатежныеДокументы(Команда)
	Если Объект.ПлатежноРасчетныеДокументы.Количество() > 0 Тогда
		ТекстНСТР = НСтр("en='Tabular section will be cleared! Continue?';ru='Табличная часть будет очищена! Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьПлатежныеДокументыОтвет", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ОКОтмена, , КодВозвратаДиалога.ОК);
        Возврат;
	КонецЕсли;
	
	ЗаполнитьДатыНомераПлатежноРасчетныхДокументов();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПлатежныеДокументыОтвет(Результат, ДопПараметры) Экспорт
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьДатыНомераПлатежноРасчетныхДокументов();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	Объект.ДокументОснование = Неопределено;
	Объект.ДокументыОснования.Очистить();
	Объект.ПлатежноРасчетныеДокументы.Очистить();
	
	//ЗаполнитьПорядокВыставленияСчетаФактуры();
	
	Объект.СуммаДокумента = 0;
	Объект.СуммаНДС = 0;
	
	ПриИзмененииКонтрагентаИлиОрганизации();
	
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	ПриИзмененииКонтрагентаИлиОрганизации();
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаПриИзменении(Элемент)
	Если Объект.ДоговорКонтрагента <> Договор И ЕстьОснованиеСДругимДоговором() Тогда
		ТекстНСТР = НСтр("en='The documents-foundations with the contract different from the empire will be removed!" +
			" Continue?';ru='Будут удалены документы-основания с договором, отличающимся от выбранного," +
			" и перезаполнены платежно-расчетные документы! Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ДоговорКонтрагентаПриИзмененииОтвет", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ОКОтмена, , КодВозвратаДиалога.ОК);
        Возврат;
	КонецЕсли;
	
	Договор = Объект.ДоговорКонтрагента;
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаПриИзмененииОтвет(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.ОК Тогда
		УдалитьОснованияСДругимДоговором();
		ЗаполнитьДатыНомераПлатежноРасчетныхДокументов();
		УстановитьВидимость();
	Иначе
		Объект.ДоговорКонтрагента = Договор;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЕстьОснованиеСДругимДоговором()
	Для Каждого ТекОснование Из Объект.ДокументыОснования Цикл
		Если ТекОснование.ДокументОснование.ДоговорКонтрагента <> Объект.ДоговорКонтрагента Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

&НаСервере
Процедура УдалитьОснованияСДругимДоговором()
	
	Объект.СуммаДокумента = 0;
	Объект.СуммаНДС       = 0;
	
	Сч = Объект.ДокументыОснования.Количество()-1;
	Пока Сч >= 0 Цикл
		Если Объект.ДокументыОснования[Сч].ДокументОснование.ДоговорКонтрагента <> Объект.ДоговорКонтрагента Тогда
			Объект.ДокументыОснования.Удалить(Сч);
		Иначе
			Объект.СуммаДокумента = Объект.СуммаДокумента + Объект.ДокументыОснования[Сч].ДокументОснование.СуммаДокумента;
			Объект.СуммаНДС = Объект.СуммаНДС + Объект.ДокументыОснования[Сч].ДокументОснование.Услуги.Итог("СуммаНДС");
		КонецЕсли;
		Сч = Сч - 1;
	КонецЦикла;
	
	Если Объект.ДокументыОснования.Количество() = 0 Тогда
		Объект.ДокументОснование = Неопределено;
	Иначе
		Объект.ДокументОснование = Объект.ДокументыОснования[0].ДокументОснование;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииКонтрагентаИлиОрганизации()
	ДанныеОбменаССервером = Новый Структура("Организация, Контрагент, ДоговорКонтрагента, Дата");
	ЗаполнитьЗначенияСвойств(ДанныеОбменаССервером, Объект);
	// Получим данные с сервера
	ДанныеОбменаССервером.ДоговорКонтрагента = Объект.ДоговорКонтрагента;
	ЗначенияДляЗаполнения = ИзменениеКонтрагентаСервер(ДанныеОбменаССервером);
	Объект.ДоговорКонтрагента = ЗначенияДляЗаполнения.ДоговорКонтрагента;
	Договор = Объект.ДоговорКонтрагента;
	
	УдалитьОснованияСДругимДоговором();
	ЗаполнитьДатыНомераПлатежноРасчетныхДокументов();
	УстановитьВидимость();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИзменениеКонтрагентаСервер(ДанныеДляЗаполнения)
	СтруктураПараметровДляПолученияДоговора = 
		уатЗаполнениеДокументов.ПолучитьСтруктуруПараметровДляПолученияДоговораПродажи();
	
	ЗначенияДляЗаполнения = уатОбщегоНазначенияСервер.ПриИзмененииЗначенияКонтрагента(ДанныеДляЗаполнения,
		СтруктураПараметровДляПолученияДоговора);
	Возврат ЗначенияДляЗаполнения;
КонецФункции

&НаКлиенте
Процедура НадписьВыборНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ВыбратьОснование();
	
КонецПроцедуры

&НаКлиенте
Процедура НадписьДокументыОснованияНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ВыбратьОснование();
	
КонецПроцедуры

&НаКлиенте
Процедура КодВидаОперацииНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекущийКод = Элемент.СписокВыбора.НайтиПоЗначению(Объект.КодВидаОперации);
	ОповещениеВыбора = Новый ОписаниеОповещения("КодВидаОперацииНачалоВыбораЗавершение",ЭтотОбъект);
	ПоказатьВыборИзСписка(ОповещениеВыбора, Элемент.СписокВыбора, Элемент, ТекущийКод);
КонецПроцедуры

&НаКлиенте
Процедура КодВидаОперацииНачалоВыбораЗавершение(ВыбранныйКод, ДополнительныеПараметры) Экспорт
    Если ВыбранныйКод <> Неопределено Тогда
		Модифицированность = Истина;
		Объект.КодВидаОперации = ВыбранныйКод.Значение;
		НадписьВидОперации = Сред(ВыбранныйКод.Представление, 5);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КодВидаОперацииПриИзменении(Элемент)
	ОтобразитьНадписьКодВидаОперации();
КонецПроцедуры

&НаКлиенте
Процедура ВыставленПриИзменении(Элемент)
	Если Объект.Выставлен Тогда
		Объект.ДатаВыставления = Объект.Дата;
	Иначе
		Объект.ДатаВыставления = '00010101';
	КонецЕсли;
	
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовТаблицыПлатежноРасчетныеДокументы

&НаКлиенте
Процедура ПлатежноРасчетныеДокументыНомерСчетаФактурыНаАвансНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура("ВидСчетаФактуры, ДоговорКонтрагента",
		ПредопределенноеЗначение("Перечисление.ВидСчетаФактурыВыставленного.НаАванс"),
		Объект.ДоговорКонтрагента));
	Оповещ = Новый ОписаниеОповещения("ПлатежноРасчетныеДокументыНомерСчетаФактурыНаАвансВыбор", ЭтотОбъект);
	ОткрытьФорму("Документ.уатСчетФактураВыданный.ФормаВыбора", ПараметрыФормы,,,,, Оповещ);
КонецПроцедуры

&НаКлиенте
Процедура ПлатежноРасчетныеДокументыНомерСчетаФактурыНаАвансВыбор(Результат, ДопПараметры) Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда
		ТекСтрока = Элементы.ПлатежноРасчетныеДокументы.ТекущиеДанные;
