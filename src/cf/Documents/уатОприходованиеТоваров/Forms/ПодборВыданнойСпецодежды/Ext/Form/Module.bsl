
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	Если Параметры.Свойство("Сотрудник") Тогда
		Сотрудник = Параметры.Сотрудник;
	КонецЕсли;
	Если Параметры.Свойство("Период") Тогда
		Период = Параметры.Период;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ПустаяСтрока(ВариантОтбора) Тогда
		ВариантОтбора = "Все";
	КонецЕсли;
	
	ЗагрузитьСпецодеждуСотрудников();
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	
	Для Каждого ТекСтрока Из Спецодежда Цикл
		ТекСтрока.Пометка = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	
	Для Каждого ТекСтрока Из Спецодежда Цикл
		ТекСтрока.Пометка = Ложь;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	
	мсвСтроки = Новый Массив;
	Для Каждого ТекСтрока Из Спецодежда Цикл
		Если НЕ ТекСтрока.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСтруктура = Новый Структура;
		СтрокаСтруктура.Вставить("Номенклатура", ТекСтрока.Номенклатура);
		СтрокаСтруктура.Вставить("ЕдиницаИзмерения", уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(
			ТекСтрока.Номенклатура, "ЕдиницаХраненияОстатков"));
		СтрокаСтруктура.Вставить("Количество", ТекСтрока.Количество);
		СтрокаСтруктура.Вставить("Сумма", ТекСтрока.Стоимость);
		СтрокаСтруктура.Вставить("Цена", ?(ТекСтрока.Количество = 0, 0, ТекСтрока.Стоимость / ТекСтрока.Количество));
		мсвСтроки.Добавить(СтрокаСтруктура);
	КонецЦикла;
		
	Закрыть(мсвСтроки);
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВариантОтбораПриИзменении(Элемент)
	
	ЗагрузитьСпецодеждуСотрудников();
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовТаблицыФормыСпецодежда

&НаКлиенте
Процедура СпецодеждаПриАктивизацииСтроки(Элемент)
	
	ТекСтрока = Элементы.Спецодежда.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		ТекНоменклатура = Неопределено;
	Иначе
		ТекНоменклатура = ТекСтрока.Номенклатура;
	КонецЕсли;
	
	СтруктураОтбор = Новый Структура("Номенклатура", ТекНоменклатура);
	Элементы.СпецодеждаПартии.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбор);
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗагрузитьСпецодеждуСотрудников()
	
	ЗапросСпецодеждаСотрудников = Новый Запрос(
	"ВЫБРАТЬ
	|	уатСпецодежда.Номенклатура КАК Номенклатура,
	|	уатСпецодежда.ДатаВыдачи КАК ДатаВыдачи,
	|	уатСпецодежда.КоличествоОстаток КАК Количество,
	|	уатСпецодежда.СтоимостьОстаток - уатСпецодежда.СуммаИзносаОстаток КАК Стоимость,
	|	ДОБАВИТЬКДАТЕ(уатСпецодежда.ДатаВыдачи, МЕСЯЦ, уатСпецодежда.Номенклатура.МодельСпецодеждыИлиИнструмента.СрокИспользования) КАК СрокИспользования
	|ИЗ
	|	РегистрНакопления.уатСпецодеждаИИнструментыСотрудников.Остатки(&Период, Сотрудник = &Сотрудник) КАК уатСпецодежда
	|ГДЕ
	|	(НЕ &ОтборНулеваяСтоимость ИЛИ уатСпецодежда.СтоимостьОстаток - уатСпецодежда.СуммаИзносаОстаток = 0)
	|	И (НЕ &ОтборСрокИспользования ИЛИ ДОБАВИТЬКДАТЕ(уатСпецодежда.ДатаВыдачи, МЕСЯЦ, уатСпецодежда.Номенклатура.МодельСпецодеждыИлиИнструмента.СрокИспользования) <= КОНЕЦПЕРИОДА(&Период, ДЕНЬ))");
	ЗапросСпецодеждаСотрудников.УстановитьПараметр("Период", Период);
	ЗапросСпецодеждаСотрудников.УстановитьПараметр("Сотрудник", Сотрудник);
	ЗапросСпецодеждаСотрудников.УстановитьПараметр("ОтборНулеваяСтоимость", ВариантОтбора = "С нулевой остаточной стоимость");
	ЗапросСпецодеждаСотрудников.УстановитьПараметр("ОтборСрокИспользования", ВариантОтбора = "С истекшим сроком использования");
		
	тблСпецодежда = ЗапросСпецодеждаСотрудников.Выполнить().Выгрузить();
	
	СпецодеждаПартии.Загрузить(тблСпецодежда);
	СпецодеждаПартии.Сортировать("Номенклатура, ДатаВыдачи");
	
	тблСпецодежда.Свернуть("Номенклатура", "Количество, Стоимость");
	Спецодежда.Загрузить(тблСпецодежда);
	
КонецПроцедуры

#КонецОбласти
