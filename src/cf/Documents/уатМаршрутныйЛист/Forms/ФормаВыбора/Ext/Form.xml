		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>~Список.Ref</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументуатМаршрутныйЛист.Ссылка КАК Ссылка,
	ДокументуатМаршрутныйЛист.ПометкаУдаления КАК ПометкаУдаления,
	ДокументуатМаршрутныйЛист.Номер КАК Номер,
	ДокументуатМаршрутныйЛист.Дата КАК Дата,
	ДокументуатМаршрутныйЛист.Проведен КАК Проведен,
	ДокументуатМаршрутныйЛист.Статус КАК Статус,
	ДокументуатМаршрутныйЛист.Организация КАК Организация,
	ДокументуатМаршрутныйЛист.ДатаИВремяВыполнения КАК ДатаИВремяВыполнения,
	ДокументуатМаршрутныйЛист.Комментарий КАК Комментарий,
	ДокументуатМаршрутныйЛист.Ответственный КАК Ответственный,
	ДокументуатМаршрутныйЛист.ТС КАК ТС,
	ДокументуатМаршрутныйЛист.АдресОтправления КАК АдресОтправления,
	ДокументуатМаршрутныйЛист.АдресНазначения КАК АдресНазначения,
	ДокументуатМаршрутныйЛист.Контрагент КАК Контрагент,
	ДокументуатМаршрутныйЛист.ДатаИВремяОтправленияПлан КАК ДатаИВремяОтправленияПлан,
	ДокументуатМаршрутныйЛист.ДатаИВремяВыполненияПлан КАК ДатаИВремяВыполненияПлан,
	ДокументуатМаршрутныйЛист.ВидОперации КАК ВидОперации,
	ДокументуатМаршрутныйЛист.Водитель1 КАК Водитель1,
	ДокументуатМаршрутныйЛист.Водитель2 КАК Водитель2,
	ДокументуатМаршрутныйЛист.Сотрудник1 КАК Сотрудник1,
	ДокументуатМаршрутныйЛист.Сотрудник2 КАК Сотрудник2,
	ДокументуатМаршрутныйЛист.ВесБрутто КАК ВесБрутто,
	ДокументуатМаршрутныйЛист.Объем КАК Объем,
	ДокументуатМаршрутныйЛист.КоличествоМест КАК КоличествоМест,
	ДокументуатМаршрутныйЛист.Расстояние КАК Расстояние,
	ДокументуатМаршрутныйЛист.ВремяВПути КАК ВремяВПути,
	ДокументуатМаршрутныйЛист.ВидПеревозки КАК ВидПеревозки,
	ДокументуатМаршрутныйЛист.МоментВремени КАК МоментВремени,
	ДокументуатМаршрутныйЛист.Выполнен КАК Выполнен,
	ДокументуатМаршрутныйЛист.Подразделение КАК Подразделение,
	ДокументуатМаршрутныйЛист.СуммаДоходов КАК СуммаДоходов,
	ДокументуатМаршрутныйЛист.СуммаЗатрат КАК СуммаЗатрат,
	ДокументуатМаршрутныйЛист.Контрагенты КАК Контрагенты,
	ВЫБОР
		КОГДА ДокументуатМаршрутныйЛист.ВидПеревозки = ЗНАЧЕНИЕ(Справочник.уатВидыПеревозок.Авиационная)
			ТОГДА 0
		КОГДА ДокументуатМаршрутныйЛист.ВидПеревозки = ЗНАЧЕНИЕ(Справочник.уатВидыПеревозок.Железнодорожная)
			ТОГДА 3
		КОГДА ДокументуатМаршрутныйЛист.ВидПеревозки = ЗНАЧЕНИЕ(Справочник.уатВидыПеревозок.Морская)
			ТОГДА 4
		ИНАЧЕ ВЫБОР
				КОГДА ДокументуатМаршрутныйЛист.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Собственное)
					ТОГДА 11
				КОГДА ДокументуатМаршрутныйЛист.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Привлеченное)
					ТОГДА 12
				ИНАЧЕ 1
			КОНЕЦ
	КОНЕЦ КАК КартинкаВидПеревозки,
	ВЫБОР
		КОГДА уатСтатусыСопроводительныхДокументовСрезПоследних.Всего = уатСтатусыСопроводительныхДокументовСрезПоследних.ОбработкаЗавершена
			ТОГДА 3
		КОГДА ЕСТЬNULL(уатСтатусыСопроводительныхДокументовСрезПоследних.Всего, 0) = 0
			ТОГДА 0
		КОГДА уатСтатусыСопроводительныхДокументовСрезПоследних.ОбработкаЗавершена = 0
			ТОГДА 1
		ИНАЧЕ 2
	КОНЕЦ КАК СтатусОбработкиСопроводительныхДокументов,
	ЕСТЬNULL(уатСтатусыСопроводительныхДокументовСрезПоследних.Всего, 0) &lt;&gt; 0 КАК НаличиеСопроводительныхДокументов,
	ВЫБОР
		КОГДА ДокументуатМаршрутныйЛист.Проведен
			ТОГДА 1
		КОГДА ДокументуатМаршрутныйЛист.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ 0
	КОНЕЦ КАК КартинкаСтатусПроведенияДокумента,
	ДокументуатМаршрутныйЛист.ОбъектСтроительства КАК ОбъектСтроительства,
	ДокументуатМаршрутныйЛист.Маршрут КАК Маршрут,
	ДокументуатМаршрутныйЛист.НаправлениеПеревозки КАК НаправлениеПеревозки,
	ДокументуатМаршрутныйЛист.ЕстьРасхождения КАК ЕстьРасхождения
ИЗ
	Документ.уатМаршрутныйЛист КАК ДокументуатМаршрутныйЛист
	ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			уатСтатусыСопроводительныхДокументовСрезПоследних.СопроводительныйДокумент.Основание КАК Основание,
			КОЛИЧЕСТВО(уатСтатусыСопроводительныхДокументовСрезПоследних.СопроводительныйДокумент) КАК Всего,
			СУММА(ВЫБОР
					КОГДА уатСтатусыСопроводительныхДокументовСрезПоследних.Статус = ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.ОбработкаЗавершена)
						ТОГДА 1
					ИНАЧЕ 0
				КОНЕЦ) КАК ОбработкаЗавершена
		ИЗ
			РегистрСведений.уатСтатусыСопроводительныхДокументов.СрезПоследних КАК уатСтатусыСопроводительныхДокументовСрезПоследних
		
		СГРУППИРОВАТЬ ПО
			уатСтатусыСопроводительныхДокументовСрезПоследних.СопроводительныйДокумент.Основание) КАК уатСтатусыСопроводительныхДокументовСрезПоследних
		ПО ДокументуатМаршрутныйЛист.Ссылка = уатСтатусыСопроводительныхДокументовСрезПоследних.Основание</QueryText>
				<MainTable>Document.уатМаршрутныйЛист</MainTable>
