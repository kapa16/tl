
Процедура ОбработкаПроведения(Отказ, Режим)

	// регистр МеКаМи_КоличествоДУТ
	Если ЗаписыватьСведенияОДУТ Тогда
		Движения.GDS_КоличествоДУТ.Записывать = Истина;
		
		Для Каждого ТекСтрокаТЧ Из ТЧ Цикл
			Движение = Движения.GDS_КоличествоДУТ.Добавить();
			Движение.Период 		= Дата;
			Движение.ТС 			= ТекСтрокаТЧ.ТС;
			Движение.СерийныйНомер 	= ТекСтрокаТЧ.СерийныйНомер;
			Движение.НомерТС 		= ТекСтрокаТЧ.НомерТС;
			
			Количество = 0;
			
			Если ТекСтрокаТЧ.LLS1 Тогда Количество = 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS2 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS3 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS4 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS5 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS6 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS7 Тогда Количество = Количество + 1 КонецЕсли;
			Если ТекСтрокаТЧ.LLS8 Тогда Количество = Количество + 1 КонецЕсли;
			
			Движение.КоличествоДУТ = Количество;
		КонецЦикла;
	КонецЕсли;
	//	
	// регистр МеКаМи_НеисправныеДУТ
	Движения.GDS_НеисправныеДУТ.Записывать = Истина;
	
	Для Каждого ТекСтрокаТЧ Из ТЧ Цикл
		Движение = Движения.GDS_НеисправныеДУТ.Добавить();
		Движение.Период 					= Дата;
		Движение.ТС 						= ТекСтрокаТЧ.ТС;
		Движение.СерийныйНомер 				= ТекСтрокаТЧ.СерийныйНомер;
		Движение.ПоследниеДанные 			= ТекСтрокаТЧ.ПоследниеДанные;
		Движение.ОстатокТоплива 			= ТекСтрокаТЧ.ОстатокТоплива;
		Движение.LLS1 						= ТекСтрокаТЧ.LLS1;
		Движение.LLS2 						= ТекСтрокаТЧ.LLS2;
		Движение.LLS3 						= ТекСтрокаТЧ.LLS3;
		Движение.LLS4 						= ТекСтрокаТЧ.LLS4;
		Движение.LLS5 						= ТекСтрокаТЧ.LLS5;
		Движение.LLS6 						= ТекСтрокаТЧ.LLS6;
		Движение.LLS7 						= ТекСтрокаТЧ.LLS7;
		Движение.LLS8 						= ТекСтрокаТЧ.LLS8;
		Движение.ПоследнееМестоположение 	= ТекСтрокаТЧ.ПоследнееМестоположение;
		Движение.НуждаетсяВРемонте 			= ТекСтрокаТЧ.НуждаетсяВРемонте;
		Движение.Комментарий 				= ТекСтрокаТЧ.Комментарий;
		Движение.НеУчитывать 				= ТекСтрокаТЧ.НеУчитывать;
		Движение.ЗаписыватьСведенияОДУТ		= ЗаписыватьСведенияОДУТ;
	КонецЦикла;
	
КонецПроцедуры
