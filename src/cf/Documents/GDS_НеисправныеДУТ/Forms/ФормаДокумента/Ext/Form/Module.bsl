КонецПроцедуры

&НаКлиенте
Процедура СтЗагрузить(Команда)

	Объект.ТЧ.Очистить();
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите имя файла для чтения";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Фильтр = "Файл MS Excel (.xlsx)| *.xlsx";
	
	Если Не Диалог.Выбрать() Тогда
		Сообщить("Файл для обработки не выбран!");
	Иначе
		ФайлДанных = Диалог.ПолноеИмяФайла;
		
		Попытка
			Excel = Новый COMОбъект("Excel.Application");
			Excel.WorkBooks.Open(ФайлДанных);
			Состояние("Обработка файла Microsoft Excel...");
		Исключение
			Сообщить("Ошибка при открытии файла с помощью Excel! Загрузка не будет произведена!");
			Сообщить(ОписаниеОшибки());
			Возврат;
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Excel.Sheets(1).Select(); // лист 1, по умолчанию
	Исключение
		Excel.ActiveWorkbook.Close();
		Excel = 0;
		Сообщить("Файл " + Строка(ФайлДанных) + " не соответствует необходимому формату! Первый лист не найден!");
		Возврат;
	КонецПопытки;
	
	Версия = Лев(Excel.Version,Найти(Excel.Version,".")-1);
	
	Если Версия = "8" Тогда
		ФайлСтрок = Excel.Cells.CurrentRegion.Rows.Count;
		ФайлКолонок = Макс(Excel.Cells.CurrentRegion.Columns.Count, 13);
	Иначе
		ФайлСтрок = Excel.Cells(1,1).SpecialCells(11).Row;
		ФайлКолонок = Excel.Cells(1,1).SpecialCells(11).Column;
	КонецЕсли;
	
	Машина = "";
	
	Для Сч = 6 По ФайлСтрок Цикл
		Состояние("Обрабатывается строка " + Строка(Сч) + " из " + Строка(ФайлСтрок));	
		
		Если НЕ СокрЛП(Excel.Cells(Сч, 1).Value) = "" Тогда
			ТС = ВернутьМашину(СокрЛП(Excel.Cells(Сч, 4).Value));
			
			НоваяСтрока = Объект.ТЧ.Добавить();
			
			НоваяСтрока.ТС = ТС;
			НоваяСтрока.НомерТС = СокрЛП(Excel.Cells(Сч, 4).Value);
			НоваяСтрока.СерийныйНомер = СокрЛП(Excel.Cells(Сч, 5).Value);
			НоваяСтрока.ПоследниеДанные = СокрЛП(Excel.Cells(Сч, 6).Value);
			НоваяСтрока.ОстатокТоплива = СокрЛП(Excel.Cells(Сч, 7).Value);
			НКоличествоДУТ = 0;
			
			Если СокрЛП(Excel.Cells(Сч, 8).Value) = "Подключен" Тогда
				НоваяСтрока.LLS1 = Истина;
				НКоличествоДУТ = 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 9).Value) = "Подключен" Тогда
				НоваяСтрока.LLS2 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 10).Value) = "Подключен" Тогда
				НоваяСтрока.LLS3 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 12).Value) = "Подключен" Тогда
				НоваяСтрока.LLS4 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 13).Value) = "Подключен" Тогда
				НоваяСтрока.LLS5 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 14).Value) = "Подключен" Тогда
				НоваяСтрока.LLS6 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 15).Value) = "Подключен" Тогда
				НоваяСтрока.LLS7 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			Если СокрЛП(Excel.Cells(Сч, 16).Value) = "Подключен" Тогда
				НоваяСтрока.LLS8 = Истина;
				НКоличествоДУТ = НКоличествоДУТ + 1;
			КонецЕсли;
			
			НоваяСтрока.ПоследнееМестоположение = СокрЛП(Excel.Cells(Сч, 17).Value);
				
			Если Не УчитыватьТС(ТС) Тогда
				НоваяСтрока.НеУчитывать = Истина;
			Иначе
				НоваяСтрока.НуждаетсяВРемонте = ПроверитьНеобходимостьРемонта(ТС, НоваяСтрока.НомерТС, НКоличествоДУТ, НоваяСтрока.ПоследниеДанные);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
		
	Excel.DisplayAlerts = 0; 
	Excel.Quit();
	Excel.DisplayAlerts = 1;
	
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите имя файла для чтения";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Фильтр = "Файл MS Excel (.xlsx)| *.xlsx";
	
	Если Не Диалог.Выбрать() Тогда
		Сообщить("Файл для обработки не выбран!");
	Иначе
		ИмяФайла = Диалог.ПолноеИмяФайла;
		Файл = Новый ДвоичныеДанные(ИмяФайла);
		Адрес = ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
		Объект.ТЧ.Очистить();
		ЗагрузитьНаСервере(Адрес);
	КонецЕсли;
	
КонецПроцедуры

