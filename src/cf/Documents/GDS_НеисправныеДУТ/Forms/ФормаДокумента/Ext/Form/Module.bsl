Функция ПроверитьНеобходимостьРемонта(ТС, НомерТС, НКоличествоДУТ, ПоследниеДанные)

	НуженРемонт = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_КоличествоДУТСрезПоследних.ТС,
		|	GDS_КоличествоДУТСрезПоследних.НомерТС,
		|	GDS_КоличествоДУТСрезПоследних.КоличествоДУТ
		|ИЗ
		|	РегистрСведений.GDS_КоличествоДУТ.СрезПоследних(&НаДату, ) КАК GDS_КоличествоДУТСрезПоследних
		|ГДЕ
		|	GDS_КоличествоДУТСрезПоследних.ТС = &ТС
		|	И GDS_КоличествоДУТСрезПоследних.НомерТС = &НомерТС";
	
	Запрос.УстановитьПараметр("НаДату", Объект.Дата);
	Запрос.УстановитьПараметр("ТС", ТС);
	Запрос.УстановитьПараметр("НомерТС", НомерТС);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.КоличествоДУТ > НКоличествоДУТ Тогда
			НуженРемонт = Истина;
		ИначеЕсли ВыборкаДетальныеЗаписи.КоличествоДУТ < НКоличествоДУТ Тогда
			НуженРемонт = Ложь;	
		КонецЕсли;			
	КонецЦикла;
	
	Если ПоследниеДанные <> "Нет данных за выбранный период" Тогда
		Если Объект.Дата - 86400 > Дата(ПоследниеДанные) Тогда
			НуженРемонт = Истина;
		КонецЕсли;
	Иначе
		НуженРемонт = Истина;
	КонецЕсли;
	
	Возврат НуженРемонт;

	
КонецФункции

Функция УчитыватьТС(ТС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_НеисправныеДУТСрезПоследних.НеУчитывать
		|ИЗ
		|	РегистрСведений.GDS_НеисправныеДУТ.СрезПоследних(
		|			,
		|			ТС = &ТС
		|				И ЗаписыватьСведенияОДУТ = ИСТИНА) КАК GDS_НеисправныеДУТСрезПоследних";
	
	Запрос.УстановитьПараметр("ТС", ТС);
	Запрос.УстановитьПараметр("НаДату", Объект.Дата);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.НеУчитывать Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ВернутьМашину(ТС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатТС.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.уатТС КАК уатТС
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА СТРНАЙТИ(уатТС.ГосударственныйНомер, ""g-"") >= 1
	               |				ТОГДА СТРЗАМЕНИТЬ(уатТС.ГосударственныйНомер, ""g-"", """") = &ГосНомер
	               |			ИНАЧЕ уатТС.ГосударственныйНомер = &ГосНомер
	               |		КОНЕЦ";
	Запрос.УстановитьПараметр("ГосНомер", ТС);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.уатТС.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция Комментарий(ТС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_НеисправныеДУТСрезПоследних.Комментарий
		|ИЗ
		|	РегистрСведений.GDS_НеисправныеДУТ.СрезПоследних(
		|			,
		|			ТС = &ТС
		|				И ЗаписыватьСведенияОДУТ = ИСТИНА) КАК GDS_НеисправныеДУТСрезПоследних";
	
	Запрос.УстановитьПараметр("ТС", ТС);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Комментарий;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

