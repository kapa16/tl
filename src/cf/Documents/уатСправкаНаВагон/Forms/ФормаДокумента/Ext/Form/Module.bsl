// Конец СтандартныеПодсистемы.Свойства

&НаКлиенте
Процедура СоздатьВагон(Команда)
	Если Модифицированность Или Объект.Ссылка.Пустая() Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьВагонЗавершение", ЭтотОбъект);
		ТекстНСтр = НСтр("ru='Необходимо записать документ. Записать?'");
		ПоказатьВопрос(ОписаниеОповещения, ТекстНСтр,РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Основание", Объект.Ссылка);
	ПараметрыФормы.Вставить("НомерВагона", Объект.НомерВагона);
	ПараметрыФормы.Вставить("ВладелецТС", Объект.ВладелецТС);
	ПараметрыФормы.Вставить("Грузоподъемность", Объект.Грузоподъемность);
	ПараметрыФормы.Вставить("СобственныйВес", Объект.СобственныйВес);
	ПараметрыФормы.Вставить("ОбъемКузова", Объект.ОбъемКузоваВагона);
	ПараметрыФормы.Вставить("ГодВыпускаВагона", Объект.ГодВыпускаВагона);
	ПараметрыФормы.Вставить("Модель", Объект.МодельВагона);
	ПараметрыФормы.Вставить("РодВагона", Объект.РодВагона);
	ПараметрыФормы.Вставить("ВладелецТС", Объект.Владелец);
	ПараметрыФормы.Вставить("ТипВладенияЖДТС", Объект.ТипСобственности);
	ОткрытьФорму("Справочник.уатТС.ФормаОбъекта", ПараметрыФормы);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СоздатьВагонЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Или Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Записать();
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Основание", Объект.Ссылка);
	ПараметрыФормы.Вставить("НомерВагона", Объект.НомерВагона);
	ПараметрыФормы.Вставить("ВладелецТС", Объект.ВладелецТС);
	ПараметрыФормы.Вставить("Грузоподъемность", Объект.Грузоподъемность);
	ПараметрыФормы.Вставить("СобственныйВес", Объект.СобственныйВес);
	ПараметрыФормы.Вставить("ОбъемКузова", Объект.ОбъемКузоваВагона);
	ПараметрыФормы.Вставить("ГодВыпускаВагона", Объект.ГодВыпускаВагона);
	ПараметрыФормы.Вставить("Модель", Объект.МодельВагона);
	ПараметрыФормы.Вставить("РодВагона", Объект.РодВагона);
	ПараметрыФормы.Вставить("ВладелецТС", Объект.Владелец);
	ПараметрыФормы.Вставить("ТипВладенияЖДТС", Объект.ТипСобственности);
	ОткрытьФорму("Справочник.уатТС.ФормаОбъекта", ПараметрыФормы);
	
КонецПроцедуры

