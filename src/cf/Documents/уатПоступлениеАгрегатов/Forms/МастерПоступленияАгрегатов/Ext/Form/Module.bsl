
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		АвтоТест = Истина;
	КонецЕсли;
	
	Если НЕ Параметры.Свойство("ДокументОснование") Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ДокументОснование = Параметры.ДокументОснование;
	Для Каждого ТекСтрока Из ДокументОснование.Товары Цикл
		НоваяСтрока = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.Валюта = ДокументОснование.ВалютаДокумента;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Заглушка = Истина;
	//Если ВладелецФормы = Неопределено Тогда
	//	ПоказатьПредупреждение(Неопределено, НСтр("en='Immediate opening for this object is prohibited!';ru='Непосредственное открытие для данного объекта запрещено!'"), 10);
	//	Отказ = Истина;
	//	Возврат;
	//КонецЕсли;
	
	Если ЗаполнитьСкладИзПоступленияМатериалов Тогда
		СкладАгрегатов = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ДокументОснование, "Склад");
		Элементы.СкладАгрегатов.ТолькоПросмотр = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СписокЗначений") Тогда
		Для Каждого ТекЭлем Из ВыбранноеЗначение Цикл
			НоваяСтрока = Агрегаты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекЭлем.Значение);
		КонецЦикла;
		ОбновитьКоличествоАгрегатов();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПакетныйВводАгрегатов(Команда)
	
	ТекСтрокаТовары = Элементы.Товары.ТекущиеДанные;
	Если ТекСтрокаТовары = Неопределено Тогда
		ТекстСообщения = "Для заполнения данных по агрегатам спозиционируйтесь на строке номенклатуры.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", ТекСтрокаТовары.Номенклатура);
	ПараметрыФормы.Вставить("Количество", ТекСтрокаТовары.Количество);
	ПараметрыФормы.Вставить("Цена", ТекСтрокаТовары.Цена);
	ПараметрыФормы.Вставить("Валюта", ТекСтрокаТовары.Валюта);
	ТипАгрегатаПоиск = ПолучитьТипАгрегатаПоНаименованиюТовара(Строка(ТекСтрокаТовары.Номенклатура));
	Если ЗначениеЗаполнено(ТипАгрегатаПоиск) Тогда
		ПараметрыФормы.Вставить("ТипАгрегата", ТипАгрегатаПоиск);
	КонецЕсли;
	ПараметрыФормы.Вставить("НеСоздаватьАгрегаты", Истина);
	
	ОткрытьФорму("Обработка.уатПакетныйВводАгрегатов.Форма.Форма", ПараметрыФормы, ЭтаФорма,,,,,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьИПеренестиВДокумент(Команда)

	Если НЕ ЗначениеЗаполнено(Механик) ИЛИ НЕ ЗначениеЗаполнено(Кладовщик) Тогда
		ТекстСообщения = "Не указаны значения реквизитов документа ""Выдача расходных материалов"".";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	ИначеЕсли НЕ ЗначениеЗаполнено(СкладАгрегатов) Тогда
		ТекстСообщения = "Не указаны значения реквизитов документа ""Поступление агрегатов"".";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	// проверка на дубли сгенерированных СН
	ТекстСообщения = "";
	ДубльСН = Неопределено;
	Если ЕстьДублиСерийныхНомеров(ДубльСН) Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + СтрШаблон(
			НСтр("en='Several units with the same serial number will be created (%1)';ru='Будет создано несколько агрегатов с одинаковым серийным номером (%1)'"), ДубльСН);
	КонецЕсли;
	// проверка на наличие в базе агрегата с таким же СН, как один из сгенерированных
	СписокАгрегатов = ПолучитьСписокАгрегатовПоСерийнымНомерам();
	Если СписокАгрегатов.Количество() Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС
			+ НСтр("en='For specified serial numbers in system are already have car parts';ru='Для указанных серийных номеров в системе уже имеются агрегаты'");
		Для Каждого ТекЭлем Из СписокАгрегатов Цикл
			ТекстСообщения = ТекстСообщения + Символы.ПС + " " + ТекЭлем.Наименование + " (" + НСтр("en='serial number';ru='с/н'") + ": " + ТекЭлем.СерийныйНомер + ")";
		КонецЦикла;
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекстСообщения) Тогда
		Оповещ = Новый ОписаниеОповещения("СоздатьИПеренестиВДокументОтвет", ЭтотОбъект);
		ТекстСообщения = Сред(ТекстСообщения, 2) + Символы.ПС + НСтр("en='Continue?';ru='Продолжить?'");
		ПоказатьВопрос(Оповещ, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	СоздатьИПеренестиВДокументПродолжение();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьИПеренестиВДокументОтвет(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		СоздатьИПеренестиВДокументПродолжение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьИПеренестиВДокументПродолжение()
	
	мсвСозданныеДокументы = Новый Массив;
	флОтказ = Ложь;
	СоздатьИПеренестиВДокументСервер(мсвСозданныеДокументы, флОтказ);
	
	Если НЕ флОтказ Тогда
		Для Каждого ТекДокумент Из мсвСозданныеДокументы Цикл
			ПоказатьЗначение(Неопределено, ТекДокумент);
		КонецЦикла;
		
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьИПеренестиВДокументСервер(мсвСозданныеДокументы, флОтказ)
	
	НачатьТранзакцию();
	
	мсвСозданныеДокументы = Новый Массив;
	флОтказ = Ложь;
		
	// 1. Агрегаты с износом
	СоздатьАгрегатыСписаниеИПоступление(Истина, мсвСозданныеДокументы, флОтказ);
	
	// 2. Агрегаты без износа
	Если НЕ флОтказ Тогда
		СоздатьАгрегатыСписаниеИПоступление(Ложь, мсвСозданныеДокументы, флОтказ);
	КонецЕсли;
	
	Если флОтказ тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры
	
#КонецОбласти


#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ТоварыПриАктивизацииСтроки(Элемент)
	
	ТекСтрокаТовары = Элементы.Товары.ТекущиеДанные;
	Если ТекСтрокаТовары = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Элементы.Агрегаты.ОтборСтрок = Новый ФиксированнаяСтруктура(
		Новый Структура("Номенклатура", ТекСтрокаТовары.Номенклатура));
	
КонецПроцедуры

&НаКлиенте
Процедура АгрегатыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекСтрока = Элементы.Агрегаты.ТекущиеДанные;
	ТекСтрокаТовары = Элементы.Товары.ТекущиеДанные;
	
	Если ТекСтрокаТовары <> Неопределено Тогда
		ТекСтрока.Номенклатура = ТекСтрокаТовары.Номенклатура;
		ТекСтрока.ПервоначальнаяСтоимость = ТекСтрокаТовары.Цена;
		ТекСтрока.Валюта = ТекСтрокаТовары.Валюта;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекСтрока.Номенклатура) Тогда
		ТипАгрегатаПоиск = ПолучитьТипАгрегатаПоНаименованиюТовара(Строка(ТекСтрока.Номенклатура));
		Если ЗначениеЗаполнено(ТипАгрегатаПоиск) Тогда
			ТекСтрока.ТипАгрегата = ТипАгрегатаПоиск;
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура АгрегатыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	ОбновитьКоличествоАгрегатов();
КонецПроцедуры

&НаКлиенте
Процедура АгрегатыПослеУдаления(Элемент)
	ОбновитьКоличествоАгрегатов();
КонецПроцедуры

&НаКлиенте
Процедура АгрегатыМодельПриИзменении(Элемент)
	
	ТекСтрока = Элементы.Агрегаты.ТекущиеДанные;
	ТекСтрока.ПараметрВыработки = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(
		ТекСтрока.Модель, "ПараметрВыработки");
	Если ТекСтрока.ТипАгрегата = ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Шина") Тогда	
		ТекСтрока.СрокСлужбыШины = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(
			ТекСтрока.Модель, "СрокСлужбы");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСкладИзПоступленияМатериаловПриИзменении(Элемент)
	Если ЗаполнитьСкладИзПоступленияМатериалов Тогда
		СкладАгрегатов = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ДокументОснование, "Склад");
		Элементы.СкладАгрегатов.ТолькоПросмотр = Истина;
	Иначе
		Элементы.СкладАгрегатов.ТолькоПросмотр = Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СоздатьАгрегатыСписаниеИПоступление(флАгрегатыСНачислениемИзноса, мсвСозданныеДокументы, флОтказ = Ложь)
	
	// Создание агрегатов
	мсвАгрегаты = Новый Массив;
	тблТовары = Новый ТаблицаЗначений;
	тблТовары.Колонки.Добавить("Номенклатура");
	тблТовары.Колонки.Добавить("ЕдиницаИзмерения");
	тблТовары.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	Для Каждого ТекСтрока Из Агрегаты Цикл
		Если (ТекСтрока.Модель.ВариантНачисленияИзноса = Перечисления.уатВариантыНачисленияИзносаАгрегатов.НеНачислять
			ИЛИ ТекСтрока.Модель.ВариантНачисленияИзноса.Пустая()) = флАгрегатыСНачислениемИзноса Тогда
			Продолжить;
		КонецЕсли;
		
		мсвСтрокиТоварыПоиск = Товары.НайтиСтроки(Новый Структура("Номенклатура", ТекСтрока.Номенклатура));
		Если мсвСтрокиТоварыПоиск.Количество() > 0 Тогда
			ТекЕИ = мсвСтрокиТоварыПоиск[0].ЕдиницаИзмерения;
		КонецЕсли;
		НоваяСтрокаТовары = тблТовары.Добавить();
		НоваяСтрокаТовары.Номенклатура = ТекСтрока.Номенклатура;
		НоваяСтрокаТовары.ЕдиницаИзмерения = ТекЕИ;
		НоваяСтрокаТовары.Количество = 1;
		
		НовыйАгрегат = Справочники.уатСерииНоменклатуры.СоздатьЭлемент();
		НовыйАгрегат.Заполнить(Неопределено);
		ЗаполнитьЗначенияСвойств(НовыйАгрегат, ТекСтрока);
		
		Попытка 
			НовыйАгрегат.Записать();
			мсвАгрегаты.Добавить(НовыйАгрегат.Ссылка);
		Исключение
			ТекстСообщения = НСтр("en='Failed to record car part:';ru='Не удалось записать агрегат:'") + " " + НовыйАгрегат.Наименование;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			флОтказ = Истина;
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	тблТовары.Свернуть("Номенклатура, ЕдиницаИзмерения", "Количество");
	
	Если флОтказ ИЛИ мсвАгрегаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	// Создание документа уатВыдачаРасходныхМатериалов
	ДокСписание = Документы.уатВыдачаРасходныхМатериалов.СоздатьДокумент();
	ДокСписание.Заполнить(Неопределено);
	ДокСписание.ДокументОснование = ДокументОснование;
	Если флАгрегатыСНачислениемИзноса Тогда
		ДокСписание.ВидОперации = Перечисления.уатВидыОперацийВыдачаРасходныхМатериалов.СписаниеВПроизводство;
	Иначе
		ДокСписание.ВидОперации = Перечисления.уатВидыОперацийВыдачаРасходныхМатериалов.СписаниеНаПрочиеРасходы;
	КонецЕсли;
	ДокСписание.Дата = ТекущаяДатаСеанса();
	ДокСписание.УстановитьНовыйНомер();
	ДокСписание.Организация = ДокументОснование.Организация;
	ДокСписание.Подразделение = ?(ЗначениеЗаполнено(ДокументОснование.Подразделение), ДокументОснование.Подразделение,
		уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
			ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновноеПодразделениеОрганизации"));
	ДокСписание.Склад = ДокументОснование.Склад;
	ДокСписание.Ответственный = ДокументОснование.Ответственный;
	ДокСписание.Кладовщик = Кладовщик;
	ДокСписание.Механик = Механик;
	
	Если ПолучитьФункциональнуюОпцию("уатИспользоватьУчетДоходовИРасходов") Тогда
		Если уатОбщегоНазначения.уатНайтиПланЗатрат(ДокСписание.ПланЗатрат, ДокСписание.Организация, Неопределено) Тогда
			//ТекстНСТР = НСтр("en='Cost plan is not found!';ru='Не найден план затрат!'");
			//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР);
		КонецЕсли;	
	КонецЕсли;
	
	Для Каждого ТекСтрока Из тблТовары Цикл
		Если ТекСтрока.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ДокСписание.Материалы.Добавить();
		НоваяСтрока.Номенклатура     = ТекСтрока.Номенклатура;
		НоваяСтрока.ЕдиницаИзмерения = ТекСтрока.ЕдиницаИзмерения;
		НоваяСтрока.Количество       = ТекСтрока.Количество;
	КонецЦикла;
	Попытка 
		ДокСписание.Записать(РежимЗаписиДокумента.Проведение);
		мсвСозданныеДокументы.Добавить(ДокСписание.Ссылка);
	Исключение
		ТекстСообщения = НСтр("en='Failed to record car part:';ru='Не удалось провести документ ""Выдача расходных материалов"":'") + " " + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		флОтказ = Истина;
	КонецПопытки;
	
	Если флОтказ Тогда
		Возврат;
	КонецЕсли;

	// Создание документа уатПоступлениеАгрегатов
	ДокПоступлениеАгрегатов = Документы.уатПоступлениеАгрегатов.СоздатьДокумент();
	ДокПоступлениеАгрегатов.Заполнить(ДокументОснование);
	ДокПоступлениеАгрегатов.Дата = ТекущаяДатаСеанса();
	ДокПоступлениеАгрегатов.УстановитьНовыйНомер();
	ДокПоступлениеАгрегатов.Организация = ДокументОснование.Организация;
	ДокПоступлениеАгрегатов.Подразделение = ?(ЗначениеЗаполнено(ДокументОснование.Подразделение), ДокументОснование.Подразделение,
		уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновноеПодразделениеОрганизации"));
	ДокПоступлениеАгрегатов.Склад = СкладАгрегатов;	
	ДокПоступлениеАгрегатов.Контрагент = ДокументОснование.Контрагент;
	ДокПоступлениеАгрегатов.ДоговорКонтрагента = ДокументОснование.ДоговорКонтрагента;
	ДокПоступлениеАгрегатов.ВалютаДокумента = ДокументОснование.ВалютаДокумента;
	
	Для Каждого ТекАгрегат Из мсвАгрегаты Цикл
		ТекТипАгрегата = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекАгрегат, "ТипАгрегата");
		Если ТекТипАгрегата	= ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Шина") Тогда
			НоваяСтрока = ДокПоступлениеАгрегатов.Шины.Добавить();
		ИначеЕсли ТекТипАгрегата = ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Аккумулятор") Тогда
			НоваяСтрока = ДокПоступлениеАгрегатов.Аккумуляторы.Добавить();
		Иначе
			НоваяСтрока = ДокПоступлениеАгрегатов.ПрочиеАгрегаты.Добавить();
		КонецЕсли;
		НоваяСтрока.СерияНоменклатуры = ТекАгрегат;
		НоваяСтрока.Цена = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекАгрегат, "ПервоначальнаяСтоимость");
	КонецЦикла;
	
	ДокПоступлениеАгрегатов.СуммаДокумента = ДокПоступлениеАгрегатов.Шины.Итог("Цена")
		+ ДокПоступлениеАгрегатов.Аккумуляторы.Итог("Цена") + ДокПоступлениеАгрегатов.ПрочиеАгрегаты.Итог("Цена");
	
	Попытка 
		ДокПоступлениеАгрегатов.Записать(РежимЗаписиДокумента.Проведение);
		мсвСозданныеДокументы.Добавить(ДокПоступлениеАгрегатов.Ссылка);
	Исключение
		ТекстСообщения = НСтр("en='Failed to record car part:';ru='Не удалось провести документ ""Поступление агрегатов"":'") + " " + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		флОтказ = Истина;
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоАгрегатов()
	Для Каждого ТекСтрока Из Товары Цикл
		ТекСтрока.КоличествоАгрегатов = Агрегаты.НайтиСтроки(
			Новый Структура("Номенклатура", ТекСтрока.Номенклатура)).Количество();
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьТипАгрегатаПоНаименованиюТовара(НаименованиеТовара)
	
	Если СтрНайти(НРег(НаименованиеТовара), "шина") <> 0 ИЛИ СтрНайти(НРег(НаименованиеТовара), "шины") <> 0 Тогда
		Возврат ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Шина");
	ИначеЕсли СтрНайти(НРег(НаименованиеТовара), "аккумулятор") <> 0 Тогда
		Возврат ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Аккумулятор");
	ИначеЕсли СтрНайти(НРег(НаименованиеТовара), "аптечка") <> 0 ИЛИ СтрНайти(НРег(НаименованиеТовара), "аптечки") <> 0 Тогда
		Возврат ПредопределенноеЗначение("Справочник.уатТипыАгрегатов.Аптечка");
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ЕстьДублиСерийныхНомеров(ДубльСН)
	
	Для Сч = 0 По Агрегаты.Количество()-1 Цикл
		Для СчВлож = Сч+1 По Агрегаты.Количество()-1 Цикл
			Если Агрегаты[Сч].СерийныйНомер = Агрегаты[СчВлож].СерийныйНомер Тогда
				ДубльСН = Агрегаты[Сч].СерийныйНомер;
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ПолучитьСписокАгрегатовПоСерийнымНомерам()
	
	МассивРезультат = Новый Массив;
	ТЗ = уатОбщегоназначения.ПолучитьСписокАгрегатовПоСерийнымНомерам(
		Агрегаты.Выгрузить().ВыгрузитьКолонку("СерийныйНомер"));
	Для Каждого ТекЭлемент Из ТЗ Цикл 
		СтрокаРезультат = Новый Структура;
		СтрокаРезультат.Вставить("Наименование",  ТекЭлемент.Значение.Наименование);
		СтрокаРезультат.Вставить("СерийныйНомер", ТекЭлемент.Значение.СерийныйНомер);
		МассивРезультат.Добавить(СтрокаРезультат);
	КонецЦикла;
	
	Возврат МассивРезультат;
	
КонецФункции

#КонецОбласти
