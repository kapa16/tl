&НаКлиенте
Процедура ПодборПоЗадолженности(флБезРазбиения)
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ТекстНСТР = НСтр("en='You must specify the counterparty'; ru='Необходимо указать контрагента'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР,, "Объект.Контрагент");
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДокументСсылка",              Объект.Ссылка);
	СтруктураПараметров.Вставить("КурсДокумента",               КурсДокумента);
	СтруктураПараметров.Вставить("КратностьДокумента",          КратностьДокумента);
	СтруктураПараметров.Вставить("Контрагент",                  Объект.Контрагент);
	СтруктураПараметров.Вставить("БанковскийСчетКасса",         Объект.Касса);
	СтруктураПараметров.Вставить("Организация",                 Объект.Организация);
	СтруктураПараметров.Вставить("ВалютаДокумента",             Объект.ВалютаДокумента);
	СтруктураПараметров.Вставить("ДатаДок",                     Объект.Дата);
	СтруктураПараметров.Вставить("СуммаДляПодбора",             Объект.СуммаДокумента);
	СтруктураПараметров.Вставить("ПлатежПоСуммеВзаиморасчетов", Истина);
	СтруктураПараметров.Вставить("ЕстьПодбор",                  Истина);
	СтруктураПараметров.Вставить("ЗакрыватьПриВыборе",          флБезРазбиения);
	СтруктураПараметров.Вставить("ВидОперацииВозврат",          Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийПКО.ВозвратОтПоставщика"));
	СтруктураПараметров.Вставить("ТипЗадолженности",            ?(СтруктураПараметров.ВидОперацииВозврат, "<0", ">0"));
	
	мсвСтрокРасшифровка = Новый Массив;
	Для Каждого ТекСтрока Из Объект.РасшифровкаПлатежа Цикл
		ТекВедениеВзаиморасчетов = уатОбщегоНазначенияТиповыеСервер.ПолучитьЗначениеРеквизита(ТекСтрока.ДоговорКонтрагента, "ВедениеВзаиморасчетов");
		Если НЕ ЗначениеЗаполнено(ТекСтрока.ДоговорКонтрагента)
			ИЛИ ТекСтрока.СуммаПлатежа = 0
			ИЛИ (ТекВедениеВзаиморасчетов = ПредопределенноеЗначение("Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным")
			ИЛИ ТекВедениеВзаиморасчетов = ПредопределенноеЗначение("Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам")
			ИЛИ ТекВедениеВзаиморасчетов = ПредопределенноеЗначение("Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС"))
			И НЕ ЗначениеЗаполнено(ТекСтрока.Сделка) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтрока = Новый Структура("ДоговорКонтрагента, КурсВзаиморасчетов, КратностьВзаиморасчетов, СуммаВзаиморасчетов, СуммаПлатежа, Сделка, СтавкаНДС, СуммаНДС");
		ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока);
		НовСтрока.Вставить("Валюта", ТекСтрока.ВалютаВзаиморасчетов);
		мсвСтрокРасшифровка.Добавить(НовСтрока);
	КонецЦикла;
	СтруктураПараметров.Вставить("РасшифровкаПлатежа", мсвСтрокРасшифровка);
	
	мсвСтрокЗаказы = Новый Массив;
	Для Каждого ТекСтрокаЗаказ Из Объект.Заказы Цикл
		мсвТекСтрока = Объект.РасшифровкаПлатежа.НайтиСтроки(Новый Структура("ID", ТекСтрокаЗаказ.ID));
		Если мсвТекСтрока.Количество() > 0 Тогда
			НовСтрока = Новый Структура("ЗаказНаТС, СуммаПлатежа, СуммаВзаиморасчетов");
			ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрокаЗаказ);
			НовСтрока.Вставить("ДоговорКонтрагента", мсвТекСтрока[0].ДоговорКонтрагента);
			НовСтрока.Вставить("Сделка", мсвТекСтрока[0].Сделка);
			НовСтрока.Вставить("Валюта", мсвТекСтрока[0].ВалютаВзаиморасчетов);
			мсвСтрокЗаказы.Добавить(НовСтрока);
		КонецЕсли;
	КонецЦикла;
	СтруктураПараметров.Вставить("Заказы", мсвСтрокЗаказы);
	
	ОповещОЗакрытии = Новый ОписаниеОповещения("ПодборПоЗадолженностиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.уатПодборПараметровРасшифровкиПлатежа.Форма.ФормаПодбораЗадолженностей", СтруктураПараметров, ЭтотОбъект,,,, ОповещОЗакрытии);
КонецПроцедуры

&НаКлиенте
Процедура ПодборПоЗадолженностиЗавершение(Результат, ДопПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Объект.РасшифровкаПлатежа.Очистить();
	НДСПоУмолчанию = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяСтавкаНДС");
		
	Для Каждого СтруктураСтроки Из Результат.РасшифровкаПлатежа Цикл
		СтрокаРасшифровка                         = Объект.РасшифровкаПлатежа.Добавить();
		СтрокаРасшифровка.ДоговорКонтрагента      = СтруктураСтроки.ДоговорКонтрагента;
		СтрокаРасшифровка.Сделка                  = СтруктураСтроки.Сделка;
		СтрокаРасшифровка.СуммаПлатежа            = СтруктураСтроки.СуммаПлатежа;
		СтрокаРасшифровка.СуммаВзаиморасчетов     = СтруктураСтроки.СуммаВзаиморасчетов;
		СтрокаРасшифровка.ВалютаВзаиморасчетов    = СтруктураСтроки.ВалютаВзаиморасчетов;
		СтрокаРасшифровка.КурсВзаиморасчетов      = СтруктураСтроки.КурсВзаиморасчетов;
		СтрокаРасшифровка.КратностьВзаиморасчетов = СтруктураСтроки.КратностьВзаиморасчетов;
		СтрокаРасшифровка.ДатаКурса = уатОбщегоНазначенияТиповые.ПолучитьДатуКурсаРасшифровкиПлатежа(
			Объект.Дата, СтрокаРасшифровка.ДоговорКонтрагента, СтрокаРасшифровка.Сделка);
		СтрокаРасшифровка.СтавкаНДС               = НДСПоУмолчанию;
		ПересчитатьСуммуНДС(СтрокаРасшифровка);
		
		Если РазнесениеПоЗаказам Тогда
			СтрокаРасшифровка.ID = Новый УникальныйИдентификатор;
			Для Каждого СтруктураСтрокиЗаказ Из Результат.ЗаказыНаТС Цикл
				Если СтруктураСтрокиЗаказ.ДоговорКонтрагента = СтруктураСтроки.ДоговорКонтрагента
					И СтруктураСтрокиЗаказ.Сделка = СтруктураСтроки.Сделка
					И СтруктураСтрокиЗаказ.ВалютаВзаиморасчетов = СтруктураСтроки.ВалютаВзаиморасчетов Тогда
					СтрокаЗаказ                     = Объект.Заказы.Добавить();
					СтрокаЗаказ.ID                  = СтрокаРасшифровка.ID;
					СтрокаЗаказ.ЗаказНаТС           = СтруктураСтрокиЗаказ.ЗаказНаТС;
					СтрокаЗаказ.СуммаПлатежа        = СтруктураСтрокиЗаказ.СуммаПлатежа;
					СтрокаЗаказ.СуммаВзаиморасчетов = СтруктураСтрокиЗаказ.СуммаВзаиморасчетов;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		СтрокаПлатеж = Объект.РасшифровкаПлатежа.Добавить();
	Иначе
		СтрокаПлатеж = Объект.РасшифровкаПлатежа[0];
	КонецЕсли;
	
	Если Объект.РасшифровкаПлатежа.Количество() > 1 Тогда
		СпособРедактирования = 1;
	Иначе
		СпособРедактирования = 0;
	КонецЕсли;
	
	Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("СуммаПлатежа");
	РассчитатьИтоги();
	
	УстановитьФокус();
	//СтрокаПлатеж = Элементы.РасшифровкаПлатежа.ТекущиеДанные;
	
	УстановитьВидимость();
	УстановитьОграничениеТипаСделка();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСтавкуНДС(Команда)
	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		ТекстПредупреждения = НСтр("ru = 'В табличной части ""Расшифровка платежа"" не введено ни одной строки.';
									|en = 'No lines entered in the Item list.'");
		ПоказатьПредупреждение(, ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	СписокСтавокНДС = ЗаполнитьСписокЗначенийСтавкиНДСНаСервере();
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьСтавкуНДСЗавершение", ЭтотОбъект);
	СписокСтавокНДС.ПоказатьВыборЭлемента(ОписаниеОповещения, "Ставки НДС");
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстНСТР = НСтр("en='Clean provided services?';ru='Очистить расшифровку платежа?'");
	ПоказатьВопрос(Новый ОписаниеОповещения("ОчиститьТЧ", ЭтотОбъект),
		ТекстНСТР, РежимДиалогаВопрос.ОКОтмена);
КонецПроцедуры

