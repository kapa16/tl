&НаКлиенте
Процедура РасшифровкаПлатежаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		ТекСтрока = Элементы.РасшифровкаПлатежа.ТекущиеДанные;
		ТекСтрока.СтавкаНДС =
			уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
			ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяСтавкаНДС");
			
		Если РазнесениеПоЗаказам Тогда
			ТекСтрока.ID = Новый УникальныйИдентификатор;
		КонецЕсли;
		ТекСтрока.ДатаКурса = Объект.Дата;
	КонецЕсли;
		
	УстановитьОграничениеТипаСделка();
КонецПроцедуры

