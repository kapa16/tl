			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.ОбщееСостояние</Field>
				<Field>Список.СогласованиеДО</Field>
				<Field>Список.СостояниеОригиналаПервичногоДокумента</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументуатСчетНаОплатуПоставщика.Ссылка КАК Ссылка,
	ДокументуатСчетНаОплатуПоставщика.ПометкаУдаления КАК ПометкаУдаления,
	ДокументуатСчетНаОплатуПоставщика.Номер КАК Номер,
	ДокументуатСчетНаОплатуПоставщика.Дата КАК Дата,
	ДокументуатСчетНаОплатуПоставщика.Проведен КАК Проведен,
	ДокументуатСчетНаОплатуПоставщика.ВалютаДокумента КАК ВалютаДокумента,
	ДокументуатСчетНаОплатуПоставщика.ДатаКон КАК ДатаКон,
	ДокументуатСчетНаОплатуПоставщика.ДатаНач КАК ДатаНач,
	ДокументуатСчетНаОплатуПоставщика.ДатаОплаты КАК ДатаОплаты,
	ДокументуатСчетНаОплатуПоставщика.ДатаОтгрузки КАК ДатаОтгрузки,
	ДокументуатСчетНаОплатуПоставщика.ДоговорКонтрагента КАК ДоговорКонтрагента,
	ДокументуатСчетНаОплатуПоставщика.ДокументОснование КАК ДокументОснование,
	ДокументуатСчетНаОплатуПоставщика.Комментарий КАК Комментарий,
	ДокументуатСчетНаОплатуПоставщика.КонтактноеЛицо КАК КонтактноеЛицо,
	ДокументуатСчетНаОплатуПоставщика.Контрагент КАК Контрагент,
	ДокументуатСчетНаОплатуПоставщика.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,
	ДокументуатСчетНаОплатуПоставщика.КурсВзаиморасчетов КАК КурсВзаиморасчетов,
	ДокументуатСчетНаОплатуПоставщика.Организация КАК Организация,
	ДокументуатСчетНаОплатуПоставщика.Ответственный КАК Ответственный,
	ДокументуатСчетНаОплатуПоставщика.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ДокументуатСчетНаОплатуПоставщика.СуммаВключаетНДС КАК СуммаВключаетНДС,
	ДокументуатСчетНаОплатуПоставщика.СуммаДокумента КАК СуммаДокумента,
	ДокументуатСчетНаОплатуПоставщика.УчитыватьНДС КАК УчитыватьНДС,
	ДокументуатСчетНаОплатуПоставщика.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	ДокументуатСчетНаОплатуПоставщика.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	ДокументуатСчетНаОплатуПоставщика.МоментВремени КАК МоментВремени,
	NULL КАК СостояниеОригиналаПервичногоДокумента,
	ИСТИНА КАК ОбщееСостояние,
	0 КАК СостояниеОригиналПолучен,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл,
	ЕСТЬNULL(ВЫБОР
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.Новый)
				ТОГДА 0
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.ЧастичноВыполнен)
				ТОГДА 2
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.Выполнен)
				ТОГДА 3
			ИНАЧЕ -1
		КОНЕЦ, -1) КАК ОплаченоСостояние,
	ВЫБОР
		КОГДА ДокументуатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС)
				ИЛИ ДокументуатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
				ИЛИ ДокументуатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
				ИЛИ ДокументуатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоДокументуАрендаТС)
			ТОГДА ЕСТЬNULL(уатТекущееСостояниеОплаты.ОплаченоПредставление, "")
		ИНАЧЕ "Не доступно"
	КОНЕЦ КАК ОплаченоПредставление,
	СогласованиеДО.Состояние КАК СогласованиеДО,
	ДокументуатСчетНаОплатуПоставщика.ТребуетСогласования КАК ТребуетСогласования,
	НЕ Согласования.КоличествоСогласований ЕСТЬ NULL КАК Согласован
ИЗ
	Документ.уатСчетНаОплатуПоставщика КАК ДокументуатСчетНаОплатуПоставщика
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументуатСчетНаОплатуПоставщика.Ссылка = НаличиеФайлов.ОбъектСФайлами
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатТекущееСостояниеОплаты КАК уатТекущееСостояниеОплаты
		ПО ДокументуатСчетНаОплатуПоставщика.Ссылка = уатТекущееСостояниеОплаты.Документ
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			СостоянияСогласованияВДокументообороте.Состояние КАК Состояние,
			СостоянияСогласованияВДокументообороте.Установил КАК Установил,
			СостоянияСогласованияВДокументообороте.ДатаУстановки КАК ДатаУстановки,
			ОбъектыИнтегрированныеС1СДокументооборотом.Объект КАК Объект
		ИЗ
			РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияСогласованияВДокументообороте КАК СостоянияСогласованияВДокументообороте
				ПО ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО = СостоянияСогласованияВДокументообороте.ИдентификаторОбъектаДО) КАК СогласованиеДО
		ПО ДокументуатСчетНаОплатуПоставщика.Ссылка = СогласованиеДО.Объект
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			тблДокумент.Ссылка КАК Документ,
			КОЛИЧЕСТВО(уатСогласование.Ссылка) КАК КоличествоСогласований
		ИЗ
			Документ.уатПотребностьВПеревозке_уэ КАК тблДокумент
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ БизнесПроцесс.уатСогласование КАК уатСогласование
				ПО тблДокумент.Ссылка = уатСогласование.Предмет
		ГДЕ
			уатСогласование.Завершен
			И (уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.Согласовано)
					ИЛИ уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.СогласованоСЗамечаниями))
			И НЕ уатСогласование.ПометкаУдаления
		
		СГРУППИРОВАТЬ ПО
			тблДокумент.Ссылка) КАК Согласования
		ПО ДокументуатСчетНаОплатуПоставщика.Ссылка = Согласования.Документ</QueryText>
