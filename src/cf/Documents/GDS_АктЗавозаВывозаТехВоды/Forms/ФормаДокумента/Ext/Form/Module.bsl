
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// ИнтеграцияС1СДокументооборотом
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец ИнтеграцияС1Сдокументооборотом
	
	Если Параметры.Ключ.Пустая() Тогда
		Объект.Ответственный = ПользователиКлиентСервер.АвторизованныйПользователь();
		Объект.Организация = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяОрганизация");
		
		ЗаполнитьОперации();
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбновитьНадписи();     
	РассчитатьПробег();
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// ИнтеграцияС1СДокументооборотом
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец ИнтеграцияС1Сдокументооборотом  
КонецПроцедуры 

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Операции.Итог("КолТехВоды") <>  Объект.ПутевыеЛисти.Итог("КолТехВоды") Тогда
		
	    Сообщение = Новый СообщениеПользователю();
	    Сообщение.Текст = "Ошибка! Не сходится количество воды в табличных частях!";
	    Сообщение.Сообщить();

		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

// СтандартныеПодсистемы.Свойства
&НаКлиенте
Процедура Подключаемый_СвойстваВыполнитьКоманду(ЭлементИлиКоманда, НавигационнаяСсылка = Неопределено, СтандартнаяОбработка = Неопределено)
	УправлениеСвойствамиКлиент.ВыполнитьКоманду(ЭтотОбъект, ЭлементИлиКоманда, СтандартнаяОбработка);
КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

// ИнтеграцияС1СДокументооборотом
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуИнтеграции(Команда)
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьПодключаемуюКомандуИнтеграции(Команда, ЭтотОбъект, Объект);
КонецПроцедуры
// Конец ИнтеграцияС1Сдокументооборотом

&НаКлиенте
Процедура Подбор(Команда)
	
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Ложь);

	ОткрытьФорму("Документ.уатПутевойЛист.Форма.ФормаВыбора", ПараметрыФормы, Элементы.ПутевыеЛисти);

КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовТаблицыФормыОперации 

&НаКлиенте
Процедура ОперацииПриИзменении(Элемент)
    ОбновитьНадписи();
КонецПроцедуры 

&НаКлиенте
Процедура ОперацииПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовТаблицыФормыПутевыеЛисти 

&НаКлиенте
Процедура ПутевыеЛистиПриИзменении(Элемент)      
	
	//ТекущиеДанные = Элементы.ПутевыеЛисти.ТекущиеДанные;
	
	ОбновитьНадписи(); 
	ОбновитьТСиВодителя();
	
КонецПроцедуры 

&НаКлиенте
Процедура ПутевыеЛистиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Для каждого ПутевойЛист Из ВыбранноеЗначение Цикл
		НоваяСтрока = Объект.ПутевыеЛисти.Добавить();
		НоваяСтрока.ПутевойЛист = ПутевойЛист;
	КонецЦикла;  
    ОбновитьТСиВодителя();
	РассчитатьПробег();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
	ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаСервере
Процедура ЗаполнитьОперации()
	Стр = Объект.Операции.Добавить();
	Стр.Наименование = Справочники.GDS_ОперацииПоЗавозуВывозуТехводы.Завоз;
	Стр = Объект.Операции.Добавить();
	Стр.Наименование = Справочники.GDS_ОперацииПоЗавозуВывозуТехводы.Довоз;
	Стр = Объект.Операции.Добавить();
	Стр.Наименование = Справочники.GDS_ОперацииПоЗавозуВывозуТехводы.Вывоз;
	Стр = Объект.Операции.Добавить();
	Стр.Наименование = Справочники.GDS_ОперацииПоЗавозуВывозуТехводы.ППУ;
	Стр = Объект.Операции.Добавить();
	Стр.Наименование = Справочники.GDS_ОперацииПоЗавозуВывозуТехводы.Промывка;
КонецПроцедуры

&НаСервере
Процедура ОбновитьНадписи()

	ИтогоОперации = Объект.Операции.Итог("КолТехВоды");
    ИтогоПутевыеЛисты = Объект.ПутевыеЛисти.Итог("КолТехВоды");
	
КонецПроцедуры 

 &НаКлиенте
Процедура РассчитатьПробег()

	Для каждого Строка из Объект.ПутевыеЛисти Цикл
		Строка.Пробег = ПолучитьПробег(Строка.ПутевойЛист);;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Функция ПолучитьПробег(ПутевойЛист)

	Пробег = ПутевойЛист.СпидометрВозвращения - ПутевойЛист.СпидометрВыезда;
	Если Пробег < 0 Тогда
		Пробег = 0;
	КонецЕсли;
	
	Возврат Пробег;

КонецФункции 

&НаСервере
Процедура ОбновитьТСиВодителя()

	Для каждого Строка из Объект.ПутевыеЛисти Цикл
		Строка.ТС = Строка.ПутевойЛист.ТранспортноеСредство;
		Строка.Водитель = Строка.ПутевойЛист.Водитель1;
		Если Не ЗначениеЗаполнено(Строка.КоличествоЕздок) Тогда
			Строка.КоличествоЕздок = 1;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры 

#КонецОбласти   

