Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ЗаполнитьПоШтрафам(Команда)
	Если Объект.Удержания.Количество() > 0 Тогда
		ТекстНСТР = НСтр("en='Table will be cleared before filling! Continue?';ru='Перед заполнением таблица будет очищена! Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьПоШтрафамВопрос", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Нет);
        Возврат;  
	КонецЕсли;  
	
	ЗаполнитьПоШтрафамОткрытьФормуЗаполнения();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоШтрафамВопрос(РезультатВопроса, ДополнительныеПараметры) Экспорт
    Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
        Возврат;
    Иначе
        Объект.Удержания.Очистить();
    КонецЕсли;  
    
    ЗаполнитьПоШтрафамОткрытьФормуЗаполнения();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоШтрафамОткрытьФормуЗаполнения()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация",      Объект.Организация);
	ПараметрыФормы.Вставить("ПериодНачисления", Объект.ПериодНачисления);
	ПараметрыФормы.Вставить("Сотрудник",        Объект.Сотрудник);
	Оповещ = Новый ОписаниеОповещения("ЗаполнитьПоШтрафамЗавершение", ЭтотОбъект);
    ОткрытьФорму("Документ.уатНачислениеУдержаний.Форма.ЗаполнениеПоШтрафам", ПараметрыФормы,,,,, Оповещ);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоШтрафамЗавершение(Результат, ДопПараметры) Экспорт
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("Штрафы")
		И ТипЗнч(Результат.Штрафы) = Тип("Массив") И Результат.Штрафы.Количество() > 0 Тогда
		ЗаполнитьПоШтрафамСервер(Результат.Штрафы);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоШтрафамСервер(мсвШтрафы)
	
	Для Каждого ТекСтрока Из мсвШтрафы Цикл
		НоваяСтрока = Объект.Удержания.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
	КонецЦикла;
	
	Объект.СуммаДокумента = Объект.Удержания.Итог("Сумма");
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовТаблицыФормыУдержания

&НаКлиенте
Процедура УдержанияТарифПриИзменении(Элемент)
	ТекСтрока = Элементы.Удержания.ТекущиеДанные;
	ТекСтрока.Удержание = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекСтрока.Тариф, "ВидНачисления");
	ТекСтрока.Сумма = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекСтрока.Тариф, "Тариф");
КонецПроцедуры

&НаКлиенте
Процедура УдержанияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле = Элементы.УдержанияОснование Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение(Неопределено, Элементы.Удержания.ТекущиеДанные.Основание);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти


