Функция ПолучитьКартинкуМакета(МакетТС, ШиринаМакета = Неопределено)
	КартинкаМакета = Неопределено;
	ШиринаМакета = 45; // по умолчанию
	
	ХранилищеМакета = МакетТС.ХранилищеМакета.Получить();
	Если ТипЗнч(ХранилищеМакета) = Тип("Картинка") Тогда
		КартинкаМакета = ХранилищеМакета;
	ИначеЕсли ТипЗнч(ХранилищеМакета) = Тип("Структура") Тогда
		Если ХранилищеМакета.Свойство("Файл") Тогда
			КартинкаМакета = Новый Картинка(ХранилищеМакета.Файл);
		ИначеЕсли ХранилищеМакета.Свойство("Макет") Тогда
			КартинкаМакета = ХранилищеМакета.Макет;
		КонецЕсли;
		Если ХранилищеМакета.Свойство("ШиринаМакета") Тогда
			ШиринаМакета = ХранилищеМакета.ШиринаМакета;
		КонецЕсли;
	КонецЕсли;
	
	Возврат КартинкаМакета;
КонецФункции

Функция ТаблицаКоординатШин(ШиринаМакетаКузова)
	
	Макет = Документы.уатАктПриемаПередачиТС.ПолучитьМакет("КоординатыШин");
	
	Рез = Новый ТаблицаЗначений;
	Рез.Колонки.Добавить("МестоУстановки");
	Рез.Колонки.Добавить("Лево");
	Рез.Колонки.Добавить("Верх");
	Рез.Колонки.Добавить("Высота");
	Рез.Колонки.Добавить("Ширина");
		
	Для Сч = 2 По Макет.ВысотаТаблицы Цикл
		НоваяСтрока = Рез.Добавить();
		НоваяСтрока.МестоУстановки = Макет.Область(Сч, 1, Сч, 1).Текст;
		НоваяСтрока.Лево = Число(Макет.Область(Сч, 2, Сч, 2).Текст);
		НоваяСтрока.Верх = Число(Макет.Область(Сч, 3, Сч, 3).Текст);
		НоваяСтрока.Ширина = Число(Макет.Область(Сч, 4, Сч, 4).Текст);
		НоваяСтрока.Высота = Число(Макет.Область(Сч, 5, Сч, 5).Текст);
		
		Если ШиринаМакетаКузова > 0 Тогда
			Если НоваяСтрока.МестоУстановки = "ЗАП" Тогда
				НоваяСтрока.Лево = НоваяСтрока.Лево + Окр((ШиринаМакетаКузова - 32)/2);
			ИначеЕсли СтрНайти("ПП,ДЗПВ,ДЗПН,ЗП,ЗПВ,ЗПН,СПВ,СПН", НоваяСтрока.МестоУстановки) <> 0 Тогда
				НоваяСтрока.Лево = НоваяСтрока.Лево + (ШиринаМакетаКузова - 32);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Рез;
	
КонецФункции

Функция ХозОперацияДляПечати(ВидОперации)

	Если ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.Осмотр Тогда
		Возврат "Акт осмотра ТС";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПервичныйОсмотр Тогда
		Возврат "Акт первичного осмотра ТС";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаАрендатору Тогда
		Возврат "Акт передачи ТС арендатору";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю Тогда
		Возврат "Акт передачи ТС водителю";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями Тогда
		Возврат "Акт передачи ТС между водителями";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПриемОтАрендатора Тогда
		Возврат "Акт приема ТС от арендатора";
	ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя Тогда
		Возврат "Акт приема ТС от водителя";
	Иначе
		Возврат "Акт приема-передачи ТС";
	КонецЕсли;

КонецФункции

