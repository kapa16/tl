	ОбновитьКоличествоСтрокВЗаголовкахСтраниц();
	ОбновитьФлагБезИзмененийВТЧ("КузовныеЭлементы");
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКузовныеЭлементыИзМоделиСервер()

	Объект.КузовныеЭлементы.Очистить();
	Для Каждого ТекТС Из ТСиПрицепыДокумента() Цикл
		Для Каждого ТекКузовнойЭлемент Из ТекТС.Модель.КузовныеЭлементы Цикл
			НоваяСтрока = Объект.КузовныеЭлементы.Добавить();
			НоваяСтрока.ТС = ТекТС;
			НоваяСтрока.КузовнойЭлемент = ТекКузовнойЭлемент.КузовнойЭлемент;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура МастерУстановкиШин(Команда)
	
	Если ЗначениеЗаполнено(Объект.Прицеп1) ИЛИ ЗначениеЗаполнено(Объект.Прицеп1) Тогда
		Оповещ = Новый ОписаниеОповещения("МастерУстановкиШинВыбратьТСПрицеп", ЭтотОбъект);
		списТС = Новый СписокЗначений;
		списТС.ЗагрузитьЗначения(ТСиПрицепыДокумента());
		списТС.ПоказатьВыборЭлемента(Оповещ, "Выберите ТС или прицеп");
		Возврат;
	КонецЕсли;
	
	МастерУстановкиШинОткрытьМастер(Объект.ТС);
	
КонецПроцедуры

&НаКлиенте
Процедура МастерУстановкиШинВыбратьТСПрицеп(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МастерУстановкиШинОткрытьМастер(Результат.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура МастерУстановкиШинОткрытьМастер(ТекТС)
	
	СтруктураПараметровПодбора = Новый Структура;
	СтруктураПараметровПодбора.Вставить("Ссылка", Объект.Ссылка);
	СтруктураПараметровПодбора.Вставить("Организация", Объект.Организация);
	СтруктураПараметровПодбора.Вставить("ТС", ТекТС);
	СтруктураПараметровПодбора.Вставить("ДатаРасчетов", Объект.ДатаОсмотра-1);
	Если Объект.Шины.Количество() > 0 Тогда
		мсвШины = Новый Массив;
		Для Каждого ТекСтрока Из Объект.Шины Цикл
			СтруктураСтрокиШина = Новый Структура;
			СтруктураСтрокиШина.Вставить("СерияНоменклатуры", ТекСтрока.СерияНоменклатуры);
			Если ЗначениеЗаполнено(ТекСтрока.Состояние) Тогда
				СтруктураСтрокиШина.Вставить("Состояние",      ТекСтрока.Состояние);
				СтруктураСтрокиШина.Вставить("МестоУстановки", ТекСтрока.МестоУстановки);
			    СтруктураСтрокиШина.Вставить("СтепеньИзноса",  ТекСтрока.СтепеньИзноса);
			Иначе
				СтруктураСтрокиШина.Вставить("Состояние",      ТекСтрока.СостояниеПредыдущее);
				СтруктураСтрокиШина.Вставить("МестоУстановки", ТекСтрока.МестоУстановкиПредыдущее);
			    СтруктураСтрокиШина.Вставить("СтепеньИзноса",  ТекСтрока.СтепеньИзносаПредыдущая);
			КонецЕсли;
			мсвШины.Добавить(СтруктураСтрокиШина);
		КонецЦикла;
		СтруктураПараметровПодбора.Вставить("Шины", мсвШины);
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.уатМастерУстановкиШин", СтруктураПараметровПодбора, ЭтотОбъект,,,, Неопределено,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиРеквизитовФормы

&НаКлиенте
Процедура ДатаОсмотраПриИзменении(Элемент)
		
	НайтиПредыдущийАктПриемаПередачи();
	ЗаполнитьПутевойЛист(1);
	ЗаполнитьПутевойЛист(2);
	
	Если ЗначениеЗаполнено(Объект.Одометр)
		ИЛИ ЗначениеЗаполнено(Объект.ОстатокТоплива) Тогда
		ТекстНСТР = НСтр("ru = 'Очистить одометр и уровень топлива?'; en = 'Clear odometer and fuel level?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ОчисткаОдометра", ЭтотОбъект), ТекстНСТР, РежимДиалогаВопрос.ДаНетОтмена);
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура РежимОтображенияПриИзменении(Элемент)
	НастроитьРежимОтображения();
	ОбновитьДопНумерациюСтрок();
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура СкрытьСтрокиБезИзмененийПриИзменении(Элемент)
	НастроитьРежимОтображения();
КонецПроцедуры

&НаКлиенте
Процедура ТСПриИзменении(Элемент)
	
	Если Объект.ТС = ТСстарое Тогда
		Возврат;
	КонецЕсли;
	
	// установим текущее местонахождение ТС
	Если ЗначениеЗаполнено(Объект.ТС)
		И уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ТС, "ПринадлежностьТС")
		= ПредопределенноеЗначение("Перечисление.уатПринадлежностьТС.Собственное") Тогда
		МестонахождениеТС = уатОбщегоНазначения.МестонахождениеТС(Объект.ТС, Объект.ДатаОсмотра);
		Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
			Объект.Организация = МестонахождениеТС.Организация;
		КонецЕсли;
		//Если НЕ ЗначениеЗаполнено(Объект.Подразделение) Тогда
		//	Объект.Подразделение = МестонахождениеТС.Подразделение;
		//КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Прицеп1) ИЛИ ЗначениеЗаполнено(Объект.Прицеп2)
		ИЛИ Объект.Шины.Количество() > 0 ИЛИ Объект.Агрегаты.Количество() > 0
		ИЛИ Объект.ЭлементыКомплектации.Количество() > 0 ИЛИ Объект.КузовныеЭлементы.Количество() > 0 Тогда
		
		ТекстНСТР = НСтр("en='document is completed table to be cleaned! Continue?';ru='Заполненные прицепы и табличные части будут очищены! Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ТСПриИзмененииВопрос", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ОКОтмена);
		Возврат;
	КонецЕсли;
	
	ТСПриИзмененииЗавершение();
	ИнициализацияДанныхАвтомобиляСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ТСПриИзмененииВопрос(Результат, ДопПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.ОК Тогда
		Объект.ТС = ТСстарое;
		Возврат;
	КонецЕсли;
	
	ТСПриИзмененииЗавершение();
		
КонецПроцедуры

&НаКлиенте
Процедура ТСПриИзмененииЗавершение()
	
	Объект.Прицеп1 = Неопределено;
	Объект.Прицеп2 = Неопределено;
	мсвПрицепы = уатОбщегоНазначения.уатСоставТС(Объект.ТС);
	Если мсвПрицепы.Количество() > 0 Тогда
		Объект.Прицеп1 = мсвПрицепы[0];
	КонецЕсли;
	Если мсвПрицепы.Количество() > 1 Тогда
		Объект.Прицеп2 = мсвПрицепы[1];
	КонецЕсли;
	
	ОбработатьИзменениеТСПрицепа();
	
	ЗаполнитьПутевойЛист(1);
	ЗаполнитьПутевойЛист(2);
	ЗаполнитьШиныСервер();
	ЗаполнитьАгрегатыСервер();
	ЗаполнитьЭлементыКомплектацииСервер();
	ЗаполнитьКузовныеЭлементыСервер();
	
	НайтиПредыдущийАктПриемаПередачи();
	ОбновитьДопНумерациюСтрок();
	НастроитьРежимОтображения();
	ОбновитьФлагБезИзмененийВТЧ();
	УстановитьВидимость();
	
	ТСстарое = Объект.ТС;
	МодельТС = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ТС, "Модель");
	
	Объект.ПунктОсмотраТС = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ТС, "Гараж");
	
КонецПроцедуры

&НаСервере
Процедура ИнициализацияДанныхАвтомобиляСервер()
	Если НЕ ЗначениеЗаполнено(Объект.ТС)
		ИЛИ Объект.ТС.Модель.НаличиеСпидометра Тогда
		Элементы.Одометр.Заголовок = НСтр("en='Odometer';ru='Одометр'");
	Иначе
		Элементы.Одометр.Заголовок = НСтр("en='Counter m/h';ru='Счетчик м/ч'");
	КонецЕсли;
КонецПроцедуры

