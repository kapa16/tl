&НаСервере
Процедура УстановитьОтборНоменклатурыПриОткрытии()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВидыНоменклатуры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|ГДЕ
	|	НЕ ВидыНоменклатуры.Услуга
	|	И НЕ ВидыНоменклатуры.ПометкаУдаления");
	мсвВидНоменклатуры = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	мсвПараметрыВыбора = Новый Массив;
	мсвПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ВидНоменклатуры", мсвВидНоменклатуры));
	Элементы.КузовныеЭлементыНоменклатура.ПараметрыВыбора = Новый ФиксированныйМассив(мсвПараметрыВыбора);
	Элементы.ЭлементыКомплектацииНоменклатура.ПараметрыВыбора = Новый ФиксированныйМассив(мсвПараметрыВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьРежимОтображения()
	
	ЗначениеОтбораТС = Неопределено;
	Если РежимОтображения = "ТС" Тогда
		ЗначениеОтбораТС = Объект.ТС;
	ИначеЕсли РежимОтображения = "Прицеп 1" Тогда
		ЗначениеОтбораТС = Объект.Прицеп1;
	ИначеЕсли РежимОтображения = "Прицеп 2" Тогда
		ЗначениеОтбораТС = Объект.Прицеп2;
	КонецЕсли;
	
	Если ЗначениеОтбораТС = Неопределено Тогда
		Если СкрытьСтрокиБезИзменений Тогда
			ОтборТС = Новый ФиксированнаяСтруктура("БезИзменений", Ложь);
		Иначе
			ОтборТС = Неопределено;
		КонецЕсли;
	Иначе
		Если СкрытьСтрокиБезИзменений Тогда
			ОтборТС = Новый ФиксированнаяСтруктура("ТС, БезИзменений", ЗначениеОтбораТС, Ложь);
		Иначе
			ОтборТС = Новый ФиксированнаяСтруктура("ТС", ЗначениеОтбораТС);
		КонецЕсли;
	КонецЕсли;
	
	Элементы.Шины.ОтборСтрок                  = ОтборТС;
	Элементы.Агрегаты.ОтборСтрок              = ОтборТС;
	Элементы.ЭлементыКомплектации.ОтборСтрок  = ОтборТС;
	Элементы.КузовныеЭлементы.ОтборСтрок      = ОтборТС;
	
	УстановитьВидимость();
			
КонецПроцедуры

&НаКлиенте
Функция ТСПоРежимуОтображения()
	Если РежимОтображения = "ТС" Тогда
		РезТС = Объект.ТС;
	ИначеЕсли РежимОтображения = "Прицеп 1" Тогда
		РезТС = Объект.Прицеп1;
	ИначеЕсли РежимОтображения = "Прицеп 2" Тогда
		РезТС = Объект.Прицеп2;
	Иначе
		Если НЕ ЗначениеЗаполнено(Объект.Прицеп1) И НЕ ЗначениеЗаполнено(Объект.Прицеп1) Тогда
			РезТС = Объект.ТС;
		Иначе
			РезТС = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезТС;
КонецФункции

&НаКлиенте
Процедура ОбновитьДопНумерациюСтрок(ИмяТЧ = Неопределено)
	
	РежимОтображенияПоКаждомуТС = (РежимОтображения = "ТС" ИЛИ РежимОтображения = "Прицеп 1"
		ИЛИ РежимОтображения = "Прицеп 2");
		
	мсвТЧ = Новый Массив;
	Если ЗначениеЗаполнено(ИмяТЧ) Тогда
		мсвТЧ.Добавить(ИмяТЧ);
	Иначе
		мсвТЧ.Добавить("Шины");
		мсвТЧ.Добавить("Агрегаты");
		мсвТЧ.Добавить("ЭлементыКомплектации");
		мсвТЧ.Добавить("КузовныеЭлементы");
	КонецЕсли;
	
	Для Каждого ТекИмяТЧ Из мсвТЧ Цикл	
		СчСтрокТС = 1;
		СчСтрокПрицеп1 = 1;
		СчСтрокПрицеп2 = 1;
		Для Каждого ТекСтрока Из Объект[ТекИмяТЧ] Цикл
			Если РежимОтображенияПоКаждомуТС Тогда
				Если ТекСтрока.ТС = Объект.ТС Тогда
					ТекСтрока.НомерСтрокиДоп = СчСтрокТС;
					СчСтрокТС = СчСтрокТС + 1;
				ИначеЕсли ЗначениеЗаполнено(Объект.Прицеп1) И ТекСтрока.ТС = Объект.Прицеп1 Тогда
					ТекСтрока.НомерСтрокиДоп = СчСтрокПрицеп1;
					СчСтрокПрицеп1 = СчСтрокПрицеп1 + 1;
				ИначеЕсли ЗначениеЗаполнено(Объект.Прицеп2) И ТекСтрока.ТС = Объект.Прицеп2 Тогда
					ТекСтрока.НомерСтрокиДоп = СчСтрокПрицеп2;
					СчСтрокПрицеп2 = СчСтрокПрицеп2 + 1;
				Иначе
					ТекСтрока.НомерСтрокиДоп = 0;
				КонецЕсли;
			Иначе
				ТекСтрока.НомерСтрокиДоп = ТекСтрока.НомерСтроки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоСтрокВЗаголовкахСтраниц()
	
	РежимОтображенияПоКаждомуТС = (РежимОтображения = "ТС" ИЛИ РежимОтображения = "Прицеп 1"
		ИЛИ РежимОтображения = "Прицеп 2");
		
	мсвТЧ = Новый Массив;
	мсвТЧ.Добавить("Шины");
	мсвТЧ.Добавить("Агрегаты");
	мсвТЧ.Добавить("ЭлементыКомплектации");
	мсвТЧ.Добавить("КузовныеЭлементы");
	Для Каждого ТекИмяТЧ Из мсвТЧ Цикл	
		СчСтрокТС = 0;
		Для Каждого ТекСтрока Из Объект[ТекИмяТЧ] Цикл
			Если СкрытьСтрокиБезИзменений И ТекСтрока.БезИзменений Тогда
				Продолжить;
			КонецЕсли;
			
			Если РежимОтображенияПоКаждомуТС Тогда
				Если РежимОтображения = "ТС" И ТекСтрока.ТС = Объект.ТС
					ИЛИ РежимОтображения = "Прицеп 1" И ЗначениеЗаполнено(Объект.Прицеп1) И ТекСтрока.ТС = Объект.Прицеп1
					ИЛИ РежимОтображения = "Прицеп 2" И ЗначениеЗаполнено(Объект.Прицеп2) И ТекСтрока.ТС = Объект.Прицеп2 Тогда
					СчСтрокТС = СчСтрокТС + 1;
				КонецЕсли;
			Иначе
				СчСтрокТС = СчСтрокТС + 1;
			КонецЕсли;
		КонецЦикла;
		ЭтаФорма["КоличествоСтрок" + ТекИмяТЧ] = СчСтрокТС;
	КонецЦикла;
	
	ОбновитьВидПереключателяРежимОтображения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьВидПереключателяРежимОтображения()
	
	мсвТЧ = Новый Массив;
	мсвТЧ.Добавить("Шины");
	мсвТЧ.Добавить("Агрегаты");
	мсвТЧ.Добавить("КузовныеЭлементы");
	мсвТЧ.Добавить("ЭлементыКомплектации");
	Для Каждого ТекИмяТЧ Из мсвТЧ Цикл
		КоличествоЗаголовок = Новый Структура;
		Если СкрытьСтрокиБезИзменений Тогда
			КоличествоЗаголовок.Вставить("Все", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("БезИзменений", Ложь)).Количество());
			КоличествоЗаголовок.Вставить("ТС", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС, БезИзменений", Объект.ТС, Ложь)).Количество());
			КоличествоЗаголовок.Вставить("Прицеп1", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС, БезИзменений", Объект.Прицеп1, Ложь)).Количество());
			КоличествоЗаголовок.Вставить("Прицеп2", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС, БезИзменений", Объект.Прицеп2, Ложь)).Количество());
		Иначе
			КоличествоЗаголовок.Вставить("Все", Объект[ТекИмяТЧ].Количество());
			КоличествоЗаголовок.Вставить("ТС", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС", Объект.ТС)).Количество());
			КоличествоЗаголовок.Вставить("Прицеп1", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС", Объект.Прицеп1)).Количество());
			КоличествоЗаголовок.Вставить("Прицеп2", Объект[ТекИмяТЧ].НайтиСтроки(Новый Структура("ТС", Объект.Прицеп2)).Количество());
		КонецЕсли;
		
		РежимОтображенияСписокВыбора = Элементы[ТекИмяТЧ + "РежимОтображения"].СписокВыбора;
		РежимОтображенияСписокВыбора.Очистить();
		РежимОтображенияСписокВыбора.Добавить("Все", "Все (" + КоличествоЗаголовок.Все + ")");
		РежимОтображенияСписокВыбора.Добавить("ТС", "ТС (" + КоличествоЗаголовок.ТС + ")");
		Если ЗначениеЗаполнено(Объект.Прицеп1) И ЗначениеЗаполнено(Объект.Прицеп2) Тогда
			РежимОтображенияСписокВыбора.Добавить("Прицеп 1", "Прицеп 1 (" + КоличествоЗаголовок.Прицеп1 + ")");
			РежимОтображенияСписокВыбора.Добавить("Прицеп 2", "Прицеп 2 (" + КоличествоЗаголовок.Прицеп2 + ")");
		ИначеЕсли ЗначениеЗаполнено(Объект.Прицеп1) Тогда
			РежимОтображенияСписокВыбора.Добавить("Прицеп 1", "Прицеп (" + КоличествоЗаголовок.Прицеп1 + ")");
		ИначеЕсли ЗначениеЗаполнено(Объект.Прицеп2) Тогда
			РежимОтображенияСписокВыбора.Добавить("Прицеп 2", "Прицеп (" + КоличествоЗаголовок.Прицеп2 + ")");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция СтруктураОтбораТС()
	
	СтруктураОтбора = Новый Структура();
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		СтруктураОтбора.Вставить("Организация", Объект.Организация);
	КонецЕсли;
	//Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
	//	СтруктураОтбора.Вставить("Подразделение", Объект.Подразделение);
	//КонецЕсли;
	мсвПринадлежностьТС = Новый Массив;
	мсвПринадлежностьТС.Добавить(ПредопределенноеЗначение("Перечисление.уатПринадлежностьТС.Собственное"));
	мсвПринадлежностьТС.Добавить(ПредопределенноеЗначение("Перечисление.уатПринадлежностьТС.Привлеченное"));
	СтруктураОтбора.Вставить("ПринадлежностьТС", мсвПринадлежностьТС);
	
	Возврат СтруктураОтбора;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьЗаголовокПредыдущееСостояниеВТЧ(ИмяТЧ = Неопределено)
	
	Если ИмяТЧ = Неопределено Тогда
		ОбновитьЗаголовокПредыдущееСостояниеВТЧ("Шины");
		ОбновитьЗаголовокПредыдущееСостояниеВТЧ("Агрегаты");
		ОбновитьЗаголовокПредыдущееСостояниеВТЧ("КузовныеЭлементы");
		ОбновитьЗаголовокПредыдущееСостояниеВТЧ("ЭлементыКомплектации");
		Возврат;
	КонецЕсли;
	
	ПредыдущаяДатаОсмотра = НачалоМинуты(уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ПредыдущийАктПриемаПередачи, "ДатаОсмотра"));
	Элементы[ИмяТЧ + "ГруппаПредыдущее"].Заголовок = Нстр("en = 'Previous inspection'; ru = 'Предыдущий осмотр'") + ?(ЗначениеЗаполнено(ПредыдущаяДатаОсмотра),
		" " + Формат(ПредыдущаяДатаОсмотра, "ДФ='dd.MM.yyyy HH:mm'"),  "");
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()
	
	ЕстьПрицепы = ЗначениеЗаполнено(Объект.Прицеп1) ИЛИ ЗначениеЗаполнено(Объект.Прицеп2);
	
	Элементы.ШиныРежимОтображения.Видимость                 = ЕстьПрицепы;
	Элементы.АгрегатыРежимОтображения.Видимость             = ЕстьПрицепы;
	Элементы.КузовныеЭлементыРежимОтображения.Видимость     = ЕстьПрицепы;
	Элементы.ЭлементыКомплектацииРежимОтображения.Видимость = ЕстьПрицепы;
	
	ВидимостьТС = (Элементы.Шины.ОтборСтрок = Неопределено ИЛИ НЕ Элементы.Шины.ОтборСтрок.Свойство("ТС")) И ЕстьПрицепы;
	
	Элементы.ШиныТС.Видимость                 = ВидимостьТС;
	Элементы.АгрегатыТС.Видимость             = ВидимостьТС;
	Элементы.ЭлементыКомплектацииТС.Видимость = ВидимостьТС;
	Элементы.КузовныеЭлементыТС.Видимость     = ВидимостьТС;
	
	ОбновитьКоличествоСтрокВЗаголовкахСтраниц();
		
	Элементы.ФормаВидОперацииПередачаВодителю.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю"));
	Элементы.ФормаВидОперацииПриемОтВодителя.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя"));
	Элементы.ФормаВидОперацииПередачаМеждуВодителями.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"));
	Элементы.ФормаВидОперацииПередачаАрендатору.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаАрендатору"));
	Элементы.ФормаВидОперацииПриемОтАрендатора.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтАрендатора"));
	Элементы.ФормаВидОперацииОсмотр.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.Осмотр"));
	Элементы.ФормаВидОперацииПервичныйОсмотр.Пометка = (Объект.ВидОперации =
		ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПервичныйОсмотр"));
		
	Элементы.Сдал.Видимость = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтАрендатора"));
	Элементы.Принял.Видимость = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаАрендатору"));
	Элементы.ОсмотрПровел.Видимость = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.Осмотр"))
		ИЛИ (Объект.ВидОперации	= ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПервичныйОсмотр"));

	Элементы.ГруппаПЛ1.Видимость = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"));
	Элементы.ГруппаПЛ2.Видимость = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю"))
		ИЛИ (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"));
		
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями") Тогда	
		Элементы.ДекорацияПЛ1.Заголовок = "Путевой лист 1:";
	Иначе
		Элементы.ДекорацияПЛ1.Заголовок = "Путевой лист:";
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями") Тогда	
		Элементы.ДекорацияПЛ2.Заголовок = "Путевой лист 2:";
	Иначе
		Элементы.ДекорацияПЛ2.Заголовок = "Путевой лист:";
	КонецЕсли;

	УстановитьВидимостьКомандМониторинга();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьКомандМониторинга()
	мсвПрицепы = Новый Массив();
	уатМониторинг.УстановитьВидимостьКомандМониторинга(Элементы, Объект.ТС, мсвПрицепы);
КонецПроцедуры

&НаСервере
Процедура НайтиПредыдущийАктПриемаПередачи()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	уатАктПриемаПередачиТС.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.уатАктПриемаПередачиТС КАК уатАктПриемаПередачиТС
	|ГДЕ
	|	уатАктПриемаПередачиТС.ТС = &ТС
	|	И уатАктПриемаПередачиТС.Проведен
	|	И уатАктПриемаПередачиТС.ДатаОсмотра < &Период
	|
	|УПОРЯДОЧИТЬ ПО
	|	уатАктПриемаПередачиТС.ДатаОсмотра УБЫВ");
	Запрос.УстановитьПараметр("ТС", Объект.ТС);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Объект.ДатаОсмотра), Объект.ДатаОсмотра, ТекущаяДата()));
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПредыдущийАктПриемаПередачи = Выборка.Ссылка;
		Элементы.ПолеПредыдущийОсмотрНеВыполнялся.Видимость = Ложь;
		Элементы.ПредыдущийАктПриемаПередачи.Видимость = Истина;
		//Элементы.ДекорацияПредОсмотрНеВыполнялся.Видимость = Ложь;
	Иначе
		Элементы.ПолеПредыдущийОсмотрНеВыполнялся.Видимость = Истина;
		ПолеПредыдущийОсмотрНеВыполнялся = Нстр("en = 'Not performed'; ru = 'Не выполнялся'");
		Элементы.ПредыдущийАктПриемаПередачи.Видимость = Ложь;
		//Элементы.ДекорацияПредОсмотрНеВыполнялся.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредыдущееСостояниеШин()
	
	тблШиныПред = уатОбщегоНазначения.уатШиныТС(ТСиПрицепыДокумента(), Объект.ДатаОсмотра-1);
		
	Для Каждого ТекСтрока Из Объект.Шины Цикл
		мсвСтрокиПоиск = тблШиныПред.НайтиСтроки(Новый Структура("ТС, СерияНоменклатуры",
			ТекСтрока.ТС, ТекСтрока.СерияНоменклатуры));
		Если мсвСтрокиПоиск.Количество() > 0 Тогда
			ТекСтрока.СостояниеПредыдущее      = мсвСтрокиПоиск[0].Состояние;
			ТекСтрока.МестоУстановкиПредыдущее = мсвСтрокиПоиск[0].МестоУстановки;
			ТекСтрока.СтепеньИзносаПредыдущая  = мсвСтрокиПоиск[0].СтепеньИзноса;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредыдущееСостояниеАгрегатов()
	
	тблАгрегатыПред = уатОбщегоНазначения.уатАгрегатыТСКромеШин(ТСиПрицепыДокумента(), Объект.ДатаОсмотра-1);
		
	Для Каждого ТекСтрока Из Объект.Агрегаты Цикл
		мсвСтрокиПоиск = тблАгрегатыПред.НайтиСтроки(Новый Структура("ТС, СерияНоменклатуры",
			ТекСтрока.ТС, ТекСтрока.СерияНоменклатуры));
		Если мсвСтрокиПоиск.Количество() > 0 Тогда
			ТекСтрока.СостояниеПредыдущее = мсвСтрокиПоиск[0].Состояние;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредыдущееСостояниеКузовныхЭлементов()
	
	тблКузовныеЭлементыПред = уатОбщегоНазначения_проф.уатКузовныеЭлементыТС(ТСиПрицепыДокумента(), Объект.ДатаОсмотра-1);
		
	Для Каждого ТекСтрока Из Объект.КузовныеЭлементы Цикл
		мсвСтрокиПоиск = тблКузовныеЭлементыПред.НайтиСтроки(Новый Структура("ТС, КузовнойЭлемент",
			ТекСтрока.ТС, ТекСтрока.КузовнойЭлемент));
		Если мсвСтрокиПоиск.Количество() > 0 Тогда
			ТекСтрока.СостояниеПредыдущее           = мсвСтрокиПоиск[0].Состояние;
			ТекСтрока.НаличиеПоврежденийПредыдущее  = мсвСтрокиПоиск[0].НаличиеПовреждений;
			ТекСтрока.ХарактерПоврежденийПредыдущий = мсвСтрокиПоиск[0].ХарактерПовреждений;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьФлагБезИзмененийВТЧ(ИмяТЧ = Неопределено)
	
	Если ИмяТЧ = Неопределено Тогда
		ОбновитьФлагБезИзмененийВТЧ("Шины");
		ОбновитьФлагБезИзмененийВТЧ("Агрегаты");
		ОбновитьФлагБезИзмененийВТЧ("КузовныеЭлементы");
		ОбновитьФлагБезИзмененийВТЧ("ЭлементыКомплектации");
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекСтрока Из Объект[ИмяТЧ] Цикл
		Если ИмяТЧ = "Шины" Тогда
			ТекСтрока.БезИзменений =
				ТекСтрока.Состояние = ТекСтрока.СостояниеПредыдущее
			    И ТекСтрока.МестоУстановки = ТекСтрока.МестоУстановкиПредыдущее
				И ТекСтрока.СтепеньИзноса = ТекСтрока.СтепеньИзносаПредыдущая;
				
		ИначеЕсли ИмяТЧ = "Агрегаты" Тогда
			ТекСтрока.БезИзменений =
				ТекСтрока.Состояние = ТекСтрока.СостояниеПредыдущее;
			    
		ИначеЕсли ИмяТЧ = "КузовныеЭлементы" Тогда
			ТекСтрока.БезИзменений =
				ТекСтрока.Состояние = ТекСтрока.СостояниеПредыдущее
				И ТекСтрока.НаличиеПовреждений = ТекСтрока.НаличиеПоврежденийПредыдущее
				И ТекСтрока.ХарактерПовреждений = ТекСтрока.ХарактерПоврежденийПредыдущий;
				
		ИначеЕсли ИмяТЧ = "ЭлементыКомплектации" Тогда
			ТекСтрока.БезИзменений =
				ТекСтрока.Состояние = ТекСтрока.СостояниеПредыдущее
				И ТекСтрока.НаличиеПовреждений = ТекСтрока.НаличиеПоврежденийПредыдущее
				И ТекСтрока.ХарактерПовреждений = ТекСтрока.ХарактерПоврежденийПредыдущий
				И ТекСтрока.Количество = ТекСтрока.КоличествоПредыдущее;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьРасчетныйИзносШин()
	
	мсвТС = Новый Массив;
	мсвТС.Добавить(Объект.ТС);
	мсвТС.Добавить(Объект.Прицеп1);
	мсвТС.Добавить(Объект.Прицеп2);
	мсвШины = Объект.Шины.Выгрузить().ВыгрузитьКолонку("СерияНоменклатуры");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	уатИзносАгрегатовОбороты.ТС КАК ТС,
	|	уатИзносАгрегатовОбороты.СерияНоменклатуры КАК СерияНоменклатуры,
	|	ВЫБОР
	|		КОГДА уатИзносАгрегатовОбороты.СерияНоменклатуры.Модель.НормаПробега = 0
	|			ТОГДА 0
	|		ИНАЧЕ уатИзносАгрегатовОбороты.ПробегОборот / уатИзносАгрегатовОбороты.СерияНоменклатуры.Модель.НормаПробега * 100
	|	КОНЕЦ КАК ПроцентИспользования
	|ИЗ
	|	РегистрНакопления.уатИзносАгрегатов.Обороты(
	|			,
	|			&Период,
	|			,
	|			ТС В (&ТС)
	|				И СерияНоменклатуры В (&Шины)) КАК уатИзносАгрегатовОбороты");
	Запрос.УстановитьПараметр("ТС", мсвТС);
	Запрос.УстановитьПараметр("Шины", мсвШины);
	Запрос.УстановитьПараметр("Период", Объект.ДатаОсмотра-1);
	
	тблРасчетныйИзнос = Запрос.Выполнить().Выгрузить();
	
	Для Каждого ТекСтрока Из Объект.Шины Цикл
		мсвСтрокиПоиск = тблРасчетныйИзнос.НайтиСтроки(Новый Структура("ТС, СерияНоменклатуры",
			ТекСтрока.ТС, ТекСтрока.СерияНоменклатуры));
		Если мсвСтрокиПоиск.Количество() > 0 Тогда
			ТекСтрока.РасчетныйИзнос = мсвСтрокиПоиск[0].ПроцентИспользования;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТСиПрицепыДокумента()
	
	Возврат Документы.уатАктПриемаПередачиТС.ТСиПрицепыДокумента(Объект);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПутевойЛист(НомерПЛ)
	
	Если НомерПЛ = 1
		И Объект.ВидОперации <> Перечисления.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя
		И Объект.ВидОперации <> Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями Тогда
		Объект.ПутевойЛист1 = Неопределено;
		Возврат;
	ИначеЕсли НомерПЛ = 2
		И Объект.ВидОперации <> Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю
		И Объект.ВидОперации <> Перечисления.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями Тогда
		Объект.ПутевойЛист2 = Неопределено;
		Возврат;
	КонецЕсли;
	
	Если НомерПЛ = 1 Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	уатПутевойЛист.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.уатПутевойЛист КАК уатПутевойЛист
		|ГДЕ
		|	уатПутевойЛист.Проведен
		|	И НЕ уатПутевойЛист.ПометкаУдаления
		|	И (уатПутевойЛист.ТранспортноеСредство = &ТС
		|			ИЛИ уатПутевойЛист.Прицепы.ТС = &ТС
		|			ИЛИ уатПутевойЛист.Задание.Прицеп1 = &ТС
		|			ИЛИ уатПутевойЛист.Задание.Прицеп2 = &ТС)
		|	И уатПутевойЛист.ДатаВыезда < &ДатаОсмотра
		|	И (&Водитель = НЕОПРЕДЕЛЕНО
		|			ИЛИ уатПутевойЛист.Водитель1 = &Водитель
		|			ИЛИ уатПутевойЛист.Водитель2 = &Водитель)
		|
		|УПОРЯДОЧИТЬ ПО
		|	уатПутевойЛист.ДатаВозвращения УБЫВ");
		Запрос.УстановитьПараметр("Водитель", ?(ЗначениеЗаполнено(Объект.Сдал), Объект.Сдал, Неопределено));
	Иначе
		Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	уатПутевойЛист.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.уатПутевойЛист КАК уатПутевойЛист
		|ГДЕ
		|	уатПутевойЛист.Проведен
		|	И НЕ уатПутевойЛист.ПометкаУдаления
		|	И (уатПутевойЛист.ТранспортноеСредство = &ТС
		|			ИЛИ уатПутевойЛист.Прицепы.ТС = &ТС
		|			ИЛИ уатПутевойЛист.Задание.Прицеп1 = &ТС
		|			ИЛИ уатПутевойЛист.Задание.Прицеп2 = &ТС)
		|	И уатПутевойЛист.ДатаВозвращения > &ДатаОсмотра
		|	И (&Водитель = НЕОПРЕДЕЛЕНО
		|			ИЛИ уатПутевойЛист.Водитель1 = &Водитель
		|			ИЛИ уатПутевойЛист.Водитель2 = &Водитель)
		|
		|УПОРЯДОЧИТЬ ПО
		|	уатПутевойЛист.ДатаВыезда");
		Запрос.УстановитьПараметр("Водитель", ?(ЗначениеЗаполнено(Объект.Принял), Объект.Принял, Неопределено));
	КонецЕсли;
	Запрос.УстановитьПараметр("ТС", Объект.ТС);
	Запрос.УстановитьПараметр("ДатаОсмотра", Объект.ДатаОсмотра);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если НомерПЛ = 1 Тогда
		Если Выборка.Следующий() Тогда
			Объект.ПутевойЛист1 = Выборка.Ссылка;
		Иначе
			Объект.ПутевойЛист1 = Неопределено;
		КонецЕсли;
	Иначе
		Если Выборка.Следующий() Тогда
			Объект.ПутевойЛист2 = Выборка.Ссылка;
		Иначе
			Объект.ПутевойЛист2 = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьВодителяИзПЛ(НомерПЛ);
	
КонецПроцедуры

Процедура ЗаполнитьВодителяИзПЛ(НомерПЛ)
	
	Если НомерПЛ = 1 И НЕ ЗначениеЗаполнено(Объект.Сдал) И ЗначениеЗаполнено(Объект.ПутевойЛист1) Тогда
		ВодительПЛ = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ПутевойЛист1, "Водитель1");
		Если ЗначениеЗаполнено(ВодительПЛ) Тогда
			Объект.Сдал = ВодительПЛ;
		КонецЕсли;
	ИначеЕсли НомерПЛ = 2 И НЕ ЗначениеЗаполнено(Объект.Принял) И ЗначениеЗаполнено(Объект.ПутевойЛист2) Тогда
		ВодительПЛ = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ПутевойЛист2, "Водитель1");
		Если ЗначениеЗаполнено(ВодительПЛ) Тогда
			Объект.Принял = ВодительПЛ;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
	
&НаКлиенте
Процедура ВидОперацииПриИзменении(НовыйВидОперации)
	
	Если Объект.ВидОперации = НовыйВидОперации Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ВидОперации = НовыйВидОперации;
	
	// Очистка реквизитов, не связанных с операцией
	Если (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтАрендатора")) Тогда
		Объект.Сдал = Неопределено;
	КонецЕсли;
	Если (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаАрендатору")) Тогда
		Объект.Принял = Неопределено;
	КонецЕсли;
	Если (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.Осмотр"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПервичныйОсмотр")) Тогда
		Объект.ОсмотрПровел = Неопределено;
	КонецЕсли;
	
	Если (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтВодителя"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями")) Тогда
		Объект.ПутевойЛист1 = Неопределено;
	КонецЕсли;
	Если (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаВодителю"))
		И (Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаМеждуВодителями")) Тогда
		Объект.ПутевойЛист2 = Неопределено;
	КонецЕсли;
	
	ЗаполнитьПутевойЛист(1);
	ЗаполнитьПутевойЛист(2);
	
	ЗаголовокСдалПринял = "Информация об операции: " + НРег(Объект.ВидОперации);
	
	УстановитьОграничениеТипаСдалПринял();
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОграничениеТипаСдалПринял()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПриемОтАрендатора") Тогда
		Элементы.Сдал.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица");
	Иначе
		Элементы.Сдал.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.уатВидыОперацийАктПриемаПередачи.ПередачаАрендатору") Тогда
		Элементы.Принял.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица");
	Иначе
		Элементы.Принял.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеТСПрицепа()
	
	// Удаление строк ТЧ, в которых есть ТС или прицеп, которых нет в шапке документа
	мсвТС = ТСиПрицепыДокумента();
	мсвТЧ = Новый Массив;
	мсвТЧ.Добавить("Шины");
	мсвТЧ.Добавить("Агрегаты");
	мсвТЧ.Добавить("КузовныеЭлементы");
	мсвТЧ.Добавить("ЭлементыКомплектации");
	Для Каждого ТекИмяТЧ Из мсвТЧ Цикл
		Сч = Объект[ТекИмяТЧ].Количество()-1;
		Пока Сч >= 0 Цикл
			Если мсвТС.Найти(Объект[ТекИмяТЧ][Сч].ТС) = Неопределено Тогда
				Объект[ТекИмяТЧ].Удалить(Сч);
			КонецЕсли;
			Сч = Сч - 1;
		КонецЦикла;
	КонецЦикла;
	
	СформироватьСписокВыбораТСвТЧ();
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьСписокВыбораТСвТЧ()
	
	Элементы.ШиныТС.СписокВыбора.Очистить();
	Элементы.АгрегатыТС.СписокВыбора.Очистить();
	Элементы.КузовныеЭлементыТС.СписокВыбора.Очистить();
	Элементы.ЭлементыКомплектацииТС.СписокВыбора.Очистить();
	
	Если ЗначениеЗаполнено(Объект.ТС) Тогда
		Элементы.ШиныТС.СписокВыбора.Добавить(Объект.ТС);
		Элементы.АгрегатыТС.СписокВыбора.Добавить(Объект.ТС);
		Элементы.КузовныеЭлементыТС.СписокВыбора.Добавить(Объект.ТС);
		Элементы.ЭлементыКомплектацииТС.СписокВыбора.Добавить(Объект.ТС);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Прицеп1) Тогда
		Элементы.ШиныТС.СписокВыбора.Добавить(Объект.Прицеп1);
		Элементы.АгрегатыТС.СписокВыбора.Добавить(Объект.Прицеп1);
		Элементы.КузовныеЭлементыТС.СписокВыбора.Добавить(Объект.Прицеп1);
		Элементы.ЭлементыКомплектацииТС.СписокВыбора.Добавить(Объект.Прицеп1);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Прицеп2) Тогда
		Элементы.ШиныТС.СписокВыбора.Добавить(Объект.Прицеп2);
		Элементы.АгрегатыТС.СписокВыбора.Добавить(Объект.Прицеп2);
		Элементы.КузовныеЭлементыТС.СписокВыбора.Добавить(Объект.Прицеп2);
		Элементы.ЭлементыКомплектацииТС.СписокВыбора.Добавить(Объект.Прицеп2);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчисткаОдометра(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Одометр        = 0;
	Объект.ОстатокТоплива = 0;

КонецПроцедуры

#КонецОбласти
