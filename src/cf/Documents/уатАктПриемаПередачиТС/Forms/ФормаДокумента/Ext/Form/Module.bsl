&НаКлиенте
Процедура ЗаполнитьОдометрИОстатокТопливаПоМониторингу(Команда)
	
	ОбъектСтруктура = Новый Структура;
	ОбъектСтруктура.Вставить("Организация",          Объект.Организация);
	ОбъектСтруктура.Вставить("ТранспортноеСредство", Объект.ТС);
	ОбъектСтруктура.Вставить("ДатаВыезда",           Объект.ДатаОсмотра - 86400);
	ОбъектСтруктура.Вставить("ДатаВозвращения",      Объект.ДатаОсмотра);
	ОбъектСтруктура.Вставить("СпидометрВыезда",      Объект.Одометр);
	ОбъектСтруктура.Вставить("СпидометрВозвращения", Объект.Одометр);
	ОбъектСтруктура.Вставить("РасчетФактРасходаГСМ", Неопределено);
	ОбъектСтруктура.Вставить("Прицепы",              Новый Массив);
		
	РезультатСтруктура = Новый Структура;
	
	// РАСЧЕТ.
	уатМониторинг.РассчитатьСпидометрПоМониторингу(ОбъектСтруктура, РезультатСтруктура);
	
	// Заполнение основных реквизитов.
	Если РезультатСтруктура.Свойство("СводныеДанные") Тогда
		СводныеДанныеТС = РезультатСтруктура.СводныеДанные.Получить(Объект.ТС);
		Если СводныеДанныеТС <> Неопределено Тогда
			Если СводныеДанныеТС.Свойство("КонечныйУровеньТоплива") Тогда
				Объект.ОстатокТоплива = СводныеДанныеТС.КонечныйУровеньТоплива;
			КонецЕсли;
			Если СводныеДанныеТС.Свойство("КонечноеЗначениеОдометра") Тогда
				Объект.Одометр = СводныеДанныеТС.КонечноеЗначениеОдометра;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Модифицированность = Истина;
	
КонецПроцедуры
	
