
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	уатЗащищенныеФункцииСервер.уатДокументФормаЭлементаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, Объект, ЭтотОбъект, ДопПараметрыОткрытие);
	Если Отказ тогда
		Возврат;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	Если Объект.Ссылка.Пустая() Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ДатаОсмотра) Тогда
			Объект.ДатаОсмотра = НачалоМинуты(ТекущаяДатаСеанса());
		КонецЕсли;
		Если ЗначениеЗаполнено(Объект.ТС) Тогда
			ЗаполнитьПутевойЛист(1);
			ЗаполнитьПутевойЛист(2);
			Если Объект.Шины.Количество() = 0 Тогда
				ЗаполнитьШиныСервер();
			КонецЕсли;
			Если Объект.Агрегаты.Количество() = 0 Тогда
				ЗаполнитьАгрегатыСервер();
			КонецЕсли;
			Если Объект.КузовныеЭлементы.Количество() = 0 Тогда
				ЗаполнитьКузовныеЭлементыСервер();	
			КонецЕсли;
			Если Объект.ЭлементыКомплектации.Количество() = 0 Тогда
				ЗаполнитьЭлементыКомплектацииСервер();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ТСстарое = Объект.ТС;
	МодельТС = Объект.ТС.Модель;
	
	НайтиПредыдущийАктПриемаПередачи();
	
	ОбновитьПредыдущееСостояниеШин();
	ОбновитьРасчетныйИзносШин();
	ОбновитьПредыдущееСостояниеАгрегатов();
	ОбновитьПредыдущееСостояниеКузовныхЭлементов();
	//ОбновитьПредыдущееСостояниеЭлементовКомплектации();
	// Невозможно получить предыдущее состояние конкретного ЭК, поскольку ведется количественный учёт
	// и часть ЭК может быть в одном состоянии, другая часть - в другом. Поэтому предыдущее состояние заполняются
	// только при заполнении установленными через кнопку меню ТЧ ЭК
	ОбновитьФлагБезИзмененийВТЧ();
	УстановитьОтборНоменклатурыПриОткрытии();
	УстановитьВидимостьКомандМониторинга();
	ИнициализацияДанныхАвтомобиляСервер();
	
	Элементы.ГруппаЭлементыКомплектации.Видимость = уатОбщегоНазначения_проф.ИспользоватьЭлементыКомплектации();
	ЗаголовокСдалПринял = "Информация об операции: " + НРег(Объект.ВидОперации);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	уатЗащищенныеФункцииКлиент.уатДокументФормаЭлементаПриОткрытии(Отказ, ЭтотОбъект, ДопПараметрыОткрытие);
	Если Отказ тогда
		Возврат;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
    УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	РежимОтображения = "Все";
	
	ОбновитьДопНумерациюСтрок();
	ОбновитьКоличествоСтрокВЗаголовкахСтраниц();
	УстановитьОграничениеТипаСдалПринял();
	ОбновитьЗаголовокПредыдущееСостояниеВТЧ();
	СформироватьСписокВыбораТСвТЧ();
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Заглушка = Истина;
	//Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	// Контроль вызываем здесь, а не в ОбработкаПроверкиЗаполненияНаСервере,
	// поскольку тот не срабатывает при записи.
	Если флПроверкаПередЗакрытием <> Неопределено Тогда
		Отказ = Отказ ИЛИ флПроверкаПередЗакрытием.Отказ;
		Для Каждого ТекСообщение Из флПроверкаПередЗакрытием.Сообщения Цикл
			уатОбщегоНазначенияТиповые.СообщитьОбОшибке(ТекСообщение);
		КонецЦикла;
		флПроверкаПередЗакрытием = Неопределено;
	ИначеЕсли ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись
		ИЛИ ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		КонтрольУменьшениеСтепениИзноса(Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если флВопросЗакрытиеФормы Тогда
		Отказ = Истина;
		Оповещ = Новый ОписаниеОповещения("ПередЗакрытиемВопрос", ЭтотОбъект);
		флВопросЗакрытиеФормы = Ложь;
		ПоказатьВопрос(Оповещ, "При проверке корректности заполнения документа возникли предупреждения!
			|Продолжить закрытие формы?", РежимДиалогаВопрос.ОКОтмена);
	ИначеЕсли Модифицированность И НЕ Объект.Ссылка.Пустая() Тогда
		флОтказ = Ложь;
		мсвСообщения = Новый Массив;
		КонтрольУменьшениеСтепениИзноса(флОтказ, Истина, мсвСообщения);
		флПроверкаПередЗакрытием = Новый Структура("Отказ, Сообщения", флОтказ, мсвСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемВопрос(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		флВопросЗакрытиеФормы = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура КонтрольУменьшениеСтепениИзноса(Отказ, ВызовПередЗакрытиемФормы = Ложь, мсвСообщения = Неопределено)
	
	Если мсвСообщения = Неопределено Тогда
		мсвСообщения = Новый Массив;
	КонецЕсли;
	флОтказ = Ложь;
	
	мЗапросРезультатыОсмотра = Новый Запрос(
	"ВЫБРАТЬ
	|	АктПриемаПередачиШины.СерияНоменклатуры КАК СерияНоменклатуры,
	|	АктПриемаПередачиШины.СтепеньИзноса КАК СтепеньИзноса
	|ПОМЕСТИТЬ втАктПриемаПередачиШины
	|ИЗ
	|	&АктПриемаПередачиШины КАК АктПриемаПередачиШины
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втАктПриемаПередачиШины.СерияНоменклатуры.СерийныйНомер КАК Шина,
	|	втАктПриемаПередачиШины.СтепеньИзноса КАК СтепеньИзноса,
	|	ЕСТЬNULL(уатАгрегатыТСПред.СтепеньИзноса, 0) КАК СтепеньИзносаПредыдущая
	|ИЗ
	|	втАктПриемаПередачиШины КАК втАктПриемаПередачиШины
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатАгрегатыТС.СрезПоследних(&ПериодПред, ) КАК уатАгрегатыТСПред
	|		ПО втАктПриемаПередачиШины.СерияНоменклатуры = уатАгрегатыТСПред.СерияНоменклатуры");
	мЗапросРезультатыОсмотра.УстановитьПараметр("АктПриемаПередачиШины", Объект.Шины.Выгрузить());
	мЗапросРезультатыОсмотра.УстановитьПараметр("ПериодПред", ?(Объект.ДатаОсмотра = '00010101', Объект.Дата-1, Объект.ДатаОсмотра-1));
	мсвРезультат = мЗапросРезультатыОсмотра.ВыполнитьПакет();
	Выборка = мсвРезультат[1].Выбрать();
	
	ШиныОшибка = "";
	Пока Выборка.Следующий() Цикл
		Если Выборка.СтепеньИзноса < Выборка.СтепеньИзносаПредыдущая Тогда
			ШиныОшибка = ШиныОшибка + ", """ + Выборка.Шина + """";
		КонецЕсли;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ШиныОшибка) Тогда
		ШиныОшибка = Сред(ШиныОшибка, 3);
		ТекстСообщения = СтрШаблон("Для следующих шин понижена степень износа: %1.", ШиныОшибка);
		флВопросЗакрытиеФормы = Истина;
		уатОбщегоНазначенияТиповые.СообщитьОбОшибке(ТекстСообщения);
	КонецЕсли;
	
	Отказ = Отказ ИЛИ флОтказ;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьПредыдущееСостояниеШин();
	ОбновитьРасчетныйИзносШин();
	ОбновитьПредыдущееСостояниеАгрегатов();
	ОбновитьПредыдущееСостояниеКузовныхЭлементов();
	ОбновитьФлагБезИзмененийВТЧ();
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ОбновитьДопНумерациюСтрок();
	ОбновитьКоличествоСтрокВЗаголовкахСтраниц();
	ОбновитьЗаголовокПредыдущееСостояниеВТЧ();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
	Если ИмяСобытия = "МастерУстановкиШин" Тогда
		мсвСтрокиУдалить = Объект.Шины.НайтиСтроки(Новый Структура("ТС", Параметр.ТС));
		Для Каждого ТекСтрокаУдалить Из мсвСтрокиУдалить Цикл
			Объект.Шины.Удалить(ТекСтрокаУдалить);
		КонецЦикла;
		
		Для Каждого ТекШина Из Параметр.СписокШин Цикл
			НоваяСтрока = Объект.Шины.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекШина);
			НоваяСтрока.ТС = Параметр.ТС;
			//НоваяСтрока.СтепеньИзноса = уатОбщегоНазначения.уатСостояниеАгрегатаТС(
			//	ТекШина.СерияНоменклатуры, Объект.ДатаНачала).СтепеньИзноса;
		КонецЦикла;
		Модифицированность = Истина;
		
		ОбновитьПредыдущееСостояниеШин();
		ОбновитьРасчетныйИзносШин();
		ОбновитьДопНумерациюСтрок("Шины");
		УстановитьВидимость();
	КонецЕсли;
	
КонецПроцедуры

