		Для Каждого ТекСтрокаУдалить Из мсвСтрокиУдалить Цикл
			Объект.Шины.Удалить(ТекСтрокаУдалить);
		КонецЦикла;
		мсвТС = Новый Массив;
		мсвТС.Добавить(ТС);
	КонецЕсли;
	
	Для Каждого ТекТС Из мсвТС Цикл
		ОМ_уатОбщегоНазначения_уэ = ОбщегоНазначения.ОбщийМодуль("уатОбщегоНазначения_уэ");
		тблЭлементыКомплектации = ОМ_уатОбщегоНазначения_уэ.уатЭлементыКомплектацииТС(ТекТС, МоментСреза);
		Для Каждого ТекСтрока Из тблЭлементыКомплектации Цикл
			НоваяСтрока = Объект.ЭлементыКомплектации.Добавить();
			НоваяСтрока.ТС                  = ТекТС;
			НоваяСтрока.ЭлементКомплектации = ТекСтрока.ЭлементКомплектации;
			НоваяСтрока.СостояниеПредыдущее           = ТекСтрока.Состояние;
			НоваяСтрока.НаличиеПоврежденийПредыдущее  = ТекСтрока.НаличиеПовреждений;
			НоваяСтрока.ХарактерПоврежденийПредыдущий = ТекСтрока.ХарактерПовреждений;
			НоваяСтрока.КоличествоПредыдущее          = ТекСтрока.Количество;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

