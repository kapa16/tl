&НаСервере
Процедура ЗаполнитьОтветственныеЛицаСервер()
	
	Объект.ОтветственныеЛица.Очистить();
	тблОтветственныеЛица = ПолучитьОтветственныеЛица(Объект.ДатаОсмотра, Объект.Организация);
	Объект.ОтветственныеЛица.Загрузить(тблОтветственныеЛица);
	
