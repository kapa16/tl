		ДолжностьПоиск = ПолучитьФизЛицоДолжностьОтветственногоЛица(ТекСтрока.ФизическоеЛицо);
		Если ЗначениеЗаполнено(ДолжностьПоиск) Тогда
			ТекСтрока.Должность = ДолжностьПоиск;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтветственныеЛицаДолжностьПриИзменении(Элемент)
	
	ТекСтрока = Элементы.ОтветственныеЛица.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекСтрока.Должность) Тогда
		ФизическоеЛицоПоиск = ПолучитьФизЛицоДолжностьОтветственногоЛица(ТекСтрока.Должность);
		Если ЗначениеЗаполнено(ФизическоеЛицоПоиск) Тогда
			ТекСтрока.ФизическоеЛицо = ФизическоеЛицоПоиск;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьФизЛицоДолжностьОтветственногоЛица(ФизЛицоИлиДолжность)
	
	тблОтветственныеЛица = ПолучитьОтветственныеЛица(Объект.ДатаОсмотра, Объект.Организация);
	
	Если ТипЗнч(ФизЛицоИлиДолжность) = Тип("СправочникСсылка.Должности") Тогда
		СтрПоиска = тблОтветственныеЛица.Найти(ФизЛицоИлиДолжность, "Должность");
		Если СтрПоиска <> Неопределено Тогда
			Возврат СтрПоиска.ФизическоеЛицо;
		КонецЕсли;
	Иначе
		СтрПоиска = тблОтветственныеЛица.Найти(ФизЛицоИлиДолжность, "ФизическоеЛицо");
		Если СтрПоиска <> Неопределено Тогда
			Возврат СтрПоиска.Должность;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьОтветственныеЛица(Период, Организация)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ОтветственныеЛицаОрганизацийСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ОтветственныеЛицаОрганизацийСрезПоследних.Должность КАК Должность
	|ИЗ
	|	РегистрСведений.ОтветственныеЛицаОрганизаций.СрезПоследних(&Период, СтруктурнаяЕдиница = &Организация) КАК ОтветственныеЛицаОрганизацийСрезПоследних");
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Организация", Организация);
	тблРез = Запрос.Выполнить().Выгрузить();
	
	Возврат тблРез;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьОтветственныеЛица(Команда)
	
	ЗаполнитьОтветственныеЛицаСервер();
	
