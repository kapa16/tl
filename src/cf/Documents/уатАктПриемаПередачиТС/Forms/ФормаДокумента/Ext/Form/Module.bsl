Процедура ЭлементыКомплектацииСостояниеПриИзмененииВопрос(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		ТекСтрока = Элементы.ЭлементыКомплектации.ТекущиеДанные;
		НовоеСостояние = ТекСтрока.Состояние;
		
		ТекСтрока.Состояние = ТекСтрока.СостояниеПредыдущее;
		ТекСтрока.Количество = ТекСтрока.Количество - 1;
		
		НовСтрока = Объект.ЭлементыКомплектации.Вставить(ТекСтрока.НомерСтроки);
		ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока, "ТС, ЭлементКомплектации, НаличиеПовреждений, ХарактерПовреждений");
		НовСтрока.Состояние = НовоеСостояние;
		НовСтрока.Количество = 1;
		Элементы.ЭлементыКомплектации.ТекущаяСтрока = НовСтрока.ПолучитьИдентификатор();
		Элементы.ЭлементыКомплектации.ИзменитьСтроку();
		
		ОбновитьФлагБезИзмененийВТЧ("ЭлементыКомплектации");
	КонецЕсли;
		
