&НаСервере
Процедура ЗаполнитьШиныСервер(ТС = Неопределено)
	
	МоментСреза = Объект.ДатаОсмотра - 1;
	
	Если ТС = Неопределено Тогда
		Объект.Шины.Очистить();
		мсвТС = ТСиПрицепыДокумента()
	Иначе
		мсвСтрокиУдалить = Объект.Шины.НайтиСтроки(Новый Структура("ТС", ТС));
		Для Каждого ТекСтрокаУдалить Из мсвСтрокиУдалить Цикл
			Объект.Шины.Удалить(ТекСтрокаУдалить);
		КонецЦикла;
		мсвТС = Новый Массив;
		мсвТС.Добавить(ТС);
	КонецЕсли;
	
	Для Каждого ТекТС Из мсвТС Цикл
		тблШины = уатОбщегоНазначения.уатШиныТС(ТекТС, МоментСреза);
		Для Каждого ТекСтрока Из тблШины Цикл
			НоваяСтрока = Объект.Шины.Добавить();
			НоваяСтрока.ТС                = ТекТС;
			НоваяСтрока.СерияНоменклатуры = ТекСтрока.СерияНоменклатуры;
		КонецЦикла;
	КонецЦикла;
	
	ОбновитьПредыдущееСостояниеШин();
	ОбновитьРасчетныйИзносШин();
	
КонецПроцедуры

