#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	уатОбщегоНазначенияСервер.Заполнить(ЭтотОбъект, ДанныеЗаполнения);
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		//ДокументОснование = ДанныеЗаполнения;
		
		Организация       = ДанныеЗаполнения.Организация;
		Подразделение     = ДанныеЗаполнения.Подразделение;
		ПУ                = ДанныеЗаполнения.ПУ;
		ДатаОсмотра       = ДанныеЗаполнения.ДатаОсмотра;
		ТС                = ДанныеЗаполнения.ТС;
		Одометр           = ДанныеЗаполнения.Одометр;
		ОдометрТО         = ДанныеЗаполнения.ОдометрТО;
		ОстатокТоплива    = ДанныеЗаполнения.ОстатокТоплива;
		Платон            = ДанныеЗаполнения.Платон;
		Пробег            = ДанныеЗаполнения.Пробег;
		
		ОдометрПрицеп        = ДанныеЗаполнения.ОдометрПрицеп;
		ОдометрПрицепТО      = ДанныеЗаполнения.ОдометрПрицепТО;
		ПробегПрицеп         = ДанныеЗаполнения.ПробегПрицеп;
		ОстатокТопливаПрицеп = ДанныеЗаполнения.ОстатокТопливаПрицеп;
		СтрокаПрицеп         = ДанныеЗаполнения.СтрокаПрицеп;
		СтрокаПринял         = ДанныеЗаполнения.СтрокаПринял;
		Ответственный        = ДанныеЗаполнения.Ответственный;
		
		Замечания         = ДанныеЗаполнения.Замечания;
		ПримечаниеКСостояниюПрицепа = ДанныеЗаполнения.ПримечаниеКСостояниюПрицепа;
		
		Если ТипЗнч(ДанныеЗаполнения.ЭлементыПроверки) = Тип("Структура") Тогда
			
			Для Каждого СтрТягач Из ДанныеЗаполнения.ЭлементыПроверки.ДанныеТягача Цикл
				НоваяСтрока = ЭлементыПроверки.Добавить();
				
				НоваяСтрока.ТС					= ДанныеЗаполнения.ТС;
				НоваяСтрока.ЭлементПроверки		= Справочники.GDS_ПунктыПроверкиТС.НайтиПоНаименованию(СтрТягач.Пункт);
				
				НоваяСтрока.Состояние 			= Перечисления.GDS_СостоянияПроверкиАПП.ЗначениеИзСтроки(СтрТягач.Ответ.Радиокнопка);
				
				Если НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
					и НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно Тогда
					
					НоваяСтрока.НаличиеПроблем = Истина;
				КонецЕсли;
				
				НоваяСтрока.Замечания 			= СтрТягач.Ответ.Комментарий;
			КонецЦикла;
			
			Для Каждого СтрТС Из ДанныеЗаполнения.ЭлементыПроверки.ДанныеТС Цикл
				НоваяСтрока = ЭлементыПроверки.Добавить();
				
				НоваяСтрока.ТС					= ДанныеЗаполнения.ТС;
				НоваяСтрока.ЭлементПроверки		= Справочники.GDS_ПунктыПроверкиТС.НайтиПоНаименованию(СтрТС.Пункт);
				
				НоваяСтрока.Состояние 			= Перечисления.GDS_СостоянияПроверкиАПП.ЗначениеИзСтроки(СтрТС.Ответ.Радиокнопка);
				
				Если НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
					и НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно Тогда
					
					НоваяСтрока.НаличиеПроблем = Истина;
				КонецЕсли;
				
				НоваяСтрока.Замечания 			= СтрТС.Ответ.Комментарий;
			КонецЦикла;
			
			Для Каждого СтрПрицеп Из ДанныеЗаполнения.ЭлементыПроверки.ДанныеПрицепа Цикл
				НоваяСтрока = ЭлементыПроверки.Добавить();
				
				НоваяСтрока.ТС					= Справочники.уатТС.ПустаяСсылка();//ДанныеЗаполнения.ТС;
				НоваяСтрока.ЭлементПроверки		= Справочники.GDS_ПунктыПроверкиТС.НайтиПоНаименованию(СтрПрицеп.Пункт);
				
				НоваяСтрока.Состояние 			= Перечисления.GDS_СостоянияПроверкиАПП.ЗначениеИзСтроки(СтрПрицеп.Ответ.Радиокнопка);
				
				Если НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
					и НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно Тогда
					
					НоваяСтрока.НаличиеПроблем = Истина;
				КонецЕсли;
				
				НоваяСтрока.Замечания 			= СтрПрицеп.Ответ.Комментарий;
			КонецЦикла;
			
			Для Каждого СтрПрицеп Из ДанныеЗаполнения.ЭлементыПроверки.ДанныеОстатки Цикл
				НоваяСтрока = ЭлементыПроверки.Добавить();
				
				НоваяСтрока.ТС					= Справочники.уатТС.ПустаяСсылка();//ДанныеЗаполнения.ТС;
				НоваяСтрока.ЭлементПроверки		= Справочники.GDS_ПунктыПроверкиТС.НайтиПоНаименованию(СтрПрицеп.Пункт);
				
				НоваяСтрока.Состояние 			= Перечисления.GDS_СостоянияПроверкиАПП.ЗначениеИзСтроки(СтрПрицеп.Ответ.Радиокнопка);
				
				Если НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
					и НоваяСтрока.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно Тогда
					
					НоваяСтрока.НаличиеПроблем = Истина;
				КонецЕсли;
				
				НоваяСтрока.Замечания 			= СтрПрицеп.Ответ.Комментарий;
			КонецЦикла;
			
		КонецЕсли;
		
		//ВРЕМЕННО _ НУЖНО ПЕРЕДЕЛАТЬ
		ТЧ_Проверка = ЭлементыПроверки.Выгрузить(,"ЭлементПроверки,Состояние,Замечания");
		
		Для Каждого СтрОтв Из ТЧ_Проверка Цикл
			Если (СтрОтв.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
				И СтрОтв.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно)
				Или (СтрОтв.Состояние = Перечисления.GDS_СостоянияПроверкиАПП.Исправно
				и СтрОтв.Замечания <> "") Тогда
				
				ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрОтв.ЭлементПроверки,"ФизическоеЛицо");
				Если ЗначениеЗаполнено(ФизическоеЛицо) Тогда
					НоваяСтрока = ОтветственныеЛица.Добавить();
					НоваяСтрока.ФизическоеЛицо = ФизическоеЛицо;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		ОтветственныеЛица.Свернуть("ФизическоеЛицо");
		
		//запись наличия проблем в акте приема передачи ТС	
		Для Каждого СтрОтв Из ТЧ_Проверка Цикл
			Если (СтрОтв.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Вналичии
				И СтрОтв.Состояние <> Перечисления.GDS_СостоянияПроверкиАПП.Исправно) Тогда
				
				ИсправностьТС = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	// Вставить содержимое обработчика.
	
	//ДополнительныеСвойства
	ДополнительныеСвойства.Вставить("ТаблицыДляДвижений", Новый Структура);
	
	Документы.GDS_АктПриемаПередачиТС.СформироватьТаблицуЭлементыПроверки(Ссылка, ДополнительныеСвойства);
	
	ДвиженияРегистр = Движения.GDS_ЭлементыПроверки;
	ДвиженияРегистр.Записывать = Истина;
	ДвиженияРегистр.Загрузить(ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЭлементыПроверкиТС);
	
	//GDS_СостояниеТСПоАПП
	Движения.GDS_СостояниеТСПоАПП.Записывать = Истина;
	Движение = Движения.GDS_СостояниеТСПоАПП.Добавить();
	Движение.Период = ДатаОсмотра;
	Движение.ТС = ТС;
	
	Если ИсправностьТС Тогда
		РезультатСостояние = Перечисления.GDS_СостояниеТСПоАПП.Неисправна;
	Иначе
		РезультатСостояние = Перечисления.GDS_СостояниеТСПоАПП.Исправна;
	КонецЕсли;
	
	Движение.Состояние = РезультатСостояние;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если НЕ ПометкаУдаления Тогда
		Если ФорматированноеОписание.Получить() = Неопределено Тогда
			ФорматированныйДокумент = GDS_РаботаСФормитированнымОписаниемСервер.ПолучитьФормитированнуюСтроку(Ссылка);
			
			текТекст = "";
			СтруктураВложений = Новый Структура;
			
			ФорматированныйДокумент.ПолучитьHTML(текТекст, СтруктураВложений);
			
			ФорматированноеОписание = Новый ХранилищеЗначения(текТекст, Новый СжатиеДанных(9));
			
			Записать();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

