Функция РезультатЗапросаДанныеДокумента(ДокументСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	GDS_АктПриемаПередачиТС.Дата КАК Дата,
	|	GDS_АктПриемаПередачиТС.Номер КАК Номер,
	|	GDS_АктПриемаПередачиТС.ДатаОсмотра КАК ДатаОсмотра,
	|	GDS_АктПриемаПередачиТС.Организация КАК Организация,
	|	GDS_АктПриемаПередачиТС.Одометр КАК Одометр,
	|	GDS_АктПриемаПередачиТС.ОстатокТоплива КАК ОстатокТоплива,
	|	GDS_АктПриемаПередачиТС.Замечания КАК Замечания,
	|	GDS_АктПриемаПередачиТС.ТС КАК ТС,
	|	GDS_АктПриемаПередачиТС.ТС.Модель КАК МодельТС,
	|	GDS_АктПриемаПередачиТС.ТС.ГосударственныйНомер КАК ГосНомер,
	|	GDS_АктПриемаПередачиТС.Сдал КАК Сдал,
	|	GDS_АктПриемаПередачиТС.Принял КАК Принял,
	|	GDS_АктПриемаПередачиТС.ОсмотрПровел КАК ОсмотрПровел,
	|	GDS_АктПриемаПередачиТС.ПУ КАК ПУ,
	|	GDS_АктПриемаПередачиТС.Платон КАК Платон,
	|	GDS_АктПриемаПередачиТС.Подразделение КАК Подразделение,
	|	GDS_АктПриемаПередачиТС.Пробег КАК Пробег,
	|	GDS_АктПриемаПередачиТС.ОдометрТО КАК ОдометрТО,
	|	GDS_АктПриемаПередачиТС.ОдометрПрицеп КАК ОдометрПрицеп,
	|	GDS_АктПриемаПередачиТС.ОдометрПрицепТО КАК ОдометрПрицепТО,
	|	GDS_АктПриемаПередачиТС.ПробегПрицеп КАК ПробегПрицеп,
	|	GDS_АктПриемаПередачиТС.ОстатокТопливаПрицеп КАК ОстатокТопливаПрицеп,
	|	GDS_АктПриемаПередачиТС.ПримечаниеКСостояниюПрицепа КАК ПримечаниеКСостояниюПрицепа,
	|	GDS_АктПриемаПередачиТС.Прицеп.ГосударственныйНомер КАК ГосНомерПрицеп,
	|	GDS_АктПриемаПередачиТС.ЭлементыПроверки.(
	|		НомерСтроки КАК НомерСтроки,
	|		ТС КАК ТС,
	|		ЭлементПроверки КАК ЭлементПроверки,
	|		Состояние КАК Состояние,
	|		Замечания КАК Замечания
	|	) КАК ЭлементыПроверки,
	|	GDS_АктПриемаПередачиТС.СтрокаПринял КАК СтрокаПринял
	|ИЗ
	|	Документ.GDS_АктПриемаПередачиТС КАК GDS_АктПриемаПередачиТС
	|ГДЕ
	|	GDS_АктПриемаПередачиТС.Ссылка В(&Ссылка)";
	Запрос.Параметры.Вставить("Ссылка", ДокументСсылка);
	
	Возврат Запрос.Выполнить();
