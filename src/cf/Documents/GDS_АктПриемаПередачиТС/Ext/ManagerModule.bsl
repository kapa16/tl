// Формирует таблицу значений, содержащую данные для проведения по регистру КузовныеЭлементы.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицуЭлементыПроверки(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	мЗапрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.Ссылка.ДатаОсмотра КАК Период,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.Ссылка КАК Регистратор,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.ТС КАК ТС,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.ЭлементПроверки КАК ЭлементПроверки,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.НаличиеПроблем КАК НаличиеПроблем,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.Замечания КАК Замечания,
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.Состояние КАК Состояние
	|ИЗ
	|	Документ.GDS_АктПриемаПередачиТС.ЭлементыПроверки КАК GDS_АктПриемаПередачиТСЭлементыПроверки
	|ГДЕ
	|	GDS_АктПриемаПередачиТСЭлементыПроверки.Ссылка = &Ссылка";
	тблЭлементыПроверкиТС = мЗапрос.Выполнить().Выгрузить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЭлементыПроверкиТС", тблЭлементыПроверкиТС);
	
КонецПроцедуры

Функция ТСиПрицепыДокумента(ДокументСсылка) Экспорт
	мсвТС = Новый Массив;
	Если ЗначениеЗаполнено(ДокументСсылка.ТС) Тогда
		мсвТС.Добавить(ДокументСсылка.ТС);
	КонецЕсли;
	
	//Пока один прицеп ,но нужно переделать на два прицепа Прицеп1 и Прицеп2
	Если ЗначениеЗаполнено(ДокументСсылка.Прицеп) Тогда
		мсвТС.Добавить(ДокументСсылка.Прицеп);
	КонецЕсли;
	//Если ЗначениеЗаполнено(ДокументСсылка.Прицеп2) Тогда
	//	мсвТС.Добавить(ДокументСсылка.Прицеп2);
	//КонецЕсли;
	
	Возврат мсвТС;
КонецФункции

