Функция ПечатьАктПриемаПередачиТС(МассивОбъектов, ОбъектыПечати) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_GDS_АктПриемаПередачиТС";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_GDS_АктПриемаПередачиТС";
		Макет = Документы.GDS_АктПриемаПередачиТС.ПолучитьМакет("GDS_КарточкаЧекЛиста");
		
		РезультатЗапроса = РезультатЗапросаДанныеДокумента(ТекущийДокумент);
		Выборка = РезультатЗапроса.Выбрать();
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьШапкаТС = Макет.ПолучитьОбласть("ШапкаТС");
		ОбластьШапкаПрицеп = Макет.ПолучитьОбласть("ШапкаПрицеп");
		ОбластьШапкаНеисправность = Макет.ПолучитьОбласть("ШапкаНеисправность");
		ОбластьСтрокаНеисправность = Макет.ПолучитьОбласть("СтрокаНеисправность");
		ОбластьПодвалТС = Макет.ПолучитьОбласть("ПодвалТС");
		ОбластьПодвалПрицеп = Макет.ПолучитьОбласть("ПодвалПрицеп");
		
		ТабличныйДокумент.Очистить();
		
		ВставлятьРазделительСтраниц = Ложь;
		Пока Выборка.Следующий() Цикл
			Если ВставлятьРазделительСтраниц Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			
			ОбластьЗаголовок.Параметры.Заполнить(Выборка);
			
			ОбластьЗаголовок.Параметры.Принял = Выборка.СтрокаПринял;
			
			ТабличныйДокумент.Вывести(ОбластьЗаголовок);
			
			ОбластьШапкаТС.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Вывести(ОбластьШапкаТС);
			
			ВыборкаЭлементыПроверки = Выборка.ЭлементыПроверки.Выбрать();
			Если ВыборкаЭлементыПроверки.Количество() Тогда
				ТабличныйДокумент.Вывести(ОбластьШапкаНеисправность);
				Пока ВыборкаЭлементыПроверки.Следующий() Цикл
					Если ВыборкаЭлементыПроверки.ТС <> Справочники.уатТС.ПустаяСсылка() Тогда
						ОбластьСтрокаНеисправность.Параметры.Пункт       = ВыборкаЭлементыПроверки.ЭлементПроверки;
						ОбластьСтрокаНеисправность.Параметры.Состояние   = ВыборкаЭлементыПроверки.Состояние;
						ОбластьСтрокаНеисправность.Параметры.Комментарий = ВыборкаЭлементыПроверки.Замечания;
						
						ЕстьВложение = ОпределитьФайлыПунктаПроверки(ТекущийДокумент, ВыборкаЭлементыПроверки.ЭлементПроверки);
						ОбластьСтрокаНеисправность.Параметры.Вложение = ЕстьВложение;
						
						ТабличныйДокумент.Вывести(ОбластьСтрокаНеисправность);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ШаблонКомментарийТС = СтрШаблон("Комментарий: %1", Выборка.Замечания);
			
			ОбластьПодвалТС.Параметры.Комментарий = ШаблонКомментарийТС;
			ТабличныйДокумент.Вывести(ОбластьПодвалТС);
			
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
			ОбластьШапкаПрицеп.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Вывести(ОбластьШапкаПрицеп);
			
			ВыборкаЭлементыПроверки = Выборка.ЭлементыПроверки.Выбрать();
			Если ВыборкаЭлементыПроверки.Количество() Тогда
				ТабличныйДокумент.Вывести(ОбластьШапкаНеисправность);
				Пока ВыборкаЭлементыПроверки.Следующий() Цикл
					Если ВыборкаЭлементыПроверки.ТС = Справочники.уатТС.ПустаяСсылка() Тогда
						ОбластьСтрокаНеисправность.Параметры.Пункт       = ВыборкаЭлементыПроверки.ЭлементПроверки;
						ОбластьСтрокаНеисправность.Параметры.Состояние   = ВыборкаЭлементыПроверки.Состояние;
						ОбластьСтрокаНеисправность.Параметры.Комментарий = ВыборкаЭлементыПроверки.Замечания;
						
						ЕстьВложение = ОпределитьФайлыПунктаПроверки(ТекущийДокумент, ВыборкаЭлементыПроверки.ЭлементПроверки);
						ОбластьСтрокаНеисправность.Параметры.Вложение = ЕстьВложение;
						
						ТабличныйДокумент.Вывести(ОбластьСтрокаНеисправность);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ШаблонКомментарийПрицеп = СтрШаблон("Комментарий: %1", Выборка.ПримечаниеКСостояниюПрицепа);
			
			ОбластьПодвалПрицеп.Параметры.Комментарий = ШаблонКомментарийПрицеп;
			ТабличныйДокумент.Вывести(ОбластьПодвалПрицеп);
			
			
		//	ОбластьЗаголовок.Параметры.ТекстЗаголовка = ХозОперацияДляПечати(Выборка.ВидОперации) + " "
		//		+ уатОбщегоНазначенияТиповые.уатСформироватьЗаголовокДокумента(Выборка);
