&НаСервере
Процедура СоздатьСтрокуДоходовВводаОстатков(Реквизиты, СчПеренесено, СчВсего, ЗагружаемыеСсылки)
	
	СоздатьСтроку = Истина;
	ТекстСообщения = "";
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("ДатаОтражения", Реквизиты.ДатаОтражения);
	
	СтрокаПоиска = "уатСтатьиДоходов/" + Реквизиты.СтатьяДоходов;
	СтатьяДоходов = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если СтатьяДоходов = Неопределено И ЗначениеЗаполнено(Реквизиты.СтатьяДоходов) Тогда
		
		СтатьяДоходов = НайтиСоздатьСтатьяДоходов(Реквизиты.СтатьяДоходов);
		
		Если СтатьяДоходов = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании статьи доходов: %2'; en = 'Line %1. Error creating income item: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.СтатьяДоходов);
		Иначе
			СтруктураСтроки.Вставить("СтатьяДоходов", СтатьяДоходов);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, СтатьяДоходов);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("СтатьяДоходов", СтатьяДоходов);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатТС/" + Реквизиты.ТС;
	ТС = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ТС = Неопределено И ЗначениеЗаполнено(Реквизиты.ТС) Тогда
		
		ТС = НайтиЭлементСправочника("уатТС", Реквизиты.ТС);
		
		Если ТС = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найдено ТС: %2'; en = 'No vehicle found for line #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ТС);
			СтруктураСтроки.Вставить("ТС", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("ТС", ТС);
			СтруктураСтроки.Вставить("Колонна", ТС.Колонна);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ТС);
		КонецЕсли;
		
	Иначе
		
		Колонна = ?(ТС = Неопределено, Неопределено, ТС.Колонна);
		СтруктураСтроки.Вставить("ТС", ТС);
		СтруктураСтроки.Вставить("Колонна", Колонна);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Реквизиты.ЗаказНомер) Тогда
		
		Заказ = НайтиДокумент(ИскатьЗаказНаТСПоДате, Реквизиты.ЗаказДата, Реквизиты.ЗаказНомер, "уатЗаказГрузоотправителя");
		
		Если Заказ.Пустой() Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найден заказ на ТС: %2'; en = 'No order found for vehicle No. %1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ЗаказНомер + ?(ИскатьЗаказНаТСПоДате, " от " + Реквизиты.ЗаказДата, ""));
			СтруктураСтроки.Вставить("Заказ", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Заказ", Заказ.Выгрузить()[0].Ссылка);
		КонецЕсли;
	Иначе
		СтруктураСтроки.Вставить("Заказ", Неопределено);
	КонецЕсли;
	
	СтрокаПоиска = "Контрагенты/" + Реквизиты.Контрагент;
	Контрагент = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Контрагент = Неопределено И ЗначениеЗаполнено(Реквизиты.Контрагент) Тогда
		
		Контрагент = НайтиЭлементСправочника("Контрагенты", Реквизиты.Контрагент);
		
		Если Контрагент = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найден Контрагент: %2'; en = 'Counterparty not found for line #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Контрагент);
			СтруктураСтроки.Вставить("Контрагент", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Контрагент", Контрагент);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Контрагент);
		КонецЕсли;
		
	Иначе
		
		СтруктураСтроки.Вставить("Контрагент", Контрагент);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатОбъектыСтроительства/" + Реквизиты.ОбъектСтроительства;
	ОбъектСтроительства = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ОбъектСтроительства = Неопределено И ЗначениеЗаполнено(Реквизиты.ОбъектСтроительства) Тогда
		
		ОбъектСтроительства = НайтиСоздатьОбъектСтроительства(Реквизиты.ОбъектСтроительства);
		
		Если ОбъектСтроительства = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Объекта строительства: %2'; en = 'Line %1. Error creating Construction Object: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ОбъектСтроительства);
		Иначе
			СтруктураСтроки.Вставить("ОбъектСтроительства", ОбъектСтроительства);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ОбъектСтроительства);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("ОбъектСтроительства", ОбъектСтроительства);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатМаршруты/" + Реквизиты.Маршрут;
	Маршрут = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Маршрут = Неопределено И ЗначениеЗаполнено(Реквизиты.Маршрут) Тогда
		
		Маршрут = НайтиСоздатьМаршруты(Реквизиты.Маршрут);
		
		Если Маршрут = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Маршрута: %2'; en = 'Line %1. Error creating Route: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Маршрут);
		Иначе
			СтруктураСтроки.Вставить("Маршрут", Маршрут);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Маршрут);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("Маршрут", Маршрут);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатВидыПеревозок/" + Реквизиты.ВидПеревозки;
	ВидПеревозки = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ВидПеревозки = Неопределено И ЗначениеЗаполнено(Реквизиты.ВидПеревозки) Тогда
		
		ВидПеревозки = НайтиСоздатьВидПеревозки(Реквизиты.ВидПеревозки);
		
		Если ВидПеревозки = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Вида перевозки: %2'; en = 'Line %1. Error creating the Transportation Type: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ВидПеревозки);
		Иначе
			СтруктураСтроки.Вставить("ВидПеревозки", ВидПеревозки);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ВидПеревозки);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("ВидПеревозки", ВидПеревозки);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатНаправленияПеревозок/" + Реквизиты.НаправлениеПеревозки;
	НаправлениеПеревозки = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если НаправлениеПеревозки = Неопределено И ЗначениеЗаполнено(Реквизиты.НаправлениеПеревозки) Тогда
		
		НаправлениеПеревозки = НайтиСоздатьНаправлениеПеревозки(Реквизиты.НаправлениеПеревозки);
		
		Если НаправлениеПеревозки = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Направления перевозки: %2'; en = 'Line %1. Error creating the Transportation Direction: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.НаправлениеПеревозки);
		Иначе
			СтруктураСтроки.Вставить("НаправлениеПеревозки", НаправлениеПеревозки);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, НаправлениеПеревозки);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("НаправлениеПеревозки", НаправлениеПеревозки);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатПараметрыВыработки/" + Реквизиты.ПараметрВыработки;
	ПараметрВыработки = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ПараметрВыработки = Неопределено И ЗначениеЗаполнено(Реквизиты.ПараметрВыработки) Тогда
		
		ПараметрВыработки = НайтиСоздатьПараметрВыработки(Реквизиты.ПараметрВыработки);
		
		Если ПараметрВыработки = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Параметра выработки: %2'; en = 'Line %1. Error creating Production Parameter: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ПараметрВыработки);
		Иначе
			СтруктураСтроки.Вставить("ПараметрВыработки", ПараметрВыработки);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ПараметрВыработки);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("ПараметрВыработки", ПараметрВыработки);
		
	КонецЕсли;
	
	СтрокаПоиска = "Номенклатура/" + Реквизиты.НоменклатураУслуги;
	НоменклатураУслуги = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если НоменклатураУслуги = Неопределено И ЗначениеЗаполнено(Реквизиты.НоменклатураУслуги) Тогда
		
		НоменклатураУслуги = НайтиСоздатьНоменклатура(Реквизиты.НоменклатураУслуги, Истина);
		
		Если НоменклатураУслуги = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'В строке №%1 возникла ошибка при создании Номенклатуры услуги: %2. Уставновите основную единицу измерения в обработке ""Установка прав и настроек""'; en = 'An error occurred in line #%1 while creating the Service Nomenclature: %2. Set the primary unit of measurement in the ""Setting Rights and Settings"" process.'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.НоменклатураУслуги);
		Иначе
			СтруктураСтроки.Вставить("НоменклатураУслуги", НоменклатураУслуги);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, НоменклатураУслуги);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("НоменклатураУслуги", НоменклатураУслуги);
		
	КонецЕсли;
	
	СтрокаПоиска = "Валюты/" + Реквизиты.Валюта;
	Валюта = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ЗначениеЗаполнено(Реквизиты.Валюта) Тогда
		
		Валюта = НайтиЭлементСправочника("Валюты", Реквизиты.Валюта, Ложь);
		
		Если Валюта = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найдена Валюта: %2'; en = 'Currency not found for row #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Валюта);
			СтруктураСтроки.Вставить("Валюта", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Валюта", Валюта);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Валюта);
		КонецЕсли;
	Иначе
		СтруктураСтроки.Вставить("Валюта", Неопределено);
	КонецЕсли;
	
	СтавкаНДС = Неопределено;
	Если ЗначениеЗаполнено(Реквизиты.СтавкаНДС) И СокрЛП(Реквизиты.СтавкаНДС) <> "%" Тогда
		ОбменСКонтрагентамиПереопределяемый.ПолучитьЗначениеПеречисления("СтавкиНДС", Реквизиты.СтавкаНДС, СтавкаНДС);
	КонецЕсли;
	СтруктураСтроки.Вставить("СтавкаНДС", СтавкаНДС);
		
	СтруктураСтроки.Вставить("Сумма", Реквизиты.Сумма);
	
	СчПеренесено = СчПеренесено + 1;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		НоваяСтрока = ТаблСообщенияПеренос.Добавить();
		НоваяСтрока.ТекстСообщенияПеренос = ТекстСообщения;
	КонецЕсли;
	
	МассивСтруктурДляПереноса.Добавить(СтруктураСтроки);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьСтрокуРасходовВводаОстатков(Реквизиты, СчПеренесено, СчВсего, ЗагружаемыеСсылки)
	
	СоздатьСтроку = Истина;
	ТекстСообщения = "";
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("ДатаОтражения", Реквизиты.ДатаОтражения);
	
	СтрокаПоиска = "уатСтатьиРасходов/" + Реквизиты.СтатьяРасходов;
	СтатьяРасходов = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если СтатьяРасходов = Неопределено И ЗначениеЗаполнено(Реквизиты.СтатьяРасходов) Тогда
		
		СтатьяРасходов = НайтиСоздатьСтатьяРасходов(Реквизиты.СтатьяРасходов);
		
		Если СтатьяРасходов = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании статьи расходов: %2'; en = 'Line %1. Error creating expense item: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.СтатьяРасходов);
		Иначе
			СтруктураСтроки.Вставить("СтатьяРасходов", СтатьяРасходов);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, СтатьяРасходов);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("СтатьяРасходов", СтатьяРасходов);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатТС/" + Реквизиты.ТС;
	ТС = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ТС = Неопределено И ЗначениеЗаполнено(Реквизиты.ТС) Тогда
		
		ТС = НайтиЭлементСправочника("уатТС", Реквизиты.ТС);
		
		Если ТС = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найдено ТС: %2'; en = 'No vehicle found for line #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ТС);
			СтруктураСтроки.Вставить("ТС", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("ТС", ТС);
			СтруктураСтроки.Вставить("Колонна", ТС.Колонна);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ТС);
		КонецЕсли;
		
	Иначе
		
		Колонна = ?(ТС = Неопределено, Неопределено, ТС.Колонна);
		СтруктураСтроки.Вставить("ТС", ТС);
		СтруктураСтроки.Вставить("Колонна", Колонна);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Реквизиты.ЗаказНомер) Тогда
		
		Заказ = НайтиДокумент(ИскатьЗаказНаТСПоДате, Реквизиты.ЗаказДата, Реквизиты.ЗаказНомер, "уатЗаказГрузоотправителя");
		
		Если Заказ.Пустой() Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найден заказ на ТС: %2'; en = 'No order found for vehicle No. %1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ЗаказНомер + ?(ИскатьЗаказНаТСПоДате, " от " + Реквизиты.ЗаказДата, ""));
			СтруктураСтроки.Вставить("Заказ", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Заказ", Заказ.Выгрузить()[0].Ссылка);
		КонецЕсли;
	Иначе
		СтруктураСтроки.Вставить("Заказ", Неопределено);
	КонецЕсли;
	
	СтрокаПоиска = "Контрагенты/" + Реквизиты.Контрагент;
	Контрагент = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Контрагент = Неопределено И ЗначениеЗаполнено(Реквизиты.Контрагент) Тогда
		
		Контрагент = НайтиЭлементСправочника("Контрагенты", Реквизиты.Контрагент);
		
		Если Контрагент = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найден Контрагент: %2'; en = 'Counterparty not found for line #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Контрагент);
			СтруктураСтроки.Вставить("Контрагент", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Контрагент", Контрагент);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Контрагент);
		КонецЕсли;
		
	Иначе
		
		СтруктураСтроки.Вставить("Контрагент", Контрагент);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатОбъектыСтроительства/" + Реквизиты.ОбъектСтроительства;
	ОбъектСтроительства = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ОбъектСтроительства = Неопределено И ЗначениеЗаполнено(Реквизиты.ОбъектСтроительства) Тогда
		
		ОбъектСтроительства = НайтиСоздатьОбъектСтроительства(Реквизиты.ОбъектСтроительства);
		
		Если ОбъектСтроительства = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Объекта строительства: %2'; en = 'Line %1. Error creating Construction Object: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ОбъектСтроительства);
		Иначе
			СтруктураСтроки.Вставить("ОбъектСтроительства", ОбъектСтроительства);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ОбъектСтроительства);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("ОбъектСтроительства", ОбъектСтроительства);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатМаршруты/" + Реквизиты.Маршрут;
	Маршрут = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Маршрут = Неопределено И ЗначениеЗаполнено(Реквизиты.Маршрут) Тогда
		
		Маршрут = НайтиСоздатьМаршруты(Реквизиты.Маршрут);
		
		Если Маршрут = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Маршрута: %2'; en = 'Line %1. Error creating Route: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Маршрут);
		Иначе
			СтруктураСтроки.Вставить("Маршрут", Маршрут);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Маршрут);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("Маршрут", Маршрут);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатВидыПеревозок/" + Реквизиты.ВидПеревозки;
	ВидПеревозки = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ВидПеревозки = Неопределено И ЗначениеЗаполнено(Реквизиты.ВидПеревозки) Тогда
		
		ВидПеревозки = НайтиСоздатьВидПеревозки(Реквизиты.ВидПеревозки);
		
		Если ВидПеревозки = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Вида перевозки: %2'; en = 'Line %1. Error creating the Transportation Type: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.ВидПеревозки);
		Иначе
			СтруктураСтроки.Вставить("ВидПеревозки", ВидПеревозки);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, ВидПеревозки);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("ВидПеревозки", ВидПеревозки);
		
	КонецЕсли;
	
	СтрокаПоиска = "уатНаправленияПеревозок/" + Реквизиты.НаправлениеПеревозки;
	НаправлениеПеревозки = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если НаправлениеПеревозки = Неопределено И ЗначениеЗаполнено(Реквизиты.НаправлениеПеревозки) Тогда
		
		НаправлениеПеревозки = НайтиСоздатьНаправлениеПеревозки(Реквизиты.НаправлениеПеревозки);
		
		Если НаправлениеПеревозки = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании Направления перевозки: %2'; en = 'Line %1. Error creating the Transportation Direction: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.НаправлениеПеревозки);
		Иначе
			СтруктураСтроки.Вставить("НаправлениеПеревозки", НаправлениеПеревозки);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, НаправлениеПеревозки);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("НаправлениеПеревозки", НаправлениеПеревозки);
		
	КонецЕсли;
	
	СтрокаПоиска = "Номенклатура/" + Реквизиты.НоменклатураУслуги;
	НоменклатураУслуги = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если НоменклатураУслуги = Неопределено И ЗначениеЗаполнено(Реквизиты.НоменклатураУслуги) Тогда
		
		НоменклатураУслуги = НайтиСоздатьНоменклатура(Реквизиты.НоменклатураУслуги, Истина);
		
		Если НоменклатураУслуги = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'В строке №%1 возникла ошибка при создании Номенклатуры услуги: %2. Уставновите основную единицу измерения в обработке ""Установка прав и настроек""'; en = 'An error occurred in line #%1 while creating the Service Nomenclature: %2. Set the primary unit of measurement in the ""Setting Rights and Settings"" process.'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.НоменклатураУслуги);
		Иначе
			СтруктураСтроки.Вставить("НоменклатураУслуги", НоменклатураУслуги);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, НоменклатураУслуги);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("НоменклатураУслуги", НоменклатураУслуги);
		
	КонецЕсли;
	
	СтрокаПоиска = "Валюты/" + Реквизиты.Валюта;
	Валюта = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если ЗначениеЗаполнено(Реквизиты.Валюта) Тогда
		
		Валюта = НайтиЭлементСправочника("Валюты", Реквизиты.Валюта, Ложь);
		
		Если Валюта = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Для строки №%1 не найдена Валюта: %2'; en = 'Currency not found for row #%1: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Валюта);
			СтруктураСтроки.Вставить("Валюта", Неопределено);
		Иначе
			СтруктураСтроки.Вставить("Валюта", Валюта);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Валюта);
		КонецЕсли;
	Иначе
		СтруктураСтроки.Вставить("Валюта", Неопределено);
	КонецЕсли;
	
	СтавкаНДС = Неопределено;
	Если ЗначениеЗаполнено(Реквизиты.СтавкаНДС) И СокрЛП(Реквизиты.СтавкаНДС) <> "%" Тогда
		ОбменСКонтрагентамиПереопределяемый.ПолучитьЗначениеПеречисления("СтавкиНДС", Реквизиты.СтавкаНДС, СтавкаНДС);
	КонецЕсли;
	СтруктураСтроки.Вставить("СтавкаНДС", СтавкаНДС);
		
	СтруктураСтроки.Вставить("Сумма", Реквизиты.Сумма);
	
	СчПеренесено = СчПеренесено + 1;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		НоваяСтрока = ТаблСообщенияПеренос.Добавить();
		НоваяСтрока.ТекстСообщенияПеренос = ТекстСообщения;
	КонецЕсли;
	
	МассивСтруктурДляПереноса.Добавить(СтруктураСтроки);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьСтрокуОстатковДСВводаОстатков(Реквизиты, СчПеренесено, СчВсего, ЗагружаемыеСсылки)
	
	СоздатьСтроку = Истина;
	ТекстСообщения = "";
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("ДатаОтражения", Реквизиты.ДатаОтражения);
	
	СтрокаПоиска = "СтатьиДвиженияДенежныхСредств/" + Реквизиты.СтатьяДвиженияДенежныхСредств;
	СтатьяДвиженияДенежныхСредств = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если СтатьяДвиженияДенежныхСредств = Неопределено И ЗначениеЗаполнено(Реквизиты.СтатьяДвиженияДенежныхСредств) Тогда
		
		СтатьяДвиженияДенежныхСредств = НайтиСоздатьСтатьяДвиженияДенежныхСредств(Реквизиты.СтатьяДвиженияДенежныхСредств);
		
		Если СтатьяДвиженияДенежныхСредств = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании статьи движения сенежных  средств: %2'; en = 'Line %1. Error creating cash flow statement: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.СтатьяДвиженияДенежныхСредств);
		Иначе
			СтруктураСтроки.Вставить("СтатьяДвиженияДенежныхСредств", СтатьяДвиженияДенежныхСредств);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, СтатьяДвиженияДенежныхСредств);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("СтатьяДвиженияДенежныхСредств", СтатьяДвиженияДенежныхСредств);
		
	КонецЕсли;
	
	СтруктураСтроки.Вставить("Сумма", Реквизиты.Сумма);
	
	Если КассаБанковскийСчет = "Касса" Тогда
		СтрокаПоиска = "Кассы/" + Реквизиты.Касса;
		Касса = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
		
		Если Касса = Неопределено И ЗначениеЗаполнено(Реквизиты.Касса) Тогда
			
			Касса = НайтиСоздатьКасса(Реквизиты.Касса);
			
			Если Касса = Неопределено Тогда
				ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании кассы: %2'; en = 'Line %1. Error creating cash register: %2'") + Символы.ПС;
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Касса);
			Иначе
				СтруктураСтроки.Вставить("БанковскийСчетКасса", Касса);
				ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Касса);
			КонецЕсли;
		Иначе
			
			СтруктураСтроки.Вставить("БанковскийСчетКасса", Касса);
			
		КонецЕсли;
	Иначе
		СтрокаПоиска = "БанковскиеСчета/" + Реквизиты.БанковскийСчет;
		БанковскийСчет = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
		
		Если БанковскийСчет = Неопределено И ЗначениеЗаполнено(Реквизиты.БанковскийСчет) Тогда
			
			БанковскийСчет = НайтиСоздатьБанковскийСчет(Реквизиты.БанковскийСчет, Реквизиты.Контрагент, 
				Реквизиты.БИК, СчВсего, ЗагружаемыеСсылки);
			
			Если БанковскийСчет = 1 Тогда
				ТекстСообщения = Нстр("ru = 'В строке №%1 ошибка при создании банковского счета: %2'; en = 'There was an error creating a bank account at line #%1: %2'") + ТекстСообщения;
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.БанковскийСчет);
			Иначе
				СтруктураСтроки.Вставить("БанковскийСчетКасса", БанковскийСчет);
				ЗагружаемыеСсылки.Вставить(СтрокаПоиска, БанковскийСчет);
			КонецЕсли;
		Иначе
			
			СтруктураСтроки.Вставить("БанковскийСчетКасса", БанковскийСчет);
			
		КонецЕсли;
	КонецЕсли;
	
	СчПеренесено = СчПеренесено + 1;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		НоваяСтрока = ТаблСообщенияПеренос.Добавить();
		НоваяСтрока.ТекстСообщенияПеренос = ТекстСообщения;
	КонецЕсли;
	
	МассивСтруктурДляПереноса.Добавить(СтруктураСтроки);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьСтрокуОстатковДСПодотчетныхЛицВводаОстатков(Реквизиты, СчПеренесено, СчВсего, ЗагружаемыеСсылки)
	
	СоздатьСтроку = Истина;
	ТекстСообщения = "";
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("ДатаОтражения", Реквизиты.ДатаОтражения);
	
	СтрокаПоиска = "ФизическиеЛица/" + Реквизиты.ПодотчетноеЛицо;
