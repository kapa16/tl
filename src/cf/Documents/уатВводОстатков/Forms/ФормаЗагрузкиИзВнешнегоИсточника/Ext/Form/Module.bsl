&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	
	ТаблСообщенияПеренос.Очистить();
	
	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаДоходы Тогда
		ПеренестиДоходы();
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаРасходы Тогда
		ПеренестиРасходы();
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаОстаткиДСПодотчетныхЛиц Тогда
		ПеренестиОстаткиДСПодотчетныхЛиц();
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаОстаткиДС Тогда
		ПеренестиОстаткиДС();
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаМатериалы Тогда
		ПеренестиМатериалы();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиДоходы()
	
	Если Не ПроверитьЗаполнениеОбязательныхПолей("Доходы") Тогда 
		Возврат;
	КонецЕсли;
	
	МассивСтруктурДляПереноса.Очистить();
	СтруктураЗаголовок = Новый Структура;
	СтруктураЗаголовок.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.уатВидыОперацийВводОстатков.ОперативныеДоходы"));
	СтруктураЗаголовок.Вставить("ТаблицаДокумента", "Доходы");
	МассивСтруктурДляПереноса.Добавить(СтруктураЗаголовок);
	
	СчВсего   = 0;
	СчПеренесено = 0;
	
	ОбработатьТаблицуДоходы(СчВсего, СчПеренесено);
	ШаблонСообщения = НСтр(
		"en = 'Rows moved: %1'; ru = 'Строк перенесено: %1'"
	);
	Если ТаблСообщенияПеренос.Количество() > 0 Тогда
