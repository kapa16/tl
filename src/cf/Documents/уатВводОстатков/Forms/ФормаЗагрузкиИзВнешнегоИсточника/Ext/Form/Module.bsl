		Если ПодотчетноеЛицо = Неопределено Тогда
			СоздатьСтроку = Ложь;
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании подотчетного лица: %2'; en = 'Line %1. Error creating accountable person: %2'") + Символы.ПС;
