&НаКлиенте
Процедура ПрочитатьДоходы(Команда)
	
	Если Не ЗначениеЗаполнено(ПутьКФайлуДоходы) Тогда 
		СообщениеПользователю(НСтр("en='You must select a file';ru='Необходимо выбрать файл'"), "ПутьКФайлуДоходы");
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ИмяТаблицы",              "Доходы");
	ДополнительныеПараметры.Вставить("ПутьКФайлу",              ПутьКФайлуДоходы);
	ДополнительныеПараметры.Вставить("НомерПервойСтрокиДанных", НомерПервойСтрокиДанныхДоходов);
	
	Если Доходы.Количество() Тогда 
		ТекстВопроса = НСтр("en='The table ""Income"" will be cleared. Continue?';ru='Таблица ""Доходы"" будет очищена. Продолжить?'");
		Оповещение = Новый ОписаниеОповещения("ОчиститьТаблицуДанных", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
	Иначе 
		ПрочитатьДанныеИзФайла(ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

