&НаСервере
Функция РеквизитыДоходов()
	Реквизиты = Новый Структура;
	Реквизиты.Вставить("ДатаОтражения",        "");
	Реквизиты.Вставить("СтатьяДоходов",        "");
	Реквизиты.Вставить("Сумма",                 0);
	Реквизиты.Вставить("Колонна",              "");
	Реквизиты.Вставить("ТС",                   "");
	Реквизиты.Вставить("ЗаказДата",            ""); 
	Реквизиты.Вставить("ЗаказНомер",           "");
	Реквизиты.Вставить("Контрагент",           "");
	Реквизиты.Вставить("ОбъектСтроительства",  "");
	Реквизиты.Вставить("Маршрут",              "");
	Реквизиты.Вставить("ВидПеревозки",         "");
	Реквизиты.Вставить("НаправлениеПеревозки", "");
	Реквизиты.Вставить("ПараметрВыработки",    "");
	Реквизиты.Вставить("НоменклатураУслуги",   "");
	Реквизиты.Вставить("Валюта",               "");
	Реквизиты.Вставить("СтавкаНДС",            "");
	Возврат Реквизиты;
КонецФункции

