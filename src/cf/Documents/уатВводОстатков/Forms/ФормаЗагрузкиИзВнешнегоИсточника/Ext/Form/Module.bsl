&НаСервере
Процедура СоздатьСтрокуМатериаловВводаОстатков(Реквизиты, СчПеренесено, СчВсего, ЗагружаемыеСсылки)
	
	СоздатьСтроку = Истина;
	ТекстСообщения = "";
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("ДатаОтражения", Реквизиты.ДатаОтражения);
	
	СтрокаПоиска = "Склады/" + Реквизиты.Склад;
	Склад = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Склад = Неопределено И ЗначениеЗаполнено(Реквизиты.Склад) Тогда
		
		Склад = НайтиСоздатьСклад(Реквизиты.Склад);
		
		Если Склад = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'Строка %1. Ошибка при создании склада: %2'; en = 'Line %1. Error creating warehouse: %2'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Склад);
		Иначе
			СтруктураСтроки.Вставить("Склад", Склад);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Склад);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("Склад", Склад);
		
	КонецЕсли;
	
	СтрокаПоиска = "Номенклатура/" + Реквизиты.Номенклатура;
	Номенклатура = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Номенклатура = Неопределено И ЗначениеЗаполнено(Реквизиты.Номенклатура) Тогда
		
		Номенклатура = НайтиСоздатьНоменклатура(Реквизиты.Номенклатура, Ложь);
		
		Если Номенклатура = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Нстр("ru = 'В строке №%1 ошибка при создании Номенклатуры услуги: %2. Уставновите основную единицу измерения в обработке ""Установка прав и настроек""'; en = 'Line #%1 contains an error while creating the Service Nomenclature: %2. Set the primary unit of measurement in the ""Setting Rights and Settings"" process.'") + Символы.ПС;
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", Реквизиты.Номенклатура);
		Иначе
			СтруктураСтроки.Вставить("Номенклатура", Номенклатура);
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Номенклатура);
		КонецЕсли;
	Иначе
		
		СтруктураСтроки.Вставить("Номенклатура", Номенклатура);
		
	КонецЕсли;
	
	СтруктураСтроки.Вставить("Количество", Реквизиты.Количество);
	СтруктураСтроки.Вставить("Стоимость", Реквизиты.Стоимость);
	СтруктураСтроки.Вставить("СтоимостьУпр", Реквизиты.СтоимостьУпр);
	
	СчПеренесено = СчПеренесено + 1;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		НоваяСтрока = ТаблСообщенияПеренос.Добавить();
		НоваяСтрока.ТекстСообщенияПеренос = ТекстСообщения;
	КонецЕсли;
	
	МассивСтруктурДляПереноса.Добавить(СтруктураСтроки);
	
КонецПроцедуры

&НаСервере
Функция НайтиЭлементСправочника(НаименованиеСправочника, НаименованиеЭлемента, Иерархический = Истина)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", НаименованиеЭлемента);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	" + НаименованиеСправочника + ".Ссылка КАК Ссылка
	|ИЗ
	|	Справочник." + НаименованиеСправочника + " КАК " + НаименованиеСправочника + "
	|ГДЕ
	|	НЕ " + НаименованиеСправочника + ".ПометкаУдаления
	|	" + ?(Иерархический, "И НЕ " + НаименованиеСправочника + ".ЭтоГруппа", "") + "
	|	И " + НаименованиеСправочника + ".Наименование = &Наименование";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
