&НаСервере
Функция НайтиСоздатьБанковскийСчет(БанковскийСчет, КонтрагентСтр, БИКСтр, СчВсего, ЗагружаемыеСсылки)
	
	Если Не ЗначениеЗаполнено(БанковскийСчет) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	(БанковскиеСчета.Наименование = &Наименование
	|			ИЛИ БанковскиеСчета.НомерСчета = &Наименование)
	|	И НЕ БанковскиеСчета.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", БанковскийСчет);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	СоздаватьСчет = Истина;
	
	Если Не ЗначениеЗаполнено(КонтрагентСтр) Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + Нстр("ru = 'Строка %1. Банковский счет: %2 не найден. Заполните колонку ""Контрагент"" для создания счета'; en = 'Line %1. Bank account: %2 not found. Please fill in the ""Counterparty"" column to create an invoice.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", БанковскийСчет);
		СоздаватьСчет = Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(БИКСтр) Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + Нстр("ru = 'Строка %1. Банковский счет: %2 не найден. Заполните колонку ""БИК"" для создания счета'; en = 'Line %1. Bank account: %2 not found. Please fill in the ""BIC"" column to create an account.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", БанковскийСчет);
		СоздаватьСчет = Ложь;
	КонецЕсли;
	
	Если Не СоздаватьСчет Тогда
		Возврат 1;
	КонецЕсли;
	
	СтрокаПоиска = "Контрагенты/" + КонтрагентСтр;
	Контрагент = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если Контрагент = Неопределено Тогда
		
		Контрагент = НайтиЭлементСправочника("Контрагенты", КонтрагентСтр);
		
		Если Контрагент = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Символы.ПС + Нстр("ru = 'Для строки №%1 не найден Контрагент: %2'; en = 'Counterparty not found for line #%1: %2'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", КонтрагентСтр);
			СоздаватьСчет = Ложь;
		Иначе
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, Контрагент);
		КонецЕсли;
		
	КонецЕсли;
	
	СтрокаПоиска = "Банки/" + БИКСтр;
	БИК = ЗагружаемыеСсылки.Получить(СтрокаПоиска);
	
	Если БИК = Неопределено Тогда
		
		БИК = НайтиБИК(БИКСтр);
		
		Если БИК = Неопределено Тогда
			ТекстСообщения = ТекстСообщения + Символы.ПС + Нстр("ru = 'Для строки №%1 не найден БИК: %2, создание счета невозможно'; en = 'BIC not found for line #%1: %2, account creation impossible'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчВсего + 1);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%2", БИКСтр);
			СоздаватьСчет = Ложь;
		Иначе
			ЗагружаемыеСсылки.Вставить(СтрокаПоиска, БИК);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не СоздаватьСчет Тогда
		Возврат 1;
	КонецЕсли;
	
	БанковскийСчетНовый = Справочники.БанковскиеСчета.СоздатьЭлемент();
	БанковскийСчетНовый.Заполнить(Неопределено);
	БанковскийСчетНовый.Наименование = БанковскийСчет;
	БанковскийСчетНовый.НомерСчета   = БанковскийСчет;
	БанковскийСчетНовый.Владелец     = Контрагент;
	БанковскийСчетНовый.Банк         = БИК;
	
	БанковскийСчетНовый.Записать();
	
	Возврат БанковскийСчетНовый.Ссылка;
	
КонецФункции

