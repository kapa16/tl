#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.ТипВедомости) Тогда
		Объект.ТипВедомости = Перечисления.GDS_ТипыЗаправочныхВедомостей.Заправочная;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновитьДанныеКолонкиКг();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ОбновитьДанныеКолонкиКг();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	СпрПривлеченный = Справочники.уатТС.НайтиПоНаименованию("Привлеченный транспорт",Истина);
	СпрВерхнееОбору = Справочники.уатТС.НайтиПоНаименованию("Верхнее  Оборудование",Истина);
	Для Каждого Строка из Объект.Заправки Цикл
		Если НЕ Строка.ПЛ.Пустая() Тогда
			Если НачалоМесяца(Строка.ПЛ.Дата)<>НачалоМесяца(Объект.Дата) Тогда
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = "В строке " + Строка.НомерСтроки + " ошибка. Путевой лист другого периода.";
				Сообщение.Сообщить();
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		Если Строка.ТС.ПринадлежитЭлементу(СпрПривлеченный) Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "В строке " + Строка.НомерСтроки + " ошибка. ТС - привлеченный транспорт.";
			Сообщение.Сообщить();
		ИначеЕсли Строка.ТС.ПринадлежитЭлементу(СпрВерхнееОбору) Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "В строке " + Строка.НомерСтроки + " ошибка. ТС - верхнее оборудование.";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;	
		Если Строка.ТС.ПометкаУдаления Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "В строке " + Строка.НомерСтроки + " ошибка. ТС помечено на удаление.";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;	
		Если Строка.ПЛ.ПометкаУдаления Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "В строке " + Строка.НомерСтроки + " ошибка. Документ Путевой лист помечен на удаление.";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;	
		
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ОбновитьДанныеКолонкиКг();
КонецПроцедуры

#КонецОбласти

