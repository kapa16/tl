;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДокументуатДиспозицияТС.Ссылка КАК Ссылка,
	ДокументуатДиспозицияТС.ПометкаУдаления КАК ПометкаУдаления,
	ДокументуатДиспозицияТС.Номер КАК Номер,
	ДокументуатДиспозицияТС.Дата КАК Дата,
	ДокументуатДиспозицияТС.Проведен КАК Проведен,
	ДокументуатДиспозицияТС.ДатаНачала КАК ДатаНачала,
	ДокументуатДиспозицияТС.ДатаОкончания КАК ДатаОкончания,
	ДокументуатДиспозицияТС.Заказ КАК Заказ,
	ДокументуатДиспозицияТС.Комментарий КАК Комментарий,
	ДокументуатДиспозицияТС.Контрагент КАК Контрагент,
	ДокументуатДиспозицияТС.Местоположение КАК Местоположение,
	ДокументуатДиспозицияТС.Организация КАК Организация,
	ДокументуатДиспозицияТС.Ответственный КАК Ответственный,
	ДокументуатДиспозицияТС.Состояние КАК Состояние,
	ДокументуатДиспозицияТС.СписокТССтрока КАК ТС,
	ДокументуатДиспозицияТС.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл,
	ЕСТЬNULL(ВТ_КоличествоСостояний.КоличествоСостояний, 0) КАК КоличествоСостояний
ИЗ
	Документ.уатДиспозицияТС КАК ДокументуатДиспозицияТС
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументуатДиспозицияТС.Ссылка = НаличиеФайлов.ОбъектСФайлами
