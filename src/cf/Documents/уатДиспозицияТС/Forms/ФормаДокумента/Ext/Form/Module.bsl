#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьСписокТСПоДокументу(Документ, ДопПараметры)
	Если ДопПараметры.Очистить Тогда
		Объект.СписокТС.Очистить();
	КонецЕсли;
	Модифицрованность = Истина;
	Для каждого ТекВагон Из Документ.Вагоны Цикл
		НоваяСтрока = Объект.СписокТС.Добавить();
		ТипНатурныйЛист      = "ДокументСсылка.уатНатурныйЛист";
		ТипДислокацияВагонов = "ДокументСсылка.уатДислокацияВагонов";
		Если ТипЗнч(Документ) = Тип(ТипНатурныйЛист) Тогда
			НоваяСтрока.ТС = ТекВагон.НомерВагона;
		ИначеЕсли ТипЗнч(Документ) = Тип(ТипДислокацияВагонов) Тогда
			НоваяСтрока.ТС = ТекВагон.Вагон;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеВыбораДокументаДляЗаполнения(Результат, ДопПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьСписокТСПоДокументу(Результат, ДопПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВагоныПоДокументу(Результат, ДопПараметры) Экспорт
	ДополнительныеПараметры = Новый Структура();
	Очистить = ?(Результат = КодВозвратаДиалога.Да, Истина, Ложь);
	ДополнительныеПараметры.Вставить("Очистить", Очистить);
	ОповещениеОВыборе = Новый ОписаниеОповещения("ЗавершениеВыбораДокументаДляЗаполнения", ЭтотОбъект, ДополнительныеПараметры);
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗаполнитьПо", ДопПараметры);
	ФормаСпискаКритерийОтбора = "КритерийОтбора.уатВагоныВДиспозицииИНатурныхЛистах.ФормаСписка";
	ОткрытьФорму(ФормаСпискаКритерийОтбора,ПараметрыОткрытия,,,,,
	ОповещениеОВыборе,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоДислокации(Команда)
	Оповещение = Новый ОписаниеОповещения("ЗаполнитьВагоныПоДокументу", ЭтотОбъект, "Дислокация");
	ТекстВопроса = НСтр("en='Clear the tabular section before filling?';ru='Очистить табличную часть при заполнении?'");
	ТекстЗаголовка = НСтр("en='Clear the table';ru='Очистка таблицы'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Нет, ТекстЗаголовка);
	Возврат;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоНатурномуЛисту(Команда)
	Оповещение = Новый ОписаниеОповещения("ЗаполнитьВагоныПоДокументу", ЭтотОбъект, "НатурныйЛист");
	ТекстВопроса = НСтр("en='Clear the tabular section before filling?';ru='Очистить табличную часть при заполнении?'");
	ТекстЗаголовка = НСтр("en='Clear the table';ru='Очистка таблицы'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Нет, ТекстЗаголовка);
	Возврат;
КонецПроцедуры

&НаКлиенте
Процедура СпособРедактрованияПриИзменении(Элемент)
	Если Не Булево(СпособРедактирования) И Объект.СписокТС.Количество() > 1 Тогда
		ТекстНСТР = НСтр("ru='Все строки ТС, кроме первой, будут удалены. Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("СпособРедактрованияПриИзмененииЗавершение", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да,);
			
		Возврат;
	Иначе
		Если Объект.СписокТС.Количество()  = 0 Тогда
			НовоеТС = Объект.СписокТС.Добавить();
		КонецЕсли;
		
		Элементы.СписокТС.ТекущаяСтрока = Объект.СписокТС[0].ПолучитьИдентификатор();
		Если Булево(СпособРедактирования) Тогда
			Объект.СписокТС[0].Состояние = Объект.Состояние;
		Иначе
			Объект.Состояние = Объект.СписокТС[0].Состояние;
		КонецЕсли;
		СтрокаТС = Элементы.СписокТС.ТекущиеДанные;
	КонецЕсли;
	
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура СпособРедактрованияПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		СпособРедактирования = 1;
		Возврат;
	КонецЕсли;
	
	Пока Объект.СписокТС.Количество() > 1 Цикл
		СтрокаУдаления = Объект.СписокТС[1];
		Объект.СписокТС.Удалить(СтрокаУдаления);
	КонецЦикла;
	
	Элементы.СписокТС.ТекущаяСтрока = Объект.СписокТС[0].ПолучитьИдентификатор();
	Объект.Состояние = Объект.СписокТС[0].Состояние;
	
	УстановитьВидимость();
	
КонецПроцедуры

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
    ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
    ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаСервере
Процедура УстановитьВидимость()
	Если СпособРедактирования = 0 Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.Страницы.ПодчиненныеЭлементы.ГруппаТС;
		Элементы.Состояние.Видимость = Истина;
		Элементы.ГруппаПериод.Видимость = Истина;
	Иначе
		Элементы.Страницы.ТекущаяСтраница = Элементы.Страницы.ПодчиненныеЭлементы.ГруппаСписокТС;
		Элементы.Состояние.Видимость = Ложь;
		Элементы.ГруппаПериод.Видимость = Ложь;
	КонецЕсли;
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		Элементы.ГруппаКоманды.Видимость = ПолучитьФункциональнуюОпцию("уатИспользоватьЖДПеревозки");
	Иначе
		Элементы.ГруппаКоманды.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
