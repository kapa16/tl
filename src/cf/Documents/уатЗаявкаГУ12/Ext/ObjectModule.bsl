
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатЗаказПеревозчику_уэ") Тогда
		Организация = ДанныеЗаполнения.Организация;
		НомерЗаявкиОператору = ДанныеЗаполнения.Номер;
		Перевозчик = ДанныеЗаполнения.Контрагент;
		ПериодПеревозкиС = ДанныеЗаполнения.ДатаИВремяОтправления;
		ПериодПеревозкиПО = ДанныеЗаполнения.ДатаИВремяПрибытия;
		ДокументОснование = ДанныеЗаполнения.Ссылка;
		Если ДанныеЗаполнения.Грузы.Количество() <> 0 Тогда
			СтанцияОтправления = ДанныеЗаполнения.Грузы[0].Заказ.АдресНазначения;
		КонецЕсли;
		
		Для каждого ТекВагон Из ДанныеЗаполнения.ПотребностьВВагонах Цикл
			НоваяСтрока = Груз.Добавить();
			НоваяСтрока.Вес = ТекВагон.Вес;
			НоваяСтрока.Заказ = ТекВагон.ЗаказНаТС;
			НоваяСтрока.КоличествоВагонов = ТекВагон.Подтверждено;
			НоваяСтрока.КодГруза = ТекВагон.КодГруза;
			НоваяСтрока.ВидПодвижногоСостава = ТекВагон.ТипВагона;
			НоваяСтрока.СтанцияНазначения = ТекВагон.ЗаказНаТС.АдресНазначения;
			НоваяСтрока.Грузополучатель = ТекВагон.ЗаказНаТС.Грузополучатель;
			Для каждого ТекГруз Из ДанныеЗаполнения.Грузы Цикл
				Если Не ЗначениеЗаполнено(ТекГруз.ГрузовоеМесто) 
					Или ТипЗнч(ТекГруз.ГрузовоеМесто) <> Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
					Продолжить;
				КонецЕсли;
				Если ТекГруз.ГрузовоеМесто.КодЕТСНГ = ТекВагон.КодГруза Или ТекГруз.ГрузовоеМесто.КодГНГ = ТекВагон.КодГруза Тогда
					НоваяСтрока.ГрузовоеМесто = ТекГруз.ГрузовоеМесто;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры
