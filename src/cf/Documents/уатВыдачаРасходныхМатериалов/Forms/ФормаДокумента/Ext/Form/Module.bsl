	МассивТипов = Новый Массив();
	МассивТипов.Добавить(Тип("СправочникСсылка.Сотрудники"));
	ОписаниеТипов = Новый ОписаниеТипов(МассивТипов);
	
	Элементы.МатериалыВодитель.ОграничениеТипа = ОписаниеТипов;
	
КонецПроцедуры

