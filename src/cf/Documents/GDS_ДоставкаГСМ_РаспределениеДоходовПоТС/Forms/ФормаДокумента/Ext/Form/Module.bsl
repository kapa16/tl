&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МожноЗаписывать = ПроверитьВозможностьПроведения();
	Если НЕ МожноЗаписывать Тогда
		ЭтаФорма.ТолькоПросмотр = Истина;
		Элементы.ТЧ_ПоПЛОтправитьПутевыеЛисты.Доступность = ЛОЖЬ;
		Элементы.ТЧЗаполнить.Доступность = ЛОЖЬ;
	КонецЕсли;
	
	//Для каждого Строка из Объект.ТЧ_ПоПЛ Цикл
	//	Строка.Статус = МеКаМи_ФункцииСПовторнымИспользованием.ВернутьСтатусДокумента(Строка.ПЛ);
	//КонецЦикла;	
	
	Если Объект.Проведен Тогда
		
		Сообщить("Форма документа открыта на просмотр. Проведенный документ запрещено редактировать!");
		ЭтаФорма.ТолькоПросмотр = Истина; 
		ЭтаФорма.Элементы.ТЧ.КоманднаяПанель.Доступность = ЛОЖЬ;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокЛокаций()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_ПУ_Расширенный.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.GDS_ПУ_Расширенный КАК GDS_ПУ_Расширенный";
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Для каждого строкаТЗ из ТЗ Цикл
		Нашли  = ЛОЖЬ;
    	Для каждого Строка из СписокЛокаций Цикл
			Если Строка.Значение = СтрокаТЗ.Ссылка Тогда
				Нашли = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;	
		Если не Нашли ТОгда
			СписокЛокаций.Добавить(СтрокаТЗ.Ссылка);
		КонецЕсли;	
	КонецЦикла;	
			
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()

	Если ГруппаТС.Пустая() Тогда
		сообщ=Новый СообщениеПользователю;
		сообщ.Текст = "Укажите в какой группе находятся перевозчики ГСМ!";
		сообщ.Поле="ГруппаТС";
		сообщ.ПутьКДанным = "Объект";
		сообщ.Сообщить();
		Возврат;
	КонецЕсли;
	
	МассивЛокаций = Новый Массив;
	Для каждого Элем из СписокЛокаций Цикл
		Если Элем.Значение.пустая() Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ Элем.Пометка Тогда
			Продолжить;
		КонецЕсли;
		МассивЛокаций.Добавить(Элем.Значение);
	КонецЦикла;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	уатПеремещениеТоваровТовары.Ссылка.МеКаМи_РасширеннаяИнформацияОЛокации КАК РасширеннаяИнформацияОЛокации,
		|	СУММА(уатПеремещениеТоваровТовары.Количество) КАК Количество,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладОтправитель КАК СкладОтправитель,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель КАК СкладПолучатель,
		|	уатПеремещениеТоваровТовары.Ссылка.МеКаМи_РасширеннаяИнформацияОЛокации КАК ПУ,
		|	уатПеремещениеТоваровТовары.Ссылка.Локация КАК Локация,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель.Контрагент КАК СкладПолучательЗаказчик,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель.ТС КАК СкладПолучательТС,
		|	уатПеремещениеТоваровТовары.Ссылка.Дата КАК Дата
		|ИЗ
		|	Документ.уатПеремещениеТоваров.Товары КАК уатПеремещениеТоваровТовары
		|ГДЕ
		|	уатПеремещениеТоваровТовары.Ссылка.Дата МЕЖДУ &Нач И &Кон
		|	И уатПеремещениеТоваровТовары.Ссылка.МеКаМи_РасширеннаяИнформацияОЛокации В(&МассивЛокаций)
		|	И (уатПеремещениеТоваровТовары.Ссылка.Проведен
		|			ИЛИ уатПеремещениеТоваровТовары.Ссылка.МеКаМи_ПоказыватьВОтчетеДвижениеГСМ)
		|	И уатПеремещениеТоваровТовары.Номенклатура = &Номенклатура
		|	И уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель.Контрагент = &Контрагент
		|
		|СГРУППИРОВАТЬ ПО
		|	уатПеремещениеТоваровТовары.Ссылка.МеКаМи_РасширеннаяИнформацияОЛокации,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель,
		|	уатПеремещениеТоваровТовары.Ссылка.Локация,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель.ТС,
		|	уатПеремещениеТоваровТовары.Ссылка.Дата,
		|	уатПеремещениеТоваровТовары.Ссылка.СкладПолучатель.Контрагент,
		|	уатПеремещениеТоваровТовары.Ссылка.МеКаМи_РасширеннаяИнформацияОЛокации";
	
	
	Запрос.Параметры.Вставить("МассивЛокаций",МассивЛокаций);
	Запрос.Параметры.Вставить("Номенклатура",Справочники.Номенклатура.НайтиПоКоду("00000000002"));
	Запрос.Параметры.Вставить("Нач",НачалоМесяца(Объект.Дата));
	Запрос.Параметры.Вставить("Кон",КонецМесяца(Объект.Дата));
	Запрос.Параметры.Вставить("Контрагент",Объект.Контрагент);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	ТЗ.Свернуть("РасширеннаяИнформацияОЛокации, ПУ, СкладОтправитель, СкладПолучатель, СкладПолучательЗаказчик, СкладПолучательТС, Локация, Дата","количество");
	ТЗ.Сортировать("ПУ, СкладОтправитель");
	
	ТЗ.Колонки.Добавить("Цена");
	Для Каждого Строка из ТЗ Цикл
		Строка.Цена = 0;
		КолСтр = Строка.РасширеннаяИнформацияОЛокации.ДетальнаяИнформацияПоПериодам.Количество();
		Пока КолСтр<>0 Цикл
			ТекСтр = Строка.РасширеннаяИнформацияОЛокации.ДетальнаяИнформацияПоПериодам[КолСтр-1];
		    Если НачалоМесяца(Объект.Дата) >= ТекСтр.Период Тогда
				Строка.Цена = ТекСтр.ЦенаЗаТоннуСУчетомЛогистики;
			КонецЕсли;
			КолСтр = КолСтр - 1;
		КонецЦикла;
	КонецЦикла;
	
	ТЗ_ДляТЧ = Объект.ТЧ.Выгрузить();
	ТЗ_ДляТЧ.Очистить();
	
	Для Каждого Строка из ТЗ Цикл
		Если Строка.СкладПолучательЗаказчик.Пустая() Тогда
			Продолжить;
		КонецЕсли;
		НовСтр = ТЗ_ДляТЧ.Добавить();
		НовСтр.Склад = Строка.СкладОтправитель;
		НовСтр.Сумма = Строка.цена * Строка.Количество;
		НовСтр.Заказчик = Строка.СкладПолучательЗаказчик;
		НовСтр.ПУ = Строка.Локация;
		НовСтр.ТС = ПолучитьТС(Строка.СкладОтправитель,Строка.Дата);
		НовСтр.Количество = Строка.Количество;
		НовСтр.РасширеннаяИнформацияОЛокации = Строка.РасширеннаяИнформацияОЛокации;
	КонецЦикла;
	ТЗ_ДляТЧ.Свернуть("Склад,Заказчик,ПУ,ТС,РасширеннаяИнформацияОЛокации","Сумма,Количество");
	Объект.ТЧ.Загрузить(ТЗ_ДляТЧ);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТС(СкладОтправитель,Дата) 
	
	ТС = СкладОтправитель.ТС;
	Если ТС.Пустая() Тогда
		Сообщить("ТС для склада " + СкладОтправитель + " не определен!");
		Возврат Справочники.уатТС.ПустаяСсылка();
	КонецЕсли;	
	Если ТС.ПринадлежитЭлементу(ГруппаТС) Тогда
		Возврат ТС;
	КонецЕсли;
	
	//Если это АТЗ то ищем когда заливался с поезда последний раз и подставим поезд
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	уатПеремещениеТоваров.СкладПолучатель КАК СкладПолучатель,
		|	уатПеремещениеТоваров.Ссылка КАК Ссылка,
		|	уатПеремещениеТоваров.Дата КАК Дата,
		|	уатПеремещениеТоваров.СкладОтправитель КАК СкладОтправитель
		|ИЗ
		|	Документ.уатПеремещениеТоваров КАК уатПеремещениеТоваров
		|ГДЕ
		|	уатПеремещениеТоваров.Дата <= &Дата
		|	И уатПеремещениеТоваров.СкладПолучатель = &СкладПолучатель
		|	И уатПеремещениеТоваров.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("СкладПолучатель", СкладОтправитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТС = ВыборкаДетальныеЗаписи.СкладОтправитель.ТС;
		Если ТС.Пустая() Тогда
			Продолжить;
		КонецЕсли;	
		Если ТС.ПринадлежитЭлементу(ГруппаТС) Тогда
			Возврат ТС;
		КонецЕсли;
	КонецЦикла;
	Сообщить("Есть ошибка! ТС для склада " + СкладОтправитель + " нет получения ГСМ с автопоезда");
	Возврат Справочники.уатТС.ПустаяСсылка();
КонецФункции

&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	ТЧ = ТекущийОбъект.ТЧ.Выгрузить();
	ТЧ.Свернуть("ТС","");
	СписокТС = ТЧ.ВыгрузитьКолонку("ТС");
	ТекущийОбъект.ТЧ_ПоПЛ.Очистить();
	ТЧ = ТекущийОбъект.ТЧ_ПоПЛ.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	уатПутевойЛистЗадание.Ссылка.ТранспортноеСредство КАК ТранспортноеСредство,
		|	СУММА(ВЫБОР
		|			КОГДА уатПутевойЛистЗадание.КоличествоЧасов = 0
		|				ТОГДА 11
		|			ИНАЧЕ уатПутевойЛистЗадание.КоличествоЧасов
		|		КОНЕЦ) КАК КоличествоЧасов,
		|	уатПутевойЛистЗадание.Ссылка КАК Ссылка,
		|	СУММА(уатПутевойЛистЗадание.КоличествоЧасов) КАК КоличествоЧасовТест
		|ПОМЕСТИТЬ ВыборкаПЛ
		|ИЗ
		|	Документ.уатПутевойЛист.Задание КАК уатПутевойЛистЗадание
		|ГДЕ
		|	уатПутевойЛистЗадание.Ссылка.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
		|	И уатПутевойЛистЗадание.Ссылка.Проведен
		|	И уатПутевойЛистЗадание.Ссылка.Рассчитан
		|	И уатПутевойЛистЗадание.Ссылка.ТранспортноеСредство В(&СписокТС)
		|	И ВЫБОР
		|			КОГДА уатПутевойЛистЗадание.МеКаМи_ВидУслуг.НеОплачиваемые = ИСТИНА
		|				ТОГДА ЛОЖЬ
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		//|	И уатПутевойЛистЗадание.Контрагент = &ОсновнойКонтрагент
		|
		|СГРУППИРОВАТЬ ПО
		|	уатПутевойЛистЗадание.Ссылка.ТранспортноеСредство,
		|	уатПутевойЛистЗадание.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВыборкаПЛ.ТранспортноеСредство КАК ТранспортноеСредство,
		|	СУММА(ВыборкаПЛ.КоличествоЧасов) КАК ВсегоКоличествоЧасов
		|ПОМЕСТИТЬ ВыборкаВсего
		|ИЗ
		|	ВыборкаПЛ КАК ВыборкаПЛ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВыборкаПЛ.ТранспортноеСредство
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВыборкаПЛ.ТранспортноеСредство КАК ТранспортноеСредство,
		|	ВыборкаПЛ.КоличествоЧасов КАК КоличествоЧасов,
		|	ВыборкаПЛ.Ссылка КАК Ссылка,
		|	ВыборкаВсего.ВсегоКоличествоЧасов КАК ВсегоКоличествоЧасов,
		|	ВыборкаПЛ.КоличествоЧасовТест КАК КоличествоЧасовТест
		|ИЗ
		|	ВыборкаПЛ КАК ВыборкаПЛ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВыборкаВсего КАК ВыборкаВсего
		|		ПО ВыборкаПЛ.ТранспортноеСредство = ВыборкаВсего.ТранспортноеСредство";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(ТекущийОбъект.Дата));
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецМесяца(ТекущийОбъект.Дата));
	Запрос.УстановитьПараметр("СписокТС", СписокТС);
    ОсновнаяОрганизацияМеКаМи = Справочники.Контрагенты.НайтиПоНаименованию("АО ""СП ""МеКаМинефть""",Истина);	
    //ОсновнаяОрганизацияМеКаМи = Справочники.Контрагенты.НайтиПоНаименованию("ООО ""Ситэк-Транс""",Истина);	
	
	Запрос.УстановитьПараметр("ОсновнойКонтрагент", ОсновнаяОрганизацияМеКаМи);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	Для каждого Строка из ТекущийОбъект.ТЧ Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("ТранспортноеСредство", Строка.ТС);
		СтрокиРаспределения = ТЗ.НайтиСтроки(Отбор);
		Сумма = Строка.Сумма;
		Количество = Строка.Количество;
		Если СтрокиРаспределения.Количество() = 0 Тогда
			Отказ = Истина;
			Сообщить("Нет путевых листов с заказчиком АО ""СП ""МеКаМинефть"" за данный месяц для ТС: " + Строка.ТС);
			Сообщить("Это ошибка!");
			Прервать;
		КонецЕсли;	
		Для каждого СтрокаТЗ из СтрокиРаспределения Цикл
			КолСтрокПЛ = СтрокаТЗ.Ссылка.Задание.Количество();
			Если КолСтрокПЛ = 0 Тогда
				НовСтр = ТЧ.Добавить();
				НовСтр.РасширеннаяИнформацияОЛокации = Строка.РасширеннаяИнформацияОЛокации;
				НовСтр.ТС         = Строка.ТС;
				НовСтр.Заказчик   = Строка.Заказчик;
				НовСтр.ПУ         = Строка.ПУ;
				НовСтр.ПЛ         = СтрокаТЗ.Ссылка;
				НовСтр.Сумма      = Строка.Сумма * (СтрокаТЗ.КоличествоЧасов/СтрокаТЗ.ВсегоКоличествоЧасов);
				НовСтр.Количество = Строка.Количество * (СтрокаТЗ.КоличествоЧасов/СтрокаТЗ.ВсегоКоличествоЧасов);
				Сумма = Сумма - НовСтр.Сумма;
				Количество = Количество - НовСтр.Количество;
			Иначе
				Коэф = 1 / КолСтрокПЛ;
				Для каждого СтрокаПЛ из СтрокаТЗ.Ссылка.Задание Цикл
					НовСтр = ТЧ.Добавить();
					НовСтр.ТС       = Строка.ТС;
					НовСтр.Заказчик = Строка.Заказчик;
					НовСтр.ПУ       = Строка.ПУ;
					НовСтр.ПЛ       = СтрокаТЗ.Ссылка;
					НовСтр.РасширеннаяИнформацияОЛокации = Строка.РасширеннаяИнформацияОЛокации;
					
					НовСтр.Контрагент           = Строка.Заказчик;
					НовСтр.Маршрут              = СтрокаПЛ.Маршрут;
					НовСтр.Подразделение        = СтрокаПЛ.Подразделение;
					НовСтр.ВидУслуг      = СтрокаПЛ.ВидУслуг;
					НовСтр.ОбщийУчасток  = СтрокаПЛ.ОбщийУчасток;
					
					НовСтр.Сумма      = Строка.Сумма * (СтрокаТЗ.КоличествоЧасов/СтрокаТЗ.ВсегоКоличествоЧасов) * Коэф;
					НовСтр.Количество = Строка.Количество * (СтрокаТЗ.КоличествоЧасов/СтрокаТЗ.ВсегоКоличествоЧасов) * Коэф;
					Сумма = Сумма - НовСтр.Сумма;
					Количество = Количество - НовСтр.Количество;
				КонецЦикла;	
			КонецЕсли;
			
		КонецЦикла;
		Если Сумма <> 0 или Количество <> 0 Тогда
			НовСтр.Сумма = НовСтр.Сумма + Сумма;
			НовСтр.Количество = НовСтр.Количество + Количество;
		КонецЕсли;	
	КонецЦикла;
	ТЧ.Свернуть("ТС, Заказчик, ПЛ, ПУ, Контрагент, Маршрут, Подразделение, ВидУслуг, ОбщийУчасток, РасширеннаяИнформацияОЛокации","Сумма,Количество");
	ТекущийОбъект.ТЧ_ПоПЛ.Загрузить(ТЧ);
	
КонецПроцедуры

&НаСервере
Функция ВернутьСтатусДокумента(Док)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МеКаМи_СостояниеПутевогоЛиста.СогласуемыйДокумент КАК СогласуемыйДокумент,
		|	МеКаМи_СостояниеПутевогоЛиста.Результат КАК Результат,
		|	МеКаМи_СостояниеПутевогоЛиста.РезультатЦифрой КАК РезультатЦифрой,
		|	МеКаМи_СостояниеПутевогоЛиста.Коментарий КАК Коментарий,
		|	МеКаМи_СостояниеПутевогоЛиста.Период КАК Период
		|ИЗ
		|	РегистрСведений.МеКаМи_СостояниеПутевогоЛиста КАК МеКаМи_СостояниеПутевогоЛиста
		|ГДЕ
		|	МеКаМи_СостояниеПутевогоЛиста.СогласуемыйДокумент = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
	
	Запрос.УстановитьПараметр("Ссылка", Док);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	    Возврат ВыборкаДетальныеЗаписи.Результат;
	Иначе
		Возврат "";
	КонецеСЛИ;	
		
КонецФункции	

