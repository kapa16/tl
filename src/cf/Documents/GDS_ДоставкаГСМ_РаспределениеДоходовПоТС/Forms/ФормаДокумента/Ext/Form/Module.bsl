&НаСервере
Функция ПоказатьКартинку()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МеКаМи_СтатусыВыгруженныхДокументов.ОбъектВыгрузки КАК ОбъектВыгрузки,
		|	МеКаМи_СтатусыВыгруженныхДокументов.Выгружать КАК Выгружать,
		|	МеКаМи_СтатусыВыгруженныхДокументов.Отправлен КАК Отправлен,
		|	МеКаМи_СтатусыВыгруженныхДокументов.Получен КАК Получен
		|ИЗ
		|	РегистрСведений.МеКаМи_СтатусыВыгруженныхДокументов КАК МеКаМи_СтатусыВыгруженныхДокументов
		|ГДЕ
		|	МеКаМи_СтатусыВыгруженныхДокументов.ОбъектВыгрузки = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.Выгружать = Истина и ВыборкаДетальныеЗаписи.Отправлен = Истина и ВыборкаДетальныеЗаписи.Получен = Истина Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЛОЖЬ;

КонецФункции	
