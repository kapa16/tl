
#Область ОписаниеПеременных

&НаКлиенте
Перем СтруктураДляОтправкиЗапроса;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Автотест = Истина;
		Возврат;
	КонецЕсли;
	
	Если Параметры.Свойство("ДокументСсылка") Тогда
		СсылкаНаСтраховойСертификат = Параметры.ДокументСсылка;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Автотест Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	СтруктураДляОтправкиЗапроса = Новый Структура;
	ЗаполнитьТаблицуСАтрибутами(СтруктураДляОтправкиЗапроса);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПродолжитьОформление(Команда)
	Закрыть(СтруктураДляОтправкиЗапроса);
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьТаблицуСАтрибутами(СтруктураДляОтправкиЗапроса)
	
	Если СсылкаНаСтраховойСертификат.Пустая() ИЛИ СсылкаНаСтраховойСертификат.Грузы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	НомерГенДоговора = СсылкаНаСтраховойСертификат.УчетнаяЗаписьСервисаСтрахования.НомерГенеральногоДоговора;
	НомерГенДоговораСтр = Лев(НомерГенДоговора, СтрНайти(НомерГенДоговора, "/") - 1);
	Элементы.Декорация1.Заголовок = СтрЗаменить(Элементы.Декорация1.Заголовок, "<НомерГенДоговора>", НомерГенДоговораСтр);
	
	ТекстОшибки = "";
	ТекстОшибкиСообщение = "";
	
	ТаблицаЗаказы = СсылкаНаСтраховойСертификат.Грузы.Выгрузить().Скопировать();
	ТаблицаЗаказы.Свернуть("ЗаказНаТС");
	
	ТаблицаГрузы = СсылкаНаСтраховойСертификат.Грузы.Выгрузить().Скопировать();
	ТаблицаГрузы.Свернуть("ОписаниеГруза", "ВесБрутто,КоличествоМест,СтоимостьГруза");
	
	ПроверитьЗаказазы(ТекстОшибкиСообщение);
	
	ДанныеТелоPOST = Новый Структура;
	ДанныеТелоPOST.Вставить("inputSource", "rarus");
	ДанныеТелоPOST.Вставить("policyNumber", НомерГенДоговора);
	Если ЗначениеЗаполнено(СсылкаНаСтраховойСертификат.НомерСтраховогоСертификата) Тогда
		ДанныеТелоPOST.Вставить("certificateNumber", СсылкаНаСтраховойСертификат.НомерСтраховогоСертификата);
	КонецЕсли;
	
	ДатаОтправлениеС = Формат(ТаблицаЗаказы[0].ЗаказНаТС.ОтправлениеС, "ДФ=yyyy-MM-dd");
	ДатаПрибытиеПо = Формат(ТаблицаЗаказы[0].ЗаказНаТС.ДоставкаПо, "ДФ=yyyy-MM-dd");
	
	МассивТерриторий = Новый Массив;
	ПунктОтправления = ТаблицаЗаказы[0].ЗаказНаТС.АдресОтправления;
	ПунктПрибытия = ТаблицаЗаказы[0].ЗаказНаТС.АдресНазначения;
	СтранаПунктаОтправления = ПунктОтправления.Страна;
	СтранаПунктаПрибытия = ПунктПрибытия.Страна;
	Если ЗначениеЗаполнено(СтранаПунктаОтправления) Тогда
		КодСтраныОтправления = СтранаПунктаОтправления.Код;
	Иначе
		КодСтраныОтправления = 0;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтранаПунктаПрибытия) Тогда
		КодСтраныПрибытия = СтранаПунктаПрибытия.Код;
	Иначе
		КодСтраныПрибытия = 0;
	КонецЕсли;
	
	Если КодСтраныОтправления <> КодСтраныПрибытия И (КодСтраныОтправления <> 0 Или КодСтраныПрибытия <> 0) Тогда
		МассивТерриторий.Добавить(Строка(КодСтраныОтправления));
		МассивТерриторий.Добавить(Строка(КодСтраныПрибытия));
	ИначеЕсли КодСтраныОтправления = КодСтраныПрибытия И КодСтраныОтправления <> 0 Тогда
		МассивТерриторий.Добавить(Строка(КодСтраныОтправления));
	ИначеЕсли КодСтраныОтправления <> КодСтраныПрибытия И КодСтраныОтправления = 0 Тогда
		МассивТерриторий.Добавить(Строка(КодСтраныПрибытия));
	ИначеЕсли КодСтраныОтправления <> КодСтраныПрибытия И КодСтраныПрибытия = 0 Тогда
		МассивТерриторий.Добавить(Строка(КодСтраныОтправления));
	Иначе
		ТекстОшибкиСообщение = ТекстОшибкиСообщение + НСтр("ru = 'Не заполнена Страна в пунктах назначения Заказов на ТС'; en = 'Country not filled in for destinations of Vehicle Orders'") + Символы.ПС;
	КонецЕсли;
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Дата отправления'; en = 'Departure date'");
	НоваяСтрока.ЗначениеАтрибута = ДатаОтправлениеС;
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Пункт отправления'; en = 'Departure point'");
	НоваяСтрока.ЗначениеАтрибута = ПунктОтправления.Наименование;
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Дата прибытия'; en = 'Arrival date'");
	НоваяСтрока.ЗначениеАтрибута = ДатаПрибытиеПо;
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Пункт прибытия'; en = 'Destination'");
	НоваяСтрока.ЗначениеАтрибута = ПунктПрибытия.Наименование;
	
	ДанныеОПеревозке = Новый Структура;
	ДанныеОПеревозке.Вставить("shippingDateNotEarlier", ДатаОтправлениеС);
	ДанныеОПеревозке.Вставить("deliveryDateNotLater", ДатаПрибытиеПо);
	
	ДанныеТелоPOST.Вставить("transportationTerm", ДанныеОПеревозке);
	
	ДанныеТелоPOST.Вставить("territories", МассивТерриторий);
	
	ДанныеОТипеОтправления = Новый Структура;
	ДанныеОТипеОтправления.Вставить("departurePointInformation", ПунктОтправления.Наименование);
	ДанныеОТипеОтправления.Вставить("destinationPointInformation", ПунктПрибытия.Наименование);
	
	ДанныеТелоPOST.Вставить("departureType", ДанныеОТипеОтправления);
	
	ДанныеОГрузах = Новый Массив;
	
	ДанныеТелоPOST.Вставить("cargoInformation", ДанныеОГрузах);
	
	НомерСтроки = 1;
	
	Для каждого ТекСтрокаГруз Из ТаблицаГрузы Цикл
		
		НоваяСтрока = ОтправляемыеДанные.Добавить();
		НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Груз. Строка №'; en = 'Cargo. Line No.'") + Строка(НомерСтроки);
		НоваяСтрока.ЗначениеАтрибута = НСтр("ru = 'Количество мест: '; en = 'Number of seats:'") + Строка(ТекСтрокаГруз.КоличествоМест) + "; " + 
									   НСтр("ru = 'Вес: '; en = 'Weight: '") + Строка(ТекСтрокаГруз.ВесБрутто) + "; " + 
									   НСтр("ru = 'Описание груза: '; en = 'Cargo description:'") + Строка(ТекСтрокаГруз.ОписаниеГруза);
		НомерСтроки = НомерСтроки + 1;
		
		ДанныеОГрузе = Новый Структура;
		ДанныеОГрузе.Вставить("numberOfSeats", ТекСтрокаГруз.КоличествоМест);
		ДанныеОГрузе.Вставить("weight", ТекСтрокаГруз.ВесБрутто);
		ДанныеОГрузе.Вставить("cargoName", ТекСтрокаГруз.ОписаниеГруза);
		ДанныеОГрузах.Добавить(ДанныеОГрузе);
		
		Если ТекСтрокаГруз.КоличествоМест - Окр(ТекСтрокаГруз.КоличествоМест) <> 0 Тогда
			ТекстОшибкиСообщение = ТекстОшибкиСообщение + НСтр("ru = 'Колонка ""Количество мест"" на вкладке ""Грузы"" должна быть заполнена целыми числами'; en = 'The ""Number of pieces"" column on the ""Cargo"" tab must be filled with whole numbers.'") + Символы.ПС;
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеТелоPOST.Вставить("cargoInformation", ДанныеОГрузах);
	
	ДанныеОСуммеСтрахования = Новый Структура;
	ДанныеОСуммеСтрахования.Вставить("transportationSumInsured", ТаблицаГрузы.Итог("СтоимостьГруза"));
	
	ДанныеТелоPOST.Вставить("sumInsuredAndLimits", ДанныеОСуммеСтрахования);
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Сумма страхования'; en = 'Insurance amount'");
	НоваяСтрока.ЗначениеАтрибута = ТаблицаГрузы.Итог("СтоимостьГруза");
	
	ДанныеОТранспортировке = Новый Структура;
	ДанныеОТипеТранспортировки = Новый Массив;
	ТаблицаДанныхОТипеТранспортировки = Новый ТаблицаЗначений;
	ТаблицаДанныхОТипеТранспортировки.Колонки.Добавить("ВидТСДляСтрахования");
	Для каждого ТекСтрокаЗаказа Из ТаблицаЗаказы Цикл
		НоваяСтрока = ТаблицаДанныхОТипеТранспортировки.Добавить();
		НоваяСтрока.ВидТСДляСтрахования = ТекСтрокаЗаказа.ЗаказНаТС.ВидПеревозки.ВидТСДляСтрахования;
	КонецЦикла;
	
	ТаблицаДанныхОТипеТранспортировки.Свернуть("ВидТСДляСтрахования");
	МассивПустыхСтрок = Новый Массив;
	Для каждого ТекДанныеОТипеТранспортировки Из ТаблицаДанныхОТипеТранспортировки Цикл
		Если Не ЗначениеЗаполнено(ТекДанныеОТипеТранспортировки.ВидТСДляСтрахования) Тогда
			МассивПустыхСтрок.Добавить(ТекДанныеОТипеТранспортировки);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекПустаяСтрока Из МассивПустыхСтрок Цикл
		ТаблицаДанныхОТипеТранспортировки.Удалить(ТекПустаяСтрока);
	КонецЦикла;
	
	Если ТаблицаДанныхОТипеТранспортировки.Количество() <> 0 Тогда
		Для каждого ТекДанныеОТипеТранспортировки Из ТаблицаДанныхОТипеТранспортировки Цикл
			ВидТСДляСтрахованияВСОГАЗ = ПолучитьВидТСДляСтрахования(ТекДанныеОТипеТранспортировки.ВидТСДляСтрахования);
			Если ВидТСДляСтрахованияВСОГАЗ = 1 Тогда
				ТекстОшибкиСообщение = ТекстОшибкиСообщение + НСтр("ru = 'Не заполнен реквизит ""Вид ТС для страхования"" в справочнике ""Вид перевозки""'; en = 'The ""Vehicle type for insurance"" field in the ""Type of transportation"" directory is not filled in.'") + Символы.ПС;
			КонецЕсли;
			
			НоваяСтрока = ОтправляемыеДанные.Добавить();
			НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Вид ТС для страхования'; en = 'Vehicle type for insurance'");
			НоваяСтрока.ЗначениеАтрибута = ПолучитьВидТСДляСтрахования(ТекДанныеОТипеТранспортировки.ВидТСДляСтрахования);
			
			ДанныеОТипеТранспортировки.Добавить(ПолучитьВидТСДляСтрахования(ТекДанныеОТипеТранспортировки.ВидТСДляСтрахования));
			
		КонецЦикла;
	Иначе
		ТекстОшибкиСообщение = ТекстОшибкиСообщение + НСтр("ru = 'Не заполнен ""Вид ТС для страхования"" в справочнике ""Вид перевозки""'; en = 'The ""Vehicle type for insurance"" field is not filled in the ""Type of transportation"" directory.'") + Символы.ПС;
	КонецЕсли;
	
	ДанныеОТранспортировке.Вставить("transportType", ДанныеОТипеТранспортировки);
	
	ДанныеТелоPOST.Вставить("transportInformation", ДанныеОТранспортировке);
	
	ДанныеОДокументахДоставки = Новый Массив;
	
	НомерСтроки = 1;
	Для каждого ТекСтрокаДокументовпоПеревозке Из СсылкаНаСтраховойСертификат.ДокументыПоПеревозке Цикл
		
		НоваяСтрока = ОтправляемыеДанные.Добавить();
		НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Документы по перевозке. Строка №'; en = 'Shipping documents. Line No.'") + Строка(НомерСтроки);
		НоваяСтрока.ЗначениеАтрибута = ТекСтрокаДокументовпоПеревозке.ТипДокумента + "; " +
		ТекСтрокаДокументовпоПеревозке.Номер + "; " + Формат(ТекСтрокаДокументовпоПеревозке.Дата, "ДФ=yyyy-MM-dd") + "; " +
		ТекСтрокаДокументовпоПеревозке.ОписаниеТипаДокумента + ". ";
		НомерСтроки = НомерСтроки + 1;
		
		ДанныеОДокументеДоставки = Новый Структура;
		ДанныеОДокументеДоставки.Вставить("documentType", ТекСтрокаДокументовпоПеревозке.ТипДокумента);
		ДанныеОДокументеДоставки.Вставить("documentNumber", ТекСтрокаДокументовпоПеревозке.Номер);
		ДанныеОДокументеДоставки.Вставить("documentDate", Формат(ТекСтрокаДокументовпоПеревозке.Дата, "ДФ=yyyy-MM-dd"));
		ДанныеОДокументеДоставки.Вставить("specifyDocument", ТекСтрокаДокументовпоПеревозке.ОписаниеТипаДокумента);
		
		ДанныеОДокументахДоставки.Добавить(ДанныеОДокументеДоставки);
		
	КонецЦикла;
	
	ДанныеТелоPOST.Вставить("shippingDocuments", ДанныеОДокументахДоставки);
	
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Создавать счет на оплату поставщика'; en = 'Create an invoice for payment to a supplier'");
	НоваяСтрока.ЗначениеАтрибута = Строка(СсылкаНаСтраховойСертификат.УчетнаяЗаписьСервисаСтрахования.СоздаватьСчетНаОплатуПоставщика);
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Особые условия'; en = 'Special conditions'");
	НоваяСтрока.ЗначениеАтрибута = Строка(СсылкаНаСтраховойСертификат.ОсобыеУсловия);
	
	НоваяСтрока = ОтправляемыеДанные.Добавить();
	НоваяСтрока.НаименованиеАтрибута = НСтр("ru = 'Комментарий менеджеру для особых условий'; en = 'Comment to the manager for special conditions'");
	НоваяСтрока.ЗначениеАтрибута = ?(СсылкаНаСтраховойСертификат.ОсобыеУсловия, СсылкаНаСтраховойСертификат.Комментарий, "");
	
	
	ДанныеТелоPOST.Вставить("invoiceRequired", СсылкаНаСтраховойСертификат.УчетнаяЗаписьСервисаСтрахования.СоздаватьСчетНаОплатуПоставщика);
	ДанныеТелоPOST.Вставить("needOtherConditions", СсылкаНаСтраховойСертификат.ОсобыеУсловия);
	ДанныеТелоPOST.Вставить("comment", ?(СсылкаНаСтраховойСертификат.ОсобыеУсловия, СсылкаНаСтраховойСертификат.Комментарий, ""));
	
	СтруктураДляОтправкиЗапроса.Вставить("data", ДанныеТелоPOST);
	
	Если ЗначениеЗаполнено(ТекстОшибкиСообщение) Тогда
		ТекстОшибкиСообщение = Лев(ТекстОшибкиСообщение, СтрДлина(ТекстОшибкиСообщение) - 1);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибкиСообщение);
		Элементы.Продолжить.Доступность = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.Продолжить.Доступность = Истина;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Истина);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, СтруктураДляОтправкиЗапроса);
	СтруктураДляОтправкиЗапроса = ЗаписьJSON.Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаказазы(ТекстОшибки = "")
	
	ТаблицаЗаказы = СсылкаНаСтраховойСертификат.Грузы.Выгрузить().Скопировать();
	ТаблицаЗаказы.Свернуть("ЗаказНаТС");
	
	ТаблицаПунктыНазначения = Новый ТаблицаЗначений;
	ТаблицаПунктыНазначения.Колонки.Добавить("АдресОтправления");
	ТаблицаПунктыНазначения.Колонки.Добавить("АдресНазначения");
	
	ТаблицаДатыОтправленияИПрибытия = Новый ТаблицаЗначений;
	ТаблицаДатыОтправленияИПрибытия.Колонки.Добавить("ОтправлениеС");
	ТаблицаДатыОтправленияИПрибытия.Колонки.Добавить("ПрибытиеПо");
	
	Для каждого ТекСтрокаЗаказы Из ТаблицаЗаказы Цикл
		
		НоваяСтрока = ТаблицаПунктыНазначения.Добавить();
		НоваяСтрока.АдресОтправления = ТекСтрокаЗаказы.ЗаказНаТС.АдресОтправления;
		НоваяСтрока.АдресНазначения = ТекСтрокаЗаказы.ЗаказНаТС.АдресНазначения;
		
		НоваяСтрока = ТаблицаДатыОтправленияИПрибытия.Добавить();
		НоваяСтрока.ОтправлениеС = ТекСтрокаЗаказы.ЗаказНаТС.ОтправлениеС;
		НоваяСтрока.ПрибытиеПо = ТекСтрокаЗаказы.ЗаказНаТС.ДоставкаПо;
		
	КонецЦикла;
	
	ТаблицаПунктыНазначения.Свернуть("АдресОтправления, АдресНазначения");
	ТаблицаДатыОтправленияИПрибытия.Свернуть("ОтправлениеС, ПрибытиеПо");
	
	Если ТаблицаПунктыНазначения.Количество() > 1  Тогда
		
		ТекстОшибки = НСтр("ru = 'В Заказах на ТС на вкладке ""Грузы"" указаны разные пункты назначения'; en = 'In Vehicle Orders, the ""Cargo"" tab shows different destinations'") + Символы.ПС;
		
	КонецЕсли;
	
	Если ТаблицаДатыОтправленияИПрибытия.Количество() > 1  Тогда
		
		ТекстОшибки = ТекстОшибки + НСтр("ru = 'В Заказах на ТС на вкладке ""Грузы"" указаны разные временные окна'; en = 'In Vehicle Orders, the ""Cargo"" tab shows different time windows'") + Символы.ПС;
	ИначеЕсли ТаблицаДатыОтправленияИПрибытия.Количество() > 0 Тогда
		
		Если НачалоДня(ТаблицаДатыОтправленияИПрибытия[0].ОтправлениеС) + 172800 < НачалоДня(ТекущаяДатаСеанса()) Тогда
			
			ТекстОшибки = ТекстОшибки + НСтр("ru = 'Дата начала отгрузки (%1) не может быть ранее дня, предшествующего дате создания Сертификата (%2).'; en = 'The shipment start date (%1) cannot be earlier than the day before the Certificate creation date (%2).'") + Символы.ПС;
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%1", ТаблицаДатыОтправленияИПрибытия[0].ОтправлениеС);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%2", НачалоДня(ТекущаяДатаСеанса()));
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВидТСДляСтрахования(ВидТСДляСтрахования)
	
	Макет = Документы.уатСтраховойСертификат_уэ.ПолучитьМакет("СоответствиеИмениАтрибутов");
	
	ТабЗначений = Новый ТаблицаЗначений;
	
	ПоследняяСтрока = Макет.ВысотаТаблицы;
	ПоследняяКолонка = Макет.ШиринаТаблицы;
	
	ОбластьЯчеек = Макет.Область(1, 1, ПоследняяСтрока, ПоследняяКолонка);
	ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);
	ПостроительОтчета = Новый ПостроительОтчета;
	ПостроительОтчета.ИсточникДанных = ИсточникДанных;
	ПостроительОтчета.Выполнить();
	
	ТабЗначений = ПостроительОтчета.Результат.Выгрузить();
	
	ВидТСДляСтрахованияВСОГАЗ = ТабЗначений.Найти(Строка(ВидТСДляСтрахования), "НаименованиеВБазе");
	
	Если ВидТСДляСтрахованияВСОГАЗ <> Неопределено Тогда
		Возврат ВидТСДляСтрахованияВСОГАЗ.НаименованиеВСистемеСОГАЗ;
	Иначе
		Возврат 1;
	КонецЕсли;
	
КонецФункции

#КонецОбласти
