&НаКлиенте
Процедура ОформитьСертификат(Команда)
	
	Если Объект.Грузы.Количество() = 0 Тогда
		
		ТекстНСтр = НСтр("ru = 'В табличной части ""Грузы"" не введено ни одной строки'; en = 'There are no rows entered in the ""Cargo"" table section.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат;
		
	КонецЕсли;
	
	Если Модифицированность Или Объект.Ссылка.Пустая() Тогда
		ТекстНСТР = НСтр("en='To perform this operation it is necessary to record the document. Continue?';ru='Для выполнения данной операции необходимо записать документ. Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ОформитьСертификатЗаписать", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ОКОтмена, , КодВозвратаДиалога.ОК);
		Возврат;
	КонецЕсли;
	ОписаниеОповещения = Новый ОписаниеОповещения("ОформитьСертификатЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.уатСтраховойСертификат_уэ.Форма.ФормаПодтвержденияФормированияСертификата", 
		Новый Структура("ДокументСсылка", Объект.Ссылка),,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОформитьСертификатЗаписать(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		Записать(Новый Структура("НеПересчитыватьИтоги", Истина));
	Исключение
		Возврат;
	КонецПопытки;
	Если Модифицированность Тогда
		ТекстОшибки = НСтр("ru = 'Документ не был записан'; en = 'The document was not recorded'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОформитьСертификатЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.уатСтраховойСертификат_уэ.Форма.ФормаПодтвержденияФормированияСертификата", 
		Новый Структура("ДокументСсылка", Объект.Ссылка),,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОформитьСертификатЗавершение(Результат, ДопПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	ОформитьСертификатНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ОформитьСертификатНаСервере(СтруктураДляОтправкиЗапроса)
	
	ТекстОшибки = "";
	ТекстОшибкиСообщение = "";
	
	ТаблицаЗаказы = Объект.Грузы.Выгрузить().Скопировать();
	ТаблицаЗаказы.Свернуть("ЗаказНаТС");
	
	ТаблицаГрузы = Объект.Грузы.Выгрузить().Скопировать();
	ТаблицаГрузы.Свернуть("ОписаниеГруза", "ВесБрутто,КоличествоМест,СтоимостьГруза");
	
	ПроверитьЗаказазы(ТекстОшибки);
	
	Если ТекстОшибки <> "" Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	Логин = Объект.УчетнаяЗаписьСервисаСтрахования.Логин;
	Пароль = Объект.УчетнаяЗаписьСервисаСтрахования.Пароль;
	ГенеральныйДоговор = Объект.УчетнаяЗаписьСервисаСтрахования.НомерГенеральногоДоговора;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
	
	Попытка
		ВнутреннийХешИнтеграции = уатЗащищенныеФункцииСервер.ЗаполнитьВнутреннийКлючИнтеграции(Объект.УчетнаяЗаписьСервисаСтрахования, 
		Заголовки);
	Исключение
		ВнутреннийХешИнтеграции = "";
	КонецПопытки;
	
	Если Объект.УчетнаяЗаписьСервисаСтрахования.ИспользоватьТестовыйКонтур Тогда
		ТелоPOST = СтрШаблон("grant_type=password&username=%1&password=%2&scope=adinsure&client_secret=EF69597F-86BA-42FE-8A73-E044075F3FAE&client_id=sogaz-external-api",
			Объект.УчетнаяЗаписьСервисаСтрахования.Логин, Объект.УчетнаяЗаписьСервисаСтрахования.Пароль);
	Иначе
		ТелоPOST = СтрШаблон("grant_type=password&username=%1&password=%2&scope=adinsure&client_secret=3F6E0053-EB99-4F8F-B8E0-5F698EE9A3F7&client_id=sogaz-external-api",
			Объект.УчетнаяЗаписьСервисаСтрахования.Логин, Объект.УчетнаяЗаписьСервисаСтрахования.Пароль);
	КонецЕсли;
	
	АдресСервиса = АдресСервисаСтрахования();
	ПолныйАдресРесурса = "https://" + АдресСервиса + "/cargo/login";
	ТекстОшибки = "";
	
	HTTPОтвет = уатЗащищенныеФункцииСервер.ВыполнитьHTTPЗапрос(ПолныйАдресРесурса,
			"Сервис страхования. СОГАЗ", ТекстОшибки,, ТелоPOST, Заголовки,, Ложь);
	
	Если ЗначениеЗаполнено(ТекстОшибки) 
		ИЛИ HTTPОтвет = Неопределено Тогда
		СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке авторизации (см. журнал регистрации).'; en = 'Error while attempting authorization (see registration log).'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
		СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке авторизации'; en = 'Error while attempting authorization'") + Символы.ПС 
			+ ТекстОшибки;
		ЗаписьЖурналаРегистрации(
		"Сервис страхования. СОГАЗ",
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.ОбщиеМодули.уатЗащищенныеФункцииСервер_проф,
		,
		СтрокаТекстаОшибки
		);
		Возврат;
	КонецЕсли;
	
	Попытка
		уатЗащищенныеФункцииСервер.ОбновитьВнутреннийКлючИнтеграции(Объект.УчетнаяЗаписьСервисаСтрахования, 
		HTTPОтвет.Заголовки, ВнутреннийХешИнтеграции);
	Исключение
	КонецПопытки;
		
	КодСостояния = HTTPОтвет.КодСостояния;
	ResponseText = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	Если КодСостояния = 200 Тогда
		Если ЗначениеЗаполнено(ResponseText) Тогда
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(ResponseText);
			Response = ПрочитатьJSON(ЧтениеJSON, Истина);
			ЧтениеJSON.Закрыть();
			
			ДанныеЗапроса = Response;
			
			ТокенАвторизации = ДанныеЗапроса.Получить("access_token");
		КонецЕсли;
	Иначе
		СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке авторизации (см. журнал регистрации).'; en = 'Error while attempting authorization (see registration log).'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
		СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке авторизации'; en = 'Error while attempting authorization'") + Символы.ПС 
			+ HTTPОтвет.ПолучитьТелоКакСтроку();
		ЗаписьЖурналаРегистрации(
		"Сервис страхования. СОГАЗ",
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.ОбщиеМодули.уатЗащищенныеФункцииСервер_проф,
		,
		СтрокаТекстаОшибки
		);
		Возврат;
	КонецЕсли;
	
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	
	АдресСервиса = АдресСервисаСтрахования();
	ПолныйАдресРесурса = "https://" + АдресСервиса + "/cargo/CreateCGInsuranceCertificate";
	
	HTTPОтвет = уатЗащищенныеФункцииСервер.ВыполнитьHTTPЗапрос(ПолныйАдресРесурса,
			"Сервис страхования. СОГАЗ", ТекстОшибки,, СтруктураДляОтправкиЗапроса, Заголовки,, Ложь);
	
	Если ЗначениеЗаполнено(ТекстОшибки) 
		ИЛИ HTTPОтвет = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КодСостояния = HTTPОтвет.КодСостояния;
	ResponseText = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	Если КодСостояния = 200 Тогда
		Если ЗначениеЗаполнено(ResponseText) Тогда
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(ResponseText);
			Response = ПрочитатьJSON(ЧтениеJSON, Истина);
			ЧтениеJSON.Закрыть();
			
			ДанныеЗапроса = Response;
			
			ОбщиеДанныеСертификата = ДанныеЗапроса.Получить("data");
			МассивОшибок = ОбщиеДанныеСертификата.Получить("errors");
			Если МассивОшибок.Количество() > 0 Тогда
				КритическаяОшибка = Ложь;
				Для каждого ТекОшибка Из МассивОшибок Цикл
					ТекстОшибкиСообщение = ТекстОшибкиСообщение + ТекОшибка.Получить("message") + Символы.ПС;
					Если ТекОшибка.Получить("isCritical") Тогда
						КритическаяОшибка = Истина;
					КонецЕсли;
				КонецЦикла;
				ТекстОшибкиСообщение = Лев(ТекстОшибкиСообщение, СтрДлина(ТекстОшибкиСообщение) - 1);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибкиСообщение);
				Если КритическаяОшибка Тогда
					Возврат;
				КонецЕсли;
			КонецЕсли;
			КодФормированияСертификата = ОбщиеДанныеСертификата.Получить("code");
			Если КодФормированияСертификата <> "OK" Тогда
				ТекстОшибкиСообщение = НСтр("ru = 'Ошибка при формировании страхового сертифката. Код формирования отчета: %1'; en = 'An error occurred while generating the insurance certificate. Report generation code: %1'");
				ТекстОшибкиСообщение = СтрЗаменить(ТекстОшибкиСообщение, "%1", КодФормированияСертификата);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибкиСообщение);
				Возврат;
			КонецЕсли;
			
			Модифицированность = Истина;
			
			Если Объект.ОсобыеУсловия Тогда
				Объект.НомерСтраховогоСертификата = ОбщиеДанныеСертификата.Получить("certificate").Получить("documentNumber");
				ТекстСообщения = ОбщиеДанныеСертификата.Получить("errors")[0].Получить("message");
				Возврат;
			КонецЕсли;
			
			Если ОбщиеДанныеСертификата.Получить("certificateData") = Неопределено Тогда
				Возврат;
			КонецЕсли;
			
			Объект.НомерСтраховогоСертификата = ОбщиеДанныеСертификата.Получить("certificateData").Получить("policyNumber");
			ДатаСтраховогоСертификатаСтрока = ОбщиеДанныеСертификата.Получить("certificateData").Получить("issueDate");
			ДатаСтраховогоСертификатаСтрокаГод = Сред(ДатаСтраховогоСертификатаСтрока, 0, 4);
			ДатаСтраховогоСертификатаСтрокаМесяц = Сред(ДатаСтраховогоСертификатаСтрока, 6, 2);
			ДатаСтраховогоСертификатаСтрокаДень = Сред(ДатаСтраховогоСертификатаСтрока, 9, 2);
			Объект.ДатаСтраховогоСертификата = Дата(ДатаСтраховогоСертификатаСтрокаГод + ДатаСтраховогоСертификатаСтрокаМесяц + ДатаСтраховогоСертификатаСтрокаДень);
			Объект.IDСертификата = ОбщиеДанныеСертификата.Получить("certificate").Получить("id");
			
			Объект.РеквизитыСертификатаПоставщика.Очистить();
			
			Для каждого ТекПолученноеПоле Из ОбщиеДанныеСертификата.Получить("certificateData") Цикл
				Если (ТекПолученноеПоле.Ключ <> "insurancePremiumOrder" И ТипЗнч(ТекПолученноеПоле.Значение) <> Тип("Строка") И ТипЗнч(ТекПолученноеПоле.Значение) <> Тип("Число"))
					Или (ТекПолученноеПоле.Ключ = "id" Или ТекПолученноеПоле.Ключ = "policyNumber" Или ТекПолученноеПоле.Ключ = "issueDate") Тогда
					Продолжить;
				КонецЕсли;
				Если ТекПолученноеПоле.Ключ = "insurancePremiumOrder" Тогда
					Для каждого ТекДанныеОПремииСтрахования Из ТекПолученноеПоле.Значение Цикл
						НайденноеНазваниеПоляВСистеме = ПолучитьНазваниеПоляВСистеме(ТекДанныеОПремииСтрахования.Ключ);
						НоваяСтрока = Объект.РеквизитыСертификатаПоставщика.Добавить();
						НоваяСтрока.РеквизитПоставщика = НайденноеНазваниеПоляВСистеме;
						НоваяСтрока.ЗначениеРеквизитаПоставщика = ТекДанныеОПремииСтрахования.Значение;
					КонецЦикла;
					Продолжить;
				КонецЕсли;
				НайденноеНазваниеПоляВСистеме = ПолучитьНазваниеПоляВСистеме(ТекПолученноеПоле.Ключ);
				НоваяСтрока = Объект.РеквизитыСертификатаПоставщика.Добавить();
				НоваяСтрока.РеквизитПоставщика = НайденноеНазваниеПоляВСистеме;
				НоваяСтрока.ЗначениеРеквизитаПоставщика = ТекПолученноеПоле.Значение;
			КонецЦикла;
			
			ПремияСтрахования = 0;
			УслугаДляСтраховойПремии = Объект.УчетнаяЗаписьСервисаСтрахования.Услуга;
			
			Попытка
				ПремияСтрахования = ОбщиеДанныеСертификата.Получить("certificateData").Получить("insurancePremium");
			Исключение
			КонецПопытки;
			
			Если ЗначениеЗаполнено(ПремияСтрахования) И ЗначениеЗаполнено(УслугаДляСтраховойПремии) Тогда
				НайденныеСтроки = Объект.Расходы.НайтиСтроки(Новый Структура("Номенклатура", УслугаДляСтраховойПремии));
				Если НайденныеСтроки.Количество() > 0 Тогда
					НайденныеСтроки[0].Номенклатура = УслугаДляСтраховойПремии;
					НайденныеСтроки[0].Сумма = ПремияСтрахования;
					Если ТаблицаЗаказы.Количество() = 1 Тогда
						НайденныеСтроки[0].ЗаказНаТС = ТаблицаЗаказы[0].ЗаказНаТС;
					КонецЕсли;
				Иначе
					НоваяСтрока = Объект.Расходы.Добавить();
					НоваяСтрока.Номенклатура = УслугаДляСтраховойПремии;
					НоваяСтрока.Сумма = ПремияСтрахования;
					НоваяСтрока.Количество     = 1;
					НоваяСтрока.СтатьяРасходов = ПредопределенноеЗначение("Справочник.уатСтатьиРасходов.ОсновнаяСтатьяРасходов");
					НоваяСтрока.СтавкаНДС      = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
					ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяСтавкаНДС");
					
					НоваяСтрока.Валюта      = мВалютаРегламентированногоУчета;
					
					Если ТаблицаЗаказы.Количество() = 1 Тогда
						НоваяСтрока.ЗаказНаТС = ТаблицаЗаказы[0].ЗаказНаТС;
					КонецЕсли;
					
				КонецЕсли;
				
				СписокЗаказы = Новый СписокЗначений;
				
				Для Каждого ТекСтрока Из Объект.Грузы Цикл
					Если ЗначениеЗаполнено(ТекСтрока.ЗаказНаТС)
						И СписокЗаказы.НайтиПоЗначению(ТекСтрока.ЗаказНаТС) = Неопределено Тогда
						СписокЗаказы.Добавить(ТекСтрока.ЗаказНаТС);
					КонецЕсли;
				КонецЦикла;
				
				мсвПараметрыВыбора = Новый Массив();
				мсвПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", СписокЗаказы));
				Элементы.РасходыЗаказНаТС.ПараметрыВыбора = Новый ФиксированныйМассив(мсвПараметрыВыбора);
				
				ОбновитьПараметрВыработкиВременный();
				ОбновитьПодвалРасходов();
				ОбновитьВсегоВТЧРасходыСервер();
				РассчитатьСуммуДокумента();
				
			КонецЕсли;
			
			ПрикрепленныеФайлыСертифката = ОбщиеДанныеСертификата.Получить("attachments");
			IDПФСертификата = "";
			IDПФСчета = "";
			Для каждого ТекПрикрепленныйФайлСертификата Из ПрикрепленныеФайлыСертифката Цикл
				
				Если СтрНачинаетсяС(ТекПрикрепленныйФайлСертификата.Получить("fileName"), "Страховой сертификат") Тогда
					IDПФСертификата = ТекПрикрепленныйФайлСертификата.Получить("id");
				КонецЕсли;
				
				Если СтрНачинаетсяС(ТекПрикрепленныйФайлСертификата.Получить("fileName"), "Счет на оплату") Тогда
					IDПФСчета = ТекПрикрепленныйФайлСертификата.Получить("id");
				КонецЕсли;
				
			КонецЦикла;
			
			Если ЗначениеЗаполнено(IDПФСертификата) Тогда
				
				Заголовки = Новый Соответствие;
				Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
				
				АдресСервиса = АдресСервисаСтрахования();
				ПолныйАдресРесурса = "https://" + АдресСервиса + "/cargo/GetAttachment/" + IDПФСертификата;
				ТекстОшибки = "";
				
				HTTPОтвет = уатЗащищенныеФункцииСервер.ВыполнитьHTTPЗапрос(ПолныйАдресРесурса,
				"Сервис страхования. СОГАЗ", ТекстОшибки,,, Заголовки,, Ложь);
				
				Если ЗначениеЗаполнено(ТекстОшибки) 
					ИЛИ HTTPОтвет = Неопределено Тогда
					СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке получения печатной формы страхового сертификата(см. журнал регистрации).'; en = 'An error occurred while attempting to obtain a printed form of the insurance certificate (see registration log).'");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
					СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке получения печатной формы страхового сертификата'; en = 'An error occurred while attempting to obtain a printed form of the insurance certificate.'") + Символы.ПС 
					+ ТекстОшибки;
					ЗаписьЖурналаРегистрации(
					"Сервис страхования. СОГАЗ",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.ОбщиеМодули.уатЗащищенныеФункцииСервер_проф,
					,
					СтрокаТекстаОшибки
					);
					Возврат;
				КонецЕсли;
				
				КодСостояния = HTTPОтвет.КодСостояния;
				ДвоичныеДанные = HTTPОтвет.ПолучитьТелоКакДвоичныеДанные();
				
				Если КодСостояния = 200 Тогда
					
					НаименованиеФайла = НСтр("ru = 'ПФ_СтраховойСертификат_'; en = 'PF_InsuranceCertificate_'") + Объект.НомерСтраховогоСертификата;
					ПрисоединенныйФайлСтраховойСертификат = ПолучитьПрисоединенныйФайлСтраховойСертификат(Объект.Ссылка, НаименованиеФайла);
					
					ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
					
					ПараметрыФайла = Новый Структура;
					ПараметрыФайла.Вставить("Автор", Пользователи.АвторизованныйПользователь());
					ПараметрыФайла.Вставить("ВладелецФайлов", Объект.Ссылка);
					ПараметрыФайла.Вставить("ИмяБезРасширения", НаименованиеФайла);
					ПараметрыФайла.Вставить("РасширениеБезТочки", "pdf");
					ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяДата());
					
					Если ПрисоединенныйФайлСтраховойСертификат <> Неопределено Тогда
						ПараметрыФайла.Вставить("АдресФайлаВоВременномХранилище", ПутьВоВременномХранилище);
						ПараметрыФайла.Вставить("АдресВременногоХранилищаТекста", "");
						РаботаСФайлами.ОбновитьФайл(ПрисоединенныйФайлСтраховойСертификат, ПараметрыФайла);
					Иначе
						ДобавленныйФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ПутьВоВременномХранилище);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если Объект.УчетнаяЗаписьСервисаСтрахования.СоздаватьСчетНаОплатуПоставщика Тогда
				
				ДанныеНакладной = ОбщиеДанныеСертификата.Получить("invoiceData");
				ДатаНакладнойСтрока = ДанныеНакладной.Получить("invoiceDate");
				ДатаНакладнойСтрокаГод = Сред(ДатаНакладнойСтрока, 0, 4);
				ДатаНакладнойСтрокаМесяц = Сред(ДатаНакладнойСтрока, 6, 2);
				ДатаНакладнойСтрокаДень = Сред(ДатаНакладнойСтрока, 9, 2);
				ДатаДляЗаполненияИзИнтеграции = Дата(ДатаНакладнойСтрокаГод + ДатаНакладнойСтрокаМесяц + ДатаНакладнойСтрокаДень);
				
				//БИКДляЗаполненияИзИнтеграции = ДанныеНакладной.Получить("bankDetails").Получить("bik");
				//СтруктураДляЗаполнения = Новый Структура("ЗаполнениеПоИнтеграции", Истина);
				//СтруктураДляЗаполнения.Вставить("ДатаДляЗаполненияИзИнтеграции", ДатаДляЗаполненияИзИнтеграции);
				//СтруктураДляЗаполнения.Вставить("БИКДляЗаполненияИзИнтеграции", БИКДляЗаполненияИзИнтеграции);
				//СтруктураДляЗаполнения.Вставить("ДанныеДляЗаполненияСертификат", Объект.Ссылка);
				
				Попытка
					Записать(Новый Структура("НеПересчитыватьИтоги", Истина));
				Исключение
					Возврат;
				КонецПопытки;
				
				СчетНаОплатуПоставщикаОбъект = Документы.уатСчетНаОплатуПоставщика.СоздатьДокумент();
				СчетНаОплатуПоставщикаОбъект.Заполнить(Объект.Ссылка);
				СчетНаОплатуПоставщикаОбъект.Дата = ДатаДляЗаполненияИзИнтеграции;
				
				СчетНаОплатуПоставщикаОбъект.ПроверитьЗаполнение();
				
				Попытка
					СчетНаОплатуПоставщикаОбъект.Записать(РежимЗаписиДокумента.Запись);
				Исключение
					СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при записи Счета на оплату поставщику (см. журнал регистрации)'; en = 'Error when recording the Invoice for payment to the supplier (see the registration log)'");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
					СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при проведении Счета на оплату поставщику'; en = 'Error when posting an invoice to a supplier'") + Символы.ПС 
					+ ОписаниеОшибки();
					ЗаписьЖурналаРегистрации(
					"Сервис страхования. СОГАЗ",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.ОбщиеМодули.уатЗащищенныеФункцииСервер_проф,
					,
					СтрокаТекстаОшибки
					);
					Возврат;
				КонецПопытки;
				
				Если СчетНаОплатуПоставщикаОбъект.Ссылка.Пустая() Тогда
					СтрокаТекстаОшибки = НСтр("ru = 'Счета на оплату поставщику не был создан'; en = 'The supplier invoice was not created.'");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
					Возврат;
				КонецЕсли;
				
				ТекстСообщения = НСтр("ru = 'Был создан Счет на оплату поставщика: %1'; en = 'A Supplier Invoice has been created: %1'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", СчетНаОплатуПоставщикаОбъект.Ссылка);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				
				Если ЗначениеЗаполнено(IDПФСчета) Тогда
					
					Заголовки = Новый Соответствие;
					Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
					
					АдресСервиса = АдресСервисаСтрахования();
					ПолныйАдресРесурса = "https://" + АдресСервиса + "/cargo/GetAttachment/" + IDПФСчета;
					ТекстОшибки = "";
					
					HTTPОтвет = уатЗащищенныеФункцииСервер.ВыполнитьHTTPЗапрос(ПолныйАдресРесурса,
					"Сервис страхования. СОГАЗ", ТекстОшибки,,, Заголовки,, Ложь);
					
					Если ЗначениеЗаполнено(ТекстОшибки) 
						ИЛИ HTTPОтвет = Неопределено Тогда
						СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке получения печатной формы страхового сертификата(см. журнал регистрации).'; en = 'An error occurred while attempting to obtain a printed form of the insurance certificate (see registration log).'");
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаТекстаОшибки);
						СтрокаТекстаОшибки = НСтр("ru = 'Ошибка при попытке получения печатной формы страхового сертификата'; en = 'An error occurred while attempting to obtain a printed form of the insurance certificate.'") + Символы.ПС 
						+ ТекстОшибки;
						ЗаписьЖурналаРегистрации(
						"Сервис страхования. СОГАЗ",
						УровеньЖурналаРегистрации.Ошибка,
						Метаданные.ОбщиеМодули.уатЗащищенныеФункцииСервер_проф,
						,
						СтрокаТекстаОшибки
						);
						Возврат;
					КонецЕсли;
					
					КодСостояния = HTTPОтвет.КодСостояния;
					ДвоичныеДанные = HTTPОтвет.ПолучитьТелоКакДвоичныеДанные();
					
					Если КодСостояния = 200 Тогда
						
						НаименованиеФайла = НСтр("ru = 'ПФ_СчетНаОплатуПоставщика_'; en = 'PF_SupplierInvoice_'") + Объект.НомерСтраховогоСертификата;
						ПрисоединенныйФайлСтраховойСертификат = ПолучитьПрисоединенныйФайлСтраховойСертификат(СчетНаОплатуПоставщикаОбъект.Ссылка, НаименованиеФайла);
						
						ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
						
						ПараметрыФайла = Новый Структура;
						ПараметрыФайла.Вставить("Автор", Пользователи.АвторизованныйПользователь());
						ПараметрыФайла.Вставить("ВладелецФайлов", СчетНаОплатуПоставщикаОбъект.Ссылка);
						ПараметрыФайла.Вставить("ИмяБезРасширения", НаименованиеФайла);
						ПараметрыФайла.Вставить("РасширениеБезТочки", "pdf");
						ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяДата());
						
						Если ПрисоединенныйФайлСтраховойСертификат <> Неопределено Тогда
							ПараметрыФайла.Вставить("АдресФайлаВоВременномХранилище", ПутьВоВременномХранилище);
							ПараметрыФайла.Вставить("АдресВременногоХранилищаТекста", "");
							РаботаСФайлами.ОбновитьФайл(ПрисоединенныйФайлСтраховойСертификат, ПараметрыФайла);
						Иначе
							ДобавленныйФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ПутьВоВременномХранилище);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		Если КодСостояния = 500 Тогда
			ТекстСообщения = НСтр("ru = 'Код ошибки 500: Ошибка сервера'; en = 'Error Code 500: Server Error'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
		Если ЗначениеЗаполнено(ResponseText) Тогда
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(ResponseText);
			Response = ПрочитатьJSON(ЧтениеJSON, Истина);
			ЧтениеJSON.Закрыть();
			
			ДанныеЗапроса = Response;
			
			ОбщиеДанныеСертификата = ДанныеЗапроса.Получить("data");
			Если ОбщиеДанныеСертификата.Получить("validationErrors") <> Неопределено Тогда
				ТекстОшибкиСообщение = НСтр("ru = 'Ошибка валидации: '; en = 'Validation error:'") + ОбщиеДанныеСертификата.Получить("validationErrors")[0].Получить("message");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибкиСообщение);
				Возврат;
			КонецЕсли;
			МассивОшибок = ОбщиеДанныеСертификата.Получить("errors");
			Если МассивОшибок.Количество() > 0 Тогда
				Для каждого ТекОшибка Из МассивОшибок Цикл
					ТекстОшибкиСообщение = ТекстОшибкиСообщение + ТекОшибка.Получить("message") + Символы.ПС;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		ТекстОшибкиСообщение = Лев(ТекстОшибкиСообщение, СтрДлина(ТекстОшибкиСообщение) - 1);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибкиСообщение);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТС(Команда)
	Если Объект.ДокументыПоПеревозке.Количество() Тогда 
		ТекстНСТР = НСтр("ru = 'Очистить таблицу ""Документы по перевозке"" перед заполнением?'; en = 'Clear the ""Transportation Documents"" table before filling it out?'");
		Оповещение = Новый ОписаниеОповещения("ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСОтвет", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстНСТР, РежимДиалогаВопрос.ДаНетОтмена);
	Иначе
		ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСОтвет(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.ДокументыПоПеревозке.Очистить();
		ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСНаСервере();
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДокументыПоПеревозкеПоЗаказамНаТСНаСервере()
	
	ТаблицаГрузы = Объект.Грузы.Выгрузить();
	
	ТаблицаГрузы.Свернуть("ЗаказНаТС");
	
	Для каждого ТекСтрокаГрузы Из ТаблицаГрузы Цикл
		
		НоваяСтрока = Объект.ДокументыПоПеревозке.Добавить();
		НоваяСтрока.ТипДокумента = Элементы.ДокументыПоПеревозкеТипДокумента.СписокВыбора.НайтиПоЗначению("other").Значение;
		НоваяСтрока.Номер = ТекСтрокаГрузы.ЗаказНаТС.Номер;
		НоваяСтрока.Дата = ТекСтрокаГрузы.ЗаказНаТС.Дата;
		НоваяСтрока.ОписаниеТипаДокумента = НСтр("ru = 'Заказ на ТС'; en = 'Order for trucking'");
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

