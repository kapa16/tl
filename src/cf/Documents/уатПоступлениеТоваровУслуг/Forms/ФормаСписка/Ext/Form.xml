			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументуатПоступлениеТоваровУслуг.Ссылка КАК Ссылка,
	ДокументуатПоступлениеТоваровУслуг.ПометкаУдаления КАК ПометкаУдаления,
	ДокументуатПоступлениеТоваровУслуг.Номер КАК Номер,
	ДокументуатПоступлениеТоваровУслуг.Дата КАК Дата,
	ДокументуатПоступлениеТоваровУслуг.Проведен КАК Проведен,
	ДокументуатПоступлениеТоваровУслуг.ВалютаДокумента КАК ВалютаДокумента,
	ДокументуатПоступлениеТоваровУслуг.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	ДокументуатПоступлениеТоваровУслуг.ДатаКон КАК ДатаКон,
	ДокументуатПоступлениеТоваровУслуг.ДоговорКонтрагента КАК ДоговорКонтрагента,
	ДокументуатПоступлениеТоваровУслуг.ДокументОснование КАК ДокументОснование,
	ДокументуатПоступлениеТоваровУслуг.Комментарий КАК Комментарий,
	ДокументуатПоступлениеТоваровУслуг.Контрагент КАК Контрагент,
	ДокументуатПоступлениеТоваровУслуг.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,
	ДокументуатПоступлениеТоваровУслуг.КурсВзаиморасчетов КАК КурсВзаиморасчетов,
	ДокументуатПоступлениеТоваровУслуг.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	ДокументуатПоступлениеТоваровУслуг.Организация КАК Организация,
	ДокументуатПоступлениеТоваровУслуг.Ответственный КАК Ответственный,
	ДокументуатПоступлениеТоваровУслуг.Подразделение КАК Подразделение,
	ДокументуатПоступлениеТоваровУслуг.Склад КАК Склад,
	ДокументуатПоступлениеТоваровУслуг.СуммаВключаетНДС КАК СуммаВключаетНДС,
	ДокументуатПоступлениеТоваровУслуг.СуммаДокумента КАК СуммаДокумента,
	ДокументуатПоступлениеТоваровУслуг.УчитыватьНДС КАК УчитыватьНДС,
	ДокументуатПоступлениеТоваровУслуг.Сделка КАК Сделка,
	ДокументуатПоступлениеТоваровУслуг.ДатаНач КАК ДатаНач,
	ДокументуатПоступлениеТоваровУслуг.ОплатаПодотчетнымЛицом КАК ОплатаПодотчетнымЛицом,
	ДокументуатПоступлениеТоваровУслуг.ПодотчетноеЛицо КАК ПодотчетноеЛицо,
	ДокументуатПоступлениеТоваровУслуг.ДатаПлатежа КАК ДатаПлатежа,
	ДокументуатПоступлениеТоваровУслуг.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	ДокументуатПоступлениеТоваровУслуг.ДатаКурса КАК ДатаКурса,
	ДокументуатПоступлениеТоваровУслуг.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
	ДокументуатПоступлениеТоваровУслуг.КроссКурс КАК КроссКурс,
	ДокументуатПоступлениеТоваровУслуг.МоментВремени КАК МоментВремени,
	NULL КАК СостояниеОригиналаПервичногоДокумента,
	ИСТИНА КАК ОбщееСостояние,
	0 КАК СостояниеОригиналПолучен,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл,
	ЕСТЬNULL(ВЫБОР
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.Новый)
				ТОГДА 0
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.ЧастичноВыполнен)
				ТОГДА 2
			КОГДА уатТекущееСостояниеОплаты.Состояние = ЗНАЧЕНИЕ(Перечисление.уатСостоянияВыполненияЗаказов.Выполнен)
				ТОГДА 3
			ИНАЧЕ -1
		КОНЕЦ, -1) КАК ОплаченоСостояние,
	ВЫБОР
		КОГДА ДокументуатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС)
				ИЛИ ДокументуатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
				ИЛИ ДокументуатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
				ИЛИ ДокументуатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоДокументуАрендаТС)
			ТОГДА ЕСТЬNULL(уатТекущееСостояниеОплаты.ОплаченоПредставление, "")
		ИНАЧЕ "Не доступно"
	КОНЕЦ КАК ОплаченоПредставление,
	СогласованиеДО.Состояние КАК СогласованиеДО,
	НЕ Согласования.КоличествоСогласований ЕСТЬ NULL КАК Согласован,
	ДокументуатПоступлениеТоваровУслуг.ТребуетСогласования КАК ТребуетСогласования
ИЗ
	Документ.уатПоступлениеТоваровУслуг КАК ДокументуатПоступлениеТоваровУслуг
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументуатПоступлениеТоваровУслуг.Ссылка = НаличиеФайлов.ОбъектСФайлами
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатТекущееСостояниеОплаты КАК уатТекущееСостояниеОплаты
		ПО ДокументуатПоступлениеТоваровУслуг.Ссылка = уатТекущееСостояниеОплаты.Документ
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			СостоянияСогласованияВДокументообороте.Состояние КАК Состояние,
			СостоянияСогласованияВДокументообороте.Установил КАК Установил,
			СостоянияСогласованияВДокументообороте.ДатаУстановки КАК ДатаУстановки,
			ОбъектыИнтегрированныеС1СДокументооборотом.Объект КАК Объект
		ИЗ
			РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияСогласованияВДокументообороте КАК СостоянияСогласованияВДокументообороте
				ПО ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО = СостоянияСогласованияВДокументообороте.ИдентификаторОбъектаДО) КАК СогласованиеДО
		ПО ДокументуатПоступлениеТоваровУслуг.Ссылка = СогласованиеДО.Объект
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			тблДокумент.Ссылка КАК Документ,
			КОЛИЧЕСТВО(уатСогласование.Ссылка) КАК КоличествоСогласований
		ИЗ
			Документ.уатПотребностьВПеревозке_уэ КАК тблДокумент
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ БизнесПроцесс.уатСогласование КАК уатСогласование
				ПО тблДокумент.Ссылка = уатСогласование.Предмет
		ГДЕ
			уатСогласование.Завершен
			И (уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.Согласовано)
					ИЛИ уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.СогласованоСЗамечаниями))
			И НЕ уатСогласование.ПометкаУдаления
		
		СГРУППИРОВАТЬ ПО
			тблДокумент.Ссылка) КАК Согласования
		ПО ДокументуатПоступлениеТоваровУслуг.Ссылка = Согласования.Документ</QueryText>
