		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.СогласованиеДО</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументуатПланированиеРаботыТС.Ссылка КАК Ссылка,
	ДокументуатПланированиеРаботыТС.ПометкаУдаления КАК ПометкаУдаления,
	ДокументуатПланированиеРаботыТС.Номер КАК Номер,
	ДокументуатПланированиеРаботыТС.Дата КАК Дата,
	ДокументуатПланированиеРаботыТС.Проведен КАК Проведен,
	ДокументуатПланированиеРаботыТС.Организация КАК Организация,
	ДокументуатПланированиеРаботыТС.Сценарий КАК Сценарий,
	ДокументуатПланированиеРаботыТС.ДатаПланирования КАК ДатаПланирования,
	ДокументуатПланированиеРаботыТС.ВалютаДокумента КАК ВалютаДокумента,
	ДокументуатПланированиеРаботыТС.КратностьДокумента КАК КратностьДокумента,
	ДокументуатПланированиеРаботыТС.КурсДокумента КАК КурсДокумента,
	ДокументуатПланированиеРаботыТС.Подразделение КАК Подразделение,
	ДокументуатПланированиеРаботыТС.Ответственный КАК Ответственный,
	ДокументуатПланированиеРаботыТС.СуммаДокумента КАК СуммаДокумента,
	ДокументуатПланированиеРаботыТС.СуммаВключаетНДС КАК СуммаВключаетНДС,
	ДокументуатПланированиеРаботыТС.УчитыватьНДС КАК УчитыватьНДС,
	ДокументуатПланированиеРаботыТС.АвтоматическийРежимОбновленияИтоговыхПоказателей КАК АвтоматическийРежимОбновленияИтоговыхПоказателей,
	ДокументуатПланированиеРаботыТС.ТребуетСогласования КАК ТребуетСогласования,
	ДокументуатПланированиеРаботыТС.Комментарий КАК Комментарий,
	ДокументуатПланированиеРаботыТС.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл,
	СогласованиеДО.Состояние КАК СогласованиеДО,
	НЕ Согласование.КоличествоСогласований ЕСТЬ NULL КАК Согласован
ИЗ
	Документ.уатПланированиеРаботыТС КАК ДокументуатПланированиеРаботыТС
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументуатПланированиеРаботыТС.Ссылка = НаличиеФайлов.ОбъектСФайлами
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			СостоянияСогласованияВДокументообороте.Состояние КАК Состояние,
			СостоянияСогласованияВДокументообороте.Установил КАК Установил,
			СостоянияСогласованияВДокументообороте.ДатаУстановки КАК ДатаУстановки,
			ОбъектыИнтегрированныеС1СДокументооборотом.Объект КАК Объект
		ИЗ
			РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияСогласованияВДокументообороте КАК СостоянияСогласованияВДокументообороте
				ПО ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО = СостоянияСогласованияВДокументообороте.ИдентификаторОбъектаДО) КАК СогласованиеДО
		ПО ДокументуатПланированиеРаботыТС.Ссылка = СогласованиеДО.Объект
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			тблДокумент.Ссылка КАК Документ,
			КОЛИЧЕСТВО(уатСогласование.Ссылка) КАК КоличествоСогласований
		ИЗ
			Документ.уатПеремещениеТСиОборудования КАК тблДокумент
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ БизнесПроцесс.уатСогласование КАК уатСогласование
				ПО тблДокумент.Ссылка = уатСогласование.Предмет
		ГДЕ
			уатСогласование.Завершен
			И (уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.Согласовано)
					ИЛИ уатСогласование.РезультатСогласования = ЗНАЧЕНИЕ(Перечисление.уатРезультатыСогласования.СогласованоСЗамечаниями))
			И НЕ уатСогласование.ПометкаУдаления
		
		СГРУППИРОВАТЬ ПО
			тблДокумент.Ссылка) КАК Согласование
		ПО ДокументуатПланированиеРаботыТС.Ссылка = Согласование.Документ</QueryText>
