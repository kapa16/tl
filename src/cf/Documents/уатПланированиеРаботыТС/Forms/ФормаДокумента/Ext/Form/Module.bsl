									Если СтрокаЗамещения.ЗамещаемаяНоменклатура = ВыборкаДетальныеЗаписи.Номенклатура Тогда
										СтруктураПоискаЗамещающейРаботы = Новый Структура("ДетализацияПланирования, Колонна, Подразделение, ВидОбслуживания");
										ЗаполнитьЗначенияСвойств(СтруктураПоискаЗамещающейРаботы, СтруктураПоиска);
										СтруктураПоискаЗамещающейРаботы.Вставить("ПлановаяДатаОбслуживания", ТекДата);
										СтруктураПоискаЗамещающейРаботы.Вставить("ВидОбслуживания", СтрокаЗамещения.ЗамещающийВидОбслуживанияТС);
										Если СоставПланаПериоды.НайтиСтроки(СтруктураПоискаЗамещающейРаботы).Количество() > 0 Тогда
											// Замещающая работа найдена, записывать эту строку с номенклатурой не требуется
											ЗамещающаяРаботаНайдена = Истина;
											Прервать;
										КонецЕсли;
									КонецЕсли;
								КонецЦикла;
								Если Не ЗамещающаяРаботаНайдена Тогда
									НоваяСтрока = СоставПланаПериоды.Добавить();
									ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураПоиска);
									НоваяСтрока.ПлановаяДатаОбслуживания           = ТекДата;
									НоваяСтрока.СоставПланаПериодыСумма_Всего      = ВыборкаДетальныеЗаписи.Сумма;
									НоваяСтрока.СоставПланаПериодыКоличество_Всего = ВыборкаДетальныеЗаписи.Количество;
									НоваяСтрока.СоставПланаПериодыЦена_Всего       = ВыборкаДетальныеЗаписи.Цена;
									НоваяСтрока.СоставПланаПериодыСтавкаНДС_Всего  = ВыборкаДетальныеЗаписи.СтавкаНДС;
									НоваяСтрока.Номенклатура                       = ВыборкаДетальныеЗаписи.Номенклатура;
								КонецЕсли;
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	Иначе
		Запрос.Текст = "ВЫБРАТЬ
		|	втКоличестваНоменклатуры.ДетализацияПланирования КАК ДетализацияПланирования,
		|	втКоличестваНоменклатуры.Колонна КАК Колонна,
		|	втКоличестваНоменклатуры.Подразделение КАК Подразделение,
		|	втКоличестваНоменклатуры.ВидОбслуживания КАК ВидОбслуживания,
		|	СУММА(уатПлановыеЦеныНоменклатурыСрезПоследних.Цена * втКоличестваНоменклатуры.Количество) КАК Сумма
		|ИЗ
		|	втКоличестваНоменклатуры КАК втКоличестваНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатПлановыеЦеныНоменклатуры.СрезПоследних(
		|				&ПериодПолученияЦен,
		|				Номенклатура В
		|					(ВЫБРАТЬ
		|						втКоличестваНоменклатуры.Номенклатура
		|					ИЗ
		|						втКоличестваНоменклатуры)) КАК уатПлановыеЦеныНоменклатурыСрезПоследних
		|		ПО втКоличестваНоменклатуры.Номенклатура = уатПлановыеЦеныНоменклатурыСрезПоследних.Номенклатура
		|			И втКоличестваНоменклатуры.ДетализацияПланирования.Модель = уатПлановыеЦеныНоменклатурыСрезПоследних.Модель
		|
		|СГРУППИРОВАТЬ ПО
		|	втКоличестваНоменклатуры.ДетализацияПланирования,
		|	втКоличестваНоменклатуры.Колонна,
		|	втКоличестваНоменклатуры.ВидОбслуживания,
		|	втКоличестваНоменклатуры.Подразделение";
		
		ОсновнаяСтавкаНДС = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
			ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяСтавкаНДС");
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтруктураПоиска = Новый Структура("ДетализацияПланирования, Колонна, Подразделение, ВидОбслуживания, РучнойВвод",
				Выборка.ДетализацияПланирования, Выборка.Колонна, Выборка.Подразделение, Выборка.ВидОбслуживания, Ложь);
			НайденныеСтроки = СоставПланаПериоды.НайтиСтроки(СтруктураПоиска);
			Для Каждого ТекСтрока Из НайденныеСтроки Цикл
				ТекСтрока.СоставПланаПериодыКоличество_Всего = 1;
				ТекСтрока.СоставПланаПериодыЦена_Всего       = Выборка.Сумма;
				ТекСтрока.СоставПланаПериодыСумма_Всего      = Выборка.Сумма;
				ТекСтрока.СоставПланаПериодыСтавкаНДС_Всего  = ОсновнаяСтавкаНДС;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПлановыеДанныеТОЗаполнитьПоПланамТОЗавершение(флКолонна, флПодразделение)
	
	НачалоПериода = Объект.ДатаПланирования;
	КонецПериода = Объект.ДатаПланирования;
	уатОбщегоНазначенияТиповые.уатВыровнятьПериод(НачалоПериода, КонецПериода, Объект.Сценарий.Периодичность);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатПлановыеДатыТО.ТС КАК ТС,
	               |	уатПлановыеДатыТО.ДатаРаботы КАК Дата,
	               |	уатПлановыеДатыТО.ТО КАК ТО,
	               |	уатТС.Колонна КАК Колонна,
	               |	уатТС.Подразделение КАК Подразделение
	               |ИЗ
	               |	РегистрСведений.уатПлановыеДатыТО КАК уатПлановыеДатыТО
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТС КАК уатТС
	               |		ПО уатПлановыеДатыТО.ТС = уатТС.Ссылка
	               |ГДЕ
	               |	уатПлановыеДатыТО.Период МЕЖДУ &НачалоПериода И &КонецПериода
	               |	И уатТС.Организация = &Организация";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = СоставПланаПериоды.Добавить();
		НоваяСтрока.ДетализацияПланирования  = ВыборкаДетальныеЗаписи.ТС;
		НоваяСтрока.ПлановаяДатаОбслуживания = ВыборкаДетальныеЗаписи.Дата;
		НоваяСтрока.ВидОбслуживания          = ВыборкаДетальныеЗаписи.ТО;
		Если флКолонна Тогда
			НоваяСтрока.Колонна              = ВыборкаДетальныеЗаписи.Колонна;
		КонецЕсли;
		Если флПодразделение Тогда
			НоваяСтрока.Подразделение        = ВыборкаДетальныеЗаписи.Подразделение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПлановыеДатыТОЗаполнитьПоРемонтнымЛистамЗавершение(флКолонна, флПодразделение)
	
	НачалоПериода = Объект.ДатаПланирования-1;
	КонецПериода = Объект.ДатаПланирования-1;
	уатОбщегоНазначенияТиповые.уатВыровнятьПериод(НачалоПериода, КонецПериода, Объект.Сценарий.Периодичность);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	уатРемонтныйЛист.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА уатРемонтныйЛист.ВидОбслуживания = &ПустойВидОбслуживания
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ + ВЫБОР
	|		КОГДА уатРемонтныйЛист.ВидОбслуживания2 = &ПустойВидОбслуживания
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ + ВЫБОР
	|		КОГДА уатРемонтныйЛист.ВидОбслуживания3 = &ПустойВидОбслуживания
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ЗаполненныхВидовТО,
	|	уатРемонтныйЛист.ДатаОкончания КАК Дата,
	|	уатРемонтныйЛист.СуммаДокумента КАК СуммаДокумента,
	|	уатРемонтныйЛист.ВидОбслуживания КАК ВидОбслуживания,
	|	уатРемонтныйЛист.ВидОбслуживания2 КАК ВидОбслуживания2,
	|	уатРемонтныйЛист.ВидОбслуживания3 КАК ВидОбслуживания3,
	|	уатРемонтныйЛист.ТС КАК ТС,
	|	ВЫБОР
	|		КОГДА &флКолонна
	|			ТОГДА уатТС.Колонна
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.уатКолонны.ПустаяССылка)
	|	КОНЕЦ КАК Колонна,
	|	ВЫБОР
	|		КОГДА &флПодразделение
	|			ТОГДА уатТС.Подразделение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяССылка)
	|	КОНЕЦ КАК Подразделение
	|ПОМЕСТИТЬ втРемонтныеЛисты
	|ИЗ
	|	Документ.уатРемонтныйЛист КАК уатРемонтныйЛист
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТС КАК уатТС
	|		ПО уатРемонтныйЛист.ТС = уатТС.Ссылка
	|ГДЕ
	|	уатРемонтныйЛист.Организация = &Организация
	|	И уатРемонтныйЛист.Проведен = ИСТИНА
	|	И уатРемонтныйЛист.Выполнен = ИСТИНА
	|	И (уатРемонтныйЛист.ВидОбслуживания = &ПустойВидОбслуживания
	|			ИЛИ уатРемонтныйЛист.ВидОбслуживания.ИспользоватьВПланированииТО = ИСТИНА)
	|	И (уатРемонтныйЛист.ВидОбслуживания2 = &ПустойВидОбслуживания
	|			ИЛИ уатРемонтныйЛист.ВидОбслуживания2.ИспользоватьВПланированииТО = ИСТИНА)
	|	И (уатРемонтныйЛист.ВидОбслуживания3 = &ПустойВидОбслуживания
	|			ИЛИ уатРемонтныйЛист.ВидОбслуживания3.ИспользоватьВПланированииТО = ИСТИНА)
	|	И уатРемонтныйЛист.ДатаОкончания МЕЖДУ &НачалоПериода И &КонецПериода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втРемонтныеЛисты.ТС КАК ТС,
	|	втРемонтныеЛисты.ВидОбслуживания КАК ВидОбслуживания,
	|	втРемонтныеЛисты.Колонна КАК Колонна,
	|	втРемонтныеЛисты.Подразделение КАК Подразделение,
	|	СУММА(втРемонтныеЛисты.СуммаДокумента / втРемонтныеЛисты.ЗаполненныхВидовТО) КАК Сумма,
	|	втРемонтныеЛисты.Дата КАК Дата
	|ИЗ
	|	втРемонтныеЛисты КАК втРемонтныеЛисты
	|ГДЕ
	|	втРемонтныеЛисты.ВидОбслуживания <> &ПустойВидОбслуживания
	|
	|СГРУППИРОВАТЬ ПО
	|	втРемонтныеЛисты.Дата,
	|	втРемонтныеЛисты.ТС,
	|	втРемонтныеЛисты.ВидОбслуживания,
	|	втРемонтныеЛисты.Колонна,
	|	втРемонтныеЛисты.Подразделение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втРемонтныеЛисты.ТС,
	|	втРемонтныеЛисты.ВидОбслуживания2,
	|	втРемонтныеЛисты.Колонна,
	|	втРемонтныеЛисты.Подразделение,
	|	СУММА(втРемонтныеЛисты.СуммаДокумента / втРемонтныеЛисты.ЗаполненныхВидовТО),
	|	втРемонтныеЛисты.Дата
	|ИЗ
	|	втРемонтныеЛисты КАК втРемонтныеЛисты
	|ГДЕ
	|	втРемонтныеЛисты.ВидОбслуживания2 <> &ПустойВидОбслуживания
	|
	|СГРУППИРОВАТЬ ПО
	|	втРемонтныеЛисты.Дата,
	|	втРемонтныеЛисты.ТС,
	|	втРемонтныеЛисты.ВидОбслуживания2,
	|	втРемонтныеЛисты.Колонна,
	|	втРемонтныеЛисты.Подразделение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втРемонтныеЛисты.ТС,
	|	втРемонтныеЛисты.ВидОбслуживания3,
	|	втРемонтныеЛисты.Колонна,
	|	втРемонтныеЛисты.Подразделение,
	|	СУММА(втРемонтныеЛисты.СуммаДокумента / втРемонтныеЛисты.ЗаполненныхВидовТО),
	|	втРемонтныеЛисты.Дата
	|ИЗ
	|	втРемонтныеЛисты КАК втРемонтныеЛисты
	|ГДЕ
	|	втРемонтныеЛисты.ВидОбслуживания3 <> &ПустойВидОбслуживания
	|
	|СГРУППИРОВАТЬ ПО
	|	втРемонтныеЛисты.Дата,
	|	втРемонтныеЛисты.ТС,
	|	втРемонтныеЛисты.ВидОбслуживания3,
	|	втРемонтныеЛисты.Колонна,
	|	втРемонтныеЛисты.Подразделение";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
	
	Периодичность = Объект.Сценарий.Периодичность;
	Если ТипЗнч(Периодичность) <> Тип("ПеречислениеСсылка.Периодичность") ИЛИ Не ЗначениеЗаполнено(Периодичность) Тогда
		Периодичность = Перечисления.Периодичность.День;
	КонецЕсли;
	
	// Смещаем дату окончания Ремонтного листа в текущий период планирования
	Для Сч = 0 По СхемаЗапроса.ПакетЗапросов[0].Операторы[0].ВыбираемыеПоля.Количество()-1 Цикл
		ТекущееПоле = СхемаЗапроса.ПакетЗапросов[0].Операторы[0].ВыбираемыеПоля[Сч];
		Если Строка(ТекущееПоле) = "уатРемонтныйЛист.ДатаОкончания" Тогда
			СхемаЗапроса.ПакетЗапросов[0].Операторы[0].ВыбираемыеПоля[Сч] = Новый ВыражениеСхемыЗапроса(
				СтрШаблон("ДОБАВИТЬКДАТЕ(уатРемонтныйЛист.ДатаОкончания, %1, 1)", Строка(Периодичность)));
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ПустойВидОбслуживания", Справочники.уатВидыОбслуживанияТС.ПустаяСсылка());
	Запрос.Параметры.Вставить("флКолонна", флКолонна);
	Запрос.Параметры.Вставить("флПодразделение", флПодразделение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ОсновнаяСтавкаНДС = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		ПользователиКлиентСервер.АвторизованныйПользователь(), "ОсновнаяСтавкаНДС");
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = СоставПланаПериоды.Добавить();
		НоваяСтрока.ДетализацияПланирования            = ВыборкаДетальныеЗаписи.ТС;
		НоваяСтрока.ПлановаяДатаОбслуживания           = ВыборкаДетальныеЗаписи.Дата;
		НоваяСтрока.ВидОбслуживания                    = ВыборкаДетальныеЗаписи.ВидОбслуживания;
		НоваяСтрока.Колонна                            = ВыборкаДетальныеЗаписи.Колонна;
		НоваяСтрока.Подразделение                      = ВыборкаДетальныеЗаписи.Подразделение;
		НоваяСтрока.СоставПланаПериодыКоличество_Всего = 1;
		НоваяСтрока.СоставПланаПериодыЦена_Всего       = ВыборкаДетальныеЗаписи.Сумма;
		НоваяСтрока.СоставПланаПериодыСумма_Всего      = ВыборкаДетальныеЗаписи.Сумма;
		НоваяСтрока.СоставПланаПериодыСтавкаНДС_Всего  = ОсновнаяСтавкаНДС;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПлановуюЦенуНоменклатуры(Период, Номенклатура, МодельТС)
	
	Возврат РегистрыСведений.уатПлановыеЦеныНоменклатуры.ПолучитьПлановуюЦенуНоменклатуры(
		Период, Номенклатура, МодельТС);
	
КонецФункции

&НаКлиенте
Процедура НастроитьКолонкуНоменклатура(КолонкаНоменклатура)
	ВариантАналитики = ХарактеристикиСценария.ВариантАналитикиНоменклатура;
	Если ВариантАналитики = ПредопределенноеЗначение("Перечисление.уатВариантыАналитик.Номенклатура") Тогда
		КолонкаНоменклатура.Заголовок       = ВариантАналитики;
		КолонкаНоменклатура.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ИначеЕсли ВариантАналитики = ПредопределенноеЗначение("Перечисление.уатВариантыАналитик.КодЕТСНГ") Тогда
		КолонкаНоменклатура.Заголовок       = ВариантАналитики;
		КолонкаНоменклатура.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.уатКодыЕТСНГ");
	Иначе
		КолонкаНоменклатура.Заголовок       = ВариантАналитики;
		КолонкаНоменклатура.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.уатКодыГНГ");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьКурсКратностьДокумента()
	СтруктураКурс = уатОбщегоНазначенияТиповые.ПолучитьКурсВалюты(Объект.ВалютаДокумента, Объект.Дата, Объект);
	Объект.КурсДокумента = СтруктураКурс.Курс;
	Объект.КратностьДокумента = СтруктураКурс.Кратность;
	
	ВывестиСуммовыеИтогиДокумента();
КонецПроцедуры

#КонецОбласти
