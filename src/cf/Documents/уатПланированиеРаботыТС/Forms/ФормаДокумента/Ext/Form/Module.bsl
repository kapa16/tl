						НайденныеСтроки = СоставПланаПериоды.НайтиСтроки(СтруктураПоиска);
						ПлановыеДатыОбслуживания = Новый Массив;
						Для Каждого ТекСтрока Из НайденныеСтроки Цикл
							// Удаляем все старые строки, т.к. по ним может отличаться состав номенклатуры,
							// т.е. количество строк для данного набора аналитик.
							Если ПлановыеДатыОбслуживания.Найти(ТекСтрока.ПлановаяДатаОбслуживания) = Неопределено Тогда
								ПлановыеДатыОбслуживания.Добавить(ТекСтрока.ПлановаяДатаОбслуживания);
							КонецЕсли;
							СоставПланаПериоды.Удалить(ТекСтрока);
						КонецЦикла;
						ВыборкаДетальныеЗаписи = ВыборкаВидОбслуживания.Выбрать();
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
