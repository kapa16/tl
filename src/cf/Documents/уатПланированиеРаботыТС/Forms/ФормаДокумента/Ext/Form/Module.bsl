		РезультатЗапроса = Запрос.ВыполнитьПакет();
		ТаблицаЗамещаемыхРабот = РезультатЗапроса[1].Выгрузить();
		ВыборкаДетализацияПланирования = РезультатЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДетализацияПланирования.Следующий() Цикл
			ВыборкаКолонна = ВыборкаДетализацияПланирования.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКолонна.Следующий() Цикл
				ВыборкаПодразделение = ВыборкаКолонна.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПодразделение.Следующий() Цикл
					ВыборкаВидОбслуживания = ВыборкаПодразделение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаВидОбслуживания.Следующий() Цикл
						ЗамещаемыеРаботы = ТаблицаЗамещаемыхРабот.НайтиСтроки(Новый Структура ("ЗамещаемыйВидОбслуживанияТС", ВыборкаВидОбслуживания.ВидОбслуживания));
						СтруктураПоиска = Новый Структура("ДетализацияПланирования, Колонна, Подразделение, ВидОбслуживания, РучнойВвод",
							ВыборкаВидОбслуживания.ДетализацияПланирования,
							ВыборкаВидОбслуживания.Колонна,
							ВыборкаВидОбслуживания.Подразделение,
							ВыборкаВидОбслуживания.ВидОбслуживания,
