		ОбновитьЗапланированноеКоличество(НомерТекущейСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоставПланаПериодыОбъектСтроительстваПриИзменении(Элемент)
	
	Если ХарактеристикиСценария.Раздел
		= ПредопределенноеЗначение("Перечисление.уатРазделыПланирования.ОбъемыПеревозок") Тогда
		РассчитатьОбъемыПеревозокПоПеревозчикам(ХарактеристикиСценария);
	КонецЕсли;
	
	ТекущиеДанные = Элементы.СоставПланаПериоды.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		НомерТекущейСтроки = СоставПланаПериоды.Индекс(ТекущиеДанные);
		ОбновитьЗапланированноеКоличество(НомерТекущейСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоставПланаПериодыНаправлениеПеревозкиПриИзменении(Элемент)
	
	Если ХарактеристикиСценария.Раздел
		= ПредопределенноеЗначение("Перечисление.уатРазделыПланирования.ОбъемыПеревозок") Тогда
		РассчитатьОбъемыПеревозокПоПеревозчикам(ХарактеристикиСценария);
	КонецЕсли;
	
	ТекущиеДанные = Элементы.СоставПланаПериоды.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		НомерТекущейСтроки = СоставПланаПериоды.Индекс(ТекущиеДанные);
		ОбновитьЗапланированноеКоличество(НомерТекущейСтроки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы_СоставПланаАналитики

&НаКлиенте
Процедура СоставПланаАналитикиПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.СоставПланаАналитики.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		СоставПланаДетально.Очистить();
		СтруктураОтбора = Новый Структура("ИдентификаторНабораАналитик", ТекущиеДанные.ИдентификаторНабораАналитик);
		НайденныеСтроки = СоставПланаПериоды.НайтиСтроки(СтруктураОтбора);
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			НоваяСтрока = СоставПланаДетально.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденнаяСтрока);
			Если НоваяСтрока.Свойство("СоставПланаДетальноКоличество_Всего") Тогда
				НоваяСтрока.СоставПланаДетальноКоличество_Всего = НайденнаяСтрока.СоставПланаПериодыКоличество_Всего;
			КонецЕсли;
			Если ХарактеристикиСценария.флРемонтыИТО Тогда
				НоваяСтрока.СоставПланаДетальноСумма_Всего = НайденнаяСтрока.СоставПланаПериодыСумма_Всего;
			КонецЕсли;
		КонецЦикла;
		СоставПланаДетально.Сортировать("ПлановаяДатаОбслуживания");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставПланаАналитикиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	ТекСтрока = Элементы.СоставПланаАналитики.ТекущиеДанные;
	Если НоваяСтрока Тогда
		ТекСтрока.ИдентификаторНабораАналитик = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставПланаАналитикиПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	ТекущиеДанные = Элементы.СоставПланаАналитики.ТекущиеДанные;
	Если Не ОтменаРедактирования И ТекущиеДанные <> Неопределено Тогда
		СтруктураОтбора = Новый Структура("ИдентификаторНабораАналитик", ТекущиеДанные.ИдентификаторНабораАналитик);
		НайденныеСтроки = СоставПланаПериоды.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			// Добавлена новая строка в таблицу наборов аналитик.
			// Необходимо добавить новую строку общей таблицы без детальных данных, т.к. их еще нет.
			НоваяСтрока = СоставПланаПериоды.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекущиеДанные);
			НоваяСтрока.СоставПланаПериодыКоличествоСводноеФакт_Всего = ТекущиеДанные.СоставПланаАналитикиКоличествоСводноеФакт_Всего;
			НоваяСтрока.СоставПланаПериодыКоличествоСводноеПлан_Всего = ТекущиеДанные.СоставПланаАналитикиКоличествоСводноеПлан_Всего;
		Иначе
			// Изменены аналитики или запланированное количество по аналитикам.
			// Необходимо обновить данные в существующих строках общей таблицы
			Для Каждого ТекСтрока Из НайденныеСтроки Цикл
				ЗаполнитьЗначенияСвойств(ТекСтрока, ТекущиеДанные);
				ТекСтрока.СоставПланаПериодыКоличествоСводноеФакт_Всего = ТекущиеДанные.СоставПланаАналитикиКоличествоСводноеФакт_Всего;
				ТекСтрока.СоставПланаПериодыКоличествоСводноеПлан_Всего = ТекущиеДанные.СоставПланаАналитикиКоличествоСводноеПлан_Всего;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставПланаАналитикиПослеУдаления(Элемент)
	
	УдаляемыеСтроки = Новый Массив;
	Для Каждого ТекСтрока Из СоставПланаПериоды Цикл
		СтруктураОтбора = Новый Структура("ИдентификаторНабораАналитик", ТекСтрока.ИдентификаторНабораАналитик);
		НайденныеСтроки = СоставПланаАналитики.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			// Удалена строка из таблицы наборов аналитик, требуется удалить строки общей таблицы
			УдаляемыеСтроки.Добавить(ТекСтрока);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекСтрока Из УдаляемыеСтроки Цикл
		СоставПланаПериоды.Удалить(ТекСтрока);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

