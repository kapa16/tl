&НаСервере
Функция ОтправитьЗапросСервер(ТекстЗапроса, Заголовки, ЗапросТокена = Ложь, ПрочитатьВСоответствие = Ложь,АдресСервера,ИмяФайлаОтвета)

	Попытка
		Соединение  =  ПолучитьHTTPСоединениеСПрокси(АдресСервера);
		
		ЗапросHttp = Новый HTTPЗапрос(ТекстЗапроса, Заголовки);
		ОтветHttp = Соединение.Получить(ЗапросHttp);
	Исключение
		Сообщить("Ошибка соединения с сервером: " + ОписаниеОшибки());
	КонецПопытки; 	
	
	Если ОтветHttp <> Неопределено И ПроверитьОтветЗапроса(ОтветHttp) Тогда
		Если ЗапросТокена Тогда
			Возврат ОтветHttp.ПолучитьТелоКакСтроку();
		КонецЕсли;
		
		ОтветHttp.ПолучитьТелоКакДвоичныеДанные().Записать(ИмяФайлаОтвета);
		
		Возврат РазобратьОтвет(ИмяФайлаОтвета, ПрочитатьВСоответствие);
	Иначе
		Возврат Неопределено;
	КонецЕсли; 	

КонецФункции

&НаСервере
Функция ПроверитьОтветЗапроса(ОтветHttp)
	
	Перем Результат;
	
	// Статусы 1XX и 2XX считаем хорошими
	Результат = Истина;
	Сообщение = Новый СообщениеПользователю;
	
	// Ошибки 4XX говорят о неправильном запросе - в широком смысле
	// Может быть неправильный адрес, ошибка аутентификации, плохой формат запроса
	// Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.4
	Если ОтветHttp.КодСостояния >= 400 и ОтветHttp.КодСостояния < 500  Тогда
		Сообщение.Текст = "Код статуса больше 4XX, ошибка запроса.  Код статуса: " + ОтветHttp.КодСостояния + 
		Символы.ПС + "Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.4";
		Сообщение.Сообщить();
		Результат = Ложь;
	КонецЕсли;
	
	// Ошибки 5XX говорят о проблемах на сервере (возможно, прокси-сервер)
	// Это может быть программная ошибка, нехватка памяти, ошибка конфигурации и т.д.
	// Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.5
	Если ОтветHttp.КодСостояния >= 500 и ОтветHttp.КодСостояния < 600  Тогда
		Сообщение.Текст = "Код статуса больше 5XX, ошибка сервера. Код статуса: " + ОтветHttp.КодСостояния +
		Символы.ПС + "Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.5";
		Сообщение.Сообщить();
		Результат = Ложь;
	КонецЕсли;
	
	// Обрабатываем перенаправление
	Если ОтветHttp.КодСостояния >= 300 и ОтветHttp.КодСостояния < 400  Тогда
		Результат = Ложь;
		Сообщение.Текст = "Код статуса больше 3XX, Перенаправление. Код статуса: " + ОтветHttp.КодСостояния;
		Сообщение.Сообщить();
		Если ОтветHttp.КодСостояния = 302 Тогда
			Сообщение.Текст = "Код статуса 302, Постоянное перенаправление.";
			Сообщение.Сообщить();
			АдресРесурса = ОтветHttp.Заголовки.Получить("Location");
			Если АдресРесурса <> Неопределено Тогда
				Сообщение.Текст = "Возможно правильнее выполнить запрос по адресу " + АдресРесурса;
			Иначе
				Сообщение.Текст = "Сервер не сообщил адрес ресурса!";
			КонецЕсли;
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
	
	Если ОтветHttp.КодСостояния < 300 Тогда 
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция РазобратьОтвет(ИмяФайлаОтвета, ПрочитатьВСоответствие)
	
	Перем ИмяJSON, ЗнJSON, ОтветJSON;
	
	ФайлНаДиске = Новый Файл(ИмяФайлаОтвета);
	Если НЕ ФайлНаДиске.Существует() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Сообщение	= Новый СообщениеПользователю;
	ЧтениеJSON	= Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьФайл(ИмяФайлаОтвета);
	ОтветJSON	= ПрочитатьJSON(ЧтениеJSON, ПрочитатьВСоответствие);
	ЧтениеJSON.Закрыть();	
	Возврат ОтветJSON;
	
КонецФункции 

&НаСервере
Функция СтруктураURI(Знач СтрокаURI) Экспорт
	
	СтрокаURI = СокрЛП(СтрокаURI);
	
	// схема
	Схема = "";
	Позиция = Найти(СтрокаURI, "://");
	Если Позиция > 0 Тогда
		Схема = НРег(Лев(СтрокаURI, Позиция - 1));
		СтрокаURI = Сред(СтрокаURI, Позиция + 3);
	КонецЕсли;

	// строка соединения и путь на сервере
	СтрокаСоединения = СтрокаURI;
	ПутьНаСервере = "";
	Позиция = Найти(СтрокаСоединения, "/");
	Если Позиция > 0 Тогда
		ПутьНаСервере = Сред(СтрокаСоединения, Позиция + 1);
		СтрокаСоединения = Лев(СтрокаСоединения, Позиция - 1);
	КонецЕсли;
		
	// информация пользователя и имя сервера
	СтрокаАвторизации = "";
	ИмяСервера = СтрокаСоединения;
	Позиция = Найти(СтрокаСоединения, "@");
	Если Позиция > 0 Тогда
		СтрокаАвторизации = Лев(СтрокаСоединения, Позиция - 1);
		ИмяСервера = Сред(СтрокаСоединения, Позиция + 1);
	КонецЕсли;
	
	// логин и пароль
	Логин = СтрокаАвторизации;
	Пароль = "";
	Позиция = Найти(СтрокаАвторизации, ":");
	Если Позиция > 0 Тогда
		Логин = Лев(СтрокаАвторизации, Позиция - 1);
		Пароль = Сред(СтрокаАвторизации, Позиция + 1);
	КонецЕсли;
	
	// хост и порт
	Хост = ИмяСервера;
	Порт = "";
	Позиция = Найти(ИмяСервера, ":");
	Если Позиция > 0 Тогда
		Хост = Лев(ИмяСервера, Позиция - 1);
		Порт = Сред(ИмяСервера, Позиция + 1);
	КонецЕсли;
	
	Логин = "User_1C";
	Пароль = "Lgdeu7916";
	Порт = 443;
	
	Результат = Новый Структура;
	Результат.Вставить("Схема", Схема);
	Результат.Вставить("Логин", Логин);
	Результат.Вставить("Пароль", Пароль);
	Результат.Вставить("ИмяСервера", ИмяСервера);
	Результат.Вставить("Хост", Хост);
	Результат.Вставить("Порт", ?(Порт <> "", Число(Порт), Неопределено));
	Результат.Вставить("ПутьНаСервере", ПутьНаСервере);
	
	Возврат Результат;
	
КонецФункции
