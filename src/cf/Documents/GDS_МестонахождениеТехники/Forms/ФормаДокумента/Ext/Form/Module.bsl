&НаСервере
Функция ПроверкаМассиваСтрокНаДвойныеКусты(МассивСтрок)
	
	СтруктураДублей = Новый Структура;
	СтруктураДублей.Вставить("Месторождение","");
	СтруктураДублей.Вставить("Кусты","");
	
	МассивДублей = Новый Массив;
	
	ДублиКустов   = "";
	Месторождение = "";
	
	//определение дублей кустов
	Для СтрМассива = 0 по МассивСтрок.Количество() - 1 Цикл
		СтрМасс = МассивСтрок[СтрМассива];
		
		Если Найти(СокрЛП(СтрМасс),"К-") > 0 Тогда
			МассивДублей.Добавить(Прав(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))-2));
		ИначеЕсли Найти(СокрЛП(СтрМасс)," К-") > 0 Тогда
			МассивДублей.Добавить(Прав(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))-2)); 	
		КонецЕсли;	
	КонецЦикла;
	
	//определением месторождения
	Для СтрМассива = 0 по МассивСтрок.Количество() - 1 Цикл
		СтрМасс = МассивСтрок[СтрМассива];
			
		Если Найти(СокрЛП(СтрМасс),"м/р") > 0 Тогда
			Местор = СокрЛП(Лев(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))-4));
			Месторождение = ВернутьЭлементМесторождение(Местор);
		КонецЕсли;		

	КонецЦикла;

	Если МассивДублей.Количество() > 1 Тогда
		ДублиКустов = СтрСоединить(МассивДублей, "-");	
	КонецЕсли;
	
	СтруктураДублей.Вставить("Месторождение",Месторождение);
	СтруктураДублей.Вставить("Кусты",ДублиКустов);
	
	Возврат СтруктураДублей;
	
КонецФункции

