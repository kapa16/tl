&НаСервере
Функция ВернутьМашину(ГосНомер)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатТС.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.уатТС КАК уатТС
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА СТРНАЙТИ(уатТС.ГосударственныйНомер, ""g-"") >= 1
	               |				ТОГДА СТРЗАМЕНИТЬ(уатТС.ГосударственныйНомер, ""g-"", """") = &ГосНомер
	               |			ИНАЧЕ уатТС.ГосударственныйНомер = &ГосНомер
	               |		КОНЕЦ";
	Запрос.УстановитьПараметр("ГосНомер", ГосНомер);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.уатТС.ПустаяСсылка();
	КонецЕсли;
	
	
	//Возврат Справочники.уатТС.НайтиПоРеквизиту("ГосударственныйНомер",ГосНомер);
	
КонецФункции

&НаСервере
Функция ВернутьЭлементМесторождение(ВхЭлемент)
	
	Месторождение = Справочники.GDS_Месторождения.ПустаяСсылка();
	
	ОтборМесторождения = Новый Структура;
	ОтборМесторождения.Вставить("Наименование", ВРег(ВхЭлемент));
	
	МассивСтрок = ТЧ_Месторождений.НайтиСтроки(ОтборМесторождения);
	Если МассивСтрок.Количество() > 0 Тогда
		Месторождение = МассивСтрок[0].Месторождение;
	КонецЕсли;
	
	Возврат Месторождение;
	
КонецФункции

&НаСервере
Функция ПолучитьМесторождения()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	GDS_Месторождения.Ссылка КАК Месторождение,
	|	GDS_Месторождения.Наименование КАК Наименование
	|ИЗ
	|	Справочник.GDS_Месторождения КАК GDS_Месторождения
	|ГДЕ
	|	НЕ GDS_Месторождения.ПометкаУдаления";
	
	ТЧ_Данные = Запрос.Выполнить().Выгрузить();
	
	Для каждого Стр из ТЧ_Данные Цикл
		Стр.Наименование = ВРег(Стр.Наименование);		
	КонецЦикла;
	
	Возврат ТЧ_Данные;

КонецФункции

&НаСервере
Функция ВернутьЭлементКуст(ВхЭлемент,Владелец)
	
	Куст = Справочники.GDS_Кусты.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	GDS_Кусты.Ссылка
	               |ИЗ
	               |	Справочник.GDS_Кусты КАК GDS_Кусты
	               |ГДЕ
	               |	GDS_Кусты.Наименование = &Наименование
	               |	И GDS_Кусты.Владелец = &Владелец
	               |	И НЕ GDS_Кусты.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Наименование", ВхЭлемент);
	Запрос.УстановитьПараметр("Владелец", Владелец);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Куст = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат Куст;	
	
КонецФункции

&НаСервере
Функция СоздатьНовыйКуст(Куст,Месторождение)
	
	СтрЭлемент = Справочники.GDS_Кусты.СоздатьЭлемент();
	
	СтрЭлемент.Наименование = Куст;
	СтрЭлемент.Владелец = Месторождение;
	
	СтрЭлемент.Записать();
	
	Возврат Справочники.GDS_Кусты.НайтиПоНаименованию(Куст,ИСТИНА,Месторождение);
	
КонецФункции

&НаСервере
Функция ПрочитатьExcel(ФайлExcel, ФункцияОбработкиСтрок = "СокрЛП(?)",
	
	ОграничиватьСверху = Истина, ОграничиватьСлева = Истина, ОграничиватьСнизу = Истина, ОграничиватьСправа = Истина) Экспорт 
	
	Ф = ФайлExcel;
	ВесьТабДок = Новый ТабличныйДокумент();
	ВесьТабДок.Прочитать(Ф, СпособЧтенияЗначенийТабличногоДокумента.Значение);
	
	Результат = Новый СписокЗначений;
	Области = ВесьТабДок.Области;
	
	Если Области.Количество()=0 Тогда 
		ВызватьИсключение("В файле нет областей");
	КонецЕсли;
	
	Для Каждого Обл Из Области Цикл
		ТекТабДок = Новый ТабличныйДокумент;
		ОгрОбласть = ПолучитьОграниченнуюОбласть(ВесьТабДок, Обл);
		// вставим область в табдок
		ОгрОбласть.Имя = Обл.Имя;
		ТекТабДок.ВставитьОбласть(ОгрОбласть, 
		ТекТабДок.Область(1, ОгрОбласть.Лево, ОгрОбласть.Низ - ОгрОбласть.Верх + 1, ОгрОбласть.Право)
		);
		СократитьСтроки(ТекТабДок, ФункцияОбработкиСтрок);
		Результат.Добавить(ТекТабДок, Обл.Имя);
	КонецЦикла;
	// зачищаем исходный таб док. хз, может лишнее
	ВесьТабДок.Очистить();
	ВесьТабДок = Неопределено;
	
	Возврат Результат;
	
КонецФункции

Процедура СократитьСтроки(ТабДок, ФункцияОбработкиСтрок = "СокрЛП(?)")
	
	Если ПустаяСтрока(ФункцияОбработкиСтрок) Тогда 
		Возврат;
	КонецЕсли;
	
	Если Ложь Тогда ТабДок = Новый ТабличныйДокумент; КонецЕсли; // фейк
	
	Для Стр = 1 По ТабДок.ВысотаТаблицы Цикл 
		Для Кол = 1 По ТабДок.ШиринаСтраницы Цикл 
			ТекОбласть = ТабДок.Область(Стр, Кол);
			ТекстОбласти = ТекОбласть.Текст;
			
			Если Не ТекОбласть.СодержитЗначение И Не ПустаяСтрока(ТекОбласть.Текст)    Тогда 
				Выражение = СтрЗаменить(ФункцияОбработкиСтрок, "?", "ТекстОбласти");
				ТекОбласть.Текст = Вычислить(Выражение);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьОграниченнуюОбласть(ТабДок, ОбластьЯчеек,
	
	ОграничиватьСверху = Истина, ОграничиватьСлева = Истина, ОграничиватьСнизу = Истина, ОграничиватьСправа = Истина)
	
	Если Не ОграничиватьСверху И Не ОграничиватьСлева И Не ОграничиватьСправа И Не ОграничиватьСнизу Тогда 
		Возврат ОбластьЯчеек;
	КонецЕсли;
	
	Если Ложь Тогда // фейк
		ТабДок = Новый ТабличныйДокумент;
		ОбластьЯчеек = ТабДок.Области[0];
	КонецЕсли;
	
	Лево = Неопределено; Право = Неопределено; Верх = Неопределено; Низ = Неопределено;
	МаксШирина = ТабДок.ШиринаТаблицы;
	
	Для Стр = ОбластьЯчеек.Верх По ОбластьЯчеек.Низ Цикл
		Для Кол = 1 По МаксШирина Цикл 
			ТекОбласть = ТабДок.Область(Стр, Кол);
			
			Если ЭтоЗначащаяОбласть(ТекОбласть) Тогда 
				Лево 	= ?(Лево=Неопределено, Кол, Мин(Лево, Кол));
				Право 	= ?(Право=Неопределено, Кол, Макс(Право, Кол));
				Верх 	= ?(Верх=Неопределено, Стр, Верх);
				Низ 	= ?(Низ=Неопределено, Стр, Макс(Низ, Стр));
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Результат = ТабДок.Область(?(ОграничиватьСверху, ?(Верх=Неопределено, ОбластьЯчеек.Верх, Верх), ОбластьЯчеек.Верх),
								?(ОграничиватьСлева, ?(Лево=Неопределено, ОбластьЯчеек.Лево, Лево), ОбластьЯчеек.Лево),
								?(ОграничиватьСнизу, ?(Низ=Неопределено, ОбластьЯчеек.Низ, Низ), ОбластьЯчеек.Низ),
								?(ОграничиватьСправа, ?(Право=Неопределено, ОбластьЯчеек.Право, Право), ОбластьЯчеек.Право));
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоЗначащаяОбласть(ОбластьЯчеек)
	
	Возврат Не ПустаяСтрока(ОбластьЯчеек.Текст) 
		Или ОбластьЯчеек.Гиперссылка
		Или ОбластьЯчеек.СодержитЗначение
		Или ОбластьЯчеек.ГраницаСлева.ТипЛинии <> ТипЛинииЯчейкиТабличногоДокумента.НетЛинии
		Или ОбластьЯчеек.ГраницаСправа.ТипЛинии <> ТипЛинииЯчейкиТабличногоДокумента.НетЛинии;
	
КонецФункции

&НаСервере
Процедура ЗагрузкаИнформацииНаСервере(Адрес)
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(Адрес);
	ИмяФайла = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ИмяФайла);
	
	ЗначениеЗагрузки = ПрочитатьExcel(ИмяФайла);
	
	ТабД = ЗначениеЗагрузки[0].Значение;
	
	КолВоСтрок = ТабД.ВысотаТаблицы;
	
	ТЧ_Месторождений.Очистить();
	ТЧ_Месторождений.Загрузить(ПолучитьМесторождения());
	
	Сч =0;
	Для Стр = 7 по КолВоСтрок Цикл
		СтруктураОшибок = Новый Структура;
		СтруктураОшибок.Вставить("ТекстОшибки","");
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(3,"ЧГ=")).Текст) Тогда //Модель
			Модель = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(3,"ЧГ=")).Текст;
		Иначе
			Модель = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(4,"ЧГ=")).Текст) Тогда //ID_Автограф для связи машин
			ID_Автограф = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(4,"ЧГ=")).Текст;
		Иначе
			ID_Автограф = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(5,"ЧГ=")).Текст) Тогда //Номер ТС
			НомерТС = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(5,"ЧГ=")).Текст;
		Иначе
			НомерТС = "";
		КонецЕсли;
	
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(6,"ЧГ=")).Текст) Тогда //Название геозоны
			НазваниеГеозоны = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(6,"ЧГ=")).Текст;
		Иначе
			НазваниеГеозоны = "";
		КонецЕсли;
		
		//+время
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(7,"ЧГ=")).Текст) Тогда//Вход в геозону
			ВремяВхода = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(7,"ЧГ=")).Текст;
		Иначе
			ВремяВхода = "00010101000000";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(8,"ЧГ=")).Текст) Тогда//Выход из геозоны
			ВремяВыхода = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(8,"ЧГ=")).Текст;
		Иначе
			ВремяВыхода = "00010101000000";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(9,"ЧГ=")).Текст) Тогда//Время в геозоне (чч:мм)
			ВремяВГеозоне = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(9,"ЧГ=")).Текст;
			
			// Добавлено условие чтобы исключить фальшивые остановки по данным автографа - Просьба МакароваЭ.В., лопушенко в курсе
			//из-за этого условия строчек в программе становится меньше чем в файле
			Если Число(Лев(ВремяВГеозоне,2)) > 0 Тогда
			Иначе
				Если Число(Прав(ВремяВГеозоне,2)) < 10 Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ВремяВГеозоне = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(11,"ЧГ=")).Текст) Тогда//Расход топлива (чч:мм)
			РасходТоплива = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(11,"ЧГ=")).Текст;
			
			Если Число(РасходТоплива) < 0 Тогда
				РасходТоплива = 0;
			КонецЕсли;
		Иначе
			РасходТоплива = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(12,"ЧГ=")).Текст) Тогда//М\Ч
			МотоЧасы = ТабД.Область("R"+Формат(Стр,"ЧГ=")+"C"+Формат(12,"ЧГ=")).Текст;
		КонецЕсли;
		//-
		Если Не НазваниеГеозоны = "" Тогда
			Месторождение = "";
			Куст = "";
			База = "";
			
			Сч = Сч+1;
			МассивСтрок = СтрРазделить(НазваниеГеозоны,",");
			РезультатПроверки = ПроверкаМассиваСтрокНаДвойныеКусты(МассивСтрок);
			
			Если РезультатПроверки.Кусты <> "" Тогда
				Сообщить("Строка № "+сч+" в Excel найдены дубли кустов"+РезультатПроверки.Кусты+" по Месторождению - "+РезультатПроверки.Месторождение);
				СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки +"Строка № "+сч+" В Excel найдены дубли кустов - "+РезультатПроверки.Кусты+" по Месторождению - "+РезультатПроверки.Месторождение;
			КонецЕсли;
			
			Для СтрМассива = 0 по МассивСтрок.Количество() - 1 Цикл
				СтрМасс = МассивСтрок[СтрМассива];
				
				Если Найти(СокрЛП(СтрМасс),"База") > 0 Тогда
					База = СокрЛП(Лев(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))));
				КонецЕсли;		
				
				Если Найти(СокрЛП(СтрМасс),"м/р") > 0 Тогда
					Местор = СокрЛП(Лев(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))-4));
					Месторождение = ВернутьЭлементМесторождение(Местор);
					
					Если НЕ ЗначениеЗаполнено(Месторождение) Тогда
						Сообщить("Строка № "+сч+" месторождения нет в БД - "+Местор);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки +"Строка № "+сч+" Месторождения нет в БД - "+Местор;// + Символы.ПС;
					КонецЕсли;
				КонецЕсли;
				
				Если Найти(СокрЛП(СтрМасс),"К-") > 0 Тогда
					Куст = Прав(СокрЛП(СтрМасс),СтрДлина(СокрЛП(СтрМасс))-2);
				КонецЕсли;
			КонецЦикла;
			
			НоваяСтрока = Объект.ТЧ.Добавить();
			
			НоваяСтрока.База = База;
			
			НоваяСтрока.ВходВГеозону   = Дата(ВремяВхода);
			НоваяСтрока.ВыходИзГеозоны = Дата(ВремяВыхода);
			
			НоваяСтрока.ID_Автограф    = ID_Автограф;
			
			Если НЕ ВремяВгеозоне = "" Тогда
				НоваяСтрока.ВремяВгеозоне = Дата("0001.01.01 "+ВремяВГеозоне+":00");
			Иначе
				НоваяСтрока.ВремяВгеозоне = Дата("00010101000000");
			КонецЕсли;
			
			НоваяСтрока.СколькоТопливаПотрачено = РасходТоплива;
			НоваяСтрока.МотоЧасы = МотоЧасы;
			
			Если ЗначениеЗаполнено(Месторождение) Тогда
				НоваяСтрока.Месторождение = Месторождение;
				
				Если НЕ Объект.СторонняяТехника Тогда
					ГосНомерТС = ВернутьМашину(НомерТС);
					Если ГосНомерТС <> Справочники.уатТС.ПустаяСсылка() Тогда
						НоваяСтрока.ТС = ГосНомерТС;
					Иначе
						Сообщить("Строка № "+сч+" не нашли ТС по ""Гос.Номер"" в БД - "+ НомерТС);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки + "Строка № " + сч + " Не нашли ТС по ""Гос.Номер"" в БД - "+ НомерТС;
					КонецЕсли;
				Иначе
					Если НомерТС <> "" Тогда
						НоваяСтрока.ТС = НомерТС;
					Иначе
						Сообщить("Строка № "+сч+" не заполнен номер ТС в файле Ecxel - " + НомерТС);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки + "Строка № " + сч + " Не заполнен номер ТС в файле Ecxel - "+ НомерТС;
					КонецЕсли;
				КонецЕсли;
				
				Если ЗначениеЗаполнено(Куст) Тогда
					СпрКуст = ВернутьЭлементКуст(СокрЛП(Куст),Месторождение);
					
					Если ЗначениеЗаполнено(СпрКуст) Тогда
						НоваяСтрока.Куст = СпрКуст;
					Иначе
						Сообщить("Строка № " + сч + " не нашли Куст " + Куст + " по Месторождениею в БД - " + Месторождение);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки + "Строка № " + сч + " Не нашли Куст "+ Куст + " по Месторождениею в БД - " + Месторождение;
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли Найти(База,"База") > 0 Тогда
				Если НЕ Объект.СторонняяТехника Тогда
					ГосНомерТС = ВернутьМашину(НомерТС);
					Если ГосНомерТС <> Справочники.уатТС.ПустаяСсылка() Тогда
						НоваяСтрока.ТС = ГосНомерТС;
					Иначе
						Сообщить("Строка № " + сч + " не нашли ТС по ""Гос.Номер"" в БД - " + НомерТС);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки + "Строка № " + сч + " Не нашли ТС по ""Гос.Номер"" в БД - " + НомерТС;
					КонецЕсли;
				Иначе
					Если НомерТС <> "" Тогда
						НоваяСтрока.ТС = НомерТС;
					Иначе
						Сообщить("Строка № " + сч + " не заполнен номер ТС в файле Ecxel - " + НомерТС);
						СтруктураОшибок.ТекстОшибки = СтруктураОшибок.ТекстОшибки + "Строка № " + сч + " Не заполнен номер ТС в файле Ecxel - " + НомерТС;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
				
			Если СтруктураОшибок.ТекстОшибки <> "" Тогда
				НоваяСтрока.ЕстьОшибки = Истина;
			Иначе 
				НоваяСтрока.ЕстьОшибки = Ложь;
			КонецЕсли;
			
			НоваяСтрока.ОписаниеОшибки = СтруктураОшибок.ТекстОшибки;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
