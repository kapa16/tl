Функция ВернутьЗначениеЗагрузкиПоНаименованию(НаименованиеЗначения, ТипЗначения) Экспорт
	ЭлементВозврата = "";
	ИмяТипа = Метаданные.Перечисления["GDS_ТипЗагружаемогоЭлемента"].ЗначенияПеречисления[Перечисления["GDS_ТипЗагружаемогоЭлемента"].Индекс(ТипЗначения)].Имя;
	
	ЭлементВозврата  = Справочники[ИмяТипа].НайтиПоНаименованию(НаименованиеЗначения,Истина);
		
	Если Не ЗначениеЗаполнено(ЭлементВозврата) ТОгда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_МестонахождениеТехники_ПравилаЗагрузки.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.GDS_МестонахождениеТехники_ПравилаЗагрузки КАК GDS_МестонахождениеТехники_ПравилаЗагрузки
		|ГДЕ
		|	GDS_МестонахождениеТехники_ПравилаЗагрузки.НаименованиеЭлемента = &НаименованиеЭлемента
		|	И GDS_МестонахождениеТехники_ПравилаЗагрузки.ТипЗагружаемогоЭлемента = &ТипЗагружаемогоЭлемента";
		
		Запрос.УстановитьПараметр("НаименованиеЭлемента", НаименованиеЗначения);
		Запрос.УстановитьПараметр("ТипЗагружаемогоЭлемента", ТипЗначения);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЭлементВозврата = ВыборкаДетальныеЗаписи.Значение;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ЭлементВозврата;
КонецФункции

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.ТЧ.Количество()>0 Тогда	
		ЗаполнениеПУвТЧ();	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнениеПУвТЧ();
	
	//собирем все данные по ТС в одну таблицу
	ТЗ_Геозоны = Объект.ТЧ.Выгрузить();
	
	ТЗ_ТС_Свернуть = ТЗ_Геозоны.Скопировать();
	
	ТЗ_ТС_Свернуть.Свернуть("ТС");
	
	ТЗ_ТС = ТЗ_ТС_Свернуть.ВыгрузитьКолонку("ТС");
	
	Для Каждого СтрТС Из ТЗ_ТС Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("ТС",СтрТС);
		
		МассивДанных = ТЗ_Геозоны.НайтиСтроки(Отбор);
		
		//Переведем из массива в ТЗ
		НоваяТЗ.Очистить();
		
		Для Каждого СтрМ Из МассивДанных Цикл
			НоваяСтрока = НоваяТЗ.Добавить();
			
			
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрМ);			
		КонецЦикла;
		
		Для Каждого СтрТЗ Из НоваяТЗ Цикл
			ИндексТекСтроки = НоваяТЗ.Индекс(СтрТЗ);
			ВсегоСтрок		= НоваяТЗ.Количество();
			
			ПредСтрока = ?(ИндексТекСтроки, НоваяТЗ[ИндексТекСтроки-1], Неопределено);
			
			СледСтрока = ?(ИндексТекСтроки < ВсегоСтрок-1, НоваяТЗ[ИндексТекСтроки+1], Неопределено);
			
			ПУ = "";
			
			//если нет месторождения, куста и заполнена база значит машина выехала с базы тобишь с ПУ
			//определим ПУ и дальше заполним его по маршруту
			Если (СтрТЗ.Месторождение = Справочники.GDS_Месторождения.ПустаяСсылка()  
				или СтрТЗ.Куст = Справочники.GDS_Кусты.ПустаяСсылка()) 
				и СтрТЗ.База <> "" Тогда
					
				ПУ = ОпределениеПУ(СтрТЗ.База);
				
				НоваяТЗ[ИндексТекСтроки].ПУ = ПУ;
				
			Иначе	
				Если ПредСтрока <> Неопределено
						И ПредСтрока.ПУ <> Справочники.уатКолонны.ПустаяСсылка() Тогда	
					
					НоваяТЗ[ИндексТекСтроки].ПУ = ПредСтрока.ПУ;					
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;
		
		//дополним данными эталонную ТЧ
		сс="";
		
		Для Каждого СтрокаТЗ Из НоваяТЗ Цикл
	
			Отбор = Новый Структура;
			Отбор.Вставить("НомерСтроки",СтрокаТЗ.НомерСтроки);
			
			СтрокаПоиска = Объект.ТЧ.НайтиСтроки(Отбор);
			
			СтрокаПоиска[0].ПУ = СтрокаТЗ.ПУ;
			
		КонецЦикла;
		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Функция ОпределениеПУ(База)
	ПУ = "";
	
	Если СтрНайти(База,"База ЗАО СП МеКаМинефть") > 0 Тогда
		
		ДлинаБазы = СтрДлина("База ЗАО СП МеКаМинефть");
		
		ПолучилиГород = СокрЛП(Сред(База,ДлинаБазы+1));
		
		Если ПолучилиГород = "г.Советский" Тогда
			ПУ = Справочники.уатКолонны.НайтиПоКоду("000000044");//ПУ 23 Урай (ГРП)
		ИначеЕсли ПолучилиГород = "г.Бузулук" Тогда
			ПУ = Справочники.уатКолонны.НайтиПоКоду("000000048");//ПУ 20 г. Оренбург
		ИначеЕсли ПолучилиГород = "г.Лангепас" Тогда
			ПУ = Справочники.уатКолонны.НайтиПоКоду("000000046");//ПУ 25 Лангепас (ГРП)
		ИначеЕсли ПолучилиГород = "г.Оренбург" Тогда
			ПУ = Справочники.уатКолонны.НайтиПоКоду("000000048");//ПУ 20 г. Оренбург
		ИначеЕсли ПолучилиГород = "г.Оса" Тогда
			ПУ = Справочники.уатКолонны.НайтиПоКоду("000000043");//ПУ 22 Пермь (ГРП)
		ИначеЕсли ПолучилиГород = "г.Пыть - Ях" Тогда
