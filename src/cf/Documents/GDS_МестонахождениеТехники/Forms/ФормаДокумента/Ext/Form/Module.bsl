&НаКлиенте
Процедура НачатьЗагрузку()
	
	ДиалогВыбора=Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Заголовок = "Выберите файл с данными ";
	ДиалогВыбора.МножественныйВыбор = Ложь;
	ДиалогВыбора.ПроверятьСуществованиеФайла = Истина;
	ДиалогВыбора.Фильтр = "Excel (*.xls, *.xlsx)|*.xls*|Все файлы (*.*)|*.*";
	
	Если ДиалогВыбора.Выбрать() Тогда
		ФайлExcel = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
	
	Двоичные = Новый ДвоичныеДанные(ФайлExcel);
	Адрес = ПоместитьВоВременноеХранилище(Двоичные, ЭтаФорма.УникальныйИдентификатор);
	
	ОчиститьСообщения();
	
	ЗагрузкаИнформацииНаСервере(Адрес);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибки(Команда)
	
	Если Объект.ТЧ.Количество()>0 Тогда
		
		Отбор = Новый Структура("ЕстьОшибки",Истина);
		МассивСтрок = Объект.ТЧ.НайтиСтроки(Отбор);
		
		Если МассивСтрок.Количество() >0 Тогда
			МассивОшибок = Новый Массив;
			Для каждого СтрМ Из МассивСтрок Цикл
				МассивОшибок.Добавить(СтрМ.ОписаниеОшибки);
			КонецЦикла;
			
			СтрСоеденим = СтрСоединить(МассивОшибок, "/");
			Ошибки = СтрЗаменить(СтрСоеденим,"/",Символы.ПС);
		Иначе
			Сообщить("Ошибок не обнаружено");
		КонецЕсли;
	Иначе
		Сообщить("Сначала необходимо загрузить информацию по геозонам!");
	КонецЕсли;
	
	Если Ошибки <> Неопределено Тогда
		ПоказатьЗначение(, Ошибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВБухгалтерию(Команда)
	
	Если Объект.ТЧ.Количество() > 0 Тогда
		ОписаниеОповещение = Новый ОписаниеОповещения("ОтправитьЗавершение", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещение,"Вы действительно хотите отправить в бухгалтерию?",РежимДиалогаВопрос.ДаНет,,,"Внимание!");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьЗавершение(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	                                            
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если НЕ Объект.Проведен Тогда
			ПоказатьПредупреждение(,"Перед отправкой необходимо провести документ!",,"Внимание!!!");
			Возврат;
		КонецЕсли;
		
		Если ПроверимПустыеСсылкиТС() Тогда
			ПоказатьПредупреждение(,"Перед отправкой необходимо заполнить ТС!",,"Внимание!!!");
			Возврат;	
		КонецЕсли;
		
		Если ПроверимПустыеТС() Тогда
			ПоказатьПредупреждение(,"Перед отправкой необходимо заполнить ТС!",,"Внимание!!!");
			Возврат;	
		КонецЕсли;
				
		ОтправитьВБухгалтериюНаСервере();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьВБухгалтериюНаСервере()
	

	СоединениеWS = GDS_ФункцииОбмена.ПолучитьДанныеОWS_БП();
	
	ТекстОшибки = "";
	
	XML_Строка = GDS_ФункцииОбмена.СерилизацияДокумента(Объект);
	
	Данные = Новый ХранилищеЗначения(XML_Строка, Новый СжатиеДанных(9));
	
	Попытка
		Результат = СоединениеWS.ПринятьДанные(Данные,ТекстОшибки);
	Исключение
	КонецПопытки;
	
	если Результат <> 1 ИЛИ Результат <> Истина тогда
		Сообщить("Не удалось выгрузить документ Местонахождение техники из УАТ",СтатусСообщения.ОченьВажное);
	Иначе
		Объект.Отправлен = Истина;
		Записать();
	конецЕсли;

	
КонецПроцедуры

