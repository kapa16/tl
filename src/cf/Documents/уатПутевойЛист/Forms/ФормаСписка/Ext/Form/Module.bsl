	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДополнительныеПараметры)
		И ТипЗнч(ДополнительныеПараметры) = Тип("ДокументСсылка.уатПутевойЛист") Тогда 
		УстановитьСтатусБезОткрытияФормы(ДополнительныеПараметры, РезультатЗакрытия.Статус, РезультатЗакрытия.ДатаУстановки);
