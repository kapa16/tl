
#Область ПеременныеФормы

&НаКлиенте
Перем СостоянияПодписейПЛ;

&НаКлиенте
Перем СоответвиеПЛЭД;

&НаКлиенте
Перем мсвПутевыхЛистов;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		АвтоТест = Истина;
	КонецЕсли;
	
	Если Параметры.Свойство("мсвДокументы") Тогда 
		Для Каждого ТекДокумент Из Параметры.мсвДокументы Цикл
			НоваяСтрока = СписокПЛ.Добавить();
			НоваяСтрока.ПутевойЛист = ТекДокумент;
		КонецЦикла; 
		ГрупповоеПодписаниеПЛ = СписокПЛ.Количество() > 1;
	КонецЕсли; 
	Элементы.СписокПЛ.Видимость = ГрупповоеПодписаниеПЛ;
	
	Элементы.КартинкаШаг1.Доступность = Ложь;
	Элементы.Шаг1.Доступность         = Ложь;
	Элементы.КартинкаШаг2.Доступность = Ложь;
	Элементы.Шаг2.Доступность         = Ложь;
	Элементы.КартинкаШаг3.Доступность = Ложь;
	Элементы.Шаг3.Доступность         = Ложь;
	Элементы.КартинкаШаг4.Доступность = Ложь;
	Элементы.Шаг4.Доступность         = Ложь;
	Элементы.КартинкаШаг5.Доступность = Ложь;
	Элементы.Шаг5.Доступность         = Ложь;
	Элементы.КартинкаШаг6.Доступность = Ложь;
	Элементы.Шаг6.Доступность         = Ложь;
	
	Если Параметры.Свойство("Подпись") Тогда
		
		Если Параметры.Представление = "Медработник" Тогда
			Если (Параметры.Свойство("ВидКонтроля")
				И Параметры.ВидКонтроля = Перечисления.уатВидыКонтроляТранспортныхДокументов.Предрейсовый)
				ИЛИ НЕ Параметры.Свойство("ВидКонтроля") Тогда
				
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "МедработникВодитель1";
				
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "МедработникВодитель2";  
				
				Элементы.КартинкаШаг2.Доступность = Истина;
				Элементы.Шаг2.Доступность         = Истина;
			КонецЕсли;
			Если (Параметры.Свойство("ВидКонтроля")
				И Параметры.ВидКонтроля = Перечисления.уатВидыКонтроляТранспортныхДокументов.Послерейсовый)
				ИЛИ НЕ Параметры.Свойство("ВидКонтроля") Тогда
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "МедработникЗаездВодитель1";
				
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "МедработникЗаездВодитель2";
				
				Элементы.КартинкаШаг6.Доступность = Истина;
				Элементы.Шаг6.Доступность         = Истина;
			КонецЕсли;

		ИначеЕсли Параметры.Представление = "Ответственный за состояние ТС" Тогда  
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
			НоваяСтрока.Подпись       = Параметры.Подпись;
			
			Элементы.КартинкаШаг3.Доступность = Истина;
			Элементы.Шаг3.Доступность         = Истина;
		Иначе   
			Если (Параметры.Свойство("ВидКонтроля")
				И Параметры.ВидКонтроля = Перечисления.уатВидыКонтроляТранспортныхДокументов.Предрейсовый)
				ИЛИ НЕ Параметры.Свойство("ВидКонтроля") Тогда
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "УполномоченныйНаПроставлениеОдометраВыезд"; 
				Элементы.КартинкаШаг4.Доступность = Истина;
				Элементы.Шаг4.Доступность         = Истина;
			КонецЕсли;
			
			Если (Параметры.Свойство("ВидКонтроля")
				И Параметры.ВидКонтроля = Перечисления.уатВидыКонтроляТранспортныхДокументов.Послерейсовый)
				ИЛИ НЕ Параметры.Свойство("ВидКонтроля") Тогда
				НоваяСтрока = СписокПодписей.Добавить();
				НоваяСтрока.Пометка       = Ложь;
				НоваяСтрока.Представление = ?(Параметры.Свойство("Представление"), Параметры.Представление, Параметры.Подпись);
				НоваяСтрока.Подпись       = "УполномоченныйНаПроставлениеОдометраЗаезд"; 
				Элементы.КартинкаШаг5.Доступность = Истина;
				Элементы.Шаг5.Доступность         = Истина;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ПолныеПрава = РольДоступна(Метаданные.Роли.ПолныеПрава);
		Если ПолныеПрава
			ИЛИ ПравоДоступа("Редактирование", Метаданные.Документы.уатПутевойЛист) Тогда
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Диспетчер";
			НоваяСтрока.Подпись       = "Диспетчер";

			Элементы.КартинкаШаг1.Доступность = Истина;
			Элементы.Шаг1.Доступность         = Истина;
		КонецЕсли;
		
		Если ПолныеПрава
			ИЛИ уатЖурналыТранспортныхДокументов.ТекущийПользовательМедработник() Тогда
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Медработник";
			НоваяСтрока.Подпись       = "МедработникВодитель1"; 
			
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Медработник";
			НоваяСтрока.Подпись       = "МедработникВодитель2"; 
			
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Медработник";
			НоваяСтрока.Подпись       = "МедработникЗаездВодитель1";
			
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Медработник";
			НоваяСтрока.Подпись       = "МедработникЗаездВодитель2";
			
			Элементы.КартинкаШаг2.Доступность = Истина;
			Элементы.Шаг2.Доступность         = Истина;
			Элементы.КартинкаШаг6.Доступность = Истина;
			Элементы.Шаг6.Доступность         = Истина;
		КонецЕсли;
		
		Если ПолныеПрава
			ИЛИ уатЖурналыТранспортныхДокументов.ТекущийПользовательКонтролерТС() Тогда
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Ответственный за состояние ТС";
			НоваяСтрока.Подпись       = "Контролер";
			
			Элементы.КартинкаШаг3.Доступность = Истина;
			Элементы.Шаг3.Доступность         = Истина;
		КонецЕсли; 
		
		Если ПолныеПрава
			ИЛИ уатЖурналыТранспортныхДокументов.ТекущийПользовательУполномоченныйНаПроставлениеОдометра() Тогда
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Уполномоченный на проставление одометра";
			НоваяСтрока.Подпись       = "УполномоченныйНаПроставлениеОдометраВыезд";
			
			НоваяСтрока = СписокПодписей.Добавить();
			НоваяСтрока.Пометка       = Ложь;
			НоваяСтрока.Представление = "Уполномоченный на проставление одометра";
			НоваяСтрока.Подпись       = "УполномоченныйНаПроставлениеОдометраЗаезд";

			Элементы.КартинкаШаг4.Доступность = Истина;
			Элементы.Шаг4.Доступность         = Истина;
			Элементы.КартинкаШаг5.Доступность = Истина;
			Элементы.Шаг5.Доступность         = Истина;
		КонецЕсли; 
	КонецЕсли;

	флЖТД = ПолучитьФункциональнуюОпцию("уатИспользоватьЖурналыТранспортныхДокументов");
	флЭД  = ПолучитьФункциональнуюОпцию("ИспользоватьОбменЭД"); 
	
	//ЭтотОбъект.Высота = ?(ГрупповоеПодписаниеПЛ, 40, 25); 

	Элементы.ГруппаОжиданиеСинхронизации.Видимость = Ложь;
	ЗаголовокОперации = Нстр("ru = 'Ожидается отправка данных в сервисы 1С-ЭДО. Пожалуйста, подождите.'");

	ИмяПользователя = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	Если ПравоДоступа("СохранениеДанныхПользователя", Метаданные) Тогда
		ХранилищеСистемныхНастроек.Удалить("Документ.уатПутевойЛист.Форма.ФормаПодписейОтвЛица", "", ИмяПользователя);
	КонецЕсли;
	КлючСохраненияПоложенияОкна = Строка(Новый УникальныйИдентификатор);

	Если ГрупповоеПодписаниеПЛ Тогда
		Элементы.ТитулМедосмотрВодитель1.Видимость      = Ложь;
		Элементы.ТитулМедосмотрВодитель2.Видимость      = Ложь;
		Элементы.ТитулМедосмотрЗаездВодитель1.Видимость = Ложь;
		Элементы.ТитулМедосмотрЗаездВодитель2.Видимость = Ложь; 
		Элементы.ГруппаМедосмотрВодитель1.ОтображатьЗаголовок      = Истина;
		Элементы.ГруппаМедосмотрВодитель2.ОтображатьЗаголовок      = Истина;
		Элементы.ГруппаМедосмотрЗаездВодитель1.ОтображатьЗаголовок = Истина;
		Элементы.ГруппаМедосмотрЗаездВодитель2.ОтображатьЗаголовок = Истина;
	ИначеЕсли СписокПЛ.Количество() <> 0 Тогда
		ТитулМедосмотрВодитель1 = СписокПЛ[0].ПутевойЛист.Водитель1;
		ТитулМедосмотрВодитель2 = СписокПЛ[0].ПутевойЛист.Водитель2;
		ТитулМедосмотрЗаездВодитель1 = ТитулМедосмотрВодитель1;
		ТитулМедосмотрЗаездВодитель2 = ТитулМедосмотрВодитель2;  
		
		СозданныеДокументы = уатЖурналыТранспортныхДокументов.СозданныеДокументыМедосмотраПоПЛ(СписокПЛ[0].ПутевойЛист);
		СозданныйДокумент  = СозданныеДокументы.Предрейсовый1;
		Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
			ТитулМедосмотрЗаключение1 = СозданныйДокумент.Заключение;
		КонецЕсли;
		СозданныйДокумент  = СозданныеДокументы.Послерейсовый1;
		Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
			ТитулМедосмотрЗаездЗаключение1 = СозданныйДокумент.Заключение;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ТитулМедосмотрВодитель2) Тогда
			Элементы.ГруппаМедосмотрВодитель2.Видимость      = Ложь;
			Элементы.ГруппаМедосмотрЗаездВодитель2.Видимость = Ложь;
		Иначе 
			СозданныйДокумент  = СозданныеДокументы.Предрейсовый2;
			Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
				ТитулМедосмотрЗаключение2 = СозданныйДокумент.Заключение;
			КонецЕсли; 
			СозданныйДокумент  = СозданныеДокументы.Послерейсовый2;
			Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
				ТитулМедосмотрЗаездЗаключение2 = СозданныйДокумент.Заключение;
			КонецЕсли;
		КонецЕсли;
		Если Параметры.Свойство("Водитель") Тогда
			Если Параметры.Водитель = ТитулМедосмотрВодитель1 Тогда
				Элементы.ГруппаМедосмотрВодитель1.Видимость      = Истина;
				Элементы.ГруппаМедосмотрЗаездВодитель1.Видимость = Истина;
				Элементы.ГруппаМедосмотрВодитель2.Видимость      = Ложь;
				Элементы.ГруппаМедосмотрЗаездВодитель2.Видимость = Ложь;
			Иначе
				Элементы.ГруппаМедосмотрВодитель1.Видимость      = Ложь;
				Элементы.ГруппаМедосмотрЗаездВодитель1.Видимость = Ложь;
				Элементы.ГруппаМедосмотрВодитель2.Видимость      = Истина;
				Элементы.ГруппаМедосмотрЗаездВодитель2.Видимость = Истина;
			Конецесли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	мсвПутевыхЛистов = ПолучитьМсвПутевыхЛистов();
	ЗаполнитьСостоянияПЛ(мсвПутевыхЛистов, СостоянияПодписейПЛ, СоответвиеПЛЭД);
	ЗаполнитьДоступностьДляПодписания();
	УставновитьТекущийШаг();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Подписать(Команда)
	
	ПроставитьОтметкиДляПодписания();
	ТребуетсяПодписание = СписокПодписей.НайтиСтроки(Новый Структура("Пометка", Истина)).Количество() <> 0;
	Если НЕ ТребуетсяПодписание Тогда 
		ПоказатьПредупреждение(Неопределено,
			НСтр("ru = 'Не выбраны титулы для подписания!'; en = 'No titles selected for signing!'"), 10);
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекСтрока Из СписокПодписей Цикл
		ТекСтрока.Выполнено = Ложь;
	КонецЦикла;
	
	Если флЭД Тогда
		ВыполнитьПодписаниеТитула();
	КонецЕсли;  
	Оповестить("Запись_ДокументыЭПД");
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НадписьОшибкиЗакрытьОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ЗакрытьОшибки" Тогда
		СтандартнаяОбработка = Ложь;
		Элементы.ГруппаОшибки.Видимость = Ложь;
		Если НЕ Элементы.ГруппаКоманднаяПанель.Видимость Тогда
			Закрыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОшибкиЗаполненияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ОшибкиЗаполнения.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	Если ТекущиеДанные.Узел = "ОформительНеПодключен" Тогда 
		ПараметрыСоздания = СинхронизацияЭДОКлиент.НовыеПараметрыСозданияУчетнойЗаписи();
		ПараметрыСоздания.Организация   = ТекущиеДанные.ОбъектПерехода; 
		ПараметрыСоздания.ВладелецФормы = ЭтотОбъект;
		СинхронизацияЭДОКлиент.СоздатьУчетнуюЗапись(ПараметрыСоздания);
	Иначе
		ПоказатьЗначение(Неопределено, ТекущиеДанные.ОбъектПерехода);
	Конецесли;
КонецПроцедуры

&НаКлиенте
Процедура Шаг1Нажатие(Элемент)
	УставновитьТекущийШаг(1);
КонецПроцедуры

