			//ЭтотОбъект.Высота = ?(ГрупповоеПодписаниеПЛ, 40, 25); 
			мсвПутевыхЛистов = ПолучитьМсвПутевыхЛистов();
			ЗаполнитьСостоянияПЛ(мсвПутевыхЛистов, СостоянияПодписейПЛ, СоответвиеПЛЭД);
		КонецЕсли; 
		ЗаполнитьДоступностьДляПодписания();
		УставновитьТекущийШаг(3);
	ИначеЕсли ТребуетсяПодписьУполномоченногоВыезд
		ИЛИ ТребуетсяПодписьУполномоченногоЗаезд Тогда
		Если ТребуетсяПодписьУполномоченногоВыезд Тогда
			ПодписьУполномоченногоВыезд[0].Выполнено = Истина; 
			Элементы.ДекорацияНадпись.Заголовок = ЗаголовокОперации + Символы.ПС + НСтр("ru = 'Выполняется формирование титула ""Показания одометра (выезд)"".'; en = 'The title ""Odometer readings (departure)"" is being generated.'");
			
			ТекущийШаг = "УполномоченныйНаПроставлениеОдометраВыезд"; 
		Иначе
			ПодписьУполномоченногоЗаезд[0].Выполнено = Истина; 
			Элементы.ДекорацияНадпись.Заголовок = ЗаголовокОперации + Символы.ПС + НСтр("ru = 'Выполняется формирование титула ""Показания одометра (заезд)"".'; en = 'The title ""Odometer readings (trip)"" is being generated.'");
			
			ТекущийШаг = "УполномоченныйНаПроставлениеОдометраЗаезд";
		КонецЕсли;
		
		уатОбменСГИСЭПДКлиент.ПодписатьТитулЭПЛ(ЭтотОбъект, мсвПутевыхЛистов, ТекущийШаг, "Показания одометра",
		СостоянияПодписейПЛ, СоответвиеПЛЭД, ОшибкиЗаполнения, ЕстьОшибки, РезультатПроведения); 
		Если НЕ ЕстьОшибки Тогда
			ОповеститьОбИзменении(Тип("ДокументСсылка.уатПутевойЛист"));
			ОповеститьОбИзменении(Тип("ДокументСсылка.уатЖурналУчетаПоказанийОдометра"));
			ОповеститьОбИзменении(Тип("РегистрСведенийКлючЗаписи.уатСвязанныеДокументыЭПД"));
			Оповестить("Запись_ДокументыЭПД", мсвПутевыхЛистов);
		Иначе
			Элементы.ГруппаОжиданиеСинхронизации.Видимость = Ложь;
			Элементы.ГруппаОшибки.Видимость                = Истина; 
			//ЭтотОбъект.Высота = ?(ГрупповоеПодписаниеПЛ, 40, 25);
			мсвПутевыхЛистов = ПолучитьМсвПутевыхЛистов();
			ЗаполнитьСостоянияПЛ(мсвПутевыхЛистов, СостоянияПодписейПЛ, СоответвиеПЛЭД);
		КонецЕсли; 
		ЗаполнитьДоступностьДляПодписания();
		Если ТребуетсяПодписьУполномоченногоВыезд Тогда
			УставновитьТекущийШаг(4);
		Иначе
			УставновитьТекущийШаг(5);
		КонецЕсли;
	ИначеЕсли ТребуетсяПодписьМедработникаЗаездВодитель1 
		ИЛИ ТребуетсяПодписьМедработникаЗаездВодитель2 Тогда  
		
		РезультатПроведения = Новый Структура();
		Если ТребуетсяПодписьМедработникаЗаездВодитель1 Тогда
			ПодписьМедработникаЗаездВодитель1[0].Выполнено = Истина; 
			Если ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1" Тогда
				РезультатПроведения.Вставить("РезультатПроведенияОсмотра", ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Пройдено"));
			Иначе
				РезультатПроведения.Вставить("РезультатПроведенияОсмотра", ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.ОтменаРейса"));
			КонецЕсли;
			РезультатПроведения.Вставить("Заключение", ТитулМедосмотрЗаключение1); 
			
			ТекущийШаг = "МедработникЗаездВодитель1";
		Иначе 
			ПодписьМедработникаЗаездВодитель2[0].Выполнено = Истина;
			Если ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1" Тогда
				РезультатПроведения.Вставить("РезультатПроведенияОсмотра", ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Пройдено"));
			Иначе
				РезультатПроведения.Вставить("РезультатПроведенияОсмотра", ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.ОтменаРейса"));
			КонецЕсли;
			РезультатПроведения.Вставить("Заключение", ТитулМедосмотрЗаключение2);
			
			ТекущийШаг = "МедработникЗаездВодитель2";
		КонецЕсли;
		Элементы.ДекорацияНадпись.Заголовок = ЗаголовокОперации + Символы.ПС 
			+ НСтр("ru = 'Выполняется формирование титула ""Медосмотр""'; en = 'The title ""Medical Examination"" is being formed'") + " " + ?(ТекущийШаг = "МедработникЗаездВодитель2", "Водитель 2.", "Водитель 1.");
		
		уатОбменСГИСЭПДКлиент.ПодписатьТитулЭПЛ(ЭтотОбъект, мсвПутевыхЛистов, ТекущийШаг, "Медосмотр",
		СостоянияПодписейПЛ, СоответвиеПЛЭД, ОшибкиЗаполнения, ЕстьОшибки, РезультатПроведения);
		Если НЕ ЕстьОшибки Тогда
			ОповеститьОбИзменении(Тип("ДокументСсылка.уатПутевойЛист"));
			ОповеститьОбИзменении(Тип("ДокументСсылка.уатЖурналМедицинскогоОсмотраВодителей"));
			ОповеститьОбИзменении(Тип("РегистрСведенийКлючЗаписи.уатСвязанныеДокументыЭПД"));
			Оповестить("Запись_ДокументыЭПД", мсвПутевыхЛистов);
		Иначе  
			Элементы.ГруппаОжиданиеСинхронизации.Видимость = Ложь;
			Элементы.ГруппаОшибки.Видимость                = Истина; 
			//ЭтотОбъект.Высота = ?(ГрупповоеПодписаниеПЛ, 40, 25);
			мсвПутевыхЛистов = ПолучитьМсвПутевыхЛистов();
			ЗаполнитьСостоянияПЛ(мсвПутевыхЛистов, СостоянияПодписейПЛ, СоответвиеПЛЭД);
		КонецЕсли;
		ЗаполнитьДоступностьДляПодписания();
		УставновитьТекущийШаг(6);
	Иначе 
		ОповеститьОбИзменении(Тип("ДокументСсылка.уатПутевойЛист"));
		ОповеститьОбИзменении(Тип("РегистрСведенийКлючЗаписи.уатСвязанныеДокументыЭПД"));
		Оповестить("Запись_ДокументыЭПД", мсвПутевыхЛистов);
		Элементы.ГруппаОжиданиеСинхронизации.Видимость = Ложь; 
		Попытка
			Закрыть();
		Исключение
		КонецПопытки;
	Конецесли; 
Конецпроцедуры

&НаСервере
Функция ПолучитьМсвПутевыхЛистов() 
	мсвПутевыхЛистов = СписокПЛ.Выгрузить().ВыгрузитьКолонку("ПутевойЛист");
	Возврат мсвПутевыхЛистов;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьДоступностьДляПодписания() 
	ЕстьЭПЛ_Титул1 = Ложь;
	ЕстьЭПЛ_Титул2 = Ложь;
	ЕстьЭПЛ_Титул3 = Ложь;
	ЕстьЭПЛ_Титул4 = Ложь;
	ЕстьЭПЛ_Титул5 = Ложь;
	ЕстьЭПЛ_Титул6 = Ложь; 
	
	КолВоВсего  = СписокПЛ.Количество();
	КолВоТитул1 = 0;
	КолВоТитул2 = 0;
	КолВоТитул3 = 0;
	КолВоТитул4 = 0;
	КолВоТитул5 = 0;
	КолВоТитул6 = 0; 
	ОбязательныйПослерейсовыйМедосмотр = Ложь;
	Для Каждого ТекСтрока Из СписокПЛ Цикл
		
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул1 = Ложь;
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул2 = Ложь;
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул3 = Ложь;
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул4 = Ложь;
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул5 = Ложь;
		ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул6 = Ложь;
		
		ТекПЛ = ТекСтрока.ПутевойЛист;
		
		СостояниеПодписейПЛ = СостоянияПодписейПЛ.Получить(ТекПЛ);
		ДанныеЭПЛ           = СоответвиеПЛЭД.Получить(ТекПЛ); 
		ЕстьЭПЛ             = ДанныеЭПЛ <> Неопределено;
		Если ЕстьЭПЛ Тогда
			ТекЭПЛ = ДанныеЭПЛ.ЭПЛ; 
			
			Если НЕ ДанныеЭПЛ.Титул2Подписан И ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 1)
				И НЕ ДанныеЭПЛ.Титул1Подписан Тогда
				ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул1 = Истина;
			КонецЕсли;
			Если ДанныеЭПЛ.Титул1Подписан Тогда
				КолВоТитул1 = КолВоТитул1 + 1;
			КонецЕсли;
			
			Если ДанныеЭПЛ.ОтменаРейса Тогда 
				Если НЕ ГрупповоеПодписаниеПЛ Тогда
					ТитулМедосмотрРезультатПроведенияМедосмотраВодитель1 = "2";
					Элементы.ГруппаМедосмотрВодитель1.Доступность = Ложь; 
					ТитулМедосмотрРезультатПроведенияМедосмотраВодитель2 = "2";
					Элементы.ГруппаМедосмотрВодитель2.Доступность = Ложь; 
					ОтменаРейса = Истина;
				КонецЕсли;
				Продолжить;
			КонецЕсли;
			
			Если ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 2) Тогда 
				Если НЕ (ДанныеЭПЛ.Титул2Подписан И ДанныеЭПЛ.Титул2Водитель2Подписан) Тогда
					ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул2 = Истина;
					Если НЕ ГрупповоеПодписаниеПЛ Тогда
						Если ДанныеЭПЛ.Титул2Подписан Тогда
							ТитулМедосмотрРезультатПроведенияМедосмотраВодитель1 = ?(ДанныеЭПЛ.ОтменаРейса, "2", "1");
							Элементы.ГруппаМедосмотрВодитель1.Доступность = Ложь;
						КонецЕсли;
						Если ДанныеЭПЛ.Титул2Водитель2Подписан
							И ЗначениеЗаполнено(ДанныеЭПЛ.Титул2Водитель2) Тогда
							ТитулМедосмотрРезультатПроведенияМедосмотраВодитель2 = ?(ДанныеЭПЛ.ОтменаРейса, "2", "1");
							Элементы.ГруппаМедосмотрВодитель2.Доступность = Ложь;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если НЕ (ДанныеЭПЛ.Титул6Подписан И ДанныеЭПЛ.Титул6Водитель2Подписан) Тогда 
					текОбязательныйПослерейсовыйМедосмотр   = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекПЛ, "ОбязательныйПослерейсовыйМедосмотр") = Истина;
					ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул6 = текОбязательныйПослерейсовыйМедосмотр;
					
					ОбязательныйПослерейсовыйМедосмотр = Макс(текОбязательныйПослерейсовыйМедосмотр, ОбязательныйПослерейсовыйМедосмотр);
					Если НЕ ГрупповоеПодписаниеПЛ Тогда
						Если ДанныеЭПЛ.Титул6Подписан Тогда
							ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1";
							Элементы.ГруппаМедосмотрЗаездВодитель1.Доступность = Ложь;
						КонецЕсли;
						Если ДанныеЭПЛ.Титул6Водитель2Подписан Тогда
							ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1";
							Элементы.ГруппаМедосмотрЗаездВодитель2.Доступность = Ложь;
						КонецЕсли;
					КонецЕсли;  
				Иначе
					текОбязательныйПослерейсовыйМедосмотр = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекПЛ, "ОбязательныйПослерейсовыйМедосмотр") = Истина;
					ОбязательныйПослерейсовыйМедосмотр    = Макс(текОбязательныйПослерейсовыйМедосмотр, ОбязательныйПослерейсовыйМедосмотр);
					
					Если НЕ ГрупповоеПодписаниеПЛ Тогда
						Если ДанныеЭПЛ.Титул6Подписан Тогда
							ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1";
							Элементы.ГруппаМедосмотрЗаездВодитель1.Доступность = Ложь;
						КонецЕсли;
						Если ДанныеЭПЛ.Титул6Водитель2Подписан Тогда
							ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1";
							Элементы.ГруппаМедосмотрЗаездВодитель2.Доступность = Ложь;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
			Если ДанныеЭПЛ.Титул2Подписан И ДанныеЭПЛ.Титул2Водитель2Подписан Тогда
				КолВоТитул2 = КолВоТитул2 + 1;
			КонецЕсли; 
			Если ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 4) 
				И НЕ ДанныеЭПЛ.Титул3Подписан Тогда
				ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул3 = Истина; 
			КонецЕсли;
			Если ДанныеЭПЛ.ТитулВыпускРезультатПроведенияПредсменногоКонтроля = "2" Тогда 
				Если НЕ ГрупповоеПодписаниеПЛ Тогда
					ТитулВыпускРезультатПроведенияПредсменногоКонтроля = "2";
					Элементы.ГруппаШаг3.Доступность = Ложь; 
				КонецЕсли;
				Продолжить;
			КонецЕсли;
			Если ДанныеЭПЛ.Титул3Подписан Тогда
				КолВоТитул3 = КолВоТитул3 + 1;
			КонецЕсли;


			Если ДанныеЭПЛ.Титул6Подписан И ДанныеЭПЛ.Титул6Водитель2Подписан Тогда
				КолВоТитул6 = КолВоТитул6 + 1;
			КонецЕсли;
			
			Если ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 8) Тогда 
				Если НЕ ДанныеЭПЛ.Титул4Подписан Тогда
					ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул4 = Истина;
				КонецЕсли; 
				Если НЕ ДанныеЭПЛ.Титул5Подписан Тогда
					ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул5 = Истина;
				КонецЕсли;
			КонецЕсли; 
			Если ДанныеЭПЛ.Титул4Подписан Тогда
				КолВоТитул4 = КолВоТитул4 + 1;
			КонецЕсли;
			Если ДанныеЭПЛ.Титул5Подписан Тогда
				КолВоТитул5 = КолВоТитул5 + 1;
			КонецЕсли;
			
		Иначе
			ТекЭПЛ = Неопределено; 
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул1 = Истина;  
			
			ДанныеТекПЛ = уатОбщегоНазначенияТиповые.ПолучитьЗначенияРеквизитов(ТекПЛ, "Медорганизация, КонтрольТранспорта");
			
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул2 = НЕ ЗначениеЗаполнено(ДанныеТекПЛ.Медорганизация);
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул3 = НЕ ЗначениеЗаполнено(ДанныеТекПЛ.КонтрольТранспорта);
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул4 = Истина;
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул5 = Истина; 
			
			текОбязательныйПослерейсовыйМедосмотр   = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ТекПЛ, "ОбязательныйПослерейсовыйМедосмотр") = Истина;
			ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул6 = текОбязательныйПослерейсовыйМедосмотр;
			
			ОбязательныйПослерейсовыйМедосмотр = Макс(текОбязательныйПослерейсовыйМедосмотр, ОбязательныйПослерейсовыйМедосмотр);
		КонецЕсли;
		
		ЕстьЭПЛ_Титул1 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул1, ЕстьЭПЛ_Титул1);
		ЕстьЭПЛ_Титул2 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул2, ЕстьЭПЛ_Титул2);
		ЕстьЭПЛ_Титул3 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул3, ЕстьЭПЛ_Титул3);
		ЕстьЭПЛ_Титул4 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул4, ЕстьЭПЛ_Титул4);
		ЕстьЭПЛ_Титул5 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул5, ЕстьЭПЛ_Титул5);
		ЕстьЭПЛ_Титул6 = Макс(ТекСтрока.ДоступенКПодписаниюЭПЛ_Титул6, ЕстьЭПЛ_Титул6);
	КонецЦикла;
	
	Элементы.КартинкаШаг1.Картинка = ?(Элементы.КартинкаШаг1.Доступность И ЕстьЭПЛ_Титул1,
		?(флОформление, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул1 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД));
	Элементы.КартинкаШаг1.Доступность = Элементы.КартинкаШаг1.Доступность И ЕстьЭПЛ_Титул1;
	
	Элементы.КартинкаШаг2.Картинка = ?(Элементы.КартинкаШаг2.Доступность И ЕстьЭПЛ_Титул2,
		?(ЗначениеЗаполнено(ТитулМедосмотрРезультатПроведенияМедосмотраВодитель1)
		ИЛИ ЗначениеЗаполнено(ТитулМедосмотрРезультатПроведенияМедосмотраВодитель2),
		БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул2 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД));
	Элементы.КартинкаШаг2.Доступность = Элементы.КартинкаШаг2.Доступность И ЕстьЭПЛ_Титул2;
	
	Элементы.КартинкаШаг3.Картинка = ?(Элементы.КартинкаШаг3.Доступность И ЕстьЭПЛ_Титул3,
		?(ТитулВыпускРезультатПроведенияПредсменногоКонтроля = "1",
		БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул3 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД)); 
 	Элементы.КартинкаШаг3.Доступность = Элементы.КартинкаШаг3.Доступность И ЕстьЭПЛ_Титул3;
	
	Элементы.КартинкаШаг4.Картинка = ?(Элементы.КартинкаШаг4.Доступность И ЕстьЭПЛ_Титул4,
		?(флПоказанияВыезд,
		БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул4 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД)); 
	Элементы.КартинкаШаг4.Доступность  = Элементы.КартинкаШаг4.Доступность И ЕстьЭПЛ_Титул4;
	
	Элементы.КартинкаШаг5.Картинка = ?(Элементы.КартинкаШаг5.Доступность И ЕстьЭПЛ_Титул5,
		?(флПоказанияЗаезд,
		БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул5 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД));
	Элементы.КартинкаШаг5.Доступность  = Элементы.КартинкаШаг5.Доступность И ЕстьЭПЛ_Титул5;
	
	Если НЕ ЕстьЭПЛ_Титул6 Тогда
		Если ОбязательныйПослерейсовыйМедосмотр Тогда
			Элементы.КартинкаШаг6.Доступность     = Ложь;
			Элементы.Шаг6.Доступность             = Ложь;
			
			Элементы.КартинкаШаг6.Картинка = ?(Элементы.КартинкаШаг6.Доступность И ЕстьЭПЛ_Титул6,
			?(ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1"
			ИЛИ ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1",
			БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
			БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
			?(КолВоТитул6 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
			БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД));
		Иначе
			Элементы.КартинкаШаг6.Видимость       = Ложь;
			Элементы.Шаг6.Видимость               = Ложь;;
		КонецЕсли;
	Иначе
		Элементы.КартинкаШаг6.Картинка = ?(Элементы.КартинкаШаг6.Доступность И ЕстьЭПЛ_Титул6,
		?(ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1"
		ИЛИ ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1",
		БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйДоступныйБЭД), 
		?(КолВоТитул6 = КолВоВсего, БиблиотекаКартинок.уатНавигацияШагТекущийВыполненныйНеДоступныйБЭД,
		БиблиотекаКартинок.уатНавигацияШагТекущийНеВыполненныйНеДоступныйБЭД));
		Элементы.КартинкаШаг6.Доступность = Элементы.КартинкаШаг6.Доступность И ЕстьЭПЛ_Титул6;
		
		Элементы.КартинкаШаг6.Видимость       = Истина;
		Элементы.Шаг6.Видимость               = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УставновитьТекущийШаг(НомерШага = Неопределено)  
	ТекущийШаг = 0; 
	ЕстьШагиДляПодписания = Ложь;
	Для Счетчик = 1 По 6 Цикл 
		Если Счетчик = НомерШага Тогда
			Элементы["Шаг" + Счетчик].ЦветТекста  = Новый Цвет(0, 150, 70);
			Элементы["Шаг" + Счетчик].Гиперссылка = Ложь;
			Элементы["КартинкаШаг" + Счетчик].Гиперссылка = Ложь;
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы["ГруппаШаг" + Счетчик];
		Иначе
			Элементы["Шаг" + Счетчик].Гиперссылка = Элементы["КартинкаШаг" + Счетчик].Доступность;
			Элементы["КартинкаШаг" + Счетчик].Гиперссылка = Элементы["КартинкаШаг" + Счетчик].Доступность;
			Элементы["Шаг" + Счетчик].ЦветТекста  = ?(Элементы["КартинкаШаг" + Счетчик].Доступность, Новый Цвет(51, 51, 51), Новый Цвет(142, 142, 142));
		КонецЕсли;
		Если Элементы["КартинкаШаг" + Счетчик].Доступность 
			И НЕ ЗначениеЗаполнено(ТекущийШаг) Тогда
			ТекущийШаг = Счетчик;
			ЕстьШагиДляПодписания = Истина;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ЕстьШагиДляПодписания Тогда
		ТекущийШаг = ?(Элементы.КартинкаШаг6.Видимость, 6, 5);
	КонецЕсли;
	Если НомерШага = Неопределено
		И ЗначениеЗаполнено(ТекущийШаг) Тогда
		Если ТекущийШаг = 6 Тогда
			Если ТитулВыпускРезультатПроведенияПредсменногоКонтроля = "2" Тогда
				ТекущийШаг = 3;
			ИначеЕсли ОтменаРейса Тогда
				ТекущийШаг = 2;
			КонецЕсли; 
		КонецЕсли;
		
		Элементы["Шаг" + ТекущийШаг].ЦветТекста  = Новый Цвет(0, 150, 70);
		Элементы["Шаг" + ТекущийШаг].Гиперссылка = Ложь;
		Элементы["картинкаШаг" + ТекущийШаг].Гиперссылка = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы["ГруппаШаг" + ТекущийШаг];
	КонецЕсли; 
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг1 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул1");
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг2 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул2"); 
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг3 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул3");
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг4 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул4");
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг5 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул5"); 
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг6 Тогда
		ТекущийТитулПодписания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул6");
	КонецЕсли;
	Элементы.ГруппаШаг1.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг1;
	Элементы.ГруппаШаг2.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг2;
	Элементы.ГруппаШаг3.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг3; 
	Элементы.ГруппаШаг4.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг4;
	Элементы.ГруппаШаг5.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг5;
	Элементы.ГруппаШаг6.Видимость = Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаШаг6;

КонецПроцедуры

&НаКлиенте
Процедура ПроставитьОтметкиДляПодписания()
	
	ПодписьДиспетчера  = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "Диспетчер"));
	Если ПодписьДиспетчера.Количество() <> 0 Тогда
		ПодписьДиспетчера[0].Пометка = флОформление;
	КонецЕсли;
	ПодписьМедработникаВодитель1 = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "МедработникВодитель1"));
	Если ПодписьМедработникаВодитель1.Количество() <> 0 Тогда
		ПодписьМедработникаВодитель1[0].Пометка = ЗначениеЗаполнено(ТитулМедосмотрРезультатПроведенияМедосмотраВодитель1);
	КонецЕсли;
	Если ЗначениеЗаполнено(ТитулМедосмотрВодитель2)
		ИЛИ ГрупповоеПодписаниеПЛ Тогда
		ПодписьМедработникаВодитель2 = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "МедработникВодитель2"));
		Если ПодписьМедработникаВодитель2.Количество() <> 0 Тогда
			ПодписьМедработникаВодитель2[0].Пометка = ЗначениеЗаполнено(ТитулМедосмотрРезультатПроведенияМедосмотраВодитель2);
		КонецЕсли; 
	КонецЕсли;  
	ПодписьКонтролера  = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "Контролер"));
	Если ПодписьКонтролера.Количество() <> 0 Тогда
		ПодписьКонтролера[0].Пометка = ЗначениеЗаполнено(ТитулВыпускРезультатПроведенияПредсменногоКонтроля);
	КонецЕсли; 
	ПодписьКонтролера  = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "Контролер"));
	Если ПодписьКонтролера.Количество() <> 0 Тогда
		ПодписьКонтролера[0].Пометка = ЗначениеЗаполнено(ТитулВыпускРезультатПроведенияПредсменногоКонтроля);
	КонецЕсли;
	ПодписьУполномоченногоВыезд  = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "УполномоченныйНаПроставлениеОдометраВыезд"));
	Если ПодписьУполномоченногоВыезд.Количество() <> 0 Тогда
		ПодписьУполномоченногоВыезд[0].Пометка = флПоказанияВыезд;
	КонецЕсли;
	ПодписьУполномоченногоЗаезд  = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "УполномоченныйНаПроставлениеОдометраЗаезд"));
	Если ПодписьУполномоченногоЗаезд.Количество() <> 0 Тогда
		ПодписьУполномоченногоЗаезд[0].Пометка = флПоказанияЗаезд;
	КонецЕсли;
    ПодписьМедработникаЗаездВодитель1 = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "МедработникЗаездВодитель1"));
	Если ПодписьМедработникаЗаездВодитель1.Количество() <> 0 Тогда
		ПодписьМедработникаЗаездВодитель1[0].Пометка = ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель1 = "1";
	КонецЕсли;
	Если ЗначениеЗаполнено(ТитулМедосмотрЗаездВодитель2)
		ИЛИ ГрупповоеПодписаниеПЛ Тогда
		ПодписьМедработникаЗаездВодитель2 = СписокПодписей.НайтиСтроки(Новый Структура("Подпись", "МедработникЗаездВодитель2"));
		Если ПодписьМедработникаЗаездВодитель2.Количество() <> 0 Тогда
			ПодписьМедработникаЗаездВодитель2[0].Пометка = ТитулМедосмотрЗаездРезультатПроведенияМедосмотраВодитель2 = "1";
		КонецЕсли; 
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти