&НаКлиенте
Процедура ГрузИзДокументаПриИзменении(Элемент)
	
	ДетализацияЗаказаПриИзменении(Неопределено);
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ГрузИзДокументаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ГрузИзДокумента) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Текст) Тогда
		ДанныеВыбора = ПолучитьСписокВыбора(Текст, "Номенклатура");
		ДанныеВыбора.Добавить(Текст,,, БиблиотекаКартинок.УровеньДоступаРедактирование);
		Если ДанныеВыбора.Количество() = 0 Тогда
			СтандартнаяОбработка = Истина;
			Возврат;
		КонецЕсли;
	Иначе
		ГрузИзДокумента = Текст;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ГрузИзДокументаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Тип")
		Или ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
		ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам");
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.уатГрузовыеМеста_уэ");
	Иначе
		ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоТоварам");
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	КонецЕсли;
	
	ГрузДляПереноса = ВыбранноеЗначение;
	ГрузДляПереносаПриИзменении(Элемент);
	ГрузИзДокумента = Строка(ВыбранноеЗначение);
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентДляПереносаПриИзменении(Элемент)
	
	ДанныеОбменаССервером = Новый Структура("Организация, Контрагент, ДоговорКонтрагента, Дата, Приоритет");
	ДанныеОбменаССервером.Организация = Организация;
	ДанныеОбменаССервером.Контрагент = КонтрагентДляПереноса;
	ДанныеОбменаССервером.Дата = ДатаПотребности;
	ДанныеОбменаССервером.Приоритет = 0;
	
	ЗначенияДляЗаполнения = ИзменениеКонтрагентаСервер(ДанныеОбменаССервером);
	ДоговорДляПереноса = ЗначенияДляЗаполнения.ДоговорКонтрагента;
	ДоговорДляПереносаПриИзменении(Неопределено);
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтактноеЛицоДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктОтправленияДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	Элементы.ПунктОтправленияДляПереноса.ОбновитьТекстРедактирования();
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктПрибытияДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ГрузДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура FTLДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	Если FTLДляПереноса И ЗначениеЗаполнено(МаршрутДляПереноса) Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеИзмененияМаршрута", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Перезаполнить пункты назначения по выбранному маршруту?", РежимДиалогаВопрос.ДаНет);
	Иначе
		FTLПриИзмененииЗавершение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МультимодальныйДляПереносаПриИзменении(Элемент)
	
	УстановитьВидимость();
	СоздаватьЭтапыМультимодальнойПеревозки = ?(Не МультимодальныйДляПереноса, Ложь, СоздаватьЭтапыМультимодальнойПеревозки);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздаватьЭтапыМультимодальнойПеревозкиПриИзменении(Элемент)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорДляПереносаПриИзменении(Элемент)
	
	Объект.ДоговорКонтрагента = ДоговорДляПереноса;
	// уатУправлениеАвтотранспортом.МодификацияКонфигурации
	уатМодификацияКонфигурацииКлиентПереопределяемый.ПолеФормыПриИзменении(ЭтаФорма, ЭтаФорма.Элементы.ДоговорДляПереноса);
	// Конец уатУправлениеАвтотранспортом.МодификацияКонфигурации
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорДляПереносаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураОтбор = Новый Структура("Организация, Владелец, ВидДоговора, ПредметДоговора",
		Организация, КонтрагентДляПереноса, 
		ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"),
		ПредопределенноеЗначение("Перечисление.уатПредметыДоговоровКонтрагентов.Перевозка"));
	ПараметрыФормы = Новый Структура("ФормаВызова, Отбор", "1", СтруктураОтбор);
		
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.Форма.ФормаВыбора", ПараметрыФормы, ЭтотОбъект,,,,
		Новый ОписаниеОповещения("ДоговорКонтрагентаНачалоВыбораЗавершение", ЭтотОбъект, Элемент));
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаНачалоВыбораЗавершение(РезультатВыбора, Элемент) Экспорт

	Если РезультатВыбора <> Неопределено Тогда
		ДоговорДляПереноса = РезультатВыбора;
		ДоговорДляПереносаПриИзменении(Неопределено);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДетализацияЗаказаПриИзменении(Элемент)
	
	Если (ТипЗнч(ГрузИзДокумента) = Тип("СправочникСсылка.Номенклатура") 
		И ДетализацияЗаказа <> ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам"))
		Или (ТипЗнч(ГрузИзДокумента) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") 
		И ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам")) Тогда
		
		ГрузДляПереноса = ГрузИзДокумента;
		
	ИначеЕсли ТипЗнч(ГрузИзДокумента) = Тип("Строка") 
		И ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		
		ГрузДляПереноса = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "уатГрузовыеМеста_уэ");
		
	ИначеЕсли ТипЗнч(ГрузИзДокумента) = Тип("Строка") 
		И ДетализацияЗаказа <> ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		
		ПолученнаяСсылка = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "Номенклатура");
		Если ПолученнаяСсылка <> Неопределено Тогда
			ГрузДляПереноса = ПолученнаяСсылка;
		КонецЕсли;
		
	Иначе
		
		ГрузДляПереноса = Неопределено;
		
	КонецЕсли;
	
	Если ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.уатГрузовыеМеста_уэ");
	Иначе
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	КонецЕсли;
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутДляПереносаПриИзменении(Элемент)
	
	Если Не FTLДляПереноса Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(МаршрутДляПереноса) Тогда
		ОтрезокПути = Неопределено;
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПунктОтправленияДляПереноса) И Не ЗначениеЗаполнено(ПунктПрибытияДляПереноса) Тогда
		УстановитьДанныеПоМаршрутуСервер();
		//ПодборВремениПрибытияУбытияПоРасписанию();
	Иначе
		Оповещение = Новый ОписаниеОповещения("ПослеИзмененияМаршрута", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Перезаполнить пункты назначения по выбранному маршруту?", РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеИзмененияМаршрута(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УстановитьДанныеПоМаршрутуСервер();
	КонецЕсли;
	
	//ПодборВремениПрибытияУбытияПоРасписанию();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтрезокПутиНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(Элементы.ОтрезокПути.СписокВыбора) Тогда
		ТекстНСТР = НСтр("en='No applicable route segments found.';
			|ru='Нет подходящих отрезков пути по маршруту.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСТР);
		Возврат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

