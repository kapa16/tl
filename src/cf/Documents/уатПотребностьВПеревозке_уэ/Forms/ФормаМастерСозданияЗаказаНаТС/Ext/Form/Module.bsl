&НаСервере
Процедура ДобавитьПунктыШапкиВПромежуточныеПункты()
	
	Если ЗначениеЗаполнено(ПунктОтправленияДляПереноса) Или ЗначениеЗаполнено(КонтактноеЛицоДляПереноса) 
		Или ЗначениеЗаполнено(ОтправлениеСДляПереноса) Тогда 
		НовСтрока = ПромежуточныеПункты.Добавить();
		НовСтрока.Пункт                 = ПунктОтправленияДляПереноса;
		НовСтрока.ПунктНазначенияИмеетКоординаты = ПунктНазначенияИмеетКоординаты(НовСтрока.Пункт);
		НовСтрока.ТипТочкиМаршрута      = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Погрузка");
		НовСтрока.ОтправительПолучатель = КонтрагентДляПереноса;
		НовСтрока.КонтактноеЛицо        = КонтактноеЛицоДляПереноса;
		НовСтрока.ПрибытиеПлан          = ОтправлениеСДляПереноса;
		НовСтрока.УбытиеПлан            = ОтправлениеПоДляПереноса;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПунктПрибытияДляПереноса) Или ЗначениеЗаполнено(ПрибытиеСДляПереноса)
			Или ЗначениеЗаполнено(ПрибытиеПоДляПереноса) Тогда 
		НовСтрока = ПромежуточныеПункты.Добавить();
		НовСтрока.Пункт                 = ПунктПрибытияДляПереноса;
		НовСтрока.ПунктНазначенияИмеетКоординаты = ПунктНазначенияИмеетКоординаты(НовСтрока.Пункт);
		НовСтрока.ТипТочкиМаршрута      = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Разгрузка");
		НовСтрока.ПрибытиеПлан          = ПрибытиеСДляПереноса;
		НовСтрока.УбытиеПлан            = ПрибытиеПоДляПереноса;
	КонецЕсли;
	
	УстановитьСпискиВыбораОтрезковПути();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПунктНазначенияИмеетКоординаты(Пункт)
	Если ТипЗнч(Пункт) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда
		Возврат (ЗначениеЗаполнено(Пункт.Лат) И ЗначениеЗаполнено(Пункт.Лон));
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

&НаСервере
Процедура УстановитьДанныеПоМаршрутуСервер()
	
	Если Не ЗначениеЗаполнено(МаршрутДляПереноса) Или МаршрутДляПереноса.Этапы.Количество() = 0 Тогда 
		Если FTLДляПереноса Тогда 
			ДобавитьПунктыШапкиВПромежуточныеПункты();
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ПромежуточныеПункты.Очистить();
	
	Если FTLДляПереноса И МаршрутЗаполненКорректно(МаршрутДляПереноса) Тогда 
		
		ID = СсылкаНаПотребность.ПунктыНазначения[0].ID;
		НомерСтроки = 1;
		
		МаршрутЭтапы = МаршрутДляПереноса.Этапы;
		Если МаршрутДляПереноса.ПредставлениеМаршрутаОднимПунктом Тогда
			Если МаршрутЭтапы.Количество() Тогда
				ПунктОтправленияДляПереноса = МаршрутЭтапы[0].ПунктОтправления;
				Если МаршрутЭтапы.Количество() > 1 Тогда
					ПунктПрибытияДляПереноса  = МаршрутЭтапы[МаршрутЭтапы.Количество()-1].ПунктОтправления;
				КонецЕсли;
			КонецЕсли;
			Сч = 0;
			Для Каждого ТекСтрока Из МаршрутЭтапы Цикл
				Сч = Сч + 1;
				НовСтрока = ПромежуточныеПункты.Добавить();
				НовСтрока.НомерСтроки = НомерСтроки;
				НомерСтроки = НомерСтроки + 1;
				НовСтрока.ID = ID;
				НовСтрока.Пункт            = ТекСтрока.ПунктОтправления;
				НовСтрока.ТипТочкиМаршрута = ТекСтрока.ТипТочкиМаршрута;
				НовСтрока.ПунктНазначенияИмеетКоординаты = ПунктНазначенияИмеетКоординаты(ТекСтрока.ПунктОтправления);
				
				ВремяДоступности = уатОбщегоНазначения_проф.ПолучитьВремяДоступностиПункта(НовСтрока.Пункт,
					НовСтрока.ОтправительПолучатель);
				НовСтрока.ОкноС            = ВремяДоступности.ВремяДоступностиС;
				НовСтрока.ОкноПо           = ВремяДоступности.ВремяДоступностиПо;
				НовСтрока.ОкноПо = ?(ЗначениеЗаполнено(НовСтрока.ОкноПо), НовСтрока.ОкноПо, '00010101235900');
				
				Если МаршрутЭтапы.Количество() > 1 И Сч = МаршрутЭтапы.Количество() Тогда
					НовСтрока.Время      = 0;
					НовСтрока.Расстояние = 0;
				Иначе
					НовСтрока.Время      = ТекСтрока.ВремяВПути;
					НовСтрока.Расстояние = ТекСтрока.Расстояние;
				КонецЕсли;
				НовСтрока.Стоянка        = ПолучитьВремяСтоянкиПоУмолчанию(НовСтрока.Пункт);
			КонецЦикла;
		Иначе
			Для Сч = 0 По МаршрутЭтапы.Количество()-1 Цикл
				Если Сч = 0 Тогда 
					ПунктОтправленияДляПереноса = МаршрутЭтапы[Сч].ПунктОтправления;
				КонецЕсли;
				Если Сч = МаршрутЭтапы.Количество()-1 И ЗначениеЗаполнено(МаршрутЭтапы[Сч].ПунктПрибытия) Тогда
					ПунктПрибытияДляПереноса = МаршрутЭтапы[Сч].ПунктПрибытия;
				ИначеЕсли Сч = МаршрутЭтапы.Количество()-1 Тогда
					ПунктПрибытияДляПереноса = МаршрутЭтапы[Сч].ПунктОтправления;
				КонецЕсли;
				
				НовСтрока = ПромежуточныеПункты.Добавить();
				НовСтрока.НомерСтроки = НомерСтроки;
				НомерСтроки = НомерСтроки + 1;
				НовСтрока.ID = ID;
				НовСтрока.Пункт            = МаршрутЭтапы[Сч].ПунктОтправления;
				НовСтрока.ПунктНазначенияИмеетКоординаты = ПунктНазначенияИмеетКоординаты(НовСтрока.Пункт);

				ВремяДоступности = уатОбщегоНазначения_проф.ПолучитьВремяДоступностиПункта(НовСтрока.Пункт,
					НовСтрока.ОтправительПолучатель);
				НовСтрока.ОкноС            = ВремяДоступности.ВремяДоступностиС;
				НовСтрока.ОкноПо           = ВремяДоступности.ВремяДоступностиПо;
				НовСтрока.ОкноПо = ?(ЗначениеЗаполнено(НовСтрока.ОкноПо), НовСтрока.ОкноПо, '00010101235900');
				НовСтрока.Время            = МаршрутЭтапы[Сч].ВремяВПути;
				НовСтрока.Расстояние       = МаршрутЭтапы[Сч].Расстояние;
				НовСтрока.Стоянка          = ПолучитьВремяСтоянкиПоУмолчанию(НовСтрока.Пункт);
				НовСтрока.ТипТочкиМаршрута = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Погрузка");
				
				НовСтрока = ПромежуточныеПункты.Добавить();
				НовСтрока.НомерСтроки = НомерСтроки;
				НомерСтроки = НомерСтроки + 1;
				НовСтрока.ID = ID;
				НовСтрока.Пункт            = МаршрутЭтапы[Сч].ПунктПрибытия;
				НовСтрока.ПунктНазначенияИмеетКоординаты = ПунктНазначенияИмеетКоординаты(НовСтрока.Пункт);
				ВремяДоступности = уатОбщегоНазначения_проф.ПолучитьВремяДоступностиПункта(НовСтрока.Пункт,
					НовСтрока.ОтправительПолучатель);
				НовСтрока.ОкноС            = ВремяДоступности.ВремяДоступностиС;
				НовСтрока.ОкноПо           = ВремяДоступности.ВремяДоступностиПо;
				НовСтрока.ОкноПо = ?(ЗначениеЗаполнено(НовСтрока.ОкноПо), НовСтрока.ОкноПо, '00010101235900');
				НовСтрока.Время            = 0;
				НовСтрока.Расстояние       = 0;
				НовСтрока.Стоянка          = ПолучитьВремяСтоянкиПоУмолчанию(НовСтрока.Пункт);
				НовСтрока.ТипТочкиМаршрута = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Разгрузка");
			КонецЦикла;
		КонецЕсли;
		
		Если ПромежуточныеПункты.Количество() И ЗначениеЗаполнено(ПромежуточныеПункты[0].Пункт)
				И Не ЗначениеЗаполнено(ПромежуточныеПункты[0].ПрибытиеПлан) Тогда 
			мВремяС  = 0; 
			мВремяПо = 0; 
			мСтоянка = 0; 
			
			Если ТипЗнч(ПромежуточныеПункты[0].Пункт) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда 
				мВыбЗнач = ПромежуточныеПункты[0].Пункт;
				мВремяС  = ПромежуточныеПункты[0].ОкноС;
				мВремяПо = ПромежуточныеПункты[0].ОкноПо;
				мСтоянка = ПолучитьВремяСтоянкиПоУмолчанию(ПромежуточныеПункты[0].Пункт);
				
			Иначе 
				мВыбЗнач = ПромежуточныеПункты[0].Пункт;
			КонецЕсли;
			
			Если ТипЗнч(мВремяС) = Тип("Дата") Тогда
				мВремяС = мВремяС - Дата('00010101');
			КонецЕсли;
			
			Если ТипЗнч(мВремяПо) = Тип("Дата") Тогда
				мВремяПо = мВремяПо - Дата('00010101');
				мВремяПо = ?(ЗначениеЗаполнено(мВремяПо), мВремяПо, '00010101235900'-Дата('00010101'))
			КонецЕсли;
			
			ПромежуточныеПункты[0].ПрибытиеПлан = НачалоДня(СсылкаНаПотребность.Дата) + мВремяС;
			ПромежуточныеПункты[0].ОкноС        = ПромежуточныеПункты[0].ПрибытиеПлан;
			ПромежуточныеПункты[0].УбытиеПлан   = НачалоДня(СсылкаНаПотребность.Дата) + мВремяПо;
			ПромежуточныеПункты[0].ОкноПо       = ПромежуточныеПункты[0].УбытиеПлан;
			
			ПромежуточныеПункты[0].Стоянка      = мСтоянка;
		КонецЕсли;
		
	Иначе 
		мВремяВПути = 0;
		мРасстояние = 0;
		
		Для Сч = 0 По МаршрутДляПереноса.Этапы.Количество()-1 Цикл 
			мВремяВПути = уатЗащищенныеФункцииСервер.СложитьВремя(мВремяВПути, Объект.Маршрут.Этапы[Сч].ВремяВПути);
			мРасстояние = мРасстояние + МаршрутДляПереноса.Этапы[Сч].Расстояние;
			
			Если Сч = 0 Тогда 
				ПунктОтправленияДляПереноса = МаршрутДляПереноса.Этапы[Сч].ПунктОтправления;
			КонецЕсли;
			Если Сч = МаршрутДляПереноса.Этапы.Количество()-1 Тогда 
				Если МаршрутДляПереноса.ПредставлениеМаршрутаОднимПунктом Тогда 
					ПунктПрибытияДляПереноса = МаршрутДляПереноса.Этапы[Сч].ПунктОтправления;
				Иначе 
					ПунктПрибытияДляПереноса= МаршрутДляПереноса.Этапы[Сч].ПунктПрибытия;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если FTLДляПереноса Тогда 
			ДобавитьПунктыШапкиВПромежуточныеПункты();
		КонецЕсли;
	КонецЕсли;
	
	НакопленноеВремя = 0;
	
	Для СчСтрок = 0 По ПромежуточныеПункты.Количество() - 1 Цикл 
		Если СчСтрок = 0 Тогда 
			ТекВремя = ПромежуточныеПункты[СчСтрок].ПрибытиеПлан;
			ПредПрибытиеПлан = ПромежуточныеПункты[СчСтрок].ПрибытиеПлан;
		Иначе 
			ТекВремя = уатЗащищенныеФункцииСервер.СложитьВремя(ТекВремя, ПромежуточныеПункты[СчСтрок].Ожидание);
		КонецЕсли;
		
		// Обновление временного окна прибытия в пункт
		СдвигОкна = НачалоДня(ТекВремя) - НачалоДня(ПромежуточныеПункты[СчСтрок].ПрибытиеПлан);
		ПромежуточныеПункты[СчСтрок].ОкноС  = ПромежуточныеПункты[СчСтрок].ОкноС  + СдвигОкна;
		ПромежуточныеПункты[СчСтрок].ОкноПо = ПромежуточныеПункты[СчСтрок].ОкноПо + СдвигОкна;
		
		ПромежуточныеПункты[СчСтрок].ПрибытиеПлан = ТекВремя;
		
		ТекВремя = уатЗащищенныеФункцииСервер.СложитьВремя(ТекВремя, ПромежуточныеПункты[СчСтрок].Стоянка);
		
		Если ТипЗнч(ПромежуточныеПункты[СчСтрок].Пункт) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда 
			ТекВремя = уатЗащищенныеФункцииСервер.СложитьВремя(ТекВремя, уатОбщегоНазначения.ПолучитьВремяДопСтонки(ПромежуточныеПункты[СчСтрок].Пункт));
		КонецЕсли;
		
		ПромежуточныеПункты[СчСтрок].УбытиеПлан = ТекВремя;
		
		ТекВремя = уатЗащищенныеФункцииСервер.СложитьВремя(ТекВремя, ПромежуточныеПункты[СчСтрок].Время);
		
		Если Не ЗначениеЗаполнено(ПромежуточныеПункты[СчСтрок].Пункт) Тогда
			ПромежуточныеПункты[СчСтрок].ПунктСтатусКартинка = -1;
		ИначеЕсли ТипЗнч(ПромежуточныеПункты[СчСтрок].Пункт) = Тип("СправочникСсылка.уатПунктыНазначения")
				И ПунктНазначенияИмеетКоординаты(ПромежуточныеПункты[СчСтрок].Пункт) Тогда
			ПромежуточныеПункты[СчСтрок].ПунктСтатусКартинка = 0;
		Иначе
			ПромежуточныеПункты[СчСтрок].ПунктСтатусКартинка = 1;
		КонецЕсли;
		
		НакопленноеВремя = НакопленноеВремя + (ПромежуточныеПункты[СчСтрок].ПрибытиеПлан - ПредПрибытиеПлан);
		ПредПрибытиеПлан = ПромежуточныеПункты[СчСтрок].ПрибытиеПлан;
		ВремяВТекТочке   = НакопленноеВремя;
		
		ПромежуточныеПункты[СчСтрок].Длительность = "";
		Если ВремяВТекТочке > 0 Тогда 
			чДней = Цел(ВремяВТекТочке / 86400);
			ВремяВТекТочке = ВремяВТекТочке - чДней * 86400;
			чЧас = Цел(ВремяВТекТочке / 3600);
			ВремяВТекТочке = ВремяВТекТочке - чЧас * 3600;
			чМин = Цел(ВремяВТекТочке / 60);
			ВремяВТекТочке = ВремяВТекТочке - чМин * 60;
			
			Если ВремяВТекТочке > 0 Тогда 
				чМин = чМин + 1;
			КонецЕсли;
			
			Если чМин > 59 Тогда 
				чМин = 0;
				чЧас = чЧас + 1;
			КонецЕсли;
			
			Если чЧас > 23 Тогда 
				чЧас = 0;
				чДней = чДней + 1;
			КонецЕсли;
			
			ПромежуточныеПункты[СчСтрок].Длительность = "" 
				+ ?(чДней = 0, "", Строка(чДней) + " " + НСтр("ru='дн.';en='days.'") + " ")
				+ Формат(чЧас, "ЧЦ=2; ЧДЦ=; ЧН=00; ЧВН=; ЧГ=0") + ":"
				+ Формат(чМин, "ЧЦ=2; ЧДЦ=; ЧН=00; ЧВН=; ЧГ=0");
		КонецЕсли;
	КонецЦикла;
	
	УстановитьСпискиВыбораОтрезковПути();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция МаршрутЗаполненКорректно(МаршрутСсылка)
	
	Если МаршрутСсылка.ПредставлениеМаршрутаОднимПунктом Тогда 
		Возврат Истина;
	КонецЕсли;
	
	флДанныеКорректны = Истина;
	Для Сч = 0 По МаршрутСсылка.Этапы.Количество()-2 Цикл 
		ТекСтрока  = МаршрутСсылка.Этапы[Сч];
		СледСтрока = МаршрутСсылка.Этапы[Сч+1];
		
		Если Не ТекСтрока.ПунктПрибытия = СледСтрока.ПунктОтправления Тогда 
			флДанныеКорректны = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат флДанныеКорректны;
	
КонецФункции // МаршрутЗаполненКорректно()

&НаСервереБезКонтекста
Функция ПолучитьВремяСтоянкиПоУмолчанию(ПунктСсылка)
	
	Возврат уатОбщегоНазначения.ПолучитьВремяСтоянкиПоУмолчанию(ПунктСсылка);
	
КонецФункции

&НаКлиенте
Функция ПроверитьЗаполнениеПолей()
	
	ТекстСообщения = НСтр("");
	
	Если Не ЗначениеЗаполнено(КонтрагентДляПереноса) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Контрагент для переноса в Заказ на ТС не заполнен'; en = 'The counterparty for transfer to the Vehicle Order is not filled in'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КонтактноеЛицоДляПереноса) И ЗначениеЗаполнено(КонтактноеЛицоИзДокумента) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Контактное лицо для переноса в Заказ на ТС не заполнено'; en = 'The contact person for transfer to the Vehicle Order is not filled in.'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПунктОтправленияДляПереноса) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Пункт отправления для переноса в Заказ на ТС не заполнен'; en = 'The departure point for transfer to the Vehicle Order is not filled in.'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОтправлениеСДляПереноса) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = '""Отправление с"" для переноса в Заказ на ТС не заполнено'; en = '""Departure from"" for transfer to the Vehicle Order is not filled in'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПунктПрибытияДляПереноса) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Пункт прибытия для переноса в Заказ на ТС не заполнен'; en = 'The destination point for transfer to the Vehicle Order is not filled in.'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПрибытиеСДляПереноса) Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = '""Прибытие с"" для переноса в Заказ на ТС не заполнено'; en = '""Arrival from"" for transfer to the Vehicle Order is not filled in'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ГрузДляПереноса) И ДетализацияЗаказа <> ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоЗаказам") Тогда
		
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Груз для переноса в Заказ на ТС не заполнен'; en = 'The load to be transferred to the Vehicle Order is not filled in.'");
		ТекстСообщения = ТекстСообщения + Символы.ПС;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		
		ТекстСообщения = Лев(ТекстСообщения, СтрДлина(ТекстСообщения) - 1);
		Возврат(ТекстСообщения);
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруПредварительнойПотребности()
	
	СтруктураДляСозданияЗаказа = Новый Структура;
	СтруктураПотребности = Новый Структура;
	
	СтруктураПотребности.Вставить("Подразделение", СсылкаНаПотребность.Подразделение);
	СтруктураПотребности.Вставить("ДетализацияЗаказов", ДетализацияЗаказа);
	СтруктураПотребности.Вставить("Контрагент", КонтрагентДляПереноса);
	СтруктураПотребности.Вставить("КонтактноеЛицоЗаказчика", КонтактноеЛицоДляПереноса);
	СтруктураПотребности.Вставить("ДоговорКонтрагента", ДоговорДляПереноса);
	СтруктураПотребности.Вставить("ВалютаТоваров", СсылкаНаПотребность.ВалютаТоваров);
	СтруктураПотребности.Вставить("ВалютаДокумента", СсылкаНаПотребность.ВалютаДокумента);
	СтруктураПотребности.Вставить("ВалютаДокумента", СсылкаНаПотребность.ВалютаДокумента);
	СтруктураПотребности.Вставить("КурсВзаиморасчетов", СсылкаНаПотребность.КурсВзаиморасчетов);
	СтруктураПотребности.Вставить("КратностьВзаиморасчетов", СсылкаНаПотребность.КратностьВзаиморасчетов);
	СтруктураПотребности.Вставить("СуммаВключаетНДС", СсылкаНаПотребность.СуммаВключаетНДС);
	СтруктураПотребности.Вставить("УчитыватьНДС", СсылкаНаПотребность.УчитыватьНДС);
	СтруктураПотребности.Вставить("СуммаДокумента", СсылкаНаПотребность.СуммаДокумента);
	СтруктураПотребности.Вставить("АдресОтправления", ПунктОтправленияДляПереноса);
	СтруктураПотребности.Вставить("АдресНазначения", ПунктПрибытияДляПереноса);
	
	СтруктураПотребности.Вставить("Мультимодальный", МультимодальныйДляПереноса);
	СтруктураПотребности.Вставить("ОтправлениеС", ОтправлениеСДляПереноса);
	СтруктураПотребности.Вставить("ОтправлениеПо", ОтправлениеПоДляПереноса);
	СтруктураПотребности.Вставить("ДоставкаС", ПрибытиеСДляПереноса);
	СтруктураПотребности.Вставить("ДоставкаПо", ПрибытиеПоДляПереноса);
	
	ТЗСтрокаПотребности = Новый ТаблицаЗначений;
	ТЗСтрокаПотребности.Колонки.Добавить("ID");
	ТЗСтрокаПотребности.Колонки.Добавить("Маршрут");
	ТЗСтрокаПотребности.Колонки.Добавить("FTL");
	ТЗСтрокаПотребности.Колонки.Добавить("СтоянкаПунктОтправления");
	ТЗСтрокаПотребности.Колонки.Добавить("СтоянкаПунктНазначения");
	ТЗСтрокаПотребности.Колонки.Добавить("ВесБрутто");
	ТЗСтрокаПотребности.Колонки.Добавить("Объем");
	ТЗСтрокаПотребности.Колонки.Добавить("КоличествоМест");
	ТЗСтрокаПотребности.Колонки.Добавить("Расстояние");
	ТЗСтрокаПотребности.Колонки.Добавить("ПробегСГрузом");
	ТЗСтрокаПотребности.Колонки.Добавить("Время");
	ТЗСтрокаПотребности.Колонки.Добавить("Стоянка");
	ТЗСтрокаПотребности.Колонки.Добавить("СтоимостьГруза");
	
	НоваяСтрока = ТЗСтрокаПотребности.Добавить();
	НоваяСтрока.ID = СсылкаНаПотребность.ПунктыНазначения[0].ID;
	НоваяСтрока.FTL = FTLДляПереноса;
	МаршрутПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "Маршрут"));
	
	Если МаршрутПоВарианту.Количество() <> 0 Тогда
		НоваяСтрока.Маршрут = МаршрутПоВарианту[0].Значение;
	Иначе
		НоваяСтрока.Маршрут = Неопределено;
	КонецЕсли;
	
	НоваяСтрока.ВесБрутто = СсылкаНаПотребность.ПунктыНазначения[0].ВесБрутто;
	НоваяСтрока.Объем = СсылкаНаПотребность.ПунктыНазначения[0].Объем;
	НоваяСтрока.КоличествоМест = СсылкаНаПотребность.ПунктыНазначения[0].КоличествоМест;
	СтруктураПотребности.Вставить("ПунктыНазначения", ОбщегоНазначения.ТаблицаЗначенийВМассив(ТЗСтрокаПотребности));
	Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоЗаказам Тогда
		СтруктураПотребности.Вставить("ОтрезкиПути", Новый Массив);
	Иначе
		СтруктураПотребности.Вставить("ОтрезкиПути", ОбщегоНазначения.ТаблицаЗначенийВМассив(ОтрезкиПути.Выгрузить()));
	КонецЕсли;
	
	ТипТСПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ТипТС"));
	Если ТипТСПоВарианту.Количество() <> 0 Тогда
		СтруктураДляСозданияЗаказа.Вставить("ТребованиеКТСТипТС", ТипТСПоВарианту[0].Значение);
	Иначе
		СтруктураДляСозданияЗаказа.Вставить("ТребованиеКТСТипТС", Неопределено);
	КонецЕсли;
	
	СтруктураОбъектовНастроек = Новый Структура;
	СтруктураОбъектовНастроек.Вставить("Организация", Организация);
	СтруктураОбъектовНастроек.Вставить("Подразделение", СсылкаНаПотребность.Подразделение);
	СтруктураОбъектовНастроек.Вставить("Пользователь", ПользователиКлиентСервер.АвторизованныйПользователь());
	
	ВидПеревозкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ВидПеревозки"));
	Если ВидПеревозкиПоВарианту.Количество() <> 0 Тогда
		СтруктураДляСозданияЗаказа.Вставить("ВидПеревозки", ВидПеревозкиПоВарианту[0].Значение);
	Иначе
		ВидПеревозкиОсновной = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ОсновнойВидПеревозок);
		СтруктураДляСозданияЗаказа.Вставить("ВидПеревозки", ВидПеревозкиОсновной);
	КонецЕсли;
	
	НаправлениеПеревозкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "НаправлениеПеревозки"));
	Если НаправлениеПеревозкиПоВарианту.Количество() <> 0 Тогда
		СтруктураДляСозданияЗаказа.Вставить("НаправлениеПеревозки", НаправлениеПеревозкиПоВарианту[0].Значение);
	Иначе
		СтруктураДляСозданияЗаказа.Вставить("НаправлениеПеревозки", Неопределено);
	КонецЕсли;
	
	ВидДоставкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ВидДоставки"));
	Если ВидДоставкиПоВарианту.Количество() <> 0 Тогда
		СтруктураДляСозданияЗаказа.Вставить("ВидДоставки", ВидДоставкиПоВарианту[0].Значение);
	Иначе
		ВидДоставкиОсновной = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ОсновнойВидДоставки);
		СтруктураДляСозданияЗаказа.Вставить("ВидДоставки", ВидДоставкиОсновной);
	КонецЕсли;
	
	ЗаполнитьТаблицуГруза(СтруктураПотребности);
	
	УслугиИзПотребности = СсылкаНаПотребность.Услуги.Выгрузить().Скопировать();
	ПолучитьУслугиПоВарианту(УслугиИзПотребности, СсылкаНаПотребность.ОсновнойВариантПеревозки, Ложь);
	
	РасходыИзПотребности = СсылкаНаПотребность.Расходы.Выгрузить().Скопировать();
	ПолучитьУслугиПоВарианту(РасходыИзПотребности, СсылкаНаПотребность.ОсновнойВариантПеревозки, Истина);
	
	СтруктураПотребности.Вставить("Услуги", ОбщегоНазначения.ТаблицаЗначенийВМассив(УслугиИзПотребности));
	СтруктураПотребности.Вставить("Расходы", ОбщегоНазначения.ТаблицаЗначенийВМассив(РасходыИзПотребности));
	
	СтруктураПотребности.Вставить("Выработка", ОбщегоНазначения.ТаблицаЗначенийВМассив(СсылкаНаПотребность.Выработка.Выгрузить()));
	
	Для каждого ТекПромежуточныйПункт Из ПромежуточныеПункты Цикл
		ТекПромежуточныйПункт.ID = СсылкаНаПотребность.ПунктыНазначения[0].ID;
	КонецЦикла;
	
	СтруктураПотребности.Вставить("ПромежуточныеПункты", ОбщегоНазначения.ТаблицаЗначенийВМассив(ПромежуточныеПункты.Выгрузить()));
	СтруктураДляСозданияЗаказа.Вставить("ДокументПотребность", СтруктураПотребности);
	
	СтруктураДляСозданияЗаказа.Вставить("ДокументОснование", СсылкаНаПотребность);
	СтруктураДляСозданияЗаказа.Вставить("ДетализацияЗакрытия", ДетализацияЗаказа);
	СтруктураДляСозданияЗаказа.Вставить("Организация", СсылкаНаПотребность.Организация);
	СтруктураДляСозданияЗаказа.Вставить("Подразделение", СсылкаНаПотребность.Подразделение);
	СтруктураДляСозданияЗаказа.Вставить("IDСтроки", СсылкаНаПотребность.ПунктыНазначения[0].ID);
	СтруктураДляСозданияЗаказа.Вставить("IDДатыДействия");
	
	СтруктураДляСозданияЗаказа.Вставить("АдресОтправления", ПунктОтправленияДляПереноса);
	СтруктураДляСозданияЗаказа.Вставить("АдресНазначения", ПунктПрибытияДляПереноса);
	
	СтруктураДляСозданияЗаказа.Вставить("ОтправлениеС", ОтправлениеСДляПереноса);
	СтруктураДляСозданияЗаказа.Вставить("ОтправлениеПо", ОтправлениеПоДляПереноса);
	СтруктураДляСозданияЗаказа.Вставить("ОписаниеГруза");
	
	СтруктураДляСозданияЗаказа.Вставить("ПрибытиеС", ПрибытиеСДляПереноса);
	СтруктураДляСозданияЗаказа.Вставить("ДатаОтправления", ОтправлениеСДляПереноса);
	СтруктураДляСозданияЗаказа.Вставить("ПрибытиеПо", ПрибытиеПоДляПереноса);
	
	СтруктураДляСозданияЗаказа.Вставить("ТребованиеКТС");
	СтруктураДляСозданияЗаказа.Вставить("Грузоотправитель");
	СтруктураДляСозданияЗаказа.Вставить("Грузополучатель");
	СтруктураДляСозданияЗаказа.Вставить("КонтактноеЛицоГрузоотправителя");
	СтруктураДляСозданияЗаказа.Вставить("КонтактноеЛицоГрузополучателя");
	СтруктураДляСозданияЗаказа.Вставить("КонтактноеЛицоГрузополучателя");
	СтруктураДляСозданияЗаказа.Вставить("ОбъектСтроительства");
	
	СтруктураДляСозданияЗаказа.Вставить("Предварительная", Истина);
	
	Пользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	Ответственный = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь,
		"ОсновнойОтветственный");
	
	Возврат СтруктураДляСозданияЗаказа;
	
КонецФункции

&НаСервере
Процедура СоздатьМультимодальныйЗаказСЭтапами(ТекстСообщения)
	
	ЭтапыМаршрута = ПолучитьЭтапыМаршрута(МаршрутДляПереноса);
	ПредставлениеМаршрутаОднимПунктом = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(МаршрутДляПереноса, "ПредставлениеМаршрутаОднимПунктом");
	ТаблицаЭтапов.Очистить();
	
	Для Сч = 0 По ЭтапыМаршрута.Количество()-1 Цикл
		
		Если ПредставлениеМаршрутаОднимПунктом Тогда
			Если Сч = 0 Тогда
				ПунктОтправления = ЭтапыМаршрута[Сч].ПунктОтправления;
				ПунктОтправленияId = НайтиДобавитьПунктНаСервере(ЭтапыМаршрута[Сч].ПунктОтправления, ЭтапыМаршрута[Сч].ТипТочкиМаршрута);
				Продолжить;
			КонецЕсли;
			ПунктНазначения = ЭтапыМаршрута[Сч].ПунктОтправления;
			ПунктНазначенияId = НайтиДобавитьПунктНаСервере(ЭтапыМаршрута[Сч].ПунктОтправления, ЭтапыМаршрута[Сч].ТипТочкиМаршрута);
			
			НовыйЭтап = ТаблицаЭтапов.Добавить();
			НовыйЭтап.id = Новый УникальныйИдентификатор;
			НовыйЭтап.ПунктОтправления = ПунктОтправления;
			НовыйЭтап.ПунктОтправленияId = ПунктОтправленияId;
			НовыйЭтап.ПунктНазначения = ПунктНазначения;
			НовыйЭтап.ПунктНазначенияId = ПунктНазначенияId;
			НовыйЭтап.Расстояние = ЭтапыМаршрута[Сч-1].Расстояние;
			НовыйЭтап.Время = ЭтапыМаршрута[Сч-1].Время;
			
			ПунктОтправления = ПунктНазначения;
			ПунктОтправленияId = ПунктНазначенияId;
		Иначе
			НовыйЭтап = ТаблицаЭтапов.Добавить();
			НовыйЭтап.id = Новый УникальныйИдентификатор;
			НовыйЭтап.ПунктОтправления = ЭтапыМаршрута[Сч].ПунктОтправления;
			НовыйЭтап.ПунктОтправленияId = НайтиДобавитьПунктНаСервере(ЭтапыМаршрута[Сч].ПунктОтправления);
			НовыйЭтап.ПунктНазначения = ЭтапыМаршрута[Сч].ПунктНазначения;
			НовыйЭтап.ПунктНазначенияId =  НайтиДобавитьПунктНаСервере(ЭтапыМаршрута[Сч].ПунктНазначения);
			НовыйЭтап.Расстояние = ЭтапыМаршрута[Сч].Расстояние;
			НовыйЭтап.Время = ЭтапыМаршрута[Сч].Время;
		КонецЕсли;
		
	КонецЦикла;
	
	ДопПараметры = Новый Структура;
	флЭтапыКорректны = ПроверитьКорректностьЭтапов(ДопПараметры);
	
	Если флЭтапыКорректны Тогда
		Если ТаблицаЭтапов.Количество() > 0 Тогда
			// Надо сохранить новые пункты отправления и назначения для родительского ММ заказа
			ПараметрыЗаписиЭтапов = Новый Структура("ПунктОтправления, ПунктНазначения");
			ЗаполнитьЗначенияСвойств(ПараметрыЗаписиЭтапов, ДопПараметры);
		КонецЕсли;
	ИначеЕсли ТаблицаЭтапов.Количество() > 0 Тогда
		// Надо сохранить новые пункты отправления и назначения для родительского ММ заказа
		ПараметрыЗаписиЭтапов = Новый Структура("ПунктОтправления, ПунктНазначения");
		ЗаполнитьЗначенияСвойств(ПараметрыЗаписиЭтапов, ДопПараметры);
		ТекстНСтр = НСтр("ru='Пункты отправления и назначения родительского ММ заказа заполнены автоматически и могут нуждаться в изменении.';
						|en='Arrival and departure points of parent order have been determined automaticaly and may need to be changed.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
	КонецЕсли;
	
	// Создание родительского заказа и/или обновление его реквизитов
	
	ПрочиеПараметрыЗаказа = Новый Структура;
	ПрочиеПараметрыЗаказа.Вставить("Дата", ТекущаяДатаСеанса());
	ПрочиеПараметрыЗаказа.Вставить("ОтправлениеС", ОтправлениеСДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ОтправлениеПо", ОтправлениеПоДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ДоставкаС", ПрибытиеСДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ДоставкаПо", ПрибытиеПоДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ДатаКурса", ТекущаяДатаСеанса());
	ПрочиеПараметрыЗаказа.Вставить("Организация", СсылкаНаПотребность.Организация);
	ПрочиеПараметрыЗаказа.Вставить("Подразделение", СсылкаНаПотребность.Подразделение);
	Пользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	ПрочиеПараметрыЗаказа.Вставить("Ответственный", уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь,
		"ОсновнойОтветственный"));
	ПрочиеПараметрыЗаказа.Вставить("Контрагент", КонтрагентДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ДоговорКонтрагента", ДоговорДляПереноса);
	ПрочиеПараметрыЗаказа.Вставить("ВалютаДокумента", СсылкаНаПотребность.ВалютаДокумента);
	ПрочиеПараметрыЗаказа.Вставить("КурсВзаиморасчетов", СсылкаНаПотребность.КурсВзаиморасчетов);
	ПрочиеПараметрыЗаказа.Вставить("КратностьВзаиморасчетов", СсылкаНаПотребность.КратностьВзаиморасчетов);
	ПрочиеПараметрыЗаказа.Вставить("УчитыватьНДС", СсылкаНаПотребность.УчитыватьНДС);
	ПрочиеПараметрыЗаказа.Вставить("СуммаВключаетНДС", СсылкаНаПотребность.СуммаВключаетНДС);
	
	СтруктураОбъектовНастроек = Новый Структура;
	СтруктураОбъектовНастроек.Вставить("Организация", Организация);
	СтруктураОбъектовНастроек.Вставить("Подразделение", СсылкаНаПотребность.Подразделение);
	СтруктураОбъектовНастроек.Вставить("Пользователь", ПользователиКлиентСервер.АвторизованныйПользователь());
	
	ТипТСПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ТипТС"));
	Если ТипТСПоВарианту.Количество() <> 0 Тогда
		ПрочиеПараметрыЗаказа.Вставить("ТребованиеКТСТипТС", ТипТСПоВарианту[0].Значение);
	Иначе
		ПрочиеПараметрыЗаказа.Вставить("ТребованиеКТСТипТС", Неопределено);
	КонецЕсли;
	
	ВидПеревозкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ВидПеревозки"));
	Если ВидПеревозкиПоВарианту.Количество() <> 0 Тогда
		ПрочиеПараметрыЗаказа.Вставить("ВидПеревозки", ВидПеревозкиПоВарианту[0].Значение);
	Иначе
		ВидПеревозкиОсновной = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ОсновнойВидПеревозок);
		ПрочиеПараметрыЗаказа.Вставить("ВидПеревозки", ВидПеревозкиОсновной);
	КонецЕсли;
	
	НаправлениеПеревозкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "НаправлениеПеревозки"));
	Если НаправлениеПеревозкиПоВарианту.Количество() <> 0 Тогда
		ПрочиеПараметрыЗаказа.Вставить("НаправлениеПеревозки", НаправлениеПеревозкиПоВарианту[0].Значение);
	Иначе
		ПрочиеПараметрыЗаказа.Вставить("НаправлениеПеревозки", Неопределено);
	КонецЕсли;
	
	ВидДоставкиПоВарианту = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", СсылкаНаПотребность.ОсновнойВариантПеревозки, "ВидДоставки"));
	Если ВидДоставкиПоВарианту.Количество() <> 0 Тогда
		ПрочиеПараметрыЗаказа.Вставить("ВидДоставки", ВидДоставкиПоВарианту[0].Значение);
	Иначе
		ВидДоставкиОсновной = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ОсновнойВидДоставки);
		ПрочиеПараметрыЗаказа.Вставить("ВидДоставки", ВидДоставкиОсновной);
	КонецЕсли;
	
	ЗаказОбъект = Документы.уатЗаказГрузоотправителя.СоздатьДокумент();
	ЗаказОбъект.Заполнить(Неопределено);
	ЗаполнитьЗначенияСвойств(ЗаказОбъект, ПрочиеПараметрыЗаказа);
	ЗаказОбъект.ДетализацияЗакрытия = ДетализацияЗаказа;
	ЗаказОбъект.Маршрут = МаршрутДляПереноса;
	ЗаказОбъект.Мультимодальный = Истина;
	
	Если ПараметрыЗаписиЭтапов.Свойство("ПунктНазначения") И ЗначениеЗаполнено(ПараметрыЗаписиЭтапов.ПунктНазначения) Тогда
		ЗаказОбъект.АдресНазначения = ПараметрыЗаписиЭтапов.ПунктНазначения;
		ЗаказОбъект.СтоянкаПунктНазначения = уатОбщегоНазначения.ПолучитьВремяСтоянкиПоУмолчанию(ЗаказОбъект.АдресНазначения);
	КонецЕсли;
	Если ПараметрыЗаписиЭтапов.Свойство("ПунктОтправления") И ЗначениеЗаполнено(ПараметрыЗаписиЭтапов.ПунктОтправления) Тогда
		ЗаказОбъект.АдресОтправления = ПараметрыЗаписиЭтапов.ПунктОтправления;
		ЗаказОбъект.СтоянкаПунктОтправления = уатОбщегоНазначения.ПолучитьВремяСтоянкиПоУмолчанию(ЗаказОбъект.АдресОтправления);
	КонецЕсли;
	
	ЗаказОбъект.КонтактноеЛицоЗаказчика        = уатОбщегоНазначения.ПолучитьКонтактноеЛицоКонтрагента(ЗаказОбъект.Контрагент);
	ЗаказОбъект.КонтактноеЛицоГрузоотправителя = уатОбщегоНазначения.ПолучитьКонтактноеЛицоКонтрагента(ЗаказОбъект.Грузоотправитель);
	ЗаказОбъект.КонтактноеЛицоГрузополучателя  = уатОбщегоНазначения.ПолучитьКонтактноеЛицоКонтрагента(ЗаказОбъект.Грузополучатель);
	
	// Перезапись грузов в уже созданном заказе - чтобы не было ошибки, если они были изменены из формы заказа.
	// Или просто запись грузов в новом заказе.
	ТаблицаГрузыЗаказа = Неопределено;
	Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
		ТаблицаГрузыЗаказа = ЗаказОбъект.ГрузовойСостав;
	ИначеЕсли ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоТоварам Тогда
		ТаблицаГрузыЗаказа = ЗаказОбъект.Товары;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТаблицаГрузыЗаказа) Тогда
		ТаблицаГрузыЗаказа.Очистить();
	КонецЕсли;
	
	Если ТаблицаГрузыЗаказа <> Неопределено Тогда
		НоваяСтрокаГруза = ТаблицаГрузыЗаказа.Добавить();
		НоваяСтрокаГруза.ВесБрутто = СсылкаНаПотребность.ПунктыНазначения[0].ВесБрутто;
		НоваяСтрокаГруза.Объем = СсылкаНаПотребность.ПунктыНазначения[0].Объем;
		НоваяСтрокаГруза.КоличествоМест = СсылкаНаПотребность.ПунктыНазначения[0].КоличествоМест;
		Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам
			И НоваяСтрокаГруза.КоличествоМест = 0 Тогда 
			НоваяСтрокаГруза.КоличествоМест = 1;
		ИначеЕсли ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоТоварам Тогда
			НоваяСтрокаГруза.Количество = 1;
		КонецЕсли;
		Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
			НоваяСтрокаГруза.ГрузовоеМесто = ГрузДляПереноса;
			НоваяСтрокаГруза.ВидУпаковки = ПолучитьВидУпаковки();
		Иначе
			НоваяСтрокаГруза.Номенклатура = ГрузДляПереноса;
			НоваяСтрокаГруза.ЕдиницаИзмерения = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(ГрузДляПереноса, "ЕдиницаХраненияОстатков");
		КонецЕсли;
	КонецЕсли;
	
	УслугиИзПотребности = СсылкаНаПотребность.Услуги.Выгрузить().Скопировать();
	ПолучитьУслугиПоВарианту(УслугиИзПотребности, СсылкаНаПотребность.ОсновнойВариантПеревозки, Ложь);
	
	РасходыИзПотребности = СсылкаНаПотребность.Расходы.Выгрузить().Скопировать();
	ПолучитьУслугиПоВарианту(РасходыИзПотребности, СсылкаНаПотребность.ОсновнойВариантПеревозки, Истина);
	
	Для Каждого ТекСтрокаУслуга Из УслугиИзПотребности Цикл
		Если ТекСтрокаУслуга.ID = СсылкаНаПотребность.ПунктыНазначения[0].ID Тогда
			НоваяСтрока = ЗаказОбъект.Услуги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрокаУслуга);
			НоваяСтрока.СтатьяДоходов = Справочники.уатСтатьиДоходов.ОсновнаяСтатьяДоходов;
			НоваяСтрока.Содержание = НоваяСтрока.Номенклатура;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекСтрокаРасходы Из РасходыИзПотребности Цикл
		Если ТекСтрокаРасходы.ID = СсылкаНаПотребность.ПунктыНазначения[0].ID Тогда
			НоваяСтрока = ЗаказОбъект.Расходы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрокаРасходы);
			НоваяСтрока.Содержание = НоваяСтрока.Номенклатура;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекСтрокаВыработка Из СсылкаНаПотребность.Выработка Цикл
		Если ТекСтрокаВыработка.ID = СсылкаНаПотребность.ПунктыНазначения[0].ID Тогда
			НоваяСтрока = ЗаказОбъект.Выработка.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрокаВыработка);
		КонецЕсли;
	КонецЦикла;
	
	ЗаказОбъект.ВесБрутто = СсылкаНаПотребность.ПунктыНазначения[0].ВесБрутто;
	ЗаказОбъект.Объем = СсылкаНаПотребность.ПунктыНазначения[0].Объем;
	ЗаказОбъект.КоличествоМест = СсылкаНаПотребность.ПунктыНазначения[0].КоличествоМест;;
	
	ЗаказОбъект.ДокументОснование = СсылкаНаПотребность;
	ЗаказОбъект.IDСтрокиПотребности = СсылкаНаПотребность.ПунктыНазначения[0].ID;
	
	ТекстСообщения = "";
	
	Если ЗаказОбъект.ПроверитьЗаполнение() Тогда
		
		Попытка
			ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
			МассивТекстаСообщения = Новый Массив;
			МассивТекстаСообщения.Добавить(НСтр("ru = 'Родительский Заказ на ТС ""'; en = 'Parental Order for the Vehicle ""'"));
			МассивТекстаСообщения.Добавить(Новый ФорматированнаяСтрока(Строка(ЗаказОбъект.Ссылка),,,,
				ПолучитьНавигационнуюСсылку(ЗаказОбъект.Ссылка)));
			МассивТекстаСообщения.Добавить(НСтр("ru = '"" был успешно проведен'; en = '"" was successfully carried out'"));
			ТекстСообщения = Новый ФорматированнаяСтрока(МассивТекстаСообщения);
		Исключение
			ДокументыЗаписаныУспешно = Ложь;
			ТекстСообщения = НСтр("en='While recording order';ru='При записи заказа'") + " " + ЗаказОбъект + " " + 
				НСтр("en='Error occurred';ru='возникла ошибка: из текущей Потребности в перевозке уже был создан Заказ на ТС'");
			Возврат;
		КонецПопытки;
		
	ИначеЕсли ЗаказОбъект.Ссылка.Пустая() Или Не ЗаказОбъект.Проведен Тогда
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись);
		ТекстСообщения = НСтр("ru = 'Родительский Заказ на ТС ""%1"" был успешно записан'; en = 'The parent order for vehicle ""%1"" was successfully recorded.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", ЗаказОбъект.Ссылка);
	Иначе
		ДокументыЗаписаныУспешно = Ложь;
		ТекстСообщения = НСтр("ru = 'Родительский Заказ на ТС не был записан'; en = 'The Parental Order for the vehicle was not recorded'");
		Возврат;
	КонецЕсли;
	ЗаказНаТС = ЗаказОбъект.Ссылка;
	
	// Получаем уже созданные этапы
	НаборЗаписей = РегистрыСведений.уатЭтапыМультимодальныхПеревозок_уэ.СоздатьНаборЗаписей();
	НаборЗаписей.Заполнить(Неопределено);
	НаборЗаписей.Отбор.ЗаказГрузоотправителя.Установить(ЗаказНаТС);
	НаборЗаписей.Прочитать();
	мсвЭтапыДляОтклонения = Новый Массив;
	Для Каждого ТекЗапись Из НаборЗаписей Цикл
		мсвЭтапыДляОтклонения.Добавить(ТекЗапись.Этап);
	КонецЦикла;
	
	// Создаем новые заказы и обновляем данные уже существующих
	Для Каждого ТекЭтап Из ТаблицаЭтапов Цикл
		флНовыйЭтап = Ложь;
		
		// Создается новый заказ
		флНовыйЭтап = Истина;
		ЭтапОбъект = Документы.уатЗаказГрузоотправителя.СоздатьДокумент();
		
		ЭтапОбъект.Дата                           = ТекущаяДата();
		ЭтапОбъект.Мультимодальный                = Истина;
		ЭтапОбъект.ЭтоЭтап                        = Истина;
		ЭтапОбъект.РодительскийЗаказ              = ЗаказНаТС.Ссылка;
		ЭтапОбъект.ДетализацияЗакрытия            = ЗаказНаТС.ДетализацияЗакрытия;
		ЭтапОбъект.Организация                    = ЗаказНаТС.Организация;
		ЭтапОбъект.Контрагент                     = ЗаказНаТС.Контрагент;
		ЭтапОбъект.КонтактноеЛицоЗаказчика        = ЗаказНаТС.КонтактноеЛицоЗаказчика;
		ЭтапОбъект.ДоговорКонтрагента             = ЗаказНаТС.ДоговорКонтрагента;
		ЭтапОбъект.ВидДоставки                    = ЗаказНаТС.ВидДоставки;
		ЭтапОбъект.ВидПеревозки                   = ЗаказНаТС.ВидПеревозки;
		ЭтапОбъект.ТребованиеКТСТипТС             = ЗаказНаТС.ТребованиеКТСТипТС;
		ЭтапОбъект.ТребованиеКТС                  = ЗаказНаТС.ТребованиеКТС;
		ЭтапОбъект.СтоянкаПунктОтправления        = ЗаказНаТС.СтоянкаПунктОтправления;
		ЭтапОбъект.СтоянкаПунктНазначения         = ЗаказНаТС.СтоянкаПунктНазначения;
		ЭтапОбъект.Грузоотправитель               = ЗаказНаТС.Грузоотправитель;
		ЭтапОбъект.КонтактноеЛицоГрузоотправителя = ЗаказНаТС.КонтактноеЛицоГрузоотправителя;
		ЭтапОбъект.Грузополучатель                = ЗаказНаТС.Грузополучатель;
		ЭтапОбъект.КонтактноеЛицоГрузополучателя  = ЗаказНаТС.КонтактноеЛицоГрузополучателя;
		ЭтапОбъект.ОбъектСтроительства            = ЗаказНаТС.ОбъектСтроительства;
		ЭтапОбъект.НазваниеГруза                  = ЗаказНаТС.НазваниеГруза;
		ЭтапОбъект.ВидОперации                    = ЗаказНаТС.ВидОперации;
		ЭтапОбъект.Подразделение                  = ЗаказНаТС.Подразделение;
		ЭтапОбъект.Ответственный                  = ЗаказНаТС.Ответственный;
		
		ЭтапОбъект.ВалютаДокумента                = ЗаказНаТС.ВалютаДокумента;
		ЭтапОбъект.ВалютаТоваров                  = ЗаказНаТС.ВалютаТоваров;
		ЭтапОбъект.КратностьВзаиморасчетов        = ЗаказНаТС.КратностьВзаиморасчетов;
		ЭтапОбъект.КурсВзаиморасчетов             = ЗаказНаТС.КурсВзаиморасчетов;
		ЭтапОбъект.ДатаКурса                      = ЗаказНаТС.ДатаКурса;
		ЭтапОбъект.УчитыватьНДС                   = ЗаказНаТС.УчитыватьНДС;
		ЭтапОбъект.СуммаВключаетНДС               = ЗаказНаТС.СуммаВключаетНДС;
		
		ЭтапОбъект.АдресОтправления = ТекЭтап.ПунктОтправления;
		ЭтапОбъект.АдресНазначения = ТекЭтап.ПунктНазначения;
		Если флНовыйЭтап Тогда
			ЭтапОбъект.УстановитьВременныеОкнаПоУмолчанию(ТекЭтап.ОтправлениеПлан, ТекЭтап.ПрибытиеПлан);
		КонецЕсли;
		
		ЭтапОбъект.ОтправлениеС  = ОтправлениеСДляПереноса;
		ЭтапОбъект.ОтправлениеПо = ОтправлениеПоДляПереноса;
		
		ЭтапОбъект.ДоставкаС  = ПрибытиеСДляПереноса;
		ЭтапОбъект.ДоставкаПо = ПрибытиеПоДляПереноса;
		
		ЭтапОбъект.Время = ТекЭтап.Время;
		ЭтапОбъект.Расстояние = ТекЭтап.Расстояние;
		ЭтапОбъект.ВесБрутто = ТекЭтап.ВесБрутто;
		ЭтапОбъект.Объем = ТекЭтап.Объем;
		ЭтапОбъект.КоличествоМест = ТекЭтап.КоличествоМест;
		
		Если ТипЗнч(ТаблицаГрузыЗаказа) = Тип("ДокументТабличнаяЧасть.уатЗаказГрузоотправителя.ГрузовойСостав") Тогда
			ЭтапОбъект.ГрузовойСостав.Загрузить(ТаблицаГрузыЗаказа.Выгрузить());
		ИначеЕсли ТипЗнч(ТаблицаГрузыЗаказа) = Тип("ДокументТабличнаяЧасть.уатЗаказГрузоотправителя.Товары") Тогда
			ЭтапОбъект.Товары.Загрузить(ТаблицаГрузыЗаказа.Выгрузить());
		КонецЕсли;
		
		Если ЭтапОбъект.ПроверитьЗаполнение() Тогда
			Попытка
				ЭтапОбъект.Записать(РежимЗаписиДокумента.Проведение);
				МассивТекстаСообщения = Новый Массив;
				МассивТекстаСообщения.Добавить(ТекстСообщения);
				МассивТекстаСообщения.Добавить(Символы.ПС);
				МассивТекстаСообщения.Добавить(НСтр("ru = 'Этап мультимодального Заказа на ТС ""'; en = 'Stage of multimodal Order for TS ""'"));
				МассивТекстаСообщения.Добавить(Новый ФорматированнаяСтрока(Строка(ЭтапОбъект.Ссылка),,,,
					ПолучитьНавигационнуюСсылку(ЭтапОбъект.Ссылка)));
				МассивТекстаСообщения.Добавить(НСтр("ru = '"" был успешно проведен'; en = '"" was successfully carried out'"));
				ТекстСообщения = Новый ФорматированнаяСтрока(МассивТекстаСообщения);
				
				//ТекстСообщения = ТекстСообщения + Символы.ПС + НСтр("ru = 'Этап мультимодального Заказа на ТС ""%1"" был успешно проведен'; en = 'The multimodal order stage for the vehicle ""%1"" was successfully completed.'");
				//
				//
				//ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", ЭтапОбъект.Ссылка);
			Исключение
				ДокументыЗаписаныУспешно = Ложь;
				ТекстОшибки = НСтр("en='While recording order';ru='При записи заказа'") + " " + ЗаказОбъект + " " + НСтр("en='Error occurred';ru='возникла ошибка'");
			КонецПопытки;
		ИначеЕсли ЭтапОбъект.Ссылка.Пустая() Или Не ЭтапОбъект.Проведен Тогда
			
			ЭтапОбъект.Записать(РежимЗаписиДокумента.Запись);
			
			МассивТекстаСообщения = Новый Массив;
			МассивТекстаСообщения.Добавить(ТекстСообщения);
			МассивТекстаСообщения.Добавить(Символы.ПС);
			МассивТекстаСообщения.Добавить(НСтр("ru = 'Этап мультимодального Заказа на ТС ""'; en = 'Stage of multimodal Order for TS ""'"));
			МассивТекстаСообщения.Добавить(Новый ФорматированнаяСтрока(Строка(ЭтапОбъект.Ссылка),,,,
				ПолучитьНавигационнуюСсылку(ЭтапОбъект.Ссылка)));
			МассивТекстаСообщения.Добавить(НСтр("ru = '"" был успешно записан'; en = '"" was successfully recorded'"));
			ТекстСообщения = Новый ФорматированнаяСтрока(МассивТекстаСообщения);
			
		Иначе
			
			ДокументыЗаписаныУспешно = Ложь;
			
			МассивТекстаСообщения = Новый Массив;
			МассивТекстаСообщения.Добавить(ТекстСообщения);
			МассивТекстаСообщения.Добавить(Символы.ПС);
			МассивТекстаСообщения.Добавить(НСтр("ru = 'Этап мультимодального Заказа на ТС не был записан""'; en = 'The stage of the multimodal Order for the vehicle was not recorded""'"));
			ТекстСообщения = Новый ФорматированнаяСтрока(МассивТекстаСообщения);
			
			Возврат;
		КонецЕсли;
		ТекЭтап.Заказ = ЭтапОбъект.Ссылка;
	КонецЦикла;
	
	// Обновляем данные регистра сведений уатЭтапыМультимодальныхПеревозок_уэ
	Для Каждого ТекЭтап Из ТаблицаЭтапов Цикл
		
		НаборЗаписей = РегистрыСведений.уатЭтапыМультимодальныхПеревозок_уэ.СоздатьНаборЗаписей();
		НаборЗаписей.Заполнить(Неопределено);
		НаборЗаписей.Отбор.ЗаказГрузоотправителя.Установить(ЗаказНаТС);
		НаборЗаписей.Отбор.Этап.Установить(ТекЭтап.Заказ);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() Тогда 
			НаборЗаписей[0].НомерЭтапа          = ТаблицаЭтапов.Индекс(ТекЭтап) + 1;
			НаборЗаписей[0].ДатаОтправленияПлан = ТекЭтап.ОтправлениеПлан;
			НаборЗаписей[0].ДатаПрибытияПлан    = ТекЭтап.ПрибытиеПлан;
			
			// Запись координат на схеме для точек отправления и назначения каждого заказа
			СтруктураПоиска = Новый Структура("Пункт", ТекЭтап.ПунктОтправления);
			НайденныеСтроки = ТаблицаПунктов.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтроки.Количество() > 0 Тогда
				НаборЗаписей[0].xПунктаОтправления = НайденныеСтроки[0].x;
				НаборЗаписей[0].yПунктаОтправления = НайденныеСтроки[0].y;
			КонецЕсли;
			СтруктураПоиска.Пункт = ТекЭтап.ПунктНазначения;
			НайденныеСтроки = ТаблицаПунктов.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтроки.Количество() > 0 Тогда
				НаборЗаписей[0].xПунктаНазначения = НайденныеСтроки[0].x;
				НаборЗаписей[0].yПунктаНазначения = НайденныеСтроки[0].y;
			КонецЕсли;
			
			НаборЗаписей.Записать(Истина);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЭтапыМаршрута(Маршрут)
	ЭтапыМаршрута = Новый Массив;
	Для Каждого ТекЭтап Из Маршрут.Этапы Цикл
		СтруктураЭтапа = Новый Структура("Время, ПунктОтправления, ПунктНазначения, Расстояние, ТипТочкиМаршрута");
		СтруктураЭтапа.Время            = ТекЭтап.ВремяВПути;
		СтруктураЭтапа.Расстояние       = ТекЭтап.Расстояние;
		СтруктураЭтапа.ПунктОтправления = ТекЭтап.ПунктОтправления;
		СтруктураЭтапа.ПунктНазначения  = ТекЭтап.ПунктПрибытия;
		СтруктураЭтапа.ТипТочкиМаршрута = ТекЭтап.ТипТочкиМаршрута;
		ЭтапыМаршрута.Добавить(СтруктураЭтапа);
	КонецЦикла;
	Возврат ЭтапыМаршрута;
КонецФункции

&НаСервере
Функция НайтиДобавитьПунктНаСервере(ПунктНазначения, Операция = Неопределено, ПоложениеНаСхемеПоГоризонтали = 0, ПоложениеНаСхемеПоВертикали = 0)
	
	НайденныеСтроки = ТаблицаПунктов.НайтиСтроки(Новый Структура("Пункт", ПунктНазначения));
	Если НайденныеСтроки.Количество() = 0 Тогда
		ТекСтрокаПункта = ТаблицаПунктов.Добавить();
		ТекСтрокаПункта.Пункт = ПунктНазначения;
		ТекСтрокаПункта.type = ПолучитьТипПункта(ПунктНазначения);
		ТекСтрокаПункта.Стоянка = ПолучитьВремяСтоянкиПоУмолчанию(ПунктНазначения);
		ТекСтрокаПункта.СтоянкаДоп = уатОбщегоНазначения.ПолучитьВремяДопСтонки(ТекСтрокаПункта.Пункт);
		ТекСтрокаПункта.x = ПоложениеНаСхемеПоГоризонтали;
		ТекСтрокаПункта.y = ПоложениеНаСхемеПоВертикали;
	Иначе
		ТекСтрокаПункта = НайденныеСтроки[0];
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекСтрокаПункта.id) Тогда
		ТекСтрокаПункта.id = Новый УникальныйИдентификатор();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Операция) Тогда
		ТекСтрокаПункта.Операция = Операция;
	КонецЕсли;
	Возврат ТекСтрокаПункта.id;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьТипПункта(Пункт, Операция = Неопределено)
	
	Если Операция = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.ПромежуточныйПункт") Тогда
		ТипПункта = "point";
		Возврат ТипПункта;
	КонецЕсли;
	
	Если Пункт.Гараж Тогда
		ТипПункта = "garage";
	Иначе
		ТипПункта = "door";
	КонецЕсли;
	// если склад, то 
	// ТипПункта = "warehouse"
	
	Если Операция = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Погрузка")
		Или Операция = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.ДополнительнаяПогрузка") Тогда
		ТипПункта = ТипПункта + "_load";
	ИначеЕсли Операция = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Разгрузка")
		Или Операция = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.ДополнительнаяРазгрузка") Тогда
		ТипПункта = ТипПункта + "_unload";
	КонецЕсли;
	
	Возврат ТипПункта;
	
КонецФункции

&НаСервере
Функция ПроверитьКорректностьЭтапов(ДопПараметры)
	
	флДанныеКорректны = Истина;
	
	// Для мультимодального заказа делаем более сложную проверку - определяем количество начальных и конечных пунктов.
	// Если их не ровно по 1, то невозможно определить пункты отправления и назначения автоматически.
	мсвНачальныеПункты = Новый Массив;
	мсвКонечныеПункты = Новый Массив;
	Для Каждого ТекСтрока Из ТаблицаЭтапов Цикл
		Если мсвНачальныеПункты.Найти(ТекСтрока.ПунктОтправления) = Неопределено Тогда
			мсвНачальныеПункты.Добавить(ТекСтрока.ПунктОтправления);
		КонецЕсли;
		Если мсвКонечныеПункты.Найти(ТекСтрока.ПунктНазначения) = Неопределено Тогда
			мсвКонечныеПункты.Добавить(ТекСтрока.ПунктНазначения);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекСтрока Из ТаблицаЭтапов Цикл
		
		ИндексПункта = мсвНачальныеПункты.Найти(ТекСтрока.ПунктНазначения);
		Если ИндексПункта <> Неопределено Тогда
			мсвНачальныеПункты.Удалить(ИндексПункта);
		КонецЕсли;
		
		ИндексПункта = мсвКонечныеПункты.Найти(ТекСтрока.ПунктОтправления);
		Если ИндексПункта <> Неопределено Тогда
			мсвКонечныеПункты.Удалить(ИндексПункта);
		КонецЕсли;
		
	КонецЦикла;
	
	Если мсвНачальныеПункты.Количество() = 1 Тогда
		// Пункт отправления определяется однозначно
		ДопПараметры.Вставить("ПунктОтправления", мсвНачальныеПункты[0]);
	ИначеЕсли ДопПараметры.Свойство("ПунктОтправления") И мсвНачальныеПункты.Найти(ДопПараметры.ПунктОтправления) <> Неопределено Тогда
		// Ничего делать не нужно. Один из допустимых пунктов отправления уже указан в заказе
	ИначеЕсли мсвНачальныеПункты.Количество() > 0 Тогда
		// Пункт отправления выбирается произвольным образом
		ДопПараметры.Вставить("ПунктОтправления", мсвНачальныеПункты[0]);
		флДанныеКорректны = Ложь;
	Иначе
		// Пункт отправления не получается определить автоматически
		ДопПараметры.Вставить("ПунктОтправления", Неопределено);
		флДанныеКорректны = Ложь;
	КонецЕсли;
	
	Если мсвКонечныеПункты.Количество() = 1 Тогда
		// Пункт назначения определяется однозначно
		ДопПараметры.Вставить("ПунктНазначения", мсвКонечныеПункты[0]);
	ИначеЕсли ДопПараметры.Свойство("ПунктНазначения") И мсвКонечныеПункты.Найти(ДопПараметры.ПунктНазначения) <> Неопределено Тогда
		// Ничего делать не нужно. Один из допустимых пунктов назначения уже указан в заказе
	ИначеЕсли мсвКонечныеПункты.Количество() > 0 Тогда
		// Пункт назначения выбирается произвольным образом
		ДопПараметры.Вставить("ПунктНазначения", мсвКонечныеПункты[0]);
		флДанныеКорректны = Ложь;
	Иначе
		// Пункт назначения не получается определить автоматически
		ДопПараметры.Вставить("ПунктНазначения", Неопределено);
		флДанныеКорректны = Ложь;
	КонецЕсли;
	
	Возврат флДанныеКорректны;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПолучитьУслугиПоВарианту(ТЧУслуги, ОсновнойВариант, ЭтоРасходы)
	
	МассивДляУдаления = Новый Массив;
	Для каждого ТекСтрокаУслуг Из ТЧУслуги Цикл
		Если ТекСтрокаУслуг.НомерВарианта <> ОсновнойВариант Тогда
			МассивДляУдаления.Добавить(ТекСтрокаУслуг);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекУслугаДляУдаления Из МассивДляУдаления Цикл
		ТЧУслуги.Удалить(ТекУслугаДляУдаления);
	КонецЦикла;
	
	ИспользоватьПлановыеУслуги = ПолучитьФункциональнуюОпцию("уатИспользоватьПлановыеУслуги_уэ");
	Если ИспользоватьПлановыеУслуги Тогда
		ТЧУслуги.Колонки.Добавить("КоличествоПлан");
		ТЧУслуги.Колонки.Добавить("ЦенаПлан");
		ТЧУслуги.Колонки.Добавить("ВсегоПлан");
		ТЧУслуги.Колонки.Добавить("СуммаСкидкиПлан");
		ТЧУслуги.Колонки.Добавить("СуммаНДСПлан");
		ТЧУслуги.Колонки.Добавить("СуммаПлан");
		
		Для каждого ТекСтрокаУслуг Из ТЧУслуги Цикл
			
			ТекСтрокаУслуг.КоличествоПлан = ТекСтрокаУслуг.Количество;
			ТекСтрокаУслуг.Количество = 0;
			
			ТекСтрокаУслуг.ЦенаПлан = ТекСтрокаУслуг.Цена;
			ТекСтрокаУслуг.Цена = 0;
			
			Если Не ЭтоРасходы Тогда
				ТекСтрокаУслуг.СуммаСкидкиПлан = ТекСтрокаУслуг.СуммаСкидки;
				ТекСтрокаУслуг.СуммаСкидки = 0;
			КонецЕсли;
			
			ТекСтрокаУслуг.СуммаПлан = ТекСтрокаУслуг.Сумма;
			ТекСтрокаУслуг.Сумма = 0;
			
			ТекСтрокаУслуг.СуммаНДСПлан = ТекСтрокаУслуг.СуммаНДС;
			ТекСтрокаУслуг.СуммаНДС = 0;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтрезокПутиОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	НомерСтрокиГруза = 1;
	Сч = ОтрезкиПути.Количество();
	Пока Сч > 0 Цикл
		Сч = Сч-1;
		Если ОтрезкиПути[Сч].Груз = НомерСтрокиГруза Тогда
			ОтрезкиПути.Удалить(Сч);
		КонецЕсли;
	КонецЦикла;
	ID = ПолучитьID(СсылкаНаПотребность);
	// Добавление новых строк, связанных с текущим грузом, в ТЧ ОтрезкиПути
	ПоложениеРазделителя = СтрНайти(ВыбранноеЗначение, " - ");
	Если ПоложениеРазделителя > 0 Тогда
		От = Число(Лев(ВыбранноеЗначение, ПоложениеРазделителя));
		До = Число(Прав(ВыбранноеЗначение, ПоложениеРазделителя));
		ПредНомерПункта = -1;
		ТекНомерПункта = -1;
		
		Для Сч = От По До Цикл
			Если ПромежуточныеПункты[Сч-1].ID <> ID Тогда
				Продолжить;
			КонецЕсли;
			
			ПредНомерПункта = ТекНомерПункта;
			ТекНомерПункта = Сч;
			Если ПредНомерПункта > 0 И ТекНомерПункта > 0 Тогда
				НоваяСтрока = ОтрезкиПути.Добавить();
				НоваяСтрока.ПунктОтправления = ПредНомерПункта;
				НоваяСтрока.ПунктНазначения = ТекНомерПункта;
				НоваяСтрока.Груз = НомерСтрокиГруза;
				НоваяСтрока.ID = ID;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьID(СсылкаНаПотребность)
	Возврат СсылкаНаПотребность.ПунктыНазначения[0].ID;
КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицуГруза(СтруктураПотребности)
	
	КопияТаблицыГМ = СсылкаНапотребность.ГрузовойСостав.Выгрузить().Скопировать();
	КопияТаблицыГМ.Очистить();
	КопияТаблицыТовары = СсылкаНапотребность.ТоварныйСостав.Выгрузить().Скопировать();
	КопияТаблицыТовары.Очистить();
	
	ID = СсылкаНаПотребность.ПунктыНазначения[0].ID;
	НомерСтроки = 1;
	
	Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
		
		НоваяСтрока = КопияТаблицыГМ.Добавить();
		НоваяСтрока.НомерСтроки = НомерСтроки;
		НомерСтроки = НомерСтроки + 1;
		НоваяСтрока.ГрузовоеМесто = ГрузДляПереноса;
		НоваяСтрока.ID = ID;
		Если СсылкаНапотребность.ДетализацияЗаказов = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
			Если СсылкаНапотребность.ГрузовойСостав.Количество() = 1 Тогда
				НоваяСтрока.ВесБрутто = СсылкаНапотребность.ГрузовойСостав[0].ВесБрутто;
				НоваяСтрока.Объем = СсылкаНапотребность.ГрузовойСостав[0].Объем;
				НоваяСтрока.КоличествоМест = СсылкаНапотребность.ГрузовойСостав[0].КоличествоМест;
				НоваяСтрока.ВидУпаковки = СсылкаНапотребность.ГрузовойСостав[0].ВидУпаковки;
			Иначе
				НоваяСтрока.ВесБрутто = 0;
				НоваяСтрока.Объем = 0;
				НоваяСтрока.КоличествоМест = 1;
				НоваяСтрока.ВидУпаковки = ГрузДляПереноса.ВидУпаковки;
			КонецЕсли;
		Иначе
			Если СсылкаНапотребность.ТоварныйСостав.Количество() = 1 Тогда
				НоваяСтрока.ВесБрутто = СсылкаНапотребность.ТоварныйСостав[0].ВесБрутто;
				НоваяСтрока.Объем = СсылкаНапотребность.ТоварныйСостав[0].Объем;
				НоваяСтрока.КоличествоМест = СсылкаНапотребность.ТоварныйСостав[0].КоличествоМест;
				НоваяСтрока.ВидУпаковки = СсылкаНапотребность.ТоварныйСостав[0].ВидУпаковки;
			Иначе
				НоваяСтрока.ВесБрутто = 0;
				НоваяСтрока.Объем = 0;
				НоваяСтрока.КоличествоМест = 1;
				НоваяСтрока.ВидУпаковки = ГрузДляПереноса.ВидУпаковки;
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		
		НоваяСтрока = КопияТаблицыТовары.Добавить();
		НоваяСтрока.НомерСтроки = НомерСтроки;
		НомерСтроки = НомерСтроки + 1;
		НоваяСтрока.Номенклатура = ГрузДляПереноса;
		НоваяСтрока.Количество = 1;
		НоваяСтрока.ID = ID;
		НоваяСтрока.ЕдиницаИзмерения = ?(ЗначениеЗаполнено(ГрузДляПереноса), ГрузДляПереноса.ЕдиницаХраненияОстатков, Неопределено);
		Если СсылкаНапотребность.ДетализацияЗаказов = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
			Если СсылкаНапотребность.ГрузовойСостав.Количество() = 1 Тогда
				НоваяСтрока.ВесБрутто = СсылкаНапотребность.ГрузовойСостав[0].ВесБрутто;
				НоваяСтрока.Объем = СсылкаНапотребность.ГрузовойСостав[0].Объем;
				НоваяСтрока.КоличествоМест = СсылкаНапотребность.ГрузовойСостав[0].КоличествоМест;
			Иначе
				НоваяСтрока.ВесБрутто = 0;
				НоваяСтрока.Объем = 0;
				НоваяСтрока.КоличествоМест = 1;
			КонецЕсли;
		Иначе
			Если СсылкаНапотребность.ТоварныйСостав.Количество() = 1 Тогда
				НоваяСтрока.ВесБрутто = СсылкаНапотребность.ТоварныйСостав[0].ВесБрутто;
				НоваяСтрока.Объем = СсылкаНапотребность.ТоварныйСостав[0].Объем;
				НоваяСтрока.КоличествоМест = СсылкаНапотребность.ТоварныйСостав[0].КоличествоМест;
			Иначе
				НоваяСтрока.ВесБрутто = 0;
				НоваяСтрока.Объем = 0;
				НоваяСтрока.КоличествоМест = 1;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если FTLДляПереноса И ЗначениеЗаполнено(ОтрезокПути) Тогда
		НоваяСтрока.ОтрезокПути = ОтрезокПути;
	КонецЕсли;
	
	СтруктураПотребности.Вставить("ГрузовойСостав", ОбщегоНазначения.ТаблицаЗначенийВМассив(КопияТаблицыГМ));
	СтруктураПотребности.Вставить("ТоварныйСостав", ОбщегоНазначения.ТаблицаЗначенийВМассив(КопияТаблицыТовары));
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВидУпаковки()
	
	Если СсылкаНаПотребность.ГрузовойСостав.Количество() > 0 
		И ЗначениеЗаполнено(СсылкаНаПотребность.ГрузовойСостав[0].ВидУпаковки) Тогда
		Возврат СсылкаНаПотребность.ГрузовойСостав[0].ВидУпаковки;
	ИначеЕсли СсылкаНаПотребность.ТоварныйСостав.Количество() > 0 
		И ЗначениеЗаполнено(СсылкаНаПотребность.ТоварныйСостав[0].ВидУпаковки) Тогда
		Возврат СсылкаНаПотребность.ТоварныйСостав[0].ВидУпаковки;
	Иначе
		Возврат СсылкаНаПотребность.ПредварительныйГруз.ВидУпаковки;
	КонецЕсли;
	
КонецФункции

#КонецОбласти
