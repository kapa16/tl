
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если НЕ Параметры.Свойство("Потребность") Тогда
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	
	ИспользоватьПодсказкиАдресов = Ложь;
	ТипПоставщика = уатЭлектронныеКартыСервер.ПолучитьТипИспользуемыхЭлектронныхКарт("ПодсказкиАдресов");
	Если ТипПоставщика = Перечисления.уатТипыЭлектронныхКарт.DaData
		Или ТипПоставщика = Перечисления.уатТипыЭлектронныхКарт.Яндекс
		Или ТипПоставщика = Перечисления.уатТипыЭлектронныхКарт.OSM Тогда
		ИспользоватьПодсказкиАдресов = Истина;
	КонецЕсли;
	
	СсылкаНаПотребность = Параметры.Потребность;
	//ОбъектПотребность = СсылкаНаПотребность.ПолучитьОбъект();
	
	ОсновнойВариант = СсылкаНаПотребность.ОсновнойВариантПеревозки;
	
	Организация = СсылкаНаПотребность.Организация;
	ДатаПотребности = СсылкаНаПотребность.Дата;
	
	РазрешитьДетализациюЗаказовПоТоварам = (уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
		Организация, "РазрешитьДетализациюЗаказовПоТоварам") = Истина);
	Если НЕ РазрешитьДетализациюЗаказовПоТоварам Тогда
		ЭлемТовары = Элементы.ДетализацияЗаказа.СписокВыбора.НайтиПоЗначению(Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоТоварам);
		Если ЭлемТовары <> Неопределено Тогда
			Элементы.ДетализацияЗаказа.СписокВыбора.Удалить(ЭлемТовары);
		КонецЕсли;
	КонецЕсли;
	РазрешитьДетализациюЗаказовПоГрузовымМестам = (уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
		Организация, "РазрешитьДетализациюЗаказовПоГрузовымМестам")= Истина);
	Если НЕ РазрешитьДетализациюЗаказовПоГрузовымМестам Тогда
		ЭлемТовары = Элементы.ДетализацияЗаказа.СписокВыбора.НайтиПоЗначению(Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам);
		Если ЭлемТовары <> Неопределено Тогда
			Элементы.ДетализацияЗаказа.СписокВыбора.Удалить(ЭлемТовары);
		КонецЕсли;
	КонецЕсли;
	
	СтруктураОбъектовНастроек = Новый Структура;
	СтруктураОбъектовНастроек.Вставить("Организация", Организация);
	ДетализацияЗаказа = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ДетализацияЗаказаГрузоотправителя);
	
	Если (Не РазрешитьДетализациюЗаказовПоТоварам И Не РазрешитьДетализациюЗаказовПоГрузовымМестам)
		Или (Не РазрешитьДетализациюЗаказовПоТоварам И ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоТоварам)
		Или (Не РазрешитьДетализациюЗаказовПоГрузовымМестам И ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам) Тогда
		ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоЗаказам;
	КонецЕсли;
	
	ЗаполнитьФормуПоПотребности();
	
	НайтиСсылкиПоНаименованию();
	
	УстановитьВидимость();
	
	// уатУправлениеАвтотранспортом.МодификацияКонфигурации
	уатМодификацияКонфигурацииПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	// Конец уатУправлениеАвтотранспортом.МодификацияКонфигурации
	
	Если Элементы.Найти("_НадписьДолгаКонтрагента") <> Неопределено Тогда
		
		Элементы._НадписьДолгаКонтрагента.Ширина = 14;
		Элементы.ГруппаДолгКонтрагента.Ширина = 17;
		
	КонецЕсли;
	
	Если FTLДляПереноса И ЗначениеЗаполнено(МаршрутДляПереноса) Тогда
		УстановитьДанныеПоМаршрутуСервер();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	Если ТипЗнч(КонтрагентИзДокумента) = Тип("СправочникСсылка.Контрагенты") Или ТипЗнч(КонтрагентИзДокумента) = Тип("СправочникСсылка.ПодразделенияОрганизаций") Тогда
		КонтрагентДляПереноса = КонтрагентИзДокумента;
	Иначе
		ПолученнаяСсылка = ПолучитьСсылкуПоНаименованию(КонтрагентИзДокумента, "Контрагенты");
		Если ПолученнаяСсылка <> Неопределено Тогда
			КонтрагентДляПереноса = ПолученнаяСсылка;
		КонецЕсли;
	КонецЕсли;
	КонтрагентДляПереносаПриИзменении(Неопределено);
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(КонтрагентИзДокумента) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Текст) Тогда
		ДанныеВыбора = ПолучитьСписокВыбора(Текст, "Контрагенты");
		ДанныеВыбора.Добавить(Текст,,, БиблиотекаКартинок.УровеньДоступаРедактирование);
		Если ДанныеВыбора.Количество() = 0 Тогда
			СтандартнаяОбработка = Истина;
			Возврат;
		КонецЕсли;
			
	Иначе
		КонтрагентИзДокумента = Текст;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Тип")
		Или ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	КонтрагентДляПереноса = ВыбранноеЗначение;
	КонтрагентДляПереносаПриИзменении(Элемент);
	КонтрагентИзДокумента = Строка(ВыбранноеЗначение);
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтактноеЛицоИзДокументаПриИзменении(Элемент)
	
	Если ТипЗнч(КонтактноеЛицоИзДокумента) = Тип("СправочникСсылка.КонтактныеЛица") Тогда
		КонтактноеЛицоДляПереноса = КонтактноеЛицоИзДокумента;
	Иначе
		ПолученнаяСсылка = ПолучитьСсылкуПоНаименованию(КонтактноеЛицоИзДокумента, "КонтактныеЛица", Ложь);
		Если ПолученнаяСсылка <> Неопределено Тогда
			КонтактноеЛицоДляПереноса = ПолученнаяСсылка;
		КонецЕсли;
	КонецЕсли;
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтактноеЛицоИзДокументаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(КонтактноеЛицоИзДокумента) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Текст) Тогда
		ДанныеВыбора = ПолучитьСписокВыбора(Текст, "КонтактныеЛица", Ложь);
		ДанныеВыбора.Добавить(Текст,,, БиблиотекаКартинок.УровеньДоступаРедактирование);
		Если ДанныеВыбора.Количество() = 0 Тогда
			СтандартнаяОбработка = Истина;
			Возврат;
		КонецЕсли;
	Иначе
		КонтактноеЛицоИзДокумента = Текст;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтактноеЛицоИзДокументаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Тип")
		Или ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	КонтактноеЛицоДляПереноса = ВыбранноеЗначение;
	КонтактноеЛицоДляПереносаПриИзменении(Элемент);
	КонтактноеЛицоИзДокумента = Строка(ВыбранноеЗначение);
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктОтправленияИзДокументаПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(ПунктОтправленияДляПереноса) Тогда
		Если ТипЗнч(ПунктОтправленияИзДокумента) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда
			ПунктОтправленияДляПереноса = ПунктОтправленияИзДокумента;
		Иначе
			ПунктОтправленияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктОтправленияИзДокумента, "уатПунктыНазначения");
		КонецЕсли;
	КонецЕсли;
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктОтправленияИзДокументаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если ТипЗнч(ПунктОтправленияИзДокумента) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если ИспользоватьПодсказкиАдресов И Не ПустаяСтрока(Текст) Тогда
		
		ТекстОшибки = "";
		ДанныеВыбора = уатЭлектронныеКартыКлиент.ПолучитьПодсказкиПоАдресу(Текст, ТекстОшибки);
		
		ПредставлениеНайтиНаКарте = СтрШаблон(НСтр("ru = 'Найти ""%1"" на карте'; en = 'Find ""%1"" on the map'"), Текст);
		ДанныеВыбора.Добавить(Текст,,, БиблиотекаКартинок.УровеньДоступаРедактирование);
		Если ТекстОшибки <> "" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
		
		СтрокаПолученияПодсказкиАдреса = Текст;
		СписокПодсказокАдреса = ДанныеВыбора.Скопировать();
		
	ИначеЕсли Не ИспользоватьПодсказкиАдресов И Не ПустаяСтрока(Текст) Тогда
		
		ДанныеВыбора = ПолучитьСписокВыбора(Текст, "уатПунктыНазначения");
		
		Если ДанныеВыбора.Количество() = 0 Тогда
			СтандартнаяОбработка = Истина;
			Возврат;
		КонецЕсли;
		
	Иначе
		
		ПунктОтправленияИзДокумента = Текст;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктОтправленияИзДокументаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	Попытка
		#Если ВебКлиент Тогда
			АдресСтруктура = ПрочитатьJSONНаСервере(ВыбранноеЗначение);
		#Иначе
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ВыбранноеЗначение);
			АдресСтруктура = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
		#КонецЕсли
		
		ВидКИ = ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента");
		ЗначениеАдреса = ПолучитьЗначениеАдресаJSON(АдресСтруктура.ПредставлениеАдреса, ВидКИ);
		АдресСтруктура.Вставить("ЗначениеАдреса", ЗначениеАдреса);
		ЭтоПунктОтправления = Истина;
		СоздатьАдресПоСтроке(ЭтоПунктОтправления, АдресСтруктура.ПредставлениеАдреса, АдресСтруктура);
		ПунктОтправленияИзДокумента = АдресСтруктура.ПредставлениеАдреса;
	Исключение
		ПунктОтправленияИзДокумента = ВыбранноеЗначение;
	КонецПопытки;
	
	УстановитьВидимость();
	
КонецПроцедуры

