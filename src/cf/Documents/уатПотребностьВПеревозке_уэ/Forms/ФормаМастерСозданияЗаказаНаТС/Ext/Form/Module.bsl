&НаКлиенте
Процедура КонтрагентСоздать(Команда)
	
	ЭлементыОтбора = Новый Структура("Наименование", КонтрагентИзДокумента);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ОписаниеОповещения = Новый ОписаниеОповещения("КонтрагентСоздатьЗавершение", ЭтотОбъект);
	КонтрагентДляПереноса = ПолучитьСсылкуПоНаименованию(КонтрагентИзДокумента, "Контрагенты");
	Если ЗначениеЗаполнено(КонтрагентДляПереноса) Тогда
		ТекстНСтр = НСтр("ru = 'Обнаружен существующий контрагент. Новый элемент не был создан.'; en = 'An existing counterparty was found. A new item was not created.'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", КонтрагентИзДокумента);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
	Иначе
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентСоздатьЗавершение(Результат, ДопПараметры = Неопределено) Экспорт
	
	КонтрагентДляПереноса = ПолучитьСсылкуПоНаименованию(КонтрагентИзДокумента, "Контрагенты");
	Если Не ЗначениеЗаполнено(КонтрагентДляПереноса) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстНСтр = НСтр("ru = 'Новый контрагент создан успешно'; en = 'The new counterparty has been created successfully'");
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
	
	ЭлементыОтбора = Новый Структура;
	ЭлементыОтбора.Вставить("Владелец", КонтрагентДляПереноса);
	ЭлементыОтбора.Вставить("Контрагент", КонтрагентДляПереноса);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДоговорСоздатьЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорСоздать(Команда)
	
	Если Не ЗначениеЗаполнено(КонтрагентДляПереноса) Тогда
		ТекстСообщения = НСтр("ru = 'Не заполнен контрагент для переноса в Заказ на ТС'; en = 'The counterparty for transfer to the Vehicle Order is not filled in.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ЭлементыОтбора = Новый Структура;
	ЭлементыОтбора.Вставить("Владелец", КонтрагентДляПереноса);
	ЭлементыОтбора.Вставить("Контрагент", КонтрагентДляПереноса);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДоговорСоздатьЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорСоздатьЗавершение(Результат, ДопПараметры = Неопределено) Экспорт
	
	ДоговорДляПереноса = ПолучитьДоговорСозданногоКонтрагента(КонтрагентДляПереноса);
