&НаКлиенте
Процедура ПунктОтправленияСоздать(Команда)
	
	ЭлементыОтбора = Новый Структура("Наименование", ПунктОтправленияИзДокумента);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ДопПараметры = Новый Структура("ПунктОтправления", Истина);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПунктНазначенияСоздатьЗавершение", ЭтотОбъект, ДопПараметры);
	
	ПунктОтправленияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктОтправленияИзДокумента, "уатПунктыНазначения");
	Если ЗначениеЗаполнено(ПунктОтправленияДляПереноса) Тогда
		ТекстНСтр = НСтр("ru = 'Обнаружен существующий пункт назначения. Новый элемент не был создан.'; en = 'An existing destination was found. No new item was created.'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ПунктОтправленияИзДокумента);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
	Иначе
		ОткрытьФорму("Справочник.уатПунктыНазначения.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктНазначенияСоздатьЗавершение(Результат, ДопПараметры) Экспорт
	
	Если ДопПараметры.Свойство("ПунктОтправления") И ДопПараметры.ПунктОтправления Тогда
		ПунктОтправленияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктОтправленияИзДокумента, "уатПунктыНазначения");
		
		Если Не ЗначениеЗаполнено(ПунктОтправленияДляПереноса) Тогда
			Возврат;
		КонецЕсли;
	Иначе
		ПунктПрибытияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктПрибытияИзДокумента, "уатПунктыНазначения");
		
		Если Не ЗначениеЗаполнено(ПунктПрибытияДляПереноса) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ТекстНСтр = НСтр("ru = 'Новый пункт назначения создано успешно'; en = 'New destination created successfully'");
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура ПунктПрибытияСоздать(Команда)
	ЭлементыОтбора = Новый Структура("Наименование", ПунктПрибытияИзДокумента);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ДопПараметры = Новый Структура("ПунктОтправления", Ложь);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПунктНазначенияСоздатьЗавершение", ЭтотОбъект, ДопПараметры);
	
	ПунктПрибытияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктПрибытияИзДокумента, "уатПунктыНазначения", Ложь);
	Если ЗначениеЗаполнено(ПунктПрибытияДляПереноса) Тогда
		ТекстНСтр = НСтр("ru = 'Обнаружен существующий пункт назначения. Новый элемент не был создан.'; en = 'An existing destination was found. No new item was created.'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ПунктПрибытияИзДокумента);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
	Иначе
		ОткрытьФорму("Справочник.уатПунктыНазначения.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ГрузСоздать(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ГрузСоздатьЗавершение", ЭтотОбъект);
	Если ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		ЭлементыОтбора = Новый Структура;
		ЭлементыОтбора.Вставить("Наименование", ГрузИзДокумента);
		ЭлементыОтбора.Вставить("СозданиеПоСтроке", Истина);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
		
		ГрузДляПереноса = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "уатГрузовыеМеста_уэ");
		Если ЗначениеЗаполнено(ГрузДляПереноса) Тогда
			ТекстНСтр = НСтр("ru = 'Обнаружено существующее грузовое место. Новый элемент не был создан.'; en = 'An existing cargo item was found. A new item was not created.'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ГрузИзДокумента);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		Иначе
			ОткрытьФорму("Справочник.уатГрузовыеМеста_уэ.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
		
	Иначе
		ЭлементыОтбора = Новый Структура;
		ЭлементыОтбора.Вставить("Наименование", ГрузИзДокумента);
		ЭлементыОтбора.Вставить("ВидНоменклатуры", ПредопределенноеЗначение("Справочник.ВидыНоменклатуры.Товар"));
		ЭлементыОтбора.Вставить("СозданиеПоСтроке", Истина);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
		
		ГрузДляПереноса = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "Номенклатура");
		Если ЗначениеЗаполнено(ГрузДляПереноса) Тогда
			ТекстНСтр = НСтр("ru = 'Обнаружен существующий товар. Новый элемент не был создан.'; en = 'An existing product was found. No new item was created.'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ГрузИзДокумента);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		Иначе
			ОткрытьФорму("Справочник.Номенклатура.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ГрузСоздатьЗавершение(Результат, ДопПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ДетализацияЗаказа = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "уатГрузовыеМеста_уэ");
	Иначе
		ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "Номенклатура");
	КонецЕсли;
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗаказНаТС(Команда)
	
	ТекстОшибки = ПроверитьЗаполнениеПолей();
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = "";
	
	Если СоздаватьЭтапыМультимодальнойПеревозки Тогда
		
		СоздатьМультимодальныйЗаказСЭтапами(ТекстСообщения);
		ПоказатьПредупреждение(,ТекстСообщения);
		
	Иначе
		
		СтруктураПотребности = ПолучитьСтруктуруПредварительнойПотребности();
		
		ФормаОбработки = ПолучитьФорму("Обработка.уатПакетнаяВыпискаЗаказовГрузоотправителей_уэ.Форма.Форма");
		ФормаОбработки.ЗаполнитьЗаказПоПодготовкеНаКлиенте(СтруктураПотребности, ТекстСообщения);
		
		ПоказатьПредупреждение(,ТекстСообщения);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СоздатьАдресПоСтроке(ЭтоПунктОтправления, АдресСтрока, СтруктураДанныеАдреса)
	
	Если ТипЗнч(СтруктураДанныеАдреса) = Тип("Структура")
		И СтруктураДанныеАдреса.Свойство("ПредставлениеАдреса")
		И СтруктураДанныеАдреса.ПредставлениеАдреса = АдресСтрока
		И СтруктураДанныеАдреса.Свойство("ЗначениеАдреса") Тогда
		// Данные о полях адреса получены из сервиса подсказок
		СоздатьАдресВводКИЗавершение(
			Новый Структура("Значение, Представление", СтруктураДанныеАдреса.ЗначениеАдреса, АдресСтрока), 
			Новый Структура("ЭтоПунктОтправления, СтруктураДанныеАдреса", ЭтоПунктОтправления, СтруктураДанныеАдреса));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьАдресВводКИЗавершение(РезультатЗакрытия, ДопПараметры)
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ТекстПредставления = РезультатЗакрытия.Представление;
	Если ПустаяСтрока(ТекстПредставления) Тогда
		Возврат;
	КонецЕсли;
	
	АдресДляПоиска = ТекстПредставления;
	ЗначениеАдреса = РезультатЗакрытия.Значение;
	Если ДопПараметры.Свойство("СтруктураДанныеАдреса")
		И ДопПараметры.СтруктураДанныеАдреса.Свойство("Широта")
		И ДопПараметры.СтруктураДанныеАдреса.Свойство("Долгота") Тогда
		КоординатыАдреса = Новый Структура("Широта, Долгота", ДопПараметры.СтруктураДанныеАдреса.Широта, ДопПараметры.СтруктураДанныеАдреса.Долгота);
		
		АдресДляПоиска   = ?(ДопПараметры.СтруктураДанныеАдреса.Свойство("АдресДляПоиска"),
		ДопПараметры.СтруктураДанныеАдреса.АдресДляПоиска, ТекстПредставления);
	Иначе
		КоординатыАдреса = ПолучитьКоординатыАдреса(ТекстПредставления, ЗначениеАдреса);
	КонецЕсли;
	
	Если ДопПараметры.ЭтоПунктОтправления Тогда
		ПунктОтправленияДляПереноса = СоздатьАдресСервер(ТекстПредставления, КоординатыАдреса, ЗначениеАдреса, АдресДляПоиска);
		ПунктОтправленияИзДокумента = ТекстПредставления;
	Иначе
		ПунктПрибытияДляПереноса = СоздатьАдресСервер(ТекстПредставления, КоординатыАдреса, ЗначениеАдреса, АдресДляПоиска);
		ПунктПрибытияИзДокумента = ТекстПредставления;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьАдресСервер(АдресПредставление, КоординатыАдреса, ЗначениеАдреса, АдресДляПоиска = "")
	
	ТекстНСтр = "";
	НовыйАдрес = Справочники.уатПунктыНазначения.СоздатьЭлемент();
	НовыйАдрес.Заполнить(Неопределено);
	НовыйАдрес.Лат = КоординатыАдреса.Широта;
	НовыйАдрес.Лон = КоординатыАдреса.Долгота;
	
	// Поиск существующего в базе пункта
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатПунктыНазначения.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатПунктыНазначения КАК уатПунктыНазначения
	|ГДЕ
	|	уатПунктыНазначения.ПометкаУдаления = ЛОЖЬ
	|	И уатПунктыНазначения.ЭтоГруппа = ЛОЖЬ
	|	И (уатПунктыНазначения.Наименование = &АдресПредставление
	|			ИЛИ уатПунктыНазначения.Адрес = &АдресПредставление)
	|	И (уатПунктыНазначения.Лат = &Широта
	|			ИЛИ &Широта = 0)
	|	И (уатПунктыНазначения.Лон = &Долгота
	|			ИЛИ &Долгота = 0)");
	Запрос.УстановитьПараметр("АдресПредставление", АдресПредставление);
	Запрос.УстановитьПараметр("Широта",             НовыйАдрес.Лат);
	Запрос.УстановитьПараметр("Долгота",            НовыйАдрес.Лон);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
		ТекстНСтр = НСтр("ru = 'Обнаружен существующий пункт назначения. Новый элемент не был создан.'; en = 'An existing destination was found. No new item was created.'");
	Иначе
		Наименование = уатНастройкиШаблонов.СформироватьНаименованиеПоШаблону("Справочник_уатПунктыНазначения", НовыйАдрес);
		
		НовыйАдрес.Наименование        = Наименование;
		НовыйАдрес.Адрес               = АдресПредставление;
		НовыйАдрес.АдресДляПоиска      = АдресДляПоиска;
		НовыйАдрес.ЗначениеАдреса      = ЗначениеАдреса;
		НовыйАдрес.ТипПункта           = Справочники.уатТипыПунктов.Адрес;
		НовыйАдрес.Страна              = РаботаСАдресамиКлиентСервер.ОсновнаяСтрана();
		НовыйАдрес.УстановитьСлучайныйЦветПункта();
		НовыйАдрес.Записать();
		
		Результат = НовыйАдрес.Ссылка;
		ТекстНСтр = НСтр("ru = 'Новый пункт создан успешно.'; en = 'New item created successfully.'");
	КонецЕсли;
	
	ОбщегоНазначения.СообщитьПользователю(ТекстНСтр);
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПолучитьКоординатыАдреса(АдресПредставление, ЗначениеАдресаJSON)
	СтруктураФорма = Новый Структура;
	СтруктураОбъект = Новый Структура("Лат, Лон, Ссылка", 0, 0, ПредопределенноеЗначение("Справочник.уатПунктыНазначения.ПустаяСсылка"));
	СтруктураОбъект.Вставить("ЗначениеАдреса", ЗначениеАдресаJSON);
	СтруктураФорма.Вставить("Объект", СтруктураОбъект);
	// {Совместимость}
	// Этот код - для совместимости с старым форматом хранения адреса в XML.
	СтруктураФорма.Вставить("ЗначениеПолей", "");
	// {/Совместимость}
	СтруктураФорма.Вставить("Модифицированность", Ложь);
	
	уатЭлектронныеКартыКлиент.ГеокодироватьКоординатыВПунктеНазначения(СтруктураФорма, Ложь);
	
	Рез = Новый Структура("Широта, Долгота", СтруктураФорма.Объект.Лат, СтруктураФорма.Объект.Лон);
	
	Возврат Рез;
КонецФункции

&НаСервере
Процедура ЗаполнитьФормуПоПотребности()
	
	//ОбъектПотребность = СсылкаНаПотребность.ПолучитьОбъект();
	КонтрагентИзДокумента = СсылкаНаПотребность.Контрагент;
	Если ТипЗнч(СсылкаНаПотребность.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
		Или ТипЗнч(СсылкаНаПотребность.Контрагент) = Тип("СправочникСсылка.ПодразделенияОрганизаций") Тогда
		КонтрагентДляПереноса = СсылкаНаПотребность.Контрагент;
		
		ДанныеОбменаССервером = Новый Структура("Организация, Контрагент, ДоговорКонтрагента, Дата, Приоритет");
		ДанныеОбменаССервером.Организация = Организация;
		ДанныеОбменаССервером.Контрагент = КонтрагентДляПереноса;
		ДанныеОбменаССервером.Дата = ДатаПотребности;
		ДанныеОбменаССервером.Приоритет = 0;
		
		ЗначенияДляЗаполнения = ИзменениеКонтрагентаСервер(ДанныеОбменаССервером);
		ДоговорДляПереноса = ЗначенияДляЗаполнения.ДоговорКонтрагента;
	КонецЕсли;
	
	КонтактноеЛицоИзДокумента = СсылкаНаПотребность.КонтактноеЛицоЗаказчика;
	Если ТипЗнч(СсылкаНаПотребность.КонтактноеЛицоЗаказчика) = Тип("СправочникСсылка.КонтактныеЛица") Тогда
		КонтактноеЛицоДляПереноса = СсылкаНаПотребность.КонтактноеЛицоЗаказчика;
	КонецЕсли;
	
	ОтправлениеС            = СсылкаНаПотребность.ПунктыНазначения[0].ДатаОтправления;
	ОтправлениеСДляПереноса = СсылкаНаПотребность.ПунктыНазначения[0].ДатаОтправления;
	ОтправлениеПоДляПереноса = ?(ОтправлениеС = Дата("00010101"), Дата("00010101"), ОтправлениеСДляПереноса + 60);
	
	ПунктОтправленияИзДокумента = СсылкаНаПотребность.ПунктыНазначения[0].АдресОтправления;
	Если ТипЗнч(СсылкаНаПотребность.ПунктыНазначения[0].АдресОтправления) = Тип("СправочникСсылка.уатПунктыНазначения")
		И ЗначениеЗаполнено(ОтправлениеС) Тогда
		ПунктОтправленияДляПереноса = СсылкаНаПотребность.ПунктыНазначения[0].АдресОтправления;
		ОтправлениеСДляПереноса = Дата(Формат(ОтправлениеС, "ДФ=yyyyMMdd") + Формат(ПунктОтправленияДляПереноса.ВремяДоступностиС, "ДФ=HHmmss"));
		Если ЗначениеЗаполнено(ПунктОтправленияДляПереноса.ВремяДоступностиПо) Тогда
			ОтправлениеПоДляПереноса = Дата(Формат(ОтправлениеС, "ДФ=yyyyMMdd") + Формат(ПунктОтправленияДляПереноса.ВремяДоступностиПо, "ДФ=HHmmss"));
		Иначе
			ОтправлениеПоДляПереноса = ОтправлениеСДляПереноса + 60;
		КонецЕсли;
	КонецЕсли;
	
	ПрибытиеС            = СсылкаНаПотребность.ПунктыНазначения[0].ДатаПрибытия;
	ПрибытиеСДляПереноса = СсылкаНаПотребность.ПунктыНазначения[0].ДатаПрибытия;
	ПрибытиеПоДляПереноса = ?(ПрибытиеС = Дата("00010101"), Дата("00010101"), ПрибытиеСДляПереноса + 60);
	
	ПунктПрибытияИзДокумента = СсылкаНаПотребность.ПунктыНазначения[0].АдресНазначения;
	Если ТипЗнч(СсылкаНаПотребность.ПунктыНазначения[0].АдресНазначения) = Тип("СправочникСсылка.уатПунктыНазначения") 
		И ЗначениеЗаполнено(ПрибытиеС) Тогда
		ПунктПрибытияДляПереноса = СсылкаНаПотребность.ПунктыНазначения[0].АдресНазначения;
		ПрибытиеСДляПереноса = Дата(Формат(ПрибытиеС, "ДФ=yyyyMMdd") + Формат(ПунктПрибытияДляПереноса.ВремяДоступностиС, "ДФ=HHmmss"));
		Если ЗначениеЗаполнено(ПунктПрибытияДляПереноса.ВремяДоступностиПо) Тогда
			ПрибытиеПоДляПереноса = Дата(Формат(ПрибытиеС, "ДФ=yyyyMMdd") + Формат(ПунктПрибытияДляПереноса.ВремяДоступностиПо, "ДФ=HHmmss"));
		Иначе
			ПрибытиеПоДляПереноса = ПрибытиеСДляПереноса;
		КонецЕсли;
	КонецЕсли;
	
	ГрузИзДокумента = СсылкаНаПотребность.ПредварительныйГруз;
	
	Если ТипЗнч(ГрузИзДокумента) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") И 
		Элементы.ДетализацияЗаказа.СписокВыбора.НайтиПоЗначению(Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам) <> Неопределено Тогда
		ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам;
	КонецЕсли;
	
	Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.уатГрузовыеМеста_уэ");
	Иначе
		Элементы.ГрузДляПереноса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	КонецЕсли;
	
	Если (ТипЗнч(СсылкаНаПотребность.ПредварительныйГруз) = Тип("СправочникСсылка.Номенклатура") 
		И ДетализацияЗаказа <> Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам)
		Или (ТипЗнч(СсылкаНаПотребность.ПредварительныйГруз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") 
		И ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам) Тогда
		
		ГрузДляПереноса = СсылкаНаПотребность.ПредварительныйГруз;
		
	КонецЕсли;
	
	FTLДляПереноса             = СсылкаНаПотребность.ПунктыНазначения[0].FTL;
	МультимодальныйДляПереноса = СсылкаНаПотребность.ПунктыНазначения[0].Мультимодальный;
	
	НайденныйМаршрут = СсылкаНаПотребность.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", 
		ОсновнойВариант, "Маршрут"));
		
	Если НайденныйМаршрут.Количество() = 0 Тогда
		МаршрутДляПереноса = Неопределено;
	Иначе
		МаршрутДляПереноса = НайденныйМаршрут[0].Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
	
	Если ТипЗнч(КонтрагентИзДокумента) = Тип("СправочникСсылка.ПодразделенияОрганизаций")
		Или ТипЗнч(КонтрагентДляПереноса) = Тип("СправочникСсылка.ПодразделенияОрганизаций") Тогда
		Элементы.Контрагент.Заголовок = Нстр("en = 'Department'; ru = 'Подразделение'");
		Элементы.КонтрагентДляПереноса.Заголовок = Нстр("en = 'Department'; ru = 'Подразделение'");
		Элементы.ДоговорДляПереноса.Видимость = Ложь;
		Элементы.ГруппаДолгКонтрагента.Видимость = Ложь;
		Элементы.ГруппаДоговор.Видимость = Ложь;
		Элементы.ДоговорСоздать.Видимость = Ложь;
		Элементы.ДоговорПропуск.Видимость = Ложь;
		Элементы.СтрелкаДоговор.Видимость = Ложь;
	Иначе
		Элементы.Контрагент.Заголовок = Нстр("en = 'Counterparty'; ru = 'Контрагент'");
		Элементы.КонтрагентДляПереноса.Заголовок = Нстр("en = 'Counterparty'; ru = 'Контрагент'");
		Элементы.ДоговорДляПереноса.Видимость = Истина;
		Элементы.ГруппаДолгКонтрагента.Видимость = Истина;
		Элементы.ГруппаДоговор.Видимость = Истина;
		Элементы.ДоговорСоздать.Видимость = Не ЗначениеЗаполнено(ДоговорДляПереноса);
		Элементы.ДоговорПропуск.Видимость = Не Элементы.ДоговорСоздать.Видимость;
		Элементы.СтрелкаДоговор.Видимость = Истина;
	КонецЕсли;
	
	Элементы.КонтрагентСоздать.Видимость = (ТипЗнч(КонтрагентИзДокумента) = Тип("Строка") И Не ЗначениеЗаполнено(КонтрагентДляПереноса));
	Элементы.КонтрагентПропуск.Видимость = Не Элементы.КонтрагентСоздать.Видимость;
	
	Элементы.КонтактноеЛицоСоздать.Видимость = (ТипЗнч(КонтактноеЛицоИзДокумента) = Тип("Строка") И Не ЗначениеЗаполнено(КонтактноеЛицоДляПереноса));
	Элементы.КонтактноеЛицоПропуск.Видимость = Не Элементы.КонтактноеЛицоСоздать.Видимость;
	
	Элементы.ПунктОтправленияСоздать.Видимость = (ТипЗнч(ПунктОтправленияИзДокумента) = Тип("Строка") И Не ЗначениеЗаполнено(ПунктОтправленияДляПереноса));
	Элементы.ПунктОтправленияПропуск.Видимость = Не Элементы.ПунктОтправленияСоздать.Видимость;
	
	Элементы.ПунктПрибытияСоздать.Видимость = (ТипЗнч(ПунктПрибытияИзДокумента) = Тип("Строка") И Не ЗначениеЗаполнено(ПунктПрибытияДляПереноса));
	Элементы.ПунктПрибытияПропуск.Видимость = Не Элементы.ПунктПрибытияСоздать.Видимость;
	
	Элементы.ГрузСоздать.Видимость = (ТипЗнч(ГрузИзДокумента) = Тип("Строка") И Не ЗначениеЗаполнено(ГрузДляПереноса));
	
	Если Не МультимодальныйДляПереноса И Не FTLДляПереноса Тогда
		Элементы.МультимодальныйДляПереноса.Доступность = Истина;
		Элементы.FTLДляПереноса.Доступность = Истина;
		Элементы.СоздаватьЭтапыМультимодальнойПеревозки.Видимость = Ложь;
		Элементы.МаршрутДляПереноса.Видимость = Ложь;
		Элементы.ОтрезокПути.Видимость = Ложь;
		
		Элементы.ЛеваяКолонкаНизПропуск4.Видимость = Ложь;
		Элементы.ЛеваяКолонкаНизПропуск5.Видимость = Ложь;
	ИначеЕсли МультимодальныйДляПереноса Тогда
		Элементы.МультимодальныйДляПереноса.Доступность = Истина;
		Элементы.FTLДляПереноса.Доступность = Ложь;
		Элементы.СоздаватьЭтапыМультимодальнойПеревозки.Видимость = Истина;
		Элементы.ОтрезокПути.Видимость = Ложь;
		
		Элементы.ЛеваяКолонкаНизПропуск4.Видимость = Истина;
		
		Если СоздаватьЭтапыМультимодальнойПеревозки Тогда
			Элементы.МаршрутДляПереноса.Видимость = Истина;
			
			Элементы.ЛеваяКолонкаНизПропуск5.Видимость = Истина;
		Иначе
			Элементы.МаршрутДляПереноса.Видимость = Ложь;
			
			Элементы.ЛеваяКолонкаНизПропуск5.Видимость = Ложь;
		КонецЕсли;
	Иначе
		Элементы.МультимодальныйДляПереноса.Доступность = Ложь;
		Элементы.FTLДляПереноса.Доступность = Истина;
		Элементы.СоздаватьЭтапыМультимодальнойПеревозки.Видимость = Ложь;
		Элементы.МаршрутДляПереноса.Видимость = Истина;
		Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоЗаказам Тогда
			Элементы.ОтрезокПути.Видимость = Ложь;
		Иначе
			Элементы.ОтрезокПути.Видимость = Истина;
		КонецЕсли;
		
		Элементы.ЛеваяКолонкаНизПропуск4.Видимость = Истина;
		Элементы.ЛеваяКолонкаНизПропуск5.Видимость = Истина;
	КонецЕсли;
		
	
КонецПроцедуры

&НаСервере
Процедура НайтиСсылкиПоНаименованию()
	
	Если ТипЗнч(КонтрагентИзДокумента) = Тип("Строка") Тогда
		КонтрагентДляПереноса = ПолучитьКонтрагентаПоНаименованиюИлиИНН(КонтрагентИзДокумента);
	КонецЕсли;
	Если ТипЗнч(КонтрагентДляПереноса) = Тип("СправочникСсылка.Контрагенты") Тогда
		ДанныеОбменаССервером = Новый Структура("Организация, Контрагент, ДоговорКонтрагента, Дата, Приоритет");
		ДанныеОбменаССервером.Организация = Организация;
		ДанныеОбменаССервером.Контрагент = КонтрагентДляПереноса;
		ДанныеОбменаССервером.Дата = ДатаПотребности;
		ДанныеОбменаССервером.Приоритет = 0;
		
		ЗначенияДляЗаполнения = ИзменениеКонтрагентаСервер(ДанныеОбменаССервером);
		ДоговорДляПереноса = ЗначенияДляЗаполнения.ДоговорКонтрагента;
	КонецЕсли;
	Если ТипЗнч(КонтактноеЛицоИзДокумента) = Тип("Строка") Тогда
		КонтактноеЛицоДляПереноса = ПолучитьСсылкуПоНаименованию(КонтактноеЛицоИзДокумента, "КонтактныеЛица", Ложь);
	КонецЕсли;
	Если ТипЗнч(ПунктОтправленияИзДокумента) = Тип("Строка") Тогда
		ПунктОтправленияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктОтправленияИзДокумента, "уатПунктыНазначения");
	КонецЕсли;
	Если ТипЗнч(ПунктПрибытияИзДокумента) = Тип("Строка") Тогда
		ПунктПрибытияДляПереноса = ПолучитьСсылкуПоНаименованию(ПунктПрибытияИзДокумента, "уатПунктыНазначения");
	КонецЕсли;
	Если ТипЗнч(ГрузИзДокумента) = Тип("Строка") Тогда
		Если ДетализацияЗаказа = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
			ГрузДляПереноса = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "уатГрузовыеМеста_уэ");
		Иначе
			ГрузДляПереноса = ПолучитьСсылкуПоНаименованию(ГрузИзДокумента, "Номенклатура");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокВыбора(НаименованиеЭлемента, НазваниеСправочника, СправочникИерархический = Истина)
	
	Если ТипЗнч(НаименованиеЭлемента) <> Тип("Строка") Тогда
		Возврат НаименованиеЭлемента;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	" + НазваниеСправочника + ".Ссылка КАК Ссылка,
	|	" + НазваниеСправочника + ".Наименование КАК Наименование
	|ИЗ
	|	Справочник." + НазваниеСправочника + " КАК " + НазваниеСправочника + "
	|ГДЕ
	|	" + НазваниеСправочника + ".Наименование ПОДОБНО ""%"" + &НаименованиеЭлемента + ""%""
	|	И НЕ " + НазваниеСправочника + ".ПометкаУдаления";
	Если СправочникИерархический Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И НЕ " + НазваниеСправочника + ".ЭтоГруппа";
	КонецЕсли;
	Если НазваниеСправочника = "Номенклатура" Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И Номенклатура.ВидНоменклатуры = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.Товар)";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НаименованиеЭлемента", НаименованиеЭлемента);
	
	Выборка = Запрос.Выполнить().Выбрать();
	СписокВыбора = Новый СписокЗначений;
	Пока Выборка.Следующий() Цикл
		
		Наименование = Выборка.Наименование;
		Если НазваниеСправочника = "Контрагенты" Или НазваниеСправочника = "Номенклатура" Тогда
			Наименование = Наименование + " (" + НазваниеСправочника + ")";
		КонецЕсли;
		
		СписокВыбора.Добавить(Выборка.Ссылка, Наименование);
		
	КонецЦикла;
	
	Если НазваниеСправочника = "Контрагенты" Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПодразделенияОрганизаций.Ссылка КАК Ссылка,
		|	ПодразделенияОрганизаций.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
		|ГДЕ
		|	ПодразделенияОрганизаций.Наименование ПОДОБНО ""%"" + &НаименованиеЭлемента + ""%""
		|	И НЕ ПодразделенияОрганизаций.ПометкаУдаления";
		Запрос.УстановитьПараметр("НаименованиеЭлемента", НаименованиеЭлемента);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СписокВыбора.Добавить(Выборка.Ссылка, Выборка.Наименование + НСтр("ru = ' (Подразделения)'; en = '(Divisions)'"));
			
		КонецЦикла;
		
		Запрос  = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	Контрагенты.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ИНН = &ИНН
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И НЕ Контрагенты.ПометкаУдаления";
		Запрос.УстановитьПараметр("ИНН", НаименованиеЭлемента);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СписокВыбора.Добавить(Выборка.Ссылка, Выборка.Наименование + НСтр("ru = ' (Контрагенты)'; en = '(Counterparties)'"));
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если НазваниеСправочника = "Номенклатура" Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	уатГрузовыеМеста_уэ.Ссылка КАК Ссылка,
		|	уатГрузовыеМеста_уэ.Наименование КАК Наименование
		|ИЗ
		|	Справочник.уатГрузовыеМеста_уэ КАК уатГрузовыеМеста_уэ
		|ГДЕ
		|	НЕ уатГрузовыеМеста_уэ.ПометкаУдаления
		|	И НЕ уатГрузовыеМеста_уэ.ЭтоГруппа
		|	И уатГрузовыеМеста_уэ.Наименование ПОДОБНО ""%"" + &НаименованиеЭлемента + ""%""";
		Запрос.УстановитьПараметр("НаименованиеЭлемента", НаименованиеЭлемента);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СписокВыбора.Добавить(Выборка.Ссылка, Выборка.Наименование + НСтр("ru = ' (Грузовые места)'; en = '(Cargo spaces)'"));
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СписокВыбора;
	
КонецФункции

&НаСервере
Функция ПолучитьСсылкуПоНаименованию(НаименованиеЭлемента, НазваниеСправочника, СправочникИерархический = Истина)
	
	Если ТипЗнч(НаименованиеЭлемента) <> Тип("Строка") Тогда
		Возврат НаименованиеЭлемента;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	" + НазваниеСправочника + ".Ссылка КАК Ссылка
	|ИЗ
	|	Справочник." + НазваниеСправочника + " КАК " + НазваниеСправочника + "
	|ГДЕ
	|	" + НазваниеСправочника + ".Наименование ПОДОБНО ""%"" + &НаименованиеЭлемента + ""%""
	|	И НЕ " + НазваниеСправочника + ".ПометкаУдаления";
	Если СправочникИерархический Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И НЕ " + НазваниеСправочника + ".ЭтоГруппа";
	КонецЕсли;
	Если НазваниеСправочника = "Номенклатура" Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И Номенклатура.ВидНоменклатуры = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.Товар)";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НаименованиеЭлемента", НаименованиеЭлемента);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ПолучитьКонтрагентаПоНаименованиюИлиИНН(НаименованиеИлиИННКонтрагента)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И НЕ Контрагенты.ЭтоГруппа
	|	И Контрагенты.Наименование ПОДОБНО ""%"" + &Наименование + ""%""";
	Запрос.УстановитьПараметр("Наименование", НаименованиеИлиИННКонтрагента);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И Контрагенты.ИНН = &ИНН";
		Запрос.УстановитьПараметр("ИНН", НаименованиеИлиИННКонтрагента);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Выгрузка = РезультатЗапроса.Выгрузить();
	
	Возврат Выгрузка[0].Ссылка;
	
КонецФункции

