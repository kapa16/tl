&НаСервере
Процедура ЗаполнитьВГХНаСервере(ВыбранныйГруз)
	
	ГрузВес = ВыбранныйГруз.ВесБрутто;
	ГрузОбъем = ВыбранныйГруз.Объем;
	ГрузКоличествоМест = ВыбранныйГруз.КоличествоМест;
	ГрузВидУпаковки = ВыбранныйГруз.ВидУпаковки;
	
	Если Объект.ДетализацияЗаказов = Перечисления.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам Тогда
		
		Объект.ГрузовойСостав[0].КоличествоМест = ГрузКоличествоМест;
		Объект.ГрузовойСостав[0].ВесБрутто = ГрузВес;
		Объект.ГрузовойСостав[0].Объем = ГрузОбъем;
		Объект.ГрузовойСостав[0].ВидУпаковки = ГрузВидУпаковки;
		
		Если ТипЗнч(ВыбранныйГруз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
			Объект.ГрузовойСостав[0].ГрузовоеМесто = ВыбранныйГруз;
		КонецЕсли;
		
	Иначе
		
		Объект.ТоварныйСостав[0].КоличествоМест = ГрузКоличествоМест;
		Объект.ТоварныйСостав[0].ВесБрутто = ГрузВес;
		Объект.ТоварныйСостав[0].Объем = ГрузОбъем;
		Объект.ТоварныйСостав[0].ВидУпаковки = ГрузВидУпаковки;
		
		Если ТипЗнч(ВыбранныйГруз) = Тип("СправочникСсылка.Номенклатура") Тогда
			Объект.ТоварныйСостав[0].Номенклатура = ВыбранныйГруз;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВариант(ПозицияДобавления)
	
	ЭлементСпискаНовыйВариант = Элементы.ТекущийВариантПеревозки.СписокВыбора.НайтиПоЗначению(ПозицияДобавления);
	ЭлементСпискаНовыйВариант.Представление = "Вариант " + Строка(ПозицияДобавления);
	Элементы.ТекущийВариантПеревозки.СписокВыбора.Добавить(ПозицияДобавления + 1, "+");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВСоответсвииСВариантом()
	
	ЗаполнитьРеквизитПоВарианту(Маршрут, "Маршрут", "Справочник.уатМаршруты.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(ВидПеревозки, "ВидПеревозки", "Справочник.уатВидыПеревозок.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(ВидДоставки, "ВидДоставки", "Перечисление.уатВидыДоставки_уэ.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(НаправлениеПеревозки, "НаправлениеПеревозки", "Справочник.уатНаправленияПеревозок.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(ТипТС, "ТипТС", "Справочник.уатТипыТС.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(Перевозчик, "Перевозчик", "Справочник.Контрагенты.ПустаяСсылка");
	
	ЗаполнитьРеквизитПоВарианту(УсловияПеревозки, "УсловияПеревозки", "");
	
	Если Объект.Ссылка.Пустая() Тогда
		
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].Маршрут, "Маршрут", "Справочник.уатМаршруты.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].ВидПеревозки, "ВидПеревозки", "Справочник.уатВидыПеревозок.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].ВидДоставки, "ВидДоставки", "Перечисление.уатВидыДоставки_уэ.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].НаправлениеПеревозки, "НаправлениеПеревозки", "Справочник.уатНаправленияПеревозок.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].ТребованиеКТСТипТС, "ТипТС", "Справочник.уатТипыТС.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].Перевозчик, "Перевозчик", "Справочник.Контрагенты.ПустаяСсылка");
		ЗаполнитьРеквизитПоВарианту(Объект.ПунктыНазначения[0].УсловияПеревозки, "УсловияПеревозки", "");
		
	КонецЕсли;
	
	ОтборСтрок = Новый ФиксированнаяСтруктура(Новый Структура("НомерВарианта", Объект.ТекущийВариантПеревозки));
	Элементы.Услуги1.ОтборСтрок = ОтборСтрок;
	Элементы.Расходы1.ОтборСтрок = ОтборСтрок;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРеквизитПоВарианту(Реквизит, ИмяРеквизита, ПустоеЗначениеЗаполнения)
	
	ДанныеПоВарианту = Объект.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", Объект.ТекущийВариантПеревозки, ИмяРеквизита));
	Если ДанныеПоВарианту.Количество() = 0 Тогда
		Если ПустоеЗначениеЗаполнения = "" Тогда
			Реквизит = "";
		Иначе
			Реквизит = ПредопределенноеЗначение(ПустоеЗначениеЗаполнения);
		КонецЕсли;
	Иначе
		Реквизит = ДанныеПоВарианту[0].Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗаполнитьСтрокуВариантаПараметраПеревозки(ИмяРеквизита, ЗначениеРеквизита)
	
	ДанныеПоВарианту = Объект.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита", Объект.ТекущийВариантПеревозки, ИмяРеквизита));
	Если ДанныеПоВарианту.Количество() = 0 Тогда
		НоваяСтрокаВарианта = Объект.ВариантыПараметровПеревозки.Добавить();
		НоваяСтрокаВарианта.ИмяРеквизита = ИмяРеквизита;
		НоваяСтрокаВарианта.НомерВарианта = Объект.ТекущийВариантПеревозки;
		НоваяСтрокаВарианта.Значение = ЗначениеРеквизита;
		Модифицированность = Истина;
		Возврат;
	КонецЕсли;
	
	ДанныеПоВарианту[0].Значение = ЗначениеРеквизита;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредварительнаяПотребностьПриИзмененииЗавершрение(Результат = Неопределено, ДопПараметры = Неопределено) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Объект.ПредварительнаяПотребность = Ложь;
		Возврат;
	КонецЕсли;
	
	МассивСтрокДляУдаления = Новый Массив;
	
	Для каждого ТекПунктНазначенния Из Объект.ПунктыНазначения Цикл
		Если ТекПунктНазначенния.НомерСтроки > 1 Тогда
			МассивСтрокДляУдаления.Добавить(ТекПунктНазначенния);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекСтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
		Объект.ПунктыНазначения.Удалить(ТекСтрокаДляУдаления);
	КонецЦикла;
	
	Если Объект.ДетализацияЗаказов = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		МассивСтрокДляУдаления = Новый Массив;
		
		Для каждого ТекГрузовоеМесто Из Объект.ГрузовойСостав Цикл
			Если ТекГрузовоеМесто.НомерСтроки > 1 Тогда
				МассивСтрокДляУдаления.Добавить(ТекГрузовоеМесто);
			КонецЕсли;
		КонецЦикла;
		
		Для каждого ТекСтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
			Объект.ГрузовойСостав.Удалить(ТекСтрокаДляУдаления);
		КонецЦикла;
	Иначе
		МассивСтрокДляУдаления = Новый Массив;
		
		Для каждого ТекТовар Из Объект.ТоварныйСостав Цикл
			Если ТекТовар.НомерСтроки > 1 Тогда
				МассивСтрокДляУдаления.Добавить(ТекТовар);
			КонецЕсли;
		КонецЦикла;
		
		Для каждого ТекСтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
			Объект.ТоварныйСостав.Удалить(ТекСтрокаДляУдаления);
		КонецЦикла;
	КонецЕсли;
	
	УстановитьВидимость();
	УстановитьОписаниеТипов();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРеквизитыПоСтрокеПунтовНазначенияИГрузов()
	
	СтрокаПунктовНазначенния = Объект.ПунктыНазначения[0];
	Если Объект.ДетализацияЗаказов = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		СтрокаГрузов = Объект.ГрузовойСостав[0];
		Если ЗначениеЗаполнено(СтрокаГрузов.ГрузовоеМесто) И Объект.Ссылка.Пустая() Тогда
			Объект.ПредварительныйГруз = СтрокаГрузов.ГрузовоеМесто;
		КонецЕсли;
	Иначе
		СтрокаГрузов = Объект.ТоварныйСостав[0];
		Если ЗначениеЗаполнено(СтрокаГрузов.Номенклатура) И Объект.Ссылка.Пустая() Тогда
			Объект.ПредварительныйГруз = СтрокаГрузов.Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.Номенклатура") Тогда
		ВидГруза = "Товар";
	ИначеЕсли ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
		ВидГруза = "ГрузовоеМесто";
	ИначеЕсли ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.уатВидыГрузов") Тогда
		ВидГруза = "ВидГруза";
	Иначе
		ВидГруза = "";
	КонецЕсли;
	
	АдресОтправления     = СтрокаПунктовНазначенния.АдресОтправления;
	АдресПрибытия        = СтрокаПунктовНазначенния.АдресНазначения;
	Отправление          = СтрокаПунктовНазначенния.ДатаОтправления + (СтрокаПунктовНазначенния.ОтправлениеС - Дата("00010101"));
	Прибытие             = СтрокаПунктовНазначенния.ДатаПрибытия + (СтрокаПунктовНазначенния.ПрибытиеС - Дата("00010101"));
	Маршрут              = СтрокаПунктовНазначенния.Маршрут;
	ВидДоставки          = СтрокаПунктовНазначенния.ВидДоставки;
	ВидПеревозки         = СтрокаПунктовНазначенния.ВидПеревозки;
	НаправлениеПеревозки = СтрокаПунктовНазначенния.НаправлениеПеревозки;
	ТипТС                = СтрокаПунктовНазначенния.ТребованиеКТСТипТС;
	УсловияПеревозки     = СтрокаПунктовНазначенния.УсловияПеревозки;
	FTL                  = СтрокаПунктовНазначенния.FTL;
	
	Если ЗначениеЗаполнено(СтрокаГрузов.ВидУпаковки) Тогда
		ГрузВидУпаковки = СтрокаГрузов.ВидУпаковки;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаГрузов.ВесБрутто) Тогда
		ГрузВес = СтрокаГрузов.ВесБрутто;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаГрузов.Объем) Тогда
		ГрузОбъем = СтрокаГрузов.Объем;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаГрузов.КоличествоМест) Тогда
		ГрузКоличествоМест = СтрокаГрузов.КоличествоМест;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСтрокуПунктовНазначенияИГрузовПоРеквизитам()
	
	СтрокаПунктовНазначенния = Объект.ПунктыНазначения[0];
	Если Объект.ДетализацияЗаказов = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		СтрокаГрузов = Объект.ГрузовойСостав[0];
		Если ЗначениеЗаполнено(Объект.ПредварительныйГруз) И ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
			СтрокаГрузов.ГрузовоеМесто = Объект.ПредварительныйГруз;
		КонецЕсли;
	Иначе
		СтрокаГрузов = Объект.ТоварныйСостав[0];
		Если ЗначениеЗаполнено(Объект.ПредварительныйГруз) И ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.Номенклатура") Тогда
			СтрокаГрузов.Номенклатура = Объект.ПредварительныйГруз;
		КонецЕсли;
	КонецЕсли;
	
	//Если ТипЗнч(АдресОтправления) <> Тип("Строка") Тогда
		СтрокаПунктовНазначенния.АдресОтправления = АдресОтправления;
	//КонецЕсли;
	СтрокаПунктовНазначенния.АдресОтправленияСтрока  = Строка(АдресОтправления);
	//Если ТипЗнч(АдресПрибытия) <> Тип("Строка") Тогда
		СтрокаПунктовНазначенния.АдресНазначения = АдресПрибытия;
	//КонецЕсли;
	СтрокаПунктовНазначенния.АдресНазначенияСтрока = Строка(АдресПрибытия);
	Если ЗначениеЗаполнено(Отправление) Тогда
		СтрокаПунктовНазначенния.ДатаОтправления = Дата(Формат(Отправление, "ДФ=yyyyMMdd"));
		СтрокаПунктовНазначенния.ОтправлениеС = Дата("00010101" + Формат(Отправление, "ДФ=HHmmss"));
	Иначе
		СтрокаПунктовНазначенния.ДатаОтправления = Дата("00010101");
		СтрокаПунктовНазначенния.ОтправлениеС = Дата("00010101");
	КонецЕсли;
	Если ЗначениеЗаполнено(Прибытие) Тогда
		СтрокаПунктовНазначенния.ДатаПрибытия = Дата(Формат(Прибытие, "ДФ=yyyyMMdd"));
		СтрокаПунктовНазначенния.ПрибытиеС = Дата("00010101" + Формат(Прибытие, "ДФ=HHmmss"));
	Иначе
		СтрокаПунктовНазначенния.ДатаПрибытия = Дата("00010101");
		СтрокаПунктовНазначенния.ПрибытиеС = Дата("00010101");
	КонецЕсли;
	СтрокаПунктовНазначенния.Маршрут = Маршрут;
	СтрокаПунктовНазначенния.ВидДоставки  = ВидДоставки;
	СтрокаПунктовНазначенния.ВидПеревозки = ВидПеревозки;
	СтрокаПунктовНазначенния.НаправлениеПеревозки = НаправлениеПеревозки;
	СтрокаПунктовНазначенния.ТребованиеКТСТипТС = ТипТС;
	СтрокаПунктовНазначенния.УсловияПеревозки = УсловияПеревозки;
	СтрокаПунктовНазначенния.Перевозчик = Перевозчик;
	СтрокаПунктовНазначенния.FTL = FTL;
	СтрокаПунктовНазначенния.Мультимодальный = Мультимодальный;
	СтрокаПунктовНазначенния.ВесБрутто = ГрузВес;
	СтрокаПунктовНазначенния.Объем = ГрузОбъем;
	СтрокаПунктовНазначенния.КоличествоМест = ГрузКоличествоМест;
	
	СтрокаГрузов.ВидУпаковки = ГрузВидУпаковки;
	СтрокаГрузов.ВесБрутто = ГрузВес;
	СтрокаГрузов.Объем = ГрузОбъем;
	СтрокаГрузов.КоличествоМест = ГрузКоличествоМест;
	
	Если Объект.ДетализацияЗаказов <> ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда

		Если ТипЗнч(Объект.ПредварительныйГруз) = Тип("СправочникСсылка.Номенклатура") Тогда
			СтрокаГрузов.ЕдиницаИзмерения = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Объект.ПредварительныйГруз, "ЕдиницаХраненияОстатков");
			СтрокаГрузов.Количество = 1;
		Иначе
			СтрокаГрузов.ЕдиницаИзмерения = ПолучитьОсновнуюЕдиницуИзмеренияВеса();
		КонецЕсли;
		
	КонецЕсли;
	
 КонецПроцедуры

&НаСервере
Процедура ОбработатьСтрокиТЧ()
	
	ЗначениеВДанныеФормы(УдалитьПустыеСтрокиТЧ(Объект.ПунктыНазначения.Выгрузить()), Объект.ПунктыНазначения);
	Если Объект.ПунктыНазначения.Количество() = 0 Тогда
		Объект.Услуги.Очистить();
		Объект.Расходы.Очистить();
		Объект.Выработка.Очистить();
		УдалитьДопВыработкуСервер();
	КонецЕсли;
	ЗначениеВДанныеФормы(УдалитьПустыеСтрокиТЧ(Объект.ГрузовойСостав.Выгрузить()), Объект.ГрузовойСостав);
	ЗначениеВДанныеФормы(УдалитьПустыеСтрокиТЧ(Объект.ТоварныйСостав.Выгрузить()), Объект.ТоварныйСостав);
	
КонецПроцедуры

&НаСервере
Функция УдалитьПустыеСтрокиТЧ(ТаблицаДляОчистки)
	
	МассивСтрокДляУдаления = Новый Массив;
	ИгнорируемыеПоля = Новый Структура;
	ИгнорируемыеПоля.Вставить("НомерСтроки");
	ИгнорируемыеПоля.Вставить("ID");
	ИгнорируемыеПоля.Вставить("ИсходныйНомерСтроки");
	ИгнорируемыеПоля.Вставить("Валюта");
	
	Для каждого ТекСтрокаДляОчистки Из ТаблицаДляОчистки Цикл
		
		СтрокаПустая = Истина;
		
		Для каждого ТекКолонка Из ТаблицаДляОчистки.Колонки Цикл
			
			Если ЗначениеЗаполнено(ТекСтрокаДляОчистки[ТекКолонка.Имя]) И Не ИгнорируемыеПоля.Свойство(ТекКолонка.Имя) 
				И (Не ТипЗнч(ТекСтрокаДляОчистки[ТекКолонка.Имя]) = Тип("Булево") Или ТекСтрокаДляОчистки[ТекКолонка.Имя]) Тогда
				СтрокаПустая = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если СтрокаПустая Тогда
			МассивСтрокДляУдаления.Добавить(ТекСтрокаДляОчистки);
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого ТекСтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
		
		ТаблицаДляОчистки.Удалить(ТекСтрокаДляУдаления);
		
	КонецЦикла;
	
	Возврат ТаблицаДляОчистки;
	
КонецФункции

&НаКлиенте
Процедура ПроиницилизироватьВариантыДоходовРасходов()
	
	Для каждого ТекДоход Из Объект.Услуги Цикл
		Если Не ЗначениеЗаполнено(ТекДоход.НомерВарианта) Тогда
			ТекДоход.НомерВарианта = 1;
		КонецЕсли;
	КонецЦикла;;
	Для каждого ТекРасход Из Объект.Расходы Цикл
		Если Не ЗначениеЗаполнено(ТекРасход.НомерВарианта) Тогда
			ТекРасход.НомерВарианта = 1;
		КонецЕсли;
	КонецЦикла;;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокиВариантаИзТЧ(Таблица, ВариантДляУдаления)
	
	МассивСтрокДляУдаления = Новый Массив;
	
	Для каждого ТекСтрока Из Таблица Цикл
		Если ТекСтрока.НомерВарианта = ВариантДляУдаления Тогда
			МассивСтрокДляУдаления.Добавить(ТекСтрока);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекСтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
		Таблица.Удалить(ТекСтрокаДляУдаления);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьДанныеВарианта(КопируемыйВариант, СкопированныйВариант)
	
	КопируемыеПараметрыПеревозки = Объект.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта", КопируемыйВариант));
	Если КопируемыеПараметрыПеревозки.Количество() <> 0 Тогда
		Для каждого ТекКопируемыйПараметрПеревозки Из КопируемыеПараметрыПеревозки Цикл
			НоваяСтрока = Объект.ВариантыПараметровПеревозки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекКопируемыйПараметрПеревозки);
			НоваяСтрока.НомерВарианта = СкопированныйВариант;
		КонецЦикла;
	КонецЕсли;
	
	КопируемыеДоходы = Объект.Услуги.НайтиСтроки(Новый Структура("НомерВарианта", КопируемыйВариант));
	Если КопируемыеДоходы.Количество() <> 0 Тогда
		Для каждого ТекКопируемыйДоход Из КопируемыеДоходы Цикл
			НоваяСтрока = Объект.Услуги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекКопируемыйДоход);
			НоваяСтрока.НомерВарианта = СкопированныйВариант;
		КонецЦикла;
	КонецЕсли;
	
	КопируемыеРасходы = Объект.Расходы.НайтиСтроки(Новый Структура("НомерВарианта", КопируемыйВариант));
	Если КопируемыеРасходы.Количество() <> 0 Тогда
		Для каждого ТекКопируемыйРасход Из КопируемыеРасходы Цикл
			НоваяСтрока = Объект.Расходы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекКопируемыйРасход);
			НоваяСтрока.НомерВарианта = СкопированныйВариант;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НаполнитьСписокВыбораВариантов()
	
	СозданоЭлементовСпискаВыбора = 1;
	
	Пока СозданоЭлементовСпискаВыбора < Объект.КоличествоВариантовПеревозки Цикл
		
		СозданоЭлементовСпискаВыбора = СозданоЭлементовСпискаВыбора + 1;
		ДобавитьВариант(СозданоЭлементовСпискаВыбора);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПереместитьГруппуДопВыработкиИДопРеквизитов()
	НовыйРодитель = ?(Объект.ПредварительнаяПотребность, Элементы.ГруппаДополнительно1, Элементы.ГруппаДополнительно);
	Элементы.Переместить(Элементы.ГруппаДополнительныеРеквизиты, НовыйРодитель);
	
	НовыйРодитель = ?(Объект.ПредварительнаяПотребность, Элементы.ГруппаСтраницаДопУслуги1, Элементы.ГруппаСтраницаДопУслуги);
	Элементы.Переместить(Элементы.ГруппаДопУслуги, НовыйРодитель);
	
КонецПроцедуры

&НаСервере
Процедура ПереместитьЭлементСтатус()
	
	НовыйРодитель = ?(Объект.ПредварительнаяПотребность, Элементы.ГруппаОрганизация, Элементы.ГруппаДетализация);
	Элементы.Переместить(Элементы.СтатусВыполнения, НовыйРодитель);
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПолучаемыеУслугиЗаписать(Результат, ДопПараметры) Экспорт
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		Записать(Новый Структура("НеПересчитыватьИтоги", Истина));
	Исключение
		Возврат;
	КонецПопытки;
	
	РассчитатьПолучаемыеУслугиДействия();
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПолучаемыеУслугиДействия()
	
	флЕстьУслуги = Ложь;
	Если Объект.ПредварительнаяПотребность Тогда
		ТекСтрока = Объект.ПунктыНазначения[0];
	Иначе
		ТекСтрока = Элементы.ПунктыНазначения.ТекущиеДанные;
	КонецЕсли;
	Если ТекСтрока = Неопределено Тогда
		флЕстьУслуги = (Объект.Расходы.Количество() > 0);
	Иначе
		Если Объект.ПредварительнаяПотребность Тогда
			мсвПоискаУслуг = Объект.Расходы.НайтиСтроки(Новый Структура("ID, НомерВарианта", ТекСтрока.ID, Объект.ТекущийВариантПеревозки));
		Иначе
			мсвПоискаУслуг = Объект.Расходы.НайтиСтроки(Новый Структура("ID", ТекСтрока.ID));
		КонецЕсли;
		флЕстьУслуги = (мсвПоискаУслуг.Количество() > 0);
	КонецЕсли;
	
	АвторизованныйПользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	
	Если флЕстьУслуги > 0 И ТипЗнч(АвторизованныйПользователь) <> Тип("СправочникСсылка.ВнешниеПользователи") Тогда
		флЕстьРучнойВвод = (Объект.Расходы.НайтиСтроки(Новый Структура("РучнойВвод, ID", Истина, ТекСтрока.ID)).Количество()>0);
		
		ТекстАнгл = "Tabular section will be cleared! Continue?";
		ТекстРус = "Табличная часть будет очищена! Продолжить?";
		
		Если флЕстьРучнойВвод Тогда
			ТекстАнгл = ТекстАнгл + "
				|Yes - save manual input data, No - clear manual input data.";
			ТекстРус = ТекстРус + "
				|Да - сохранить строки с ручным вводом, Нет - удалить строки с ручным вводом.";
			РежимДиалога = РежимДиалогаВопрос.ДаНетОтмена;
		Иначе
			РежимДиалога = РежимДиалогаВопрос.ОКОтмена;
		КонецЕсли;
		
		ТекстНСТР = НСтр("en='" + ТекстАнгл + "'; ru='" + ТекстРус + "'");
		ПоказатьВопрос(Новый ОписаниеОповещения("РассчитатьПолучаемыеУслугиОтвет", ЭтотОбъект), ТекстНСТР, РежимДиалога);
	Иначе
		РассчитатьПолучаемыеУслугиЗавершение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПолучаемыеУслугиОтвет(Результат, ДопПараметры) Экспорт
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	флУдалитьРучнойВвод = (Результат = КодВозвратаДиалога.Нет);
	
	РассчитатьПолучаемыеУслугиЗавершение(, флУдалитьРучнойВвод);
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПолучаемыеУслугиЗавершение(флСообщение = Ложь, флУдалитьРучнойВвод = Ложь)
	Если Объект.ПредварительнаяПотребность Тогда
		ТекСтрокаПункт = Объект.ПунктыНазначения[0];
	Иначе
		ТекСтрокаПункт = Элементы.ПунктыНазначения.ТекущиеДанные;
	КонецЕсли;
	
	Если ТекСтрокаПункт = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ПредварительнаяПотребность Тогда
		ТекСтрока = Элементы.Расходы1.ТекущиеДанные;
	Иначе
		ТекСтрока = Элементы.Расходы.ТекущиеДанные;
	КонецЕсли;
	
	Если ТекСтрока = Неопределено Тогда
		НомерСтрокиУслуги = Неопределено;
	Иначе
		НомерСтрокиУслуги = ТекСтрока.НомерСтроки-1;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ОценкаПроизводительности
	ОценкаПроизводительностиКлиент.НачатьЗамерВремени(Истина, "ПотребностьВПеревозке.РасчетРасходов");
	// Конец СтандартныеПодсистемы.ОценкаПроизводительности
	
	// очистка строк
	//Если флОчистить Тогда
	//	мсвСтрокиУдалить = Новый Массив;
	//	Для Каждого ТекСтрока Из Объект.Услуги Цикл
	//		Если ТекСтрока.ID <> ТекСтрокаПункт.ID Тогда
	//			Продолжить;
	//		КонецЕсли;
	//		Если НЕ (флДинамическийРасчет И ТекСтрока.РучнойРасчет) Тогда
	//			мсвСтрокиУдалить.Добавить(ТекСтрока);
	//		КонецЕсли;
	//	КонецЦикла;
	//	Для Каждого ТекСтрокаУдалить Из мсвСтрокиУдалить Цикл
	//		Объект.Услуги.Удалить(ТекСтрокаУдалить);
	//	КонецЦикла;
	//КонецЕсли;
	
	Если флУдалитьРучнойВвод Тогда
		мсвСтрокиУдалить = Объект.Расходы.НайтиСтроки(Новый Структура("РучнойВвод, ID", Истина, ТекСтрокаПункт.ID));
		Для Каждого ТекСтрокаУдалить Из мсвСтрокиУдалить Цикл
			Объект.Расходы.Удалить(ТекСтрокаУдалить);
		КонецЦикла;
	КонецЕсли;
	
	ДопПараметры = Новый Структура("ЗаполнятьТЧДоходы, ЗаполнятьТЧРасходы", Ложь, Ложь);
	НайденныеСтроки = Объект.ВариантыПараметровПеревозки.НайтиСтроки(Новый Структура("НомерВарианта, ИмяРеквизита",
		Объект.ТекущийВариантПеревозки, "Перевозчик"));
	ПеревозчикДляРассчета = ?(НайденныеСтроки.Количество() = 0, Неопределено, НайденныеСтроки[0].Значение);
	СтруктураДокумента = уатОбщегоНазначенияКлиентСервер.СтруктураДокумента(Объект, "уатПотребностьВПеревозке_уэ", ДопПараметры);
	СтруктураДокумента.ПунктыНазначения[0].Вставить("Перевозчик", ПеревозчикДляРассчета);
	РассчитатьУслугиСервер(СтруктураДокумента, "Расходы", ТекСтрокаПункт.ID, НомерСтрокиУслуги);
	уатРасчетыПоТарифамКлиентСервер_уэ.ЗаполнитьДоходыРасходыИзСтруктуры(Объект, СтруктураДокумента,
		"Расходы", "уатПотребностьВПеревозке_уэ",, флСообщение, ТекСтрокаПункт.ID);
	
	Для Каждого ТекСтрока Из Объект.Расходы Цикл
		Если НЕ ЗначениеЗаполнено(ТекСтрока.ID) Тогда
			ТекСтрока.ID = ТекСтрокаПункт.ID;
		КонецЕсли;
		Если Объект.ПредварительнаяПотребность И НЕ ЗначениеЗаполнено(ТекСтрока.НомерВарианта) Тогда
			ТекСтрока.НомерВарианта = Объект.ТекущийВариантПеревозки;
		КонецЕсли;
	КонецЦикла;
	
	РассчитатьСуммуДокумента();
	ОбновитьВсегоВТЧ();
	ОбновитьПараметрВыработкиВременный();
	ОбновитьАдресаСтрокойСервер();
	ЗаполнитьСформированныеЗаказы();
	ОбновитьКоличествоСтрокВШапкахТЧ();
	
	ПунктыНазначенияПриАктивизацииСтроки(Неопределено);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьОсновнойВариантПеревозки(Знач СписокВыбораТекущийВариантПеревозки, ТекущийВариантПеревозки)
	
	ОсновнойВариант = ТекущийВариантПеревозки;
	
	Для каждого ТекВариантПеревозки Из СписокВыбораТекущийВариантПеревозки Цикл
		Если ТекВариантПеревозки.Пометка Тогда
			ОсновнойВариант = ТекВариантПеревозки.Значение;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОсновнойВариант;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьПодписьОсновногоВарианта()
	
	Для каждого ТекВариантПеревозки Из Элементы.ТекущийВариантПеревозки.СписокВыбора Цикл
		
		Если СтрНайти(ТекВариантПеревозки.Представление, " (Основной)") <> 0 Тогда
			ТекВариантПеревозки.Представление = СтрЗаменить(ТекВариантПеревозки.Представление, " (Основной)", "");
		КонецЕсли;
		Если ТекВариантПеревозки.Значение = Объект.ОсновнойВариантПеревозки Тогда
			ТекВариантПеревозки.Представление = ТекВариантПеревозки.Представление + НСтр("ru=' (Основной)'");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьОсновнуюЕдиницуИзмеренияВеса()
	Возврат Константы.уатЕдиницаИзмеренияВеса.Получить();
КонецФункции

&НаСервереБезКонтекста
Функция ЗаполнитьКонстантыЕдиницИзмерения()
	
	СтруктураЕдиницЕзмерения = Новый Структура;
	СтруктураЕдиницЕзмерения.Вставить("ЕдиницаИзмеренияВеса", Строка(Константы.уатЕдиницаИзмеренияВеса.Получить()));
	СтруктураЕдиницЕзмерения.Вставить("ЕдиницаИзмеренияОбъема", Строка(Константы.уатЕдиницаИзмеренияОбъема.Получить()));
	СтруктураЕдиницЕзмерения.Вставить("ЕдиницаИзмеренияКоличестваМест", 
		Справочники.уатВидыУпаковки_уэ.ПолучитьОсновнойВидУпаковки().КраткоеНаименование);
	Возврат СтруктураЕдиницЕзмерения;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПотребностьПоГМНаСервере(ID)
	Если ОтборСтрокПоПунктам Тогда
		ГрузовыеМеста = Объект.ГрузовойСостав.Выгрузить(Новый Структура ("ID", ID));
	Иначе
		ГрузовыеМеста = Объект.ГрузовойСостав.Выгрузить();
	КонецЕсли;
	Объект.ПотребностьВВагонах.Загрузить(уатЗащищенныеФункцииСервер_уэ.ЗаполнитьПотребностьВВагонахПоКодам(ГрузовыеМеста, 
		?(Элементы.ПотребностьИспользоватьКодЕТСНГ.Пометка, "ЕТСНГ", "ГНГ"), Объект.ПотребностьВВагонах.Выгрузить()));
КонецПроцедуры

&НаСервере
Процедура УстановитьКодГНГИлиЕТСНГ()
	ТолькоКодыЕТСНГ = Истина;
	ТолькоКодыГНГ = Истина;
	Для каждого ТекПотребностьВагоны Из Объект.ПотребностьВВагонах Цикл
		Если ТипЗнч(ТекПотребностьВагоны.КодГруза) = ТипЗнч(Справочники.уатКодыГНГ.ПустаяСсылка()) Тогда
			ТолькоКодыЕТСНГ = Ложь;
		ИначеЕсли ТипЗнч(ТекПотребностьВагоны.КодГруза) = ТипЗнч(Справочники.уатКодыЕТСНГ.ПустаяСсылка()) Тогда
			ТолькоКодыГНГ = Ложь;
		КонецЕсли;
	КонецЦикла;
	Если ТолькоКодыЕТСНГ Тогда
		Элементы.ПотребностьИспользоватьКодЕТСНГ.Пометка = Истина;
		Элементы.ПотребностьИспользоватьКодГНГ.Пометка   = Ложь;
	ИначеЕсли ТолькоКодыГНГ Тогда
		Элементы.ПотребностьИспользоватьКодЕТСНГ.Пометка = Ложь;
		Элементы.ПотребностьИспользоватьКодГНГ.Пометка   = Истина;
	Иначе
		Элементы.ПотребностьИспользоватьКодЕТСНГ.Пометка = Ложь;
		Элементы.ПотребностьИспользоватьКодГНГ.Пометка   = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьФункциональнуюОпциюНаСервере(ИмяФункциональнойОпции)
	
	Возврат ПолучитьФункциональнуюОпцию(ИмяФункциональнойОпции);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьИспользованиеВидаПеревозкиДляЖДПеревозок(ВидПеревозки)
	Возврат ВидПеревозки.ИспользоватьДляЖДПеревозок;
КонецФункции

&НаКлиенте
Процедура ОчиститьКодыГруза()
	Если Объект.ДетализацияЗаказов = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоЗаказам") Тогда
		Для каждого ТекСтрока Из Объект.ПотребностьВВагонах Цикл
			ТекСтрока.КодГруза = Неопределено;
		КонецЦикла;
	ИначеЕсли Объект.ДетализацияЗаказов = ПредопределенноеЗначение("Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам") Тогда
		Объект.КодГруза = Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьКурсКратностьДокумента()
	ДатаКурса = ?(Объект.ДатаКурса = '00010101', Объект.Дата, Объект.ДатаКурса);
	СтруктураКурс = уатОбщегоНазначенияТиповые.ПолучитьКурсВалюты(Объект.ВалютаДокумента, ДатаКурса, Объект);
	Объект.КурсВзаиморасчетов = СтруктураКурс.Курс;
	Объект.КратностьВзаиморасчетов = СтруктураКурс.Кратность;
КонецПроцедуры

#КонецОбласти
