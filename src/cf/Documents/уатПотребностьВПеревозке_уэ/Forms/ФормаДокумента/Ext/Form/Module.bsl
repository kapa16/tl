		ЭтаФорма,,,,
		ОписаниеОповещенияОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца
	);
КонецПроцедуры

&НаКлиенте
Процедура РежимТехническогоСпециалиста(Команда)
	Элементы.ФормаРежимТехническогоСпециалиста.Пометка = Не Элементы.ФормаРежимТехническогоСпециалиста.Пометка;
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ВыборДатПоРасписанию(Команда)
	
	ТекСтрока = Элементы.ПунктыНазначения.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекСтрока.АдресОтправления) Или Не ЗначениеЗаполнено(ТекСтрока.АдресНазначения) Тогда
		ТекстНСтр = НСтр("ru = 'Перед выполнением операции необходимо заполнить адреса отправления и прибытия'; en = 'Before performing the operation, you must fill in the departure and arrival addresses.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат;
	КонецЕсли;
	
	ПараметрыВыбораДат = Новый Структура("АдресОтправления, АдресНазначения, Грузоотправитель, Грузополучатель, Маршрут");
	ЗаполнитьЗначенияСвойств(ПараметрыВыбораДат, ТекСтрока);
	ОповещениеОЗакрытииФормы = Новый ОписаниеОповещения("ВыборДатПоРасписаниюПослеВыбора", ЭтаФорма);
	ОткрытьФорму("Документ.уатЗаказГрузоотправителя.Форма.ФормаВыбораИзРасписания", ПараметрыВыбораДат, ЭтаФорма,,,,
		ОповещениеОЗакрытииФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСтавкуНДС(Команда)
	Если Элементы.Страницы.ТекущаяСтраница.Имя = "ГруппаТоварныйСостав" Тогда
		Если Объект.ТоварныйСостав.Количество() = 0 Тогда
			ТекстПредупреждения = НСтр("ru = 'В табличной части ""Товары"" не введено ни одной строки.';
			|en = 'No lines entered in the Item list.'");
			ПоказатьПредупреждение(, ТекстПредупреждения);
			Возврат;
		КонецЕсли;
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница.Имя = "ГруппаУслуги" Или Элементы.СтраницыПраваяКолонка.ТекущаяСтраница.Имя = "ГруппаУслуги2" Тогда
		Если Объект.Услуги.Количество() = 0 Тогда
			ТекстПредупреждения = НСтр("ru = 'В табличной части ""Доходы"" не введено ни одной строки.';
			|en = 'No lines entered in the Item list.'");
			ПоказатьПредупреждение(, ТекстПредупреждения);
			Возврат;
		КонецЕсли;
	ИначеЕсли Элементы.Страницы.ТекущаяСтраница.Имя = "ГруппаЗатраты" Или Элементы.СтраницыПраваяКолонка.ТекущаяСтраница.Имя = "ГруппаЗатраты2" Тогда
		Если Объект.Расходы.Количество() = 0 Тогда
			ТекстПредупреждения = НСтр("ru = 'В табличной части ""Расходы"" не введено ни одной строки.';
			|en = 'No lines entered in the Item list.'");
			ПоказатьПредупреждение(, ТекстПредупреждения);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	СписокСтавокНДС = ЗаполнитьСписокЗначенийСтавкиНДСНаСервере();
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьСтавкуНДСЗавершение", ЭтотОбъект);
	СписокСтавокНДС.ПоказатьВыборЭлемента(ОписаниеОповещения, "Ставки НДС");
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДопВыработку(Команда)
	
	ДобавитьДопВыработкуСервер(Истина);
	УстановитьДоступностьДопВыработки(); 
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьДопВыработку(Команда)
	
	Если ТекущийЭлемент = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Лев(ТекущийЭлемент.Имя, СтрДлина("ПараметрВыработкиУдалить")) = "ПараметрВыработкиУдалить" Тогда 
		УдалитьДопВыработкуСервер(Число(Прав(ТекущийЭлемент.Имя, СтрДлина(ТекущийЭлемент.Имя) - СтрДлина("ПараметрВыработкиУдалить"))));
		// Происходит сброс панелей
		уатЗащищенныеФункцииКлиент.уатДокументФормаЭлементаПриОткрытии(Ложь, ЭтотОбъект, ДопПараметрыОткрытие);
	КонецЕсли; 
	ЗаписатьДопВыработку();
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыСделатьОсновным(Команда)
	
	Для каждого ТекВариант Из Элементы.ТекущийВариантПеревозки.СписокВыбора Цикл
		Если ТекВариант.Значение = Объект.ТекущийВариантПеревозки И ТекВариант.Пометка Тогда
			Продолжить;
		КонецЕсли;
		Если ТекВариант.Значение = Объект.ТекущийВариантПеревозки Тогда
			ТекВариант.Представление = ТекВариант.Представление + Нстр("en = ' (Main)'; ru = ' (Основной)'");
			ТекВариант.Пометка = Истина;
		Иначе
			ТекВариант.Представление = СтрЗаменить(ТекВариант.Представление,  Нстр("en = ' (Main)'; ru = ' (Основной)'"), "");
			ТекВариант.Пометка = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Объект.ОсновнойВариантПеревозки = Объект.ТекущийВариантПеревозки;
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыУдалить(Команда)
	
	Если Объект.КоличествоВариантовПеревозки < 2 Тогда
		Возврат;
	КонецЕсли;
	
	ВариантУдалить = Объект.ТекущийВариантПеревозки;
	ЭлементСпискаНовыйВариант = Элементы.ТекущийВариантПеревозки.СписокВыбора.НайтиПоЗначению(Объект.ТекущийВариантПеревозки);
	
	Элементы.ТекущийВариантПеревозки.СписокВыбора.Удалить(ЭлементСпискаНовыйВариант);
	
	Для каждого ТекВариант Из Элементы.ТекущийВариантПеревозки.СписокВыбора Цикл
		Если ТекВариант.Значение > ВариантУдалить Тогда
			ТекВариант.Представление = СтрЗаменить(ТекВариант.Представление, Строка(ТекВариант.Значение), Строка(ТекВариант.Значение - 1));
			ТекВариант.Значение = ТекВариант.Значение - 1;
		КонецЕсли;
	КонецЦикла;
	
	УдалитьСтрокиВариантаИзТЧ(Объект.ВариантыПараметровПеревозки, ВариантУдалить);
	
	УдалитьСтрокиВариантаИзТЧ(Объект.Услуги, ВариантУдалить);
	
	УдалитьСтрокиВариантаИзТЧ(Объект.Расходы, ВариантУдалить);
	
	Для каждого ТекСтрокаВариантаПараметровПеревозки Из Объект.ВариантыПараметровПеревозки Цикл
		ТекСтрокаВариантаПараметровПеревозки.НомерВарианта = ?(ТекСтрокаВариантаПараметровПеревозки.НомерВарианта > ВариантУдалить,
			ТекСтрокаВариантаПараметровПеревозки.НомерВарианта - 1, ТекСтрокаВариантаПараметровПеревозки.НомерВарианта);
	КонецЦикла;
	
	Для каждого ТекСтрокаДоходов Из Объект.Услуги Цикл
		ТекСтрокаДоходов.НомерВарианта = ?(ТекСтрокаДоходов.НомерВарианта > ВариантУдалить,
			ТекСтрокаДоходов.НомерВарианта - 1, ТекСтрокаДоходов.НомерВарианта);
	КонецЦикла;
	
	Для каждого ТекСтрокаВариантаРасходов Из Объект.Расходы Цикл
		ТекСтрокаВариантаРасходов.НомерВарианта = ?(ТекСтрокаВариантаРасходов.НомерВарианта > ВариантУдалить,
			ТекСтрокаВариантаРасходов.НомерВарианта - 1, ТекСтрокаВариантаРасходов.НомерВарианта);
	КонецЦикла;
	
	Объект.КоличествоВариантовПеревозки = Объект.КоличествоВариантовПеревозки - 1;
	
	Если Объект.ТекущийВариантПеревозки > Объект.КоличествоВариантовПеревозки Тогда
		Объект.ТекущийВариантПеревозки = Объект.ТекущийВариантПеревозки - 1;
	КонецЕсли;
	
	ЗаполнитьВСоответсвииСВариантом();
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыСкопировать(Команда)
	
	КопируемыйВариант = Объект.ТекущийВариантПеревозки;
	Копирование = Истина;
	ДобавитьВариант(Объект.КоличествоВариантовПеревозки + 1);
	Объект.КоличествоВариантовПеревозки = Объект.КоличествоВариантовПеревозки + 1;
	Объект.ТекущийВариантПеревозки = Объект.КоличествоВариантовПеревозки;
	
	СкопироватьДанныеВарианта(КопируемыйВариант, Объект.ТекущийВариантПеревозки);
	
	ЗаполнитьВСоответсвииСВариантом();
	ОбновитьКоличествоСтрокВШапкахТЧ();
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПолучаемыеУслуги(Команда)
	Если Модифицированность Тогда
		ТекстНСТР = НСтр("en='To perform this operation it is necessary to record the document. Continue?';ru='Для выполнения данной операции необходимо записать документ. Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("РассчитатьПолучаемыеУслугиЗаписать", ЭтотОбъект),
			ТекстНСТР, РежимДиалогаВопрос.ОКОтмена, , КодВозвратаДиалога.ОК);
		Возврат;
	КонецЕсли;
	
	РассчитатьПолучаемыеУслугиДействия();
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьПолучаемыеУслуги(Команда)
	
	ТекСтрокаПункта = Объект.ПунктыНазначения[0];
	
	Если ТекСтрокаПункта = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекСтрока Из Объект.Расходы Цикл
		Если ТекСтрока.ID <> ТекСтрокаПункта.ID Тогда
			Продолжить;
		КонецЕсли;
		
		ПересчитатьПолучаемыеУслугиВТекущейСтроке(ТекСтрока);
	КонецЦикла;
	
	РассчитатьСуммуДокумента();
	ОбновитьПодвалДоходовРасходов("Расходы");
	ОбновитьПараметрВыработкиВременный();
	ОбновитьВсегоВТЧЗатраты();
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьПолучаемыеУслугиВСтроке(Команда)
	ТекСтрока = Элементы.Расходы1.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПересчитатьПолучаемыеУслугиВТекущейСтроке(ТекСтрока);
	
	РассчитатьСуммуДокумента();
	ОбновитьПодвалДоходовРасходов("Расходы");
	ОбновитьПараметрВыработкиВременный();
	ОбновитьВсегоВТЧУслуги();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗаказНаТСИзПредварительнойПотребности(Команда)
	
	Если Модифицированность Или Объект.Ссылка.Пустая() Тогда
		Оповещение = Новый ОписаниеОповещения("СоздатьЗаказНаТСИзПредварительнойПотребностиЗаписатьДокумент", ЭтотОбъект);
		ТекстНСТР = НСтр("en='To perform this operation it is necessary to record the document. Continue?';ru='Для выполнения данной операции необходимо записать документ. Продолжить?'");
		ПоказатьВопрос(Оповещение, ТекстНСТР, РежимДиалогаВопрос.ОКОтмена,, КодВозвратаДиалога.ОК);
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Потребность", Объект.Ссылка);
	ОткрытьФорму("Документ.уатПотребностьВПеревозке_уэ.Форма.ФормаМастерСозданияЗаказаНаТС", ПараметрыФормы, 
		ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗаказНаТСИзПредварительнойПотребностиЗаписатьДокумент(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Не РезультатВопроса = КодВозвратаДиалога.ОК Тогда 
		Возврат;
	КонецЕсли;
	
	Если Записать() Тогда 
		ОсновнойВариант = 0;
		Для каждого ТекВариантПеревозки Из Элементы.ТекущийВариантПеревозки.СписокВыбора Цикл
			Если ТекВариантПеревозки.Пометка Тогда
				ОсновнойВариант = ТекВариантПеревозки.Значение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ОсновнойВариант = 0 Тогда
			ОсновнойВариант = Объект.ТекущийВариантПеревозки;
		КонецЕсли;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОсновнойВариант", ОсновнойВариант);
		ПараметрыФормы.Вставить("Потребность", Объект.Ссылка);
		ОткрытьФорму("Документ.уатПотребностьВПеревозке_уэ.Форма.ФормаМастерСозданияЗаказаНаТС", ПараметрыФормы,
			ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

