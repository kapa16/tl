	Элементы.ФормаОперацияОбеспечениеПланов.Пометка = флОбеспечениеПланов;
	
	Элементы.ГруппаОбеспечениеПланов.Видимость = флОбеспечениеПланов;
	Элементы.ТоварыЗаполнитьПоПланам.Видимость = флОбеспечениеПланов;
	
	Элементы.ТоварыСтавкаНДС.Видимость = Объект.УчитыватьНДС;
	Элементы.ТоварыСуммаНДС.Видимость  = Объект.УчитыватьНДС;
