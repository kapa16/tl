	Если Ответ = КодВозвратаДиалога.Да Тогда
		Объект.Товары.Очистить();
		ТоварыЗаполнитьПоПланамСервер();
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда
		ТоварыЗаполнитьПоПланамСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТоварыЗаполнитьПоПланамСервер()
	
	ТаблицаНоменклатуры = Объект.ОбеспечениеПланов.Выгрузить(, "Номенклатура, КоличествоПоПлану");
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТаблицаНоменклатуры.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТаблицаНоменклатуры.КоличествоПоПлану КАК ЧИСЛО) КАК Количество
	|ПОМЕСТИТЬ втТаблицаНоменклатуры
	|ИЗ
	|	&ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	СУММА(втТаблицаНоменклатуры.Количество) КАК Количество,
	|	СправочникНоменклатура.ЕдиницаХраненияОстатков КАК ЕдиницаИзмерения,
	|	СправочникНоменклатура.СтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	втТаблицаНоменклатуры КАК втТаблицаНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО втТаблицаНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	втТаблицаНоменклатуры.Номенклатура,
	|	СправочникНоменклатура.ЕдиницаХраненияОстатков,
	|	СправочникНоменклатура.СтавкаНДС");
	Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ТаблицаНоменклатуры);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
	
КонецПроцедуры

