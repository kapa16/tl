Процедура ПолучитьЗаказыДляПерепроведения(МассивЗаказов, Операция) Экспорт
	МассивЗаказовДляПерепроведения = Новый Массив;
	Если Не Операция.ЗаказНаТСВыполнен Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	уатЗаказГрузоотправителя.Ссылка КАК Заказ
	|ПОМЕСТИТЬ ВТ_Заказы
	|ИЗ
	|	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
	|ГДЕ
	|	уатЗаказГрузоотправителя.Ссылка В(&МассивЗаказов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_Заказы.Заказ.Ссылка КАК Заказ,
	|	ЕСТЬNULL(уатЗаказыГрузоотправителейОстатки.КоличествоОстаток, 0) КАК Количество
	|ИЗ
	|	ВТ_Заказы КАК ВТ_Заказы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.уатЗаказыГрузоотправителей.Остатки(
	|				&МоментВремени,
	|				ЗаказГрузоотправителя В
	|					(ВЫБРАТЬ
	|						Заказы.Заказ
	|					ИЗ
	|						ВТ_Заказы КАК Заказы)) КАК уатЗаказыГрузоотправителейОстатки
	|		ПО ВТ_Заказы.Заказ.Ссылка = уатЗаказыГрузоотправителейОстатки.ЗаказГрузоотправителя.Ссылка";
	Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
	Запрос.УстановитьПараметр("МоментВремени", Дата("39991101"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			Продолжить;
		КонецЕсли;
		МассивЗаказовДляПерепроведения.Добавить(Выборка.Заказ);
	КонецЦикла;
	
	Для каждого ТекЗаказ Из МассивЗаказовДляПерепроведения Цикл
		ТекЗаказОбъект = ТекЗаказ.ПолучитьОбъект();
		//Попытка
			ТекЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		//Исключение
		//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось провести заказ '; en = 'Failed to process your order'") + ТекЗаказ.Номер);
		//КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

