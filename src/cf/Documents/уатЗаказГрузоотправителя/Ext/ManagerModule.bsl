	КонецЕсли;
	
	Если НеФормироватьДвиженийПоУслугам Тогда
		ТаблицаДоходы  = Новый ТаблицаЗначений();
		ТаблицаРасходы = Новый ТаблицаЗначений();
	Иначе
		ТаблицаДоходы  = МассивРезультатов[4].Выгрузить();
		ТаблицаРасходы = МассивРезультатов[5].Выгрузить();
