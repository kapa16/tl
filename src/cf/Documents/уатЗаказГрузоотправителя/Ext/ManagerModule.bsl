Функция ЗаполнитьПотребностьВВагонахПоКодам(ГрузовыеМеста, Код, Потребность) Экспорт
	
	Потребность.Очистить();
	
	ВсеГрузовыеМеста = ГрузовыеМеста.Скопировать();
	ВсеГрузовыеМеста.Колонки.Добавить("Код");
	
	ДобавлятьID    = Ложь;
	ДобавлятьЗаказ = Ложь;
	Если ВсеГрузовыеМеста.Колонки.Найти("ID") <> Неопределено Тогда
		ДобавлятьID = Истина;
	ИначеЕсли ВсеГрузовыеМеста.Колонки.Найти("Заказ") <> Неопределено Тогда
		ДобавлятьЗаказ = Истина;
	КонецЕсли;
	
	Для каждого ТекГМ Из ВсеГрузовыеМеста Цикл
		НоваяСтрокаПотребности = Потребность.Добавить();
		Если Код = "ГНГ" Тогда
			НоваяСтрокаПотребности.КодГруза = ТекГМ.ГрузовоеМесто.КодГНГ;
		Иначе
			НоваяСтрокаПотребности.КодГруза = ТекГМ.ГрузовоеМесто.КодЕТСНГ;
		КонецЕсли;
		НоваяСтрокаПотребности.Вес   = ТекГМ.ВесБрутто;
		НоваяСтрокаПотребности.Объем = ТекГМ.Объем;
		Если ДобавлятьID Тогда
			НоваяСтрокаПотребности.ID = ТекГМ.ID;
		ИначеЕсли ДобавлятьЗаказ Тогда
			НоваяСтрокаПотребности.ЗаказНаТС = ТекГМ.Заказ;
		КонецЕсли;
	КонецЦикла;
	Если ДобавлятьID Тогда
		Потребность.Свернуть("ID, КодГруза", "Вес, Объем");
	ИначеЕсли ДобавлятьЗаказ Тогда
		Потребность.Свернуть("ЗаказНаТС, КодГруза", "Вес, Объем");
	Иначе
		Потребность.Свернуть("КодГруза", "Вес, Объем");
	КонецЕсли;
	Возврат Потребность;
	
КонецФункции

Процедура ПолучитьФактПоПараметрамВыработки(ФактПараметрыВыработки, Сценарий, ДокументСсылка, ПараметрыВыработкиПоПлану)
	
	ПараметрыВыработкиПоПлануТЗ = Новый ТаблицаЗначений;
	ПараметрыВыработкиПоПлануТЗ.Колонки.Добавить("ПараметрВыработки");
	
	Для каждого ТекПараметр Из ПараметрыВыработкиПоПлану Цикл
		НоваяСтрока = ПараметрыВыработкиПоПлануТЗ.Добавить();
		НоваяСтрока.ПараметрВыработки = ТекПараметр;
	КонецЦикла;
	
	флДетализацияПланированияПоГруппам = Ложь;
	флМаршрутПоГруппам = Ложь;
	флНоменклатураПоГруппам = Ложь;
	флКолоннаПоГруппам = Ложь;
	флОбъектСтроительстваПоГруппам = Ложь;
	флНаправлениеПеревозкиПоГруппам = Ложь;
	флКонтрагентПоГруппам = Ложь;
	
	РазрезыПланирования = Сценарий.РазрезыПланирования.Выгрузить();
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.ТС) <> Неопределено Тогда
		ДетализацияПланирования = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.ТС).ВариантАналитики;
		флДетализацияПланированияПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.ТС).ПланированиеПоГруппам;
	Иначе
		ДетализацияПланирования = Перечисления.уатВариантыАналитик.ПустаяСсылка();
	КонецЕсли;
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Маршрут) <> Неопределено Тогда
		Маршрут = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Маршрут).ВариантАналитики;
		флМаршрутПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Маршрут).ПланированиеПоГруппам;
	Иначе
		Маршрут = Перечисления.уатВариантыАналитик.ПустаяСсылка();
	КонецЕсли;
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.НоменклатураГруза) <> Неопределено Тогда
		Номенклатура = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.НоменклатураГруза).ВариантАналитики;
		флНоменклатураПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.НоменклатураГруза).ПланированиеПоГруппам;
	Иначе
		Номенклатура = Перечисления.уатВариантыАналитик.ПустаяСсылка();
	КонецЕсли;
	
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Колонна) <> Неопределено Тогда
		флКолоннаПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Колонна).ПланированиеПоГруппам;
	КонецЕсли;
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.ОбъектСтроительства) <> Неопределено Тогда
		флОбъектСтроительстваПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.ОбъектСтроительства).ПланированиеПоГруппам;
	КонецЕсли;
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.НаправлениеПеревозки) <> Неопределено Тогда
		флНаправлениеПеревозкиПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.НаправлениеПеревозки).ПланированиеПоГруппам;
	КонецЕсли;
	Если РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Контрагент) <> Неопределено Тогда
		флКонтрагентПоГруппам = РазрезыПланирования.Найти(Перечисления.уатРазрезыПланирования.Контрагент).ПланированиеПоГруппам;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС КАК ЗаказНаТС,
	|	ВЫБОР
	|		КОГДА &Номенклатура = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.КодЕТСНГ)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Груз.КодЕТСНГ
	|		КОГДА &Номенклатура = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.КодГНГ)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Груз.КодГНГ
	|	КОНЕЦ КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТипТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон.ТипТС
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПринадлежностьТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон.ПринадлежностьТС
	|	КОНЕЦ КАК Вагон,
	|	СУММА(уатОбеспечениеЗаказовНаТСВагонами.Вес) КАК Вес,
	|	СУММА(уатОбеспечениеЗаказовНаТСВагонами.Объем) КАК Объем,
	|	ЕСТЬNULL(уатМестонахождениеТССрезПоследних.Колонна, ЗНАЧЕНИЕ(Справочник.уатКолонны.ПустаяСсылка)) КАК Колонна
	|ПОМЕСТИТЬ ВТ_Обеспеченность
	|ИЗ
	|	РегистрСведений.уатОбеспечениеЗаказовНаТСВагонами КАК уатОбеспечениеЗаказовНаТСВагонами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатМестонахождениеТС.СрезПоследних(&МВ, ) КАК уатМестонахождениеТССрезПоследних
	|		ПО уатОбеспечениеЗаказовНаТСВагонами.Вагон = уатМестонахождениеТССрезПоследних.ТС
	|ГДЕ
	|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС,
	|	ВЫБОР
	|		КОГДА &Номенклатура = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.КодЕТСНГ)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Груз.КодЕТСНГ
	|		КОГДА &Номенклатура = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.КодГНГ)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Груз.КодГНГ
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТипТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон.ТипТС
	|		КОГДА &ДетализацияПланирования = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПринадлежностьТС)
	|			ТОГДА уатОбеспечениеЗаказовНаТСВагонами.Вагон.ПринадлежностьТС
	|	КОНЕЦ,
	|	ЕСТЬNULL(уатМестонахождениеТССрезПоследних.Колонна, ЗНАЧЕНИЕ(Справочник.уатКолонны.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Обеспеченность.Вагон КАК ДетализацияПланирования,
	|	ВЫБОР
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.Маршрут)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.Маршрут, ЗНАЧЕНИЕ(Справочник.уатМаршруты.ПустаяСсылка))
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПунктНазначения)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.АдресНазначения, ЗНАЧЕНИЕ(Справочник.уатПунктыНазначения.ПустаяСсылка))
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПунктОтправления)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.АдресОтправления, ЗНАЧЕНИЕ(Справочник.уатПунктыНазначения.ПустаяСсылка))
	|	КОНЕЦ КАК Маршрут,
	|	СУММА(ВТ_Обеспеченность.Вес) КАК ВесГрузаКоличество,
	|	СУММА(ВТ_Обеспеченность.Объем) КАК ОбъемКоличество,
	|	ВТ_Обеспеченность.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ВидПеревозки, ЗНАЧЕНИЕ(Справочник.уатВидыПеревозок.ПустаяСсылка)) КАК ВидПеревозки,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Организация, ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)) КАК Организация,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Подразделение, ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)) КАК Подразделение,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ОбъектСтроительства, ЗНАЧЕНИЕ(Справочник.уатОбъектыСтроительства.ПустаяСсылка)) КАК ОбъектСтроительства,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.НаправлениеПеревозки, ЗНАЧЕНИЕ(Справочник.уатНаправленияПеревозок.ПустаяСсылка)) КАК НаправлениеПеревозки,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Ссылка, ЗНАЧЕНИЕ(Документ.уатЗаказГрузоотправителя.ПустаяСсылка)) КАК Регистратор,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ДоставкаПо, ДАТАВРЕМЯ(1, 1, 1)) КАК Период,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ДоговорКонтрагента, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК Договор,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_Обеспеченность.Вагон) КАК КоличествоВагоновКоличество,
	|	&Сценарий КАК Сценарий,
	|	ВТ_Обеспеченность.Колонна КАК Колонна,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Ответственный, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)) КАК Менеджер
	|ИЗ
	|	ВТ_Обеспеченность КАК ВТ_Обеспеченность
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
	|		ПО (уатЗаказГрузоотправителя.Ссылка = ВТ_Обеспеченность.ЗаказНаТС)
	|ГДЕ
	|	уатЗаказГрузоотправителя.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	уатЗаказГрузоотправителя.ВидПеревозки,
	|	уатЗаказГрузоотправителя.Организация,
	|	уатЗаказГрузоотправителя.Подразделение,
	|	уатЗаказГрузоотправителя.ОбъектСтроительства,
	|	уатЗаказГрузоотправителя.НаправлениеПеревозки,
	|	уатЗаказГрузоотправителя.Ссылка,
	|	ВТ_Обеспеченность.Вагон,
	|	ВЫБОР
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.Маршрут)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.Маршрут, ЗНАЧЕНИЕ(Справочник.уатМаршруты.ПустаяСсылка))
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПунктНазначения)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.АдресНазначения, ЗНАЧЕНИЕ(Справочник.уатПунктыНазначения.ПустаяСсылка))
	|		КОГДА &Маршрут = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ПунктОтправления)
	|			ТОГДА ЕСТЬNULL(уатЗаказГрузоотправителя.АдресОтправления, ЗНАЧЕНИЕ(Справочник.уатПунктыНазначения.ПустаяСсылка))
	|	КОНЕЦ,
	|	ВТ_Обеспеченность.Номенклатура,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ДоставкаПо, ДАТАВРЕМЯ(1, 1, 1)),
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)),
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.ДоговорКонтрагента, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)),
	|	ВТ_Обеспеченность.Колонна,
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Ответственный, 0),
	|	ЕСТЬNULL(уатЗаказГрузоотправителя.Ответственный, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка))";
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("ДетализацияПланирования", ДетализацияПланирования);
	Запрос.УстановитьПараметр("Маршрут", Маршрут);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Сценарий", Сценарий);
	Запрос.УстановитьПараметр("МВ", ДокументСсылка.ОтправлениеС);
	
	Запрос.УстановитьПараметр("флДетализацияПланированияПоГруппам", флДетализацияПланированияПоГруппам);
	Запрос.УстановитьПараметр("флМаршрутПоГруппам", флМаршрутПоГруппам);
	Запрос.УстановитьПараметр("флНоменклатураПоГруппам", флНоменклатураПоГруппам);
	Запрос.УстановитьПараметр("флКолоннаПоГруппам", флКолоннаПоГруппам);
	Запрос.УстановитьПараметр("флОбъектСтроительстваПоГруппам", флОбъектСтроительстваПоГруппам);
	Запрос.УстановитьПараметр("флНаправлениеПеревозкиПоГруппам", флНаправлениеПеревозкиПоГруппам);
	Запрос.УстановитьПараметр("флКонтрагентПоГруппам", флКонтрагентПоГруппам);
	
	ТЗВесОбъем = Запрос.Выполнить().Выгрузить();
	
	Для каждого ТекТЗВесОбъем Из ТЗВесОбъем Цикл
		Если флДетализацияПланированияПоГруппам Тогда
			ТекТЗВесОбъем.ДетализацияПланирования = ТекТЗВесОбъем.ДетализацияПланирования.Родитель;
		КонецЕсли;
		Если флМаршрутПоГруппам Тогда
			ТекТЗВесОбъем.Маршрут = ТекТЗВесОбъем.Маршрут.Родитель;
		КонецЕсли;
		Если флНоменклатураПоГруппам Тогда
			ТекТЗВесОбъем.Номенклатура = ТекТЗВесОбъем.Номенклатура.Родитель;
		КонецЕсли;
		Если флКолоннаПоГруппам Тогда
			ТекТЗВесОбъем.Колонна = ТекТЗВесОбъем.Колонна.Родитель;
		КонецЕсли;
		Если флОбъектСтроительстваПоГруппам Тогда
			ТекТЗВесОбъем.ОбъектСтроительства = ТекТЗВесОбъем.ОбъектСтроительства.Родитель;
		КонецЕсли;
		Если флНаправлениеПеревозкиПоГруппам Тогда
			ТекТЗВесОбъем.НаправлениеПеревозки = ТекТЗВесОбъем.НаправлениеПеревозки.Родитель;
		КонецЕсли;
		Если флКонтрагентПоГруппам Тогда
			ТекТЗВесОбъем.Контрагент = ТекТЗВесОбъем.Контрагент.Родитель;
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекСтрокаВыработки Из ТЗВесОбъем Цикл
		
		ДобавитьВыработкуВФакт(ФактПараметрыВыработки, ТекСтрокаВыработки, ПараметрыВыработкиПоПлануТЗ, "Вес груза");
		ДобавитьВыработкуВФакт(ФактПараметрыВыработки, ТекСтрокаВыработки, ПараметрыВыработкиПоПлануТЗ, "Объем");
		ДобавитьВыработкуВФакт(ФактПараметрыВыработки, ТекСтрокаВыработки, ПараметрыВыработкиПоПлануТЗ, "Количество вагонов");
		
	КонецЦикла;
	
	// Доп. выработка
	Для каждого ТекДопВыработка из ДокументСсылка.Выработка Цикл
		Если ФактПараметрыВыработки.Найти(ТекДопВыработка.ПараметрВыработки, "ПараметрВыработки") <> Неопределено Тогда
			Для каждого ТекФактСтрока Из ФактПараметрыВыработки.НайтиСтроки(Новый Структура("ПараметрВыработки", ТекДопВыработка.ПараметрВыработки)) Цикл
				ТекФактСтрока.Количество = ТекФактСтрока.Количество + ТекДопВыработка.Значение;
			КонецЦикла;
		ИначеЕсли ТекДопВыработка.ПараметрВыработки.ДействуетНаТСЗаказ
			И ПараметрыВыработкиПоПлануТЗ.Найти(ТекДопВыработка.ПараметрВыработки) <> Неопределено Тогда
			Запрос.УстановитьПараметр("ДетализацияПланирования", Перечисления.уатВариантыАналитик.ПустаяСсылка());
			Запрос.УстановитьПараметр("Маршрут", Маршрут);
			Запрос.УстановитьПараметр("Номенклатура", Перечисления.уатВариантыАналитик.ПустаяСсылка());
			ВыгрузкаДляДопВыработки = Запрос.Выполнить().Выгрузить();
			Если ВыгрузкаДляДопВыработки.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			СтрокаДляДопВыработки = ВыгрузкаДляДопВыработки[0];
			СтрокаВыработки = ФактПараметрыВыработки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаВыработки, СтрокаДляДопВыработки);
			СтрокаВыработки.Сценарий = Сценарий;
			СтрокаВыработки.ПараметрВыработки = ТекДопВыработка.ПараметрВыработки;
			СтрокаВыработки.Количество = ТекДопВыработка.Значение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьТаблицуВыработки(ДокументСсылка, СтруктураДополнительныеСвойства)
	
	// Проверка на то были ли движения и нулевые остатки
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	уатЗаказыГрузоотправителей.ЗаказГрузоотправителя КАК ЗаказГрузоотправителя
	|ПОМЕСТИТЬ ВТ_Заказ
	|ИЗ
	|	РегистрНакопления.уатЗаказыГрузоотправителей КАК уатЗаказыГрузоотправителей
	|ГДЕ
	|	уатЗаказыГрузоотправителей.ЗаказГрузоотправителя = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_Заказ.ЗаказГрузоотправителя КАК ЗаказГрузоотправителя,
	|	ЕСТЬNULL(уатЗаказыГрузоотправителейОстатки.КоличествоОстаток, 0) КАК Количество
	|ИЗ
	|	ВТ_Заказ КАК ВТ_Заказ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.уатЗаказыГрузоотправителей.Остатки(
	|				&МоментВремени,
	|				ЗаказГрузоотправителя В
	|					(ВЫБРАТЬ
	|						Заказ.ЗаказГрузоотправителя
	|					ИЗ
	|						ВТ_Заказ КАК Заказ)) КАК уатЗаказыГрузоотправителейОстатки
	|		ПО ВТ_Заказ.ЗаказГрузоотправителя.Ссылка = уатЗаказыГрузоотправителейОстатки.ЗаказГрузоотправителя.Ссылка";
	
	Запрос.УстановитьПараметр("МоментВремени", Дата("39991101"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	// Проверка на действующий план работы ТС и составление таблицы с параметрами выработки и сценарием
	Запрос.Текст =
	"ВЫБРАТЬ
	|	уатПланированиеРаботыТС.Ссылка КАК Ссылка,
	|	уатПланированиеРаботыТС.Сценарий КАК Сценарий,
	|	уатПланированиеРаботыТССоставПлана.ПараметрВыработки КАК ПараметрВыработки,
	|	ВЫБОР
	|		КОГДА уатПланированиеРаботыТС.Сценарий.ВидПланирования = ЗНАЧЕНИЕ(Перечисление.уатВидыПланирования.Краткосрочный)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ВидПланирования,
	|	ВЫБОР
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ДЕКАДА)
	|			ТОГДА 0
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|			ТОГДА 1
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
	|			ТОГДА 2
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ПОЛУГОДИЕ)
	|			ТОГДА 3
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
	|			ТОГДА 4
	|	КОНЕЦ КАК Периодичность
	|ИЗ
	|	Документ.уатПланированиеРаботыТС КАК уатПланированиеРаботыТС
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатПланированиеРаботыТС.СоставПлана КАК уатПланированиеРаботыТССоставПлана
	|		ПО уатПланированиеРаботыТС.Ссылка = уатПланированиеРаботыТССоставПлана.Ссылка
	|ГДЕ
	|	уатПланированиеРаботыТС.Проведен
	|	И &Дата МЕЖДУ уатПланированиеРаботыТС.ДатаПланирования И ВЫБОР
	|			КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|				ТОГДА ДОБАВИТЬКДАТЕ(уатПланированиеРаботыТС.ДатаПланирования, МЕСЯЦ, 1)
	|			КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
	|				ТОГДА ДОБАВИТЬКДАТЕ(уатПланированиеРаботыТС.ДатаПланирования, ГОД, 1)
	|			КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
	|				ТОГДА ДОБАВИТЬКДАТЕ(уатПланированиеРаботыТС.ДатаПланирования, КВАРТАЛ, 1)
	|			КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ПОЛУГОДИЕ)
	|				ТОГДА ДОБАВИТЬКДАТЕ(уатПланированиеРаботыТС.ДатаПланирования, ПОЛУГОДИЕ, 1)
	|			КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ДЕКАДА)
	|				ТОГДА ДОБАВИТЬКДАТЕ(уатПланированиеРаботыТС.ДатаПланирования, ДЕКАДА, 1)
	|		КОНЕЦ
	|	И уатПланированиеРаботыТС.Сценарий.Раздел = ЗНАЧЕНИЕ(Перечисление.уатРазделыПланирования.ЗаказыНаЖДПеревозки)
	|	И уатПланированиеРаботыТС.Организация = &Организация
	|
	|СГРУППИРОВАТЬ ПО
	|	уатПланированиеРаботыТССоставПлана.ПараметрВыработки,
	|	уатПланированиеРаботыТС.Ссылка,
	|	уатПланированиеРаботыТС.Сценарий,
	|	ВЫБОР
	|		КОГДА уатПланированиеРаботыТС.Сценарий.ВидПланирования = ЗНАЧЕНИЕ(Перечисление.уатВидыПланирования.Краткосрочный)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ДЕКАДА)
	|			ТОГДА 0
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|			ТОГДА 1
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
	|			ТОГДА 2
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.ПОЛУГОДИЕ)
	|			ТОГДА 3
	|		КОГДА уатПланированиеРаботыТС.Сценарий.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
	|			ТОГДА 4
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Периодичность,
	|	ВидПланирования";
	Запрос.УстановитьПараметр("Организация", ДокументСсылка.Организация);
	Запрос.УстановитьПараметр("Дата", ДокументСсылка.ДоставкаПо);
	
	СценарийПланирования = Запрос.Выполнить().Выгрузить();
	Если СценарийПланирования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	РазрезыПланированияСценария = СценарийПланирования[0].Сценарий.РазрезыПланирования;
	
	ФактПараметрыВыработки = Новый ТаблицаЗначений;
	ФактПараметрыВыработки.Колонки.Добавить("Регистратор");
	ФактПараметрыВыработки.Колонки.Добавить("Менеджер");
	ФактПараметрыВыработки.Колонки.Добавить("Период");
	ФактПараметрыВыработки.Колонки.Добавить("Сценарий");
	ФактПараметрыВыработки.Колонки.Добавить("ПараметрВыработки");
	ФактПараметрыВыработки.Колонки.Добавить("Организация");
	ФактПараметрыВыработки.Колонки.Добавить("ДетализацияПланирования");
	ФактПараметрыВыработки.Колонки.Добавить("Количество");
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.Подразделение, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Подразделение");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.ВидПеревозки, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("ВидПеревозки");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.ОбъектСтроительства, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("ОбъектСтроительства");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.Контрагент, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Контрагент");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.Договор, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Договор");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.Маршрут, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Маршрут");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.НаправлениеПеревозки, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("НаправлениеПеревозки");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.НоменклатураГруза, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Номенклатура");
	КонецЕсли;
	Если РазрезыПланированияСценария.Найти(Перечисления.уатРазрезыПланирования.Колонна, "РазрезПланирования") <> Неопределено Тогда
		ФактПараметрыВыработки.Колонки.Добавить("Колонна");
	КонецЕсли;
	//ФактПараметрыВыработки.Колонки.Добавить("Регистратор");
	ПолучитьФактПоПараметрамВыработки(ФактПараметрыВыработки, СценарийПланирования[0].Сценарий, ДокументСсылка, СценарийПланирования.ВыгрузитьКолонку("ПараметрВыработки"));
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаФактВыработки", ФактПараметрыВыработки);
КонецПроцедуры

