Функция ПечатьЕдиныйТранспортныйДокумент(МассивЗаказов, ОбъектыПечати, ПараметрыПечати)
	
	мсвРейсов = ПараметрыПечати.мсвРейсов;
	мсвЭтапов = ПараметрыПечати.мсвЭтапов;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ЕдиныйТранспортныйДокумент";
	ТабличныйДокумент.ОриентацияСтраницы   = ОриентацияСтраницы.Портрет;
	
	ЗаказНаТС = ?(МассивЗаказов.Количество() = 0, Неопределено, МассивЗаказов[0]);
	
	Если ЗаказНаТС = Неопределено Тогда
		Возврат 1;
	КонецЕсли;
	
	тзРейсы = Новый ТаблицаЗначений();
	тзРейсы.Колонки.Добавить("Заказ", Новый ОписаниеТипов("ДокументСсылка.уатЗаказГрузоотправителя"));
	тзРейсы.Колонки.Добавить("Рейс",  Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист, ДокументСсылка.уатЗаказПеревозчику_уэ"));
	Для Каждого ТекМЛ Из мсвРейсов Цикл 
		НоваяСтрока = тзРейсы.Добавить();
		НоваяСтрока.Заказ = ЗаказНаТС;
		НоваяСтрока.Рейс  = ТекМЛ;
	КонецЦикла;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("тзРейсы",  тзРейсы);
	Запрос.УстановитьПараметр("мсвЭтапов",  мсвЭтапов);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	тзРейсы.Заказ КАК Заказ,
	|	тзРейсы.Рейс КАК Рейс
	|ПОМЕСТИТЬ втРейсы
	|ИЗ
	|	&тзРейсы КАК тзРейсы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	втРейсы.Заказ КАК Заказ,
	|	втРейсы.Рейс КАК Рейс,
	|	уатМаршрутныйЛист.ТС КАК ТС,
	|	уатМаршрутныйЛист.Водитель1 КАК Водитель1,
	|	уатМаршрутныйЛист.Водитель2 КАК Водитель2,
	|	уатМаршрутныйЛист.Контрагент КАК Контрагент,
	|	уатМаршрутныйЛист.Ответственный КАК Ответственный,
	|	уатМаршрутныйЛист.Организация КАК Организация,
	|	уатМаршрутныйЛист.ВалютаДокумента КАК ВалютаДокумента,
	|	уатМаршрутныйЛист.Дата КАК Дата
	|ПОМЕСТИТЬ втВыборка
	|ИЗ
	|	втРейсы КАК втРейсы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	|		ПО втРейсы.Рейс = уатМаршрутныйЛист.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	уатМаршрутныйЛистЗаказы.Ссылка КАК Ссылка,
	|	уатМаршрутныйЛистЗаказы.НомерСтроки КАК НомерСтроки,
	|	уатМаршрутныйЛистЗаказы.GUIDСтроки КАК GUIDСтроки,
	|	уатМаршрутныйЛистЗаказы.ВесБрутто КАК ВесБрутто,
