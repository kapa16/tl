Функция ВернутьОтветHTTPЗапроса(JSONОбъект)
	
	HTTPСоединение = GDS_ФункцииОбмена.ПолучитьСоединениеHTTP("evm.mecamineft.com");
	
    ЗаголовокЗапросаHTTP = Новый Соответствие();
	
	ЗаголовокЗапросаHTTP.Вставить("Content-Type", "application/json; charset=utf-8");
	
    ЗапросHTTP = Новый HTTPЗапрос(GDS_ФункцииОбмена.ПолучитьАдресРесурсаДляHTTPЗапроса("Бухгалтерия_МеКаМи"), ЗаголовокЗапросаHTTP);
	                     
    //создадим заголовок запроса
	
	ЗапросHTTP.УстановитьТелоИзСтроки(JSONОбъект, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);	
	
	HTTPОтвет = HTTPСоединение.ВызватьHTTPМетод("POST",ЗапросHTTP);
	
	HTTPСоединение = Неопределено;
	
	Возврат HTTPОтвет;
	
КонецФункции

&НаСервере
Процедура КомандаРазблокироватьНаСервере()
	
	Структура = Новый Структура(); 
	
	Структура.Вставить("Type",Объект.Ссылка.ПолучитьОбъект().Метаданные().Имя);
	Структура.Вставить("Ref",строка(Объект.Ссылка.УникальныйИдентификатор()));
	Структура.Вставить("СтаусЭДО", "Разблокирован");
	
	JSONОбъект = GDS_ФункцииОбмена.ПолучитьОбъектJSON(Структура,Истина);
	
	HTTPОтвет = ВернутьОтветHTTPЗапроса(JSONОбъект);
	
    Сообщение = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	Если HTTPОтвет.КодСостояния = 200 тогда
	
		ЧтениеJSON 		= Новый ЧтениеJSON;
	    ЧтениеJSON.УстановитьСтроку(Сообщение);
	    ДанныеДругойБазы = ПрочитатьJSON(ЧтениеJSON);
	    ЧтениеJSON.Закрыть();
	
		Если ДанныеДругойБазы.Результат <> "НеСмогЗаписатьДокумент" Тогда 
			Сообщить("Документ разблокирован");
		Иначе
			Сообщить("Не смог разблокировать документ, сообщите программистам.");
		КонецЕсли;
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура КомандаРазблокировать(Команда)
	КомандаРазблокироватьНаСервере();
КонецПроцедуры

