КонецПроцедуры

 &НаСервере
Процедура ВывестиИнформациюПоТТН(ИдентификаторСтроки = 0)

	Если ИдентификаторСтроки = 0 Тогда
		Для каждого СтрокаМаршруты Из Объект.Маршруты Цикл
			ОписаниеТТН = "";
			МассаНетто = 0;
			мСтрокиТТН = Объект.ТТН.НайтиСтроки(Новый Структура("ИдентификаторСтрокиМаршруты",СтрокаМаршруты.ИдентификаторСтроки));
			Для Каждого Строка Из  мСтрокиТТН Цикл 
				ОписаниеТТН = ОписаниеТТН + Строка.ТТН + ";";
				МассаНетто = МассаНетто + Строка.МассаНетто;
			КонецЦикла;	
			Если ОписаниеТТН = "" Тогда
				ОписаниеТТН = "Выбрать ТТН";
			Конецесли;
			СтрокаМаршруты.ГиперссылкаТТН = ОписаниеТТН; 
			СтрокаМаршруты.ТТНМассаНетто = МассаНетто; 
		КонецЦикла;
	Иначе	
		ОписаниеТТН = "";
    	МассаНетто = 0;
		мСтрокиТТН = Объект.ТТН.НайтиСтроки(Новый Структура("ИдентификаторСтрокиМаршруты",ИдентификаторСтроки));
		Для Каждого Строка Из  мСтрокиТТН Цикл 
			ОписаниеТТН = ОписаниеТТН + Строка.ТТН + ";";
			МассаНетто = МассаНетто + Строка.МассаНетто;
		КонецЦикла;
		Если ОписаниеТТН = "" Тогда
			ОписаниеТТН = "Выбрать ТТН";
		Конецесли;
		мСтрокиМаршруты = Объект.Маршруты.НайтиСтроки(Новый Структура("ИдентификаторСтроки",ИдентификаторСтроки));
		мСтрокиМаршруты[0].ГиперссылкаТТН = ОписаниеТТН;
		мСтрокиМаршруты[0].ТТНМассаНетто = МассаНетто;
	КонецЕсли;
	
КонецПроцедуры
