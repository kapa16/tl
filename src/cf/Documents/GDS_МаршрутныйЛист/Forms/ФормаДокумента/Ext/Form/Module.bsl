&НаСервере
Процедура ВывестиТабльныеНомераВодителей()
	Если ЗначениеЗаполнено(Объект.Водитель1) Тогда
		ТабельныйНомер1 = Объект.Водитель1.Код;	
	КонецЕсли;	
	Если ЗначениеЗаполнено(Объект.Водитель2) Тогда
		ТабельныйНомер2 = Объект.Водитель2.Код;	
	КонецЕсли;	
КонецПроцедуры

