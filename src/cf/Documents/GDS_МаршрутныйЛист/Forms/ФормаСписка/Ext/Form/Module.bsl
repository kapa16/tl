
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Элементы.Список.РежимВыбора = Параметры.РежимВыбора;
	
	Если Параметры.Свойство("ПодборМаршрутногоЛиста") Тогда
		
		Элементы.Список.РежимВыбора = Истина;
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	GDS_МаршрутныйЛистМаршруты.Ссылка КАК Ссылка
		               |ИЗ
		               |	Документ.GDS_МаршрутныйЛист.Маршруты КАК GDS_МаршрутныйЛистМаршруты
		               |ГДЕ
		               |	GDS_МаршрутныйЛистМаршруты.Ссылка.ТС = &ТС
		               |	И НАЧАЛОПЕРИОДА(GDS_МаршрутныйЛистМаршруты.Дата, ДЕНЬ) = &ДатаВыезда
		               |	И (GDS_МаршрутныйЛистМаршруты.Ссылка.Водитель1.ФизическоеЛицо В (&Водители)
		               |				И GDS_МаршрутныйЛистМаршруты.Смена = 1
		               |			ИЛИ GDS_МаршрутныйЛистМаршруты.Ссылка.Водитель2.ФизическоеЛицо В (&Водители)
		               |				И GDS_МаршрутныйЛистМаршруты.Смена = 2)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	GDS_МаршрутныйЛистМаршруты.Ссылка";

		ВодителиФизическоеЛицо = Новый Массив;
		Для каждого СтрокаВодители Из Параметры.Отбор.Водители Цикл
		    ВодителиФизическоеЛицо.Добавить(СтрокаВодители.ФизическоеЛицо);
		КонецЦикла; 
		 
		Запрос.УстановитьПараметр("ТС", Параметры.Отбор.ТС);
		Запрос.УстановитьПараметр("Водители", ВодителиФизическоеЛицо);
		Запрос.УстановитьПараметр("ДатаВыезда", Параметры.Отбор.ДатаВыезда);
		
		МассивСсылкок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		
		Если МассивСсылкок.Количество() > 0 Тогда
			ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			//ЭлементОтбора.ВидСравнения 		= ВидСравненияКомпоновкиДанных.НеВСписке;
			ЭлементОтбора.ВидСравнения 		= ВидСравненияКомпоновкиДанных.ВСписке;
			ЭлементОтбора.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("Ссылка");
			ЭлементОтбора.ПравоеЗначение 	= МассивСсылкок;
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры 

#Область ОбработчикиКомандФормы

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Элементы.Список);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Элементы.Список, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Элементы.Список);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти
