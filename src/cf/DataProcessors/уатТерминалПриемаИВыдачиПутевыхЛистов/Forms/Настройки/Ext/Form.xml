<?xml version="1.0" encoding="UTF-8"?>
<Form xmlns="http://v8.1c.ru/8.3/xcf/logform" xmlns:app="http://v8.1c.ru/8.2/managed-application/core" xmlns:cfg="http://v8.1c.ru/8.1/data/enterprise/current-config" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcssch="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:ent="http://v8.1c.ru/8.1/data/enterprise" xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform" xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows" xmlns:xr="http://v8.1c.ru/8.3/xcf/readable" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.20">
	<Title>
		<v8:item>
			<v8:lang>ru</v8:lang>
			<v8:content>Настройки терминала путевых листов</v8:content>
		</v8:item>
		<v8:item>
			<v8:lang>en</v8:lang>
			<v8:content>Waybill terminal settings</v8:content>
		</v8:item>
	</Title>
	<AutoTitle>false</AutoTitle>
	<AutoCommandBar name="ФормаКоманднаяПанель" id="-1">
		<ChildItems>
			<Button name="ФормаОК" id="4">
				<Type>CommandBarButton</Type>
				<DefaultButton>true</DefaultButton>
				<CommandName>Form.Command.ПрименитьНастройки</CommandName>
				<ExtendedTooltip name="ФормаОКРасширеннаяПодсказка" id="5"/>
			</Button>
		</ChildItems>
	</AutoCommandBar>
	<Events>
		<Event name="OnCreateAtServer">ПриСозданииНаСервере</Event>
	</Events>
	<ChildItems>
		<InputField name="Комментарий" id="1">
			<DataPath>Комментарий</DataPath>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Произвольный комментарий, всегда отображаемый на форме терминала</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>A custom comment that is always displayed on the terminal form.</v8:content>
				</v8:item>
			</ToolTip>
			<ToolTipRepresentation>Button</ToolTipRepresentation>
			<AutoMaxWidth>false</AutoMaxWidth>
			<ContextMenu name="КомментарийКонтекстноеМеню" id="2"/>
			<ExtendedTooltip name="КомментарийРасширеннаяПодсказка" id="3"/>
		</InputField>
		<InputField name="ТаймерРаботыСоСтраницей" id="6">
			<DataPath>ТаймерРаботыСоСтраницей</DataPath>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>При открытии конкретной страницы запускается таймер и если пользователь не завершил работу со страницей за это время возникает окно "Продолжить работу". 
Если пользователь не подтвердил в течение 10 секунд, авторизация пользователя автоматически завершается.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>When a specific page is opened, a timer starts, and if the user hasn't completed working on the page within this time, a "Continue Working" window appears.
If the user doesn't confirm within 10 seconds, the user's authorization is automatically terminated.</v8:content>
				</v8:item>
			</ToolTip>
			<ToolTipRepresentation>Button</ToolTipRepresentation>
			<EditFormat>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ДФ=мм:сс; ДП=00:00</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>DF=mm:ss; DP=00:00</v8:content>
				</v8:item>
			</EditFormat>
			<ContextMenu name="ТаймерРаботыСоСтраницейКонтекстноеМеню" id="7"/>
			<ExtendedTooltip name="ТаймерРаботыСоСтраницейРасширеннаяПодсказка" id="8"/>
		</InputField>
		<InputField name="МаксимальноеКоличествоКопийПЛ" id="12">
			<DataPath>МаксимальноеКоличествоКопийПЛ</DataPath>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Максимальное количество распечатанных копий путевого листа</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Maximum number of printed copies of the waybill</v8:content>
				</v8:item>
			</ToolTip>
			<Width>7</Width>
			<SpinButton>true</SpinButton>
			<ContextMenu name="МаксимальноеКоличествоКопийПЛКонтекстноеМеню" id="13"/>
			<ExtendedTooltip name="МаксимальноеКоличествоКопийПЛРасширеннаяПодсказка" id="14"/>
		</InputField>
		<CheckBoxField name="РазрешитьАвторизациюПоШтрихкоду" id="9">
			<DataPath>РазрешитьАвторизациюПоШтрихкоду</DataPath>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Если настройка установлена, то водитель может перейти к закрытию путевого листа минуя этап авторизации.
Если сброшена - сперва нужно авторизоваться по штрихкоду/магнитной карте водителя и только после этого сканировать штрихкод путевого листа либо выбирать один из путевых листов на экране.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>If this setting is enabled, the driver can proceed to closing the waybill without going through the authorization step.
If this setting is disabled, the driver must first log in using the barcode/magnetic card and only then scan the waybill barcode or select one of the waybills on the screen.</v8:content>
				</v8:item>
			</ToolTip>
			<ToolTipRepresentation>Button</ToolTipRepresentation>
			<CheckBoxType>Auto</CheckBoxType>
			<ContextMenu name="РазрешитьАвторизациюПоШтрихкодуКонтекстноеМеню" id="10"/>
			<ExtendedTooltip name="РазрешитьАвторизациюПоШтрихкодуРасширеннаяПодсказка" id="11"/>
		</CheckBoxField>
	</ChildItems>
	<Attributes>
		<Attribute name="Комментарий" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Комментарий</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Comment</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:string</v8:Type>
				<v8:StringQualifiers>
					<v8:Length>150</v8:Length>
					<v8:AllowedLength>Variable</v8:AllowedLength>
				</v8:StringQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ТаймерРаботыСоСтраницей" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Время работы со страницей (минут)</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Time spent working with the page (minutes)</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:dateTime</v8:Type>
				<v8:DateQualifiers>
					<v8:DateFractions>Time</v8:DateFractions>
				</v8:DateQualifiers>
			</Type>
		</Attribute>
		<Attribute name="РазрешитьАвторизациюПоШтрихкоду" id="3">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Разрешить авторизацию по штрихкоду</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Allow barcode authorization</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:boolean</v8:Type>
			</Type>
		</Attribute>
		<Attribute name="МаксимальноеКоличествоКопийПЛ" id="4">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Максимальное количество распечатанных копий ПЛ</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Maximum number of printed copies of the PL</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>10</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
	</Attributes>
	<Commands>
		<Command name="ПрименитьНастройки" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Применить настройки</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Apply settings</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Применить настройки</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Apply settings</v8:content>
				</v8:item>
			</ToolTip>
			<Action>ПрименитьНастройки</Action>
			<CurrentRowUse>DontUse</CurrentRowUse>
		</Command>
	</Commands>
</Form>