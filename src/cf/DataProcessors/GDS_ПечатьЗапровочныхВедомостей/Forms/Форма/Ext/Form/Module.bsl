#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Печать(Команда)
	
	ТабличныйДокумент = ПечатьНаСервере();
	Представление = "Бланк заправочной ведомости";
	
	Идентификатор = "ПечатнаяФорма";
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(Идентификатор);
	ПечатнаяФорма = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
	
	ПечатнаяФорма.ТабличныйДокумент     = ТабличныйДокумент;
	ПечатнаяФорма.СинонимМакета         = Представление;
	ПечатнаяФорма.ИмяФайлаПечатнойФормы = Представление;
	
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПечатьНаСервере()
	Возврат Обработки.GDS_ПечатьЗапровочныхВедомостей.СформироватьПечатнуюФорму(Объект);
КонецФункции

