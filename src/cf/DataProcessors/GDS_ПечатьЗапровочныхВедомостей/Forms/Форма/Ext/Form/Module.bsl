
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.ДатаВедомостей = ТекущаяДатаСеанса();
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Объект.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	КонецЕсли;
	
	Если Параметры.Свойство("ДокументыЗаправочныеВедомости") Тогда
		Для Каждого ЗаправочнаяВедомость Из Параметры.ДокументыЗаправочныеВедомости Цикл
			НоваяСтрока = Объект.ДокументыДляПечати.Добавить();
			НоваяСтрока.ЗаправочнаяВедомость = ЗаправочнаяВедомость;
			НоваяСтрока.ТипВедомости = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаправочнаяВедомость, "ТипВедомости");
		КонецЦикла;
		Объект.ДокументыДляПечати.Сортировать("ТипВедомости");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Объект.ДокументыДляПечати.Количество() > 0 Тогда
		ПечатьПоДокументам();
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура АЗСПриИзменении(Элемент)
	
	ЗаполнитьПоследниеНомера();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриходныхПриИзменении(Элемент)
	
	ЗаполнитьПоследниеНомера();
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПереливныхПриИзменении(Элемент)
	
	ЗаполнитьПоследниеНомера();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы_ЗаправочныеВедомости

&НаКлиенте
Процедура ЗаправочныеВедомостиКонтрагентПриИзменении(Элемент)
	
	ЗаполнитьПоследниеНомера();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Печать(Команда)
	
	Идентификаторы = Новый Массив;
	
	ДанныеДляОбработки = ДанныеДляОбработкиПоНастройкам();
	Для Каждого СтрокаДанных Из ДанныеДляОбработки Цикл
		Если Идентификаторы.Найти(СтрокаДанных.Идентификатор) = Неопределено Тогда
			Идентификаторы.Добавить(СтрокаДанных.Идентификатор);
		КонецЕсли;
	КонецЦикла;
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(СтрСоединить(Идентификаторы, ","));
	
	Для Каждого СтрокаДанных Из ДанныеДляОбработки Цикл
		
		ТабличныйДокумент = ПечатьНаСервере(СтрокаДанных);
		
		Идентификатор = СтрокаДанных.Идентификатор;
		
		ПечатнаяФорма = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
		
		ПечатнаяФорма.ТабличныйДокумент     = ТабличныйДокумент;
		ПечатнаяФорма.СинонимМакета         = СтрокаДанных.ПредставлениеПечатнойФормы;
		ПечатнаяФорма.ИмяФайлаПечатнойФормы = СтрокаДанных.ПредставлениеПечатнойФормы;
		
	КонецЦикла;
	
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПечатьПоДокументам()
	
	Идентификаторы = Новый Массив;
	
	ДанныеДляОбработки = ДанныеДляОбработкиПоДокументам();
	Для Каждого ДанниеТип Из ДанныеДляОбработки Цикл
		Идентификаторы.Добавить(ДанниеТип.Ключ);
	КонецЦикла;
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(СтрСоединить(Идентификаторы, ","));
	
	Для Каждого ДанниеТип Из ДанныеДляОбработки Цикл
		
		ТабличныйДокумент = СформироватьПечатнуюФорму(ДанниеТип.Значение);
		
		Идентификатор = ДанниеТип.Ключ;
		ПечатнаяФорма = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
		
		ПечатнаяФорма.ТабличныйДокумент     = ТабличныйДокумент;
		ПечатнаяФорма.СинонимМакета         = ДанниеТип.Значение[0].ПредставлениеПечатнойФормы;
		ПечатнаяФорма.ИмяФайлаПечатнойФормы = ДанниеТип.Значение[0].ПредставлениеПечатнойФормы;
		
	КонецЦикла;
	
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоследниеНомера()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Обработка.ЗаполнитьПоследниеНомера();
	ЗначениеВРеквизитФормы(Обработка, "Объект");
	
КонецПроцедуры

&НаСервере
Функция ДанныеДляОбработкиПоНастройкам()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Возврат Обработка.ДанныеДляОбработкиПоНастройкам();
	
КонецФункции

&НаСервере
Функция ДанныеДляОбработкиПоДокументам()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Возврат Обработка.ДанныеДляОбработкиПоДокументам();
	
КонецФункции

&НаСервере
Функция ПечатьНаСервере(СтрокаДанных)
	
	Обработка = РеквизитФормыВЗначение("Объект");
	ТабличныйДокумент = Обработка.Обработать(СтрокаДанных);
	ЗначениеВРеквизитФормы(Обработка, "Объект");
	
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаСервере
Функция СформироватьПечатнуюФорму(Знач Ведомости)
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Возврат Обработка.СформироватьПечатнуюФорму(Ведомости);
	
КонецФункции

#КонецОбласти

