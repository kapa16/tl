							<Type>Hyperlink</Type>
							<CommandName>Form.Command.ВыбратьТипЗаказаFTL</CommandName>
							<ExtendedTooltip name="ВыбратьТипЗаказаFTLРасширеннаяПодсказка" id="20"/>
