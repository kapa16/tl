							<Type>Hyperlink</Type>
							<CommandName>Form.Command.ВыбратьТипЗаказаМультимодальный</CommandName>
							<ExtendedTooltip name="ВыбратьТипЗаказаМультимодальныйРасширеннаяПодсказка" id="22"/>
