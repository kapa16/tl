&НаСервере
Процедура ЗапроситьДанныеНаСервере()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	ОтветСервера = Обработка.ЗапроситьДанныеИзСервисаЧекЛистов(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности);
	detailsIn = Обработка.ЗапроситьДанныеИзСервисаЧекЛистов(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности, "details/out");
	detailsOut = Обработка.ЗапроситьДанныеИзСервисаЧекЛистов(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности, "files");
	detailsFiles = Обработка.ЗапроситьДанныеИзСервисаЧекЛистов(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности, "files", ИдентификаторФайла);

//	detailsIn = Обработка.ЗапроситьДанныеИзЛичногоКабинета(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности, "detailsIn");
//	detailsOut = Обработка.ЗапроситьДанныеИзЛичногоКабинета(ОрганизацияИНН, РесурсСервера, ИдентификаторСущности, "detailsOut");
	
КонецПроцедуры

&НаСервере
Процедура ИзвлечьСписокИдентификаторовФайлаНаСервере()
	
	ДанныеОтвета = GDS_HTTPКоннектор.JsonВОбъект(detailsOut);
	НеисправностиФайлы.Очистить();
	Для Каждого СтрокаОтвета Из ДанныеОтвета Цикл
		
		Идентификатор		= СтрокаОтвета.Получить("id");
		НаименованиеФайл	= СтрокаОтвета.Получить("filename");
		Размер				= СтрокаОтвета.Получить("size");
		СтрокаИдентификаторФайла	= СтрокаОтвета.Получить("hiddenFieldId");
		Версия				= СтрокаОтвета.Получить("version");
		ВремяИзменения		= СтрокаОтвета.Получить("lastModifiedTime");
		КонтрольнаяСумма	= СтрокаОтвета.Получить("checksum");
		
		НоваяСтрока = НеисправностиФайлы.Добавить();
		НоваяСтрока.id					= Идентификатор;
		НоваяСтрока.filename			= НаименованиеФайл;
		НоваяСтрока.size				= Размер;
		НоваяСтрока.hiddenFieldId		= СтрокаИдентификаторФайла;
		НоваяСтрока.version				= Версия;
		НоваяСтрока.lastModifiedTime	= ВремяИзменения;
		НоваяСтрока.checksum			= КонтрольнаяСумма;
		
	КонецЦикла;

КонецПроцедуры

