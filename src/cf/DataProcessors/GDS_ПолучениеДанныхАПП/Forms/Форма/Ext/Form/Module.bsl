&НаСервере
Процедура ПоказатьКартинкуНаСервере()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	
	Для каждого Стр Из НеисправностиФайлы Цикл
		
		ДД = Обработка.ЗапроситьДанныеИзСервисаЧекЛистов(ОрганизацияИНН,РесурсСервера, ИдентификаторСущности, "files", Стр.id);	
		
		РасширениеФайла= ПолучитьРасширениеИмениФайла(Стр.filename);
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла(РасширениеФайла);
		
		ДД.Записать(ИмяВременногоФайла);
		
		УдалитьФайлы(ИмяВременногоФайла);
	
	КонецЦикла;
	
КонецПроцедуры 

Функция ПолучитьРасширениеИмениФайла(Знач ИмяФайла) Экспорт
	
	РасширениеФайла = "";
	МассивСтрок = СтрРазделить(ИмяФайла, ".", Ложь);
	Если МассивСтрок.Количество() > 1 Тогда
		РасширениеФайла = МассивСтрок[МассивСтрок.Количество() - 1];
	КонецЕсли;
	Возврат РасширениеФайла;
	
КонецФункции

&НаСервере
Процедура РазборЧерезРегуляркаНаСервере()
	НеисправностиТехники.Очистить();
	
	СтрокаПоиска = detailsIn;
	СтрокаРегулярноеВыражение = РегулярноеВыражение;
	
	//[^"][^"]*\{[^}]*\}(?=":\s*"Неисправно")
	//[^"]*\{[^}]*\}(?=":\s*"Неисправно")
	
	//"([^"]*?) \{радиокнопка\}"\s*:\s*"Неисправно"|"([^"]*?) \{комментарий\}"\s*:\s*"([^"]*)"
	
	//нашли строки, где есть Неисправно
	МассивНеисправно = СтрНайтиВсеПоРегулярномуВыражению(СтрокаПоиска, СтрокаРегулярноеВыражение,,Истина);
	
	Для Каждого СтрМ Из МассивНеисправно Цикл
		ГруппаМ = СтрМ.ПолучитьГруппы();
		
		НоваяСтрока = НеисправностиТехники.Добавить();
		НоваяСтрока.Неисправность = ГруппаМ[0].Значение;
	КонецЦикла;
	
	СтрокаРегулярноеВыражениеv2 = РегулярноеВыражение2;
	
	МассивКомментарий = СтрНайтиВсеПоРегулярномуВыражению(СтрокаПоиска, СтрокаРегулярноеВыражениеv2,,Истина);
	
	НеисправностиКомментарий.Очистить();
	Для Каждого СтрМ Из МассивКомментарий Цикл
		ГруппаМ = СтрМ.ПолучитьГруппы();
		
		НоваяСтрока = НеисправностиКомментарий.Добавить();
		НоваяСтрока.Наименование = ГруппаМ[0].Значение;
		НоваяСтрока.Комментарий  = ГруппаМ[1].Значение
	КонецЦикла;
	
	Для Каждого СтрНеисправности Из НеисправностиТехники Цикл
		
		Отбор = Новый Структура;
		Отбор.Вставить("Наименование",СтрНеисправности.Неисправность);	
		
		МассивСтрок = НеисправностиКомментарий.НайтиСтроки(Отбор);
		Если МассивСтрок.Количество() = 1 Тогда
			
			ИндексСтроки = НеисправностиТехники.Индекс(СтрНеисправности);
			СтрокаТЧ = НеисправностиТехники.Получить(ИндексСтроки);
			
			СтрокаТЧ.ПричиныНеисправности = МассивСтрок[0].Комментарий;
			
		КонецЕсли;
		
	КонецЦикла;
	
	сс= "";
	
	//ТЧ_Параметры = Новый ТаблицаЗначений;
	//ТЧ_Параметры.Колонки.Добавить("НаименованиеПроблемы");
	//ТЧ_Параметры.Колонки.Добавить("Значение");
	//ТЧ_Параметры.Колонки.Добавить("Комментарий");
	//
	//Для Каждого Стр Из МассивНайденныхЗначений Цикл
	//	
	//	   СтрНайтиПоРегулярномуВыражению(
	//	
	//	
	//КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИзвлечьИДНаСервере()
	
	ДанныеОтвета = GDS_HTTPКоннектор.JsonВОбъект(ОтветСервера);
	
	Для Каждого СтрокаОтвета Из ДанныеОтвета Цикл
		Идентификатор = СтрокаОтвета.Получить("id");
		МассивДаты = СтрокаОтвета.Получить("updatedAt");
		
		СтрокаДаты = Строка(МассивДаты[0])+"-"+Строка(МассивДаты[1])+"-"+?(МассивДаты[2] >= 1,"0"+Строка(МассивДаты[2]),МассивДаты[2]);
		
		СтрокаДаты = УбратьЛишниеСимволы(СтрокаДаты);
		
		ДатаИзJSON = ПрочитатьДатуJSON(СтрокаДаты+"T00:00:00Z", ФорматДатыJSON.ISO);
		
		Если Не ЗначениеЗаполнено(Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ИДЧекЛистов.Добавить();
		НоваяСтрока.id = Идентификатор;
		НоваяСтрока.data = ДатаИзJSON;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПреобразоватьДатуИзМассива(МассивДаты);
	
	СтрокаДата = СтрСоединить(МассивДаты, "");
	СтрокаБезСимволов = УбратьЛишниеСимволы(СтрокаДата);
	
	//НашаДата = ПрочитатьДатуJSON(СтрокаБезСимволов,ФорматДатыJSON.ISO);
	
	Возврат Дата(СтрокаБезСимволов);
	
КонецФункции

Функция УбратьЛишниеСимволы(Знач ВходящаяСтрока)
	ПолученнаяСтрока = ВходящаяСтрока;
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, " ", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, " ", "");
	
	Возврат ПолученнаяСтрока;
КонецФункции

Функция ДесериализоватьИзJSON(СтрокаJSON, ПоляДата = "") Экспорт
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Значение = ПрочитатьJSON(ЧтениеJSON,, ПоляДата, ФорматДатыJSON.ISO);
	ЧтениеJSON.Закрыть();
	Возврат Значение;
	
КонецФункции

