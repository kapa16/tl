Процедура ЗагрузитьФайлыЧекЛистовИзСервиса(ИдЧекЛиста, НаимФайлов)
	
	ЧастиАдреса = Новый Массив;
	ЧастиАдреса.Добавить(ПараметрыЧекЛистовТекущейОрганизации.Адрес);
	ЧастиАдреса.Добавить("checkLists");
	ЧастиАдреса.Добавить(ИдЧекЛиста);
	ЧастиАдреса.Добавить("files");
	Адрес = СтрСоединить(ЧастиАдреса, "/");
	
	ОтветHTTP = GDS_HTTPКоннектор.Get(Адрес, , , Сессия);
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстОшибки = ТекстСообщенияОбОшибке("Ошибка чтения деталей чек-листа из сервиса", ОтветHTTP);
		ВызватьИсключение (ТекстОшибки, КатегорияОшибки.ОшибкаВнешнегоИсточникаДанных);
	КонецЕсли;
	
	ФайлыЧекЛистов = GDS_HTTPКоннектор.КакJson(ОтветHTTP, ПараметрыПреобразованияJSON);
	
	МассивФайлов = Новый Массив;
	//	Если ФайлыЧекЛистов.Количество()>1 Тогда
	Для Каждого СтрФайл Из ФайлыЧекЛистов Цикл
		Файл_ID = СтрФайл.Получить("id");
		
		ИмяДляРасширения = СтрФайл.Получить("filename");
		Расширение = ПолучитьРасширениеИмениФайла(ИмяДляРасширения);
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Файл",СтрФайл.Получить("filename"));
		
		ТЧ_Файлов = МассивСтруктурВТаблицуЗначений(НаимФайлов);
		
		Если НаимФайлов.Количество() > 0 Тогда
			МассивСтр = ТЧ_Файлов.НайтиСтроки(СтруктураПоиска);
			Если МассивСтр.Количество() = 1 Тогда
				ИмяФайла = МассивСтр[0].Пункт;
			Иначе
				Если СтрНайти(СтрФайл.Получить("filename"),"CAP") > 0 Тогда
					ИмяФайла = "Фото сотрудника";
				Иначе
					ИмяФайла = СтрФайл.Получить("filename");
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если СтрНайти(СтрФайл.Получить("filename"),"CAP") > 0 Тогда
				ИмяФайла = "Фото сотрудника";
			Иначе
				ИмяФайла = СтрФайл.Получить("filename");
			КонецЕсли;
		КонецЕсли;
		
		Размер = СтрФайл.Получить("size");//байт
		ДД_Файла = ЗагрузитьМассивФайловЧекЛистовИзСервиса(ИдЧекЛиста, Файл_ID);
		
		ПараметрыФайлов = ПараметрыФайловАПП();
		ПараметрыФайлов.ИдентификаторФайла = Новый УникальныйИдентификатор(Файл_ID);
		ПараметрыФайлов.Имя = ИмяФайла;
		ПараметрыФайлов.Размер = Размер;
		ПараметрыФайлов.Расширение = Расширение;
		ПараметрыФайлов.ДвоичныеДанныеФайла = ДД_Файла;
		
		МассивФайлов.Добавить(ПараметрыФайлов);
		
	КонецЦикла;
	//	КонецЕсли;
	
	РегистрыСведений.GDS_ФайлыАПП.ДобавитьЗапись(Новый УникальныйИдентификатор(ИдЧекЛиста), МассивФайлов);
	
КонецПроцедуры

