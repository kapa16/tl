КонецФункции

Функция ТекстСообщенияОбОшибке(ОписаниеДействия, ОтветHTTP, ДанныеЗапроса = Неопределено)
	ШаблонСообщения = НСтр("ru = '%1. 
	                             |Код состояния %2. 
	                             |Ответ сервера %3.
	                             |Данные отправки %4'");
	ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонСообщения,
		ОписаниеДействия,
		ОтветHTTP.КодСостояния,
		GDS_HTTPКоннектор.КакТекст(ОтветHTTP),
		?(ЗначениеЗаполнено(ДанныеЗапроса), GDS_HTTPКоннектор.ОбъектВJson(ДанныеЗапроса), "")
	);
	
	Возврат ТекстОшибки;
КонецФункции

