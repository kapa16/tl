Функция МассивСтруктурВТаблицуЗначений(МассивСтруктур)

	ТаблицаЗначений = Новый ТаблицаЗначений;
	ДобавлятьКолонки = Истина;
	
	Для каждого СтруктураСтроки Из МассивСтруктур Цикл
		
		Если ДобавлятьКолонки Тогда
			Для каждого ЭлементСтруктуры Из СтруктураСтроки Цикл
				ТаблицаЗначений.Колонки.Добавить(ЭлементСтруктуры.Ключ);
			КонецЦикла;
			ДобавлятьКолонки = Ложь;
		КонецЕсли;

		НоваяСтрока = ТаблицаЗначений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураСтроки); 
	
	КонецЦикла;

	Возврат ТаблицаЗначений;

КонецФункции // МассивСтруктурВТаблицуЗначений()

Процедура НастроитьПодключениеПоОрганизации(ИНН)
	
	Если ЗначениеЗаполнено(ПараметрыЧекЛистовТекущейОрганизации) 
		И ПараметрыЧекЛистовТекущейОрганизации.ИНН = ИНН Тогда
		
		Возврат;
	КонецЕсли;
	
	ЗапроситьТокенOAuth2(ИНН);
	ПараметрыЧекЛистовТекущейОрганизации = ПараметрыЧекЛистов.Получить(ИНН);
	Сессия = GDS_HTTPКоннектор.СоздатьСессию();
	Сессия.Заголовки.Вставить("Authorization", "Bearer " + ПараметрыЧекЛистовТекущейОрганизации.ТокенДоступа);
	Сессия.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
КонецПроцедуры

Процедура Иницаилизировать()
	
	ПараметрыЗапроса = GDS_HTTPКоннектор.НовыеПараметры();
	ЗаполнитьПараметрыСоединенияОрганизации();
	ПараметрыПреобразованияJSON = ПараметрыПреобразованияJSONПоУмолчанию();
	
КонецПроцедуры

Процедура ЗапроситьТокенOAuth2(ИНН)
	
	ПараметрыСоединения = ПараметрыЧекЛистов.Получить(ИНН);
	
	Если ПараметрыСоединения.МетодАутентификации <> Перечисления.GDS_МетодыАутентификации.OAuth2 Тогда
		Возврат;
	КонецЕсли;
	
	Данные = Новый Структура;
	Данные.Вставить("code", "AUTH_CODE");
	Данные.Вставить("client_id", "app");
	Данные.Вставить("redirect_uri", ПараметрыСоединения.Адрес);
	Данные.Вставить("grant_type", "password");
	Данные.Вставить("username", ПараметрыСоединения.Логин);
	Данные.Вставить("password", ПараметрыСоединения.Пароль);
	
	Параметры = GDS_HTTPКоннектор.НовыеПараметры();
	Параметры.Данные = Данные;
	
	Ответ = GDS_HTTPКоннектор.Post("https://check-car.itjn.ru:8079/realms/check-car/protocol/openid-connect/token", , Параметры);
	ОтветЛК = GDS_HTTPКоннектор.КакJson(Ответ);
		
	ПараметрыСоединения.ТокенОбновления = ОтветЛК.Получить("refresh_token");
	ПараметрыСоединения.ТокенДоступа = ОтветЛК.Получить("access_token");
	ТекущийТокенДоступа = ПараметрыСоединения.ТокенДоступа;
	
	ПараметрыЧекЛистов.Вставить(ИНН, ПараметрыСоединения);
	
КонецПроцедуры

Функция ПараметрыПреобразованияJSONПоУмолчанию()
	
	ПараметрыПреобразованияПоУмолчанию = Новый Структура;
	ПараметрыПреобразованияПоУмолчанию.Вставить("ПрочитатьВСоответствие", Истина);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ФорматДатыJSON", ФорматДатыJSON.ISO);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ИменаСвойствСоЗначениямиДата", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ВариантЗаписиДатыJSON", ВариантЗаписиДатыJSON.ЛокальнаяДата);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ИмяФункцииПреобразования", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("МодульФункцииПреобразования", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ДополнительныеПараметрыФункцииПреобразования", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ИмяФункцииВосстановления", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("МодульФункцииВосстановления", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ДополнительныеПараметрыФункцииВосстановления", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("ИменаСвойствДляОбработкиВосстановления", Неопределено);
	ПараметрыПреобразованияПоУмолчанию.Вставить("МаксимальнаяВложенность", 500);
	
	Возврат ПараметрыПреобразованияПоУмолчанию;
	
КонецФункции

Функция УбратьЛишниеСимволы(Знач ВходящаяСтрока)
	ПолученнаяСтрока = ВходящаяСтрока;
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, " ", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, " ", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, "[", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, "]", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, "\", "");
	ПолученнаяСтрока = СтрЗаменить(ПолученнаяСтрока, """", "");
	
	Возврат ПолученнаяСтрока;
КонецФункции

Функция ОпределитьПризнакВложения(ПризнакВложения)
	
	ЕстьВложение = Перечисления.GDS_ПризнакВложения.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(ПризнакВложения) Тогда
		ЕстьВложение = Перечисления.GDS_ПризнакВложения.Присутствует;
	Иначе
		ЕстьВложение = Перечисления.GDS_ПризнакВложения.Отсутствует;
	КонецЕсли;
	
	Возврат ЕстьВложение;
	
КонецФункции

Функция ОпределитьПризнакСостоянияПроверки(ПризнакСостояния)
	
	Состояние = Перечисления.GDS_СостояниеПроверки.ПустаяСсылка();
	
	Если ПризнакСостояния = "Исправно" Тогда
		Состояние = Перечисления.GDS_СостояниеПроверки.Исправно;
	ИначеЕсли ПризнакСостояния = "В наличии" Тогда
		Состояние = Перечисления.GDS_СостояниеПроверки.ВНаличии;
	ИначеЕсли ПризнакСостояния = "Неисправно" Тогда
		Состояние = Перечисления.GDS_СостояниеПроверки.Неисправно;
	ИначеЕсли ПризнакСостояния = "Отсутствует" Тогда
		Состояние = Перечисления.GDS_СостояниеПроверки.Отсутствует;
	ИначеЕсли ПризнакСостояния = "Просрочено" Тогда
		Состояние = Перечисления.GDS_СостояниеПроверки.Просрочено;
	КонецЕсли;
	
	Возврат Состояние;
	
КонецФункции

Функция ОпределитьПунктПроверки(Пункт, ТЧ_Поиска, ВидМодели)
	
	ПунктПоиска = Справочники.GDS_ПунктыПроверкиТС.ПустаяСсылка();
	
	Отбор = Новый Структура("ДанныеСервиса,",Пункт); 
	
	МассивСтрок = ТЧ_Поиска.НайтиСтроки(Отбор);
	
	Если МассивСтрок.Количество() =1 Тогда
		Возврат МассивСтрок[0].ДанныеИБ;
	Иначе
		сс="";
	КонецЕсли;
КонецФункции

Процедура ЗаполнитьПараметрыСоединенияОрганизации()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	GDS_НастройкиПодключенияАПП.URL КАК URL,
	|	GDS_НастройкиПодключенияАПП.Логин КАК Логин,
	|	GDS_НастройкиПодключенияАПП.Пароль КАК Пароль,
	|	GDS_НастройкиПодключенияАПП.ТокенОбновления КАК ТокенОбновления,
	|	GDS_НастройкиПодключенияАПП.ТокенДоступа КАК ТокенДоступа,
	|	GDS_НастройкиПодключенияАПП.ИНН_Организации КАК ИНН,
	|	GDS_НастройкиПодключенияАПП.МетодАутентификации КАК МетодАутентификации,
	|	GDS_НастройкиПодключенияАПП.КоличествоВыгружаемыхДокументов КАК КоличествоВыгружаемыхДокументов,
	|	GDS_НастройкиПодключенияАПП.ИдентификаторЛичногоКабинета КАК ИдентификаторЛичногоКабинета
	|ИЗ
	|	РегистрСведений.GDS_НастройкиПодключенияАПП КАК GDS_НастройкиПодключенияАПП";
	
	ПараметрыЧекЛистов = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ПараметрыСоединения = НовыйПараметрыСоединения();
		ЗаполнитьЗначенияСвойств(ПараметрыСоединения, Выборка);
		ПараметрыСоединения.Адрес = "https://" + Выборка.URL;
		
		ПараметрыЧекЛистов.Вставить(Выборка.ИНН, ПараметрыСоединения);
	КонецЦикла;

КонецПроцедуры

