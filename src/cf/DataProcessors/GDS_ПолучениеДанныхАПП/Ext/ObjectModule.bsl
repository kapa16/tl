Функция ЗагрузитьСписокЧекЛистовИзСервиса(ДатаЗапроса)
	
	ЧастиАдреса = Новый Массив;
	ЧастиАдреса.Добавить(ПараметрыЧекЛистовТекущейОрганизации.Адрес);
	ЧастиАдреса.Добавить("checkLists/search/by_date?date=");//"checkLists/list_all"
	Адрес = СтрСоединить(ЧастиАдреса, "/");
	
	Адрес = Адрес + ДатаЗапроса;
	
	ОтветHTTP = GDS_HTTPКоннектор.Get(Адрес, , , Сессия);
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстОшибки = ТекстСообщенияОбОшибке("Ошибка чтения чек-листов из сервиса", ОтветHTTP);
		ВызватьИсключение (ТекстОшибки, КатегорияОшибки.ОшибкаВнешнегоИсточникаДанных);
	КонецЕсли;
	
	Заявки = GDS_HTTPКоннектор.КакJson(ОтветHTTP, ПараметрыПреобразованияJSON);
	
	Возврат Заявки;
	
КонецФункции

Функция ЗагрузитьДеталиЧекЛистовИзСервиса(ИдЧекЛиста)
	
	ЧастиАдреса = Новый Массив;
