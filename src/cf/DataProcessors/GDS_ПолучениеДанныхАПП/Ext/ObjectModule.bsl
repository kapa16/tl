	ПараметрыФайлов.Вставить("ИдентификаторФайла", "");
	ПараметрыФайлов.Вставить("Имя", "");
	ПараметрыФайлов.Вставить("Размер", "");
	ПараметрыФайлов.Вставить("Расширение", "");
	ПараметрыФайлов.Вставить("ДвоичныеДанныеФайла", "");
	
	Возврат ПараметрыФайлов;
	
КонецФункции

Функция ПараметрыДанныеАПП()
	
	ДанныеАПП = Новый Структура;
	ДанныеАПП.Вставить("ДатаОсмотра");
	ДанныеАПП.Вставить("Принял");
	ДанныеАПП.Вставить("ЭлементыПроверки");
	ДанныеАПП.Вставить("ТС", ПараметрыДанныеТС());
	ДанныеАПП.Вставить("ПрицепОборудование", ПараметрыДанныеПрицепОборудование());
	ДанныеАПП.Вставить("Модель", ПараметрыДанныеМодели());
	ДанныеАПП.Вставить("ПУ", ПараметрыДанныеПУ());
	ДанныеАПП.Вставить("Подразделение", ПараметрыДанныеПодразделение());
	
	Возврат ДанныеАПП;
	
КонецФункции

Функция ПараметрыДанныеТС()
	
	ДанныеТС = Новый Структура;
	ДанныеТС.Вставить("Ид");
	ДанныеТС.Вставить("Наименование");
