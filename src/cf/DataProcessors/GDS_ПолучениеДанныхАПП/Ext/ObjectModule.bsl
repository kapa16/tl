функция РазборПоляЧерезРегулярноеВыражениеНаСервере(ДеталиЧекЛист)
	
	СтруктураВозврата = Новый Структура;
	
	МассивПоиска = Новый Массив;
	МассивПоиска.Добавить("тягача");
	МассивПоиска.Добавить("прицепа");
	МассивПоиска.Добавить("ТС");
	
	ТЧ_Вложений = Новый ТаблицаЗначений;
	ТЧ_Вложений.Колонки.Добавить("Пункт");
	ТЧ_Вложений.Колонки.Добавить("Файл");
	
	//КОРРЕКТИРОВКА
	МассивВложений = Новый Массив;
	
	НовыйМеханизм = Ложь;
	
	Если НовыйМеханизм Тогда
		
		Для Каждого СтрМ Из МассивПоиска Цикл
			
			ШаблонВыражения = "([^""]*?)\s*"+СтрМ+"\s*\{(радиокнопка|слайдер|комментарий|вложение)\}"":\s*""((?:[^""\\]|\\.)*)""(?=\s*,|\s*\}|$)";
			
			Если СтрМ = "ТС" Тогда
				НаименованиеТаблицы = "Данные"+СтрМ;
			Иначе
				НаименованиеТаблицы = "Данные"+ТРег(СтрМ);
			КонецЕсли;
			
			НазваниеТаблицы = Новый ТаблицаЗначений;
			НазваниеТаблицы.Колонки.Добавить("Пункт");
			НазваниеТаблицы.Колонки.Добавить("Ответ");
			
			МассивОтвета = Новый Массив;
			
			СтруктураОтвета = Новый Структура;
			СтруктураОтвета.Вставить("Пункт");
			СтруктураОтвета.Вставить("Ответ", Новый Структура("Значение, Комментарий, Вложение"));
			
			Результаты = СтрНайтиВсеПоРегулярномуВыражению(ДеталиЧекЛист,ШаблонВыражения,,Истина);
			Для Каждого Результат Из Результаты Цикл
				ГруппыРезультата = Результат.ПолучитьГруппы();
				
				МассивРезультатов = Новый Массив;
				Для каждого ГруппаРезультата Из ГруппыРезультата Цикл
					МассивРезультатов.Добавить(ГруппаРезультата.Значение);
				КонецЦикла;
				//МассивОтвета.Добавить(СтрСоединить(МассивРезультатов, "/"));
				
				СтруктураОтвета.Пункт = ГруппыРезультата[0].Значение;
				СтруктураОтвета.Ответ.Значение = ГруппыРезультата[2].Значение;
				//СтруктураОтвета.Ответ.Комментарий = "";
				//СтруктураОтвета.Ответ.Вложение = "";
				
			КонецЦикла;
			
			СтруктураВозврата.Вставить(НаименованиеТаблицы,МассивОтвета);
			
		КонецЦикла;
		
		Возврат СтруктураВозврата;
		
	Иначе
		Для Каждого СтрМ Из МассивПоиска Цикл
			
			РегулярноеВыражение = "([^""]*?)\s*"+СтрМ+"\s*\{(радиокнопка|слайдер|комментарий|вложение)\}"":\s*""((?:[^""\\]|\\.)*)""(?=\s*,|\s*\}|$)";
			
			//"([^""]*?)\s*"+СтрМ+"\s*\{(радиокнопка|слайдер|комментарий|вложение)\}"":\s*""([^""]*)""(?=\s*,|\s*\}|$)";
			//"([^""]*?)\s*"+СтрМ+"\s*\{(радиокнопка|слайдер|комментарий|вложение)\}"":\s*""?(.*?)""?(?=\s*,|\s*\})";
			
			Если СтрМ = "ТС" Тогда
				НаименованиеТаблицы = "Данные"+СтрМ;
			Иначе
				НаименованиеТаблицы = "Данные"+ТРег(СтрМ);
			КонецЕсли;
			
			НазваниеТаблицы = Новый ТаблицаЗначений;
			НазваниеТаблицы.Колонки.Добавить("Пункт");
			НазваниеТаблицы.Колонки.Добавить("Ответ");
			
			МассивРВ = СтрНайтиВсеПоРегулярномуВыражению(ДеталиЧекЛист,РегулярноеВыражение,,Истина);
			Если МассивРВ.Количество() > 0 Тогда
				Для Каждого СтрРВ Из МассивРВ Цикл
					ГруппаМ = СтрРВ.ПолучитьГруппы();
					
					ПараметрыОтвета = Новый Структура;
					ПараметрыОтвета.Вставить("Радиокнопка");
					ПараметрыОтвета.Вставить("Комментарий");
					ПараметрыОтвета.Вставить("Вложение");
					
					МассивСтрок = НазваниеТаблицы.НайтиСтроки(Новый Структура("Пункт", ГруппаМ[0].Значение));
					Если МассивСтрок.Количество() > 0 Тогда
						НоваяСтрока = МассивСтрок[0]; 
					Иначе
						НоваяСтрока = НазваниеТаблицы.Добавить();
						НоваяСтрока.Пункт = ГруппаМ[0].Значение;
						НоваяСтрока.Ответ = ПараметрыОтвета; 
					КонецЕсли;
					
					//исправить слайдет - тех.долг
					Если ГруппаМ[1].Значение = "слайдер" Тогда
						НоваяСтрока.Ответ["Радиокнопка"] = ГруппаМ[2].Значение;
					Иначе
						НоваяСтрока.Ответ[ГруппаМ[1].Значение] = ГруппаМ[2].Значение;
					КонецЕсли;
					
					Если ГруппаМ[1].Значение = "вложение" Тогда
						ДобавитьПунктФайл(ТЧ_Вложений, ГруппаМ[0].Значение, ГруппаМ[2].Значение);
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			
			НазваниеТаблицы.Сортировать("Пункт");
			
			МассивСтруктур = ОбщегоНазначения.ТаблицаЗначенийВМассив(НазваниеТаблицы);
			
			СтруктураВозврата.Вставить(НаименованиеТаблицы, МассивСтруктур);
			
		КонецЦикла;
		
		МассивВложений = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТЧ_Вложений);
		
		СтруктураВозврата.Вставить("Вложение",МассивВложений);
		
		//найдем остатки без приписки ТС, тягач, прицеп
		РегулярноеВыражениеОстатки = """((?!.*тягача|.*прицепа|.*ТС)[^""]*?)\s+\{(радиокнопка|слайдер|комментарий|вложение)\}"":\s*""((?:[^""\\]|\\.)*)";
		
		НаименованиеТаблицы = "ДанныеОстатки";
		
		НазваниеТаблицы = Новый ТаблицаЗначений;
		НазваниеТаблицы.Колонки.Добавить("Пункт");
		НазваниеТаблицы.Колонки.Добавить("Ответ");
		
		МассивРВ_Остатки = СтрНайтиВсеПоРегулярномуВыражению(ДеталиЧекЛист,РегулярноеВыражениеОстатки,,);
		Если МассивРВ_Остатки.Количество() > 0 Тогда
			Для Каждого СтрРВ Из МассивРВ_Остатки Цикл
				ГруппаМ = СтрРВ.ПолучитьГруппы();
				
				ПараметрыОтвета = Новый Структура;
				ПараметрыОтвета.Вставить("Радиокнопка");
				ПараметрыОтвета.Вставить("Комментарий");
				ПараметрыОтвета.Вставить("Вложение");
				
				МассивСтрок = НазваниеТаблицы.НайтиСтроки(Новый Структура("Пункт", ГруппаМ[0].Значение));
				Если МассивСтрок.Количество() > 0 Тогда
					НоваяСтрока = МассивСтрок[0]; 
				Иначе
					НоваяСтрока = НазваниеТаблицы.Добавить();
					НоваяСтрока.Пункт = ГруппаМ[0].Значение;
					НоваяСтрока.Ответ = ПараметрыОтвета; 
				КонецЕсли;
				
				//исправить слайдет - тех.долг
				Если ГруппаМ[1].Значение = "слайдер" Тогда
					НоваяСтрока.Ответ["Радиокнопка"] = ГруппаМ[2].Значение;
				Иначе
					НоваяСтрока.Ответ[ГруппаМ[1].Значение] = ГруппаМ[2].Значение;
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
		
		НазваниеТаблицы.Сортировать("Пункт");
		
		МассивСтруктур = ОбщегоНазначения.ТаблицаЗначенийВМассив(НазваниеТаблицы);
		
		СтруктураВозврата.Вставить(НаименованиеТаблицы, МассивСтруктур);
		
		Возврат СтруктураВозврата;
	КонецЕсли;
	
КонецФункции

Процедура ДобавитьПунктФайл(ТЧ,ЗначениеНаименование,ЗначениеФайл)
	
	СтрокаФайл = УбратьЛишниеСимволы(ЗначениеФайл);
	
	МассивСтрок = СтрРазделить(СтрокаФайл,",");
	
	Для Каждого СтрМ Из МассивСтрок Цикл
		
		НоваяСтрока = ТЧ.Добавить();
		НоваяСтрока.Пункт = ЗначениеНаименование;
		НоваяСтрока.Файл = СтрМ;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьПунктыПроверкиНаСервере(СтруктураРазбора)
	
	Для Каждого СтрТягача Из СтруктураРазбора.ДанныеТягача Цикл
		СоздатьПунктыПровекиИзРазбора(СтрТягача.Пункт, Перечисления.уатВидыМоделейТС.Автотранспорт);
	КонецЦикла;
	
	Для Каждого СтрПрицеп Из СтруктураРазбора.ДанныеПрицепа Цикл
		СоздатьПунктыПровекиИзРазбора(СтрПрицеп.Пункт, Перечисления.уатВидыМоделейТС.Прицеп);
	КонецЦикла;
	
	Для Каждого СтрПрицеп Из СтруктураРазбора.ДанныеТС Цикл
		СоздатьПунктыПровекиИзРазбора(СтрПрицеп.Пункт, Перечисления.уатВидыМоделейТС.Автотранспорт);
	КонецЦикла;
	
	Для Каждого СтрПрицеп Из СтруктураРазбора.ДанныеОстатки Цикл
		СоздатьПунктыПровекиИзРазбора(СтрПрицеп.Пункт, Перечисления.уатВидыМоделейТС.ПустаяСсылка());
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьПунктыПровекиИзРазбора(Пункт, ВидМодели)
	
	ПунктПроверки = Справочники.GDS_ПунктыПроверкиТС.НайтиПоНаименованию(Пункт);
	
	Если ПунктПроверки = Справочники.GDS_ПунктыПроверкиТС.ПустаяСсылка() Тогда
		НовыйПунктПроверки = Справочники.GDS_ПунктыПроверкиТС.СоздатьЭлемент();
		//НовыйПунктПроверки.УстановитьНовыйКод();
		НовыйПунктПроверки.Наименование = Пункт;
		НовыйПунктПроверки.ВидМодели    = ВидМодели;
		НовыйПунктПроверки.Записать();
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьРасширениеИмениФайла(Знач ИмяФайла)
	
	РасширениеФайла = "";
	МассивСтрок = СтрРазделить(ИмяФайла, ".", Ложь);
	Если МассивСтрок.Количество() > 1 Тогда
		РасширениеФайла = МассивСтрок[МассивСтрок.Количество() - 1];
	КонецЕсли;
	Возврат РасширениеФайла;
	
КонецФункции

Функция ПараметрыФайловАПП()
	
