Функция ЗапроситьДанныеИзСервисаЧекЛистов(ИНН, Ресурс, Идентификатор = "", РесурсУточнение = "", ИдентификаторФ = "") Экспорт
	
	НастроитьПодключениеПоОрганизации(ИНН);
	
	ЧастиАдреса = Новый Массив;
	ЧастиАдреса.Добавить(ПараметрыЧекЛистовТекущейОрганизации.Адрес);
	ЧастиАдреса.Добавить(Ресурс);
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		ЧастиАдреса.Добавить(Идентификатор);
	КонецЕсли;
	Если ЗначениеЗаполнено(РесурсУточнение) Тогда
		ЧастиАдреса.Добавить(РесурсУточнение);
	КонецЕсли;
	Если ЗначениеЗаполнено(ИдентификаторФ) Тогда
		ЧастиАдреса.Добавить(ИдентификаторФ);
	КонецЕсли;
			
	Адрес = СтрСоединить(ЧастиАдреса, "/");
	
	//временно
	Если ЗначениеЗаполнено(ИдентификаторФ) Тогда
		Адрес = Адрес+"/data";
	КонецЕсли;
	
	ОтветHTTP = GDS_HTTPКоннектор.Get(Адрес, , , Сессия);
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстОшибки = ТекстСообщенияОбОшибке("Ошибка чтения из ЛК", ОтветHTTP);
		Возврат ТекстОшибки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Идентификатор)
		И ИдентификаторФ = "" Тогда
		
		Данные = GDS_HTTPКоннектор.КакJson(ОтветHTTP, ПараметрыПреобразованияJSON);
		ОтветСервера = GDS_HTTPКоннектор.ОбъектВJson(Данные);

	Иначе
		Если ЗначениеЗаполнено(ИдентификаторФ) Тогда
			Данные = GDS_HTTPКоннектор.КакДвоичныеДанные(ОтветHTTP);
			ОтветСервера = Данные;
			ЭтотОбъект.ДДКартинки = Данные;
		Иначе
			Данные = GDS_HTTPКоннектор.КакJson(ОтветHTTP, ПараметрыПреобразованияJSON);
			ОтветСервера = GDS_HTTPКоннектор.ОбъектВJson(Данные);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ОтветСервера;
	
КонецФункции


Функция ЗапроситьДатыИзСервисаЧекЛистов(ИНН, Ресурс, Идентификатор = "") Экспорт
	
	НастроитьПодключениеПоОрганизации(ИНН);
	
	ЧастиАдреса = Новый Массив;
	ЧастиАдреса.Добавить(ПараметрыЧекЛистовТекущейОрганизации.Адрес);
	ЧастиАдреса.Добавить(Ресурс);
	Адрес = СтрСоединить(ЧастиАдреса, "/");
	
	Адрес = Адрес + Идентификатор;
	
	ОтветHTTP = GDS_HTTPКоннектор.Get(Адрес, , , Сессия);
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстОшибки = ТекстСообщенияОбОшибке("Ошибка чтения из ЛК", ОтветHTTP);
		Возврат ТекстОшибки;
	КонецЕсли;
	
	Данные = GDS_HTTPКоннектор.КакJson(ОтветHTTP, ПараметрыПреобразованияJSON);
	ОтветСервера = Данные;//ЛК_HTTPКоннектор.ОбъектВJson(Данные);
	
	Возврат ОтветСервера;
	
КонецФункции

