Процедура ОбработатьЧекЛист(ЧекЛист, ДеталиЧекЛист, ФайлыЧекЛист, ИНН)
	
	сс="";
	
	id = ЧекЛист.Получить("id");
	title = ЧекЛист.Получить("title");
	
	Описание = СтрШаблон("ЧекЛист/%1/%2", title, id);

	Запись = РегистрыСведений.GDS_ОчередьСообщенийЧекЛист.СоздатьМенеджерЗаписи();
	//ЗаполнитьЗначенияСвойств(Запись, Сообщение);
	Запись.Период = ТекущаяДатаСеанса();
	Запись.ИНН = ИНН;
	Запись.Описание = Описание;
	
	Запись.Статус = Перечисления.ЛК_СтатусСообщения.Ожидает;
	Запись.Сообщение    = ДеталиЧекЛист;
	Запись.УИНСообщения = id;
	
	Запись.ДанныеТС = Новый ХранилищеЗначения(ЧекЛист);
	Запись.ДопДанные = Новый ХранилищеЗначения(ФайлыЧекЛист);
	
	
	
	
	Запись.Записать(Истина);
	
	
	
	
	
КонецПроцедуры

Процедура ОбработатьДанныеТехники(ДанныеТС, ДанныеПрицеп)
	
	МенеджерЗаписи = РегистрыСведений.GDS_СведенияОТехнике.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ДанныеТС);
	МенеджерЗаписи.Записать();
	
	МенеджерЗаписи = РегистрыСведений.GDS_СведенияОТехнике.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ДанныеПрицеп);
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

Процедура ОбработатьДанныеЧекЛист(ЧекЛист, ДанныеРазбора)

	ДанныеТягача  = ДанныеРазбора.ДанныеТягача;
	ДанныеПрицепа = ДанныеРазбора.ДанныеПрицепа;
	
	id = ЧекЛист.Получить("id");
		
	Если ДанныеТягача.Количество() > 0 Тогда
		
		ТЧ_Данных = РегистрыСведений.GDS_СоответствиеДанныхЧекЛисты.СоответствиеВидовРаспознаваемыхДанных(Перечисления.GDS_ВидМоделиТС.Автотранспорт);
		
		НаборЗаписей = РегистрыСведений.GDS_СведенияОЧекЛисте.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Идентификатор.Установить(id);
		Для Каждого СтрТягач Из ДанныеТягача Цикл
			НоваяЗапись = НаборЗаписей.Добавить();
			
			НоваяЗапись.Идентификатор		= id;
			НоваяЗапись.Пункт				= ОпределитьПунктПроверки(СтрТягач.Пункт, ТЧ_Данных,Перечисления.GDS_ВидМоделиТС.Автотранспорт);
			НоваяЗапись.ВидМодели			= Перечисления.GDS_ВидМоделиТС.Автотранспорт;
			НоваяЗапись.СостояниеПроверки	= ОпределитьПризнакСостоянияПроверки(СтрТягач.Ответ.Радиокнопка);
			НоваяЗапись.Комментарий			= СтрТягач.Ответ.Комментарий;
			НоваяЗапись.Вложение			= ОпределитьПризнакВложения(СтрТягач.Ответ.Вложение);
			
		КонецЦикла;
		
		НаборЗаписей.Записать(); 
	КонецЕсли;
	
	Если ДанныеПрицепа.Количество() > 0 Тогда
		
		ТЧ_Данных = РегистрыСведений.GDS_СоответствиеДанныхЧекЛисты.СоответствиеВидовРаспознаваемыхДанных(Перечисления.GDS_ВидМоделиТС.Прицеп);
		
		НаборЗаписей = РегистрыСведений.GDS_СведенияОЧекЛисте.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Идентификатор.Установить(id);
		НаборЗаписей.Прочитать();
		Для Каждого СтрПрицеп Из ДанныеПрицепа Цикл
			НоваяЗапись = НаборЗаписей.Добавить();

			НоваяЗапись.Идентификатор		= id;
			НоваяЗапись.Пункт				= ОпределитьПунктПроверки(СтрПрицеп.Пункт, ТЧ_Данных, Перечисления.GDS_ВидМоделиТС.Автотранспорт);
			НоваяЗапись.ВидМодели			= Перечисления.GDS_ВидМоделиТС.Прицеп;
			НоваяЗапись.СостояниеПроверки	= ОпределитьПризнакСостоянияПроверки(СтрПрицеп.Ответ.Радиокнопка);
			НоваяЗапись.Комментарий			= СтрПрицеп.Ответ.Комментарий;
			НоваяЗапись.Вложение			= ОпределитьПризнакВложения(СтрПрицеп.Ответ.Вложение);
			
		КонецЦикла;
		
		НаборЗаписей.Записать(); 
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьСтруктуруИзСоответствия(ЗначВход)
	
	СтруктураВозврат=Новый Структура;
	
	Если ТипЗнч(ЗначВход)=Тип("Соответствие") Тогда
		
		ФлагОщибка=Ложь;
		
		Для Каждого р Из ЗначВход Цикл
			Попытка
				СтруктураВозврат.Вставить(р.Ключ,ПолучитьСтруктуруИзСоответствия(р.Значение));
			Исключение
				ФлагОщибка=Истина;
				Прервать;
			КонецПопытки;
		КонецЦикла;
		
		Если ФлагОщибка Тогда // пришел ключь который не возможно поместить в структуру
			СтруктураВозврат = Новый Массив;
			Для Каждого р Из ЗначВход Цикл
				ДопСтруктура=Новый Структура;
				ДопСтруктура.Вставить("Ключ",р.Ключ);
				ДопСтруктура.Вставить("Значение",ПолучитьСтруктуруИзСоответствия(р.Значение));
				СтруктураВозврат.Добавить(ДопСтруктура);
			КонецЦикла;
		КонецЕсли;
		
		Возврат СтруктураВозврат; 
		
	ИначеЕсли ТипЗнч(ЗначВход)=Тип("Массив") Тогда
		
		НовыйМассив=Новый Массив;
		Для Каждого ЭлМ Из ЗначВход Цикл
			НовыйМассив.Добавить(ПолучитьСтруктуруИзСоответствия(ЭлМ));
		КонецЦикла;
		Возврат НовыйМассив;
		
	КонецЕсли;
	
	Возврат ЗначВход; 
	
КонецФункции

#КонецОбласти

