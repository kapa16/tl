			Запрос.Текст = Запрос.Текст + "
			|	И втДанные.ТС В (&МассивТС)";
		КонецЕсли;
		
	КонецЕсли;

	Выборка = Запрос.Выполнить().Выбрать();
	МассивЗаказов = Новый Массив();
	Пока Выборка.Следующий() Цикл
		МассивЗаказов.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат МассивЗаказов;
	
КонецФункции


