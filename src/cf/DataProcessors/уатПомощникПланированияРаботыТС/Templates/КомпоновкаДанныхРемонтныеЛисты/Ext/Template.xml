		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	уатРемонтныйЛист.Ссылка КАК Ссылка,
	уатРемонтныйЛист.ВидОбслуживания КАК ВидОбслуживания,
	уатРемонтныйЛист.ВидОбслуживания2 КАК ВидОбслуживания2,
	уатРемонтныйЛист.ВидОбслуживания3 КАК ВидОбслуживания3,
	уатРемонтныйЛист.Организация КАК Организация,
	уатРемонтныйЛист.Подразделение КАК Подразделение,
	ВЫБОР
		КОГДА &amp;ДетализацияТС = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТС)
			ТОГДА уатРемонтныйЛист.ТС
		ИНАЧЕ уатРемонтныйЛист.ТС.Модель
	КОНЕЦ КАК ДетализацияПланирования,
	уатРемонтныйЛист.ТС.Колонна КАК ТСКолонна,
	уатРемонтныйЛист.ДатаОкончания КАК ПлановаяДатаОбслуживания,
	уатРемонтныйЛист.ТС КАК ТС,
	уатРемонтныйЛист.ТС.Модель КАК МодельТС
ПОМЕСТИТЬ втРемонтныеЛисты
ИЗ
	Документ.уатРемонтныйЛист КАК уатРемонтныйЛист
ГДЕ
	уатРемонтныйЛист.ДатаОкончания МЕЖДУ &amp;ДатаНач И &amp;ДатаКон
	И (уатРемонтныйЛист.ВидОбслуживания = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
			ИЛИ уатРемонтныйЛист.ВидОбслуживания.ИспользоватьВПланированииТО)
	И (уатРемонтныйЛист.ВидОбслуживания2 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
			ИЛИ уатРемонтныйЛист.ВидОбслуживания2.ИспользоватьВПланированииТО)
	И (уатРемонтныйЛист.ВидОбслуживания3 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
			ИЛИ уатРемонтныйЛист.ВидОбслуживания3.ИспользоватьВПланированииТО)
	И уатРемонтныйЛист.Организация = &amp;Организация
	И уатРемонтныйЛист.Проведен = ИСТИНА
	И уатРемонтныйЛист.ПометкаУдаления = ЛОЖЬ
	И уатРемонтныйЛист.Выполнен = ИСТИНА
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	уатРемонтныйЛистМатериалы.Номенклатура КАК Номенклатура,
	уатРемонтныйЛистМатериалы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	уатРемонтныйЛистМатериалы.Количество КАК Количество,
	уатРемонтныйЛистМатериалы.Сумма КАК Сумма,
	уатРемонтныйЛистМатериалы.СуммаНДС КАК СуммаНДС,
	уатРемонтныйЛистМатериалы.Цена КАК Цена,
	уатРемонтныйЛистМатериалы.СтавкаНДС КАК СтавкаНДС,
	втРемонтныеЛисты.ВидОбслуживания КАК ВидОбслуживания,
	втРемонтныеЛисты.Организация КАК Организация,
	втРемонтныеЛисты.Подразделение КАК Подразделение,
	втРемонтныеЛисты.ТСКолонна КАК Колонна,
	втРемонтныеЛисты.ДетализацияПланирования КАК ДетализацияПланирования,
	втРемонтныеЛисты.ПлановаяДатаОбслуживания КАК ПлановаяДатаОбслуживания
ИЗ
	втРемонтныеЛисты КАК втРемонтныеЛисты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатРемонтныйЛист.Материалы КАК уатРемонтныйЛистМатериалы
		ПО втРемонтныеЛисты.Ссылка = уатРемонтныйЛистМатериалы.Ссылка

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	уатРемонтныйЛистРаботы.Работа.Номенклатура,
	уатРемонтныйЛистРаботы.Работа.Номенклатура.ЕдиницаХраненияОстатков,
	уатРемонтныйЛистРаботы.Количество,
	уатРемонтныйЛистРаботы.Сумма,
	уатРемонтныйЛистРаботы.СуммаНДС,
	уатРемонтныйЛистРаботы.Цена,
	уатРемонтныйЛистРаботы.СтавкаНДС,
	втРемонтныеЛисты.ВидОбслуживания,
	втРемонтныеЛисты.Организация,
	втРемонтныеЛисты.Подразделение,
	втРемонтныеЛисты.ТСКолонна,
	втРемонтныеЛисты.ДетализацияПланирования,
	втРемонтныеЛисты.ПлановаяДатаОбслуживания
ИЗ
	втРемонтныеЛисты КАК втРемонтныеЛисты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатРемонтныйЛист.Работы КАК уатРемонтныйЛистРаботы
		ПО втРемонтныеЛисты.Ссылка = уатРемонтныйЛистРаботы.Ссылка

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	уатРемонтныйЛистСобственныеМатериалы.Номенклатура,
	уатРемонтныйЛистСобственныеМатериалы.ЕдиницаИзмерения,
	уатРемонтныйЛистСобственныеМатериалы.Количество,
	0,
	0,
	0,
	уатРемонтныйЛистСобственныеМатериалы.Номенклатура.СтавкаНДС,
	втРемонтныеЛисты.ВидОбслуживания,
	втРемонтныеЛисты.Организация,
	втРемонтныеЛисты.Подразделение,
	втРемонтныеЛисты.ТСКолонна,
	втРемонтныеЛисты.ДетализацияПланирования,
	втРемонтныеЛисты.ПлановаяДатаОбслуживания
ИЗ
	втРемонтныеЛисты КАК втРемонтныеЛисты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатРемонтныйЛист.СобственныеМатериалы КАК уатРемонтныйЛистСобственныеМатериалы
		ПО втРемонтныеЛисты.Ссылка = уатРемонтныйЛистСобственныеМатериалы.Ссылка</query>
