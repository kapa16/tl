		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВыработкаПрошлогоПериода.Колонна КАК Колонна,
	ВыработкаПрошлогоПериода.Организация КАК Организация,
	ВыработкаПрошлогоПериода.ПараметрВыработки КАК ПараметрВыработки,
	ВыработкаПрошлогоПериода.Подразделение КАК Подразделение,
	ВыработкаПрошлогоПериода.ТС КАК ТС,
	уатТС.Модель КАК МодельТС,
	ВыработкаПрошлогоПериода.НаправлениеПеревозки КАК НаправлениеПеревозки,
	ВыработкаПрошлогоПериода.КоличествоОборот КАК КоличествоОборот,
	ВыработкаПрошлогоПериода.КоличествоОборот / РАЗНОСТЬДАТ(&amp;ДатаНач, &amp;ДатаКон, ДЕНЬ) КАК СреднесуточнаяВыработка,
	ЕСТЬNULL(НачальнаяВыработка.КоличествоОборот, 0) КАК НачальнаяВыработка,
	уатТС.ДатаВводаВЭксплуатацию КАК ДатаВводаВЭксплуатацию
ПОМЕСТИТЬ втВыработкаТС
ИЗ
	РегистрНакопления.уатВыработкаТС.Обороты({(&amp;ДатаНач)}, {(&amp;ДатаКон)}, , Организация = &amp;Организация) КАК ВыработкаПрошлогоПериода
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.уатВыработкаТС.Обороты({(&amp;НачалоВремен)}, {(&amp;ДатаНач)}, , Организация = &amp;Организация) КАК НачальнаяВыработка
		ПО ВыработкаПрошлогоПериода.ТС = НачальнаяВыработка.ТС
			И ВыработкаПрошлогоПериода.Организация = НачальнаяВыработка.Организация
			И ВыработкаПрошлогоПериода.Подразделение = НачальнаяВыработка.Подразделение
			И ВыработкаПрошлогоПериода.ПараметрВыработки = НачальнаяВыработка.ПараметрВыработки
			И ВыработкаПрошлогоПериода.Колонна = НачальнаяВыработка.Колонна
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТС КАК уатТС
		ПО ВыработкаПрошлогоПериода.ТС = уатТС.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втВыработкаТС.Колонна КАК Колонна,
	втВыработкаТС.Организация КАК Организация,
	втВыработкаТС.ПараметрВыработки КАК ПараметрВыработки,
	втВыработкаТС.Подразделение КАК Подразделение,
	втВыработкаТС.ТС КАК ТС,
	втВыработкаТС.МодельТС КАК МодельТС,
	ВЫБОР
		КОГДА &amp;ДетализацияТС = ЗНАЧЕНИЕ(Перечисление.уатВариантыАналитик.ТС)
			ТОГДА втВыработкаТС.ТС
		ИНАЧЕ втВыработкаТС.МодельТС
	КОНЕЦ КАК ДетализацияПланирования,
	втВыработкаТС.НаправлениеПеревозки КАК НаправлениеПеревозки,
	1 КАК Количество,
	втВыработкаТС.СреднесуточнаяВыработка КАК СреднесуточнаяВыработка,
	втВыработкаТС.НачальнаяВыработка КАК НачальнаяВыработка,
	втВыработкаТС.ДатаВводаВЭксплуатацию КАК ДатаВводаВЭксплуатацию,
	уатМоделиТСНормативыОбслуживания.ВидОбслуживания КАК ВидОбслуживания,
	уатМоделиТСНормативыОбслуживания.ПериодичностьОбслуживания КАК ПериодичностьОбслуживания,
	уатМоделиТСНормативыОбслуживания.ЗначениеПараметраВыработки КАК ЗначениеПараметраВыработки,
	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
	ДАТАВРЕМЯ(1, 1, 1) КАК ПлановаяДатаОбслуживания,
	0 КАК Сумма,
	0 КАК СуммаНДС
ПОМЕСТИТЬ втВыработкаИВидыТО
ИЗ
	втВыработкаТС КАК втВыработкаТС
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.уатМоделиТС.НормативыОбслуживания КАК уатМоделиТСНормативыОбслуживания
		ПО втВыработкаТС.МодельТС = уатМоделиТСНормативыОбслуживания.Ссылка
			И втВыработкаТС.ПараметрВыработки = уатМоделиТСНормативыОбслуживания.ПараметрВыработки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втВыработкаИВидыТО.Колонна КАК Колонна,
	втВыработкаИВидыТО.Организация КАК Организация,
	втВыработкаИВидыТО.ПараметрВыработки КАК ПараметрВыработки,
	втВыработкаИВидыТО.Подразделение КАК Подразделение,
	втВыработкаИВидыТО.ТС КАК ТС,
	втВыработкаИВидыТО.МодельТС КАК МодельТС,
	втВыработкаИВидыТО.ДетализацияПланирования КАК ДетализацияПланирования,
	втВыработкаИВидыТО.НаправлениеПеревозки КАК НаправлениеПеревозки,
	втВыработкаИВидыТО.Количество КАК Количество,
	втВыработкаИВидыТО.СреднесуточнаяВыработка КАК СреднесуточнаяВыработка,
	втВыработкаИВидыТО.НачальнаяВыработка КАК НачальнаяВыработка,
	втВыработкаИВидыТО.ВидОбслуживания КАК ВидОбслуживания,
	втВыработкаИВидыТО.ПериодичностьОбслуживания КАК ПериодичностьОбслуживания,
	втВыработкаИВидыТО.ЗначениеПараметраВыработки КАК ЗначениеПараметраВыработки,
	втВыработкаИВидыТО.Номенклатура КАК Номенклатура,
	втВыработкаИВидыТО.ПлановаяДатаОбслуживания КАК ПлановаяДатаОбслуживания,
	втВыработкаИВидыТО.Сумма КАК Сумма,
	втВыработкаИВидыТО.СуммаНДС КАК СуммаНДС,
	ЕСТЬNULL(уатПрохождениеТОСрезПоследних.Выработка, 0) КАК ВыработкаПослеПоследнегоТО,
	ЕСТЬNULL(уатПрохождениеТОСрезПоследних.Период, втВыработкаИВидыТО.ДатаВводаВЭксплуатацию) КАК ДатаПоследнегоТО
ИЗ
	втВыработкаИВидыТО КАК втВыработкаИВидыТО
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатПрохождениеТО.СрезПоследних({(&amp;ДатаНач)}, ) КАК уатПрохождениеТОСрезПоследних
		ПО втВыработкаИВидыТО.ТС = уатПрохождениеТОСрезПоследних.ТС
			И втВыработкаИВидыТО.ВидОбслуживания = уатПрохождениеТОСрезПоследних.ВидТО
			И втВыработкаИВидыТО.ПараметрВыработки = уатПрохождениеТОСрезПоследних.ПараметрВыработки</query>
	</dataSet>
