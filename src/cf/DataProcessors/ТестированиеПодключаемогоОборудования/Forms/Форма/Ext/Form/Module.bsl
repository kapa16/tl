	ШтрихкодEAN13 = "2900001462105";
	ШтрихкодCODE39 = "2PMP-468-PJM";
	ШтрихкодQR = "http://www.1c.ru";    
	ПИоТ_КонтрольнаяМарка = "MDQ2MDYyMDMxMDIyMjgheDttQT1rQUNhVWFqbmo=";
	
	ПечатьШтрихкодаEAN8 = Истина;
	ПечатьШтрихкодаEAN13 = Истина;
	ПечатьШтрихкодаCODE39 = Истина;
	ПечатьШтрихкодаQR = Истина;
	
	Отправляет1СEmail = Ложь;
	Отправляет1СSMS   = Ложь;
	ККТ_Электронно    = Ложь;  
	
	НефискальнаяКвитанция = Ложь;
	ОбновлениеДисплея  = Истина;  
	ГотовностьКРаботе  = Истина;    
	НаличнаяОплата = Ложь;    
	ПроверятьОСУ = Ложь; 
	
	ЭТСумма  = 10.12;
	СуммаИнкассации = 10.12;
	
	Если Не ОбщегоНазначенияБПО.ИспользуетсяПринтерыЭтикеток() Тогда
		Элементы.ГруппаПЭ.Видимость = Ложь;
		Элементы.РаботаСПЭ.Видимость = Ложь;
	КонецЕсли;
	
	Если Не ОбщегоНазначенияБПО.ИспользуетсяСчитывательRFID() Тогда
		Элементы.ГруппаRFID.Видимость = Ложь;
		Элементы.РаботаRFID.Видимость = Ложь;
