		КартинкаBase64 = СтрЗаменить(КартинкаBase64, Символы.ПС, "");
		КартинкаBase64 = СтрЗаменить(КартинкаBase64, Символы.ВК, "");   
		ТекущаяСрока.КартинкаBase64 = КартинкаBase64;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
