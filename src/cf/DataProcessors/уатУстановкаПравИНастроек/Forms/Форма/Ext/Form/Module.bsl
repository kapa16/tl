	ПрочитатьИсключения();
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИсключение(Команда)
	
	ТекСтрока = Элементы.ДеревоПрав.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		СтруктураОтбора = Новый Структура("Пользователь, ПравоНастройка", ОбъектНастройкиПрав, ТекСтрока.ПравоНастройка);
		НайденныеСтроки = ТаблицаИсключений.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = ТаблицаИсключений.Добавить();
			НоваяСтрока.Пользователь = ОбъектНастройкиПрав;
			НоваяСтрока.ПравоНастройка = ТекСтрока.ПравоНастройка;
			Модифицированность = Истина;
		Иначе
			ТекстНСтр = НСтр("ru = 'Для пользователя ""%1"" и права/настройки ""%2"" уже существует исключение.'; en = 'An exception already exists for user ""%1"" and permission/setting ""%2"".'");
			ТекстНСтр = СтрШаблон(ТекстНСтр, ОбъектНастройкиПрав, ТекСтрока.ПравоНастройка);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

