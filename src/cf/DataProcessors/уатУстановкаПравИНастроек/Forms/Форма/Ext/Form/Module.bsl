&НаКлиенте
Процедура УстановитьДляВсехВидовДокументов(Команда)
	
	ТекСтрока = Элементы.ДеревоПрав.ТекущиеДанные;
	
	Если ТекСтрока = Неопределено 
		Или ТипЗнч(ТекСтрока.Значение) <> Тип("ПеречислениеСсылка.уатВидыПравДляДокументов") Тогда
		ТекстНСтр = НСтр("ru = 'Необходимо выбрать строку, в которой настроены права доступа к документу'; en = 'You must select the line in which the access rights to the document are configured.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		Возврат;
	КонецЕсли;
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДеревоПравИНастроек Тогда
		// Таблица доступностей объектов перезаполняется, если она сейчас не отображается на экране
		ПредыдущийВидОбъектаНастройкиПрав = ВидОбъектаНастройкиПрав;
		ВидОбъектаНастройкиПрав = "Документы";
		ЗаполнитьТаблицуДоступностейОбъектов(ТекСтрока);
		ВидОбъектаНастройкиПрав = ПредыдущийВидОбъектаНастройкиПрав;
	КонецЕсли;
	
	УстановитьДляВсехВидовДокументовСервер(ТекСтрока.ПравоНастройка, ТекСтрока.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДляВсехВидовСправочников(Команда)
	
	ТекСтрока = Элементы.ДеревоПрав.ТекущиеДанные;
	
	Если ТекСтрока = Неопределено 
		Или ТипЗнч(ТекСтрока.Значение) <> Тип("ПеречислениеСсылка.уатВидыПравДляСправочников") Тогда
		ТекстНСтр = НСтр("ru = 'Необходимо выбрать строку, в которой настроены права доступа к справочнику'; en = 'You must select the line in which access rights to the directory are configured.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстНСтр);
		Возврат;
	КонецЕсли;
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДеревоПравИНастроек Тогда
		// Таблица доступностей объектов перезаполняется, если она сейчас не отображается на экране
		ПредыдущийВидОбъектаНастройкиПрав = ВидОбъектаНастройкиПрав;
		ВидОбъектаНастройкиПрав = "Справочники";
		ЗаполнитьТаблицуДоступностейОбъектов(ТекСтрока);
		ВидОбъектаНастройкиПрав = ПредыдущийВидОбъектаНастройкиПрав;
	КонецЕсли;
	
	УстановитьДляВсехВидовСправочниковСервер(ТекСтрока.ПравоНастройка, ТекСтрока.Значение);
	
КонецПроцедуры

