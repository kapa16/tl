	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втРезультат.Заказ КАК Заказ,
	|	втРезультат.Состояние КАК Состояние,
	|	втРезультат.КоличествоВыполнено КАК КоличествоВыполнено,
	|	втРезультат.КоличествоВсего КАК КоличествоВсего,
	|	ВЫБОР
	|		КОГДА втРезультат.КоличествоВсего = 0
	|			ТОГДА 0
	|		ИНАЧЕ втРезультат.КоличествоВыполнено / втРезультат.КоличествоВсего * 100
	|	КОНЕЦ КАК ПроцентВыполнения
	|ИЗ
	|	втРезультат КАК втРезультат";
	
	Попытка
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Сч = 0;
		Пока Выборка.Следующий() Цикл 
			Сч = Сч + 1;
			
			НаборЗаписей = РегистрыСведений.уатТекущееСостояниеВыполненияЗаказов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Заказ.Установить(Выборка.Заказ); 
			НаборЗаписей.Прочитать(); 
			
			Если НаборЗаписей.Количество() > 0 Тогда 
				Запись = НаборЗаписей[0];
			Иначе
				Запись = НаборЗаписей.Добавить();
			КонецЕсли;
			
			Если ОтклоненныеЗаказы.Найти(Запись.Заказ) <> Неопределено Тогда
				Запись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.Отклонен;
			Иначе
				ЗаполнитьЗначенияСвойств(Запись, Выборка);
			КонецЕсли;
			НаборЗаписей.Записать();
			
			Если ШагВыводаПрогресса > 0 И Сч % ШагВыводаПрогресса = 0 Тогда
				ПроцентВыполнения = Окр(Сч / ВсегоДокументов * 100);
				ТекстНСТР = "Выполняется отложенное обновление состояний заказов на ТС (" + ВерсияКонфигурации + ")";
				ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
			КонецЕсли;
		КонецЦикла;
	Исключение
		Информация = ИнформацияОбОшибке();
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеВерсия_1_1_24_1

Процедура ОбработатьЗаполнениеНДСУпр_1_1_24_1Сервер(СтруктураПараметров, АдресХранилища) Экспорт
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ВерсияКонфигурации = "1.1.24.1";
	Иначе
		ВерсияКонфигурации = "2.2.24.1";
	КонецЕсли;
	
	ШаблонЗапрос = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	тблДокумента.Ссылка,
	|	тблДокумента.Дата
	|ИЗ
	|	Документ.%ИмяДокумента% КАК тблДокумента
	|ГДЕ
	|	тблДокумента.Проведен
	|	И НЕ тблДокумента.ПометкаУдаления
	|	И тблДокумента.Дата >= НАЧАЛОПЕРИОДА(&НачДата, ДЕНЬ)
	|	И (&КонДата = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ тблДокумента.Дата <= КОНЕЦПЕРИОДА(&КонДата, ДЕНЬ))";
	
	ТекстЗапроса = "";
	Для Сч = 0 По СтруктураПараметров.Документы.Количество()-1 Цикл
		ТекЗапрос = СтрЗаменить(ШаблонЗапрос, "%ИмяДокумента%", СтруктураПараметров.Документы[Сч]);
		
		Если Сч > 0 Тогда
			ТекЗапрос = СтрЗаменить(ТекЗапрос, "РАЗРЕШЕННЫЕ", "");
			ТекстЗапроса = ТекстЗапроса + "
				|ОБЪЕДИНИТЬ ВСЕ
				|";
		КонецЕсли;
		
		ТекстЗапроса = ТекстЗапроса + ТекЗапрос;
	КонецЦикла;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("НачДата", СтруктураПараметров.Период.ДатаНачала);
	Запрос.УстановитьПараметр("КонДата", СтруктураПараметров.Период.ДатаОкончания);
	
	тблДокументы = Запрос.Выполнить().Выгрузить();
	тблДокументы.Сортировать("Дата");
	
	ВсегоДокументов = тблДокументы.Количество();
	ШагВыводаПрогресса = Макс(Окр(ВсегоДокументов/10), 1);
	
	Для Сч = 0 По тблДокументы.Количество()-1 Цикл
		
		ДокОбъект = тблДокументы[Сч].Ссылка.ПолучитьОбъект();
		
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		КонецПопытки;
		
		Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
			ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
			ТекстНСТР = "Выполняется перепроведение документов (" + ВерсияКонфигурации + ")";
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Процедура ОбработатьПлатежныйКалендарь_1_1_24_1Сервер(СтруктураПараметров, АдресХранилища) Экспорт
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ВерсияКонфигурации = "1.1.24.1";
	Иначе
		ВерсияКонфигурации = "2.2.24.1";
	КонецЕсли;
	
	// выбор записей РН уатРасчетыПоДокументам
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатРасчетыПоДокументамОбороты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.уатРасчетыПоДокументам.Обороты(&НачДата, &КонДата, Регистратор, ) КАК уатРасчетыПоДокументамОбороты
	|ГДЕ
	|	(уатРасчетыПоДокументамОбороты.СуммаПриходОборот < 0
	|			ИЛИ уатРасчетыПоДокументамОбороты.СуммаПриходУпрОборот < 0)");
	Запрос.УстановитьПараметр("НачДата", СтруктураПараметров.Период.ДатаНачала);
	Запрос.УстановитьПараметр("КонДата", СтруктураПараметров.Период.ДатаОкончания);
	ВыборкаРегистраторы = Запрос.Выполнить().Выбрать();
	
	// выбор Заказов, по которым нет записей в РС уатТекущееСостояниеОплаты
	ЗапросЗаказы = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатЗаказГрузоотправителя.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
	|ГДЕ
	|	уатЗаказГрузоотправителя.Проведен
	|	И (уатЗаказГрузоотправителя.Дата МЕЖДУ &НачДата И &КонДата)
	|	И (уатЗаказГрузоотправителя.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
	|	ИЛИ уатЗаказГрузоотправителя.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
	|	ИЛИ уатЗаказГрузоотправителя.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС))");
	ЗапросЗаказы.УстановитьПараметр("НачДата", СтруктураПараметров.Период.ДатаНачала);
	ЗапросЗаказы.УстановитьПараметр("КонДата", КонецДня(СтруктураПараметров.Период.ДатаОкончания));
	мсвЗаказы = ЗапросЗаказы.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	// расчет общего количества регистраторов для вывода прогресса
	ВсегоДокументов = ВыборкаРегистраторы.Количество() + мсвЗаказы.Количество();
	ШагВыводаПрогресса = Макс(Окр(ВсегоДокументов/10), 1);
	Сч = 0;
	
	// заполнение СуммаРасход и СуммаРасходУпр в РН уатРасчетыПоДокументам
	НЗПлатежныйКалендарь = РегистрыНакопления.уатРасчетыПоДокументам.СоздатьНаборЗаписей();
	Пока ВыборкаРегистраторы.Следующий() Цикл
		Сч = Сч + 1;
		
		НЗПлатежныйКалендарь.Отбор.Регистратор.Установить(ВыборкаРегистраторы.Регистратор);
		НЗПлатежныйКалендарь.Прочитать();
		Для Каждого ТекЗапись Из НЗПлатежныйКалендарь Цикл
			Если ТекЗапись.СуммаПриход < 0 Тогда
				ТекЗапись.СуммаРасход = -ТекЗапись.СуммаПриход;
				ТекЗапись.СуммаПриход = 0;
			КонецЕсли;
			Если ТекЗапись.СуммаПриходУпр < 0 Тогда
				ТекЗапись.СуммаРасходУпр = -ТекЗапись.СуммаПриходУпр;
				ТекЗапись.СуммаПриходУпр = 0;
			КонецЕсли;
		КонецЦикла;
		
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НЗПлатежныйКалендарь);
		
		Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
			ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
			ТекстНСТР = "Выполняется отложенное обновление Платежного календаря (" + ВерсияКонфигурации + ")";
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
		КонецЕсли;
	КонецЦикла;
	
	мсвСостояниеОплатыПоЗаказам = уатОбщегоНазначения_проф.СостояниеОплатыПоДокументам(мсвЗаказы);
	Для Каждого СостояниеОплатыПоЗаказу Из мсвСостояниеОплатыПоЗаказам Цикл
		Сч = Сч + 1;
		
		НоваяЗапись = РегистрыСведений.уатТекущееСостояниеОплаты.СоздатьМенеджерЗаписи();
		НоваяЗапись.Документ      = СостояниеОплатыПоЗаказу.Документ;
		НоваяЗапись.СуммаВсего    = СостояниеОплатыПоЗаказу.Сумма;
		НоваяЗапись.Оплачено      = СостояниеОплатыПоЗаказу.СуммаОплатыФакт;
		НоваяЗапись.ПроцентОплаты = СостояниеОплатыПоЗаказу.ПроцентОплатыФакт;
		Если СостояниеОплатыПоЗаказу.ПроцентОплатыФакт = 0 Тогда
			НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.Новый;
		ИначеЕсли Окр(СостояниеОплатыПоЗаказу.ПроцентОплатыФакт) >= 100 Тогда
			НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.Выполнен;
		Иначе
			НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.ЧастичноВыполнен;
		КонецЕсли;
		НоваяЗапись.ПредоплатыНедостаточно = (СостояниеОплатыПоЗаказу.СуммаОплатыФакт < СостояниеОплатыПоЗаказу.СуммаПредоплаты);
		НоваяЗапись.ОплаченоПредставление = СтрШаблон("%1 (%2)",
			Формат(СостояниеОплатыПоЗаказу.СуммаОплатыФакт, "ЧДЦ=2; ЧН=0"),
			Формат(СостояниеОплатыПоЗаказу.ПроцентОплатыФакт, "ЧДЦ=0; ЧН=0") + "%");
		НоваяЗапись.Записать();
		
		Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
			ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
			ТекстНСТР = "Выполняется отложенное обновление Платежного календаря (" + ВерсияКонфигурации + ")";
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеВерсия_1_1_27_1

// Процедура-обработчик фонового задания, вызываемого из обработки уатПереносОстатковПартийТоваровНаОрганизации
Процедура ПереносОстатковПартийТоваровНаОрганизации_2_2_27_1(СтруктураПараметров, АдресХранилища) Экспорт
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ВерсияКонфигурации = "1.1.27.1";
	Иначе
		ВерсияКонфигурации = "2.2.27.1";
	КонецЕсли;
	
	ТекПользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	ТекОтветственный = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		ТекПользователь, "ОсновнойОтветственный");
	ТекПодразделение = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		ТекПользователь, "ОсновноеПодразделениеОрганизации");
		
	ТекОрганизация = СтруктураПараметров.Организация;
	
	мсвСозданныеДокументы = Новый Массив;
	ТекстОшибок = "";
	
	мсвСклады = Новый Массив;
	Для Каждого ТекЭлем Из СтруктураПараметров.Склады Цикл
		Если ТекЭлем.Пометка Тогда
			мсвСклады.Добавить(ТекЭлем.Значение);
		КонецЕсли;
	КонецЦикла;

	ТекстНСТР = "Выполняется перенос партий на организации (" + ВерсияКонфигурации + "): запрос остатков партий";
	ДлительныеОперации.СообщитьПрогресс(0, ТекстНСТР);
			
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА уатПартииТоваровНаСкладахОстатки.Партия В (&мсвПустаяПартия)
	|			ТОГДА &Организация
	|		ИНАЧЕ уатПартииТоваровНаСкладахОстатки.Партия.Организация
	|	КОНЕЦ КАК Организация,
	|	уатПартииТоваровНаСкладахОстатки.Склад КАК Склад,
	|	уатПартииТоваровНаСкладахОстатки.Номенклатура КАК Номенклатура,
	|	уатПартииТоваровНаСкладахОстатки.Партия КАК Партия,
	|	СУММА(уатПартииТоваровНаСкладахОстатки.КоличествоОстаток) КАК Количество,
	|	СУММА(уатПартииТоваровНаСкладахОстатки.СтоимостьОстаток) КАК Стоимость,
	|	СУММА(уатПартииТоваровНаСкладахОстатки.СтоимостьУпрОстаток) КАК СтоимостьУпр,
	|	СУММА(уатПартииТоваровНаСкладахОстатки.СуммаНДСОстаток) КАК СуммаНДС
	|ИЗ
	|	РегистрНакопления.уатПартииТоваровНаСкладах.Остатки(
	|			&Период,
	|			Склад В (&мсвСклады)
	|				И (Партия.Организация = &Организация
	|					ИЛИ Партия В (&мсвПустаяПартия))
	|				И Организация = &ОрганизацияРегистра) КАК уатПартииТоваровНаСкладахОстатки
	|ГДЕ
	|	уатПартииТоваровНаСкладахОстатки.КоличествоОстаток > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА уатПартииТоваровНаСкладахОстатки.Партия В (&мсвПустаяПартия)
	|			ТОГДА &Организация
	|		ИНАЧЕ уатПартииТоваровНаСкладахОстатки.Партия.Организация
	|	КОНЕЦ,
	|	уатПартииТоваровНаСкладахОстатки.Склад,
	|	уатПартииТоваровНаСкладахОстатки.Номенклатура,
	|	уатПартииТоваровНаСкладахОстатки.Партия");
	Запрос.УстановитьПараметр("Период", НачалоДня(СтруктураПараметров.ДатаОбработки)+1);
	Запрос.УстановитьПараметр("Организация", ТекОрганизация);
	Запрос.УстановитьПараметр("мсвСклады", мсвСклады);
	
	мсвПустаяПартия = Новый Массив;
	мсвПустаяПартия.Добавить(Неопределено);
	мсвПустаяПартия.Добавить(Документы.уатВводОстатков.ПустаяСсылка());
	мсвПустаяПартия.Добавить(Документы.уатОперацииСТехническимиЖидкостями.ПустаяСсылка());
	мсвПустаяПартия.Добавить(Документы.уатОприходованиеТоваров.ПустаяСсылка());
	мсвПустаяПартия.Добавить(Документы.уатПоступлениеТоваровУслуг.ПустаяСсылка());
	мсвПустаяПартия.Добавить(Документы.уатСливГСМ.ПустаяСсылка());
	Запрос.УстановитьПараметр("мсвПустаяПартия", мсвПустаяПартия);

	ПредУчПолитика = уатОбщегоНазначения.УчетнаяПолитика(ТекОрганизация, НачалоДня(СтруктураПараметров.ДатаОбработки)-1);
	Если ПредУчПолитика.УчетПартийПоОрганизациям Тогда
		Запрос.УстановитьПараметр("ОрганизацияРегистра", ТекОрганизация);
	Иначе
		Запрос.УстановитьПараметр("ОрганизацияРегистра", Справочники.Организации.ПустаяСсылка());
	КонецЕсли;
		
	тблПартии = Запрос.Выполнить().Выгрузить();
	
	Если тблПартии.Количество() = 0 Тогда
		Если АдресХранилища <> Неопределено Тогда
			ТекстОшибок = "Отсутствуют остатки партий для переноса по выбранным организациям и складам.";
		    ПоместитьВоВременноеХранилище(Новый Структура("СозданныеДокументы, ТекстОшибок, РезультатЗавершения",
				мсвСозданныеДокументы, ТекстОшибок, Истина), АдресХранилища);
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	тблТовары = тблПартии.Скопировать();
	тблТовары.Свернуть("Организация, Склад, Номенклатура", "Количество, Стоимость, СтоимостьУпр, СуммаНДС");
	
	// расчет общего количества регистраторов для вывода прогресса
	ВсегоСтрок = 0;
	Для Каждого ТекСклад Из мсвСклады Цикл
		ВсегоСтрок = ВсегоСтрок + 1;
		
		мсвТовары = тблТовары.НайтиСтроки(Новый Структура("Организация, Склад", ТекОрганизация, ТекСклад));
		Если мсвТовары.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
	КонецЦикла;
	ШагВыводаПрогресса = Макс(Окр(ВсегоСтрок/10), 1);
	Сч = 0;
	
	флОК = Истина;
	Для Каждого ТекСклад Из мсвСклады Цикл
		флЕстьТовары = Ложь;

		// 1. Списание
		мсвТовары = тблТовары.НайтиСтроки(Новый Структура("Организация, Склад", ТекОрганизация, ТекСклад));
		Если мсвТовары.Количество() > 0 Тогда
			ДокСписание               = Документы.уатСписаниеТоваров.СоздатьДокумент();
			ДокСписание.Дата          = НачалоДня(СтруктураПараметров.ДатаОбработки)-1;
			ДокСписание.Организация   = ТекОрганизация;
			ДокСписание.Склад         = ТекСклад;
			ДокСписание.Подразделение = ТекПодразделение;
			ДокСписание.Ответственный = ТекОтветственный;
			ДокСписание.Комментарий   = "Создан обработкой ""Перенос остатков партий на организации (Отложенное обновление ИБ)""";
			
			Для Каждого ТекСтрокаТовар Из мсвТовары Цикл
				НоваяСтрока                  = ДокСписание.Товары.Добавить();
				НоваяСтрока.Номенклатура     = ТекСтрокаТовар.Номенклатура;
				НоваяСтрока.ЕдиницаИзмерения = ТекСтрокаТовар.Номенклатура.ЕдиницаХраненияОстатков;
				НоваяСтрока.Количество       = ТекСтрокаТовар.Количество;
			КонецЦикла;
			ДокСписание.Товары.Сортировать("Номенклатура, ЕдиницаИзмерения");
			
			Попытка
				ДокСписание.ДополнительныеСвойства.Вставить("НеСписыватьСоСкладскихЯчеек");
				ДокСписание.ДополнительныеСвойства.Вставить("ОрганизацияПартий", ТекОрганизация);
				ДокСписание.Записать(РежимЗаписиДокумента.Проведение);
				флЕстьТовары = Истина;
				НоваяСтрокаСозд = Новый Структура;
				НоваяСтрокаСозд.Вставить("Организация", ТекОрганизация);
				НоваяСтрокаСозд.Вставить("Склад", ТекСклад);
				НоваяСтрокаСозд.Вставить("СписаниеТоваров", ДокСписание.Ссылка);
			Исключение
				ТекстОшибок = ТекстОшибок + Символы.ПС + 
					СтрШаблон("Не удалось провести документ ""Списание товаров"" по складу ""%1""",	ТекСклад);
				Если ДокСписание.ДополнительныеСвойства.Свойство("ОписаниеОшибки") Тогда
					ТекстОшибок = ТекстОшибок + ": " + ДокСписание.ДополнительныеСвойства.ОписаниеОшибки;
				КонецЕсли;
				
				флОК = Ложь;
			КонецПопытки;
		КонецЕсли;
		
		// 2. Ввод остатков
		Если флЕстьТовары Тогда
			мсвТовары = тблПартии.НайтиСтроки(Новый Структура("Организация, Склад", ТекОрганизация, ТекСклад));
			Если мсвТовары.Количество() > 0 Тогда
				ДокВводОстатков               = Документы.уатВводОстатков.СоздатьДокумент();
				ДокВводОстатков.Дата          = НачалоДня(СтруктураПараметров.ДатаОбработки);
				ДокВводОстатков.ВидОперации   = Перечисления.уатВидыОперацийВводОстатков.ПартииТоваровНаСкладах;
				ДокВводОстатков.Организация   = ТекОрганизация;
				ДокВводОстатков.Подразделение = ТекПодразделение;
				ДокВводОстатков.Ответственный = ТекОтветственный;
				ДокВводОстатков.Комментарий   = "Создан обработкой ""Перенос остатков партий на организации (Отложенное обновление ИБ)""";
				
				Для Каждого ТекСтрокаТовар Из мсвТовары Цикл
					НоваяСтрока                  = ДокВводОстатков.Материалы.Добавить();
					НоваяСтрока.ДатаОтражения    = ДокВводОстатков.Дата;
					НоваяСтрока.Склад            = ТекСклад;
					НоваяСтрока.Номенклатура     = ТекСтрокаТовар.Номенклатура;
					НоваяСтрока.Партия           = ТекСтрокаТовар.Партия;
					НоваяСтрока.Количество       = ТекСтрокаТовар.Количество;
					НоваяСтрока.Стоимость        = ТекСтрокаТовар.Стоимость;
					НоваяСтрока.СтоимостьУпр     = ТекСтрокаТовар.СтоимостьУпр;
					НоваяСтрока.СуммаНДС         = ТекСтрокаТовар.СуммаНДС;
				КонецЦикла;
				ДокВводОстатков.Материалы.Сортировать("Номенклатура, Партия");
			
				Попытка
					ДокВводОстатков.Записать(РежимЗаписиДокумента.Проведение);
					НоваяСтрокаСозд.Вставить("ВводОстатков", ДокВводОстатков.Ссылка);
				Исключение
					ТекстОшибок = ТекстОшибок + Символы.ПС + 
						СтрШаблон("Не удалось провести документ ""Ввод остатков (партии товаров)"" по складу %1 и организации %2: %3",
						ТекСклад, ТекОрганизация, ИнформацияОбОшибке().Описание);
					флОК = Ложь;
				КонецПопытки;
				
				мсвСозданныеДокументы.Добавить(НоваяСтрокаСозд);
			КонецЕсли;
		КонецЕсли;
		
		Сч = Сч + 1;
		Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
			ПроцентВыполнения = Окр(Сч/ВсегоСтрок*100);
			ТекстНСТР = "Выполняется перенос партий на организации (" + ВерсияКонфигурации + ")";
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
		КонецЕсли;
	КонецЦикла;	
	
	Если НЕ ПустаяСтрока(ТекстОшибок) Тогда
		ТекстОшибок = Сред(ТекстОшибок, 2);
	КонецЕсли;
	
	Если АдресХранилища <> Неопределено Тогда
	    ПоместитьВоВременноеХранилище(Новый Структура("СозданныеДокументы, ТекстОшибок, РезультатЗавершения",
			мсвСозданныеДокументы, ТекстОшибок, флОК), АдресХранилища);
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеВерсия_1_1_31_1

Процедура ЗаполнениеРасшифровкиРасходаГСМ_1_1_31_1(СтруктураПараметров, АдресХранилища) Экспорт
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ВерсияКонфигурации = "1.1.31.1";
	Иначе
		ВерсияКонфигурации = "2.2.31.1";
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатПутевойЛистРасходГСМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ПЛсРасходом
	|ИЗ
	|	Документ.уатПутевойЛист.РасходГСМ КАК уатПутевойЛистРасходГСМ
	|ГДЕ
	|	&флПЛ
	|	И уатПутевойЛистРасходГСМ.Ссылка.Проведен
	|	И уатПутевойЛистРасходГСМ.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&НачДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонДата, ДЕНЬ)
	|	И уатПутевойЛистРасходГСМ.РасходПоНорме > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатТехнологическийПутевойЛистРасходГСМ.Ссылка
	|ИЗ
	|	Документ.уатТехнологическийПутевойЛист.РасходГСМ КАК уатТехнологическийПутевойЛистРасходГСМ
	|ГДЕ
	|	&флТПЛ
	|	И уатТехнологическийПутевойЛистРасходГСМ.Ссылка.Проведен
	|	И уатТехнологическийПутевойЛистРасходГСМ.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&НачДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонДата, ДЕНЬ)
	|	И уатТехнологическийПутевойЛистРасходГСМ.РасходПоНорме > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатПутевойЛистРасшифровкаРасходаГСМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ПЛсРасшифровкой
	|ИЗ
	|	Документ.уатПутевойЛист.РасшифровкаРасходаГСМ КАК уатПутевойЛистРасшифровкаРасходаГСМ
	|ГДЕ
	|	&флПЛ
	|	И уатПутевойЛистРасшифровкаРасходаГСМ.Ссылка.Проведен
	|	И уатПутевойЛистРасшифровкаРасходаГСМ.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&НачДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонДата, ДЕНЬ)
	|	И уатПутевойЛистРасшифровкаРасходаГСМ.РасходПоНорме > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатТехнологическийПутевойЛистРасходГСМ.Ссылка
	|ИЗ
	|	Документ.уатТехнологическийПутевойЛист.РасшифровкаРасходаГСМ КАК уатТехнологическийПутевойЛистРасходГСМ
	|ГДЕ
	|	&флТПЛ
	|	И уатТехнологическийПутевойЛистРасходГСМ.Ссылка.Проведен
	|	И уатТехнологическийПутевойЛистРасходГСМ.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&НачДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонДата, ДЕНЬ)
	|	И уатТехнологическийПутевойЛистРасходГСМ.РасходПоНорме > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПЛсРасходом.Ссылка КАК Ссылка
	|ИЗ
	|	ПЛсРасходом КАК ПЛсРасходом
	|ГДЕ
	|	НЕ ПЛсРасходом.Ссылка В
	|				(ВЫБРАТЬ
	|					ПЛсРасшифровкой.Ссылка
	|				ИЗ
	|					ПЛсРасшифровкой)");
	
	Запрос.УстановитьПараметр("НачДата", СтруктураПараметров.Период.ДатаНачала);
	Запрос.УстановитьПараметр("КонДата", СтруктураПараметров.Период.ДатаОкончания);
	Запрос.УстановитьПараметр("флПЛ",    СтруктураПараметров.ОбрабатыватьПЛ);
	Запрос.УстановитьПараметр("флТПЛ",   СтруктураПараметров.ОбрабатыватьТПЛ);
	
	тблДокументы = Запрос.Выполнить().Выгрузить();
		
	ВсегоДокументов = тблДокументы.Количество();
	ШагВыводаПрогресса = Макс(Окр(ВсегоДокументов/10), 1);
	
	Для Сч = 0 По тблДокументы.Количество()-1 Цикл
		ДокОбъект = тблДокументы[Сч].Ссылка.ПолучитьОбъект();
		флТПЛ = (ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.уатТехнологическийПутевойЛист"));
		
		ПараметрыРасчетаГСМ = уатПутевыеЛисты.ПолучитьПараметрыРасчетаРасходаГСМ(ДокОбъект);
		
		флОтказ = Ложь;
		ДокОбъект.РасшифровкаРасходаГСМ.Очистить();
		Для Каждого ТекСтрока Из ДокОбъект.РасходГСМ Цикл
			Если НЕ ТекСтрока.Активен ИЛИ уатГСМ.ЭтоТехническаяЖидкость(ТекСтрока.ГСМ) Тогда
				Продолжить;
			КонецЕсли;
			
			СписокНормРасхода = Новый Массив;
			РасходПоНорме = уатГСМ.РасчитатьРасходГСМПоНорме(ПараметрыРасчетаГСМ, ТекСтрока.ТС, ТекСтрока.ГСМ, флОтказ, СписокНормРасхода);
			Если флОтказ Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ТекРасшифровка Из СписокНормРасхода Цикл
				НоваяСтрока = ДокОбъект.РасшифровкаРасходаГСМ.Добавить();
				НоваяСтрока.ТС = ТекСтрока.ТС;
				НоваяСтрока.ГСМ = ТекСтрока.ГСМ;
				НоваяСтрока.ВидНормы = ТекРасшифровка.ВидНормы;
				НоваяСтрока.РасходПоНорме = ТекРасшифровка.Значение;
				Если НЕ флТПЛ Тогда
					НоваяСтрока.СпециальнаяРабота = ТекРасшифровка.Спецработа;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		// если не удалось рассчитать расшифровку, то записывать нет смысла
		Если ДокОбъект.РасшифровкаРасходаГСМ.Количество() = 0 Тогда
			флОтказ = Истина;
		КонецЕсли;
		
		Если НЕ флОтказ Тогда
			// запись документа и заполненной ТЧ "Расшифровка расхода ГСМ"
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокОбъект,,, РежимЗаписиДокумента.Запись);
			Исключение
				флОтказ = Истина;
			КонецПопытки;
		
			// запись движений документа только по регистру "Расшифровка расхода ГСМ"
			НЗуатРасшифровкаРасходаГСМнаТС = РегистрыНакопления.уатРасшифровкаРасходаГСМнаТС.СоздатьНаборЗаписей();
			НЗуатРасшифровкаРасходаГСМнаТС.Отбор.Регистратор.Установить(ДокОбъект.Ссылка);
			НЗуатРасшифровкаРасходаГСМнаТС.Записать();
			НЗуатОстаткиГСМнаТС = РегистрыНакопления.уатОстаткиГСМнаТС.СоздатьНаборЗаписей();
			НЗуатОстаткиГСМнаТС.Отбор.Регистратор.Установить(ДокОбъект.Ссылка);
			НЗуатОстаткиГСМнаТС.Прочитать();
			
			уатПроведение.ИнициализироватьДополнительныеСвойстваДляПроведения(ДокОбъект.Ссылка, ДокОбъект.ДополнительныеСвойства);
			
			тблОстаткиГСМнаТС = НЗуатОстаткиГСМнаТС.Выгрузить();
			ДокОбъект.ДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаГСМ", тблОстаткиГСМнаТС);
			
			Если флТПЛ Тогда
				Документы.уатТехнологическийПутевойЛист.СформироватьТаблицаРасходГСМ(ДокОбъект.Ссылка, ДокОбъект.ДополнительныеСвойства);
				Документы.уатТехнологическийПутевойЛист.СформироватьТаблицаРасшифровкаРасходаГСМ(ДокОбъект.Ссылка, ДокОбъект.ДополнительныеСвойства);
			Иначе
				Документы.уатПутевойЛист.СформироватьТаблицаРасходГСМ(ДокОбъект.Ссылка, ДокОбъект.ДополнительныеСвойства);
				Документы.уатПутевойЛист.СформироватьТаблицаРасшифровкаРасходаГСМ(ДокОбъект.Ссылка, ДокОбъект.ДополнительныеСвойства);
			КонецЕсли;
						
			флОтказ = Ложь;
			уатПроведение.ОтразитьРасшифровкуРасходаГСМНаТС(ДокОбъект.ДополнительныеСвойства, ДокОбъект.Движения, флОтказ);
			ДокОбъект.Движения.уатРасшифровкаРасходаГСМнаТС.Записывать = Истина;
			
			уатПроведение.ЗаписатьНаборыЗаписей(ДокОбъект);
		КонецЕсли;
		
		Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
			ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
			ТекстНСТР = "Выполняется перезапись документов (" + ВерсияКонфигурации + ")";
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеВерсия_1_1_31_1

// СтруктураПараметров = [Период, ЗаполнениеТЧЗаказы, ОбновлениеСостоянияОплаты]
Процедура ОбработатьПлатежныеДокументы_1_1_32_1(СтруктураПараметров, АдресХранилища) Экспорт
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ВерсияКонфигурации = "1.1.32.1";
	Иначе
		ВерсияКонфигурации = "2.2.32.1";
	КонецЕсли;
	
	Если СтруктураПараметров.ЗаполнениеТЧЗаказы Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	уатПраваИНастройки.Объект КАК Организация
		|ПОМЕСТИТЬ втОрганизации
		|ИЗ
		|	РегистрСведений.уатПраваИНастройки КАК уатПраваИНастройки
		|ГДЕ
		|	уатПраваИНастройки.ПравоНастройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.уатПраваИНастройки.РазнесениеПлатежейПоЗаказам)
		|	И уатПраваИНастройки.Значение = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	уатРасчетыПоДокументамОбороты.Регистратор КАК Регистратор
		|ПОМЕСТИТЬ втДокументы
		|ИЗ
		|	РегистрНакопления.уатРасчетыПоДокументам.Обороты(
		|			&НачПериода,
		|			&КонПериода,
		|			Регистратор,
		|			Организация В
		|					(ВЫБРАТЬ
		|						втОрганизации.Организация
		|					ИЗ
		|						втОрганизации)
		|				И ЗаказНаТС <> ЗНАЧЕНИЕ(Документ.уатЗаказГрузоотправителя.ПустаяСсылка)
		|				И (ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
		|					ИЛИ ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам))) КАК уатРасчетыПоДокументамОбороты
		|ГДЕ
		|	уатРасчетыПоДокументамОбороты.СуммаРасходОборот > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	уатПлатежноеПоручениеВходящее.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.уатПлатежноеПоручениеВходящее КАК уатПлатежноеПоручениеВходящее
		|ГДЕ
		|	уатПлатежноеПоручениеВходящее.Ссылка В
		|			(ВЫБРАТЬ
		|				втДокументы.Регистратор
		|			ИЗ
		|				втДокументы)
		|
		|СГРУППИРОВАТЬ ПО
		|	уатПлатежноеПоручениеВходящее.Ссылка
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(уатПлатежноеПоручениеВходящее.Заказы.ЗаказНаТС) = 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатПлатежноеПоручениеИсходящее.Ссылка
		|ИЗ
		|	Документ.уатПлатежноеПоручениеИсходящее КАК уатПлатежноеПоручениеИсходящее
		|ГДЕ
		|	уатПлатежноеПоручениеИсходящее.Ссылка В
		|			(ВЫБРАТЬ
		|				втДокументы.Регистратор
		|			ИЗ
		|				втДокументы)
		|
		|СГРУППИРОВАТЬ ПО
		|	уатПлатежноеПоручениеИсходящее.Ссылка
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(уатПлатежноеПоручениеИсходящее.Заказы.ЗаказНаТС) = 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатПриходныйКассовыйОрдер.Ссылка
		|ИЗ
		|	Документ.уатПриходныйКассовыйОрдер КАК уатПриходныйКассовыйОрдер
		|ГДЕ
		|	уатПриходныйКассовыйОрдер.Ссылка В
		|			(ВЫБРАТЬ
		|				втДокументы.Регистратор
		|			ИЗ
		|				втДокументы)
		|
		|СГРУППИРОВАТЬ ПО
		|	уатПриходныйКассовыйОрдер.Ссылка
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(уатПриходныйКассовыйОрдер.Заказы.ЗаказНаТС) = 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатРасходныйКассовыйОрдер.Ссылка
		|ИЗ
		|	Документ.уатРасходныйКассовыйОрдер КАК уатРасходныйКассовыйОрдер
		|ГДЕ
		|	уатРасходныйКассовыйОрдер.Ссылка В
		|			(ВЫБРАТЬ
		|				втДокументы.Регистратор
		|			ИЗ
		|				втДокументы)
		|
		|СГРУППИРОВАТЬ ПО
		|	уатРасходныйКассовыйОрдер.Ссылка
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(уатРасходныйКассовыйОрдер.Заказы.ЗаказНаТС) = 0");
		Запрос.УстановитьПараметр("НачПериода", СтруктураПараметров.Период.ДатаНачала);
		Запрос.УстановитьПараметр("КонПериода", СтруктураПараметров.Период.ДатаОкончания);
		ВыборкаДокументы = Запрос.Выполнить().Выбрать();
		
		НЗДвиженияРасчетыПоДокументам = РегистрыНакопления.уатРасчетыПоДокументам.СоздатьНаборЗаписей();
		
		ВсегоДокументов    = ВыборкаДокументы.Количество();
		ШагВыводаПрогресса = Макс(Окр(ВсегоДокументов/10), 1);

		Сч = 0;
		Пока ВыборкаДокументы.Следующий() Цикл
			Сч = Сч + 1;
			
			НЗДвиженияРасчетыПоДокументам.Отбор.Регистратор.Установить(ВыборкаДокументы.Ссылка);
			НЗДвиженияРасчетыПоДокументам.Прочитать();
			тблДвижения = НЗДвиженияРасчетыПоДокументам.Выгрузить();
			
			ДокОбъект = ВыборкаДокументы.Ссылка.ПолучитьОбъект();
			Для Каждого ТекСтрокаРасшифровка Из ДокОбъект.РасшифровкаПлатежа Цикл
				ТекСтрокаID = Неопределено;
				
				СтруктураПоиска = Новый Структура("ДоговорКонтрагента, Сделка, Валюта",
					ТекСтрокаРасшифровка.ДоговорКонтрагента, ТекСтрокаРасшифровка.Сделка, ТекСтрокаРасшифровка.ВалютаВзаиморасчетов);
				мсвДвижения = тблДвижения.НайтиСтроки(СтруктураПоиска);
				Для Каждого ТекДвижение Из мсвДвижения Цикл
					Если НЕ ЗначениеЗаполнено(ТекДвижение.ЗаказНаТС) Тогда
						Продолжить;
					КонецЕсли;
					Если ТекСтрокаID = Неопределено Тогда
						ТекСтрокаID = Новый УникальныйИдентификатор;
					КонецЕсли;
					
					НоваяСтрокаЗаказы = ДокОбъект.Заказы.Добавить();
					НоваяСтрокаЗаказы.ID        = ТекСтрокаID;
					НоваяСтрокаЗаказы.ЗаказНаТС = ТекДвижение.ЗаказНаТС;
					
					НоваяСтрокаЗаказы.СуммаВзаиморасчетов = ТекДвижение.СуммаРасход;
					
					Если НоваяСтрокаЗаказы.СуммаВзаиморасчетов = ТекСтрокаРасшифровка.СуммаВзаиморасчетов Тогда
						НоваяСтрокаЗаказы.СуммаПлатежа = ТекСтрокаРасшифровка.СуммаПлатежа;
					ИначеЕсли ТекСтрокаРасшифровка.ВалютаВзаиморасчетов = ДокОбъект.ВалютаДокумента Тогда
						НоваяСтрокаЗаказы.СуммаПлатежа = НоваяСтрокаЗаказы.СуммаВзаиморасчетов;
					Иначе
						НоваяСтрокаЗаказы.СуммаПлатежа = уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(
							НоваяСтрокаЗаказы.СуммаВзаиморасчетов,
							ТекСтрокаРасшифровка.ВалютаВзаиморасчетов,    ДокОбъект.ВалютаДокумента,
							ТекСтрокаРасшифровка.КурсВзаиморасчетов,      ДокОбъект.Дата,
							ТекСтрокаРасшифровка.КратностьВзаиморасчетов,,,
							ДокОбъект);
					КонецЕсли;
				КонецЦикла;
				
				Если ТекСтрокаID <> Неопределено Тогда
					ТекСтрокаРасшифровка.ID = ТекСтрокаID;
				КонецЕсли;
			КонецЦикла;
			
			ДокОбъект.ОбменДанными.Загрузка = Истина;
			ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
			
			Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
				ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
				ТекстНСТР = "Заполнение ТЧ ""Разнесение по заказам"" (" + ВерсияКонфигурации + ") платежных документов";
				ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураПараметров.ОбновлениеСостоянияОплаты Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	уатТекущееСостояниеОплаты.Документ КАК Документ
		|ПОМЕСТИТЬ втДокументы
		|ИЗ
		|	РегистрСведений.уатТекущееСостояниеОплаты КАК уатТекущееСостояниеОплаты
		|ГДЕ
		|	уатТекущееСостояниеОплаты.Документ.Дата МЕЖДУ &НачПериода И &КонПериода
		|	И (уатТекущееСостояниеОплаты.Документ ССЫЛКА Документ.уатСчетНаОплатуПокупателю
		|			ИЛИ уатТекущееСостояниеОплаты.Документ ССЫЛКА Документ.уатСчетНаОплатуПоставщика
		|			ИЛИ уатТекущееСостояниеОплаты.Документ ССЫЛКА Документ.уатПоступлениеТоваровУслуг
		|			ИЛИ уатТекущееСостояниеОплаты.Документ ССЫЛКА Документ.уатРеализацияУслуг)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	уатПоступлениеТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.уатПоступлениеТоваровУслуг КАК уатПоступлениеТоваровУслуг
		|ГДЕ
		|	НЕ уатПоступлениеТоваровУслуг.ПометкаУдаления
		|	И уатПоступлениеТоваровУслуг.Дата МЕЖДУ &НачПериода И &КонПериода
		|	И (уатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
		|			ИЛИ уатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
		|			ИЛИ уатПоступлениеТоваровУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС))
		|	И НЕ уатПоступлениеТоваровУслуг.Ссылка В
		|				(ВЫБРАТЬ
		|					втДокументы.Документ
		|				ИЗ
		|					втДокументы)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатРеализацияУслуг.Ссылка
		|ИЗ
		|	Документ.уатРеализацияУслуг КАК уатРеализацияУслуг
		|ГДЕ
		|	НЕ уатРеализацияУслуг.ПометкаУдаления
		|	И уатРеализацияУслуг.Дата МЕЖДУ &НачПериода И &КонПериода
		|	И (уатРеализацияУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
		|			ИЛИ уатРеализацияУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
		|			ИЛИ уатРеализацияУслуг.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС))
		|	И НЕ уатРеализацияУслуг.Ссылка В
		|				(ВЫБРАТЬ
		|					втДокументы.Документ
		|				ИЗ
		|					втДокументы)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатСчетНаОплатуПокупателю.Ссылка
		|ИЗ
		|	Документ.уатСчетНаОплатуПокупателю КАК уатСчетНаОплатуПокупателю
		|ГДЕ
		|	НЕ уатСчетНаОплатуПокупателю.ПометкаУдаления
		|	И уатСчетНаОплатуПокупателю.Дата МЕЖДУ &НачПериода И &КонПериода
		|	И (уатСчетНаОплатуПокупателю.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
		|			ИЛИ уатСчетНаОплатуПокупателю.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
		|			ИЛИ уатСчетНаОплатуПокупателю.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС))
		|	И НЕ уатСчетНаОплатуПокупателю.Ссылка В
		|				(ВЫБРАТЬ
		|					втДокументы.Документ
		|				ИЗ
		|					втДокументы)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	уатСчетНаОплатуПоставщика.Ссылка
		|ИЗ
		|	Документ.уатСчетНаОплатуПоставщика КАК уатСчетНаОплатуПоставщика
		|ГДЕ
		|	НЕ уатСчетНаОплатуПоставщика.ПометкаУдаления
		|	И уатСчетНаОплатуПоставщика.Дата МЕЖДУ &НачПериода И &КонПериода
		|	И (уатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным)
		|			ИЛИ уатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам)
		|			ИЛИ уатСчетНаОплатуПоставщика.ДоговорКонтрагента.ВедениеВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС))
		|	И НЕ уатСчетНаОплатуПоставщика.Ссылка В
		|				(ВЫБРАТЬ
		|					втДокументы.Документ
		|				ИЗ
		|					втДокументы)");
		Запрос.УстановитьПараметр("НачПериода", СтруктураПараметров.Период.ДатаНачала);
		Запрос.УстановитьПараметр("КонПериода", СтруктураПараметров.Период.ДатаОкончания);
		мсвДокументы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		
		ТекстНСТР = "Обновление состояния оплаты счетов и накладных. Расчет состояния оплаты, всего документов " + мсвДокументы.Количество();
		ДлительныеОперации.СообщитьПрогресс(0, ТекстНСТР);
				
		мсвСостояниеОплатыПоЗаказам = уатОбщегоНазначения_проф.СостояниеОплатыПоДокументам(мсвДокументы);
		
		ВсегоДокументов    = мсвДокументы.Количество();
		ШагВыводаПрогресса = Макс(Окр(ВсегоДокументов/10), 1);

		Сч = 0;
		Для Каждого СостояниеОплатыПоЗаказу Из мсвСостояниеОплатыПоЗаказам Цикл
			Сч = Сч + 1;
			
			НоваяЗапись = РегистрыСведений.уатТекущееСостояниеОплаты.СоздатьМенеджерЗаписи();
			НоваяЗапись.Документ      = СостояниеОплатыПоЗаказу.Документ;
			НоваяЗапись.СуммаВсего    = СостояниеОплатыПоЗаказу.Сумма;
			НоваяЗапись.Оплачено      = СостояниеОплатыПоЗаказу.СуммаОплатыФакт;
			НоваяЗапись.ПроцентОплаты = СостояниеОплатыПоЗаказу.ПроцентОплатыФакт;
			Если СостояниеОплатыПоЗаказу.ПроцентОплатыФакт = 0 Тогда
				НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.Новый;
			ИначеЕсли Окр(СостояниеОплатыПоЗаказу.ПроцентОплатыФакт) >= 100 Тогда
				НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.Выполнен;
			Иначе
				НоваяЗапись.Состояние = Перечисления.уатСостоянияВыполненияЗаказов.ЧастичноВыполнен;
			КонецЕсли;
			НоваяЗапись.ПредоплатыНедостаточно = (СостояниеОплатыПоЗаказу.СуммаОплатыФакт < СостояниеОплатыПоЗаказу.СуммаПредоплаты);
			НоваяЗапись.ОплаченоПредставление = СтрШаблон("%1 (%2)",
				Формат(СостояниеОплатыПоЗаказу.СуммаОплатыФакт, "ЧДЦ=2; ЧН=0"),
				Формат(СостояниеОплатыПоЗаказу.ПроцентОплатыФакт, "ЧДЦ=0; ЧН=0") + "%");
			НоваяЗапись.Записать();
			
			Если ШагВыводаПрогресса > 0 И Сч%ШагВыводаПрогресса=0 Тогда
				ПроцентВыполнения = Окр(Сч/ВсегоДокументов*100);
				ТекстНСТР = "Обновление состояния оплаты счетов и накладных";
				ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстНСТР);
			КонецЕсли;
		КонецЦикла;	    
	КонецЕсли;
	
КонецПроцедуры

