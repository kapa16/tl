
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ТипЗнч(ПараметрКоманды) = Тип("Массив") Тогда
		Если ПараметрКоманды.Количество() > 0 Тогда
			ДокументСсылка = ПараметрКоманды[0];
		Конецесли;
	Иначе
		ДокументСсылка = ПараметрКоманды;
	КонецЕсли;  
	
	Если ДокументСсылка = Тип("ДокументСсылка.уатМаршрутныйЛист") Тогда
		ПараметрыФормы = Новый Структура("ОтборПоВодителям", ПолучитьВодителейИзМаршрутныхЛистов(ПараметрКоманды));
	ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси() Тогда 
		ПараметрыФормы = Новый Структура("ОтборПоВодителям", ПолучитьВодителейИзЗаказаТакси(ПараметрКоманды));
	Конецесли;
	
	ОткрытьФорму(
		"Обработка.уатСообщенияМобильногоПриложения.Форма", 
		ПараметрыФормы, 
		ПараметрыВыполненияКоманды.Источник, 
		ПараметрыВыполненияКоманды.Уникальность, 
		ПараметрыВыполненияКоманды.Окно, 
		ПараметрыВыполненияКоманды.НавигационнаяСсылка
	);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьВодителейИзМаршрутныхЛистов(Знач МаршрутныеЛисты)
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("мсвМаршрутныхЛистов", МаршрутныеЛисты);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатМаршрутныйЛист.Водитель1 КАК Водитель
	|ИЗ
	|	Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	|ГДЕ
	|	уатМаршрутныйЛист.Ссылка В(&мсвМаршрутныхЛистов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	уатМаршрутныйЛист.Водитель2
	|ИЗ
	|	Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	|ГДЕ
	|	уатМаршрутныйЛист.Ссылка В(&мсвМаршрутныхЛистов)";
	
	мсвВодители = Новый Массив();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Не ЗначениеЗаполнено(Выборка.Водитель) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(Выборка.Водитель) = Тип("СправочникСсылка.Сотрудники") Тогда 
			мсвВодители.Добавить(Выборка.Водитель.ФизическоеЛицо);
		Иначе 
			мсвВодители.Добавить(Выборка.Водитель);
		КонецЕсли;
	КонецЦикла;
	
	Возврат мсвВодители;
	
КонецФункции // ПолучитьВодителейИзМаршрутныхЛистов()

&НаСервере
Функция ПолучитьВодителейИзЗаказаТакси(Знач ЗаказыТакси)
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("мсвЗаказовТакси", ЗаказыТакси);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	такЗаказТакси.Водитель КАК Водитель
	|ИЗ
	|	Документ.такЗаказТакси КАК такЗаказТакси
	|ГДЕ
	|	такЗаказТакси.Ссылка В(&мсвЗаказовТакси)";
	
	мсвВодители = Новый Массив();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Не ЗначениеЗаполнено(Выборка.Водитель) Тогда 
