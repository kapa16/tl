	Возврат ГруппаОбъект.Ссылка;
	
КонецФункции // НайтиСоздатьГруппуФизЛиц()

&НаСервере
Функция НайтиСоздатьФизЛицо(Наименование, Фамилия, Имя, Отчество, ДатаРождения, Группа = Неопределено,
	Пол = Неопределено, ИНН = Неопределено, ТелефонВодитель = Неопределено, АдресВодитель = Неопределено, EmailВодитель = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(Наименование)
		И НЕ ЗначениеЗаполнено(Фамилия)
		И НЕ ЗначениеЗаполнено(Имя) Тогда
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;

	ФИОФизЛица = Фамилия + " " + Имя + " " + Отчество;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("ФИО",          ФИОФизЛица);
	Запрос.УстановитьПараметр("ДатаРождения", ДатаРождения);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФизическиеЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	ФизическиеЛица.Наименование = &Наименование
	|	И ФизическиеЛица.ФИО = &ФИО
	|	И ФизическиеЛица.ДатаРождения = &ДатаРождения
	|	И НЕ ФизическиеЛица.ЭтоГруппа
	|	И НЕ ФизическиеЛица.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	ФизЛицоОбъект = Справочники.ФизическиеЛица.СоздатьЭлемент();
	ФизЛицоОбъект.Заполнить(Неопределено);
	ФизЛицоОбъект.Наименование = Наименование;
	Если ЗначениеЗаполнено(Группа) Тогда
		ФизЛицоОбъект.Родитель     = НайтиСоздатьГруппуФизЛиц(Группа);
	Конецесли;
	ФизЛицоОбъект.ДатаРождения = ДатаРождения;
	ФизЛицоОбъект.ФИО          = ФИОФизЛица;
	ФизЛицоОбъект.ИНН               = ИНН;

	Если ЗначениеЗаполнено(Пол) Тогда
		ФизЛицоОбъект.Пол          = ?(Пол = "Мужской", Перечисления.ПолФизическогоЛица.Мужской, Перечисления.ПолФизическогоЛица.Женский);
	КонецЕсли;
	ФизЛицоОбъект.Записать();
	
	Если ЗначениеЗаполнено(ТелефонВодитель) Тогда  
		ЗначениеТелефон = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(ТелефонВодитель,
		Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица, "");
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ФизЛицоОбъект.Ссылка, ЗначениеТелефон, 
		Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица);
	КонецЕсли;
	Если ЗначениеЗаполнено(АдресВодитель) Тогда  
		ЗначениеАдрес = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(АдресВодитель,
		Справочники.ВидыКонтактнойИнформации.АдресМестаПроживанияФизическиеЛица, "");
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ФизЛицоОбъект.Ссылка, ЗначениеТелефон, 
		Справочники.ВидыКонтактнойИнформации.АдресМестаПроживанияФизическиеЛица);
	КонецЕсли;
	Если ЗначениеЗаполнено(EmailВодитель) Тогда  
		ЗначениеEmail = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(EmailВодитель,
		Справочники.ВидыКонтактнойИнформации.EmailФизЛица, "");
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ФизЛицоОбъект.Ссылка, ЗначениеEmail, 
		Справочники.ВидыКонтактнойИнформации.EmailФизЛица);
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ФИОФизическихЛиц.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Заполнить(Неопределено);
	МенеджерЗаписи.Период         = '19700101';
