КонецФункции

&НаСервере
Функция НайтиЕдиницуИзмерения(Наименование, Номенклатура)
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕдиницыИзмерения.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	|ГДЕ
	|	ЕдиницыИзмерения.Наименование = &Наименование
	|	И НЕ ЕдиницыИзмерения.ПометкаУдаления
	|	И ЕдиницыИзмерения.Владелец = &Номенклатура";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.ЕдиницыИзмерения.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ОбработатьТаблицуДанныхПлановыеЦеныНоменклатуры(СчВсего, СчСоздано, ТекстОшибки)
	
	тчТаблицаДанныхПлановыеЦены = ТаблицаДанныхПлановыеЦеныНоменклатуры.Выгрузить();
	НаборЗаписей = РегистрыСведений.уатПлановыеЦеныНоменклатуры.СоздатьНаборЗаписей();
	
	Для Каждого ТекСтрока Из ТаблицаДанныхПлановыеЦеныНоменклатуры Цикл
		СчВсего = СчВсего + 1;
		
		ТекСтрока.МодельСсылка = НайтиМодельТС(ТекСтрока.Модель);
		ТекСтрока.НоменклатураСсылка = НайтиНоменклатуру(ТекСтрока.Номенклатура);
		ТекСтрока.ЕдиницаИзмеренияСсылка = НайтиЕдиницуИзмерения(ТекСтрока.ЕдиницаИзмерения, ТекСтрока.НоменклатураСсылка);
		ТекСтрока.ВалютаСсылка = НайтиВалюту(ТекСтрока.Валюта);
		
		Если ЗначениеЗаполнено(ТекСтрока.НоменклатураСсылка)
			И ЗначениеЗаполнено(ТекСтрока.ЕдиницаИзмеренияСсылка)
			И ЗначениеЗаполнено(ТекСтрока.ВалютаСсылка) Тогда
			НоваяЗапись                  = НаборЗаписей.Добавить();
			НоваяЗапись.Период           = ТекСтрока.Период;
			НоваяЗапись.Модель           = ТекСтрока.МодельСсылка;
			НоваяЗапись.Номенклатура     = ТекСтрока.НоменклатураСсылка;
			НоваяЗапись.ЕдиницаИзмерения = ТекСтрока.ЕдиницаИзмеренияСсылка;
			НоваяЗапись.Цена             = ТекСтрока.Цена;
			НоваяЗапись.Валюта           = ТекСтрока.ВалютаСсылка;
			
			СчСоздано = СчСоздано + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	РежимЗаписи = ОбщегоНазначенияБЭД.РежимСлиянияНабораЗаписей();
	Если РежимЗаписи = Неопределено Тогда
		РежимЗаписи = Ложь;
	КонецЕсли;
	НаборЗаписей.Записать(РежимЗаписи);
	
КонецПроцедуры

&НаСервере
Функция ТаблицаВМассивСтруктур(Знач ТаблицаЗначений)
	Результат = Новый Массив;
	
	ИменаКолонок = "";
	Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл
		ИменаКолонок = ИменаКолонок + "," + Колонка.Имя;
	КонецЦикла;
	ИменаКолонок = Сред(ИменаКолонок, 2);
	
	Для Каждого Строка Из ТаблицаЗначений Цикл
		СтруктураСтроки = Новый Структура(ИменаКолонок);
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, Строка);
		Результат.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

