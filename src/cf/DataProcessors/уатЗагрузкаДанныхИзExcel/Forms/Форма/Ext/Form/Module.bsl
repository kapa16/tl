	ГруппаОбъект = Справочники.Контрагенты.СоздатьГруппу();
	ГруппаОбъект.Наименование = Группа;
	ГруппаОбъект.Записать();
	
	Возврат ГруппаОбъект.Ссылка;
	
КонецФункции

