#Область ОбработкаТаблицы_ЗаказыТакси

&НаСервере
Процедура ОбработатьТаблицуДанныхЗаказыТакси(СчВсего, СчСоздано, ТекстОшибки = "")
	
	тчТаблицаДанныхЗаказыТакси = ТаблицаДанныхЗаказыТакси.Выгрузить();
	
	МассивОбработанныхДокументов = Новый Массив();
	
	Для Каждого ТекСтрока Из тчТаблицаДанныхЗаказыТакси Цикл
		Если МассивОбработанныхДокументов.Найти(ТекСтрока.ВходНомер) <> Неопределено Тогда
			Продолжить;
		КонецЕсли; 
		мЗаказыТакси = ТаблицаДанныхЗаказыТакси.НайтиСтроки(Новый Структура("ВходНомер", ТекСтрока.ВходНомер));
		
		массивДоходы = Новый Массив();
		Для Каждого ТекСтрокаЗаказ Из мЗаказыТакси Цикл
			СтруктураПолей   = Новый Структура("Услуга, Цена, Количество, Сумма, СтавкаНДС, СуммаНДС, Трансфер, СуммаСкидки");
			ЗаполнитьЗначенияСвойств(СтруктураПолей, ТекСтрокаЗаказ);  
			массивДоходы.Добавить(СтруктураПолей);
		КонецЦикла;

		ОбъектСсылка = НайтиСоздатьЗаказТакси(
			ТекСтрока,
			массивДоходы,
			СчСоздано,
			СчВсего,
			ТекстОшибки
		);
		Для Каждого ТекСтрокаЗаказ Из мЗаказыТакси Цикл
			ТекСтрокаЗаказ.Ссылка = ОбъектСсылка;
		КонецЦикла;

		ТекСтрока.Ссылка = ОбъектСсылка;
		МассивОбработанныхДокументов.Добавить(ТекСтрока.ВходНомер);
		
		СчВсего = СчВсего + 1;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Процедура ОбработатьТаблицуДанныхАрендаТС(СчВсего, СчСоздано, ТекстОшибки = "")
	
	Для Каждого ТекСтрока Из ТаблицаДанныхАрендаТС Цикл 
		ОбъектСсылка = НайтиСоздатьАрендаТС(
			ТекСтрока,
			СчСоздано,
			СчВсего,
			ТекстОшибки
		);
		ТекСтрока.Ссылка = ОбъектСсылка;
		СчВсего = СчВсего + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НайтиСоздатьЗаказТакси(СтрокаТаблицы, массивДоходы, СчСоздано, СчВсего, ТекстОшибки = "")

	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Дата) Тогда
		ДатаДокумента = ДатаЗаказа;
	Иначе
		ДатаДокумента = СтрокаТаблицы.Дата;
	КонецЕсли;
	
	ЗаказчикСсылка = НайтиСоздатьКонтрагента(СтрокаТаблицы.Заказчик, СтрокаТаблицы.ЮридическоеЛицо,,СтрокаТаблицы.АдресЗаказчик,,СтрокаТаблицы.Телефон,,
	СтрокаТаблицы.ИНН, СтрокаТаблицы.КПП, СтрокаТаблицы.КодПоОКПО, СтрокаТаблицы.БИК, СтрокаТаблицы.НомерСчета,
	СтрокаТаблицы.ПредпочитаемыйТипТС, СтрокаТаблицы.СогласенНаПовышение, СтрокаТаблицы.СогласенНаПонижение, СтрокаТаблицы.ЗаказчикEmail);
	
	КонтактноеЛицо = Неопределено;
	Если ЗначениеЗаполнено(СтрокаТаблицы.КонтактноеЛицо) Тогда
		КонтактноеЛицо = НайтиСоздатьКонтактноеЛицо(Перечисления.ВидыКонтактныхЛиц.КонтактноеЛицоКонтрагента,
			СтрокаТаблицы.КонтактноеЛицо, ЗаказчикСсылка, СтрокаТаблицы.КонтактноеЛицоДатаРождения, СтрокаТаблицы.КонтактноеЛицоТелефон,
