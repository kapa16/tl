			ТипДвигателя = Перечисления.уатТипыДвигателей.Бензиновый;
		ИначеЕсли НРег(ЗагружаемыйТипДвигателя) = "diesel" Тогда 
			ТипДвигателя = Перечисления.уатТипыДвигателей.Дизельный;
