			МенеджерЗаписи = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.Заполнить(Неопределено);
			МенеджерЗаписи.Период       = ?(ЗначениеЗаполнено(СтрокаТаблицы.ДатаВыдачиВодУдостоверения), СтрокаТаблицы.ДатаВыдачиВодУдостоверения, ТекущаяДатаСеанса());
			МенеджерЗаписи.Физлицо      = ДокументОбъект.Водитель;
			МенеджерЗаписи.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение;
			МенеджерЗаписи.Серия        = СтрокаТаблицы.СерияВодУдостоверения;
			МенеджерЗаписи.Номер        = СтрокаТаблицы.НомерВодУдостоверения;
			МенеджерЗаписи.ДатаВыдачи   = СтрокаТаблицы.ДатаВыдачиВодУдостоверения; 
			МенеджерЗаписи.СрокДействия = СтрокаТаблицы.СрокОкончанияДействияВодУдостоверения;  
			МенеджерЗаписи.Записать(Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.ДатаПрибытияФакт) 
		И (ЗначениеЗаполнено(ДокументОбъект.Водитель) 
		ИЛИ ЗначениеЗаполнено(ДокументОбъект.ТС)) Тогда
		ДокументОбъект.Статус  = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Закрыт"); 
	КонецЕсли;
	
	Для Каждого ТекСтрока Из массивДоходы Цикл
		НоваяСтрока = ДокументОбъект.Услуги.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.Номенклатура = НайтиСоздатьНоменклатуру(ТекСтрока.Услуга, "", Справочники.ВидыНоменклатуры.Услуга); 
		ОбменСКонтрагентамиПереопределяемый.ПолучитьЗначениеПеречисления("СтавкиНДС",ТекСтрока.СтавкаНДС, НоваяСтрока.СтавкаНДС);
		НоваяСтрока.Содержание    = ТекСтрока.Услуга;
		НоваяСтрока.РучнойВвод    = Истина;
		НоваяСтрока.СтатьяДоходов = уатОбщегоНазначенияСервер.СтатьяДоходовНоменклатуры(НоваяСтрока.Номенклатура);
		Попытка
			НоваяСтрока.ПроцентСкидки = НоваяСтрока.СуммаСкидки / (НоваяСтрока.Количество * НоваяСтрока.Цена) * 100; 
		Исключение
		КонецПопытки;
		НоваяСтрока.Сумма = НоваяСтрока.Сумма - НоваяСтрока.СуммаСкидки;
	КонецЦикла;
	СтруктураДокумента = уатОбщегоНазначенияКлиентСервер.СтруктураДокумента(ДокументОбъект, "такЗаказТакси");
	ДокументОбъект.СуммаДокумента  = уатОбщегоНазначенияТиповые.уатПолучитьСуммуДокументаСНДС(СтруктураДокумента, "Услуги");
	
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		СчСоздано = СчСоздано + 1;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
	
	Если СтрокаТаблицы.ВодительВЧерномСписке
		И ЗначениеЗАполнено(ДокументОбъект.Водитель) Тогда
		МенеджерЗаписи = РегистрыСведений.такЧерныйСписок.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Заполнить(Неопределено);
		МенеджерЗаписи.ВидОбъектаЧерногоСписка = Перечисления.такВидыОбъектовЧерногоСписка.Водитель;
		МенеджерЗаписи.Объект                  = ?(ТипЗнч(ДокументОбъект.Водитель) = Тип("СправочникСсылка.Сотрудники"), ДокументОбъект.Водитель.ФизическоеЛицо, ДокументОбъект.Водитель);
		МенеджерЗаписи.Заказчик                = ДокументОбъект.Заказчик;
		МенеджерЗаписи.ДатаЗанесения           = СтрокаТаблицы.ВодительВЧерномСпискеДатаЗанесения;
		МенеджерЗаписи.ПериодЧерногоСписка     = СтрокаТаблицы.ВодительВЧерномСпискеПериодЧерногоСписка; 
		МенеджерЗаписи.Навсегда                = СтрокаТаблицы.ВодительВЧерномСпискеНавсегда;  
		МенеджерЗаписи.Причина                 = НайтиСоздатьПричинуЗанесенияВЧерныйСписок(СтрокаТаблицы.ВодительВЧерномСпискеПричина);
		МенеджерЗаписи.Комментарий             = СтрокаТаблицы.ВодительВЧерномСпискеКомментарий;
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	Если СтрокаТаблицы.ЗаказчикВЧерномСписке
		И ЗначениеЗАполнено(ДокументОбъект.Заказчик) Тогда
		МенеджерЗаписи = РегистрыСведений.такЧерныйСписок.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Заполнить(Неопределено);
		МенеджерЗаписи.ВидОбъектаЧерногоСписка = Перечисления.такВидыОбъектовЧерногоСписка.Контрагент;
		МенеджерЗаписи.Объект                  = ДокументОбъект.Заказчик;
		МенеджерЗаписи.ДатаЗанесения           = СтрокаТаблицы.ЗаказчикВЧерномСпискеДатаЗанесения;
		МенеджерЗаписи.ПериодЧерногоСписка     = СтрокаТаблицы.ЗаказчикВЧерномСпискеПериодЧерногоСписка; 
		МенеджерЗаписи.Навсегда                = СтрокаТаблицы.ЗаказчикВЧерномСпискеНавсегда;  
		МенеджерЗаписи.Причина                 = НайтиСоздатьПричинуЗанесенияВЧерныйСписок(СтрокаТаблицы.ЗаказчикВЧерномСпискеПричина);
		МенеджерЗаписи.Комментарий             = СтрокаТаблицы.ЗаказчикВЧерномСпискеКомментарий;
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	Если СтрокаТаблицы.ЗаказчикТелефонВЧерномСписке 
		И ЗначениеЗаполнено(СтрокаТаблицы.Телефон) Тогда
		МенеджерЗаписи = РегистрыСведений.такЧерныйСписок.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Заполнить(Неопределено);
		МенеджерЗаписи.ВидОбъектаЧерногоСписка = Перечисления.такВидыОбъектовЧерногоСписка.Телефон;
		МенеджерЗаписи.Объект                  = СтрокаТаблицы.Телефон;
		МенеджерЗаписи.ДатаЗанесения           = СтрокаТаблицы.ЗаказчикТелефонВЧерномСпискеДатаЗанесения;
		МенеджерЗаписи.ПериодЧерногоСписка     = СтрокаТаблицы.ЗаказчикТелефонВЧерномСпискеПериодЧерногоСписка; 
		МенеджерЗаписи.Навсегда                = СтрокаТаблицы.ЗаказчикТелефонВЧерномСпискеНавсегда;  
		МенеджерЗаписи.Причина                 = НайтиСоздатьПричинуЗанесенияВЧерныйСписок(СтрокаТаблицы.ЗаказчикТелефонВЧерномСпискеПричина);
		МенеджерЗаписи.Комментарий             = СтрокаТаблицы.ЗаказчикТелефонВЧерномСпискеКомментарий;
		МенеджерЗаписи.ПредставлениеТелефона   = СтрокаТаблицы.Телефон;
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;  
	Если СтрокаТаблицы.ПассажирТелефонВЧерномСписке 
		И ЗначениеЗаполнено(СтрокаТаблицы.ТелефонПассажир) Тогда
		МенеджерЗаписи = РегистрыСведений.такЧерныйСписок.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Заполнить(Неопределено);
		МенеджерЗаписи.ВидОбъектаЧерногоСписка = Перечисления.такВидыОбъектовЧерногоСписка.Телефон;
		МенеджерЗаписи.Объект                  = СтрокаТаблицы.ТелефонПассажир;
		МенеджерЗаписи.ДатаЗанесения           = СтрокаТаблицы.ПассажирТелефонВЧерномСпискеДатаЗанесения;
		МенеджерЗаписи.ПериодЧерногоСписка     = СтрокаТаблицы.ПассажирТелефонВЧерномСпискеПериодЧерногоСписка; 
		МенеджерЗаписи.Навсегда                = СтрокаТаблицы.ПассажирТелефонВЧерномСпискеНавсегда;  
		МенеджерЗаписи.Причина                 = НайтиСоздатьПричинуЗанесенияВЧерныйСписок(СтрокаТаблицы.ПассажирТелефонВЧерномСпискеПричина);
		МенеджерЗаписи.Комментарий             = СтрокаТаблицы.ПассажирТелефонВЧерномСпискеКомментарий;
		МенеджерЗаписи.ПредставлениеТелефона   = СтрокаТаблицы.ТелефонПассажир;
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	Возврат ДокументОбъект.Ссылка;
	
КонецФункции // НайтиСоздатьЗаказТакси()

&НаСервере
Функция НайтиСоздатьАрендаТС(СтрокаТаблицы, СчСоздано, СчВсего, ТекстОшибки = "")

	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Дата) Тогда
		ДатаДокумента = ДатаЗаказа;
	Иначе
		ДатаДокумента = СтрокаТаблицы.Дата;
	КонецЕсли;
	
	ЗаказчикСсылка = НайтиСоздатьКонтрагента(СтрокаТаблицы.Заказчик, СтрокаТаблицы.ЮридическоеЛицо,,,,СтрокаТаблицы.Телефон);
	
	ДокументОбъект                         = Документы["такАрендаТС"].СоздатьДокумент();
	ДокументОбъект.Дата                    = ДатаДокумента;
	ДокументОбъект.Организация             = Организация;
	ДокументОбъект.Ответственный           = Ответственный;
	ДокументОбъект.Контрагент              = ЗаказчикСсылка;
	ДокументОбъект.Комментарий             = СтрокаТаблицы.Комментарий;
	
	Если ТипЗнч(ЗаказчикСсылка) = Тип("СправочникСсылка.Контрагенты")
		И ЗаказчикСсылка.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
		ДокументОбъект.ДоговорКонтрагента  = ПолучитьДоговорКонтрагентаДляЗаказаНаТС(ЗаказчикСсылка);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ПунктВыдачи) Тогда
		мАдресВыдачи      = Нстр("ru='Пункт выдачи';en='Point of departure'") + " " + (СчВсего + 1);
		ПунктВыдачиСсылка = НайтиСоздатьПунктНазначения(, СтрокаТаблицы.ПунктВыдачи, СтрокаТаблицы.ЛатВыдачи, СтрокаТаблицы.ЛонВыдачи, ТекстОшибки, мАдресВыдачи);
	Иначе
		ПунктВыдачиСсылка = НайтиСоздатьПунктНазначения(, СтрокаТаблицы.ПунктВыдачи, СтрокаТаблицы.ЛатВыдачи, СтрокаТаблицы.ЛонВыдачи, ТекстОшибки);
	КонецЕсли;
	ДокументОбъект.ПунктВыдачи = ПунктВыдачиСсылка;
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.ПунктВозврата)
		ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.ЛатВозврата)
		ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.ЛонВозврата) Тогда
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ПунктВозврата) Тогда
			мАдресВозврата      = Нстр("ru='Пункт возврата';en='Point of departure'") + " " + (СчВсего + 1);
			ПунктВозвратаСсылка = НайтиСоздатьПунктНазначения(, СтрокаТаблицы.ПунктВозврата, СтрокаТаблицы.ЛатВозврата, СтрокаТаблицы.ЛонВозврата, ТекстОшибки, мАдресВозврата);
		Иначе
			ПунктВозвратаСсылка = НайтиСоздатьПунктНазначения(, СтрокаТаблицы.ПунктВозврата, СтрокаТаблицы.ЛатВозврата, СтрокаТаблицы.ЛонВозврата, ТекстОшибки);
		КонецЕсли;
		ДокументОбъект.ПунктВозврата = ПунктВозвратаСсылка;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ДатаВыдачиПлан) Тогда
		ДатаВыдачиПлан = НачалоДня(ДатаДокумента);
	Иначе
		ДатаВыдачиПлан = СтрокаТаблицы.ДатаВыдачиПлан;
	Конецесли;
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ВремяВыдачиПлан) Тогда
		ВремяВыдачиПлан = Дата(1,1,1,0,0,0); 
	Иначе
		ВремяВыдачиПлан = СтрокаТаблицы.ВремяВыдачиПлан;
	Конецесли;
	ДокументОбъект.ДатаНачалаПлановая = ДатаВыдачиПлан + (ВремяВыдачиПлан - '00010101');
	
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ДатаВозвратаПлан) Тогда
		ДатаВозвратаПлан = НачалоДня(ДатаДокумента);
	Иначе
		ДатаВозвратаПлан = СтрокаТаблицы.ДатаВозвратаПлан;
	Конецесли;
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ВремяВозвратаПлан) Тогда
		ВремяВозвратаПлан = Дата(1,1,1,0,0,0);
	Иначе
		ВремяВозвратаПлан = СтрокаТаблицы.ВремяВозвратаПлан;
	Конецесли;
	Если ЗначениеЗаполнено(ДатаВозвратаПлан)
		ИЛИ ЗначениеЗаполнено(ВремяВозвратаПлан) Тогда
		ДокументОбъект.ДатаОкончанияПлановая = ДатаВозвратаПлан + (ВремяВозвратаПлан - '00010101'); 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ДатаВыдачиФакт) Тогда
		ДатаВыдачиФакт = НачалоДня(ДатаДокумента);
	Иначе
		ДатаВыдачиФакт = СтрокаТаблицы.ДатаВыдачиФакт;
	Конецесли;
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ВремяВыдачиФакт) Тогда
		ВремяВыдачиФакт = Дата(1,1,1,0,0,0);
	Иначе
		ВремяВыдачиФакт = СтрокаТаблицы.ВремяВыдачиФакт;
	Конецесли;
	Если ЗначениеЗаполнено(ДатаВыдачиФакт)
		ИЛИ ЗначениеЗаполнено(ВремяВыдачиФакт) Тогда
		ДокументОбъект.ДатаВыдачиФактическая = ДатаВыдачиФакт + (ВремяВыдачиФакт - '00010101');
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ДатаВозвратаФакт) Тогда
		ДатаВозвратаФакт = НачалоДня(ДатаДокумента);
	Иначе
		ДатаВозвратаФакт = СтрокаТаблицы.ДатаВозвратаФакт;
	Конецесли;
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ВремяВозвратаФакт) Тогда
		ВремяВозвратаФакт = Дата(1,1,1,0,0,0);
	Иначе
		ВремяВозвратаФакт = СтрокаТаблицы.ВремяВозвратаФакт;
	Конецесли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.ДатаВозвратаФакт)
		ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.ВремяВозвратаФакт) Тогда
		ДокументОбъект.ДатаВозвратаФактическая = ДатаВозвратаФакт + (ВремяВозвратаФакт - '00010101');
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.НомерТС)
		ИЛИ ЗначениеЗаполнено(ТСАрендаТС) Тогда
		МодельТС  = ?(ЗначениеЗаполнено(СтрокаТаблицы.Модель), СтрокаТаблицы.Модель, "МодельТС");
		мДатаВвода = ?(ЗначениеЗаполнено(СтрокаТаблицы.ДатаВвода), СтрокаТаблицы.ДатаВвода, Дата("20180101000000")); 
		
		ТССсылка  = НайтиСоздатьТС(СтрокаТаблицы.НомерТС, "", "", МодельТС, Организация,"", "", "","",
		мДатаВвода, "", "Автотранспорт",
		"", "", "", "", "", "", "", "", "", "", "", "", "", "","", 0, 0, 0, 0, "", 0,  ТСЗаказыТакси,, Истина); 
		ДокументОбъект.ТС = ТССсылка;
		
		Если НЕ ВариантПоставкиСТД
			И (СоздаватьВводВЭксплуатациюТС И ТССсылка.ПринадлежностьТС = Перечисления.уатПринадлежностьТС.Собственное) Тогда 
			НайтиСоздатьВводВЭксплуатациюТС(ТССсылка, мДатаВвода);
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(СтрокаТаблицы.Водитель) Тогда     
		ДокументОбъект.Водитель	 = ?(ДокументОбъект.ТС.ПринадлежностьТС = Перечисления.уатПринадлежностьТС.Собственное,
		НайтиСоздатьВодителя(
		"", 
		СтрокаТаблицы.Водитель, 
		"", 
		"", 
		"", 
		"", 
		"", 
		"", 
		0),
		НайтиСоздатьФизЛицо(СтрокаТаблицы.Водитель, СтрокаТаблицы.Водитель, "", "", "", ""));

		ДокументОбъект.ТребуетсяВодитель = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.ДатаВозвратаФакт) 
		И (ЗначениеЗаполнено(ДокументОбъект.Водитель) 
		ИЛИ ЗначениеЗаполнено(ДокументОбъект.ТС)) Тогда
		ДокументОбъект.Статус  = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Закрыт");
	КонецЕсли;
	
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		СчСоздано = СчСоздано + 1;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;

	Возврат ДокументОбъект.Ссылка;
	
КонецФункции


