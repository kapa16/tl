&НаСервере
Функция НайтиСоздатьВидЗакрытия(Наименование, Неуспешно)
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда 
		Возврат Справочники.уатПричиныЗакрытияЗаказов.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	уатПричиныЗакрытияЗаказов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатПричиныЗакрытияЗаказов КАК уатПричиныЗакрытияЗаказов
	|ГДЕ
	|	уатПричиныЗакрытияЗаказов.Наименование = &Наименование
	|	И НЕ уатПричиныЗакрытияЗаказов.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	ВидЗакрытияОбъект = Справочники.уатПричиныЗакрытияЗаказов.СоздатьЭлемент();
	ВидЗакрытияОбъект.Заполнить(Неопределено);
	ВидЗакрытияОбъект.Наименование  = Наименование; 
	ВидЗакрытияОбъект.ЗакрытУспешно = НЕ Неуспешно;
