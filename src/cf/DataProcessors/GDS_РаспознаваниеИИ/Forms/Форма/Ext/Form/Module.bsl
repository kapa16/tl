
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Обработка = РеквизитФормыВЗначение("Объект");
	Настройки = Обработка.ПолучитьНастройкиИИ();

	ДвухпроходноеРаспознавание = Настройки.ДвухпроходноеРаспознавание;
	БезПостобработки = Настройки.БезПостобработки;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Распознать(Команда)
	
	Начало = ТекущаяДата();
	РаспознатьНаСервере(); 
	Окончание = ТекущаяДата();
	
	ВремяРаботы = Дата(1, 1, 1) + (Окончание - Начало);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура РаспознатьНаСервере()
	
	Если Не ЗначениеЗаполнено(Ведомость) Тогда
		ВызватьИсключение НСтр("ru = 'Укажите ведомость для распознавания.'");
	КонецЕсли;
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Обработка.УстановитьНастройкиИИ(Новый Структура(
		"ДвухпроходноеРаспознавание, БезПостобработки",
		ДвухпроходноеРаспознавание,
		БезПостобработки));
	
	Если ЗаполнятьВедомость Тогда
		Результат = Обработка.РаспознатьИЗаполнитьВедомость(Ведомость);
	Иначе
		Результат = Обработка.РаспознатьВедомость(Ведомость);
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(Обработка, "Объект");
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатJSON = Результат.ДанныеJSON;
	ТекстПредупреждений = СформироватьТекстПредупреждений(Результат.Предупреждения);
	
	СвязиСтрокVLM = Неопределено;
	ДокументДляСводки = Неопределено;
	Если Результат.Свойство("Заполнение") Тогда
		Если Результат.Заполнение.Свойство("СвязиСтрокVLM") Тогда
			СвязиСтрокVLM = Результат.Заполнение.СвязиСтрокVLM;
		КонецЕсли;
		Если Результат.Заполнение.Свойство("ДокументОбъект") Тогда
			ДокументДляСводки = Результат.Заполнение.ДокументОбъект;
		КонецЕсли;
	КонецЕсли;
	
	ТаблицаВизуальногоКонтроля.Загрузить(Обработка.СформироватьТаблицуВизуальногоКонтроля(
		Результат.Данные,
		Ведомость,
		СвязиСтрокVLM));
	СводкаИтогов = Обработка.СформироватьСводкуВизуальногоКонтроля(
		Результат.Данные,
		Ведомость,
		СвязиСтрокVLM,
		ДокументДляСводки);
	ТекстСводкиИтогов = СводкаИтогов.ТекстСводки;
	
	Если ЗаполнятьВедомость Тогда
		Если Результат.ПредупреждениеЗаполнения Тогда
			ТекстПредупреждений = ТекстПредупреждений
				+ ?(ЗначениеЗаполнено(ТекстПредупреждений), Символы.ПС, "")
				+ НСтр("ru = 'Ведомость заполнена с предупреждениями.'");
		Иначе
			ТекстПредупреждений = ТекстПредупреждений
				+ ?(ЗначениеЗаполнено(ТекстПредупреждений), Символы.ПС, "")
				+ НСтр("ru = 'Ведомость заполнена и записана.'");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СформироватьТекстПредупреждений(Предупреждения)

	Если Предупреждения = Неопределено Или Предупреждения.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	Строки = Новый Массив;

	Для Каждого Предупреждение Из Предупреждения Цикл
		Строки.Добавить(СтрШаблон("[%1] %2: %3",
			Предупреждение.code,
			Предупреждение.field,
			Предупреждение.message));
	КонецЦикла;

	Возврат СтрСоединить(Строки, Символы.ПС);

КонецФункции

#КонецОбласти
