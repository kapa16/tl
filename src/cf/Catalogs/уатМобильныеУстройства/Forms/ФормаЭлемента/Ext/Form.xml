				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
    МАКСИМУМ(уатСтатусыМобильногоПриложения.Дата) КАК Дата,
    уатСтатусыМобильногоПриложения.МобильноеУстройство КАК МобильноеУстройство,
    уатСтатусыМобильногоПриложения.Водитель КАК Водитель,
    уатСтатусыМобильногоПриложения.ТС КАК ТС
ПОМЕСТИТЬ втДатаПоследнегоВыходаНаЛинию
ИЗ
    РегистрСведений.уатСтатусыМобильногоПриложения КАК уатСтатусыМобильногоПриложения
ГДЕ
    уатСтатусыМобильногоПриложения.МобильноеУстройство = &amp;МобильноеУстройство

СГРУППИРОВАТЬ ПО
    уатСтатусыМобильногоПриложения.МобильноеУстройство,
    уатСтатусыМобильногоПриложения.Водитель,
    уатСтатусыМобильногоПриложения.ТС
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
    уатПользователиМобильногоПриложения_ТС.Пользователь КАК Пользователь,
    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ уатПользователиМобильногоПриложения_ТС.ТС) КАК ТСКоличество
ПОМЕСТИТЬ втКолВоТС
ИЗ
    РегистрСведений.уатПользователиМобильногоПриложения_ТС КАК уатПользователиМобильногоПриложения_ТС

СГРУППИРОВАТЬ ПО
    уатПользователиМобильногоПриложения_ТС.Пользователь
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
    уатПользователиМобильногоПриложения_ТС.Пользователь КАК Пользователь,
    уатПользователиМобильногоПриложения_ТС.ТС КАК ТС
ПОМЕСТИТЬ втТСПользователей
ИЗ
    втКолВоТС КАК втКолВоТС
        ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.уатПользователиМобильногоПриложения_ТС КАК уатПользователиМобильногоПриложения_ТС
        ПО втКолВоТС.Пользователь = уатПользователиМобильногоПриложения_ТС.Пользователь
            И (ВЫБОР
                КОГДА втКолВоТС.ТСКоличество = 1
                    ТОГДА ИСТИНА
                ИНАЧЕ ЛОЖЬ
            КОНЕЦ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
    втДатаПоследнегоВыходаНаЛинию.Водитель КАК Водитель,
    втДатаПоследнегоВыходаНаЛинию.Дата КАК Дата,
    ВЫБОР
        КОГДА втДатаПоследнегоВыходаНаЛинию.ТС = ЗНАЧЕНИЕ(Справочник.уатТС.ПустаяСсылка)
            ТОГДА ЕСТЬNULL(втТСПользователей.ТС, ЗНАЧЕНИЕ(Справочник.уатТС.ПустаяСсылка))
        ИНАЧЕ втДатаПоследнегоВыходаНаЛинию.ТС
    КОНЕЦ КАК ТС
ПОМЕСТИТЬ втВодители
ИЗ
    втДатаПоследнегоВыходаНаЛинию КАК втДатаПоследнегоВыходаНаЛинию
        ЛЕВОЕ СОЕДИНЕНИЕ втТСПользователей КАК втТСПользователей
        ПО втДатаПоследнегоВыходаНаЛинию.Водитель = втТСПользователей.Пользователь
;

