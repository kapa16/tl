			<Attribute uuid="fcfc1de6-beb4-47b3-a3bd-7f04df99f6ff">
				<Properties>
					<Name>ВозможностьВозврата</Name>
					<Synonym>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Возможность возврата на склад</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Possibility of return to warehouse</v8:content>
						</v8:item>
					</Synonym>
