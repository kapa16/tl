	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникуатРежимыРаботыТС.Ссылка КАК Ссылка,
	СправочникуатРежимыРаботыТС.ПометкаУдаления КАК ПометкаУдаления,
	СправочникуатРежимыРаботыТС.Код КАК Код,
	СправочникуатРежимыРаботыТС.Наименование КАК Наименование,
	СправочникуатРежимыРаботыТС.НачалоРаботы КАК НачалоРаботы,
	СправочникуатРежимыРаботыТС.КонецРаботы КАК КонецРаботы,
	ВЫБОР
		КОГДА СправочникуатРежимыРаботыТС.КонецРаботы &gt; СправочникуатРежимыРаботыТС.НачалоРаботы
			ТОГДА ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), СЕКУНДА, РАЗНОСТЬДАТ(СправочникуатРежимыРаботыТС.НачалоРаботы, СправочникуатРежимыРаботыТС.КонецРаботы, СЕКУНДА))
		ИНАЧЕ ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), СЕКУНДА, РАЗНОСТЬДАТ(СправочникуатРежимыРаботыТС.НачалоРаботы, ДОБАВИТЬКДАТЕ(СправочникуатРежимыРаботыТС.КонецРаботы, СЕКУНДА, 24 * 3600), СЕКУНДА))
	КОНЕЦ КАК Продолжительность,
	СправочникуатРежимыРаботыТС.НачалоОбеда КАК НачалоОбеда,
	СправочникуатРежимыРаботыТС.КонецОбеда КАК КонецОбеда,
	СправочникуатРежимыРаботыТС.Обед КАК Обед,
	ВЫБОР
		КОГДА СправочникуатРежимыРаботыТС.Обед = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА "По интервалу"
		ИНАЧЕ "По продолжительности"
	КОНЕЦ КАК СпособРасчетаОбеда,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл
ИЗ
	Справочник.уатРежимыРаботыТС КАК СправочникуатРежимыРаботыТС
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО СправочникуатРежимыРаботыТС.Ссылка = НаличиеФайлов.ОбъектСФайлами</QueryText>
				<MainTable>Catalog.уатРежимыРаботыТС</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
