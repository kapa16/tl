		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Применение</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникуатТарифыЗП.Ссылка КАК Ссылка,
	СправочникуатТарифыЗП.ВерсияДанных КАК ВерсияДанных,
	СправочникуатТарифыЗП.ПометкаУдаления КАК ПометкаУдаления,
	СправочникуатТарифыЗП.Предопределенный КАК Предопределенный,
	СправочникуатТарифыЗП.Родитель КАК Родитель,
	СправочникуатТарифыЗП.ЭтоГруппа КАК ЭтоГруппа,
	СправочникуатТарифыЗП.Наименование КАК Наименование,
	СправочникуатТарифыЗП.ГруппировкаТарифа1 КАК ГруппировкаТарифа1,
	СправочникуатТарифыЗП.ГруппировкаТарифа2 КАК ГруппировкаТарифа2,
	СправочникуатТарифыЗП.ГруппировкаТарифа3 КАК ГруппировкаТарифа3,
	СправочникуатТарифыЗП.ВидНачисления КАК ВидНачисления,
	СправочникуатТарифыЗП.ПараметрВыработки КАК ПараметрВыработки,
	СправочникуатТарифыЗП.СложныйТариф КАК СложныйТариф,
	СправочникуатТарифыЗП.Тариф КАК Тариф,
	СправочникуатТарифыЗП.РасчетПоСтрокам КАК РасчетПоСтрокам,
	СправочникуатТарифыЗП.Применение КАК Применение,
	СправочникуатТарифыЗП.ТаблицаРасчета.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		ЗнакГруппировки1 КАК ЗнакГруппировки1,
		ЗнакГруппировки2 КАК ЗнакГруппировки2,
		ЗнакГруппировки3 КАК ЗнакГруппировки3,
		ЗначениеГруппировки1 КАК ЗначениеГруппировки1,
		ЗначениеГруппировки2 КАК ЗначениеГруппировки2,
		ЗначениеГруппировки3 КАК ЗначениеГруппировки3,
		Тариф КАК Тариф
	) КАК ТаблицаРасчета,
	СправочникуатТарифыЗП.ОбластиДействия.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		ВидОбластиДействия КАК ВидОбластиДействия,
		ЗначениеОбластиДействия КАК ЗначениеОбластиДействия
	) КАК ОбластиДействия,
	СправочникуатТарифыЗП.Организации.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		Организация КАК Организация
	) КАК Организации,
	ВЫБОР
		КОГДА СправочникуатТарифыЗП.ЭтоГруппа
			ТОГДА ""
		КОГДА СправочникуатТарифыЗП.Применение = 1
			ТОГДА "Маршрутные листы"
		КОГДА СправочникуатТарифыЗП.Применение = 2
			ТОГДА "Ремонтные листы"
		КОГДА СправочникуатТарифыЗП.Применение = 3
			ТОГДА "Премии"
		КОГДА СправочникуатТарифыЗП.Применение = 4
			ТОГДА "Удержания"
		КОГДА СправочникуатТарифыЗП.Применение = 5
			ТОГДА "Заказы такси"
		ИНАЧЕ "Путевые листы"
	КОНЕЦ КАК ПрименениеПредставление,
	ВЫБОР
		КОГДА СправочникуатТарифыЗП.Применение = 1
				И СправочникуатТарифыЗП.ВидНачисления.СпособРасчетаОплатыТруда = ЗНАЧЕНИЕ(Перечисление.уатСпособыРасчетаОплатыТруда.ПроцентомОтВыручки)
			ТОГДА ВЫБОР
					КОГДА СправочникуатТарифыЗП.ИсточникВыручки = 1
						ТОГДА "Маршрутный лист"
					ИНАЧЕ "Заказ на ТС"
				КОНЕЦ
		ИНАЧЕ ""
	КОНЕЦ КАК ИсточникВыручки,
	"" КАК ЯчейкаЕдиницаТарифа,
	ВЫБОР
