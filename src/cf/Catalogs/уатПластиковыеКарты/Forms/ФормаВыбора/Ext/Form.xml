			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
    СправочникуатПластиковыеКарты.Ссылка КАК Ссылка,
    СправочникуатПластиковыеКарты.ПометкаУдаления КАК ПометкаУдаления,
    СправочникуатПластиковыеКарты.Код КАК Код,
    СправочникуатПластиковыеКарты.КомуВыдана КАК КомуВыдана,
    СправочникуатПластиковыеКарты.КемВыдана КАК КемВыдана,
    СправочникуатПластиковыеКарты.Статус КАК Статус,
    СправочникуатПластиковыеКарты.Основная КАК Основная,
    СправочникуатПластиковыеКарты.Предопределенный КАК Предопределенный,
    СправочникуатПластиковыеКарты.КомуВыдана.Наименование КАК КомуВыданаПредставление,
    СправочникуатПластиковыеКарты.ДатаОкончания КАК ДатаОкончания,
    СправочникуатПластиковыеКарты.ПинКод КАК ПинКод,
    ВЫБОР
        КОГДА СправочникуатПластиковыеКарты.Статус.Действует &lt;&gt; Ложь
                И СправочникуатПластиковыеКарты.ДатаОкончания &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
            ТОГДА ВЫБОР
                    КОГДА СправочникуатПластиковыеКарты.ДатаОкончания &lt;= ДОБАВИТЬКДАТЕ(&amp;ТекущаяДата, ДЕНЬ, 1 * &amp;ДниДоОкончанияДействияТопливныхКарт) 
                        ТОГДА ИСТИНА
                    ИНАЧЕ ЛОЖЬ
                КОНЕЦ
        ИНАЧЕ ЛОЖЬ
    КОНЕЦ КАК ТКПросрочена,
    СправочникуатПластиковыеКарты.Код + " (" + "__СОСТОЯНИЕ_НЕДЕЙСТВУЕТ_" + ")" КАК ТекстНеДействует,
    СправочникуатПластиковыеКарты.Статус.Действует КАК СтатусДействует
ИЗ
    Справочник.уатПластиковыеКарты КАК СправочникуатПластиковыеКарты
ГДЕ
    ВЫБОР
            КОГДА СправочникуатПластиковыеКарты.ДатаОкончания &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
                ТОГДА СправочникуатПластиковыеКарты.ДатаОкончания &gt;= &amp;ДатаОкончания
            ИНАЧЕ ИСТИНА
        КОНЕЦ</QueryText>
