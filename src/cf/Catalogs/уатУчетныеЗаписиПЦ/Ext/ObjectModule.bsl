
#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	Если СохранятьОтчетВКаталог тогда
		ПроверяемыеРеквизиты.Добавить("КаталогФайлаДанных");
	КонецЕсли;
	
	Если ВнешняяСистема = Справочники.уатВнешниеСистемы.Газпромнефть Тогда
		ПроверяемыеРеквизиты.Добавить("КлючАвторизации");
		ПроверяемыеРеквизиты.Добавить("Пароль");
	ИначеЕсли ВнешняяСистема = Справочники.уатВнешниеСистемы.ППР Тогда
		Если Версия = 2 Тогда  
			ПроверяемыеРеквизиты.Добавить("КлючАвторизации");
			ПроверяемыеРеквизиты.Добавить("ИдентификаторКлиента");
		Иначе
			ПроверяемыеРеквизиты.Добавить("КлючАвторизации");
		КонецЕсли;
	ИначеЕсли ВнешняяСистема = Справочники.уатВнешниеСистемы.ЛукойлЛИКАРД Тогда
		Если ЗначениеЗаполнено(SSLСертификат.Получить()) Тогда
			ПроверяемыеРеквизиты.Добавить("Пароль");
			ПроверяемыеРеквизиты.Добавить("IDКонтракта");
		КонецЕсли;
	ИначеЕсли ВнешняяСистема = Справочники.уатВнешниеСистемы.Роснефть Тогда
		ПроверяемыеРеквизиты.Добавить("Пароль");
		ПроверяемыеРеквизиты.Добавить("IDКонтракта");
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования) 
	ВнутреннийКлючИнтеграции = "";
	ВнутреннийХешИнтеграции  = 0;
КонецПроцедуры

#КонецОбласти


