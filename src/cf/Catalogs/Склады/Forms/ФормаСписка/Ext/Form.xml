				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникСклады.Ссылка КАК Ссылка,
	СправочникСклады.ПометкаУдаления КАК ПометкаУдаления,
	СправочникСклады.Родитель КАК Родитель,
	СправочникСклады.ЭтоГруппа КАК ЭтоГруппа,
	СправочникСклады.Код КАК Код,
	СправочникСклады.Наименование КАК Наименование,
	СправочникСклады.Комментарий КАК Комментарий,
	СправочникСклады.ВидСклада КАК ВидСклада,
	уатАдресаСкладов.Адрес КАК Адрес,
	СправочникСклады.КонтактноеЛицо КАК КонтактноеЛицо,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ НаличиеФайлов.ЕстьФайлы
	КОНЕЦ КАК ПрисоединенныйФайл,
	СправочникСклады.АдресноеХранение КАК АдресноеХранение,
	СправочникСклады.ТранзитнаяЯчейка КАК ТранзитнаяЯчейка,
	СправочникСклады.СкладСнабжения КАК СкладСнабжения
ИЗ
	Справочник.Склады КАК СправочникСклады
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатАдресаСкладов_уэ КАК уатАдресаСкладов
		ПО СправочникСклады.Ссылка = уатАдресаСкладов.Склад
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО СправочникСклады.Ссылка = НаличиеФайлов.ОбъектСФайлами</QueryText>
				<MainTable>Catalog.Склады</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
