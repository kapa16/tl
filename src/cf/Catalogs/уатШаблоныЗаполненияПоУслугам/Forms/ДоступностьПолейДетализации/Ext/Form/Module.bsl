
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Макет = Справочники.уатШаблоныЗаполненияПоУслугам.ПолучитьМакет("ПоляДетализации");
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиПРОФ() Тогда
		ОбластьШапка  = Макет.ПолучитьОбласть("Шапка|НаПечатьПРОФ");
		ОбластьДанные = Макет.ПолучитьОбласть("Строки|НаПечатьПРОФ");
	ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ОбластьШапка  = Макет.ПолучитьОбласть("Шапка|НаПечатьКОРП");
		ОбластьДанные = Макет.ПолучитьОбласть("Строки|НаПечатьКОРП");
	ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси() Тогда
		ОбластьШапка  = Макет.ПолучитьОбласть("Шапка|НаПечатьТакси");
		ОбластьДанные = Макет.ПолучитьОбласть("Строки|НаПечатьТакси");
	Иначе
		ОбластьШапка  = Макет.ПолучитьОбласть("Шапка|НаПечать");
		ОбластьДанные = Макет.ПолучитьОбласть("Строки|НаПечать");
	КонецЕсли;
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиПРОФ() ИЛИ уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		ОбластьЗаголовокДокументы = ОбластьШапка.Область(1, 2, 1, ОбластьШапка.ШиринаТаблицы);
		ОбластьЗаголовокДокументы.Объединить();
		ОбластьЗаголовокДокументы.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
	КонецЕсли;
	ТабДокумент.Вывести(ОбластьШапка);
	
	// Не выводятся строки, в которых во всех колонках стоит "Нет"
	Для Сч = 1 По ОбластьДанные.ВысотаТаблицы Цикл
		флЕстьДа = Ложь;
		Для СчКол = 2 По ОбластьДанные.ШиринаТаблицы Цикл
			ТекОбласть = ОбластьДанные.Область(Сч, СчКол, Сч, СчКол);
			флЕстьДа = (СтрНайти(ТекОбласть.Текст, "Да") <> 0);
			Если флЕстьДа Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если НЕ флЕстьДа Тогда
			Продолжить;
		КонецЕсли;
		
		ОбластьСтрока = ОбластьДанные.ПолучитьОбласть(Сч, ,Сч, );
		
		ТабДокумент.Вывести(ОбластьСтрока);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
