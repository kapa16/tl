
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	уатЗащищенныеФункцииСервер.уатСправочникФормаСпискаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ДопПараметрыОткрытие);
	Если Отказ тогда
		Возврат;
	КонецЕсли;
	Элементы.ФормаЗаполнитьПоГНГ.Доступность = ПолучитьФункциональнуюОпцию("уатИспользоватьЖДПеревозки");
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	уатЗащищенныеФункцииКлиент.уатСправочникФормаСпискаПриОткрытии(Отказ, ДопПараметрыОткрытие);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьПоКлассификатору(Команда)
	ЗаполнитьПоКлассификаторуНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПоКлассификаторуНаСервере()
	Макет = Справочники.уатКодыГНГ.ПолучитьМакет("КлассификаторыГНГ");
	
	ТабЗначений = Новый ТаблицаЗначений;
	
	ПоследняяСтрока = Макет.ВысотаТаблицы;
	ПоследняяКолонка = Макет.ШиринаТаблицы;
	
	ОбластьЯчеек = Макет.Область(1, 1, ПоследняяСтрока, ПоследняяКолонка); 
	ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);  
	ПостроительОтчета = Новый ПостроительОтчета; 
	ПостроительОтчета.ИсточникДанных = ИсточникДанных;
	ПостроительОтчета.Выполнить();
	
	ТабЗначений = ПостроительОтчета.Результат.Выгрузить();
	
	Запрос = Новый Запрос;

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КодыГНГ.Код КАК Код
	|ИЗ
	|	Справочник.уатКодыГНГ КАК КодыГНГ
	|ГДЕ
	|	НЕ КодыГНГ.ПометкаУдаления";
	Выгрузка = Запрос.Выполнить().Выгрузить();
	
	Для каждого Строка Из ТабЗначений Цикл
		Если Выгрузка.Найти(Строка.КодГНГ, "Код") = Неопределено Тогда
			НовыйГНГ = Справочники.уатКодыГНГ.СоздатьЭлемент();
			НовыйГНГ.Заполнить(Неопределено);
			НовыйГНГ.Код = Строка.КодГНГ;
			НовыйГНГ.Наименование = Строка.НаименованиеГрузаПоГНГ;
			НовыйГНГ.Записать();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти