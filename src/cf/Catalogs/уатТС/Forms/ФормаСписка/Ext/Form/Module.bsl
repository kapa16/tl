КонецПроцедуры

&НаКлиенте
Процедура ПанельДопИнформацииПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	уатОбщегоНазначенияКлиент.ПанельДопИнформацииПоТСПриНажатии(
		ЭтотОбъект, 
		Элемент, 
		ДанныеСобытия, 
		СтандартнаяОбработка,
		ТекущаяСтрока
	);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьВыбывшиеПриИзменении(Элемент)
	УстановитьОтборВыбывшие();
	СохранитьНастройки();
КонецПроцедуры

&НаКлиенте
Процедура ЕстьПросроченныеДокументыОтборПриИзменении(Элемент)
	УстановитьОтборПросроченныеДокументы();
	СохранитьНастройки();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ПодключитьОбработчикОжидания("Подключаемый_СписокПриАктивизацииСтроки", 0.2, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.ПросроченныеДокументы И ВыбраннаяСтрока <> Неопределено Тогда
		СтандартнаяОбработка = Ложь;
		
		Отбор = Новый Структура("ВладелецДокументов, ПринадлежностьДокументов", ВыбраннаяСтрока,
			ПредопределенноеЗначение("Перечисление.уатПринадлежностьДокументов.ДокументыТС"));
		ПараметрыФормы = Новый Структура("Отбор", Отбор);
		
		ОткрытьФорму("Справочник.уатРегистрационныеДокументы.ФормаСписка", ПараметрыФормы, Элемент);
		
	ИначеЕсли Поле = Элементы.ТО И ВыбраннаяСтрока <> Неопределено Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("Отбор",                   Новый Структура("ТС", ВыбраннаяСтрока));
		ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
		ОткрытьФорму("Отчет.уатПриближениеСроковТО.Форма", ПараметрыФормы, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	КлючиСтрок = Строки.ПолучитьКлючи();
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ уатТСОбязательныеВидыДокументов.ВидДокумента) КАК КоличествоНеобходимых,
	|	уатТСОбязательныеВидыДокументов.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ втКоличествоНеобходимых
	|ИЗ
	|	Справочник.уатТС.ОбязательныеВидыДокументов КАК уатТСОбязательныеВидыДокументов
	|ГДЕ
	|	уатТСОбязательныеВидыДокументов.Принадлежность = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьДокументов.ДокументыТС)
	|
	|СГРУППИРОВАТЬ ПО
	|	уатТСОбязательныеВидыДокументов.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатТСОбязательныеВидыДокументов.Ссылка КАК Ссылка,
	|	уатТСОбязательныеВидыДокументов.Принадлежность КАК Принадлежность,
	|	уатТСОбязательныеВидыДокументов.ВидДокумента КАК ВидДокумента,
	|	втКоличествоНеобходимых.КоличествоНеобходимых КАК КоличествоНеобходимых
	|ПОМЕСТИТЬ втНеобходимыеДоки
	|ИЗ
	|	Справочник.уатТС.ОбязательныеВидыДокументов КАК уатТСОбязательныеВидыДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКоличествоНеобходимых КАК втКоличествоНеобходимых
	|		ПО уатТСОбязательныеВидыДокументов.Ссылка = втКоличествоНеобходимых.Ссылка
	|ГДЕ
	|	уатТСОбязательныеВидыДокументов.Принадлежность = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьДокументов.ДокументыТС)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатРегистрационныеДокументы.ВидДокумента КАК ВидДокумента,
	|	уатРегистрационныеДокументы.ВладелецДокументов КАК ВладелецДокументов,
	|	уатРегистрационныеДокументы.ПринадлежностьДокументов КАК ПринадлежностьДокументов
	|ПОМЕСТИТЬ втЗакрепленныеДоки
	|ИЗ
	|	Справочник.уатРегистрационныеДокументы КАК уатРегистрационныеДокументы
	|ГДЕ
	|	уатРегистрационныеДокументы.ПринадлежностьДокументов = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьДокументов.ДокументыТС)
	|	И НЕ уатРегистрационныеДокументы.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	уатРегистрационныеДокументы.ВладелецДокументов,
	|	уатРегистрационныеДокументы.ПринадлежностьДокументов,
	|	уатРегистрационныеДокументы.ВидДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втНеобходимыеДоки.ВидДокумента КАК ВидДокумента,
	|	втНеобходимыеДоки.Ссылка КАК Ссылка,
	|	втЗакрепленныеДоки.ВидДокумента КАК ВидДокумента1,
	|	втЗакрепленныеДоки.ВладелецДокументов КАК ВладелецДокументов,
	|	ВЫБОР
	|		КОГДА втНеобходимыеДоки.ВидДокумента = втЗакрепленныеДоки.ВидДокумента
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Совпадения,
	|	втНеобходимыеДоки.КоличествоНеобходимых КАК КоличествоНеобходимых
	|ПОМЕСТИТЬ втПересечениеДоков
	|ИЗ
	|	втНеобходимыеДоки КАК втНеобходимыеДоки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЗакрепленныеДоки КАК втЗакрепленныеДоки
	|		ПО втНеобходимыеДоки.Ссылка = втЗакрепленныеДоки.ВладелецДокументов
	|			И втНеобходимыеДоки.ВидДокумента = втЗакрепленныеДоки.ВидДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатТС.Ссылка КАК ТС,
	|	СУММА(втПересечениеДоков.Совпадения) КАК Совпадения,
	|	втПересечениеДоков.КоличествоНеобходимых КАК КоличествоНеобходимых
	|ПОМЕСТИТЬ втСуммаСовпадений
	|ИЗ
	|	Справочник.уатТС КАК уатТС
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПересечениеДоков КАК втПересечениеДоков
	|		ПО уатТС.Ссылка = втПересечениеДоков.Ссылка
	|ГДЕ
	|	уатТС.Ссылка В(&мсвТС)
	|
	|СГРУППИРОВАТЬ ПО
	|	уатТС.Ссылка,
	|	втПересечениеДоков.КоличествоНеобходимых
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	уатДокументыТС.ВладелецДокументов КАК ТС
	|ПОМЕСТИТЬ втПросроченныеДокументы
	|ИЗ
	|	Справочник.уатРегистрационныеДокументы КАК уатДокументыТС
	|ГДЕ
	|	уатДокументыТС.ПринадлежностьДокументов = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьДокументов.ДокументыТС)
	|	И уатДокументыТС.Статус <> ЗНАЧЕНИЕ(Перечисление.уатСтатусыдействия.НеДействует)
	|	И уатДокументыТС.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|	И уатДокументыТС.ДатаОкончания <= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, 1 * &ДниДоОкончанияДействияДокументовТС)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	уатПластиковыеКарты.КомуВыдана
	|ИЗ
	|	Справочник.уатПластиковыеКарты КАК уатПластиковыеКарты
	|ГДЕ
	|	уатПластиковыеКарты.Статус.Действует <> ЛОЖЬ
	|	И уатПластиковыеКарты.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|	И уатПластиковыеКарты.ДатаОкончания <= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, 1 * &ДниДоОкончанияДействияТопливныхКарт)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатТС.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА КОЛИЧЕСТВО(втПросроченныеДокументы.ТС) > 0
	|				ИЛИ втСуммаСовпадений.КоличествоНеобходимых > втСуммаСовпадений.Совпадения
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ЕстьПросроченныеДокументы
	|ИЗ
	|	Справочник.уатТС КАК уатТС
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПросроченныеДокументы КАК втПросроченныеДокументы
	|		ПО уатТС.Ссылка = втПросроченныеДокументы.ТС
	|		ЛЕВОЕ СОЕДИНЕНИЕ втСуммаСовпадений КАК втСуммаСовпадений
	|		ПО уатТС.Ссылка = втСуммаСовпадений.ТС
	|ГДЕ
	|	уатТС.Ссылка В(&мсвТС)
	|
	|СГРУППИРОВАТЬ ПО
	|	уатТС.Ссылка,
	|	втСуммаСовпадений.КоличествоНеобходимых,
	|	втСуммаСовпадений.Совпадения";
	
	ТекПользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	мВремяДоОкончанияДействияДокументовТС = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
		уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ТекПользователь, "ОсновнаяОрганизация"),
		ПредопределенноеЗначение("ПланВидовХарактеристик.уатПраваИНастройки.ДниДоОкончанияДействияДокументовТС"));
	мВремяДоОкончанияДействияТопливныхКарт = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
		уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ТекПользователь, "ОсновнаяОрганизация"),
		ПредопределенноеЗначение("ПланВидовХарактеристик.уатПраваИНастройки.ДниДоОкончанияДействияТопливныхКарт"));
	Запрос.УстановитьПараметр("мсвТС", КлючиСтрок);
	Запрос.УстановитьПараметр("ДниДоОкончанияДействияДокументовТС", мВремяДоОкончанияДействияДокументовТС);
	Запрос.УстановитьПараметр("ДниДоОкончанияДействияТопливныхКарт", мВремяДоОкончанияДействияТопливныхКарт);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	ВыборкаТС = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаТС.Следующий() Цикл
		СтрокаСписка        = Строки[ВыборкаТС.Ссылка];
		ДанныеСтрокаСписка  = СтрокаСписка.Данные;
		Если ДанныеСтрокаСписка.Свойство("ПросроченныеДокументы") Тогда
			ДанныеСтрокаСписка.ПросроченныеДокументы = ВыборкаТС.ЕстьПросроченныеДокументы;
		Иначе
			Возврат;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

