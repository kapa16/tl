&НаСервереБезКонтекста
Функция СоздатьНайтиМодельЖДТранспорта(НаименованиеМодели)
	
	Если ПустаяСтрока(НаименованиеМодели) Тогда
		ТекстНСтр = НСтр("ru='Не заполнено значение модели'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Справочники.уатМоделиТС.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	уатМоделиТС.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатМоделиТС КАК уатМоделиТС
	|ГДЕ
	|	НЕ уатМоделиТС.ПометкаУдаления
	|	И уатМоделиТС.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", НаименованиеМодели);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ТекстНСтр = НСтр("ru='Была найдена модель: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", Выборка.Ссылка.Наименование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	МодельЖД = Справочники.уатМоделиТС.СоздатьЭлемент();
	МодельЖД.Наименование = НаименованиеМодели;
	МодельЖД.ВидМоделиТС = Перечисления.уатВидыМоделейТС.ЖДТранспорт;
	
	Попытка
		МодельЖД.Записать();
		ТекстНСтр = НСтр("ru='Была создана модель: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", НаименованиеМодели);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат МодельЖД.Ссылка;
	Исключение
		ТекстНСтр = НСтр("ru='Ошибка при записи элемента справочника модели ТС: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", НаименованиеМодели);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаСервереБезКонтекста
Функция СоздатьНайтиТипТСЖДТранспорта(РодВагонаНаименование)
	
	Если ПустаяСтрока(РодВагонаНаименование) Тогда
		ТекстНСтр = НСтр("ru='Не заполнено значение классификатора родов подвижного состава'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Справочники.уатТипыТС.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	уатКлассификаторРодовПодвижногоСостава.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатКлассификаторРодовПодвижногоСостава КАК уатКлассификаторРодовПодвижногоСостава
	|ГДЕ
	|	НЕ уатКлассификаторРодовПодвижногоСостава.ПометкаУдаления
	|	И уатКлассификаторРодовПодвижногоСостава.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", РодВагонаНаименование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ТекстНСтр = НСтр("ru='Был найден классификатор родов подвижного состава: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", Выборка.Ссылка.Наименование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		РодВагона = Выборка.Ссылка;
	Иначе
		РодВагонаОбъект = Справочники.уатКлассификаторРодовПодвижногоСостава.СоздатьЭлемент();
		РодВагонаОбъект.Наименование = РодВагонаНаименование;
		Попытка
			РодВагонаОбъект.Записать();
			ТекстНСтр = НСтр("ru='Был создан классификатор родов подвижного состава: %1'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", РодВагонаНаименование);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			РодВагона = РодВагонаОбъект.Ссылка;
		Исключение
			ТекстНСтр = НСтр("ru='Ошибка при записи элемента справочника Классификатор родов подвижного состава %1'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", РодВагонаНаименование);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			Возврат Неопределено
		КонецПопытки;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	уатТипыТС.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.уатТипыТС КАК уатТипыТС
	|ГДЕ
	|	НЕ уатТипыТС.ПометкаУдаления
	|	И уатТипыТС.РодВагона = &РодВагона";
	Запрос.УстановитьПараметр("РодВагона", РодВагона);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ТекстНСтр = НСтр("ru='Был найден тип ТС: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", Выборка.Ссылка.Наименование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Выборка.Ссылка;
	Иначе
		ТипТСОбъект = Справочники.уатТипыТС.СоздатьЭлемент();
		ТипТСОбъект.Наименование = РодВагонаНаименование;
		ТипТСОбъект.ВидТС = Перечисления.уатВидыТС.Вагон;
		ТипТСОбъект.РодВагона = РодВагона;
		Попытка
			ТипТСОбъект.Записать();
			ТекстНСтр = НСтр("ru='Был создан тип ТС: %1'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", РодВагонаНаименование);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			Возврат ТипТСОбъект.Ссылка;
		Исключение
			ТекстНСтр = НСтр("ru='Ошибка при записи элемента справочника Тип ТС %1'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", РодВагонаНаименование);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			Возврат Неопределено
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция НайтиВладельцаПоНаименованию(ВладелецТСНаименование)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Наименование = &Наименование
	|	И НЕ Контрагенты.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", ВладелецТСНаименование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ТекстНСтр = НСтр("ru='Был найден владелец ТС: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ВладелецТСНаименование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Выборка.Ссылка;
	Иначе
		ТекстНСтр = НСтр("ru='Не был найден владелец ТС: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ВладелецТСНаименование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция СопоставитьТипВладенияЖДТС(ТипВладенияЖДТСНаменование)
	Если ПустаяСтрока(ТипВладенияЖДТСНаменование) Тогда
		ТекстНСтр = НСтр("ru='Не заполнен тип владения вагоном'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Перечисления.уатТипыВладенияЖДТС.ПустаяСсылка();
	КонецЕсли;
	Если ТипВладенияЖДТСНаменование = "Собственный" Тогда
		Возврат Перечисления.уатТипыВладенияЖДТС.Собственный;
	ИначеЕсли ТипВладенияЖДТСНаменование = "Арендованный" Тогда
		Возврат Перечисления.уатТипыВладенияЖДТС.Арендованный;
	ИначеЕсли ТипВладенияЖДТСНаменование = "Принадлежат перевозчику" Тогда 
		Возврат Перечисления.уатТипыВладенияЖДТС.ПринадлежатПеревозчику;
	Иначе
		ТекстНСтр = НСтр("ru='Не найден тип владения вагоном: %1'");
		ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", ТипВладенияЖДТСНаменование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
		Возврат Перечисления.уатТипыВладенияЖДТС.ПустаяСсылка();
	КонецЕсли;
КонецФункции

#КонецОбласти
