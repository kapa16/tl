
#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если НЕ ЭтоГруппа Тогда
		Если СоздаватьДокументыГСМ Тогда
			ПроверяемыеРеквизиты.Добавить("ПрофильОбмена");
			ПроверяемыеРеквизиты.Добавить("Ответственный");
			
			СоздаватьЗаправкиГСМ = ПрофильОбмена.РежимОбработкиЗаправок <> 1; // Пропускать строки
			Если СоздаватьЗаправкиГСМ Тогда 
				ПроверяемыеРеквизиты.Добавить("АЗС");
				ПроверяемыеРеквизиты.Добавить("ВидЗаправки");
			КонецЕсли; 
			СоздаватьСливыГСМ = ПрофильОбмена.РежимОбработкиСливов <> 3; // Пропускать строки
			Если СоздаватьСливыГСМ Тогда    
				ПроверяемыеРеквизиты.Добавить("АЗССлив");
				ПроверяемыеРеквизиты.Добавить("ВидСлива");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования) 
	ВнутреннийКлючИнтеграции = "";
	ВнутреннийХешИнтеграции  = 0;
КонецПроцедуры

#КонецОбласти 
