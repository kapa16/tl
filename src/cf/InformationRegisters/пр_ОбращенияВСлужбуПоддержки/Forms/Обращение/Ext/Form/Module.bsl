#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Регистрируем событие
	Если ПустаяСтрока(Запись.Идентификатор) Тогда
		пр_ПоддержкаОтраслевыхРешений.ЗаписатьОперациюБизнесСтатистики("ПоддержкаОтраслевыхРешений.Обращение.Создание");
	Иначе
		пр_ПоддержкаОтраслевыхРешений.ЗаписатьОперациюБизнесСтатистики("ПоддержкаОтраслевыхРешений.Обращение.Открытие");
	КонецЕсли;
	
	// Инициализируем новый объект
	Если ПустаяСтрока(Запись.Идентификатор) Тогда
		
		// Определим ключевые параметры обращения
		Запись.ДатаОбращения = ТекущаяДатаСеанса();
		Параметры.Свойство("ВидОбращения", Запись.ВидОбращения);
		
		// Попытаемся заполнить информацию о пользователе
		Запись.Пользователь = Пользователи.ТекущийПользователь();
		ПользовательПриИзмененииНаСервере();
		
	КонецЕсли;
	
	// Вызываем переопределяемый обработчик события
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка, РеквизитФормыВЗначение("Запись").Прикрепления);
	
	// Проверим состояние подсистемы обращений
	ОбновитьГруппуОписанияОшибки();
	
	// Обновим информацию о прикрепленных файлах
	ЭтотОбъект.РазмерФайловМаксимум = РегистрыСведений.пр_ОбращенияВСлужбуПоддержки.МаксимальныйРазмерПрикрепленийДляОбращения();
	ОбновитьНадписьРазмераФайла(ЭтотОбъект.Элементы.РазмерФайлов, ЭтотОбъект.РазмерФайловСумма, ЭтотОбъект.РазмерФайловМаксимум);
	
	НастроитьФормуПоВидуОбращения();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	УстановитьЗаголовокФормы();
	
	Для каждого УдаляемаяГруппа Из ЭтотОбъект.Элементы.Файлы.ПодчиненныеЭлементы Цикл
		Для каждого УдаляемыйЭлемент Из УдаляемаяГруппа.ПодчиненныеЭлементы Цикл
			ЭтотОбъект.Элементы.Удалить(УдаляемыйЭлемент);
		КонецЦикла;
		ЭтотОбъект.Элементы.Удалить(УдаляемаяГруппа);
	КонецЦикла;
	
	ЭтотОбъект.РазмерФайловСумма = 0;
	ЭтотОбъект.Файлы.Очистить();
	
	Прикрепления = ТекущийОбъект.Прикрепления.Получить();
	
	Если ТипЗнч(Прикрепления)<>Тип("Массив") ИЛИ Прикрепления.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого ОписаниеФайла Из Прикрепления Цикл
		
		Если ТипЗнч(ОписаниеФайла)<>Тип("Структура") Или (ТипЗнч(ОписаниеФайла) = Тип("Структура") И Не ОписаниеФайла.Свойство("ИмяФайла")) Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавитьФайлНаСервере(ОписаниеФайла.ИмяФайла, ОписаниеФайла.Размер,, ОписаниеФайла.Данные);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Финальная проверка, что выполнены все условия для отправки статистики
	Если ЭтотОбъект.КодОшибки<>0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Отправка обращения невозможна. Не выполнены все условия.'"),,,, Отказ);
		Возврат;
	КонецЕсли;
	
	Если Не Запись.СогласиеОтправитьСведенияОПродукте Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Необходимо дать согласие на обработку персональных данных.'"),,
			"Запись.СогласиеОтправитьСведенияОПродукте",, Отказ);
		Возврат;
	КонецЕсли;
	
	// Инициализируем идентификатор обращения
	Если ПустаяСтрока(ТекущийОбъект.Идентификатор) Тогда
		ТекущийОбъект.Идентификатор = Строка(Новый УникальныйИдентификатор());
	КонецЕсли;
	
	// Добавление прикрепленных файлов
	Прикрепления = Новый Массив();
	
	Для каждого Файл Из ЭтотОбъект.Файлы Цикл
		
		ОписаниеФайла = Новый Структура("ИмяФайла,Размер,Данные");
		ОписаниеФайла.ИмяФайла = Файл.ИмяФайла;
		ОписаниеФайла.Данные   = ПолучитьИзВременногоХранилища(Файл.Адрес);
		ОписаниеФайла.Размер   = Файл.Размер;
		
		Если Файл.Размер > 0 Тогда
			Прикрепления.Добавить(ОписаниеФайла);
		КонецЕсли;
		
	КонецЦикла;
	
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.ПередЗаписьюНаСервере(ЭтотОбъект, Прикрепления);
	
	ТекущийОбъект.Прикрепления = Новый ХранилищеЗначения(Прикрепления, Новый СжатиеДанных(9));
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// Оперативную отправку выполняем только если номер еще не присвоен
	Если НЕ ПустаяСтрока(ТекущийОбъект.НомерОбращения) ИЛИ ЭтотОбъект.КодОшибки<>0 Тогда
		Возврат;
	КонецЕсли;
	
	// Регистрируем событие
	пр_ПоддержкаОтраслевыхРешений.ЗаписатьОперациюБизнесСтатистики("ПоддержкаОтраслевыхРешений.Обращение.Запись");
	
	// Вызываем обработчик сбора статистики с клиента
	пр_ПоддержкаОтраслевыхРешений.ОбновитьПараметрыПоДаннымСеанса(ИСТИНА);
	
	// Подготовим систему к непосредственной отправке обращения
	ПараметрыЦентраМониторинга = Новый Структура();
	ПараметрыЦентраМониторинга.Вставить("ОзнакомительныйПакетОтправлен", ЛОЖЬ);
	ПараметрыЦентраМониторинга.Вставить("ЗапросКонтактнойИнформации",    1);
	ПараметрыЦентраМониторинга.Вставить("КонтактнаяИнформацияИзменена",  ИСТИНА);
	
	УстановитьПривилегированныйРежим(Истина);
	ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	УстановитьПривилегированныйРежим(Ложь);
	
	// Получим идентификатор информационной базы.
	ЦентрМониторингаСлужебный.ЗапускОтправкиОзнакомительногоПакета();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаСервере
Процедура ПользовательПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Запись.Пользователь) Тогда
		Возврат;
	КонецЕсли;
	
	// подтягивание контактных данных из справочника
	Если НЕ ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		Возврат;
	КонецЕсли;
	
	МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
	Если НЕ МодульУправлениеКонтактнойИнформацией.СодержитКонтактнуюИнформацию(Запись.Пользователь) Тогда
		Возврат;
	КонецЕсли;
	
	ВидЭлектроннаяПочта = МодульУправлениеКонтактнойИнформацией.ВидКонтактнойИнформацииПоИмени("EmailПользователя");
	ВидТелефон          = МодульУправлениеКонтактнойИнформацией.ВидКонтактнойИнформацииПоИмени("ТелефонПользователя");
	
	Запись.ЭлектроннаяПочта = МодульУправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Запись.Пользователь, ВидЭлектроннаяПочта);
	Запись.Телефон          = МодульУправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Запись.Пользователь, ВидТелефон);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользовательПриИзменении(Элемент)
	
	ПользовательПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОбращенияПриИзменении(Элемент)
	НастроитьФормуПоВидуОбращения();
КонецПроцедуры

&НаКлиенте
Процедура ТемаПриИзменении(Элемент)
	НастроитьФормуПоВидуОбращения();
КонецПроцедуры

