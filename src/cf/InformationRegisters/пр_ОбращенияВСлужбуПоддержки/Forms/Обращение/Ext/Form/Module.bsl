#КонецОбласти

#Область ОбработчикиКомандФормы

&НаСервере
Процедура ДобавитьФайлНаСервере(ИмяФайла, Размер, Адрес=Неопределено, Данные=Неопределено)
	
	Если Данные<>Неопределено Тогда
		Адрес = ПоместитьВоВременноеХранилище(Данные, ЭтотОбъект.УникальныйИдентификатор);
	КонецЕсли;
	
	Файл = ЭтотОбъект.Файлы.Добавить();
	Файл.ИмяФайла  = ИмяФайла;
	Файл.Размер    = Размер;
	Файл.Адрес     = Адрес;
	
	ЭтотОбъект.РазмерФайловСумма = ЭтотОбъект.РазмерФайловСумма + Размер;
	
	// Создаем элементы управления
	НомерФайла = ЭтотОбъект.Файлы.Количество();
	Суффикс = "Файл"+Формат(НомерФайла, "ЧДЦ=0; ЧН=0; ЧГ=0");
	
	// Создаем группу для текущего файла
	ГруппаФайла = ЭтотОбъект.Элементы.Добавить("Группа"+Суффикс, Тип("ГруппаФормы"), ЭтотОбъект.Элементы.Файлы);
	ГруппаФайла.Вид                  = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФайла.ЦветФона             = Новый Цвет(218, 240, 249);
	ГруппаФайла.ОтображатьЗаголовок  = Ложь;
	
	// Создаем кнопку открытия
	ОткрытьФайл = ЭтотОбъект.Элементы.Добавить("Открыть"+Суффикс, Тип("КнопкаФормы"), ГруппаФайла);
	ОткрытьФайл.ИмяКоманды           = "ОткрытьФайл";
	ОткрытьФайл.Вид                  = ВидКнопкиФормы.Гиперссылка;
	ОткрытьФайл.Заголовок            = Файл.ИмяФайла + "("+НадписьРазмераФайла(Размер)+")";
	ОткрытьФайл.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	
	// Создаем кнопку удаления
	УдалитьФайл = ЭтотОбъект.Элементы.Добавить("Удалить"+Суффикс, Тип("КнопкаФормы"), ГруппаФайла);
	УдалитьФайл.ИмяКоманды           = "УдалитьФайл";
	УдалитьФайл.Вид                  = ВидКнопкиФормы.Гиперссылка;
	
	Файл.ИмяГруппы = ГруппаФайла.Имя;
	
КонецПроцедуры // ДобавитьФайлНаСервере()

&НаКлиенте
Асинх Процедура ДобавитьФайл(Команда)
	
	ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ВыборФайла.Заголовок          = "Выберите файл";
	ВыборФайла.ПолноеИмяФайла     = "";
	ВыборФайла.Фильтр             = НСтр("ru = 'Все форматы'") + "(*.*)|*.*";
	ВыборФайла.МножественныйВыбор = Ложь;
	
	ВыбранныеФайлы = Ждать ВыборФайла.ВыбратьАсинх();
	
	Если ТипЗнч(ВыбранныеФайлы)<>Тип("Массив") ИЛИ ВыбранныеФайлы.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	Файл = Новый Файл(ВыбранныеФайлы[0]);
	Размер = Ждать Файл.РазмерАсинх();
	
	Если ЭтотОбъект.РазмерФайловСумма+Размер > ЭтотОбъект.РазмерФайловМаксимум Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Общий размер прикреплений не должен превышать %1'"), НадписьРазмераФайла(ЭтотОбъект.РазмерФайловМаксимум));
		Ждать ПредупреждениеАсинх(ТекстСообщения,, НСтр("ru = 'Прикрепление файла'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		Данные = Новый ДвоичныеДанные(Файл.ПолноеИмя);
		Адрес  = ПоместитьВоВременноеХранилище(Данные, ЭтотОбъект.УникальныйИдентификатор);
	Исключение
		ПричинаОшибки = ИнформацияОбОшибке();
		ТекстСообщения = СтрШаблон(НСтр("ru = 'При чтении данных файла %1 произошла ошибка: %2'"), Файл.Имя, ПодробноеПредставлениеОшибки(ПричинаОшибки));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецПопытки;
	
	ДобавитьФайлНаСервере(Файл.Имя, Размер, Адрес);
	
	ОбновитьНадписьРазмераФайла(ЭтотОбъект.Элементы.РазмерФайлов, ЭтотОбъект.РазмерФайловСумма, ЭтотОбъект.РазмерФайловМаксимум);
	
КонецПроцедуры // ДобавитьФайл()

&НаСервере
Процедура УдалитьФайлНаСервере(ОписаниеФайла)
	
	Элементы.Удалить(Элементы.Найти(ОписаниеФайла.ИмяГруппы));
	ЭтотОбъект.РазмерФайловСумма = ЭтотОбъект.РазмерФайловСумма - ОписаниеФайла.Размер;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура УдалитьФайл(Команда)
	
	Если ЭтотОбъект.ТолькоПросмотр Тогда 
		ПредупреждениеАсинх(НСтр("ru = 'Редактирование обращения недоступно!'"));
		Возврат;
	КонецЕсли;
	
	ИмяГруппы = ТекущийЭлемент.Родитель.Имя;
	
	МассивФайлов = Файлы.НайтиСтроки(Новый Структура("ИмяГруппы", ИмяГруппы));
	Если МассивФайлов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Файл = МассивФайлов[0];
	
	ОписаниеФайла = Новый Структура("ИмяГруппы, Размер");
	ОписаниеФайла.ИмяГруппы = Файл.ИмяГруппы;
	ОписаниеФайла.Размер    = Файл.Размер;
	
	// При записи в регистр файлы с нулевым размером пропускаются (см. ПередЗаписьюНаСервере)
	Файл.Размер = 0;
	УдалитьФайлНаСервере(ОписаниеФайла);
	
	ОбновитьНадписьРазмераФайла(ЭтотОбъект.Элементы.РазмерФайлов, ЭтотОбъект.РазмерФайловСумма, ЭтотОбъект.РазмерФайловМаксимум);
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ОткрытьФайл(Команда)
	
	ИмяГруппы = ТекущийЭлемент.Родитель.Имя;
	
	МассивФайлов = Файлы.НайтиСтроки(Новый Структура("ИмяГруппы", ИмяГруппы));
	Если МассивФайлов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Файл       = МассивФайлов[0];
	ИмяФайла   = Файл.ИмяФайла;
	ЧастиИмени = СтрРазделить(ИмяФайла, ".");
	Расширение = ЧастиИмени[ЧастиИмени.ВГраница()];
	
	ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ВыборФайла.Заголовок          = "Укажите путь для сохранения файла";
	ВыборФайла.ПолноеИмяФайла     = ИмяФайла;
	ВыборФайла.Фильтр             = НСтр("ru = 'Все форматы'") + "(*.*)|*.*";
	ВыборФайла.МножественныйВыбор = Ложь;
	
	ПутьСохранения = Ждать ВыборФайла.ВыбратьАсинх();
	
	Если ПутьСохранения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Данные = ПолучитьИзВременногоХранилища(Файл.Адрес);
	Данные.Записать(ПутьСохранения[0]+"."+Расширение);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОбработкиОшибкиОбращений(Результат, ДополнительныеПараметры=Неопределено) Экспорт
	
	ОбновитьГруппуОписанияОшибки();
	
КонецПроцедуры // ПослеОбработкиОшибкиОбращений()

&НаКлиенте
Процедура ОбработатьОшибкуОбращений(Команда)
	
	Если ЭтотОбъект.КодОшибки = 1 Тогда
		ОткрытьФорму("Обработка.пр_ПоддержкаОтраслевыхРешений.Форма.КонтактыСлужбыПоддержки");
		
	ИначеЕсли ЭтотОбъект.КодОшибки = 2 Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеОбработкиОшибкиОбращений", ЭтотОбъект);
		ОткрытьФорму("Обработка.пр_ПоддержкаОтраслевыхРешений.Форма.РегистрационнаяАнкета",,,,,, Оповещение);
		
	ИначеЕсли ЭтотОбъект.КодОшибки = 3 Тогда
		ВключитьОтправкуСтатистикиНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьНадписьРазмераФайла(Элемент, Сумма, Максимум)
	
	Элемент.Заголовок = СтрШаблон(НСтр("ru = '(используется %1 из %2)'"), НадписьРазмераФайла(Сумма), НадписьРазмераФайла(Максимум));
	
	Если Сумма > Максимум Тогда
		Элемент.ЦветТекста = Новый Цвет(255, 0, 0);
	Иначе
		Элемент.ЦветТекста = Новый Цвет();
	КонецЕсли;
	
КонецПроцедуры // ОбновитьНадписьРазмераФайла()

&НаКлиентеНаСервереБезКонтекста
Функция НадписьРазмераФайла(Размер)
	
	Если Размер>1024*1024 Тогда
		СокращенныйРазмер = Окр(Размер / 1024 / 1024, 1);
		Суффикс = НСтр("ru = 'Мб'");
	ИначеЕсли Размер>1024 Тогда
		СокращенныйРазмер = Окр(Размер / 1024, 1);
		Суффикс = НСтр("ru = 'Кб'");
	Иначе
		СокращенныйРазмер = Размер;
		Суффикс = НСтр("ru = 'Б'");
	КонецЕсли;
	
	Возврат Формат(СокращенныйРазмер, "ЧН=0; ЧГ=0") + Суффикс;
	
КонецФункции // НадписьРазмераФайла()

&НаСервере
Процедура УстановитьЗаголовокФормы()
	
	Если Запись.ВидОбращения = 0 Тогда
		ШаблонЗаголовка = НСтр("ru = 'Пожелание %1от %2'");
	ИначеЕсли Запись.ВидОбращения = 1 Тогда
		ШаблонЗаголовка = НСтр("ru = 'Ошибка %1от %2'");
	ИначеЕсли Запись.ВидОбращения = 2 Тогда
		ШаблонЗаголовка = НСтр("ru = 'Вопрос %1от %2'");
	// {УАТ}
	ИначеЕсли Запись.ВидОбращения = 3 Или Запись.ВидОбращения = 4 Или Запись.ВидОбращения = 5 Тогда
		ЭтотОбъект.Заголовок = НСтр("ru='Заявка на подключение'");
	// {/УАТ}
	КонецЕсли;
	
	НомерОбращения = ?(ПустаяСтрока(Запись.НомерОбращения), "", Запись.НомерОбращения+" ");
	ДатаОбращения  = Формат(Запись.ДатаОбращения, "ДФ='dd.MM.yyyy H:mm'");
	// {УАТ}
	Если Не (Запись.ВидОбращения = 3 Или Запись.ВидОбращения = 4 Или Запись.ВидОбращения = 5) Тогда
	// {/УАТ}
		ЭтотОбъект.Заголовок = СтрШаблон(ШаблонЗаголовка, НомерОбращения, ДатаОбращения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьГруппуОписанияОшибки()
	
	// Проверим возможность отправки обращений в службу поддержки
	ЭтотОбъект.КодОшибки = РегистрыСведений.пр_ОбращенияВСлужбуПоддержки.ПроверитьВозможностьОтправкиОбращений(Элементы);
	
	// Меняем доступность объекта
	Если ПустаяСтрока(Запись.Идентификатор) Тогда
		ЭтотОбъект.ТолькоПросмотр = (ЭтотОбъект.КодОшибки<>0);
	КонецЕсли;
	
	// Корректируем видимость основных кнопок формы
	НетОшибки = (ЭтотОбъект.КодОшибки=0);
	Элементы.ФормаЗаписатьИЗакрыть.КнопкаПоУмолчанию = НетОшибки;
	Элементы.ФормаЗаписатьИЗакрыть.Видимость         = НетОшибки;
	
КонецПроцедуры // ОбновитьГруппуОписанияОшибки()

&НаСервере
Процедура ВключитьОтправкуСтатистикиНаСервере()
	
	// Производим настройку параметров подсистемы
	пр_ПоддержкаОтраслевыхРешений.ВключитьОтправкуСтатистики(ИСТИНА);
	
	// Инициализируем ключевые параметры клиента
	пр_ПоддержкаОтраслевыхРешений.ОбновитьПараметрыПоДаннымСеанса(ИСТИНА);
	
	// Проверим состояние подсистемы
	ОбновитьГруппуОписанияОшибки();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоВидуОбращения()
	
	// Отразим в заголовке вид текущего обращения
	УстановитьЗаголовокФормы();
	
	ЭтоПожелание = Запись.ВидОбращения = 0;
	ЭтоОшибка    = Запись.ВидОбращения = 1;
	ЭтоВопрос    = Запись.ВидОбращения = 2;
	
	ЭтотОбъект.Элементы.ВозможноПредоставлениеБазы.Видимость = ЭтоОшибка;
	ЭтотОбъект.Элементы.ФактическоеПоведение.Видимость = ЭтоПожелание Или ЭтоОшибка;
	Если ЭтоОшибка Тогда
		ЭтотОбъект.Элементы.ФактическоеПоведение.Заголовок = НСтр("ru = 'Порядок пошагового воспроизведения и полученный результат'");
	Иначе
		ЭтотОбъект.Элементы.ФактическоеПоведение.Заголовок = НСтр("ru = 'Полученный результат'");
	КонецЕсли;
	Если ЭтоВопрос Тогда
		ЭтотОбъект.Элементы.ОжидаемаяЦель.Заголовок = НСтр("ru = 'Что вызывает вопрос'");
		ЭтотОбъект.Элементы.ОжидаемаяЦель.Подсказка = НСтр("ru = 'Подробное описание возникающих сложностей'");
	Иначе
		ЭтотОбъект.Элементы.ОжидаемаяЦель.Заголовок = НСтр("ru = 'Ожидаемый результат'");
		ЭтотОбъект.Элементы.ОжидаемаяЦель.Подсказка = НСтр("ru = 'Подробное описание предполагаемого результата после выполнения вышеуказанных действий'");
	КонецЕсли;
	
	// Вызываем переопределяемую процедуру для управления добавленными элементами
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.НастроитьФормуПоВидуОбращения(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

