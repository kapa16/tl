
&НаКлиенте
Процедура СоздатьОбъект(Команда)
	мВыделенныеСтроки = Элементы.Список.ВыделенныеСтроки;
	
	СоздатьОбъектНаСервере(мВыделенныеСтроки);
	
	Элементы.Список.Обновить();
КонецПроцедуры  

&НаСервере
Процедура СоздатьОбъектНаСервере(мВыделенныеСтроки)
	
	Для каждого Строка Из мВыделенныеСтроки Цикл
		
		МенеджерЗаписи = РегистрыСведений.GDS_СоответствияОбъектовИнформационныхБаз.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.УзелИнформационнойБазы = Строка.УзелИнформационнойБазы;	
		МенеджерЗаписи.УникальныйИдентификаторИсточника = Строка.УникальныйИдентификаторИсточника;	
		МенеджерЗаписи.ТипПриемника = Строка.ТипПриемника;	
		МенеджерЗаписи.Прочитать();
		 
		Если ЗначениеЗаполнено(МенеджерЗаписи.СсылкаНаОбъект) Тогда
			Сообщить("В строке с УИН: " + Строка.УникальныйИдентификаторИсточника + " заполнен реквизит ""СсылкаНаОбъект""!!!");
			Продолжить;
		КонецЕсли;

		ПолноеИмя = Метаданные.НайтиПоТипу(Тип(МенеджерЗаписи.ТипПриемника)).ПолноеИмя(); 
		
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ПолноеИмя);
		МетаданныеОбъекта = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
		Если ОбщегоНазначения.ЭтоСправочник(МетаданныеОбъекта)
			Или ОбщегоНазначения.ЭтоПланВидовХарактеристик(МетаданныеОбъекта) Тогда
			
			УИД = Новый УникальныйИдентификатор(МенеджерЗаписи.УникальныйИдентификаторИсточника);
			
			СправочникСсылка = МенеджерОбъекта.ПолучитьСсылку(УИД);
			
			СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
			Если СправочникОбъект = Неопределено Тогда
				СправочникОбъект = МенеджерОбъекта.СоздатьЭлемент();
                СправочникОбъект.УстановитьСсылкуНового(СправочникСсылка);
			КонецЕсли;
			
			СправочникОбъект.Наименование = МенеджерЗаписи.ОписаниеИсточника;
			СправочникОбъект.ОбъектВыгруженПоСсылке = Истина;
			СправочникОбъект.ОбменДанными.Загрузка = Истина;
			СправочникОбъект.Записать();
		//ИначеЕсли ОбщегоНазначения.ЭтоДокумент(МетаданныеОбъектаИС) Тогда
		//	ОбъектИС = МенеджерОбъектаИС.СоздатьДокумент();
		//ИначеЕсли ОбщегоНазначения.ЭтоПланВидовРасчета(МетаданныеОбъектаИС) Тогда
		//	ОбъектИС = МенеджерОбъектаИС.СоздатьВидРасчета();
		//ИначеЕсли ОбщегоНазначения.ЭтоБизнесПроцесс(МетаданныеОбъектаИС) Тогда
		//	ОбъектИС = МенеджерОбъектаИС.СоздатьБизнесПроцесс();
		//ИначеЕсли ОбщегоНазначения.ЭтоЗадача(МетаданныеОбъектаИС) Тогда
		//	ОбъектИС = МенеджерОбъектаИС.СоздатьЗадачу();
		Иначе
			ВызватьИсключение
			СтрШаблон(НСтр("ru = 'Ошибка при создании: %1'"), ПолноеИмя);
		КонецЕсли;
				
		МенеджерЗаписи.СсылкаНаОбъект = СправочникОбъект.Ссылка;
		МенеджерЗаписи.Записать();
	КонецЦикла;  
	
КонецПроцедуры
