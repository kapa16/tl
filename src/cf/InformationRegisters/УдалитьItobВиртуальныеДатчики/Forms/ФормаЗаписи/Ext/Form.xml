	<Width>72</Width>
	<WindowOpeningMode>LockOwnerWindow</WindowOpeningMode>
	<VerticalScroll>useIfNecessary</VerticalScroll>
	<AutoCommandBar name="ФормаКоманднаяПанель" id="-1"/>
	<ChildItems>
		<InputField name="БазовыйДатчик" id="1">
			<DataPath>Запись.БазовыйДатчик</DataPath>
			<ContextMenu name="БазовыйДатчикКонтекстноеМеню" id="2"/>
			<ExtendedTooltip name="БазовыйДатчикРасширеннаяПодсказка" id="14"/>
		</InputField>
		<InputField name="ВиртуальныйДатчик" id="3">
			<DataPath>Запись.ВиртуальныйДатчик</DataPath>
			<ContextMenu name="ВиртуальныйДатчикКонтекстноеМеню" id="4"/>
			<ExtendedTooltip name="ВиртуальныйДатчикРасширеннаяПодсказка" id="15"/>
		</InputField>
		<LabelDecoration name="ДекорацияРасчетДляВсехТерминалов" id="12">
			<Height>2</Height>
			<HorizontalStretch>true</HorizontalStretch>
			<TextColor>style:FieldSelectionBackColor</TextColor>
			<Title formatted="false">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Если флажок "Расчет для всех терминалов" снят - значение датчика будет рассчитываться только если данный виртуальный датчик указан в таблице датчиков терминала</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>If the "Calculate for all terminals" checkbox is unchecked, the sensor value will be calculated only if this virtual sensor is specified in the terminal sensor table.</v8:content>
				</v8:item>
			</Title>
			<TitleHeight>3</TitleHeight>
			<ContextMenu name="ДекорацияРасчетДляВсехТерминаловКонтекстноеМеню" id="13"/>
			<ExtendedTooltip name="ДекорацияРасчетДляВсехТерминаловРасширеннаяПодсказка" id="16"/>
		</LabelDecoration>
		<CheckBoxField name="РасчетДляВсехТерминалов" id="10">
			<DataPath>Запись.РасчетДляВсехТерминалов</DataPath>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Расчет для всех терминалов</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Calculation for all terminals</v8:content>
				</v8:item>
			</Title>
			<CheckBoxType>Auto</CheckBoxType>
			<ContextMenu name="РасчетДляВсехТерминаловКонтекстноеМеню" id="11"/>
			<ExtendedTooltip name="РасчетДляВсехТерминаловРасширеннаяПодсказка" id="17"/>
		</CheckBoxField>
		<LabelDecoration name="ДекорацияФормулаРаcчета" id="7">
			<Width>71</Width>
			<Height>4</Height>
			<TextColor>style:FieldSelectionBackColor</TextColor>
			<Title formatted="false">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Выражение, по которому будет вычисляться значение виртуального датчика, на встроенном языке 1С:Предприятие. Исходное значение содержится в переменной Значение. Этой же переменной присваивается новое значение. Подробная информация по выражениям представлена в справочной информации.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>The expression used to calculate the virtual sensor value, written in the 1C:Enterprise built-in language. The original value is contained in the "Value" variable. The new value is assigned to this same variable. Detailed information on expressions is provided in the reference information.</v8:content>
				</v8:item>
			</Title>
			<ContextMenu name="ДекорацияФормулаРаcчетаКонтекстноеМеню" id="8"/>
			<ExtendedTooltip name="ДекорацияФормулаРаcчетаРасширеннаяПодсказка" id="18"/>
		</LabelDecoration>
		<TextDocumentField name="ФормулаРасчета" id="5">
			<DataPath>Запись.ФормулаРасчета</DataPath>
			<TitleLocation>None</TitleLocation>
			<ContextMenu name="ФормулаРасчетаКонтекстноеМеню" id="6"/>
			<ExtendedTooltip name="ФормулаРасчетаРасширеннаяПодсказка" id="19"/>
		</TextDocumentField>
	</ChildItems>
	<Attributes>
		<Attribute name="Запись" id="1">
			<Type>
				<v8:Type>cfg:InformationRegisterRecordManager.УдалитьItobВиртуальныеДатчики</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<SavedData>true</SavedData>
		</Attribute>
	</Attributes>
</Form>