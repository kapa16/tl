&НаКлиенте
Процедура РасчетПоФормулеПриИзменении(Элемент)
	Если НЕ РасчетПоФормуле Тогда
		АлгоритмРасчета = Неопределено;
	КонецЕсли;
	
	ОтобразитьФормулуРасчета();
	УстановитьВидимостьДоступностьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьФормулуНажатие(Элемент)
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("МодельТС", Запись.МодельТС);
	ПараметрыФормы.Вставить("АлгоритмРасчета", АлгоритмРасчета);
	ОповещениеЗакрытие = Новый ОписаниеОповещения("РедактироватьФормулуЗакрытиеФормы", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.уатНормыРасходаГСМ.Форма.КонструкторФормул", ПараметрыФормы, ЭтаФорма,,,, ОповещениеЗакрытие, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьФормулуЗакрытиеФормы(Результат, ДопПараметры) Экспорт
	Если Результат <> Неопределено Тогда
		АлгоритмРасчета = Результат;
		ОтобразитьФормулуРасчета();
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РежимРаботыНаДвухВидахТопливаПриИзменении(Элемент)
	Запись.РаботаНаДвухВидахТопливаОдновременно = (ПереключательДваВидаТоплива = "Одновременно");
	Модифицированность = Истина;
	УстановитьВидимостьДоступностьНаСервере();
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьВидимостьДоступностьНаСервере()
	
	Если ТипЗнч(Запись.МодельТС) = Тип("СправочникСсылка.уатМоделиТС") Тогда
		НаличиеСпидометра = Запись.МодельТС.НаличиеСпидометра;
		НаличиеТопливногоБака = Запись.МодельТС.НаличиеТопливногоБака;
		ВидМоделиТС = Запись.МодельТС.ВидМоделиТС;
	ИначеЕсли ТипЗнч(Запись.МодельТС) = Тип("СправочникСсылка.уатТС") Тогда
		НаличиеСпидометра = Запись.МодельТС.Модель.НаличиеСпидометра;
		НаличиеТопливногоБака = Запись.МодельТС.Модель.НаличиеТопливногоБака;
		ВидМоделиТС = Запись.МодельТС.Модель.ВидМоделиТС;
	Иначе
		НаличиеСпидометра = Истина;
		НаличиеТопливногоБака = Истина;
		ВидМоделиТС = Неопределено;
	КонецЕсли;
	
	Элементы.ГруппаЛинейнаяНорма.Видимость = НаличиеСпидометра;
	Элементы.ГруппаНормаНаИзменениеСобственногоВеса.Видимость = НаличиеСпидометра;
	Элементы.ГруппаНормаНаТранспортнуюРаботу.Видимость = НаличиеСпидометра;
	Элементы.ГруппаНормаСпециальнаяНаМоточас.Видимость = НЕ НаличиеСпидометра;
	
	Элементы.ВидНормыНаПростой.СписокВыбора.Очистить();
	Если НаличиеСпидометра Тогда
		Элементы.ВидНормыНаПростой.СписокВыбора.Добавить(0, НСтр("en='km/1 hour of downtime';ru='км/1 час простоя'"));
		Элементы.ВидНормыНаПростой.СписокВыбора.Добавить(1, НСтр("en='% of basic';ru='% от базовой'"));
		Элементы.ВидНормыНаПростой.СписокВыбора.Добавить(2, НСтр("en='l/1 hour of downtime';ru='л/1 час простоя'"));
	Иначе
		Элементы.ВидНормыНаПростой.СписокВыбора.Добавить(0, НСтр("en='l/1 hour of downtime';ru='л/1 час простоя'"));
		Элементы.ВидНормыНаПростой.СписокВыбора.Добавить(1, НСтр("en='% of spec. on moto hour';ru='% от спец. на моточас'"));
		Если ВидНормыНаПростой = 2 Тогда
			ВидНормыНаПростой = 0;
			Модифицированность = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ВидНормыНаПростой = 0 Тогда
		Элементы.ГруппаСтраницыВидПростоя.ТекущаяСтраница = Элементы.ГруппаСтраницаПростойКм;
	ИначеЕсли ВидНормыНаПростой = 1 Тогда
		Элементы.ГруппаСтраницыВидПростоя.ТекущаяСтраница = Элементы.ГруппаСтраницаПростойПроцент;
	ИначеЕсли ВидНормыНаПростой = 2 Тогда
		Элементы.ГруппаСтраницыВидПростоя.ТекущаяСтраница = Элементы.ГруппаСтраницаПростойЛ;
	КонецЕсли;
	
	Для Сч = 1 По 10 Цикл 
		СпецРабота = Запись["СпециальнаяРабота" + Формат(Сч, "ЧГ=0")];
		Элементы["НормаНаСпециальнуюРаботу" + Формат(Сч, "ЧГ=0")].Заголовок = НСтр("en='Norm';ru='Норма'") + " " + Формат(Сч, "ЧГ=0") + ", " + ЕдиницаИзмеренияДляТоплива()// НСтр("en='l';ru='л'")
		+ ?(ЗначениеЗаполнено(СпецРабота), "/" + ?(СпецРабота.Временный, " ", " 100 ") + СпецРабота.ЕдиницаИзмерения, "");
	КонецЦикла;
	
	Элементы.РедактироватьФормулу.Доступность = НЕ ТолькоПросмотр И РасчетПоФормуле;
	
	Элементы.ДекорацияНетПоочереднойНормы.Видимость = Запись.РаботаНаДвухВидахТопливаОдновременно
		И НЕ ЕстьПоочереднаяНорма(Запись.МодельТС, Запись.ГСМ, Запись.Организация, Запись.ИсходныйКлючЗаписи);
		
	Элементы.ГруппаДваВидаТоплива.Доступность =
		НЕ (ВидМоделиТС = Перечисления.уатВидыМоделейТС.Прицеп
		ИЛИ ВидМоделиТС = Перечисления.уатВидыМоделейТС.Оборудование);
		
	УстановкаЕдиницИзмерения();
	
	Если ВидМоделиТС = Перечисления.уатВидыМоделейТС.Прицеп
		ИЛИ ВидМоделиТС = Перечисления.уатВидыМоделейТС.Оборудование Тогда
		Элементы.ГруппаПредупреждение.Видимость = Истина;
		
		Если НаличиеСпидометра Тогда
			Элементы.тПредупреждение.Заголовок = СтрШаблон("В Путевом листе при выборе %1 в табличной части ""Прицепы и оборудование"" или ""Задание"""
				+ " при расчете нормативного расхода ГСМ нормы %1 не учитываются. Наличие %1"
				+ " влияет на применение нормы на изменение собственного веса для основного ТС по Путевому листу.",
				?(ВидМоделиТС = Перечисления.уатВидыМоделейТС.Прицеп, "прицепа", "оборудования"));
		Иначе
			Элементы.тПредупреждение.Заголовок = СтрШаблон("В Путевом листе при выборе %1 в табличной части ""Прицепы и оборудование"" или ""Задание"""
				+ " при расчете нормативного расхода ГСМ учитывается норма специальная на моточас%2 Наличие %1"
				+ " влияет на применение нормы на изменение собственного веса для основного ТС по Путевому листу.",
				?(ВидМоделиТС = Перечисления.уатВидыМоделейТС.Прицеп, "прицепа", "оборудования"),
				?(НаличиеТопливногоБака, ".", " (на работу специального оборудования для основного ТС)."));
		КонецЕсли;
	Иначе
		Элементы.ГруппаПредупреждение.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьФормулуРасчета()
	Если ТипЗнч(АлгоритмРасчета) <> Тип("Структура")
		ИЛИ НЕ АлгоритмРасчета.Свойство("ОбщаяФормула")
		ИЛИ НЕ ЗначениеЗаполнено(АлгоритмРасчета.ОбщаяФормула) Тогда
		Элементы.РедактироватьФормулу.Заголовок = Нстр("en = 'Formula not specified'; ru = 'Формула не указана'");
	Иначе
		Элементы.РедактироватьФормулу.Заголовок = АлгоритмРасчета.ОбщаяФормула;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЕстьПоочереднаяНорма(МодельТС, ГСМ, Организация, ИсходныйКлючЗаписи)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	уатНормыРасходаГСМСрезПоследних.ЛинейнаяНорма КАК ЛинейнаяНорма
	|ИЗ
	|	РегистрСведений.уатНормыРасходаГСМ.СрезПоследних(
	|			,
	|			НЕ РаботаНаДвухВидахТопливаОдновременно
	|				И МодельТС = &МодельТС
	|				И ГСМ = &ГСМ
	|				И Организация = &Организация) КАК уатНормыРасходаГСМСрезПоследних");
	Запрос.УстановитьПараметр("МодельТС", МодельТС);
	Запрос.УстановитьПараметр("ГСМ", ГСМ);
	Запрос.УстановитьПараметр("Организация", Организация);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат Ложь; // нет записей с поочередной нормой
	ИначеЕсли ЗначениеЗаполнено(ИсходныйКлючЗаписи.Период)
		И НЕ ИсходныйКлючЗаписи.РаботаНаДвухВидахТопливаОдновременно Тогда
		Возврат Ложь; // запись с поочередной нормой есть, но это измененная текущая запись - считаем что нет
	Иначе
		Возврат Истина; // есть запись с поочередной нормой
	КонецЕсли;
КонецФункции

&НаСервере
Процедура УстановкаЕдиницИзмерения()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	уатНоменклатураГСМ.ГруппаГСМ КАК ГруппаГСМ
	|ИЗ
	|	РегистрСведений.уатНоменклатураГСМ КАК уатНоменклатураГСМ
	|ГДЕ
	|	уатНоменклатураГСМ.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("Номенклатура", Запись.ГСМ);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Если Не РезультатЗапроса.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Запись.МодельТС) = Тип("СправочникСсылка.уатМоделиТС") Тогда
		НаличиеСпидометра = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Запись.МодельТС, "НаличиеСпидометра");
	ИначеЕсли ТипЗнч(Запись.МодельТС) = Тип("СправочникСсылка.уатТС") Тогда
		НаличиеСпидометра = уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(уатОбщегоНазначенияТиповые.ПолучитьЗначениеРеквизита(Запись.МодельТС, "Модель"), "НаличиеСпидометра");
	Иначе
		НаличиеСпидометра = Истина;
	КонецЕсли;
	
	ИндексВидаНормыНаПростой = ?(НаличиеСпидометра, 2, 0);
	
	Если РезультатЗапроса.ГруппаГСМ = Перечисления.уатГруппыГСМ.Электроэнергия Тогда
		Элементы.ДекорацияЛинейнаяНорма.Заголовок = НСтр("ru = 'Линейная норма, кВт/100 км'; en = 'Linear rate, kW/100 km'");
		Элементы.ЛинейнаяНорма.Подсказка = НСтр("ru = 'Линейная норма, кВт/100 км'; en = 'Linear rate, kW/100 km'");
		Элементы.ДекорацияНормаСпециальнаяНаМоточас.Заголовок = НСтр("ru = 'Норма спец. на моточас, кВт/ч'; en = 'Special standard per engine hour, kW/h'");
		Элементы.НормаСпециальнаяНаМоточас.Подсказка = НСтр("ru = 'Норма спец. на моточас, кВт/ч'; en = 'Special standard per engine hour, kW/h'");
		Элементы.ДекорацияНормаНаИзменениеСобственногоВеса.Заголовок = НСтр("ru = 'Норма на изм. собств. веса, кВт/100 т.км'; en = 'Standard for change of tare weight, kW/100 t.km'");
		Элементы.НормаНаИзменениеСобственногоВеса.Подсказка = НСтр("ru = 'Норма на изм. собств. веса, кВт/100 т.км'; en = 'Standard for change of tare weight, kW/100 t.km'");
		Элементы.ДекорацияНормаНаТранспортнуюРаботу.Заголовок = НСтр("ru = 'Норма на трансп. работу, кВт/100 т.км'; en = 'Standard for transport work, kW/100 t.km'");
		Элементы.НормаНаТранспортнуюРаботу.Подсказка = НСтр("ru = 'Норма на трансп. работу, кВт/100 т.км'; en = 'Standard for transport work, kW/100 t.km'");
		Элементы.ДекорацияЕздка.Заголовок = НСтр("ru = 'Норма на ездку, кВт'; en = 'Driving rate, kW'");
		Элементы.НормаНаЕздку.Подсказка = НСтр("ru = 'Норма на ездку, кВт'; en = 'Driving rate, kW'");
		Элементы.ДекорацияНормаНаОперацию.Заголовок = НСтр("ru = 'Норма на операцию, кВт'; en = 'Standard per operation, kW'");
		Элементы.НормаНаОперацию.Подсказка = НСтр("ru = 'Норма на операцию, кВт'; en = 'Standard per operation, kW'");
		Элементы.ДекорацияНормаНаЗапуск.Заголовок = НСтр("ru = 'Норма на запуск, кВт'; en = 'Starting power, kW'");
		Элементы.НормаНаЗапуск.Подсказка = НСтр("ru = 'Норма на запуск, кВт'; en = 'Starting power, kW'");
		Элементы.ДекорацияНормаНаОтопитель.Заголовок = НСтр("ru = 'Норма на отопитель, кондиционер, климат-контроль, кВт/ч'; en = 'Standard for heater, air conditioner, climate control, kW/h'");
		Элементы.НормаНаОтопитель.Подсказка = НСтр("ru = 'Норма на отопитель, кондиционер, климат-контроль, кВт/ч'; en = 'Standard for heater, air conditioner, climate control, kW/h'");
		Элементы.ВидНормыНаПростой.СписокВыбора[ИндексВидаНормыНаПростой].Представление = НСтр("ru = 'кВт/1 час простоя'; en = 'kW/1 hour of downtime'");
	Иначе
		Элементы.ДекорацияЛинейнаяНорма.Заголовок = НСтр("ru = 'Линейная норма, л/100 км'; en = 'Linear rate, l/100 km'");
		Элементы.ЛинейнаяНорма.Подсказка = НСтр("ru = 'Линейная норма, л/100 км'; en = 'Linear rate, l/100 km'");
		Элементы.ДекорацияНормаСпециальнаяНаМоточас.Заголовок = НСтр("ru = 'Норма спец. на моточас, л/ч'; en = 'Special standard per engine hour, l/h'");
		Элементы.НормаСпециальнаяНаМоточас.Подсказка = НСтр("ru = 'Норма спец. на моточас, л/ч'; en = 'Special standard per engine hour, l/h'");
		Элементы.ДекорацияНормаНаИзменениеСобственногоВеса.Заголовок = НСтр("ru = 'Норма на изм. собств. веса, л/100 т.км'; en = 'Standard for change of tare weight, l/100 t.km'");
		Элементы.НормаНаИзменениеСобственногоВеса.Подсказка = НСтр("ru = 'Норма на изм. собств. веса, л/100 т.км'; en = 'Standard for change of tare weight, l/100 t.km'");
		Элементы.ДекорацияНормаНаТранспортнуюРаботу.Заголовок = НСтр("ru = 'Норма на трансп. работу, л/100 т.км'; en = 'Standard for transport work, l/100 t.km'");
		Элементы.НормаНаТранспортнуюРаботу.Подсказка = НСтр("ru = 'Норма на трансп. работу, л/100 т.км'; en = 'Standard for transport work, l/100 t.km'");
		Элементы.ДекорацияЕздка.Заголовок = НСтр("ru = 'Норма на ездку, л'; en = 'Driving norm, l'");
		Элементы.НормаНаЕздку.Подсказка = НСтр("ru = 'Норма на ездку, л'; en = 'Driving norm, l'");
		Элементы.ДекорацияНормаНаОперацию.Заголовок = НСтр("ru = 'Норма на операцию, л'; en = 'Norm per operation, l'");
		Элементы.НормаНаОперацию.Подсказка = НСтр("ru = 'Норма на операцию, л'; en = 'Norm per operation, l'");
		Элементы.ДекорацияНормаНаЗапуск.Заголовок = НСтр("ru = 'Норма на запуск, л'; en = 'Starting norm, l'");
		Элементы.НормаНаЗапуск.Подсказка = НСтр("ru = 'Норма на запуск, л'; en = 'Starting norm, l'");
		Элементы.ДекорацияНормаНаОтопитель.Заголовок = НСтр("ru = 'Норма на отопитель, кондиционер, климат-контроль, л/ч'; en = 'Standard for heater, air conditioner, climate control, l/h'");
		Элементы.НормаНаОтопитель.Подсказка = НСтр("ru = 'Норма на отопитель, кондиционер, климат-контроль, л/ч'; en = 'Standard for heater, air conditioner, climate control, l/h'");
		Элементы.ВидНормыНаПростой.СписокВыбора[ИндексВидаНормыНаПростой].Представление = НСтр("ru = 'л/1 час простоя'; en = 'l/1 hour of downtime'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЕдиницаИзмеренияДляТоплива()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	уатНоменклатураГСМ.ГруппаГСМ КАК ГруппаГСМ
	|ИЗ
	|	РегистрСведений.уатНоменклатураГСМ КАК уатНоменклатураГСМ
	|ГДЕ
	|	уатНоменклатураГСМ.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("Номенклатура", Запись.ГСМ);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Если Не РезультатЗапроса.Следующий() Тогда
		Возврат НСтр("en='l';ru='л'");
	КонецЕсли;
	
	Если РезультатЗапроса.ГруппаГСМ = Перечисления.уатГруппыГСМ.Электроэнергия Тогда
		Возврат НСтр("ru = 'кВт/ч'; en = 'kW/h'");
	Иначе
		Возврат НСтр("en='l';ru='л'");
	КонецЕсли;
КонецФункции

#КонецОбласти
