Процедура ПРО_Документ_уатРасходныйКассовыйОрдер_ПослеОбработки(ПРО, Отказ, Объект, ОбъектМетаданных, Получатели, Выгрузка)

	СчУзлов = Получатели.Количество();
	Пока СчУзлов > 0 Цикл
		СчУзлов = СчУзлов - 1;
		
		ТаблЗапрещенных = Получатели[СчУзлов].ЗапрещенныеКОтправке;
		
		РегистрацияЗапрещена = Ложь;
		
		ВидОперации = Объект.ВидОперации;
		
		Если ВидОперации = Перечисления.уатВидыОперацийРКО.ОплатаПоставщику Тогда 
			Если Не ТаблЗапрещенных.Найти("РасходныйКассовыйОрдер_ОплатаПоставщику", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийРКО.РасходДенежныхСредствПрочее Тогда 
			Если Не ТаблЗапрещенных.Найти("РасходныйКассовыйОрдер_РасходДенежныхСредствПрочее", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийРКО.ПрочиеРасчетыСКонтрагентами Тогда 
			Если Не ТаблЗапрещенных.Найти("РасходныйКассовыйОрдер_ПрочиеРасчетыСКонтрагентами", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийРКО.ВыдачаПодотчетнику Тогда 
			Если Не ТаблЗапрещенных.Найти("РасходныйКассовыйОрдер_ВыдачаПодотчетнику", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыОперацийРКО.ВозвратПокупателю Тогда 
			Если Не ТаблЗапрещенных.Найти("РасходныйКассовыйОрдер_ВозвратПокупателю", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
					
		Иначе 
			РегистрацияЗапрещена = Истина;
			
		КонецЕсли;
		
		Если РегистрацияЗапрещена Тогда 
			Получатели.Удалить(СчУзлов);
		КонецЕсли;
	КонецЦикла;
