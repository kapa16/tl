Процедура ПРО_Документ_уатЗаправкаГСМ_ПослеОбработки(ПРО, Отказ, Объект, ОбъектМетаданных, Получатели, Выгрузка)

	СчУзлов = Получатели.Количество();
	Пока СчУзлов > 0 Цикл
		СчУзлов = СчУзлов - 1;
		
		ТаблЗапрещенных = Получатели[СчУзлов].ЗапрещенныеКОтправке;
		
		РегистрацияЗапрещена = Ложь;
		
		ВидОперации = Объект.ВидДвиженияГСМ;
		
		Если ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаНаличные Тогда 
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_Наличные", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаСклад 
			Или ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаПластиковаяКартаСклад 
			Или ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаТалоны Тогда 
			флОтказСкладТалон_ПередМатВПроизводство = Ложь;
			флОтказСкладТалон_ПередМатВЭксплуатацию = Ложь;
			флОтказСкладТалон_Перемещение           = Ложь;
			флОтказСкладТалон_Списание              = Ложь;
			
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_СкладТалон_ПередМатВПроизводство", "Имя") = Неопределено Тогда 
				флОтказСкладТалон_ПередМатВПроизводство = Истина;
			КонецЕсли;
			
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_СкладТалон_ПередМатВЭксплуатацию", "Имя") = Неопределено Тогда 
				флОтказСкладТалон_ПередМатВЭксплуатацию = Истина;
			КонецЕсли;
			
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_СкладТалон_Перемещение", "Имя") = Неопределено Тогда 
				флОтказСкладТалон_Перемещение = Истина;
			КонецЕсли;
			
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_СкладТалон_СписаниеЗапасов", "Имя") = Неопределено Тогда 
				флОтказСкладТалон_Списание = Истина;
			КонецЕсли;
			
			Если флОтказСкладТалон_ПередМатВПроизводство И флОтказСкладТалон_ПередМатВЭксплуатацию И флОтказСкладТалон_Перемещение И флОтказСкладТалон_Списание Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		ИначеЕсли ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаПоставщик Или ВидОперации = Перечисления.уатВидыДвиженияГСМ.ЗаправкаПластиковаяКарта Тогда 
			Если Не ТаблЗапрещенных.Найти("ЗаправкаГСМ_Поставщик", "Имя") = Неопределено Тогда 
				РегистрацияЗапрещена = Истина;
			КонецЕсли;
			
		Иначе 
			РегистрацияЗапрещена = Истина;
		КонецЕсли;
		
		Если РегистрацияЗапрещена Тогда 
			Получатели.Удалить(СчУзлов);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

