			|		<СвойствоОбъекта>ВидРаботыСотрудника</СвойствоОбъекта>
			|		<Вид>АлгоритмЗначения</Вид>
			|		<ЗначениеКонстанты>Значение = Справочники.ВидыРаботСотрудников.ПустаяСсылка();</ЗначениеКонстанты>
			|		<ТаблицаСвойствОбъекта>
			|			<Свойство>
			|				<Наименование>ВидРаботыСотрудника</Наименование>
			|				<Тип>СправочникСсылка.ВидыРаботСотрудников</Тип>
			|				<Вид>Реквизит</Вид>
			|			</Свойство>
			|		</ТаблицаСвойствОбъекта>
