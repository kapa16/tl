Процедура ПРО_Документ_уатРемонтныйЛист_ПослеОбработки(ПРО, Отказ, Объект, ОбъектМетаданных, Получатели, Выгрузка)

	ЕстьПоступленияМатериаловИУслуг = Объект.ПоступленияМатериаловИУслуг.Количество() > 0;
	
	СчУзлов = Получатели.Количество();
	Пока СчУзлов > 0 Цикл
		СчУзлов = СчУзлов - 1;
		
		ТаблЗапрещенных = Получатели[СчУзлов].ЗапрещенныеКОтправке;
		
		флОтказВыработкаСотрудников             = Ложь;
		флОтказРемЗона_СписаниеЗапасов          = Ложь;
		флОтказРемЗона_ПередМатВПроизводство    = Ложь;
		флОтказРемЗона_ПередМатВЭксплуатацию    = Ложь;
		флОтказАвтосервис_СписаниеЗапасов       = Ложь;
		флОтказАвтосервис_ПередМатВПроизводство = Ложь;
		флОтказАвтосервис_ПередМатВЭксплуатацию = Ложь;
		флОтказАвтосервис_ПоступлениеМатериалов = Ложь;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_ВыработкаСотрудников", "Имя") = Неопределено Тогда 
			флОтказВыработкаСотрудников = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_РемЗона_СписаниеЗапасов", "Имя") = Неопределено Тогда 
			флОтказРемЗона_СписаниеЗапасов = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_РемЗона_ПередМатВПроизводство", "Имя") = Неопределено Тогда 
			флОтказРемЗона_ПередМатВПроизводство = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_РемЗона_ПередМатВЭксплуатацию", "Имя") = Неопределено Тогда 
			флОтказРемЗона_ПередМатВЭксплуатацию = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_Автосервис_СписаниеЗапасов", "Имя") = Неопределено Тогда 
			флОтказАвтосервис_СписаниеЗапасов = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_Автосервис_ПередМатВПроизводство", "Имя") = Неопределено Тогда 
			флОтказАвтосервис_ПередМатВПроизводство = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_Автосервис_ПередМатВЭксплуатацию", "Имя") = Неопределено Тогда 
			флОтказАвтосервис_ПередМатВЭксплуатацию = Истина;
		КонецЕсли;
		
		Если Не ТаблЗапрещенных.Найти("РемонтныйЛист_Автосервис_ПоступлениеМатериалов", "Имя") = Неопределено
			Или ЕстьПоступленияМатериаловИУслуг Тогда 
			флОтказАвтосервис_ПоступлениеМатериалов = Истина;
		КонецЕсли;
		
		Если флОтказВыработкаСотрудников
			И флОтказРемЗона_СписаниеЗапасов И флОтказРемЗона_ПередМатВПроизводство И флОтказРемЗона_ПередМатВЭксплуатацию
			И флОтказАвтосервис_СписаниеЗапасов И флОтказАвтосервис_ПередМатВПроизводство И флОтказАвтосервис_ПередМатВЭксплуатацию И флОтказАвтосервис_ПоступлениеМатериалов Тогда 
			Получатели.Удалить(СчУзлов);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

