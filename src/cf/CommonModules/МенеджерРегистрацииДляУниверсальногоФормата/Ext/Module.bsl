Процедура ДобавитьПРО_Документ_уатВозвратТоваров(ПравилаРегистрацииОбъектов, ИмяМенеджераРегистрации)
	НовоеПравило = ПравилаРегистрацииОбъектов.Добавить();
	
	НовоеПравило.ИмяМенеджераРегистрации = ИмяМенеджераРегистрации; 
	НовоеПравило.Идентификатор = "Документ_уатВозвратТоваров";
	
	НовоеПравило.ОбъектМетаданныхИмя = "Документ.уатВозвратТоваров";
	НовоеПравило.ИмяПланаОбмена = "СинхронизацияДанныхЧерезУниверсальныйФормат";
	НовоеПравило.ИмяРеквизитаФлага = "РежимВыгрузкиДокументов";	
	НовоеПравило.ПравилоПоСвойствамОбъектаПустое = Ложь; 
	НовоеПравило.ПакетноеВыполнениеОбработчиков = Ложь;
	НовоеПравило.ЕстьОбработчикПередОбработкой = Ложь;
	НовоеПравило.ЕстьОбработчикПриОбработке = Ложь;
	НовоеПравило.ЕстьОбработчикПриОбработкеДополнительный = Ложь;
	НовоеПравило.ЕстьОбработчикПослеОбработки = Истина;
		
	УстановитьОтборы(НовоеПравило, 
		ОтборПоСвойствамПланаОбмена_1(),
		ОтборПоСвойствамОбъекта_2());
КонецПроцедуры



Процедура ПРО_Документ_уатВозвратТоваров_ПослеОбработки(ПРО, Отказ, Объект, ОбъектМетаданных, Получатели, Выгрузка)

	СчУзлов = Получатели.Количество();
	Пока СчУзлов > 0 Цикл
		СчУзлов = СчУзлов - 1;
		
		ТаблЗапрещенных = Получатели[СчУзлов].ЗапрещенныеКОтправке;
		
		РегистрацияЗапрещена = Ложь;
		
		Если Не ТаблЗапрещенных.Найти("ВозвратТоваров", "Имя") = Неопределено Тогда 
			РегистрацияЗапрещена = Истина;
		КонецЕсли;
		
		Если РегистрацияЗапрещена Тогда 
			Получатели.Удалить(СчУзлов);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

