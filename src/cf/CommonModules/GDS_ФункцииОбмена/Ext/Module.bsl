Функция ОбработкаXML_СерииНоменклатуры(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.Агрегат_УИД);
	АгрегатСсылка = Справочники.уатСерииНоменклатуры.ПолучитьСсылку(УИН);
	Если Найти(Строка(АгрегатСсылка), "<Объект не найден>") > 0 Тогда
		Если ДанныеОбмена.Агрегат_ПометкаУдаления Тогда
			Возврат Истина;
		КонецЕсли;
		АгрегатОбъект = Справочники.уатСерииНоменклатуры.СоздатьЭлемент();
		АгрегатОбъект.УстановитьСсылкуНового(АгрегатСсылка);
	Иначе	
		АгрегатОбъект = АгрегатСсылка.ПолучитьОбъект();	
	КонецЕсли;
	
	АгрегатОбъект.Наименование = ДанныеОбмена.Агрегат_Наименование;
	АгрегатОбъект.ПометкаУдаления = ДанныеОбмена.Агрегат_ПометкаУдаления;
	
	АгрегатОбъект.ПервоначальнаяСтоимость = ДанныеОбмена.Агрегат_ПервоначальнаяСтоимость;
	
	АгрегатОбъект.Валюта = Справочники.Валюты.НайтиПоНаименованию("RUB"); 
	//Справочники.Валюты.НайтиПоНаименованию(ДанныеОбмена.Агрегат_Валюта);
	
	АгрегатОбъект.СерийныйНомер = ДанныеОбмена.Агрегат_СерийныйНомер;
	
	Если ДанныеОбмена.Свойство("Агрегат_Номенклатура") Тогда
		АгрегатОбъект.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Агрегат_Номенклатура));
	КонецЕсли;
	
	Если ОбработкаXML_ТипыАгрегатов(ДанныеОбмена) Тогда
		АгрегатОбъект.ТипАгрегата = Справочники.уатТипыАгрегатов.НайтиПоНаименованию(ДанныеОбмена.ТипАгрегата_Наименование);
	КонецЕсли;

	Если ОбработкаXML_МоделиАгрегатов(ДанныеОбмена) Тогда
		АгрегатОбъект.Модель = Справочники.уатМоделиАгрегатов.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.МодельАгрегата_УИД));
	КонецЕсли;
	
	Если АгрегатОбъект.ТипАгрегата <> Справочники.уатТипыАгрегатов.Шина Тогда
		АгрегатОбъект.НачалоЭксплуатации = XMLЗначение(Тип("Дата"), ДанныеОбмена.Агрегат_НачалоЭксплуатации);
		АгрегатОбъект.ГоденДо = XMLЗначение(Тип("Дата"), ДанныеОбмена.Агрегат_ГоденДо); 
	КонецЕсли;
	
	Попытка
		АгрегатОбъект.Записать();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
		
КонецФункции

Функция ОбработкаXML_МоделиАгрегатов(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.МодельАгрегата_УИД);
	МодельАгрегатСсылка = Справочники.уатМоделиАгрегатов.ПолучитьСсылку(УИН);
	Если Найти(Строка(МодельАгрегатСсылка), "<Объект не найден>") > 0 Тогда
		Если ДанныеОбмена.МодельАгрегата_ПометкаУдаления Тогда
			Возврат Истина;
		КонецЕсли;
		Если ДанныеОбмена.МодельАгрегата_ЭтоГруппа Тогда
			МодельАгрегатОбъект = Справочники.уатМоделиАгрегатов.СоздатьГруппу();
		Иначе
			МодельАгрегатОбъект = Справочники.уатМоделиАгрегатов.СоздатьЭлемент();
		КонецЕсли;
		МодельАгрегатОбъект.УстановитьСсылкуНового(МодельАгрегатСсылка);
	Иначе	
		МодельАгрегатОбъект = МодельАгрегатСсылка.ПолучитьОбъект();	
	КонецЕсли;
	
	МодельАгрегатОбъект.Наименование = ДанныеОбмена.МодельАгрегата_Наименование;
	МодельАгрегатОбъект.Родитель = ОбработкаГрупп(ДанныеОбмена.МодельАгрегата_Родитель, ДанныеОбмена.МодельАгрегата_РодительНаименование, "уатМоделиАгрегатов");
	МодельАгрегатОбъект.ПометкаУдаления = ДанныеОбмена.МодельАгрегата_ПометкаУдаления;
	
	Если НЕ ДанныеОбмена.МодельАгрегата_ЭтоГруппа Тогда
		Если ОбработкаXML_ТипыАгрегатов(ДанныеОбмена) Тогда
			МодельАгрегатОбъект.ТипАгрегата = Справочники.уатТипыАгрегатов.НайтиПоНаименованию(ДанныеОбмена.ТипАгрегата_Наименование).Ссылка;
		КонецЕсли;
		Если МодельАгрегатОбъект.ТипАгрегата = Справочники.уатТипыАгрегатов.Шина Тогда
			МодельАгрегатОбъект.ШинаВысота = ОбработкаXML_ВысотаШин(ДанныеОбмена);
			МодельАгрегатОбъект.ШинаШирина = ОбработкаXML_ШиринаШин(ДанныеОбмена);
			МодельАгрегатОбъект.ШинаДиаметр = ОбработкаXML_РадиусШин(ДанныеОбмена);
			Если ДанныеОбмена.Свойство("МодельАгрегата_ШинаТипКонструкции") И ДанныеОбмена.МодельАгрегата_ШинаТипКонструкции <> "" Тогда
				МодельАгрегатОбъект.ШинаТипКонструкции = Перечисления.уатТипыКонструкцииШин[ДанныеОбмена.МодельАгрегата_ШинаТипКонструкции];	
			КонецЕсли;
				
			МодельАгрегатОбъект.Модель = ДанныеОбмена.МодельАгрегата_Модель;
			Если ДанныеОбмена.МодельАгрегата_ШинаСезонность <> "" Тогда
				МодельАгрегатОбъект.ШинаСезонность = Перечисления.уатСезонностьШин[ДанныеОбмена.МодельАгрегата_ШинаСезонность];
			КонецЕсли;
			МодельАгрегатОбъект.ВариантНачисленияИзноса = Перечисления.уатВариантыНачисленияИзносаАгрегатов.Выработка;
			МодельАгрегатОбъект.НормаПробега = ДанныеОбмена.МодельАгрегата_НормаПробега;
		ИначеЕсли МодельАгрегатОбъект.ТипАгрегата = Справочники.уатТипыАгрегатов.Аккумулятор Тогда
			МодельАгрегатОбъект.ВариантНачисленияИзноса = Перечисления.уатВариантыНачисленияИзносаАгрегатов.Период;
			МодельАгрегатОбъект.Емкость = ОбработкаXML_ЕмкостьАккумулятор(ДанныеОбмена);
			МодельАгрегатОбъект.СрокСлужбы = ДанныеОбмена.МодельАгрегата_СрокСлужбы;
			
		КонецЕсли;
	КонецЕсли;
	
	
	Попытка
		МодельАгрегатОбъект.Записать();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

