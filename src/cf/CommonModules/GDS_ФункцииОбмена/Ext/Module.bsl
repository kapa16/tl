Функция ОбработкаXML_ЗаявкаНаРемонт_GMG_MKM(ДанныеОбмена)
	
	сс="";
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ref);
	ДокументСсылка = Документы.уатЗаявкаНаРемонт.ПолучитьСсылку(УИН);
	Если Найти(строка(ДокументСсылка),"<Объект не найден>")>0 Тогда
		ДокументОбъект = Документы.уатЗаявкаНаРемонт.СоздатьДокумент();
		ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);
	Иначе
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ДокументОбъект.Дата = XMLЗначение(Тип("Дата"), ДанныеОбмена.Date);
	ДокументОбъект.ДатаНачала = XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаНачала);
	ДокументОбъект.ДатаОкончания = XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаОкончания);
	
	ТС = Справочники.уатТС.НайтиПоРеквизиту("ГосударственныйНомер", ДанныеОбмена.ГосударственныйНомер);
	Если ТС <> Справочники.уатТС.ПустаяСсылка()
		или ТС <> Неопределено Тогда
		
		ДокументОбъект.ТС = ТС;
		
	КонецЕсли;
	
	ДокументОбъект.Комментарий = ДанныеОбмена.Комментарий;
	//ДокументОбъект.Ответственный = ДанныеОбмена.Ответственный;
	
	ДокументОбъект.ПричинаОбращения = ДанныеОбмена.ПричинаОбращения;
	
	Если ДанныеОбмена.СпособРемонта = "Автосервис" Тогда
		ДокументОбъект.СпособРемонта = Перечисления.уатСпособыРемонта.Автосервис;
	КонецЕсли;
	
	Если ДанныеОбмена.СтатусВыполнения = "Новый" Тогда
		СтатусВыполнения = Справочники.уатСтатусы_уэ.Новый;
	КонецЕсли;
	
	ДокументОбъект.СтатусВыполнения = СтатусВыполнения;
	
	ДокументОбъект.Организация = Справочники.Организации.НайтиПоРеквизиту("ИНН", ДанныеОбмена.Организация_ИНН);
	
	ДокументОбъект.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеОбмена.Контрагент_ИНН);
	ДокументОбъект.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.НайтиПоРеквизиту("Номер", ДанныеОбмена.ДоговорКонтрагента_Номер);
	
	Попытка
		ДокументОбъект.Записать();
	Исключение
		
		Возврат Ложь;
	КонецПопытки;
	
	GDS_ДополнительныеФункции.ПроверкаАвторизацииДляЗапуска();
	
	ДанныеВозврата = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ДокументОбъект.Ссылка);
	Если ДанныеВозврата = Неопределено 
		И ДанныеОбмена.Свойство("ОбъектДОID") Тогда
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДобавитьСвязь(ДанныеОбмена.ОбъектДОID, ДанныеОбмена.ОбъектДОТип, ДокументОбъект.Ссылка);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти
