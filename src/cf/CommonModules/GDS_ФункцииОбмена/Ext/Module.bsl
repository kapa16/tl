Функция ОбработкаXML_ТСИОборудование(ДанныеОбмена)
	
	НовСтр = РегистрыСведений.GDS_ТСИОборудование.СоздатьМенеджерЗаписи();
	
	НовСтр.Период      = ДанныеОбмена.Период;
	НовСтр.ТС 	       = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТС));
	Если Найти(строка(НовСтр.ТС),"<Объект не найден>")>0 Тогда
		Возврат Истина;	
	КонецЕсли;
    НовСтр.Состояние   = Перечисления.GDS_СостоянияТахографа;
	НовСтр.НетНеобходимости = ДанныеОбмена.НетНеобходимости;
	НовСтр.ДатаУстановкиАктивации = ДанныеОбмена.ДатаУстановкиАктивации;
	НовСтр.СрокДействия = ДанныеОбмена.СрокДействия;
	НовСтр.СерийныйНомер = ДанныеОбмена.СерийныйНомер;
	НовСтр.ШтатныйТахограф = ДанныеОбмена.ШтатныйТахограф;
	НовСтр.ПУ = Справочники.уатКолонны.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ПУ));
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ТипТахографа_УИД);
	ТипТахографаСсылка = Справочники.GDS_ТипыТахогрофов.ПолучитьСсылку(УИН);
	Если Найти(Строка(ТипТахографаСсылка), "<Объект не найден>") > 0 Тогда
		ТипТахографаОбъект = Справочники.GDS_ТипыТахогрофов.СоздатьЭлемент();
		ТипТахографаОбъект.УстановитьСсылкуНового(ТипТахографаСсылка);
	Иначе	
		ТипТахографаОбъект = ТипТахографаСсылка.ПолучитьОбъект();	
	КонецЕсли;	
	ТипТахографаОбъект.Наименование = ДанныеОбмена.ТипТахографа_Наименование;
	ТипТахографаОбъект.Записать();
	НовСтр.ТипТахографа = ТипТахографаСсылка;
	
	Если ДанныеОбмена.КомпанияУстановщик_ИНН <> "" Тогда
		КомпанияУстановщикСсылка = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеОбмена.КомпанияУстановщик_ИНН);
		Если КомпанияУстановщикСсылка = Справочники.Контрагенты.ПустаяСсылка() Тогда
			КомпанияУстановщикОбъект = Справочники.Контрагенты.СоздатьЭлемент();
		Иначе	
			КомпанияУстановщикОбъект = КомпанияУстановщикСсылка.ПолучитьОбъект();	
		КонецЕсли;
		КомпанияУстановщикОбъект.Наименование = ДанныеОбмена.КомпанияУстановщик_Наименование;
		КомпанияУстановщикОбъект.НаименованиеПолное = ДанныеОбмена.КомпанияУстановщик_НаименованиеПолное;
		КомпанияУстановщикОбъект.ИНН = ДанныеОбмена.КомпанияУстановщик_ИНН;
		КомпанияУстановщикОбъект.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо[СтрЗаменить(ДанныеОбмена.КомпанияУстановщик_ЮрФизЛицо, " ", "")];
		КомпанияУстановщикОбъект.Записать();
		НовСтр.КомпанияУстановщик = КомпанияУстановщикСсылка;
		
		НовСтр.Примечание = ДанныеОбмена.Примечание;
	КонецЕсли;
	
	НовСтр.Записать();
	
КонецФункции

Функция ОбработкаXML_МатериалыУАТ(ДанныеОбмена)

	Если ДанныеОбмена.МатериалыУАТ <> "" Тогда
		
		
		
		Счетчик = 0;
		
		Для Каждого Строка Из ДанныеОбмена.МатериалыУАТ Цикл
			
			Если Счетчик % 1000 = 0 Тогда
				ДокументОбъект = Документы.уатКорректировкаЗаписейРегистров.СоздатьДокумент();
				ДокументОбъект.Дата = Дата(2017, 1, 1);
				ДокументОбъект.Записать();
				
				ДокументОбъект.Движения.уатНоменклатураТС.Записывать = Истина;
			КонецЕсли;
			Движение = ДокументОбъект.Движения.уатНоменклатураТС.Добавить();
			ЗначениеСтроки = Строка.Значение;
			Движение.Регистратор = ДокументОбъект;
			Движение.Период = Дата(ЗначениеСтроки.ДатаОкончания);
			Движение.ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ЗначениеСтроки.ТранспортноеСредство));
			Движение.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ЗначениеСтроки.Номенклатура));
			Движение.Количество = ЗначениеСтроки.Количество;
			Движение.Стоимость = ЗначениеСтроки.Сумма;
			Движение.Регистратор = ДокументОбъект;
			
			ДокументОбъект.Движения.уатНоменклатураТС.Записать();
			
			Счетчик = Счетчик + 1;
		КонецЦикла;
	КонецЕсли;
	
КонецФункции

Функция ОбработкаXML_СоставТС(ДанныеОбмена)
	Прицеп = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТС_Прицеп_УИД));
	ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТС_УИД));
	Если Найти(Строка(ТС), "<Объект не найден>") = 0 И Найти(Строка(Прицеп), "<Объект не найден>") = 0 Тогда
		НовЗапись = РегистрыСведений.уатСоставТС.СоздатьМенеджерЗаписи();
		НовЗапись.ТС = Прицеп;
		НовЗапись.ВСоставе = ТС;
		Попытка
			НовЗапись.Записать();
			Возврат Истина;
		Исключение
			Возврат Ложь;
		КонецПопытки
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ОбработкаXML_НоменклатураГСМ(ДанныеОбмена)
	Узел = ПланыОбмена[ДанныеОбмена.ПланОбмена].НайтиПоКоду(ДанныеОбмена.УзелИнформационнойБазы);

	Менеджеры = Новый Структура();
	Менеджеры.Вставить("Узел", Узел);
	Менеджеры.Вставить("Менеджер", Справочники.Номенклатура);
	Менеджеры.Вставить("ИмяТипа", "Справочник"); 
	Менеджеры.Вставить("Имя", "Номенклатура"); 

	Возврат НайтиИлиСоздатьОбъект(Менеджеры, ДанныеОбмена);
	
КонецФункции

Функция ОбработкаXML_Контрагент(ДанныеОбмена, ДополнительныеСвойства)
	
	Если ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ИНН"] = "" Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Организации.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Организации КАК Организации
	               |ГДЕ
	               |	Организации.ИНН = &ИНН";
	Запрос.УстановитьПараметр("ИНН", ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ИНН"]);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Справочники.Организации.ОрганизацияПоУмолчанию();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Контрагенты.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.ИНН = &ИНН";
	Запрос.УстановитьПараметр("ИНН", ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ИНН"]);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ОбъектКонтрагент = ВыборкаДетальныеЗаписи.Ссылка;
		Возврат ОбъектКонтрагент;
	Иначе
		ОбъектКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
		Попытка
			ОбъектКонтрагент.ЮридическоеФизическоеЛицо 	= Перечисления.ЮридическоеФизическоеЛицо[ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ВидКонтрагента"]];
			ОбъектКонтрагент.Наименование 				= ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_Наименование"];
			ОбъектКонтрагент.НаименованиеПолное 		= ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ПолноеНаименование"];
			ОбъектКонтрагент.ИНН 						= ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_ИНН"];
			ОбъектКонтрагент.КПП 						= ДанныеОбмена["ТС_" + ДополнительныеСвойства + "_КПП"];
		Исключение
			Возврат Справочники.Контрагенты.ПустаяСсылка();
		КонецПопытки;		
	КонецЕсли;
	
	Попытка
		ОбъектКонтрагент.Записать();
		Возврат ОбъектКонтрагент.Ссылка;
	Исключение
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецПопытки;
	
КонецФункции

Функция ОбработкаXML_НормыРасходаГСМ(ДанныеОбмена)
	Если ДанныеОбмена.Свойство("ТС") Тогда
		Если XMLЗначение(Тип("Булево"), ДанныеОбмена.ТС) = Истина Тогда
			МодельТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.НРГСМ_МодельТС))
		Иначе
			МодельТС = Справочники.уатМоделиТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.НРГСМ_МодельТС))
		КонецЕсли;
	КонецЕсли;
	Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	Период = XMLЗначение(Тип("Дата"), ДанныеОбмена.НРГСМ_Период);
	Номенклатура = ОбработкаXML_НоменклатураГСМ(ДанныеОбмена);
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат Ложь;	   	
	КонецЕсли;
	Если Найти(Строка(МодельТС), "<Объект не найден>") = 0 Тогда
		Запись = РегистрыСведений.уатНормыРасходаГСМ.СоздатьМенеджерЗаписи();
		Запись.Организация = Организация;
		Запись.МодельТС = МодельТС;
		Запись.ГСМ = Номенклатура;
		Запись.Период = Период;
		
		Запись.ЛинейнаяНорма = ДанныеОбмена.НРГСМ_ЛинейнаяНорма;
		Запись.НормаНаЕздку = ДанныеОбмена.НРГСМ_НормаНаЕздку;
		Запись.НормаНаЗапуск = ДанныеОбмена.НРГСМ_НормаНаЗапуск;
		Запись.НормаНаИзменениеСобственногоВеса = ДанныеОбмена.НРГСМ_НормаНаИзменениеСобственногоВеса;
		Запись.НормаНаОперацию = ДанныеОбмена.НРГСМ_НормаНаОперацию;
		Запись.НормаНаОтопитель = ДанныеОбмена.НРГСМ_НормаНаОтопитель;
		Запись.НормаНаПростойСВклДвигателем = ДанныеОбмена.НРГСМ_НормаНаПростойСВклДвигателем;
		Запись.НормаНаПростойСВклДвигателемЛитры = ДанныеОбмена.НРГСМ_НормаНаПростойСВклДвигателемЛитры;
		Запись.НормаНаПростойСВклДвигателемПроцентомОтБазовой = ДанныеОбмена.НРГСМ_НормаНаПростойСВклДвигателемПроцентомОтБазовой;
		Запись.НормаНаПредПЖД = ДанныеОбмена.НРГСМ_НормаНаПредПЖД;
		Запись.НормаНаБулиты = ДанныеОбмена.НРГСМ_НормаНаБулиты;
		Запись.СезоннаяНадбавка = ДанныеОбмена.НРГСМ_СезоннаяНадбавка;
		Запись.НадбавкаНаКондиционер = ДанныеОбмена.НРГСМ_НадбавкаНаКондиционер;
		Запись.УчитыватьПростоиДляРасчетаНормыМоточасов = ДанныеОбмена.НРГСМ_УчитыватьПростоиДляРасчетаНормыМоточасов;
		Запись.НормаНаТранспортнуюРаботу = ДанныеОбмена.НРГСМ_НормаНаТранспортнуюРаботу;
		Запись.НормаСпециальнаяНаМоточас = ДанныеОбмена.НРГСМ_НормаСпециальнаяНаМоточас;
		Если ДанныеОбмена.НРГСМ_СпециальнаяРабота1 <> "" Тогда
			Запись.СпециальнаяРабота1 = Справочники.уатПараметрыВыработки.НайтиПоНаименованию(ДанныеОбмена.НРГСМ_СпециальнаяРабота1);
		    Запись.НормаНаСпециальнуюРаботу1 = ДанныеОбмена.НРГСМ_НормаНаСпециальнуюРаботу1;
		КонецЕсли;
		
		Попытка
			Запись.Записать(Истина);
			Возврат Истина;
		Исключение
			Возврат Ложь;
		КонецПопытки
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	
КонецФункции

Функция ОбработкаXML_РегистрационныеДокументы(ДанныеОбмена) 
	
	Попытка
		
		УИД = Новый УникальныйИдентификатор(ДанныеОбмена.РегДок_УникальныйИдентификатор);
		ДокументСсылка = Справочники.уатРегистрационныеДокументы.ПолучитьСсылку(УИД);	
		Если ДокументСсылка.Пустая() или Найти(СокрЛП(ДокументСсылка),"<Объект не найден>")>0 Тогда
			Если ДанныеОбмена.РегДок_ПометкаУдаления Тогда
				Возврат Истина;
			КонецЕсли;
			ДокументОбъект = Справочники.уатРегистрационныеДокументы.СоздатьЭлемент();
			ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);
			ДокументОбъект.УстановитьНовыйКод();
		Иначе
			ДокументОбъект = ДокументСсылка.ПолучитьОбъект();	
		КонецЕсли;
		
		Если ДанныеОбмена.Свойство("РегДок_ПринадлежностьДокументов") Тогда
			Если ДанныеОбмена.РегДок_ПринадлежностьДокументов = "ДокументыТС" Тогда
				ДокументОбъект.ВладелецДокументов = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТС_УИД));
				Если Найти(Строка(ДокументОбъект.ВладелецДокументов), "<Объект не найден>") > 0 Тогда
					Возврат Истина;	
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
		
		ДанныеОбмена1 = ДанныеОбмена;
		
		ДокументОбъект.Наименование = ДанныеОбмена.РегДок_Наименование;
		ДокументОбъект.ПометкаУдаления = СокрЛП(ДанныеОбмена.РегДок_ПометкаУдаления);
		
		ДанныеОбмена = ДанныеОбмена1;
		
		ДокументОбъект.Статус = Перечисления.уатСтатусыДействия[ДанныеОбмена.РегДок_Статус];
		ДокументОбъект.ДатаВыдачи = XMLЗначение(Тип("Дата"),ДанныеОбмена.РегДок_ДатаНачала);
		ДокументОбъект.ДатаОкончания = XMLЗначение(Тип("Дата"),ДанныеОбмена.РегДок_СрокДействия);
		ДокументОбъект.Серия = СокрЛП(ДанныеОбмена.РегДок_Серия);
		ДокументОбъект.Номер = СокрЛП(ДанныеОбмена.РегДок_Номер);
		ДокументОбъект.КемВыдан = СокрЛП(ДанныеОбмена.РегДок_КемВыдан);
		ДокументОбъект.Комментарий = СокрЛП(ДанныеОбмена.РегДок_Комментарий);
		ДокументОбъект.ВидДокумента = ПолучитьВидДокументаРегДок(ДанныеОбмена);	
		ДокументОбъект.ПринадлежностьДокументов = Перечисления.уатПринадлежностьДокументов[ДанныеОбмена.РегДок_ПринадлежностьДокументов];
		
		Если Не ЗначениеЗаполнено(ДокументОбъект.ВидДокумента) Тогда
			Возврат Ложь;
		КонецЕсли;	
		ДокументОбъект.ОбменДанными.Загрузка = Истина;
		ДокументОбъект.Записать();  
		
		//установка саязи объекта ИС с ДО
		ИмяПользователяДО = Константы.ИнтеграцияС1СДокументооборотИмяПользователяДляОбмена.Получить();
		ПарольДО = Константы.ИнтеграцияС1СДокументооборотПарольДляОбмена.Получить();
		
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьНастройкиАвторизацииВПараметрыСеанса(ИмяПользователяДО, ПарольДО, Ложь, Ложь);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьВерсиюСервисаВПараметрыСеанса();
		
		ДанныеСвязи = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ДокументОбъект.Ссылка);
		
		СоединениеWS = ПолучитьДанныеОWS_УП();
		
		Данные = СоединениеWS.ВернутьДанныеПоЗапросу("ВернутьУИДОбъектаДО_ТЛ", ДанныеОбмена.РегДок_УникальныйИдентификатор, ТекущаяДата());
		
		XML_Строка = Данные.Получить();
		
		СписокПолученныхДанных = РазобратьПолученныеДанные(XML_Строка);
		
		СписокДанных = СписокПолученныхДанных[0].Значение;
		
		Если ДанныеСвязи = Неопределено Тогда 	
			// Добавление новой связи.
			ОбъектДОID = СокрЛП(СписокДанных.ID);
			ОбъектДОТип = СокрЛП("DMDocument");
			Если ЗначениеЗаполнено(ОбъектДОID) И ЗначениеЗаполнено(ОбъектДОТип) Тогда
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДобавитьСвязь(ОбъектДОID, ОбъектДОТип, ДокументОбъект.Ссылка);
			КонецЕсли;
		КонецЕсли;
		
		ДокументОбъект.Записать();
		Возврат Истина;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Возврат Ложь;
	КонецПопытки;
	
	ОбъектСсылка = ДокументОбъект.Ссылка;
	
		
КонецФункции

Функция ОбработкаXML_МестонахождениеТС(ДанныеОбмена)
	
	Попытка
		ПериодДата = XMLЗначение(Тип("Дата"),ДанныеОбмена.Местонахождение_Период);
		ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Местонахождение_ТС));
		Колонна = Справочники.уатКолонны.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Местонахождение_Колонна));
		Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Местонахождение_Подразделение));
		
		ДокументОбъект = Документы.уатКорректировкаЗаписейРегистров.СоздатьДокумент();
		ДокументОбъект.Дата = ТекущаяДатаСеанса();
		ДокументОбъект.Ответственный = Пользователи.ТекущийПользователь();
		
		НоваяСтрока = ДокументОбъект.ТаблицаРегистров.Добавить();
		НоваяСтрока.Имя = "уатМестонахождениеТС";
		
		ДокументОбъект.Движения.уатМестонахождениеТС.Записывать = Истина;
		
		Движение = ДокументОбъект.Движения.уатМестонахождениеТС.Добавить();
		Движение.Период = ПериодДата;
		Движение.ТС = ТС;
		Движение.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
		Движение.Колонна = Колонна;
		Движение.Подразделение = Подразделение;
		Движение.Регистратор = ДокументОбъект;
		
		ДокументОбъект.Записать();
		Возврат Истина
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция ОбработкаXML_АЗС(ДанныеОбмена)
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.АЗС_УИД);
	АЗССсылка = Справочники.уатАЗС.ПолучитьСсылку(УИН);
	Если Найти(Строка(АЗССсылка), "<Объект не найден>") > 0 Тогда
		Если ДанныеОбмена.АЗС_ПометкаУдаления Тогда
			Возврат Истина;
		КонецЕсли;
		АЗСОбъект = Справочники.уатАЗС.СоздатьЭлемент();
		АЗСОбъект.УстановитьСсылкуНового(АЗССсылка);
	Иначе	
		АЗСОбъект = АЗССсылка.ПолучитьОбъект();	
	КонецЕсли;
	
	АЗСОбъект.Наименование = ДанныеОбмена.АЗС_Наименование;
	АЗСОбъект.ПометкаУдаления = ДанныеОбмена.АЗС_ПометкаУдаления;
	АЗСОбъект.ЭтоАЗССклад = ДанныеОбмена.АЗС_ЭтоСклад;
	
	Если АЗСОбъект.ЭтоАЗССклад Тогда
		УИН = Новый УникальныйИдентификатор(ДанныеОбмена.СкладКонтрагент_Ссылка);
		СкладСсылка = Справочники.Склады.ПолучитьСсылку(УИН);
		Если Найти(Строка(СкладСсылка), "<Объект не найден>") > 0 Тогда
			Если ДанныеОбмена.СкладКонтрагент_ПометкаУдаления Тогда
				Возврат Истина;
			КонецЕсли;
			СкладОбъект = Справочники.Склады.СоздатьЭлемент();
			СкладОбъект.УстановитьСсылкуНового(СкладСсылка);
		Иначе
			Попытка
				СкладОбъект = СкладСсылка.ПолучитьОбъект();
			Исключение 
				АЗСОбъект.Записать();
				Возврат Истина;
			КонецПопытки;
		КонецЕсли;
		СкладОбъект.Наименование = ДанныеОбмена.СкладКонтрагент_Наименование;
		СкладОбъект.ПометкаУдаления = ДанныеОбмена.СкладКонтрагент_ПометкаУдаления;
		СкладОбъект.GDS_ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.СкладКонтрагент_ТС));
		Попытка
			СкладОбъект.Записать();
			АЗСОбъект.Контрагент_Склад = СкладОбъект.Ссылка;
		Исключение
		КонецПопытки;
	Иначе
		АЗСОбъект.Контрагент_Склад = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеОбмена.СкладКонтрагент_ИНН);
	КонецЕсли;
	
	Попытка
		АЗСОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;			
КонецФункции

Функция ОбработкаXML_ТК(ДанныеОбмена)
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ТК_УИД);	
	ТКСсылка = Справочники.уатПластиковыеКарты.ПолучитьСсылку(УИН);
	
	Если Найти(строка(ТКСсылка),"<Объект не найден>")>0 Тогда
		ТКСсылкаПоКоду = Справочники.уатПластиковыеКарты.НайтиПоКоду(СокрЛП(ДанныеОбмена.ТК_Код));
		Если ЗначениеЗаполнено(ТКСсылкаПоКоду) Тогда
			Возврат Истина;	
		КонецЕсли;
		Если ДанныеОбмена.ТК_ПометкаУдаления Тогда
			Возврат Истина;	
		КонецЕсли;
		ТКОбъект = Справочники.уатПластиковыеКарты.СоздатьЭлемент();
		ТКОбъект.УстановитьСсылкуНового(ТКСсылка);
	Иначе
		ТКОбъект = ТКСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ТКОбъект.Код = СокрЛП(ДанныеОбмена.ТК_Код);
	ТКОбъект.ПометкаУдаления = ДанныеОбмена.ТК_ПометкаУдаления;
	ТКОбъект.ДатаВыдачи			 = Дата(ДанныеОбмена.ТК_ДатаВыдачи);
	Если ДанныеОбмена.ТК_ЭтоАЗС Тогда
		Если Найти(строка(Справочники.уатАЗС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТК_КемВыдана))),"<Объект не найден>") = 0 Тогда 
			ТКОбъект.КемВыдана = Справочники.уатАЗС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТК_КемВыдана));
		Иначе
			Возврат Истина;
		КонецЕсли;
	Иначе
		ТКОбъект.КемВыдана = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеОбмена.ТК_ИНН);	
	КонецЕсли;
	
	Если ДанныеОбмена.ТК_КомуВыдана <> "" Тогда
		Если ДанныеОбмена.ТК_ЭтоТС Тогда
			Если Найти(строка(Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТК_КомуВыдана))),"<Объект не найден>") = 0 Тогда
				ТКОбъект.КомуВыдана = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТК_КомуВыдана));
			КонецЕсли;
		Иначе
			ТКОбъект.КомуВыдана = Справочники.Сотрудники.НайтиПоРеквизиту("Код", ДанныеОбмена.ТК_ТабНомер);	
		КонецЕсли;
	КонецЕсли;
	ТКОбъект.Статус = Справочники.уатСтатусыТопливныхКарт.Действует;
	
	Попытка
		ТКОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;		
КонецФункции

Функция ОбработкаXML_СоответствиеПУ(ДанныеОбмена)
	Попытка
		
		ДанныеОбмена.Вставить("ПланОбмена", "GDS_ОбменСУАТ");
		ДанныеОбмена.Вставить("УзелИнформационнойБазы", "СТ");
		
		Узел = ПланыОбмена[ДанныеОбмена.ПланОбмена].НайтиПоКоду(ДанныеОбмена.УзелИнформационнойБазы);

		МенеджерыПУ = Новый Структура();
		МенеджерыПУ.Вставить("Узел", Узел);
		МенеджерыПУ.Вставить("Менеджер", Справочники.уатНаправленияПеревозок);
		МенеджерыПУ.Вставить("ИмяТипа", "Справочник"); 
		МенеджерыПУ.Вставить("Имя", "ПУ");
		
		МенеджерыПодразделения = Новый Структура();
		МенеджерыПодразделения.Вставить("Узел", Узел);
		МенеджерыПодразделения.Вставить("Менеджер", Справочники.ПодразделенияОрганизаций);
		МенеджерыПодразделения.Вставить("ИмяТипа", "Справочник"); 
		МенеджерыПодразделения.Вставить("Имя", "Подразделение");
		
		Колонна = Справочники.уатКолонны.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Колонна));
		ТипТС = Справочники.уатТипыТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТипТС));
		ТипПрицепа = Справочники.уатТипыТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТипПрицепа));
		Подразделение = НайтиИлиСоздатьОбъект(МенеджерыПодразделения, ДанныеОбмена);
		ПУ = НайтиИлиСоздатьОбъект(МенеджерыПУ, ДанныеОбмена);
		
		НовЗапись = РегистрыСведений.GDS_СоответствиеТСиПУПодразделению.СоздатьМенеджерЗаписи();
		НовЗапись.Колонна = Колонна;
		НовЗапись.ТипТС = ТипТС;
		НовЗапись.ТипПрицепа = ТипПрицепа;
		НовЗапись.Подразделение = Подразделение;
		НовЗапись.ПУ = ПУ;
		НовЗапись.Записать(Истина);
		Возврат Истина
	Исключение
		Возврат Ложь;
	КонецПопытки;			
КонецФункции

Функция ОбработкаXML_ПривлеченныйВодитель(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.Водитель_УИН);	
	СотрудникСсылка = Справочники.Сотрудники.ПолучитьСсылку(УИН);
	
	Если Найти(строка(СотрудникСсылка),"<Объект не найден>")>0 Тогда
		СотрудникОбъект = Справочники.Сотрудники.СоздатьЭлемент();
		СотрудникОбъект.УстановитьСсылкуНового(СотрудникСсылка);
	Иначе
		СотрудникОбъект = СотрудникСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	СотрудникОбъект.Наименование = ДанныеОбмена.Сотрудник_Наименование;		
	СотрудникОбъект.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	СотрудникОбъект.Подразделение = Справочники.ПодразделенияОрганизаций.НайтиПоНаименованию("Бригада № 50-ПЛ");
	СотрудникОбъект.Должность = Справочники.Должности.НайтиПоНаименованию("Водитель автомобиля");
	СотрудникОбъект.ДатаПриема = Дата(2026, 6, 1);
	
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ВодительФЛ_УИН);	
	ФизическоеЛицоСсылка = Справочники.ФизическиеЛица.ПолучитьСсылку(УИН);
	Если Найти(Строка(ФизическоеЛицоСсылка), "<Объект не найден>") > 0 Тогда
		ФизическоеЛицоОбъект = Справочники.ФизическиеЛица.СоздатьЭлемент();
		ФизическоеЛицоОбъект.УстановитьСсылкуНового(ФизическоеЛицоСсылка);
	Иначе
		ФизическоеЛицоОбъект = ФизическоеЛицоСсылка.ПолучитьОбъект();
	КонецЕсли;
	ФизическоеЛицоОбъект.ФИО = ДанныеОбмена.Сотрудник_Наименование;
	ФизическоеЛицоОбъект.Наименование = ДанныеОбмена.Сотрудник_Наименование;
	Попытка
		ФизическоеЛицоОбъект.Записать();
	Исключение
	КонецПопытки;
	
	СотрудникОбъект.ФизическоеЛицо = ФизическоеЛицоСсылка;
	
	
	Попытка
		СотрудникОбъект.Записать();
		НовЗапись = РегистрыСведений.уатКадроваяИсторияСотрудников.СоздатьМенеджерЗаписи();
		НовЗапись.Период 				= Дата(2026, 6, 1);
		НовЗапись.Сотрудник 		= СотрудникОбъект.Ссылка;
		НовЗапись.Организация 	= Справочники.Организации.ОрганизацияПоУмолчанию();
		НовЗапись.Подразделение	= Справочники.ПодразделенияОрганизаций.НайтиПоНаименованию("Бригада № 50-ПЛ");
		НовЗапись.Должность			= Справочники.Должности.НайтиПоНаименованию("Водитель автомобиля");
		НовЗапись.Записать(Истина);
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;				
КонецФункции
