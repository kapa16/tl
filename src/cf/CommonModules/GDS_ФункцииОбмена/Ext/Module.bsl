Функция ОбработкаXML_Номенклатура(ДанныеОбмена)
	
	Если ДанныеОбмена.Номенклатура_УИД = "" Тогда 
		Возврат Истина;	
	КонецЕсли;
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.Номенклатура_УИД);
	
	НоменклатураСсылка = Справочники.Номенклатура.ПолучитьСсылку(УИН);
	
	Если Найти(Строка(НоменклатураСсылка), "<Объект не найден>") > 0 Тогда
		Если ДанныеОбмена.Номенклатура_ПометкаУдаления Тогда
			Возврат Истина;	
		КонецЕсли;
		
		Если НЕ ДанныеОбмена.Номенклатура_ЭтоГруппа Тогда
			НоменклатураОбъект = Справочники.Номенклатура.СоздатьЭлемент();
		Иначе
			НоменклатураОбъект = Справочники.Номенклатура.СоздатьГруппу();
		КонецЕсли;
		НоменклатураОбъект.УстановитьСсылкуНового(НоменклатураСсылка);
	Иначе
		НоменклатураОбъект = НоменклатураСсылка.ПолучитьОбъект();
	КонецЕсли;                                                       
	
	НоменклатураОбъект.Наименование = ДанныеОбмена.Номенклатура_Наименование;
	НоменклатураОбъект.ПометкаУдаления = ДанныеОбмена.Номенклатура_ПометкаУдаления;
	НоменклатураОбъект.Родитель = ОбработкаГрупп(ДанныеОбмена.Номенклатура_Родитель_УИД, ДанныеОбмена.Номенклатура_Родитель_Наименование, "Номенклатура");
	
	Если Не ДанныеОбмена.Номенклатура_ЭтоГруппа Тогда
		НоменклатураОбъект.GDS_КодНСИ = ДанныеОбмена.Номенклатура_КодНСИ;
		Если ДанныеОбмена.Номенклатура_Услуга Тогда
			НоменклатураОбъект.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Услуга");
		Иначе
			НоменклатураОбъект.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Товар");
		КонецЕсли;                                                                                         
		НоменклатураОбъект.ЕдиницаИзмерения = ПервоначальноеСозданиеЕдиницИзмерения(ДанныеОбмена);
	КонецЕсли;
	
	Попытка
		НоменклатураОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

