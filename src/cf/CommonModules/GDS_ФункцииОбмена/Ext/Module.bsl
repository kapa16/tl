Функция ПервоначальноеСозданиеПоискМоделиТС(ДанныеОбмена)
	Если ДанныеОбмена.МодельТС_Наименование = "" Тогда
		Возврат Справочники.уатМоделиТС.ПустаяСсылка();
	КонецЕсли;
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.МодельТС_УИД);
	МодельСсылка = Справочники.уатМоделиТС.ПолучитьСсылку(УИН);
	Если Найти(строка(МодельСсылка),"<Объект не найден>")>0 Тогда
		МодельТСОбъект = Справочники.уатМоделиТС.СоздатьЭлемент();
		МодельТСОбъект.УстановитьСсылкуНового(Справочники.уатМоделиТС.ПолучитьСсылку(УИН));
		МодельТСОбъект.Наименование = ДанныеОбмена.МодельТС_Наименование;
		МодельТСОбъект.ВидМоделиТС = Перечисления.уатВидыМоделейТС[ДанныеОбмена.МодельТС_ВидМоделиТС];
		МодельТСОбъект.Записать();
		Возврат МодельТСОбъект.Ссылка;
	Иначе
		Возврат МодельСсылка;
	КонецЕсли;
КонецФункции

Функция ПервоначальноеСозданиеПоискТипаТС(ДанныеОбмена)
	Если ДанныеОбмена.ТипТС_ПометкаУдаления ИЛИ ДанныеОбмена.ТипТС_УИД = "" Тогда
		Возврат Справочники.уатТипыТС.ПустаяСсылка();
	КонецЕсли;
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ТипТС_УИД);
	ТипСсылка = Справочники.уатТипыТС.ПолучитьСсылку(УИН);
	Если Найти(строка(ТипСсылка),"<Объект не найден>")>0 Тогда
		ТипТСОбъект = Справочники.уатТипыТС.СоздатьЭлемент();
		ТипТСОбъект.УстановитьСсылкуНового(Справочники.уатТипыТС.ПолучитьСсылку(УИН));
		ТипТСОбъект.Наименование = ДанныеОбмена.ТипТС_Наименование;
		ТипТСОбъект.Записать();
		Возврат ТипТСОбъект.Ссылка;
	Иначе
		Возврат ТипСсылка;
	КонецЕсли;	
КонецФункции

