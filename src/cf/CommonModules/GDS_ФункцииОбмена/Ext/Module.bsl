Функция ПервоначальноеСозданиеЕдиницИзмерения(ДанныеОбмена)
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ЕдиницаИзмерения_УИД);
	Код = ДанныеОбмена.ЕдиницаИзмерения_Код;
	
	Если Код = "" Тогда
		Возврат Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Код) И Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(Код) <> Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка() Тогда
		Возврат Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(Код);
	Иначе
		ЕИСсылка = Справочники.КлассификаторЕдиницИзмерения.ПолучитьСсылку(УИН);
		Если Найти(Строка(ЕИСсылка), "<Объект не найден>") Тогда
			ОбъектЕИ = Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
			ОбъектЕИ.УстановитьСсылкуНового(ЕИСсылка);
		Иначе
			ОбъектЕИ = ЕИСсылка.ПолучитьОбъект();
		КонецЕсли;
		
		ОбъектЕИ.Наименование = ДанныеОбмена.ЕдиницаИзмерения_Наименование;
		ОбъектЕИ.НаименованиеПолное = ДанныеОбмена.ЕдиницаИзмерения_НаименованиеПолное;
		ОбъектЕИ.Код		  = Код;
		
		Попытка
			ОбъектЕИ.Записать();
		Исключение
			Возврат Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
		КонецПопытки;
		
		Возврат ОбъектЕИ.Ссылка;
		
	КонецЕсли;
	
	
	
КонецФункции

Функция ПервоначальноеСозданиеПоискДолжности(ДанныеОбмена)
    
	Ссылка_Должность = Справочники.Должности.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Должность_УникальныйИдентификатор));
	
	Если Ссылка_Должность.Пустая() Или Найти(СокрЛП(Ссылка_Должность),"<Объект не найден>") <> 0 Тогда
		Если ДанныеОбмена.Свойство("Должность_Создать") И ДанныеОбмена.Должность_Создать Тогда
			Объект_Должность = Справочники.Должности.СоздатьЭлемент();
			Объект_Должность.УстановитьСсылкуНового(Ссылка_Должность);
		Иначе 
			Возврат Ссылка_Должность;
		КонецЕсли;
	Иначе 
		Объект_Должность = Ссылка_Должность.ПолучитьОбъект();
	КонецЕсли;
	
	Объект_Должность.Наименование = ДанныеОбмена.Должность_Наименование;
	Объект_Должность.GDS_ЯвляетсяВодительскойДолжностью = ДанныеОбмена.Должность_ЯвляетсяВодительскойДолжностью;
	Объект_Должность.GDS_КатегорияВоинскогоУчета = Перечисления.GDS_КатегорииДолжностейДляВоинскогоУчета[ДанныеОбмена.Должность_КатегорияВоинскогоУчета];
	Объект_Должность.ПометкаУдаления = ДанныеОбмена.Должность_ПометкаУдаления;
	Объект_Должность.Записать();         
	
	Ссылка_Должность = Объект_Должность.Ссылка;
	
	Возврат Ссылка_Должность;

КонецФункции

Функция ПервоначальноеСозданиеПоискПодразделени(ДанныеОбмена)
	
	ПустаяСсылка_Подразделения = Справочники.ПодразделенияОрганизаций.ПустаяСсылка();
	
	Если Не ЗначениеЗаполнено(ДанныеОбмена.Подразделение_УИД) Тогда
		Возврат ПустаяСсылка_Подразделения;
	КонецЕсли;	
		
	Ссылка_Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Подразделение_УИД));
	Если Ссылка_Подразделение.Пустая() Или Найти(СокрЛП(Ссылка_Подразделение),"<Объект не найден>") <> 0 Тогда
		Если ДанныеОбмена.Свойство("Подразделение_Создать") И ДанныеОбмена.Подразделение_Создать Тогда
			Объект_Подразделение = Справочники.ПодразделенияОрганизаций.СоздатьЭлемент();
			Объект_Подразделение.УстановитьСсылкуНового(Ссылка_Подразделение);
		Иначе
			УзелИнформационнойБазы = ПланыОбмена[ДанныеОбмена.ПланОбмена].НайтиПоКоду(ДанныеОбмена.УзелИнформационнойБазы);
			
			СтруктураЗаписи = Новый Структура();               
			СтруктураЗаписи.Вставить("УзелИнформационнойБазы", УзелИнформационнойБазы);
			СтруктураЗаписи.Вставить("УникальныйИдентификаторИсточника", ДанныеОбмена.Подразделение_УИД);
			СтруктураЗаписи.Вставить("ОписаниеИсточника", ДанныеОбмена.Подразделение_Наименование);
			СтруктураЗаписи.Вставить("СсылкаНаОбъект", ПустаяСсылка_Подразделения);     
			СтруктураЗаписи.Вставить("ТипИсточника", "ПодразделенияОрганизаций");
			СтруктураЗаписи.Вставить("ТипПриемника", "ПодразделенияОрганизаций");
			
			Возврат РегистрыСведений.GDS_СоответствияОбъектовИнформационныхБаз.НайтиЗапись(СтруктураЗаписи);
		КонецЕсли; 
	Иначе
		Объект_Подразделение = Ссылка_Подразделение.ПолучитьОбъект();
	КонецЕсли;
	
	Если ДанныеОбмена.Свойство("Подразделение_Родитель_УИД") Тогда
		СтруктураЗаписи = Новый Структура();               
		СтруктураЗаписи.Вставить("Подразделение_Создать", Истина);
		СтруктураЗаписи.Вставить("Подразделение_УИД", ДанныеОбмена.Подразделение_Родитель_УИД);
		СтруктураЗаписи.Вставить("Подразделение_Наименование", ДанныеОбмена.Подразделение_Родитель_Наименование);
		СтруктураЗаписи.Вставить("Подразделение_ПометкаУдаления", ?(ДанныеОбмена.Свойство("Подразделение_Родитель_ПометкаУдаления"), ДанныеОбмена.Подразделение_Родитель_ПометкаУдаления, Ложь));
		
		Родитель = ПервоначальноеСозданиеПоискПодразделени(СтруктураЗаписи); 
	Иначе 
		Родитель = ПустаяСсылка_Подразделения;
	КонецЕсли;
	
	Объект_Подразделение.Наименование = ДанныеОбмена.Подразделение_Наименование;
	Объект_Подразделение.ПометкаУдаления = ДанныеОбмена.Подразделение_ПометкаУдаления;
	Объект_Подразделение.Владелец = Справочники.Организации.ОрганизацияПоУмолчанию();
	Объект_Подразделение.Родитель = Родитель;
	Объект_Подразделение.Записать();
	
	Возврат Объект_Подразделение.Ссылка;
	
КонецФункции

//-
Функция НайтиИлиСоздатьОбъект(Менеджеры, ДанныеОбмена) Экспорт
	
	Имя = Менеджеры.Имя;
	ИмяТипа = Менеджеры.ИмяТипа;
	
	Ссылка = НайтиОбъект(Менеджеры, ДанныеОбмена);
	
	ОбъектНайден = НЕ (Ссылка = Неопределено ИЛИ Ссылка.Пустая()); 
	
	Если ИмяТипа = "Справочник" Тогда 
		Если ДанныеОбмена.Свойство(Имя + "_Создать") И XMLЗначение(Тип("Булево"), ДанныеОбмена[Имя + "_Создать"]) Тогда 
			
			Если Не ОбъектНайден Тогда 
				Объект = СоздатьНовыйОбъект(Менеджеры, ДанныеОбмена);
			Иначе
				Объект = Ссылка.ПолучитьОбъект();
			КонецЕсли;
			
			//Объект.Код = ДанныеОбмена[Имя + "_Код"];
			Объект.Наименование = ДанныеОбмена[Имя + "_Наименование"];
			Объект.ПометкаУдаления = ДанныеОбмена[Имя + "_ПометкаУдаления"];
		
			Если ДанныеОбмена.Свойство(Имя + "_Родитель_Наименование") И ЗначениеЗаполнено(ДанныеОбмена[Имя + "_Родитель_Наименование"]) Тогда 
				СтруктураОбъекта = Новый Структура;
				СтруктураОбъекта.Вставить(Имя + "_Создать", ДанныеОбмена[Имя + "_Создать"]); 
				СтруктураОбъекта.Вставить(Имя + "_УникальныйИдентификатор", ДанныеОбмена[Имя + "_Родитель_УникальныйИдентификатор"]); 
				СтруктураОбъекта.Вставить(Имя + "_Наименование", ДанныеОбмена[Имя + "_Родитель_Наименование"]);
				Если ДанныеОбмена.Свойство(Имя + "_Родитель_ЭтоГруппа") Тогда
					СтруктураОбъекта.Вставить(Имя + "_ЭтоГруппа", ДанныеОбмена[Имя + "_Родитель_ЭтоГруппа"]);
				КонецЕсли;
				СтруктураОбъекта.Вставить(Имя + "_ПометкаУдаления", ДанныеОбмена[Имя + "_Родитель_ПометкаУдаления"]); 
				
				Объект.Родитель = НайтиИлиСоздатьОбъект(Менеджеры, СтруктураОбъекта);
			КонецЕсли;
			
			Если Имя = "Подразделение" Тогда
				Если ДанныеОбмена.Свойство(Имя + "_Организация_ИНН") Тогда
					Объект.Владелец = ОрганизацияПоИНН(ДанныеОбмена[Имя + "_Организация_ИНН"]);
				Иначе
					Объект.Владелец = Справочники.Организации.ОрганизацияПоУмолчанию();
				КонецЕсли; 
			КонецЕсли; 

			Если (Имя = "ГрафикРаботы" 
				Или Имя = "РегистрационныйДокумент") 
				И Не XMLЗначение(Тип("Булево"), ДанныеОбмена[Имя + "_ЭтоГруппа"]) Тогда
				Объект.ОбменДанными.Загрузка = Истина;
			КонецЕсли; 
			
			Объект.Записать();
			
			Ссылка = Объект.Ссылка;
			
			Если ДанныеОбмена.Свойство(Имя + "_Родитель_ЭтоГруппа") Тогда
				Если XMLЗначение(Тип("Булево"), ДанныеОбмена[Имя + "_ЭтоГруппа"]) Тогда
					Возврат Ссылка;	
				КонецЕсли;
			КонецЕсли;
			
			
			Попытка
				Если ДанныеОбмена.Свойство(Имя + "_Объект") И XMLЗначение(Тип("Булево"), ДанныеОбмена[Имя + "_Объект"]) Тогда
					ИмяПроцедуры = СтрШаблон("Заполнить%1(Менеджеры, Ссылка, ДанныеОбмена)", Имя); 
					Выполнить(ИмяПроцедуры); 
				КонецЕсли;
			Исключение 
				Ошибка = ИнформацияОбОшибке();
				ОшибкаПодробно = ПодробноеПредставлениеОшибки(Ошибка);
				ЗаписьЖурналаРегистрации("Ошибки", УровеньЖурналаРегистрации.Ошибка,,, ОшибкаПодробно);

				Возврат Неопределено;
			КонецПопытки; 
			
		КонецЕсли;

	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции 

Функция НайтиОбъект(Менеджеры, ДанныеОбмена)
	
	Узел = Менеджеры.Узел; 
	Имя = Менеджеры.Имя;
	ИмяТипа = Менеджеры.ИмяТипа;
	Менеджер = Менеджеры.Менеджер; 
	
	Если ИмяТипа = "Справочник" Тогда 
		
		//Поиск предопределенных
		Если ДанныеОбмена.Свойство(Имя + "_Предопределенный") И ДанныеОбмена[Имя + "_Предопределенный"] Тогда
			Попытка
				Ссылка = Менеджер[ДанныеОбмена.ВидДокумента_ИмяПредопределенныхДанных];
				Возврат Ссылка;
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		//Поиск по уникальный идентификатор
		УИ = ДанныеОбмена[Имя + "_УникальныйИдентификатор"];
		Если УИ <> Неопределено Тогда
			Ссылка = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(УИ));
			Ссылка = ПроверитьСуществованиеСсылки(Ссылка, Менеджер);
		Иначе
			Ссылка = Неопределено;
		КонецЕсли;
		
		ОбъектНайден = НЕ (Ссылка = Неопределено ИЛИ Ссылка.Пустая()); 
		
		Если ОбъектНайден Тогда
			Возврат Ссылка;
		КонецЕсли;
		
		//Поиск по регистру соответствий
		Если Не ДанныеОбмена.Свойство(Имя + "_Создать") Или Не XMLЗначение(Тип("Булево"),ДанныеОбмена[Имя + "_Создать"]) Тогда
			СтруктураЗаписи = Новый Структура();               
			СтруктураЗаписи.Вставить("УзелИнформационнойБазы", Узел);
			СтруктураЗаписи.Вставить("УникальныйИдентификаторИсточника", ДанныеОбмена[Имя + "_УникальныйИдентификатор"]);
			СтруктураЗаписи.Вставить("ОписаниеИсточника", ДанныеОбмена[Имя + "_Наименование"]);
			СтруктураЗаписи.Вставить("СсылкаНаОбъект", Менеджеры.Менеджер.ПустаяСсылка());     
			СтруктураЗаписи.Вставить("ТипИсточника", Имя);     
			СтруктураЗаписи.Вставить("ТипПриемника", Имя);
			
			Ссылка = РегистрыСведений.GDS_СоответствияОбъектовИнформационныхБаз.НайтиЗапись(СтруктураЗаписи); 
		КонецЕсли; 
	
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Ссылка; 
	
КонецФункции 

Функция ПроверитьСуществованиеСсылки(Ссылка, Менеджер)
	
	Попытка
		НайденныйОбъектПоУникальномуИдентификатору = Ссылка.ПолучитьОбъект();
		Если НайденныйОбъектПоУникальномуИдентификатору = Неопределено Тогда
			Возврат Менеджер.ПустаяСсылка();
		КонецЕсли;
		Возврат Ссылка;	
	Исключение
		Возврат Менеджер.ПустаяСсылка();
	КонецПопытки;
	
КонецФункции

Функция СоздатьНовыйОбъект(Менеджеры, ДанныеОбмена)

	Имя = Менеджеры.Имя;
	ИмяТипа = Менеджеры.ИмяТипа;
    Менеджер = Менеджеры.Менеджер; 

	Если ИмяТипа = "Справочник" Тогда
		ЭтоГруппа = XMLЗначение(Тип("Булево"), ДанныеОбмена[Имя + "_ЭтоГруппа"]);
		Если ЭтоГруппа = Истина Тогда
			Объект = Менеджер.СоздатьГруппу();
		Иначе
			Объект = Менеджер.СоздатьЭлемент();
		КонецЕсли;
	КонецЕсли;
	
    НоваяСсылка = УстановитьСсылкуНового(Объект, Менеджеры, ДанныеОбмена);

	Возврат Объект;
	
КонецФункции

Функция УстановитьСсылкуНового(Объект, Менеджеры, ДанныеОбмена)
	
	Имя = Менеджеры.Имя;
    Менеджер = Менеджеры.Менеджер; 
	
	УИ = ДанныеОбмена[Имя + "_УникальныйИдентификатор"];
	Если УИ <> Неопределено Тогда
		НоваяСсылка = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(УИ));
		
		Объект.УстановитьСсылкуНового(НоваяСсылка);
	Иначе
		НоваяСсылка = Неопределено;
	КонецЕсли;
	
	Возврат НоваяСсылка;
	
КонецФункции

Процедура ЗаполнитьДолжность(Менеджеры, Ссылка, ДанныеОбмена)
	Объект = Ссылка.Получитьобъект(); 
	Объект.GDS_ЯвляетсяВодительскойДолжностью = ДанныеОбмена.Должность_ЯвляетсяВодительскойДолжностью;
	Объект.GDS_КатегорияВоинскогоУчета = ?(ЗначениеЗаполнено(ДанныеОбмена.Должность_КатегорияВоинскогоУчета),Перечисления.GDS_КатегорииДолжностейДляВоинскогоУчета[ДанныеОбмена.Должность_КатегорияВоинскогоУчета],"");
	Объект.Записать();
КонецПроцедуры

Процедура ЗаполнитьПодразделение(Менеджеры, Ссылка, ДанныеОбмена)

	Объект = Ссылка.Получитьобъект(); 
	Объект.Владелец = Справочники.Организации.ОрганизацияПоУмолчанию();
	Объект.Записать(); 
	
КонецПроцедуры

Процедура ЗаполнитьГрафикРаботы(Менеджеры, Ссылка, ДанныеОбмена)

	Объект = Ссылка.Получитьобъект(); 
	Объект.ДатаНачала = Дата(1990,1,1);
	Объект.СпособЗаполнения = Перечисления.СпособыЗаполненияГрафикаРаботы.ПоНеделям;
	Объект.Записать(); 
	
КонецПроцедуры

Процедура ЗаполнитьФизическоеЛицо(Менеджеры, Ссылка, ДанныеОбмена)

	Объект = Ссылка.Получитьобъект(); 

	Объект.ДатаРождения = XMLЗначение(Тип("Дата"), ДанныеОбмена.ФизическоеЛицо_ДатаРождения);
	Объект.Пол = Перечисления.ПолФизическогоЛица[ДанныеОбмена.ФизическоеЛицо_Пол];
	Объект.ИНН = XMLЗначение(Тип("Строка"), ДанныеОбмена.ФизическоеЛицо_ИНН);
	Объект.СтраховойНомерПФР = XMLЗначение(Тип("Строка"), ДанныеОбмена.ФизическоеЛицо_СНИЛС);
	
	Если ДанныеОбмена.Свойство("ФизическоеЛицо_АдресПоПропискеФизическиеЛица") Тогда	
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(Объект, ДанныеОбмена.ФизическоеЛицо_АдресПоПропискеФизическиеЛица, Справочники.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица, ТекущаяДата(), Истина);
	КонецЕсли; 
    Если ДанныеОбмена.Свойство("ФизическоеЛицо_АдресМестаПроживанияФизическиеЛица") Тогда	
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(Объект, ДанныеОбмена.ФизическоеЛицо_АдресМестаПроживанияФизическиеЛица, Справочники.ВидыКонтактнойИнформации.АдресМестаПроживанияФизическиеЛица, ТекущаяДата(), Истина);
	КонецЕсли;                  
	//Если ДанныеОбмена.Свойство("ФизическоеЛицо_ТелефонМобильныйФизическиеЛица") Тогда	
	//	УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(Объект, ДанныеОбмена.ФизическоеЛицо_ТелефонМобильныйФизическиеЛица, Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица, ТекущаяДата(), Истина);
	//КонецЕсли;                  
	Если ДанныеОбмена.Свойство("ФизическоеЛицо_ТелефонРабочийФизическиеЛица") Тогда	
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(Объект, ДанныеОбмена.ФизическоеЛицо_ТелефонРабочийФизическиеЛица, Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица, ТекущаяДата(), Истина);
	КонецЕсли;
	
	Объект.Записать();
	
	НаборЗаписейРегистра = РегистрыСведений.ФИОФизическихЛиц.СоздатьНаборЗаписей();
	НаборЗаписейРегистра.Отбор.ФизическоеЛицо.Установить(Ссылка);
	НаборЗаписейРегистра.Прочитать();
	НаборЗаписейРегистра.Очистить();

	Если ДанныеОбмена.ФИОФизическихЛиц <> "" Тогда
		Для каждого Запись Из ДанныеОбмена.ФИОФизическихЛиц Цикл
			НоваяСтрока = НаборЗаписейРегистра.Добавить();	
			НоваяСтрока.ФизическоеЛицо = Ссылка;
			НоваяСтрока.Период = XMLЗначение(Тип("Дата"), Запись.Значение.Период);
			НоваяСтрока.Фамилия = Запись.Значение.Фамилия;
			НоваяСтрока.Имя = Запись.Значение.Имя;
			НоваяСтрока.Отчество = Запись.Значение.Отчество;
		КонецЦикла;
	КонецЕсли; 
	
	НаборЗаписейРегистра.Записать();

	НаборЗаписейРегистра = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
	НаборЗаписейРегистра.Отбор.Физлицо.Установить(Ссылка);
	НаборЗаписейРегистра.Прочитать();
	НаборЗаписейРегистра.Очистить();
	
	Если ДанныеОбмена.ДокументыФизическихЛиц <> "" Тогда
		Для каждого Запись Из ДанныеОбмена.ДокументыФизическихЛиц Цикл
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.ВидыДокументовФизическихЛиц);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "ВидДокумента"); 
			
			ВидДокумента = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);  
	
			НоваяСтрока = НаборЗаписейРегистра.Добавить();	
			НоваяСтрока.Физлицо = Ссылка;
			НоваяСтрока.Период = XMLЗначение(Тип("Дата"), Запись.Значение.Период); 
			НоваяСтрока.ВидДокумента = ВидДокумента;
			НоваяСтрока.ДатаВыдачи =  XMLЗначение(Тип("Дата"),Запись.Значение.ДатаВыдачи);
