	ЗапросHTTP = Новый HTTPЗапрос(ПолучитьАдресРесурсаДляHTTPЗапроса("УАТ_СитэкТранс"), ЗаголовокЗапросаHTTP);
	ЗапросHTTP.УстановитьТелоИзСтроки(JSONОбъект, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);	
	
	HTTPОтвет = HTTPСоединение.ВызватьHTTPМетод("POST", ЗапросHTTP);
	
	HTTPСоединение = Неопределено;
	
	Возврат HTTPОтвет;
	
