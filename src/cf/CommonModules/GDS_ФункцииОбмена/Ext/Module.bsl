Процедура ЗаполнитьСотрудник(Менеджеры, Ссылка, ДанныеОбмена)

	Объект = Ссылка.Получитьобъект(); 
	
	НовыйМенеджер = Новый Структура();
	НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
	НовыйМенеджер.Вставить("Менеджер", Справочники.ФизическиеЛица);
	НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
	НовыйМенеджер.Вставить("Имя", "ФизическоеЛицо"); 
	
	ФизическоеЛицо = НайтиИлиСоздатьОбъект(НовыйМенеджер, ДанныеОбмена);
	
	Объект.Код = СокрЛП(ДанныеОбмена.Сотрудник_Код);
	Объект.ФизическоеЛицо = ФизическоеЛицо;
	Объект.ДатаУвольнения = Дата(1,1,1);
	
	НаборЗаписейРегистра = РегистрыСведений.уатКадроваяИсторияСотрудников.СоздатьНаборЗаписей();
	НаборЗаписейРегистра.Отбор.Сотрудник.Установить(Ссылка);
	НаборЗаписейРегистра.Прочитать();
	НаборЗаписейРегистра.Очистить();

	Если ДанныеОбмена.КадроваяИсторияСотрудника <> "" Тогда
		Для каждого Запись Из ДанныеОбмена.КадроваяИсторияСотрудника Цикл
			Если Запись.Значение.ВидСобытия = "Увольнение" Тогда
				Объект.ДатаУвольнения = XMLЗначение(Тип("Дата"), Запись.Значение.Период)-1;
			КонецЕсли;
			
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.Организации);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "Организация"); 
			
			Организация = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);
			
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.ПодразделенияОрганизаций);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "Подразделение"); 
			
			Подразделение = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);
			
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.Должности);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "Должность"); 
			
			Должность = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);
			
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.Календари);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "ГрафикРаботы"); 
			
			ГрафикРаботы = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);
			
			НоваяСтрока = НаборЗаписейРегистра.Добавить();	
			НоваяСтрока.Сотрудник = Ссылка; 
			НоваяСтрока.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
			НоваяСтрока.Период = XMLЗначение(Тип("Дата"), Запись.Значение.Период);
			НоваяСтрока.Подразделение = Подразделение;
			НоваяСтрока.Должность = Должность;
			НоваяСтрока.ГрафикРаботы = ГрафикРаботы;
			НоваяСтрока.Комментарий = Запись.Значение.Основание;
		КонецЦикла;
	КонецЕсли; 
	
	НаборЗаписейРегистра.Записать();
	
	Объект.Записать(); 

	уатОбщегоНазначенияСервер.ОбновитьТекущееМестоРаботыВСправочникеСотрудники(Ссылка);
	
    Если ДанныеОбмена.ДокументыСправкиУдостоверения <> "" Тогда
		Для каждого Запись Из ДанныеОбмена.ДокументыСправкиУдостоверения Цикл
			
			НовыйМенеджер = Новый Структура();
			НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
			НовыйМенеджер.Вставить("Менеджер", Справочники.уатРегистрационныеДокументы);
			НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
			НовыйМенеджер.Вставить("Имя", "ДокументыСправкиУдостоверения"); 
			
			ДокументСправкУдостоверение = НайтиИлиСоздатьОбъект(НовыйМенеджер, Запись.Значение);
			
		КонецЦикла;
	КонецЕсли;

