//
// Возвращаемое значение:
//   Массив из ПланОбменаСсылка.GDS_ОбменСТранспортнойЛогистикой
//
Функция УзлыОбменаИнтегрированныхСистем() Экспорт
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	GDS_ОбменСТранспортнойЛогистикой.Ссылка КАК Ссылка
		|ИЗ
		|	ПланОбмена.GDS_ОбменСТранспортнойЛогистикой КАК GDS_ОбменСТранспортнойЛогистикой
		|ГДЕ
		|	НЕ GDS_ОбменСТранспортнойЛогистикой.ПометкаУдаления
		|	И GDS_ОбменСТранспортнойЛогистикой.Ссылка <> &ЭтотУзел");
	Запрос.УстановитьПараметр("ЭтотУзел", ПланыОбмена.GDS_ОбменСТранспортнойЛогистикой.ЭтотУзел());
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Узлы = Новый Массив;
	Иначе
		Узлы = Результат.Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
	Возврат Узлы;
	
КонецФункции

