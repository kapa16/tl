	Менеджеры.Вставить("ИмяТипа", "Справочник"); 
	Менеджеры.Вставить("Имя", "Подразделение");
	
	Возврат НайтиИлиСоздатьОбъект(Менеджеры, ДанныеОбмена);
	
КонецФункции

Функция ПолучитьИлиСоздатьНоменклатуруГСМ(ДанныеОбмена)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатНоменклатураГСМ.ГруппаГСМ КАК ГруппаГСМ,
	               |	уатНоменклатураГСМ.Номенклатура КАК Номенклатура
	               |ИЗ
	               |	РегистрСведений.уатНоменклатураГСМ КАК уатНоменклатураГСМ
	               |ГДЕ
	               |	уатНоменклатураГСМ.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.МодельТС_НоменклатураГСМ_Номенклатура))); 
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Номенклатура;	
	КонецЕсли;
	
	НовЗапись = РегистрыСведений.уатНоменклатураГСМ.СоздатьМенеджерЗаписи();
	НовЗапись.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.МодельТС_НоменклатураГСМ_Номенклатура));
	НовЗапись.ГруппаГСМ = Перечисления.уатГруппыГСМ[ДанныеОбмена.МодельТС_НоменклатураГСМ_ГруппаГСМ];
	Попытка 
		НовЗапись.Записать();
		Возврат НовЗапись.Номенклатура;
	Исключение
	КонецПопытки;
	
КонецФункции

функция ПолучитьВидДокументаРегДок(ДанныеОбмена)
	
	Предопределенный = XMLЗначение(Тип("Булево"),ДанныеОбмена.ВидДокумента_Предопределенный); 
	Если Предопределенный Тогда
		Возврат Справочники.уатВидыДокументов[ДанныеОбмена.ВидДокумента_ИмяПредопределенныхДанных];
	КонецЕсли;
	
	УИД = Новый УникальныйИдентификатор(ДанныеОбмена.ВидДокумента_УникальныйИдентификатор);
	спрЭлемент = Справочники.уатВидыДокументов.ПолучитьСсылку(УИД);	
	Если спрЭлемент.Пустая() или Найти(СокрЛП(спрЭлемент),"<Объект не найден>")>0 Тогда	
		спрОбъект = Справочники.уатВидыДокументов.СоздатьЭлемент();
		спрОбъект.УстановитьСсылкуНового(спрЭлемент); 
	Иначе
		спрОбъект = спрЭлемент.ПолучитьОбъект();	
	КонецЕсли;
	
	спрОбъект.Наименование = СокрЛП(ДанныеОбмена.ВидДокумента_Наименование);
	//спрОбъект.СлужебноеНаименование = GDS_ДополнительныеФункции.ОбработатьСтрочкуДляИмени(спрОбъект.Наименование);
	спрОбъект.Записать();            
	
	ВидДокумента = спрОбъект.Ссылка;
	
	Возврат ВидДокумента;
	
КонецФункции

Процедура ЗагрузитьФайлыКДокументу(ДанныеОбмена, Документ, ДанныеСвязи)
	
	Если ДанныеСвязи = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	
	КоличествоФайлов = Число(ДанныеОбмена.Файлы_Количество);
	
	ПроверкаНаличияФайлов = НаличиеФайловВПапкеНаСервере(ДанныеОбмена,КоличествоФайлов);
	
	Если ПроверкаНаличияФайлов = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		
		Для Счетчик = 1 По КоличествоФайлов Цикл
			
			АдресФайла = ДанныеОбмена["Файлы_Файл_"+ Строка(Счетчик)];
			
			ДвоичныеДанные = Новый ДвоичныеДанные(АдресФайла);
			АдресВХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
			
			Файл = Новый Файл(АдресФайла);
			Если НЕ Файл.Существует() Тогда 
				//	Сообщить("Файла не найден " + ВыборкаДетальныеЗаписи.Ссылка.ВидДокумента + " " + ВыборкаДетальныеЗаписи.Ссылка.Владелец);
				//	//Возврат;
			Иначе
				
				//перед добавлением файлов проверим на уже прикрепленные файлы к ДО	
				НашиФайлы = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ФайлыПоВладельцу(ДанныеСвязи.id,ДанныеСвязи.name,ДанныеСвязи.type);
				Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
				
				Для Каждого СтрНашиФайлы Из НашиФайлы.files Цикл//нашли все прикрепленные файлы к ДО			
					ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПометитьНаУдалениеСнятьПометкуОбъекта(Прокси,СтрНашиФайлы.objectID.id,СтрНашиФайлы.objectID.type);				
				КонецЦикла;
				
				ДанныеХранения = Новый ДвоичныеДанные(АдресФайла);
				
				Адрес = ПоместитьВоВременноеХранилище(ДанныеХранения);
				
				ФайлНаименование = Файл.ИмяБезРасширения;
				
				ТекущийФайл = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеФайла(ФайлНаименование, ДанныеСвязи.id, ДанныеСвязи.type, НРег(Файл.Расширение));
				
				ПараметрыСоздания = Новый Структура;
				ПараметрыСоздания.Вставить("ТекущийФайл", ТекущийФайл);
				ПараметрыСоздания.Вставить("АдресВременногоХранилищаФайла", Адрес);
				ПараметрыСоздания.Вставить("Владелец", Документ);
				ПараметрыСоздания.Вставить("ЯвляетсяСканКопией", Ложь);
				ПараметрыСоздания.Вставить("ШаблонID", Неопределено);
				ПараметрыСоздания.Вставить("ВнешнийОбъект", Новый Структура("ID, type, name"));
				
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СоздатьФайлВДокументообороте(ПараметрыСоздания,ДанныеСвязи.id,ДанныеСвязи.type,ДанныеСвязи.name);
			КонецЕсли;
			
			УдалитьФайлы(АдресФайла);
			
		КонецЦикла;
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();	
	КонецПопытки;
	
КонецПроцедуры

Функция НаличиеФайловВПапкеНаСервере(ДанныеОбмена,КоличествоФайлов);
	НаличиеФайлов = Истина;
	
	Для Счетчик = 1 По КоличествоФайлов Цикл
		АдресФайла = ДанныеОбмена["Файлы_Файл_"+ Строка(Счетчик)];
		Файл = Новый Файл(АдресФайла);
		
		Если НЕ Файл.Существует() Тогда 
			НаличиеФайлов	= Ложь;
		Иначе
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат НаличиеФайлов;
	
