Функция СерилизацияДокумента(ОбъектСерилизации) Экспорт
	
	ТипОбъекта = Неопределено;
	
	Если ТипЗнч(ОбъектСерилизации.Ссылка)= ТипЗнч(Документы.уатЗаявкаНаРемонт.ПустаяСсылка()) тогда
		ТипОбъекта = "уатЗаявкаНаРемонт_ТЛ";	
	ИначеЕсли ТипЗнч(ОбъектСерилизации.Ссылка)= ТипЗнч(Документы.уатРемонтныйЛист.ПустаяСсылка()) тогда
		ТипОбъекта = "уатРемонтныйЛист_ТЛ";
	ИначеЕсли ТипЗнч(ОбъектСерилизации.Ссылка)= ТипЗнч(Документы.GDS_МестонахождениеТехники.ПустаяСсылка()) тогда
		ТипОбъекта = "МеКаМи_МестонахождениеТехники";
	ИначеЕсли ТипЗнч(ОбъектСерилизации.Ссылка)= ТипЗнч(Справочники.уатТС.ПустаяСсылка()) Тогда
		ТипОбъекта = "уатТС_ТЛ";
		Если НЕ ЗначениеЗаполнено(ОбъектСерилизации.ОсновноеСредство) Тогда
			Возврат "";	
		КонецЕсли;
	КонецЕсли;
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Корневой");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("DocumentObject."+ТипОбъекта);
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("ref");
	ЗаписьXML.ЗаписатьТекст(Строка(ОбъектСерилизации.Ссылка.УникальныйИдентификатор()));
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Если ТипОбъекта = "уатТС_ТЛ" Тогда  
		 
		ЗаписьXML.ЗаписатьНачалоЭлемента("УИН_ОС");
		ЗаписьXML.ЗаписатьТекст(XMLСтрока(ОбъектСерилизации.ОсновноеСредство.УникальныйИдентификатор()));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Наименование");
		ЗаписьXML.ЗаписатьТекст(XMLСтрока(ОбъектСерилизации.Наименование));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("ГосНомер");
		ЗаписьXML.ЗаписатьТекст(XMLСтрока(ОбъектСерилизации.ГосударственныйНомер));
