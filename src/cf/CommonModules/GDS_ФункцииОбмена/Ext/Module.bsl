Функция ПолучитьПУАвто(ТС, ДатаДокумента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатМестонахождениеТССрезПоследних.Колонна КАК Колонна
	               |ИЗ
	               |	РегистрСведений.уатМестонахождениеТС.СрезПоследних(НачалоПериода(&ДатаДокумента, ДЕНЬ), ТС = &ТС) КАК уатМестонахождениеТССрезПоследних";
	Запрос.УстановитьПараметр("ТС", ТС);
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Выборка = Запрос.Выполнить().Выгрузить();
	Если Выборка.Количество() <> 0 Тогда
		Возврат Выборка[0].Колонна;
	Иначе
		Возврат Справочники.уатКолонны.ПустаяСсылка();
	КонецЕсли;	
КонецФункции

Процедура ОчиститьИсториюКадровыхДанных(ДатаНачала, Сотрудник)
	
	Отбор = Новый Структура("Сотрудник", Сотрудник);
	Таблица = РегистрыСведений.уатКадроваяИсторияСотрудников.Выбрать(ДатаНачала + 1, ТекущаяДата(), Отбор);
	Пока Таблица.Следующий() Цикл
		Таблица.ПолучитьМенеджерЗаписи().Удалить();
	КонецЦикла
	
КонецПроцедуры

Функция ОбработкаГрупп(УИД, Наименование, НаименованиеСправочника)
	УИН = Новый УникальныйИдентификатор(УИД);
	СсылкаРод = Справочники[НаименованиеСправочника].ПолучитьСсылку(УИН);
	Если Найти(строка(СсылкаРод),"<Объект не найден>")>0 Тогда
		Если НаименованиеСправочника = "ПодразделенияОрганизаций" Тогда
			ГруппаСправочника = Справочники[НаименованиеСправочника].СоздатьЭлемент();
			ГруппаСправочника.Владелец = Справочники.Организации.ОрганизацияПоУмолчанию();
		Иначе
			ГруппаСправочника = Справочники[НаименованиеСправочника].СоздатьГруппу();
		КонецЕсли;
		ГруппаСправочника.УстановитьСсылкуНового(Справочники[НаименованиеСправочника].ПолучитьСсылку(УИН));
		ГруппаСправочника.Наименование = Наименование; 
		ГруппаСправочника.Записать();
		Возврат ГруппаСправочника.Ссылка;
	Иначе
		Возврат СсылкаРод;
	КонецЕсли;
КонецФункции

Функция ПолучитьПодразделение(ДанныеОбмена)
	
	Узел = ПланыОбмена[ДанныеОбмена.ПланОбмена].НайтиПоКоду(ДанныеОбмена.УзелИнформационнойБазы);

	Менеджеры = Новый Структура();
	Менеджеры.Вставить("Узел", Узел);
