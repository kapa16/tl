#Область ПолучениеИРазборДанных

Функция ОбменXML_Данными(ДанныеОбмена) Экспорт
	
	ОбработанныеДанные = РазобратьПолученныеДанные(ДанныеОбмена);
	ВсегоЭлементов = ОбработанныеДанные.Количество() - 1;
	
	Для Счетчик = 0 По ВсегоЭлементов Цикл	
		ЭлементОбмена 		= ОбработанныеДанные[Счетчик];	
		НаименованиеОбъекта = Прав(ЭлементОбмена.Представление,СтрДлина(ЭлементОбмена.Представление)-Найти(ЭлементОбмена.Представление,"."));
		ТипОбъекта          = Лев(ЭлементОбмена.Представление,Найти(ЭлементОбмена.Представление,".")-1);
		
		Если НаименованиеОбъекта = "уатТС" Тогда
			Результат = ОбработкаXML_ТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатМоделиТС" Тогда
			Результат = ОбработкаXML_МодельТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатТипыТС" Тогда
			Результат = ОбработкаXML_ТипТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Колонна" Тогда
			Результат = ОбработкаXML_Колонна(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатВидыОбслуживанияТС" Тогда
			Результат = ОбрабоктаXML_ВидОбслуживания(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатРаботыПоРемонту" Тогда
			Результат = ОбработкаXML_РемонтныеРаботы(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатСоставТС" Тогда
			Результат = ОбработкаXML_СоставТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "НормыРасходаГСМ" Тогда
			Результат = ОбработкаXML_НормыРасходаГСМ(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатРегистрационныеДокументы" Тогда
			Результат = ОбработкаXML_РегистрационныеДокументы(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатМестонахождениеТС" Тогда
			Результат = ОбработкаXML_МестонахождениеТС(ЭлементОбмена.Значение)
		ИначеЕсли НаименованиеОбъекта = "уатАЗС" Тогда
			Результат = ОбработкаXML_АЗС(ЭлементОбмена.Значение)
		ИначеЕсли НаименованиеОбъекта = "уатТопливныеКарты" Тогда
			Результат = ОбработкаXML_ТК(ЭлементОбмена.Значение)
		ИначеЕсли НаименованиеОбъекта = "СоответствиеТСИПУПодразделению" Тогда
			Результат = ОбработкаXML_СоответствиеПУ(ЭлементОбмена.Значение)
		ИначеЕсли НаименованиеОбъекта = "ПривлеченныйВодитель" Тогда
			Результат = ОбработкаXML_ПривлеченныйВодитель(ЭлементОбмена.Значение)
			
		ИначеЕсли НаименованиеОбъекта = "Номенклатура" Тогда
			Результат = ОбработкаXML_Номенклатура(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Склады" Тогда
			Результат = ОбработкаXML_Склады(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "МеКаМи_Сотрудники" Тогда   
			Результат = ОбработкаXML_Сотрудники(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Должность" Тогда    
			Результат = ОбработкаXML_Должность(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Подразделение" Тогда       
			Результат = ОбработкаXML_Подразделение(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "ГрафикРаботы" Тогда    
			Результат = ОбработкаXML_ГрафикРаботыСотрудника(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "ФизическоеЛицо" Тогда    
			Результат = ОбработкаXML_ФизическоеЛицо(ЭлементОбмена.Значение);  
		ИначеЕсли НаименованиеОбъекта = "Сотрудник" Тогда 
			Результат = ОбработкаXML_Сотрудник(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "ДокументыСправкиУдостоверения" Тогда 
			Результат = ОбработкаXML_ДокументыСправкиУдостоверения(ЭлементОбмена.Значение);
			
		ИначеЕсли НаименованиеОбъекта = "МеКаМи_ОсновныеСредства" Тогда
			Результат = ОбработкаXML_ОсновныеСредства(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатСерииНоменклатуры" Тогда
			Результат = ОбработкаXML_СерииНоменклатуры(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатТипыАгрегатов" Тогда
			Результат = ОбработкаXML_ТипыАгрегатов(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатМоделиАгрегатов" Тогда
			Результат = ОбработкаXML_МоделиАгрегатов(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "АгрегатыТС" Тогда
			Результат = ОбработкаXML_АгрегатыТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "ДатчикиТС" Тогда
			Результат = ОбработкаXML_ДатчикиТС(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Месторождения" Тогда
			Результат = ОбработкаXML_Месторождения(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Кусты" Тогда
			Результат = ОбработкаXML_Кусты(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "Скважины" Тогда
			Результат = ОбработкаXML_Скважины(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "ТСИОборудование" Тогда
			Результат = ОбработкаXML_ТСИОборудование(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "МатериалыУАТ" Тогда
			Результат = ОбработкаXML_МатериалыУАТ(ЭлементОбмена.Значение);
		ИначеЕсли НаименованиеОбъекта = "уатЗаявкаНаРемонт_GMG_MKM" Тогда
			Результат = ОбработкаXML_ЗаявкаНаРемонт_GMG_MKM(ЭлементОбмена.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

Функция РазобратьПолученныеДанные(ДанныеОбмена) Экспорт
	
	Чтение = Новый ЧтениеXML(); 
	Чтение.УстановитьСтроку(ДанныеОбмена); 
	Чтение.Прочитать(); //Вышли на root
	СписокПолученныхДанных  = Новый СписокЗначений;
	Структура 				= Новый Структура;
	Таблица 				= Новый СписокЗначений;
	ЭтоНовыйОбъект 			= Ложь;
	ЭтоТабличнаяЧасть		= Ложь;
	ИмяТаблицы 				= "";
	ОткрыласьСтрокаТЧ   	= Ложь;
	ИмяУзла 				= "";
	
	Пока Чтение.Прочитать() Цикл 
		// Прочитать "структурные части" элементов. 
		// Проверить, какая часть элемента - текущая. 
		Если Чтение.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда 
			если Найти(Чтение.Имя,"DocumentObject.")=1 или
				Найти(Чтение.Имя,"ДопДанные.")=1 или
				Найти(Чтение.Имя,"CatalogObject.")=1 или Чтение.Имя= "РезультатОбмена" тогда
				//Это новый объект
				ЭтоНовыйОбъект 			= Истина;
				Структура 				= Новый Структура;
				Таблица 				= Новый СписокЗначений;
				ЭтоНовыйОбъект 			= Ложь;
				ЭтоТабличнаяЧасть		= Ложь;
				ИмяТаблицы 				= "";
				ОткрыласьСтрокаТЧ   	= Ложь;
				ИмяУзла 				= "";
			иначеЕсли Найти(Чтение.Имя,"Row")=1 тогда
				//Это новый документ
				если НЕ ЭтоТабличнаяЧасть тогда
					Таблица 			= Новый СписокЗначений;
					ИмяТаблицы 			= ИмяУзла;
					ЭтоТабличнаяЧасть 	= Истина;
				конецЕсли;
				ОткрыласьСтрокаТЧ 	= Истина;
				НоваяСтрока 		= Новый Структура;
			иначе
				если ЭтоТабличнаяЧасть и ОткрыласьСтрокаТЧ тогда
					НоваяСтрока.Вставить(Чтение.Имя,"");
				иначе
					Структура.Вставить(Чтение.Имя,"");
				конецЕсли;	
			конецЕсли;	
			
			ИмяУзла = Чтение.Имя;
			// Атрибуты элементов можно читать только если текущая часть - 
			// начало элемента 
			Пока Чтение.ПрочитатьАтрибут() Цикл 
				
				// Прочитать данные узла атрибута. 
				ТипУзла = Чтение.ТипУзла; 
				Имя 	= Чтение.Имя; 
				Значение= Чтение.Значение; 
				// Обработать полученные значения.
			КонецЦикла;
		ИначеЕсли Чтение.ТипУзла = ТипУзлаXML.Текст Тогда
			если ЭтоТабличнаяЧасть тогда
				НоваяСтрока.Вставить(ИмяУзла,Чтение.Значение);
			иначе
				Структура.Вставить(ИмяУзла,Чтение.Значение);
			конецЕсли;
		ИначеЕсли Чтение.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда 
			если Найти(Чтение.Имя,"DocumentObject.")=1 или Найти(Чтение.Имя,"ДопДанные.")=1 или Найти(Чтение.Имя,"CatalogObject.")=1 или Чтение.Имя= "РезультатОбмена" тогда
				//Закончили разбор документов
				СписокПолученныхДанных.Добавить(Структура,СокрЛП(Чтение.Имя));
				ЭтоНовыйОбъект 		= Ложь;
			иначеЕсли Найти(Чтение.Имя,"Row")=1 тогда
				Таблица.Добавить(НоваяСтрока);
				ОткрыласьСтрокаТЧ 	= Ложь;
			иначеЕсли ЗначениеЗаполнено(ИмяТаблицы) и Найти(Чтение.Имя,ИмяТаблицы)=1 и ОткрыласьСтрокаТЧ = Ложь тогда
				Структура.Вставить(ИмяТаблицы,Таблица);
				ИмяТаблицы 			= "";
				ЭтоТабличнаяЧасть 	= Ложь;
			конецЕсли;	
		КонецЕсли; 
	КонецЦикла;
	
	Возврат СписокПолученныхДанных;
	
КонецФункции

#КонецОбласти

#Область ОбработкаДанных

Функция ОбработатьВходящийJSONОбъект(ДанныеДругойБазы) Экспорт
	Если ДанныеДругойБазы.Type = "МеКаМи_МаршрутныйЛист" Тогда
		Ответ = ПопыткаСоздатьДокумент_МаршрутныйЛист(ДанныеДругойБазы);
		Возврат Ответ;
	КонецЕсли;
КонецФункции

Функция ПопыткаСоздатьДокумент_МаршрутныйЛист(ДанныеДругойБазы)
	
	СтруктураВозврата = Новый Структура;
	СтруктураОтвета	  = Новый Структура;
	
	Попытка
		
		УИН = Новый УникальныйИдентификатор(ДанныеДругойБазы.Ref);
		ОбъектССылка = Документы.GDS_МаршрутныйЛист.ПолучитьСсылку(УИН);
		
		Если СтрНачинаетсяС(Строка(ОбъектССылка),"<Объект") Тогда 
			ОбъектДокумент = Документы.GDS_МаршрутныйЛист.СоздатьДокумент();
			ОбъектДокумент.УстановитьСсылкуНового(ОбъектССылка);
		Иначе 
			ОбъектДокумент = ОбъектССылка.ПолучитьОбъект();
			ОбъектДокумент.Маршруты.Очистить();
			ОбъектДокумент.ТТН.Очистить();
		КонецЕсли;
		
		ПрефиксыНомеров = Новый Соответствие;
		ПрефиксыНомеров.Вставить("8620006279", "МКМ-");
		ПрефиксыНомеров.Вставить("8603251721", "GMG-");
		Префикс = ПрефиксыНомеров.Получить(ДанныеДругойБазы.ИННЗаказчика);
		Если Префикс = Неопределено Тогда
			Префикс = "";
		КонецЕсли;
		
		НомерДокумента = СтрШаблон("%1%2", Префикс, ДанныеДругойБазы.Номер);
		
		ОбъектДокумент.Дата  = ПрочитатьДатуJSON(ДанныеДругойБазы.Дата, ФорматДатыJSON.ISO);
		ОбъектДокумент.Номер = НомерДокумента;
		
		УИНТС = Новый УникальныйИдентификатор(ДанныеДругойБазы.ТСУИН);
		ОбъектДокумент.ТС = Справочники.уатТС.ПолучитьСсылку(УИНТС);
		
		УИНОборудование = Новый УникальныйИдентификатор(ДанныеДругойБазы.ОборудованиеУИН);
		ОбъектДокумент.Оборудование = Справочники.уатТС.ПолучитьСсылку(УИНОборудование);
			
		УИНВодитель1 = Новый УникальныйИдентификатор(ДанныеДругойБазы.Водитель1УИН);
		Если Найти(Строка(Справочники.Сотрудники.ПолучитьСсылку(УИНВодитель1)), "<Объект") = 0 Тогда
			ОбъектДокумент.Водитель1 = Справочники.Сотрудники.ПолучитьСсылку(УИНВодитель1);
		Иначе
			ОбъектДокумент.Водитель1 = Справочники.Сотрудники.НайтиПоКоду(ДанныеДругойБазы.Водитель1Код);	
		КонецЕсли;
		
		УИНВодитель2 = Новый УникальныйИдентификатор(ДанныеДругойБазы.Водитель2УИН);
		Если Найти(Строка(Справочники.Сотрудники.ПолучитьСсылку(УИНВодитель2)), "<Объект") = 0 Тогда
			ОбъектДокумент.Водитель2 = Справочники.Сотрудники.ПолучитьСсылку(УИНВодитель2);
		Иначе
			ОбъектДокумент.Водитель2 = Справочники.Сотрудники.НайтиПоКоду(ДанныеДругойБазы.Водитель2Код);	
		КонецЕсли;
		
		Попытка 
			Если ЗначениеЗаполнено(СокрЛП(ДанныеДругойБазы.Состояние)) Тогда 
				ОбъектДокумент.СостоянияДокументов = ВернутьСостоянияДокументов(СокрЛП(ДанныеДругойБазы.Состояние));
			КонецЕсли;  
		Исключение
		КонецПопытки;
	
		ОбъектДокумент.Контрагент                 = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеДругойБазы.ИННЗаказчика);
		ОбъектДокумент.Комментарий                = ДанныеДругойБазы.Комментарий;
		ОбъектДокумент.Ответственный              = СокрЛП(ДанныеДругойБазы.Ответственный);
		ОбъектДокумент.ДолжностьОтветственный     = СокрЛП(ДанныеДругойБазы.ДолжностьОтветственного);
		ОбъектДокумент.ТелефонОтветственного      = СокрЛП(ДанныеДругойБазы.ТелефонОтветственного);
		ОбъектДокумент.EmailОтветственного        = СокрЛП(ДанныеДругойБазы.EmailОтветственного);
		ОбъектДокумент.НачальникУчастка           = СокрЛП(ДанныеДругойБазы.НачальникУчастка);
		ОбъектДокумент.ДолжностьНачальникУчастка  = СокрЛП(ДанныеДругойБазы.ДолжностьНачальникаУчастка);
		ОбъектДокумент.Мастер                     = СокрЛП(ДанныеДругойБазы.Мастер);
		ОбъектДокумент.ДолжностьМастер            = СокрЛП(ДанныеДругойБазы.ДолжностьМастера);
		ОбъектДокумент.Редактирование             = ДанныеДругойБазы.Редактирование;
		
		
		РодительСправочникСсылка = Справочники.уатОбъектыСтроительства.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеДругойБазы.УИДЗаказчика));
		Если Найти(Строка(РодительСправочникСсылка), "<Объект") Тогда
			РодительСправочникОбъект = Справочники.уатОбъектыСтроительства.СоздатьГруппу();
			РодительСправочникОбъект.УстановитьСсылкуНового(РодительСправочникСсылка);
			РодительСправочникОбъект.Наименование = ?(Префикс = "МКМ-", "АО СП Мекаминефть", "ООО ДЖИЭМДЖИ");
			РодительСправочникОбъект.Записать();
		КонецЕсли;
		
		ПУ_УИН = Новый УникальныйИдентификатор(ДанныеДругойБазы.ПУУИН);
		ЭлементСправочникСсылка = Справочники.уатОбъектыСтроительства.ПолучитьСсылку(Новый УникальныйИдентификатор(ПУ_УИН));
		
		Если Найти(Строка(ЭлементСправочникСсылка),"<Объект") Тогда 
			ЭлементСправочникОбъект = Справочники.уатОбъектыСтроительства.СоздатьЭлемент();
			ЭлементСправочникОбъект.УстановитьСсылкуНового(ЭлементСправочникСсылка);
			ЭлементСправочникОбъект.Родитель = РодительСправочникСсылка;
			ЭлементСправочникОбъект.Наименование = ДанныеДругойБазы.ПУ;
			ЭлементСправочникОбъект.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ДанныеДругойБазы.ИННЗаказчика);
			ЭлементСправочникОбъект.Записать();
		Иначе
			ЭлементСправочникаОбъект = ЭлементСправочникСсылка.ПолучитьОбъект();
			ЭлементСправочникаОбъект.Наименование = ДанныеДругойБазы.ПУ;
			ЭлементСправочникаОбъект.Родитель = РодительСправочникСсылка;
			ОбъектДокумент.ПУ = ЭлементСправочникСсылка;
		КонецЕсли;

		Для Каждого Строка Из ДанныеДругойБазы.МаршрутыНомерСтроки Цикл
			НоваяСтрока = ОбъектДокумент.Маршруты.Добавить();
			НоваяСтрока.НомерПутевогоЛиста = ДанныеДругойБазы.МаршрутыНомерПутевогоЛиста[Строка-1];
			НоваяСтрока.Дата             = ПрочитатьДатуJSON(ДанныеДругойБазы.МаршрутыДата[Строка-1], ФорматДатыJSON.ISO);
			НоваяСтрока.Смена            = ДанныеДругойБазы.МаршрутыСмена[Строка-1];
			НоваяСтрока.Водитель         = ДанныеДругойБазы.МаршрутыВодитель[Строка-1];
			НоваяСтрока.ПунктОтправления = ДанныеДругойБазы.МаршрутыПунктОтправления[Строка-1];
			НоваяСтрока.ПунктНазначения  = ДанныеДругойБазы.МаршрутыПунктНазначения[Строка-1];
			
			УИНВидРабот = Новый УникальныйИдентификатор(ДанныеДругойБазы.ВидыРаботУИД[Строка-1]);
			ВидРабот = Справочники.GDS_ВидыРабот.ПолучитьСсылку(УИНВидРабот);
			Если СтрНачинаетсяС(строка(ВидРабот),"<Объект") Тогда
				ВидРаботОбъект = Справочники.GDS_ВидыРабот.СоздатьЭлемент();
				ВидРаботОбъект.УстановитьСсылкуНового(ВидРабот);
				ВидРаботОбъект.Наименование = ДанныеДругойБазы.ВидыРаботНаименование[Строка-1];
				ВидРаботОбъект.Записать();
				ВидРабот = ВидРаботОбъект.Ссылка;
			КонецЕсли;
			НоваяСтрока.ВидРабот               = ВидРабот;
			
			НоваяСтрока.Месторождение          = ДанныеДругойБазы.МаршрутыМесторождение[Строка-1];
			НоваяСтрока.Куст                   = ДанныеДругойБазы.МаршрутыКуст[Строка-1];
			НоваяСтрока.Скважина               = ДанныеДругойБазы.МаршрутыСкважина[Строка-1];
			НоваяСтрока.ВремяВпути             = ДанныеДругойБазы.МаршрутыВремяВпути[Строка-1];
			НоваяСтрока.КмВПути                = ДанныеДругойБазы.МаршрутыКмВПути[Строка-1];
			НоваяСтрока.ВремяНаВыполнениеРабот = ДанныеДругойБазы.МаршрутыВремяНаВыполнениеРабот[Строка-1];
			НоваяСтрока.ВремяВпутиОбратно      = ДанныеДругойБазы.МаршрутыВремяВпутиОбратно[Строка-1];
			НоваяСтрока.КмВПутиОбратно         = ДанныеДругойБазы.МаршрутыКмВПутиОбратно[Строка-1];
			НоваяСтрока.ПеревезеноТонн         = ДанныеДругойБазы.МаршрутыПеревезеноТонн[Строка-1];
			НоваяСтрока.ПеревезеноЕмкостей     = ДанныеДругойБазы.МаршрутыПеревезеноЕмкостей[Строка-1];
			НоваяСтрока.ИдентификаторСтроки    = ДанныеДругойБазы.МаршрутыИдентификаторСтроки[Строка-1];
			
		КонецЦикла;
		
		Для Каждого СтрокаТТН Из ДанныеДругойБазы.ТТННомерСтроки Цикл
			
			НоваяСтрокаТТН = ОбъектДокумент.ТТН.Добавить();
			
			НоваяСтрокаТТН.ИдентификаторСтрокиМаршруты = ДанныеДругойБазы.ТТНИдентификаторСтрокиМаршруты[СтрокаТТН-1];
			НоваяСтрокаТТН.ТТН                         = ДанныеДругойБазы.ТТНТТНКодНомер[СтрокаТТН-1];
			НоваяСтрокаТТН.ТТНСтрокой                  = ДанныеДругойБазы.ТТНТТН[СтрокаТТН-1];
			НоваяСтрокаТТН.МассаНетто                  = ДанныеДругойБазы.ТТНТТНРеквизиты[СтрокаТТН-1].МассаНетто;
			
		КонецЦикла;

		ОбъектДокумент.Записать();
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		СтруктураОтвета.Вставить("Результат",ТекстОшибки);
		
		СтруктураВозврата.Вставить("КодОтвета",200);
		СтруктураВозврата.Вставить("Ответ",СтруктураОтвета);

		Возврат СтруктураВозврата;
	КонецПопытки;
	
	СтруктураОтвета.Вставить("Результат","ДокументЗаписан");

	СтруктураВозврата.Вставить("КодОтвета",200);
	СтруктураВозврата.Вставить("Ответ",СтруктураОтвета);
	
	Возврат СтруктураВозврата;

КонецФункции

#Область УАТ

Функция ОбработкаXML_ТС(ДанныеОбмена)
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ТС_УИД);	
	ТССсылка = Справочники.уатТС.ПолучитьСсылку(УИН);
	
	Если Найти(строка(ТССсылка),"<Объект не найден>")>0 Тогда
		Если ДанныеОбмена.ТС_ПометкаУдаления ИЛИ XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВыбытия) <> Дата(1,1,1) Тогда
			Возврат Истина;	
		КонецЕсли;
		Если ДанныеОбмена.ТС_ЭтоГруппа Тогда
			ТСОбъект = Справочники.уатТС.СоздатьГруппу();
		Иначе
			ТСОбъект = Справочники.уатТС.СоздатьЭлемент()
		КонецЕсли;
		ТСОбъект.УстановитьСсылкуНового(ТССсылка);
	Иначе
		ТСОбъект = ТССсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ТСОбъект.Наименование = ДанныеОбмена.ТС_Наименование;
	ТСОбъект.Родитель = ОбработкаГрупп(ДанныеОбмена.ТС_Родитель_УИД, ДанныеОбмена.ТС_Родитель_Наименование, "уатТС");
	ТСОбъект.ПометкаУдаления = ДанныеОбмена.ТС_ПометкаУдаления;
	
	Если НЕ ТСОбъект.ЭтоГруппа Тогда
		//Если XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВводаВЭксплуатацию) = Дата(1, 1, 1) Тогда
		//	Возврат Истина;
		//КонецЕсли;
		//Если XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВыбытия) <> Дата(1, 1, 1) Тогда
		//	УдалениеВыбывшегоТС(ТСОбъект);
		//	Возврат Истина;
		//КонецЕсли;
		ТСОбъект.ГосударственныйНомер = ДанныеОбмена.ТС_ГосНомер;
		ТСОбъект.ГаражныйНомер		  = ДанныеОбмена.ТС_ГаражныйНомер;
		ТСОбъект.ВидМоделиТС		  = Перечисления.уатВидыМоделейТС[ДанныеОбмена.ТС_ВидМоделиТС];
		ТСОбъект.Модель 			  = ПервоначальноеСозданиеПоискМоделиТС(ДанныеОбмена);
		ТСОбъект.ТипТС				  = ПервоначальноеСозданиеПоискТипаТС(ДанныеОбмена);
		ТСОбъект.VIN				  = ДанныеОбмена.ТС_VIN;
		Если ДанныеОбмена.Свойство("ТС_ОбъемБака") Тогда
			ТСОбъект.GDS_ОбъемБака		  = ДанныеОбмена.ТС_ОбъемБака;
		КонецЕсли;
		ТСОбъект.Комментарий		  = ДанныеОбмена.ТС_Комментарий;
		ТСОбъект.ГодВыпуска			  = ДанныеОбмена.ТС_ГодВыпуска;
		ТСОбъект.ЦветКузова			  = ПервоначальноеСозданиеПоискЦветаТС(ДанныеОбмена);
		ТСОбъект.СобственныйВес		  = ДанныеОбмена.ТС_СобственныйВес;
		Если ДанныеОбмена.Свойство("ТС_ВидПутевогоЛиста") И ДанныеОбмена.ТС_ВидПутевогоЛиста <> "" Тогда
			ТСОбъект.ОсновнойВидПЛ = Перечисления.уатВидыПЛ[ДанныеОбмена.ТС_ВидПутевогоЛиста];	
		КонецЕсли;
		Если ДанныеОбмена.Свойство("ТС_ПривлеченныйТранспорт") Тогда
			ТСОбъект.GDS_ПривлеченныйТранспорт = ДанныеОбмена.ТС_ПривлеченныйТранспорт;
			Если НЕ ТСОбъект.GDS_ПривлеченныйТранспорт Тогда
				ТСОбъект.ВладелецТС 	= Справочники.Организации.ОрганизацияПоУмолчанию();
				Если ТСОбъект.ТипВладенияТС = Перечисления.уатТипыВладенияТС.Собственность Тогда
					ТСОбъект.GDS_СобственникТС = Справочники.Контрагенты.ПустаяСсылка();	
				Иначе
					ТСОбъект.GDS_СобственникТС = ОбработкаXML_Контрагент(ДанныеОбмена, "Собственник");
				КонецЕсли;
				Если ДанныеОбмена.ТС_ПравоПользования <> "" Тогда
					ТСОбъект.ТипВладенияТС = Перечисления.уатТипыВладенияТС[ДанныеОбмена.ТС_ПравоПользования];
				КонецЕсли;
			Иначе
				ТСОбъект.ВладелецТС 	= ОбработкаXML_Контрагент(ДанныеОбмена, "Владелец");
				ТСОбъект.GDS_СобственникТС = Справочники.Контрагенты.ПустаяСсылка();
				ТСОбъект.ТипВладенияТС = Перечисления.уатТипыВладенияТС.ПустаяСсылка();
			КонецЕсли;	
			
		КонецЕсли
	КонецЕсли;
	
	
	
	Попытка
		ТСОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	Отказ = Ложь;
	Если НЕ ТСОбъект.ЭтоГруппа И XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВыбытия) = Дата(1,1,1) И XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВводаВЭксплуатацию) <> Дата(1,1,1) Тогда
		ЗаполнитьВводВЭксплуатацию(ДанныеОбмена, УИН, Отказ);
		Если Отказ = Истина Тогда
			Возврат Ложь;
		КонецЕсли;
	ИначеЕсли НЕ ТСОбъект.ЭтоГруппа И XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВыбытия) <> Дата(1,1,1) Тогда
		Если НЕ ЗначениеЗаполнено(ТСОбъект.Колонна) И НЕ ЗначениеЗаполнено(ТСОбъект.Подразделение) Тогда
			Возврат Истина;	
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;			
КонецФункции

Функция ОбработкаXML_МодельТС(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.МодельТС_УИД);	
	МодельТССсылка = Справочники.уатМоделиТС.ПолучитьСсылку(УИН);
	
	Если Найти(строка(МодельТССсылка),"<Объект не найден>")>0 Тогда
		Если ДанныеОбмена.МодельТС_ПометкаУдаления Тогда
			Возврат Истина;	
		КонецЕсли;
		Если ДанныеОбмена.МодельТС_ЭтоГруппа Тогда
			МодельТСОбъект = Справочники.уатМоделиТС.СоздатьГруппу();
		Иначе
			МодельТСОбъект = Справочники.уатМоделиТС.СоздатьЭлемент()
		КонецЕсли;
		МодельТСОбъект.УстановитьСсылкуНового(МодельТССсылка);
	Иначе
		МодельТСОбъект = МодельТССсылка.ПолучитьОбъект();
	КонецЕсли;
	
	МодельТСОбъект.Наименование = ДанныеОбмена.МодельТС_Наименование;
	МодельТСОбъект.Родитель = ОбработкаГрупп(ДанныеОбмена.МодельТС_Родитель_УИД, ДанныеОбмена.МодельТС_Родитель_Наименование, "уатМоделиТС");			
	МодельТСОбъект.ПометкаУдаления = ДанныеОбмена.МодельТС_ПометкаУдаления;
	Если НЕ МодельТСОбъект.ЭтоГруппа Тогда
		Если ДанныеОбмена.МодельТС_ВидМоделиТС <> "" Тогда 
			МодельТСОбъект.ВидМоделиТС	   = Перечисления.уатВидыМоделейТС[ДанныеОбмена.МодельТС_ВидМоделиТС];
		КонецЕсли;
		МодельТСОбъект.ТипТС		   = ПервоначальноеСозданиеПоискТипаТС(ДанныеОбмена);
		Если ДанныеОбмена.МодельТС_ТипДвигателя <> "" Тогда 
			МодельТСОбъект.ТипДвигателя	   = Перечисления.уатТипыДвигателей[ДанныеОбмена.МодельТС_ТипДвигателя];
		КонецЕсли;
		МодельТСОбъект.НаличиеСпидометра = ДанныеОбмена.МодельТС_Одометр;
		МодельТСОбъект.НаличиеТопливногоБака = ДанныеОбмена.МодельТС_НаличиеТопливногоБака;
	КонецЕсли;

	Если ДанныеОбмена.Свойство("МодельТС_ЗаполнитьХарактеристики") Тогда
		МодельТСОбъект.МодельДвигателя = ДанныеОбмена.МодельТС_МодельДвигателя;
		МодельТСОбъект.МощностьДвигателяЛС = ДанныеОбмена.МодельТС_Мощность_ЛС;
		МодельТСОбъект.МощностьДвигателяКВТ = ДанныеОбмена.МодельТС_Мощность_КВТ;
		МодельТСОбъект.РабочийОбъемДвигателя = ДанныеОбмена.МодельТС_РабочийОбъем;
		МодельТСОбъект.ОбъемБака = ДанныеОбмена.МодельТС_ОбъемБака;
		Если ДанныеОбмена.Свойство("МодельТС_ОснТопливо") Тогда
			МодельТСОбъект.ОсновноеТопливо = ОбработкаXML_НоменклатураГСМ(ДанныеОбмена);
			Если МодельТСОбъект.ОсновноеТопливо = Справочники.Номенклатура.ПустаяСсылка() Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
		Если ДанныеОбмена.Свойство("МодельТС_ДопТопливо") Тогда
			ДанныеОбмена.Номенклатура_УникальныйИдентификатор = ДанныеОбмена.Номенклатура_УникальныйИдентификатор2;
			ДанныеОбмена.Номенклатура_Наименование = ДанныеОбмена.Номенклатура_Наименование2;
			МодельТСОбъект.ДополнительноеТопливо = ОбработкаXML_НоменклатураГСМ(ДанныеОбмена);
			Если МодельТСОбъект.ДополнительноеТопливо = Справочники.Номенклатура.ПустаяСсылка() Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
		МодельТСОбъект.МаксимальнаяСкорость = ДанныеОбмена.МодельТС_МаксимальнаяСкорость;
		МодельТСОбъект.СобственныйВес = ДанныеОбмена.МодельТС_СобственныйВес;
		МодельТСОбъект.Грузоподъемность = ДанныеОбмена.МодельТС_Грузоподъемность;
		МодельТСОбъект.ОбъемКузова = ДанныеОбмена.МодельТС_ОбъемКузова;
		Если ДанныеОбмена.МодельТС_ВидПривода <> "" Тогда
			МодельТСОбъект.ВидПривода = Перечисления.уатВидыПриводаТС[ДанныеОбмена.МодельТС_ВидПривода];
		КонецЕсли;
		МодельТСОбъект.КоличествоОсей = ДанныеОбмена.МодельТС_КоличествоОсей;
		МодельТСОбъект.КоличествоКолес = ДанныеОбмена.МодельТС_КоличествоКолес;
		МодельТСОбъект.ВсегоМест = ДанныеОбмена.МодельТС_ВсегоМест;
		МодельТСОбъект.СидячихМест = ДанныеОбмена.МодельТС_СидячихМест;
		МодельТСОбъект.СпособПогрузки = ДанныеОбмена.МодельТС_СпособПогрузки;
	КонецЕсли;
	
	
	Попытка
		МодельТСОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;			
КонецФункции

Функция ОбработкаXML_ТипТС(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.ТипТС_УИД);	
	ТипТССсылка = Справочники.уатТипыТС.ПолучитьСсылку(УИН);
	
	Если Найти(строка(ТипТССсылка),"<Объект не найден>")>0 Тогда
		Если ДанныеОбмена.ТипТС_ПометкаУдаления Тогда
			Возврат Истина;	
		КонецЕсли;
		
		Если ДанныеОбмена.ТипТС_ЭтоГруппа Тогда
			ТипТСОбъект = Справочники.уатТипыТС.СоздатьГруппу();
		Иначе
			ТипТСОбъект = Справочники.уатТипыТС.СоздатьЭлемент()
		КонецЕсли;
		ТипТСОбъект.УстановитьСсылкуНового(ТипТССсылка);
	Иначе
		ТипТСОбъект = ТипТССсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ТипТСОбъект.Наименование = ДанныеОбмена.ТипТС_Наименование;
	ТипТСОбъект.Родитель = ОбработкаГрупп(ДанныеОбмена.ТипТС_Родитель_УИД, ДанныеОбмена.ТипТС_Родитель_Наименование, "уатТипыТС");			
	ТипТСОбъект.ПометкаУдаления = ДанныеОбмена.ТипТС_ПометкаУдаления;
	
	Если НЕ ТипТСОбъект.ЭтоГруппа Тогда
		Если ДанныеОбмена.ТипТС_ВидТС <> "" Тогда
			ТипТСобъект.ВидТС = Перечисления.уатВидыТС[ДанныеОбмена.ТипТС_ВидТС];
		КонецЕсли;
		
	КонецЕсли;
	
	
	
	Попытка
		ТипТСОбъект.Записать();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;			
КонецФункции

Функция ОбработкаXML_Колонна(ДанныеОбмена)
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.Колонна_УИД);	
	КолоннаСсылка = Справочники.уатКолонны.ПолучитьСсылку(УИН);
	
