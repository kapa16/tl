Процедура ЗаполнитьДокументыСправкиУдостоверения(Менеджеры, Ссылка, ДанныеОбмена)

	Объект = Ссылка.Получитьобъект(); 
	
	Объект.ПринадлежностьДокументов = Перечисления.уатПринадлежностьДокументов.ДокументыВодителя;

	НовыйМенеджер = Новый Структура();
	НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
	НовыйМенеджер.Вставить("Менеджер", Справочники.уатВидыДокументов);
	НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
	НовыйМенеджер.Вставить("Имя", "ВидДокумента"); 
	
	ВидДокумента = НайтиИлиСоздатьОбъект(НовыйМенеджер, ДанныеОбмена);
	
	Объект.ВидДокумента = ВидДокумента;

	НовыйМенеджер = Новый Структура();
	НовыйМенеджер.Вставить("Узел", Менеджеры.Узел);
	НовыйМенеджер.Вставить("Менеджер", Справочники.Сотрудники);
	НовыйМенеджер.Вставить("ИмяТипа", "Справочник"); 
	НовыйМенеджер.Вставить("Имя", "Сотрудник"); 
	
	Сотрудник = НайтиИлиСоздатьОбъект(НовыйМенеджер, ДанныеОбмена);
	
	Объект.ВладелецДокументов = Сотрудник;
	
	Объект.Серия = ДанныеОбмена.ДокументыСправкиУдостоверения_Серия;
	Объект.Номер = ДанныеОбмена.ДокументыСправкиУдостоверения_Номер;
	Объект.ДатаВыдачи = XMLЗначение(Тип("Дата"), ДанныеОбмена.ДокументыСправкиУдостоверения_ДатаВыдачи);
	Объект.ДатаОкончания = XMLЗначение(Тип("Дата"), ДанныеОбмена.ДокументыСправкиУдостоверения_ДатаОкончания);
 	Объект.Статус = Перечисления.уатСтатусыДействия[ДанныеОбмена.ДокументыСправкиУдостоверения_Статус];
	Объект.КемВыдан = ДанныеОбмена.ДокументыСправкиУдостоверения_КемВыдан;
	Объект.ОткрытыеКатегории = ДанныеОбмена.ДокументыСправкиУдостоверения_ОткрытыеКатегории;
	Объект.Комментарий = ДанныеОбмена.ДокументыСправкиУдостоверения_Комментарий;
	
	Для каждого мСтрокаТЧ  Из Объект.Категории Цикл
		мСтрокаТЧ.Открыта = Ложь;
	КонецЦикла;
	
	ОткрытыеКатегории = СокрЛП(Объект.ОткрытыеКатегории);
	
	Если ЗначениеЗаполнено(ОткрытыеКатегории) тогда
		мКатерогий = СтрРазделить(ОткрытыеКатегории, ",");
		Если мКатерогий.Количество() = 1 Тогда
			мКатерогий = СтрРазделить(СокрЛП(мКатерогий[0]), " ");
		КонецЕсли;
		
		Для каждого Строка Из мКатерогий Цикл
			Категория = СокрЛП(СтрЗаменить(Строка," ",""));	
			Если ЗначениеЗаполнено(Категория) Тогда
				Категория = СтрЗаменить(Категория,"А","A");
				Категория = СтрЗаменить(Категория,"В","B");
				Категория = СтрЗаменить(Категория,"С","C");
				Категория = СтрЗаменить(Категория,"Д","D");
				Категория = СтрЗаменить(Категория,"Е","E");
				Категория = СтрЗаменить(Категория,"М","M");
				
				Категория = Справочники.уатКатегорииДокументов.НайтиПоНаименованию(Категория);
				Если ЗначениеЗаполнено(Категория) Тогда  
					мСтрока = Объект.Категории.НайтиСтроки(Новый Структура("Категория", Категория));
					Для каждого мСтрокаТЧ  Из мСтрока Цикл
						мСтрокаТЧ.Открыта = Истина;
					КонецЦикла;
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла; 
	КонецЕсли;

	Объект.Записать();
	
	ИмяПользователяДО = Константы.ИнтеграцияС1СДокументооборотИмяПользователяДляОбмена.Получить();
	ПарольДО = Константы.ИнтеграцияС1СДокументооборотПарольДляОбмена.Получить();
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьНастройкиАвторизацииВПараметрыСеанса(ИмяПользователяДО, ПарольДО, Ложь, Ложь);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьВерсиюСервисаВПараметрыСеанса();
	
	ДанныеСвязи = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(Объект.Ссылка);
	Если ДанныеСвязи = Неопределено Тогда 	
		// Добавление новой связи.
		ОбъектДОID = СокрЛП(ДанныеОбмена.ОбъектДОID);
		ОбъектДОТип = СокрЛП(ДанныеОбмена.ОбъектДОТип);
		Если ЗначениеЗаполнено(ОбъектДОID) И ЗначениеЗаполнено(ОбъектДОТип) Тогда
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДобавитьСвязь(ОбъектДОID, ОбъектДОТип, Объект.Ссылка);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры
