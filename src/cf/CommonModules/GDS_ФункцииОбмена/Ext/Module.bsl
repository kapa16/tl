Функция ОбработкаXML_Сотрудники(ДанныеОбмена)
	СтурктураВозврата = Новый Структура;
	СтурктураВозврата.Вставить("ОписаниеОшибки","");
	СтурктураВозврата.Вставить("Результат",Истина);
	
	Организация = Справочники.Организации.НайтиПоКоду("000000001", Истина);
	
	ФизЛицо = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ФизЛицо));
	
	Если Найти(строка(ФизЛицо),"<Объект не найден>") > 0 Тогда
		Попытка
			Если XMLЗначение(Тип("Дата"),ДанныеОбмена.ДатаУвольнения) <> Дата("00010101010101") Тогда
				Возврат СтурктураВозврата.Результат;	
			КонецЕсли;
		Исключение
		КонецПопытки;
		Объект_ФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
		Объект_ФизЛицо.УстановитьСсылкуНового(ФизЛицо);
		Объект_ФизЛицо.Записать();
	Иначе
		Объект_ФизЛицо = ФизЛицо.ПолучитьОбъект();
	КонецЕсли;
	
	Попытка
		Объект_ФизЛицо.Наименование 	= ДанныеОбмена.ФИО;
		Объект_ФизЛицо.ФИО				= ДанныеОбмена.ФИО;
		Объект_ФизЛицо.ИНН   			= ДанныеОбмена.ИНН;
		Объект_ФизЛицо.СтраховойНомерПФР= ДанныеОбмена.СНИЛС;
		Объект_ФизЛицо.ДатаРождения		= XMLЗначение(Тип("Дата"),ДанныеОбмена.ДатаРождения);
		Объект_ФизЛицо.Пол				= Перечисления.ПолФизическогоЛица[ДанныеОбмена.Пол];
		Объект_ФизЛицо.Записать();
		
		
		НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Отбор.ФизЛицо.Установить(Объект_ФизЛицо.Ссылка);
		НаборЗаписей.Очистить();
		
		Если ЗначениеЗаполнено(ДанныеОбмена.ДатаВыдачиПаспорта) Тогда
			ЗаписьНабора 				= НаборЗаписей.Добавить();
			ЗаписьНабора.Период			= Дата("20180101");
			ЗаписьНабора.Физлицо		= Объект_ФизЛицо.Ссылка;
			ЗаписьНабора.ВидДокумента	= Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ;
			ЗаписьНабора.Серия			= ДанныеОбмена.СерияПаспорта;
			ЗаписьНабора.Номер			= ДанныеОбмена.НомерПаспорта;
			ЗаписьНабора.ДатаВыдачи		= XMLЗначение(Тип("Дата"),ДанныеОбмена.ДатаВыдачиПаспорта);
			ЗаписьНабора.КемВыдан		= ДанныеОбмена.КемВыданПаспорт;
			ЗаписьНабора.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
			
			Если ЗначениеЗаполнено(ДанныеОбмена.КодПодразделенияПаспорта) Тогда
				ЗаписьНабора.КодПодразделения = ДанныеОбмена.КодПодразделенияПаспорта;
			КонецЕсли;
			
			Если ПустаяСтрока(ЗаписьНабора.Представление) И Не ЗаписьНабора.ВидДокумента.Пустая() Тогда
				ЗаписьНабора.Представление = Строка(ЗаписьНабора.ВидДокумента) + ", " + ЗаписьНабора.Серия + ", " + ЗаписьНабора.Номер + ", " + 
				Строка(Формат(ЗаписьНабора.ДатаВыдачи,"ДФ=dd.MM.yyyy")) + ", " + ЗаписьНабора.КемВыдан +", "+ ЗаписьНабора.КодПодразделения;
			КонецЕсли;
			
			НаборЗаписей.Записать();
		КонецЕсли;
	Исключение	
		СтурктураВозврата.Вставить("ОписаниеОшибки","Не удалось создать новое ФизЛицо: "+ДанныеОбмена.ФИО);
		СтурктураВозврата.Вставить("Результат",Ложь);
		
		Возврат СтурктураВозврата;
	КонецПопытки;
	Если ДанныеОбмена.Свойство("Сотрудник") = Истина Тогда
		Если ЗначениеЗаполнено(ДанныеОбмена.Сотрудник) Тогда
			Сотрудник = Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Сотрудник));
			
			Если Найти(строка(Сотрудник),"<Объект не найден>")>0 Тогда
				Объект_Сотрудник = Справочники.Сотрудники.СоздатьЭлемент();
				Объект_Сотрудник.УстановитьСсылкуНового(Сотрудник);
				Попытка
					Объект_Сотрудник.Записать();
				Исключение
					Объект_Сотрудник.УстановитьНовыйКод("Зад-");
					Объект_Сотрудник.Записать();
				КонецПопытки;
			Иначе
				Объект_Сотрудник = Сотрудник.ПолучитьОбъект();
			КонецЕсли;
			
			Попытка
				Объект_Сотрудник.ФизическоеЛицо 	= Объект_ФизЛицо.Ссылка;
				Объект_Сотрудник.Наименование 		= ДанныеОбмена.ФИО;
				Объект_Сотрудник.Код				= ДанныеОбмена.ТабНомер;
				Объект_Сотрудник.Организация		= Организация;
				Объект_Сотрудник.ДатаПриема			= XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаПриема);
				Объект_Сотрудник.ДатаУвольнения		= XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаУвольнения);
				Объект_Сотрудник.ВАрхиве			= Ложь;
				Объект_Сотрудник.Записать();
				
				Если ЗначениеЗаполнено(Объект_Сотрудник.Организация) Тогда
					СрезДанных = РегистрыСведений.уатКадроваяИсторияСотрудников.СрезПоследних(, Новый Структура("Сотрудник", Объект_Сотрудник.Ссылка));
					Если СрезДанных.Количество() = 0 Тогда
						МенЗаписи = РегистрыСведений.уатКадроваяИсторияСотрудников.СоздатьМенеджерЗаписи();
						МенЗаписи.Период        = ?(Объект_Сотрудник.ДатаПриема = Дата("00010101"), ТекущаяДата(), Объект_Сотрудник.ДатаПриема);
						МенЗаписи.Сотрудник     = Объект_Сотрудник.Ссылка;
						МенЗаписи.Организация   = Объект_Сотрудник.Организация;
						МенЗаписи.Подразделение = Объект_Сотрудник.Подразделение;
						МенЗаписи.Должность     = Объект_Сотрудник.Должность;
						МенЗаписи.ГрафикРаботы  = Объект_Сотрудник.ГрафикРаботы;
						МенЗаписи.Записать();
					КонецЕсли;
				КонецЕсли;
				
				
				НаборЗаписейКадровыеДанные = РегистрыСведений.уатКадроваяИсторияСотрудников.СоздатьМенеджерЗаписи();
				НаборЗаписейКадровыеДанные.Период = ?(XMLЗначение(Тип("Дата"),ДанныеОбмена.ДатаПеремещения)<>Дата("00010101010101"),XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаПеремещения),XMLЗначение(Тип("Дата"), ДанныеОбмена.ДатаПриема)) ;
				НаборЗаписейКадровыеДанные.Организация			= Организация;
				НаборЗаписейКадровыеДанные.Сотрудник			= Объект_Сотрудник.Ссылка;
				НаборЗаписейКадровыеДанные.Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ДанныеОЗвене));
				Должность = Справочники.Должности.НайтиПоНаименованию(СокрЛП(ДанныеОбмена.НаименованиеДолжности),Истина);
				
				Если ЗначениеЗаполнено(Должность) Тогда
					НаборЗаписейКадровыеДанные.Должность	= Должность;
				Иначе
					СпрДолжность = Справочники.Должности.СоздатьЭлемент();
					СпрДолжность.Наименование = СокрЛП(ДанныеОбмена.НаименованиеДолжности);
					СпрДолжность.Записать();
					НаборЗаписейКадровыеДанные.Должность = СпрДолжность.Ссылка;
				КонецЕсли;
				
				
				НаборЗаписейКадровыеДанные.Записать();
				уатОбщегоНазначенияСервер.ОбновитьТекущееМестоРаботыВСправочникеСотрудники(НаборЗаписейКадровыеДанные.Сотрудник);
				
				СрезДанных = РегистрыСведений.уатКадроваяИсторияСотрудников.СрезПоследних(, Новый Структура("Сотрудник", Объект_Сотрудник.Ссылка));
				Если СрезДанных[0].Период > НаборЗаписейКадровыеДанные.Период Тогда  
				
					ОчиститьИсториюКадровыхДанных(НаборЗаписейКадровыеДанные.Период, НаборЗаписейКадровыеДанные.Сотрудник);
					
				КонецЕсли;
			Исключение
				СтурктураВозврата.Вставить("ОписаниеОшибки","Не удалось создать нового Сотрудника: "+ДанныеОбмена.ФИО);
				СтурктураВозврата.Вставить("Результат",Истина);
				
				Возврат СтурктураВозврата;
			КонецПопытки;
			
			//++ Проверка на увольнение
			ПроверкаНаДатуУвольнения = XMLЗначение(Тип("Дата"),ДанныеОбмена.ДатаУвольнения);
			
			Если СокрЛП(ДанныеОбмена.ПричинаИзмененияСостояния) = "Увольнение" и ПроверкаНаДатуУвольнения <= ТекущаяДата() Тогда
				СпрПользователи = Справочники.Пользователи.НайтиПоРеквизиту("ФизическоеЛицо",Объект_ФизЛицо.Ссылка);
				
				Если ЗначениеЗаполнено(СпрПользователи) Тогда
					ОбъектПользователи = СпрПользователи.ПолучитьОбъект();
					ОбъектПользователи.Недействителен = Истина;
					
					Попытка
						ОбъектПользователи.Записать();
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтурктураВозврата.Результат;
КонецФункции

