			ЗаписьXML.ЗаписатьТекст(XMLСтрока(ДанныеВозврата.ID));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("ОбъектДОТип");
			ЗаписьXML.ЗаписатьТекст(XMLСтрока(ДанныеВозврата.type));
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
	конецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	xml_строка = ЗаписьXML.Закрыть();
	
	Возврат xml_строка;
	
КонецФункции

функция ПолучитьОбъектJSON(ОбъектЗначение) Экспорт
	
	Структура = Новый Структура(); /// реквизиты
	
	Структура.Вставить("Type",ОбъектЗначение.Метаданные().Имя);
	Структура.Вставить("Ref",строка(ОбъектЗначение.УникальныйИдентификатор()));
	Структура.Вставить("ИННЗаказчика","8620006279");
	Для каждого Реквизит из ОбъектЗначение.Метаданные().СтандартныеРеквизиты Цикл
		Если ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Число") ИЛИ ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Дата") ИЛИ ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Булево") тогда
			Структура.Вставить(Реквизит.Имя, ОбъектЗначение[Реквизит.Имя]);
		иначе
			Структура.Вставить(Реквизит.Имя, Строка(ОбъектЗначение[Реквизит.Имя]));
		КонецЕсли;
	КонецЦикла; 
	
	Для каждого Реквизит из ОбъектЗначение.Метаданные().Реквизиты Цикл
		Если ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Число") ИЛИ ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Дата") ИЛИ ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("Булево") тогда
			Структура.Вставить(Реквизит.Имя, ОбъектЗначение[Реквизит.Имя]);
		иначе
			Структура.Вставить(Реквизит.Имя, Строка(ОбъектЗначение[Реквизит.Имя]));
		КонецЕсли;
		Если ТипЗнч(ОбъектЗначение[Реквизит.Имя]) = тип("СправочникСсылка.Организации") ИЛИ ТипЗнч(ОбъектЗначение[Реквизит.Имя])  = тип("СправочникСсылка.Контрагенты") тогда
			Структура.Вставить(Реквизит.Имя+"ИНН", ОбъектЗначение[Реквизит.Имя].ИНН);
			Структура.Вставить(Реквизит.Имя+"КПП", ОбъектЗначение[Реквизит.Имя].КПП);
		КонецЕсли;
		//т.к. код или номер объекта для индефикации
		Если НЕ ОбъектЗначение[Реквизит.Имя] = Неопределено и Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(ОбъектЗначение[Реквизит.Имя])) тогда
			Структура.Вставить(Реквизит.Имя+"Код", ОбъектЗначение[Реквизит.Имя].Код);
			Структура.Вставить(Реквизит.Имя+"УИН", строка(ОбъектЗначение[Реквизит.Имя].Ссылка.УникальныйИдентификатор()));
		ИначеЕсли НЕ ОбъектЗначение[Реквизит.Имя] = Неопределено и Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(ОбъектЗначение[Реквизит.Имя])) тогда
			Структура.Вставить(Реквизит.Имя+"Номер", ОбъектЗначение[Реквизит.Имя].Номер);
			Структура.Вставить(Реквизит.Имя+"УИН", строка(ОбъектЗначение[Реквизит.Имя].Ссылка.УникальныйИдентификатор()));
		КонецЕсли;
		
		Если НЕ ОбъектЗначение[Реквизит.Имя] = Неопределено И Перечисления.ТипВсеСсылки().СодержитТип(ТипЗнч(ОбъектЗначение[Реквизит.Имя])) Тогда
			ИмяПеречисления = ОбъектЗначение[Реквизит.Имя].Метаданные().Имя;
			ИндексЗначенияПеречисления = Перечисления[ИмяПеречисления].Индекс(ОбъектЗначение[Реквизит.Имя]);
			ИмяЗначенияПеречисления = Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления[ИндексЗначенияПеречисления].Имя; 
			
			Структура.Вставить(Реквизит.Имя+"Имя", ИмяЗначенияПеречисления);
		КонецЕсли;	
	КонецЦикла;                       
	
	Для каждого ТабличнаяЧасть из ОбъектЗначение.Метаданные().ТабличныеЧасти Цикл    
		ТаблизазНач = ОбъектЗначение[ТабличнаяЧасть.Имя].Выгрузить();
		Для Каждого Колонка Из ТаблизазНач.Колонки цикл
			Массив =  ТаблизазНач.ВыгрузитьКолонку(Колонка.Имя);
			МассивВстроку = Новый Массив;
			МассивКодНомер = Новый Массив;
			МассивАртикул = Новый Массив;
			МассивИНН = Новый Массив;
			МассивКПП = Новый Массив;
			МассивУИН = Новый Массив;
			МассивРеквизиты = Новый Массив;
			Для Каждого Стр из Массив цикл
				Если ТипЗнч(Стр) = тип("Число") ИЛИ ТипЗнч(Стр) = тип("Дата") ИЛИ ТипЗнч(Стр) = тип("Булево") тогда
					МассивВстроку.Добавить(Стр);
				иначе
					МассивВстроку.Добавить(Строка(Стр));
				КонецЕсли;
				Если ТипЗнч(Стр) = тип("СправочникСсылка.Номенклатура") тогда
					МассивАртикул.Добавить(Стр.Артикул);
				КонецЕсли;
				Если ТипЗнч(Стр) = тип("СправочникСсылка.Организации") ИЛИ ТипЗнч(Стр) = тип("СправочникСсылка.Контрагенты") тогда
					МассивИНН.Добавить(Стр.ИНН);
					МассивКПП.Добавить(Стр.КПП);
				КонецЕсли;
				//Если ТипЗнч(Стр) = тип("ДокументСсылка.МеКаМи_ТТН") тогда
				//	МассивРеквизиты.Добавить(Новый Структура("МассаНетто",Стр.СписокТМЦ.Итог("МассаНетто")));
				//КонецЕсли;
				//т.к. код или номер объекта для индефикации
				Если НЕ Стр = Неопределено и Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Стр)) тогда
					МассивКодНомер.Добавить(Стр.Код);
					МассивУИН.Добавить(строка(Стр.УникальныйИдентификатор()));
				ИначеЕсли НЕ Стр = Неопределено и Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Стр)) тогда
					МассивКодНомер.Добавить(Стр.Номер);
					МассивУИН.Добавить(строка(Стр.УникальныйИдентификатор()));
				КонецЕсли;
			КонецЦикла;
			Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя, МассивВстроку);
			//проверяем и добавляем дополнительные колонки
			Если МассивАртикул.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "Артикул", МассивАртикул);
			КонецЕсли;
			Если МассивКодНомер.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "КодНомер", МассивКодНомер);
			КонецЕсли;
			Если МассивКПП.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "КПП", МассивКПП);
			КонецЕсли;
			Если МассивИНН.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "ИНН", МассивИНН);
			КонецЕсли;
			Если МассивУИН.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "УИН", МассивУИН);
			КонецЕсли;
			Если МассивРеквизиты.Количество() > 0 тогда
				Структура.Вставить(ТабличнаяЧасть.Имя+Колонка.Имя + "Реквизиты", МассивРеквизиты);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Структура.Вставить("ВыполнилВыгрузку", Пользователи.ТекущийПользователь().Наименование);
	
	ЗаписиJSON = Новый ЗаписьJSON;
	//ЗаписиJSON.ОткрытьФайл(ИмяФайлаОтправки,,, Новый ПараметрыЗаписиJSON(, Символы.Таб));
	
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(,Символы.Таб);
	ЗаписиJSON.УстановитьСтроку(ПараметрыЗаписи);
	
	НастройкиСериал = Новый НастройкиСериализацииJSON;
	
	НастройкиСериал.ВариантЗаписиДаты  = ВариантЗаписиДатыJSON.ЛокальнаяДата;
	НастройкиСериал.ФорматСериализацииДаты  = ФорматДатыJSON.ISO;
	
	ЗаписатьJSON(ЗаписиJSON, Структура, НастройкиСериал);
	//Значение = Объект.Ссылка.ПолучитьОбъект();
	//СериализаторXDTO.ЗаписатьJSON(ЗаписиJSON, Значение, НазначениеТипаXML.Явное);
	JSONОбъект = ЗаписиJSON.Закрыть();	
	
	Возврат JSONОбъект;
конецФункции

Процедура НачатьОтправкуДанных() Экспорт
	
	СоединениеWS = ПолучитьДанныеОWS_БП();
	
	ТекстОшибки = "";
	
	Узел = ПланыОбмена.GDS_ОбменСБухгалтерией.НайтиПоКоду("БУХ");
	
	ВыборкаВыгрузки = ПланыОбмена.ВыбратьИзменения(Узел, 0);
	
	Пока ВыборкаВыгрузки.Следующий() цикл
			ОбъектВыгрузки = ВыборкаВыгрузки.Получить();
			Результат = 0;
			
			Если Строка(ОбъектВыгрузки) = "УдалениеОбъекта" и СтрНайти(ОбъектВыгрузки.Ссылка,"<Объект не найден>") > 0 Тогда
				ПланыОбмена.УдалитьРегистрациюИзменений(Узел,ОбъектВыгрузки);
			КонецЕсли;
			
			XML_Строка = СерилизацияДокумента(ОбъектВыгрузки);
			
			Если XML_Строка = "" Тогда
				ПланыОбмена.УдалитьРегистрациюИзменений(Узел, ОбъектВыгрузки);
				Продолжить;
			КонецЕсли;
			
			Данные = Новый ХранилищеЗначения(XML_Строка, Новый СжатиеДанных(9));
			
			Попытка
				Результат = СоединениеWS.ПринятьДанные(Данные,ТекстОшибки);
			Исключение
			КонецПопытки;
			
			Если Результат = 1 ИЛИ Результат = Истина Тогда
				ПланыОбмена.УдалитьРегистрациюИзменений(Узел,ОбъектВыгрузки);			
			КонецЕсли;
		КонецЦикла;
	
КонецПроцедуры

Процедура НачатьОтправкуДанныхВУАТ() Экспорт
	
	ТекстОшибки = "";
	
	Узел = ПланыОбмена.GDS_ОбменСУАТ.НайтиПоКоду("СТ");

	Если ТекущаяДата() <= Узел.ДатаОбмена Тогда
		Возврат;
	КонецЕсли;

	ВыборкаВыгрузки = ПланыОбмена.ВыбратьИзменения(Узел, 0);
	
	Пока ВыборкаВыгрузки.Следующий() цикл
		
		ОбъектВыгрузки = ВыборкаВыгрузки.Получить();
		
		Результат = 0;
		
		Если Строка(ОбъектВыгрузки) = "УдалениеОбъекта" и СтрНайти(ОбъектВыгрузки.Ссылка,"<Объект не найден>") > 0 Тогда
			ПланыОбмена.УдалитьРегистрациюИзменений(Узел,ОбъектВыгрузки);
			Продолжить;
		КонецЕсли;
		
		РезультатОтправки = ОтправкуJSONОбъект(ОбъектВыгрузки.Ссылка);
		
		Если РезультатОтправки = "ДокументЗаписан" Тогда 
			ПланыОбмена.УдалитьРегистрациюИзменений(Узел, ОбъектВыгрузки);
		Иначе
			ТекстОшибки = СтрШаблон("%1. %2",ОбъектВыгрузки.Ссылка, РезультатОтправки);
			ЗаписьЖурналаРегистрации("Выгрузка в УАТ", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОтправкуJSONОбъект(СсылкаНаОбъект)
	
	JSONОбъект = ПолучитьОбъектJSON(СсылкаНаОбъект);
	
	HTTPОтвет = ОтправитьHTTPЗапрос(JSONОбъект);
	
	Сообщение = HTTPОтвет.ПолучитьТелоКакСтроку();	
	
	ЧтениеJSON 		= Новый ЧтениеJSON;
	
	ЧтениеJSON.УстановитьСтроку(Сообщение);
	
	ДанныеДругойБазы = ПрочитатьJSON(ЧтениеJSON);
	
	ЧтениеJSON.Закрыть();
	
	ОтветСитэкТранс = ДанныеДругойБазы.Результат;
	
	Возврат ОтветСитэкТранс;
	
КонецФункции

