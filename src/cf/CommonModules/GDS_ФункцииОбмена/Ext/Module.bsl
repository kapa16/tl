Функция ОбработкаXML_ОсновныеСредства(ДанныеОбмена) Экспорт
	
	СтурктураВозврата = Новый Структура;
	СтурктураВозврата.Вставить("ОписаниеОшибки","");
	СтурктураВозврата.Вставить("Результат",Истина);
	
	УИН = Новый УникальныйИдентификатор(ДанныеОбмена.Ссылка);
	СправочникСсылка = Справочники.ОсновныеСредства.ПолучитьСсылку(УИН);
	
	Если Найти(строка(СправочникСсылка),"<Объект не найден>")>0 тогда
		Если ДанныеОбмена.ПометкаУдаления Тогда
			Возврат Истина;
		КонецЕсли;
		СправочникОбъект = Справочники.ОсновныеСредства.СоздатьЭлемент();
		СправочникОбъект.УстановитьСсылкуНового(СправочникСсылка);
		СправочникОбъект.Код 			= ДанныеОбмена.КодОС;
		СправочникОбъект.Наименование 	= СокрЛП(ДанныеОбмена.НаименованиеОС);		
		Попытка
			СправочникОбъект.Записать();
		Исключение
			СтурктураВозврата.Вставить("ОписаниеОшибки",ИнформацияОбОшибке());
			СтурктураВозврата.Вставить("Результат",Ложь);
			Возврат СтурктураВозврата.Результат;
		КонецПопытки;
	Иначе
		СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
		СправочникОбъект.Код 			= ДанныеОбмена.КодОС;
		СправочникОбъект.Наименование 	= СокрЛП(ДанныеОбмена.НаименованиеОС);
		СправочникОбъект.ПометкаУдаления = ДанныеОбмена.ПометкаУдаления;
		Попытка
			СправочникОбъект.Записать();
		Исключение
			СтурктураВозврата.Вставить("ОписаниеОшибки",ИнформацияОбОшибке());
			СтурктураВозврата.Вставить("Результат",Ложь);
			Возврат СтурктураВозврата.Результат;
		КонецПопытки;
	КонецЕсли;	
	
	Если СокрЛП(Лев(Прав(ДанныеОбмена.КодОС,5),1)) = "0" Тогда
		СсылкаТС = Справочники.уатТС.НайтиПоРеквизиту("ГаражныйНомер",СокрЛП(Прав(ДанныеОбмена.КодОС,4)));
	Иначе
		СсылкаТС = Справочники.уатТС.НайтиПоРеквизиту("ГаражныйНомер",СокрЛП(Прав(ДанныеОбмена.КодОС,5)));
	КонецЕсли;
	
	Если НЕ СсылкаТС.Пустая() Тогда
		ОбъектТС = СсылкаТС.ПолучитьОбъект();
		ОбъектТС.ОсновноеСредство = СправочникОбъект.Ссылка;
		ОбъектТС.Записать();
	КонецЕсли;
	
	Возврат СтурктураВозврата.Результат;
КонецФункции

