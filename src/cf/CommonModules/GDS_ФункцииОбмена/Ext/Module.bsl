Функция ОбработкаXML_АгрегатыТС(ДанныеОбмена)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	уатОперацииСАгрегатами.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.уатОперацииСАгрегатами КАК уатОперацииСАгрегатами
	               |ГДЕ
	               |	уатОперацииСАгрегатами.Дата = &Дата";
	Запрос.УстановитьПараметр("Дата", НачалоДня(Дата(ДанныеОбмена.Период)));
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если НЕ ВыборкаДетальныеЗаписи.Следующий() Тогда	
		ДокументОбъект = Документы.уатОперацииСАгрегатами.СоздатьДокумент();
		ДокументОбъект.Дата = НачалоДня(Дата(ДанныеОбмена.Период));
		ДокументОбъект.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	Иначе		
		ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();	
	КонецЕсли;
	
	НовСтр = ДокументОбъект.ПрочиеАгрегаты.Добавить();
	НовСтр.ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ТС));
	НовСтр.СерияНоменклатуры = Справочники.уатСерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Агрегат));
	НовСтр.Состояние = Перечисления.уатСостоянияАгрегатов[СтрЗаменить(ДанныеОбмена.СостояниеАгрегата, " ", "")];
	
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Возврат Истина;
	КонецПопытки;
	
