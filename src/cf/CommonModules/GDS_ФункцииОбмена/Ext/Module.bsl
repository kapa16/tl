Процедура ЗаполнитьВводВЭксплуатацию(ДанныеОбмена, УИН, Отказ)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	уатМестонахождениеТССрезПервых.Период КАК Период
	|ИЗ
	|	РегистрСведений.уатМестонахождениеТС.СрезПервых(, ТС = &ТС) КАК уатМестонахождениеТССрезПервых
	|ГДЕ
	|	уатМестонахождениеТССрезПервых.Регистратор.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("ТС", Справочники.уатТС.ПолучитьСсылку(УИН));
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат;	
	КонецЕсли;
	
	Период = XMLЗначение(Тип("Дата"), ДанныеОбмена.ТС_ДатаВводаВЭксплуатацию);
	
	Документ = Документы.уатВводВЭксплуатациюТСиОборудования.СоздатьДокумент();
	Документ.Дата = Дата(Период);
	Документ.Ответственный = Пользователи.ТекущийПользователь();
	Документ.Колонна = Справочники.уатКолонны.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.ВВЭ_Колонна));
	Документ.Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбмена.Подразделение_УникальныйИдентификатор));
	Если Найти(Строка(Документ.Подразделение), "<Объект не найден>") > 0 ИЛИ Документ.Подразделение = Справочники.ПодразделенияОрганизаций.ПустаяСсылка() Тогда
		Документ.Подразделение = ПолучитьПодразделение(ДанныеОбмена);
		Если НЕ ЗначениеЗаполнено(Документ.Подразделение) Тогда 
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	Документ.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	НовСтрока = Документ.ТС.Добавить();
	НовСтрока.ТС = Справочники.уатТС.ПолучитьСсылку(УИН);
	НовСтрока.ДатаВвода = Дата(Период);
	Документ.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

