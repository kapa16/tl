		Возврат Ложь;
	КонецПопытки;
	
	Если НЕ СпособРеализацииВебСервиса = Перечисления.уатСпособыРеализацииВебСервиса.REST Тогда
		УстановитьПризнакОтправлено(ДанныеАвторизации.ФизическоеЛицо, ДанныеАвторизации.ТС,,,,,Истина);
	КонецЕсли;
	resultCode = 0;
	
	Возврат Истина;
КонецФункции

