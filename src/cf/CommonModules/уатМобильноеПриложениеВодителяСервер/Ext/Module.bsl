			РедСтр.ВремяСтоянкиСек = РедСтр.ВремяСтоянкиСек + ((Выборка.ВремяСтоянки - Цел(Выборка.ВремяСтоянки))*6000 + Цел(Выборка.ВремяСтоянки)*3600);
