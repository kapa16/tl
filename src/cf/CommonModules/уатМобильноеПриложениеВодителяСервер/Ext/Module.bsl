Функция СериализоватьTaxiOrders(Знач TaxiOrders, ОтправлятьАдресНазначенияВОткрытыхЗаказах, ОдинЗаказ = Ложь, СпособРеализацииВебСервиса)
	
	Если СпособРеализацииВебСервиса = Перечисления.уатСпособыРеализацииВебСервиса.REST Тогда 
		Возврат уатМобильноеПриложениеВодителяСерверREST.СериализоватьTaxiOrders(TaxiOrders, ОтправлятьАдресНазначенияВОткрытыхЗаказах, ОдинЗаказ);
	Иначе
		Возврат уатМобильноеПриложениеВодителяСерверSOAP.СериализоватьTaxiOrders(TaxiOrders, ОтправлятьАдресНазначенияВОткрытыхЗаказах, ОдинЗаказ);
	КонецЕсли;

КонецФункции // СериализоватьCarServices()

Функция ОбработатьМетодUpdateTaxiOrder(Знач requestData, responseData, resultCode, Знач ДанныеАвторизации, СпособРеализацииВебСервиса)
	responseData = ПолучитьПустыеВыходныеДанные(СпособРеализацииВебСервиса);
	
	флОшибка = Ложь;
	
	ДанныеМодификации = ДесериализоватьUpdateTaxiOrder(requestData, флОшибка, СпособРеализацииВебСервиса);

	Если флОшибка 
		ИЛИ ДанныеМодификации.Количество() = 0 Тогда 
		resultCode = 160;
		
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураЗаказа = ДанныеМодификации[0];

	ДокСсылка   = СтруктураЗаказа.orderRef; 	
	ЗаказОбъект = ДокСсылка.ПолучитьОбъект();
	
	Если ЗаказОбъект.ПометкаУдаления Тогда
		resultCode = 161;
		Возврат Ложь;
	КонецЕсли;  
	
	
	Таксометр = Новый Структура("ДокументСсылка,transportingDistance,transportingDuration,waitingTime,pickupDistance,pickupDuration,pickupStartDate,waitingStartDate,factStartTime");
	ЗаполнитьЗначенияСвойств(Таксометр, СтруктураЗаказа.taximeter);
	Таксометр.ДокументСсылка = ЗаказОбъект.Ссылка; 
	ЗаписатьДанныеТаксометра(ДанныеАвторизации, Таксометр, 0);
	

	ЕстьИзмененияПоЗаказу = Ложь;
	Если СтруктураЗаказа.services.Количество() Тогда
		Для Каждого ТекУслуга Из СтруктураЗаказа.services Цикл 
			НомерСтроки = 1;
			Для Каждого ТекУслугаЗаказа Из ЗаказОбъект.Услуги Цикл
				Если ТекУслуга.serviceNumber = НомерСтроки
					И ТекУслуга.serviceRef = ТекУслугаЗаказа.Номенклатура Тогда
					ТекУслугаЗаказа.Количество = ТекУслуга.serviceAmount; 
					ТекУслугаЗаказа.РучнойВвод = Истина; 
					ТекУслугаЗаказа.СуммаСкидки =
					ТекУслугаЗаказа.Количество * ТекУслугаЗаказа.Цена * ТекУслугаЗаказа.ПроцентСкидки / 100;
					ТекУслугаЗаказа.Сумма = ТекУслугаЗаказа.Количество * ТекУслугаЗаказа.Цена;
					Если ЗначениеЗаполнено(ТекУслугаЗаказа.СуммаСкидки) Тогда
						ТекУслугаЗаказа.Сумма = ТекУслугаЗаказа.Сумма - ТекУслугаЗаказа.СуммаСкидки;
					КонецЕсли; 
					
					СтавкаНДС = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеСтавкиНДС(ТекУслугаЗаказа.СтавкаНДС);
					
					Попытка
						СуммаВклНДС = ТекУслугаЗаказа.СуммаВключаетНДС;
					Исключение
						СуммаВклНДС = ЗаказОбъект.СуммаВключаетНДС;
					КонецПопытки;
					
					ТекУслугаЗаказа.СуммаНДС = ?(СуммаВклНДС, 
					ТекУслугаЗаказа.Сумма - (ТекУслугаЗаказа.Сумма) / ((СтавкаНДС + 100) / 100),
					ТекУслугаЗаказа.Сумма * СтавкаНДС / 100);

					Прервать;
				КонецЕсли;
				НомерСтроки = НомерСтроки + 1;
			КонецЦикла;
		КонецЦикла;
		СтруктураДокумента  = уатОбщегоНазначенияКлиентСервер.СтруктураДокумента(ЗаказОбъект, "такЗаказТакси");
		ЗаказОбъект.СуммаДокумента  = уатОбщегоНазначенияТиповые.уатПолучитьСуммуДокументаСНДС(СтруктураДокумента, "Услуги");  
		
		ЕстьИзмененияПоЗаказу = Истина;
	КонецЕсли;
	
	НовыйСтатус = ПолучитьСтатусЗаказаТакси(СтруктураЗаказа.currentStatus); 
	Если ЗаказОбъект.Статус <> НовыйСтатус Тогда
		ЗаказОбъект.Статус    = НовыйСтатус;
		ЕстьИзмененияПоЗаказу = Истина;
	КонецЕсли;
	
	Если СтруктураЗаказа.isPaid <> Неопределено
		И ЗаказОбъект.Оплачено <> СтруктураЗаказа.isPaid Тогда 
		ЗаказОбъект.Оплачено  = СтруктураЗаказа.isPaid;
		ЕстьИзмененияПоЗаказу = Истина;
	КонецЕсли; 

	Если ЕстьИзмененияПоЗаказу Тогда
		ЗаказОбъект.ВремяПодачиФактическое    	= Таксометр.factStartTime;
		ЗаказОбъект.ВремяОкончанияФактическое 	= Таксометр.factStartTime + Таксометр.transportingDuration; 
		ЗаказОбъект.ВремяОжиданияОбщее       	= Таксометр.waitingTime / 60;
	КонецЕсли;
	ПересчетИтогов = Ложь;
	Если ЕстьИзмененияПоЗаказу
		И ЗаказОбъект.Статус = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Закрыт")
		ИЛИ ЗаказОбъект.Статус = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Сорван") Тогда
		ЗаказОбъект.КоличествоКмФакт	= Таксометр.transportingDistance;
		ЗаказОбъект.КоличествоМинФакт   = Таксометр.transportingDuration / 60;
		
		СтруктураОбъектовНастроек = Новый Структура;
		СтруктураОбъектовНастроек.Вставить("Организация",   ЗаказОбъект.Организация);
		СтруктураОбъектовНастроек.Вставить("Подразделение", ЗаказОбъект.Подразделение);

		changeMainServices = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ИспользоватьДанныеТаксометраВодительУАТДляПересчетаУслуг); 
	
		ПересчетИтогов = changeMainServices;
	КонецЕсли;	

	Если ЗаказОбъект.Статус = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Сорван")
		ИЛИ ЗаказОбъект.Статус = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Отклонен") Тогда
		ЗаказОбъект.ВидЗакрытия = Справочники.уатПричиныЗакрытияЗаказов.Отклонен;
	ИначеЕсли ЗаказОбъект.Статус = ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Закрыт") Тогда
		ЗаказОбъект.ВидЗакрытия = Справочники.уатПричиныЗакрытияЗаказов.ЗакрытУспешно;
	КонецЕсли;
	
	Если ЕстьИзмененияПоЗаказу
		И ЗначениеЗаполнено(НовыйСтатус) Тогда
		
		ЗаписатьСтатус = Истина;
		
