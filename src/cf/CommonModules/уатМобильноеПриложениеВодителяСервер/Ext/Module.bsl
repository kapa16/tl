Функция ПолучитьGetVehicles(Пользователь, ПолучатьПрицепы = Истина)
	ЗапросТерминал = Новый Запрос();
	ЗапросТерминал.УстановитьПараметр("Пользователь", Пользователь);
	
	ЗапросТерминал.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатПользователиМобильногоПриложения_ТС.ТС КАК ТС,
	|	ЛОЖЬ КАК Прицеп,
	|	уатПользователиМобильногоПриложения_ТС.ТС.Модель.НаличиеТопливногоБака КАК НаличиеТопливногоБака,
	|	уатПользователиМобильногоПриложения_ТС.Пользователь КАК Пользователь
	|ПОМЕСТИТЬ втТС
	|ИЗ
	|	РегистрСведений.уатПользователиМобильногоПриложения_ТС КАК уатПользователиМобильногоПриложения_ТС
	|ГДЕ
	|	уатПользователиМобильногоПриложения_ТС.Пользователь = &Пользователь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втТС.ТС КАК ТС,
	|	ЛОЖЬ КАК Прицеп,
	|	втТС.ТС.Модель.НаличиеТопливногоБака КАК НаличиеТопливногоБака,
	|	ВЫБОР
	|		КОГДА втТС.ТС.ГосударственныйНомер <> """"
	|			ТОГДА втТС.ТС.ГосударственныйНомер
	|		ИНАЧЕ втТС.ТС.Наименование
	|	КОНЕЦ КАК Наименование,
	|	Неопределено КАК ТСРодитель
	|ИЗ
	|	втТС КАК втТС";

	Если ПолучатьПрицепы Тогда
		ЗапросТерминал.Текст = ЗапросТерминал.Текст +"
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	уатСоставТС.ТС,
		|	ИСТИНА КАК Прицеп,
		|	уатСоставТС.ТС.Модель.НаличиеТопливногоБака,
		|	ВЫБОР
		|		КОГДА уатСоставТС.ТС.ГосударственныйНомер <> """"
		|			ТОГДА уатСоставТС.ТС.ГосударственныйНомер
		|		ИНАЧЕ уатСоставТС.ТС.Наименование
		|	КОНЕЦ,
		|	втТС.ТС
		|ИЗ
		|	втТС КАК втТС
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.уатСоставТС КАК уатСоставТС
		|		ПО втТС.ТС = уатСоставТС.ВСоставе
		|			И (НЕ уатСоставТС.ТС.ПометкаУдаления)
		|ГДЕ
		|	(уатСоставТС.ТС.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМоделейТС.Прицеп)
		|			ИЛИ уатСоставТС.ТС.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМоделейТС.Оборудование))
		|	И ВЫБОР
		|			КОГДА уатСоставТС.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Привлеченное)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ уатСоставТС.ТС.ДатаВыбытия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|					И НЕ уатСоставТС.ТС.ДатаВводаВЭксплуатацию = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|		КОНЕЦ";
	КонецЕсли;

	ВыборкаТерминал = ЗапросТерминал.Выполнить().Выгрузить();
	Возврат ВыборкаТерминал;
КонецФункции

Функция ОбработатьМетодGetTaxiOrders(responseData, resultCode, Знач ДанныеАвторизации, СпособРеализацииВебСервиса)
	
	стрНастроек = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьНастройкиМобильногоПриложения();

	ОграничениеЧислаЗаказовДнейВперед = стрНастроек.такОграничениеЧислаЗаказовДнейВперед;
	ОграничениеЧислаЗаказовДнейНазад  = стрНастроек.такОграничениеЧислаЗаказовДнейНазад;

	ОграничениеЧислаЗаказовЧасовВперед = стрНастроек.такОграничениеЧислаЗаказовЧасовВперед;
	ОграничениеЧислаЗаказовЧасовНазад  = стрНастроек.такОграничениеЧислаЗаказовЧасовНазад;

	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	ДатаОт = НачалоДня(ТекущаяДатаСеанса) - ОграничениеЧислаЗаказовДнейНазад * (60 * 60 * 24);
	ДатаПо = КонецДня(ТекущаяДатаСеанса) + ОграничениеЧислаЗаказовДнейВперед * (60 * 60 * 24);
	
	ВремяОт = ТекущаяДатаСеанса - ОграничениеЧислаЗаказовЧасовНазад * 60 * 60;
	ВремяПо = ТекущаяДатаСеанса + ОграничениеЧислаЗаказовЧасовВперед * 60 * 60;
	
	СписокСтатусов = Новый Массив;
	
	ВодительНеЗаполнен = Новый Массив();
	ВодительНеЗаполнен.Добавить(ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка"));
	ВодительНеЗаполнен.Добавить(ПредопределенноеЗначение("Справочник.ФизическиеЛица.ПустаяСсылка"));
	ВодительНеЗаполнен.Добавить(Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТС",           ДанныеАвторизации.ТС);
	Запрос.УстановитьПараметр("Водитель",     ДанныеАвторизации.ФизическоеЛицо); 
	Запрос.УстановитьПараметр("ДатаОт",       ДатаОт);
	Запрос.УстановитьПараметр("ДатаПо",       ДатаПо);
	Запрос.УстановитьПараметр("ВремяОт",      ВремяОт);
	Запрос.УстановитьПараметр("ВремяПо",      ВремяПо);
	Запрос.УстановитьПараметр("СписокСтатусов",        СписокСтатусов);
	Запрос.УстановитьПараметр("СтатусОткрытогоЗаказа", Справочники.уатСтатусы_уэ.Отклонен);
	Запрос.УстановитьПараметр("ТекДата",               ТекущаяДатаСеанса); 
	Запрос.УстановитьПараметр("ВодительНеЗаполнен",    ВодительНеЗаполнен); 
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	такЗаказТакси.Ссылка КАК Ссылка,
	               |	такЗаказТакси.Номер КАК Номер,
	               |	такЗаказТакси.АдресНазначения КАК АдресНазначения,
