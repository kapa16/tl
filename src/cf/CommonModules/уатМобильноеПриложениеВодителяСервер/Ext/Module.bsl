Процедура ПередЗаписьюЗаказаТаксиУстановкаПризнакаОбновления(Источник, ЗарегистрироватьВодителей)
	
	Если НЕ ЗначениеЗаполнено(Источник.Водитель) Тогда
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	уатВодителиНаЛинии.ФизическоеЛицо КАК ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.уатВодителиНаЛинии КАК уатВодителиНаЛинии
		|ГДЕ
		|	уатВодителиНаЛинии.ТС = &ТС";
		Запрос.УстановитьПараметр("ТС", Источник.ТС);
		
		ЗарегистрироватьВодителей = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ФизическоеЛицо");
	Иначе
		Если ТипЗнч(Источник.Водитель) = Тип("СправочникСсылка.Сотрудники") Тогда 
			ЗарегистрироватьВодителей.Добавить(Источник.Водитель.ФизическоеЛицо);
		Иначе 
			ЗарегистрироватьВодителей.Добавить(Источник.Водитель);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписьюЗаявкиНаРемонтУстановкаПризнакаОбновления(Источник, ЗарегистрироватьВодителей)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	уатВодителиНаЛинии.ФизическоеЛицо КАК ФизическоеЛицо
	|ИЗ
	|	РегистрСведений.уатВодителиНаЛинии КАК уатВодителиНаЛинии
	|ГДЕ
	|	уатВодителиНаЛинии.ТС = &ТС";
	Запрос.УстановитьПараметр("ТС", Источник.ТС);
	
	ЗарегистрироватьВодителей = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ФизическоеЛицо");
	
КонецПроцедуры

Процедура ЗарегистрироватьНеобходимостьОбновленияОбъекта(Источник, ЗарегистрироватьВодителей, ТС)
	
	Запрос = Новый Запрос();

	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	уатВодителиНаЛинии.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	уатВодителиНаЛинии.ТС КАК ТС
	               |ИЗ
	               |	РегистрСведений.уатВодителиНаЛинии КАК уатВодителиНаЛинии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.уатПользователиМобильногоПриложения КАК уатПользователиМобильногоПриложения
	               |		ПО уатВодителиНаЛинии.ФизическоеЛицо = уатПользователиМобильногоПриложения.Пользователь
	               |ГДЕ
	               |	уатВодителиНаЛинии.ФизическоеЛицо В(&массивВодителей)
	               |	И уатВодителиНаЛинии.ТС = &ТС
	               |	И ВЫБОР
	               |			КОГДА ТИПЗНАЧЕНИЯ(&Источник) = ТИП(Документ.уатМаршрутныйЛист)
	               |				ТОГДА ВЫБОР
	               |						КОГДА &ИспользоватьМаршрутныеЛисты И уатПользователиМобильногоПриложения.ИспользоватьМаршрутныеЛисты
	               |							ТОГДА ИСТИНА
	               |						ИНАЧЕ ЛОЖЬ
	               |					КОНЕЦ
	               |			ИНАЧЕ ВЫБОР
	               |					КОГДА ТИПЗНАЧЕНИЯ(&Источник) = ТИП(Документ.уатПутевойЛист)
	               |						ТОГДА ВЫБОР
	               |								КОГДА &ИспользоватьПутевыеЛисты И уатПользователиМобильногоПриложения.ИспользоватьПутевыеЛисты
	               |									ТОГДА ИСТИНА
	               |								ИНАЧЕ ЛОЖЬ
	               |							КОНЕЦ
	               |					ИНАЧЕ ВЫБОР
	               |							КОГДА ТИПЗНАЧЕНИЯ(&Источник) = ТИП(Справочник.уатЧаты)
	               |								ТОГДА ВЫБОР
	               |										КОГДА &ИспользоватьЧат И уатПользователиМобильногоПриложения.ИспользоватьЧат
	               |											ТОГДА ИСТИНА
	               |										ИНАЧЕ ЛОЖЬ
	               |									КОНЕЦ
	               |							ИНАЧЕ ВЫБОР
	               |									КОГДА ТИПЗНАЧЕНИЯ(&Источник) = ТИП(Документ.уатЗаявкаНаРемонт)
	               |										ТОГДА ВЫБОР
	               |												КОГДА &ИспользоватьЗаявкиНаРемонт И уатПользователиМобильногоПриложения.ИспользоватьЗаявкиНаРемонт
	               |													ТОГДА ИСТИНА
	               |												ИНАЧЕ ЛОЖЬ
	               |											КОНЕЦ
	               |									ИНАЧЕ ВЫБОР
	               |											КОГДА &ИспользоватьЗаказыТакси И уатПользователиМобильногоПриложения.ИспользоватьЗаказыТакси
	               |												ТОГДА ИСТИНА
	               |											ИНАЧЕ ЛОЖЬ
	               |										КОНЕЦ
	               |								КОНЕЦ
	               |						КОНЕЦ
	               |				КОНЕЦ
	               |		КОНЕЦ
	               |	И уатПользователиМобильногоПриложения.РаботаРазрешена";
	Запрос.УстановитьПараметр("массивВодителей", ЗарегистрироватьВодителей); 
	Запрос.УстановитьПараметр("ТС", ТС);
	Запрос.УстановитьПараметр("Источник", Источник);
	стрНастройкиМобильногоПриложения = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьНастройкиМобильногоПриложения(); 
	Запрос.УстановитьПараметр("ИспользоватьМаршрутныеЛисты", ?(стрНастройкиМобильногоПриложения.useRouteLists, Истина, Ложь));
	Запрос.УстановитьПараметр("ИспользоватьПутевыеЛисты", ?(стрНастройкиМобильногоПриложения.useWaybills, Истина, Ложь));
	Запрос.УстановитьПараметр("ИспользоватьЧат", ?(стрНастройкиМобильногоПриложения.useChat, Истина, Ложь));
	Запрос.УстановитьПараметр("ИспользоватьЗаявкиНаРемонт", ?(стрНастройкиМобильногоПриложения.useOrdersForRepair, Истина, Ложь));
	Запрос.УстановитьПараметр("ИспользоватьЗаказыТакси", ?(стрНастройкиМобильногоПриложения.useTaxiOrders, Истина, Ложь));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.уатОбъектыДляОбновленияМобильногоПриложения.СоздатьНаборЗаписей(); 
		НаборЗаписей.Заполнить(Неопределено);
		НаборЗаписей.Отбор.ФизическоеЛицо.Установить(Выборка.ФизическоеЛицо);
		НаборЗаписей.Отбор.ТС.Установить(Выборка.ТС);
		НаборЗаписей.Отбор.Объект.Установить(Источник);

		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() = 0 Тогда 
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.ФизическоеЛицо = Выборка.ФизическоеЛицо;
			НоваяЗапись.ТС             = Выборка.ТС;
			НоваяЗапись.Объект         = Источник;
			НоваяЗапись.ДатаЗанесения  = ТекущаяДатаСеанса();
			НаборЗаписей.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьПризнакОтправлено(ФизическоеЛицо, ТС = Неопределено, ОтправкаМЛ = Ложь, ОтправкаПЛ = Ложь, ОтправкаЗаказТакси = Ложь, ОтправкаСообщений = Ложь, ОтправкаЗР = Ложь)
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ФизическоеЛицо",     ФизическоеЛицо);
	Запрос.УстановитьПараметр("ОтправкаМЛ",         ОтправкаМЛ);
	Запрос.УстановитьПараметр("ОтправкаПЛ",         ОтправкаПЛ);
	Запрос.УстановитьПараметр("ОтправкаЗаказТакси", ОтправкаЗаказТакси);
	Запрос.УстановитьПараметр("ОтправкаСообщений",  ОтправкаСообщений);
	Запрос.УстановитьПараметр("ОтправкаЗР",         ОтправкаЗР);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатОбъектыДляОбновленияМобильногоПриложения.ФизическоеЛицо КАК ФизическоеЛицо,
	|	уатОбъектыДляОбновленияМобильногоПриложения.Объект КАК Объект,
	|	уатОбъектыДляОбновленияМобильногоПриложения.ТС КАК ТС
	|ИЗ
	|	РегистрСведений.уатОбъектыДляОбновленияМобильногоПриложения КАК уатОбъектыДляОбновленияМобильногоПриложения
	|ГДЕ
	|	уатОбъектыДляОбновленияМобильногоПриложения.ФизическоеЛицо = &ФизическоеЛицо
	|	И ВЫБОР
	|			КОГДА &ОтправкаМЛ
	|					И ТИПЗНАЧЕНИЯ(уатОбъектыДляОбновленияМобильногоПриложения.Объект) = ТИП(Документ.уатМаршрутныйЛист)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА &ОтправкаПЛ
	|							И ТИПЗНАЧЕНИЯ(уатОбъектыДляОбновленияМобильногоПриложения.Объект) = ТИП(Документ.уатПутевойЛист)
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ВЫБОР
	|							КОГДА &ОтправкаСообщений
	|									И ТИПЗНАЧЕНИЯ(уатОбъектыДляОбновленияМобильногоПриложения.Объект) = ТИП(Справочник.уатЧаты)
	|								ТОГДА ИСТИНА
	|							ИНАЧЕ ВЫБОР
	|									КОГДА &ОтправкаЗР
	|											И ТИПЗНАЧЕНИЯ(уатОбъектыДляОбновленияМобильногоПриложения.Объект) = ТИП(Документ.уатЗаявкаНаРемонт)
	|										ТОГДА ИСТИНА
	|									ИНАЧЕ ВЫБОР
	|											КОГДА &ОтправкаЗаказТакси
	|												ТОГДА ИСТИНА
	|											ИНАЧЕ ЛОЖЬ
	|										КОНЕЦ
	|								КОНЕЦ
	|						КОНЕЦ
	|				КОНЕЦ
	|		КОНЕЦ";
	Если ЗначениеЗаполнено(ТС) Тогда
		Запрос.УстановитьПараметр("ТС", ТС);
		Запрос.Текст = Запрос.Текст + "
		|	И уатОбъектыДляОбновленияМобильногоПриложения.ТС = &ТС";
	КонецЕсли;

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НаборЗаписи = РегистрыСведений.уатОбъектыДляОбновленияМобильногоПриложения.СоздатьНаборЗаписей(); 
		НаборЗаписи.Заполнить(Неопределено);
		НаборЗаписи.Отбор.ФизическоеЛицо.Установить(Выборка.ФизическоеЛицо);
		НаборЗаписи.Отбор.Объект.Установить(Выборка.Объект);
		Если ЗначениеЗаполнено(ТС) Тогда
			НаборЗаписи.Отбор.ТС.Установить(Выборка.ТС);
		КонецЕсли;
		НаборЗаписи.Записать();
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Возвращает объект, полученный в результате конвертации со строки JSON.
//
// Параметры:
//  СтрокаJSON - Строка
//
// Возвращаемое значение:
//  Произвольный
//
Функция СтрокуJSONВЗначение(СтрокаJSON) Экспорт
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
	
	ЧтениеJSON.Закрыть();
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьРеквизитыЭПЛ(Waybill) Экспорт 
	
	СоответвиеРеквизитовЭПЛ = Новый Соответствие();

	флЭД  = ПолучитьФункциональнуюОпцию("ИспользоватьОбменЭД");
	
	мсвПутевыеЛисты        = Новый Массив();
	мсвДанныеПутевыхЛистов = Новый Массив();
	СоответвиеПЛЭД         = Новый Соответствие();
	СостоянияПодписейПЛ    = Новый Соответствие();
	
	Если флЭД Тогда
		Пока Waybill.Следующий() Цикл
			Если ЗначениеЗаполнено(Waybill.ЭПД) 
				И мсвПутевыеЛисты.Найти(Waybill.Ссылка) = Неопределено Тогда
				мсвПутевыеЛисты.Добавить(Waybill.Ссылка); 
				
				ДанныеПутевыхЛистов = Новый Структура("ЭПД,Ссылка,ОбязательныйПослерейсовыйМедосмотр,
				|ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован,ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста");   
				ЗаполнитьЗначенияСвойств(ДанныеПутевыхЛистов, Waybill);
				мсвДанныеПутевыхЛистов.Добавить(ДанныеПутевыхЛистов);
			КонецЕсли;
		КонецЦикла;
		Waybill.Сбросить();
		Если мсвПутевыеЛисты.Количество() <> 0 Тогда
			уатОбменСГИСЭПД.ЗаполнитьСостоянияПЛ(мсвПутевыеЛисты, СостоянияПодписейПЛ, СоответвиеПЛЭД);
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого ТекПЛ Из мсвДанныеПутевыхЛистов Цикл
		РезультатСтруктара = Новый Структура();
		РезультатСтруктара.Вставить("QR", ?(НЕ флЭД, Ложь, Истина)); 
		
		// Сформирован электронный документ
		// 0 - не используется (отключено использование ЭПД на уровне базы или ЭПД используется, но ЭПЛ не создан)
		// 1 - используется, не оформлен (создан в базе и не подписан диспетчером)
		// 2 - используется, оформлен
		SignedT1 = 0;
		SignedT2 = 0;
		SignedT3 = 0;
		SignedT4 = 0;
		SignedT5 = 0;
		SignedT6 = 0;
		ElectronicWaybillCreated = 0;
		Если ЗначениеЗаполнено(ТекПЛ.ЭПД)
			И флЭД Тогда 
			ТекЭПЛ = СоответвиеПЛЭД.Получить(ТекПЛ.Ссылка);
			Если ТекЭПЛ <> Неопределено Тогда
				ElectronicWaybillCreated = ?(ТекЭПЛ.Титул1Подписан, 2, 1);
				
				SignedT1 = ?(ТекЭПЛ.Титул1Подписан, 2, 1);
				SignedT2 = ?(ТекЭПЛ.Титул2Подписан, 2, 1);
				SignedT3 = ?(ТекЭПЛ.Титул3Подписан, 2, 1);
				SignedT4 = ?(ТекЭПЛ.Титул4Подписан, 2, 1);
				SignedT5 = ?(ТекЭПЛ.Титул5Подписан, 2, 1);
				SignedT6 = ?(ТекЭПЛ.Титул6Подписан, 2, ?(ТекПЛ.ОбязательныйПослерейсовыйМедосмотр, 1, 0));
			Иначе 
				ElectronicWaybillCreated = 1;
			КонецЕсли;
		КонецЕсли;
		
		РезультатСтруктара.Вставить("ElectronicWaybillCreated", ElectronicWaybillCreated);
		РезультатСтруктара.Вставить("SignedT1", SignedT1);
		РезультатСтруктара.Вставить("SignedT2", SignedT2);
		РезультатСтруктара.Вставить("SignedT3", SignedT3);
		РезультатСтруктара.Вставить("SignedT4", SignedT4);
		РезультатСтруктара.Вставить("SignedT5", SignedT5);
		РезультатСтруктара.Вставить("SignedT6", SignedT6);

		Если SignedT4 = 2 Тогда
			Если ЗначениеЗаполнено(ТекПЛ.ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован) Тогда
				
				QRCodeValidUntil = КонецДня(ТекПЛ.ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован);
				
				Если ТекущаяДатаСеанса() <= QRCodeValidUntil Тогда
					РезультатСтруктара.Вставить("QRCodeValidFrom",  уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(НачалоДня(ТекПЛ.ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован)));
					РезультатСтруктара.Вставить("QRCodeValidUntil", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(QRCodeValidUntil));
				КонецЕсли;
			ИначеЕсли ЗначениеЗаполнено(ТекПЛ.ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста) Тогда
				QRCodeValidUntil = КонецДня(ТекПЛ.ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста);
				Если ТекущаяДатаСеанса() <= QRCodeValidUntil Тогда
					РезультатСтруктара.Вставить("QRCodeValidUntil", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(QRCodeValidUntil));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		СоответвиеРеквизитовЭПЛ.Вставить(ТекПЛ.Ссылка, РезультатСтруктара);
	КонецЦикла;
	
	Возврат СоответвиеРеквизитовЭПЛ;
КонецФункции

Процедура УстановитьПараметрыТЛЭ(МаршЛистОб, НайдСтр, мВыборкаЗаказы, ДанныеМодификацииМЛ)
	
	СтрокиМодификации = ДанныеМодификацииМЛ.НайтиСтроки(Новый Структура("routeListRef, lineID", мВыборкаЗаказы.МаршрутныйЛист, Строка(мВыборкаЗаказы.GUIDСтроки)));
	Если СтрокиМодификации.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокиМодификации[0].orderResultRef) Тогда 
		НайдСтр.ПричинаЗакрытияЗаказа = СтрокиМодификации[0].orderResultRef;
	КонецЕсли;
	
	Если уатЗащищенныеФункцииСервер.ВариантПоставкиКОРП() Тогда 
		ПараметрВыработки1 = НайдСтр.ПараметрВыработки1;
		ПараметрВыработки2 = НайдСтр.ПараметрВыработки2;
		
		Если ЗначениеЗаполнено(СтрокиМодификации[0].productivityRef1) Тогда 
			Если ПараметрВыработки1 = СтрокиМодификации[0].productivityRef1 Тогда 
				НайдСтр.Выработка1 = СтрокиМодификации[0].productivityVal1;
			ИначеЕсли ПараметрВыработки2 = СтрокиМодификации[0].productivityRef1 Тогда 
				НайдСтр.Выработка2 = СтрокиМодификации[0].productivityVal1;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокиМодификации[0].productivityRef2) Тогда 
			Если ПараметрВыработки1 = СтрокиМодификации[0].productivityRef2 Тогда 
				НайдСтр.Выработка1 = СтрокиМодификации[0].productivityVal2;
			ИначеЕсли ПараметрВыработки2 = СтрокиМодификации[0].productivityRef2 Тогда 
				НайдСтр.Выработка2 = СтрокиМодификации[0].productivityVal2;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаписатьКоординатыВРегистрТекущегоМестоположения(Знач ДанныеАвторизации, Знач ТабКоординат, resultCode)
	
	// Текущее местоположение
	ТабКоординат.Сортировать("Дата УБЫВ");
	
	Попытка
		МенЗаписи = РегистрыСведений.уатТекущиеКоординатыМП.СоздатьМенеджерЗаписи();
		МенЗаписи.Заполнить(Неопределено);
		
	Исключение
		ЗаписатьСообщениеОбОшибке("SetVehiclePositions", ОписаниеОшибки());
		resultCode = 35;
		
		Возврат Ложь;
	КонецПопытки;
	
	МенЗаписи.ТС           = ДанныеАвторизации.ТС;
	МенЗаписи.Дата         = ТабКоординат[0].Дата;
	МенЗаписи.ДатаВремяUTC = ТабКоординат[0].ДатаВремяUTC;
	МенЗаписи.Лат          = ТабКоординат[0].Лат;
	МенЗаписи.Лон          = ТабКоординат[0].Лон;
	МенЗаписи.Алт          = ТабКоординат[0].Алт;
	МенЗаписи.Скорость     = ТабКоординат[0].Скорость;
	МенЗаписи.Направление  = ТабКоординат[0].Направление;
	МенЗаписи.ЧасовойПояс  = ТабКоординат[0].ЧасовойПояс; 
	
	Попытка
		МенЗаписи.Записать(Истина);
	Исключение
		ЗаписатьСообщениеОбОшибке("SetVehiclePositions", ОписаниеОшибки());
		resultCode = 35;
		
		Возврат Ложь;
	КонецПопытки;
	
	resultCode = 0;
	
	Возврат Истина;
	
КонецФункции // ЗаписатьКоординатыВРегистрТекущегоМестоположения()

Функция ЗаписатьДанныеТаксометра(Знач ДанныеАвторизации, Знач Таксометр, resultCode)
	
