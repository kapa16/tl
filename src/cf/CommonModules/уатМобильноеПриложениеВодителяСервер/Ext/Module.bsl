Функция ДесериализоватьUpdateTaxiOrder(Знач requestData, флОшибка, СпособРеализацииВебСервиса)
	
	Если СпособРеализацииВебСервиса = Перечисления.уатСпособыРеализацииВебСервиса.REST Тогда 
		Возврат уатМобильноеПриложениеВодителяСерверREST.ДесериализоватьUpdateTaxiOrder(requestData, флОшибка);
	Иначе
		Возврат уатМобильноеПриложениеВодителяСерверSOAP.ДесериализоватьUpdateTaxiOrder(requestData, флОшибка);
	КонецЕсли;
	
КонецФункции // ДесериализоватьUpdateTaxiOrder()

Функция ОбработатьМетодSendRequestForOrder(Знач requestData, responseData, resultCode, Знач ДанныеАвторизации, СпособРеализацииВебСервиса)
	
	responseData = ПолучитьПустыеВыходныеДанные(СпособРеализацииВебСервиса);
	ГУИД = "" + requestData; 
	Попытка 
		ДокСсылка = Документы.такЗаказТакси.ПолучитьСсылку(Новый УникальныйИдентификатор(ГУИД));	
	Исключение
		resultCode = 170;
		
		Возврат Ложь;
	КонецПопытки;
	
	Если ДокСсылка.ПолучитьОбъект() = Неопределено Тогда 
		resultCode = 170;
		
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокСсылка.Водитель) тогда
		// Заказ уже распределен, дальше можно ничего не проверять
		resultCode = 171;
		Возврат Ложь;
	КонецЕсли;

	// Проверим границу распределения заказов
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	такГраницыРаспределенияЗаказов.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	РегистрСведений.такГраницыРаспределенияЗаказов КАК такГраницыРаспределенияЗаказов
	|ГДЕ
	|	такГраницыРаспределенияЗаказов.Заказ = &Заказ");
	Запрос.УстановитьПараметр("Заказ", ДокСсылка);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	Если ТЗ.Количество() Тогда
		Если ТекущаяДата() >= ТЗ[0].ДатаОкончания Тогда
			// Время приема заявок истекло
			resultCode = 172;
			Возврат Ложь;
		КонецЕсли;
	Иначе
		// Первая заявка на данный заказ
		МенЗаписи = РегистрыСведений.такГраницыРаспределенияЗаказов.СоздатьМенеджерЗаписи(); 
		МенЗаписи.Заполнить(Неопределено);
		МенЗаписи.Заказ = ДокСсылка;
		Если Константы.такСпособОграниченияПриемаЗаявок.Получить() = Перечисления.такСпособыОграниченияПриемаЗаявокНаАвтоматическоеРаспределение.ВремяДоВремениПодачи тогда
			менЗаписи.ДатаОкончания = ДокСсылка.ВремяПодачи - Константы.такВремяОграниченияПриемаЗаявок.Получить();
		Иначе
			менЗаписи.ДатаОкончания = ТекущаяДатаСеанса() + Константы.такВремяОграниченияПриемаЗаявок.Получить();
		КонецЕсли;
		Попытка
			МенЗаписи.Записать();
		Исключение   
			resultCode = 170;
			Возврат Ложь;	
		КонецПопытки;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ФизическоеЛицо = &Водитель");
	
	Запрос.УстановитьПараметр("Водитель", ДанныеАвторизации.ФизическоеЛицо);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Водитель = Выборка.Ссылка;
	Иначе 
		Водитель = ДанныеАвторизации.ФизическоеЛицо;
	КонецЕсли;
	ТС = ДанныеАвторизации.ТС;	
	
	// Подадим заявку на заказ, если уже подана ранее, то ничего не делаем
	ЗаказКРаспределению = РегистрыСведений.такЗаказыКРаспределению.СоздатьМенеджерЗаписи();  
	ЗаказКРаспределению.Заполнить(Неопределено);
	ЗаказКРаспределению.Заказ    = ДокСсылка;
	ЗаказКРаспределению.Водитель = Водитель;
	ЗаказКРаспределению.Прочитать();
	Если НЕ ЗаказКРаспределению.Выбран() Тогда
		ЗаказКРаспределению.Заказ    		 = ДокСсылка;
		ЗаказКРаспределению.Водитель		 = Водитель;
		ЗаказКРаспределению.ТС 				 = ТС;
		ЗаказКРаспределению.ДатаПодачиЗаявки = ТекущаяДатаСеанса();
		ЗаказКРаспределению.Записать();
	КонецЕсли;
		
	Возврат Истина;
	
КонецФункции // ОбработатьМетодSendLateArrival()

Функция ПолучитьИмяСтатусаЗаказаТакси(текСтатус) Экспорт
	
	СоответствиеСтатусов = Новый Соответствие;
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.ВПути, "transportation");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Закрыт, "closed");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Нераспределенный, "unassigned");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.ОжиданиеКлиента, "waiting");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Отклонен, "cancelled");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.ПереданВАренду, "");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.ПодачаПоАдресу, "driving");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Предварительный, "preorder");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Распределенный, "assigned");
	СоответствиеСтатусов.Вставить(Справочники.уатСтатусы_уэ.Сорван, "failed");

	НайденныйСтатус = СоответствиеСтатусов[текСтатус];
	Если НайденныйСтатус = Неопределено Тогда
		НайденныйСтатус = Строка(текСтатус);
	КонецЕсли;
	
	Возврат НайденныйСтатус;
	
КонецФункции

Функция ПолучитьСтатусЗаказаТакси(текСтатус)
	
	СоответствиеСтатусов = Новый Соответствие;
	СоответствиеСтатусов.Вставить("transportation", Справочники.уатСтатусы_уэ.ВПути);
	СоответствиеСтатусов.Вставить("closed",         Справочники.уатСтатусы_уэ.Закрыт);
	СоответствиеСтатусов.Вставить("unassigned",     Справочники.уатСтатусы_уэ.Нераспределенный);
	СоответствиеСтатусов.Вставить("waiting",        Справочники.уатСтатусы_уэ.ОжиданиеКлиента);
	СоответствиеСтатусов.Вставить("cancelled",      Справочники.уатСтатусы_уэ.Отклонен);
	СоответствиеСтатусов.Вставить("driving",        Справочники.уатСтатусы_уэ.ПодачаПоАдресу);
	СоответствиеСтатусов.Вставить("preorder",       Справочники.уатСтатусы_уэ.Предварительный);
	СоответствиеСтатусов.Вставить("assigned",       Справочники.уатСтатусы_уэ.Распределенный);
	СоответствиеСтатусов.Вставить("failed",         Справочники.уатСтатусы_уэ.Сорван);
	
	НайденныйСтатус = СоответствиеСтатусов[текСтатус];
	Если НайденныйСтатус = Неопределено Тогда
		НайденныйСтатус = Строка(текСтатус);
	КонецЕсли;
	
	Возврат НайденныйСтатус;
	
КонецФункции

// Функция предназначена для отражения изменений по закявкам на ремонт с мобильного приложения
//
// Параметры:
//  requestData       - строка    - строка XML, входные данные, содержимое определяется контекстом выполняемого метода
//  responseData      - строка    - строка XML, выходные данные, содержимое определяется контекстом выполняемого метода
//  resultCode        - число     - код результата выполнения
//  ДанныеАвторизации - структура - данные об авторизованном пользователе (ФизическоеЛицо и ТС)
//
// Возвращаемое значение:
//   Булево      - истина - метод выполнен успешно;
//               - ложь   - при выполнении метода возникла ошибка
//
Функция ОбработатьМетодUpdateOrderForRepair(Знач requestData, responseData, resultCode, Знач ДанныеАвторизации, СпособРеализацииВебСервиса)
	
	responseData = ПолучитьПустыеВыходныеДанные(СпособРеализацииВебСервиса);
	
	флОшибка = Ложь;
	
	ДанныеЗР = ДесериализоватьUpdateOrderForRepair(requestData, флОшибка, СпособРеализацииВебСервиса);
	
	Если флОшибка Тогда 
		resultCode = 29999;
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка
		НовыйДокумент              = ДанныеЗР.Ссылка.ПолучитьОбъект();
	Исключение
		ЗаписатьСообщениеОбОшибке(НСтр("en='ОбработатьМетодUpdateOrderForRepair';ru='ОбработатьМетодUpdateOrderForRepair'"), ОписаниеОшибки());
		resultCode = 29999;
		Возврат Ложь;
	КонецПопытки;
	
	НовыйДокумент.ДатаНачала       = ДанныеЗР.ДатаНачала;
	НовыйДокумент.ДатаОкончания    = ДанныеЗР.ДатаОкончания;
	НовыйДокумент.ПричинаОбращения = ДанныеЗР.ПричинаОбращения;
	НовыйДокумент.ТС               = ДанныеЗР.ТС;
	НовыйДокумент.ВидОбслуживания  = ДанныеЗР.ВидРемонта;
	НовыйДокумент.СтатусПодтвержденияВодителем = ДанныеЗР.СтатусПодтвержденияВодителем;
	НовыйДокумент.КомментарийВодителя          = ДанныеЗР.КомментарийВодителя;
	
	Попытка 
		НовыйДокумент.ДополнительныеСвойства.Вставить("НеУстановливатьПризнакОбновленияМобильногоПриложения", Истина);
		НовыйДокумент.Записать();
	Исключение
		ЗаписатьСообщениеОбОшибке(НСтр("en='ОбработатьМетодUpdateOrderForRepair';ru='ОбработатьМетодUpdateOrderForRepair'"), ОписаниеОшибки());
		resultCode = 29999;
		Возврат Ложь;
	КонецПопытки;
	УстановитьПривилегированныйРежим(Ложь);
	
	resultCode = 0;
	Возврат Истина;
	
КонецФункции // ОбработатьМетодUpdateOrderForRepair()

// Функция предназначена для отражения изменений по закявкам на ремонт с мобильного приложения
//
// Параметры:
//  requestData       - строка    - строка XML, входные данные, содержимое определяется контекстом выполняемого метода
//  responseData      - строка    - строка XML, выходные данные, содержимое определяется контекстом выполняемого метода
//  resultCode        - число     - код результата выполнения
//  ДанныеАвторизации - структура - данные об авторизованном пользователе (ФизическоеЛицо и ТС)
//
// Возвращаемое значение:
//   Булево      - истина - метод выполнен успешно;
//               - ложь   - при выполнении метода возникла ошибка
//
Функция ОбработатьМетодAddOrderForRepair(Знач requestData, responseData, resultCode, Знач ДанныеАвторизации, СпособРеализацииВебСервиса)
	
	responseData = ПолучитьПустыеВыходныеДанные(СпособРеализацииВебСервиса);
	
	флОшибка = Ложь;
	
	ДанныеЗР = ДесериализоватьAddOrderForRepair(requestData, флОшибка, СпособРеализацииВебСервиса);
	
	Если флОшибка Тогда 
		resultCode = 29999;
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЗначениеЗаполнено(ДанныеЗР.Ссылка) Тогда
		Попытка
			НовыйДокумент = ДанныеЗР.Ссылка.ПолучитьОбъект();
		Исключение
			ЗаписатьСообщениеОбОшибке(НСтр("en='ОбработатьМетодAddOrderForRepair';ru='ОбработатьМетодAddOrderForRepair'"), ОписаниеОшибки());
			resultCode = 125;
			Возврат Ложь;
		КонецПопытки;
		Если НовыйДокумент = Неопределено Тогда
			НовыйДокумент  = Документы.уатЗаявкаНаРемонт.СоздатьДокумент();  
			НовыйДокумент.Заполнить(Неопределено);
			НовыйДокумент.УстановитьСсылкуНового(ДанныеЗР.Ссылка); 
			НовыйДокумент.Дата = ДанныеЗР.Дата; 
		КонецЕсли; 
	Иначе
		НовыйДокумент  = Документы.уатЗаявкаНаРемонт.СоздатьДокумент();
		НовыйДокумент.Заполнить(Неопределено);
		НовыйДокумент.УстановитьСсылкуНового(ДанныеЗР.Ссылка); 
		НовыйДокумент.Дата = ДанныеЗР.Дата; 
	КонецЕсли;
	
	НовыйДокумент.ДатаНачала       = ДанныеЗР.ДатаНачала;
	НовыйДокумент.ДатаОкончания    = ДанныеЗР.ДатаОкончания;
	НовыйДокумент.ПричинаОбращения = ДанныеЗР.ПричинаОбращения;
	НовыйДокумент.ТС               = ДанныеЗР.ТС;
	НовыйДокумент.ВидОбслуживания  = ДанныеЗР.ВидРемонта;
	НовыйДокумент.СтатусПодтвержденияВодителем  = ДанныеЗР.СтатусПодтвержденияВодителем;
	НовыйДокумент.КомментарийВодителя           = ДанныеЗР.КомментарийВодителя;
	
	МестоТС      = уатОбщегоНазначения.МестонахождениеТС(НовыйДокумент.ТС, НовыйДокумент.Дата);
	Пользователь = ПользователиКлиентСервер.АвторизованныйПользователь();
	Если НЕ ЗначениеЗаполнено(МестоТС.Организация) Тогда
		ОсновнаяОрганизация = уатОбщегоНазначенияПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, 
		"ОсновнаяОрганизация");
	Иначе
		ОсновнаяОрганизация = МестоТС.Организация;
	КонецЕсли;
	
	НовыйДокумент.Организация      = ОсновнаяОрганизация;
	НовыйДокумент.Ответственный    = Пользователь;
	НовыйДокумент.СпособРемонта    = Перечисления.уатСпособыРемонта.Автосервис;
	НовыйДокумент.СозданВодителем  = Истина;
	НовыйДокумент.Водитель         = ДанныеАвторизации.ФизическоеЛицо;
	НовыйДокумент.СтатусВыполнения = Справочники.уатСтатусы_уэ.Новый;
		
	Попытка
		НовыйДокумент.ДополнительныеСвойства.Вставить("НеУстановливатьПризнакОбновленияМобильногоПриложения", Истина);
		НовыйДокумент.Записать();
	Исключение
		ЗаписатьСообщениеОбОшибке(НСтр("en='ОбработатьМетодAddOrderForRepair';ru='ОбработатьМетодAddOrderForRepair'"), ОписаниеОшибки());
		resultCode = 125;
		Возврат Ложь;
	КонецПопытки;
	УстановитьПривилегированныйРежим(Ложь);
	
	resultCode = 0;
	Возврат Истина;
	
КонецФункции // ОбработатьМетодUpdateOrderForRepair()

#КонецОбласти

