	МенЗаписи.ДатаНачалаНаПодачу = Таксометр.pickupStartDate;
	МенЗаписи.ДатаНачалаОжидания = Таксометр.waitingStartDate;
	МенЗаписи.ДатаНачалаПоездки  = Таксометр.factStartTime;
	
	Попытка
		МенЗаписи.Записать(Истина);
	Исключение
		ЗаписатьСообщениеОбОшибке("SetVehiclePositions", ОписаниеОшибки());
		resultCode = 35;
		
		Возврат Ложь;
	КонецПопытки;
	
	resultCode = 0;
	
	Возврат Истина;
	
КонецФункции

