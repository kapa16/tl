		КонецЕсли;
		
		Если Результат И resultCode = 0 Тогда 
			ОбновитьВремяПоследнегоСобытия(ДанныеАвторизации);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ОбработатьМетодExecuteCommand()

