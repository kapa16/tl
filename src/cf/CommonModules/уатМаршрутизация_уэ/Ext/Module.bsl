
#Область СлужебныйПрограммныйИнтерфейс

Процедура ВыполнитьМаршрутизациюАлгоритмомОчередей(АдресВрХранилища, Заказы, ЗаказыПоКоординатам, мсвТС, мсвВиртТС, АдресДепо, 
		НастройкаКластеризации, РежимОптимизации, ОграничениеЧасов=0, ОграничениеПоРасстоянию=0, МаксимальноеКоличествоЗаказовТС=0,
		МаксимальноеЧислоПунктов=0, ВремяВыезда='00010101000000', СжиматьЗаказы=Ложь, АлгоритмМаршрутизации=0, ИндивидуальныйГаражТС=Ложь,
		ВозвратВГаражСобственныеТС=Ложь, ВозвратВГаражПривлеченныеТС=Ложь, ВозвратВГаражВиртуальныеТС=Ложь, УчитыватьОграниченияПоЗагрузкеТС=Ложь,
		ПараметрыСжатия=Неопределено, УчитыватьОкнаПоЗаказам=Ложь, УчитыватьРазрешенныеТипыТС=Ложь, РежимВремениВыездаИзГаража=0, ПараметрРазмераЗаказа=0,
		ПриоритетыМаршрутизации=Неопределено, ИспользоватьВПриоритетеСобственныйТранспорт=Ложь, УчитыватьНаправленияПеревозки=Ложь,
		ИспользоватьХарактеристикиЗаказовНаТС=Ложь) Экспорт
	
	Если АлгоритмМаршрутизации = 0 Тогда // Балансировки очередей
		ПолучитьРаспределениеЗаказов(АдресВрХранилища, Заказы, ЗаказыПоКоординатам, мсвТС, мсвВиртТС, АдресДепо, 
			НастройкаКластеризации, РежимОптимизации, ОграничениеЧасов, ОграничениеПоРасстоянию, МаксимальноеКоличествоЗаказовТС,
			МаксимальноеЧислоПунктов, ВремяВыезда, СжиматьЗаказы, ИндивидуальныйГаражТС, ВозвратВГаражСобственныеТС,
			ВозвратВГаражПривлеченныеТС, ВозвратВГаражВиртуальныеТС, ПараметрыСжатия, УчитыватьОкнаПоЗаказам,
			УчитыватьРазрешенныеТипыТС, РежимВремениВыездаИзГаража, ПараметрРазмераЗаказа,
			ПриоритетыМаршрутизации, ИспользоватьВПриоритетеСобственныйТранспорт, УчитыватьНаправленияПеревозки,
			ИспользоватьХарактеристикиЗаказовНаТС
		);
	Иначе 
		ВызватьИсключение НСтр("ru = 'Неверный параметр ""АлгоритмМаршрутизации"".'; en = ""Invalid 'RoutingAlgorithm' parameter.""");
	КонецЕсли;
	
КонецПроцедуры

#Область Яндекс

Функция ПолучитьСтруктуруЗапросаMVRP(ДатаПланирования, тблТСдляМаршрутизации, ТаблицаЗаказов, СтруктураНастроекАРМ,
	Склад, тблАдреса, РазрешенныеТСПоЗаказам, МассивГеозон, СоответствиеГеозонПунктов, СоответствиеГеозонТС,
	ТекстОшибки, ПересчетМетрик = Ложь, флПереносДаты = Ложь, СчДобавленныхОбъектов = 0) Экспорт
	
	флRarusVRP    = СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4;
	флагСдвигДаты = флПереносДаты; 
	
	// Получаем экпертные настройки
	НастройкиМаршрутизации = уатЗащищенныеФункцииСервер_уэ.ПрочитатьНастройкиВнешнийМаршрутизатор(СтруктураНастроекАРМ.НастройкиВнешнийМаршрутизатор);
	
	// Заполняем параметры склада  
	Структура_depot = ЗаполнитьСтруктуруПараметровСклада(ДатаПланирования, Склад, СтруктураНастроекАРМ, НастройкиМаршрутизации, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса);
	// Перенесем дату, если требуется
	МассивДат = Новый СписокЗначений;
	Для Каждого ТекЗаказ Из ТаблицаЗаказов Цикл
		МинДата        = Мин(ТекЗаказ.ОтправлениеСДата, ТекЗаказ.ДоставкаСДата);
		ДнейИзменилась = (ДатаПланирования - МинДата) / 60 / 60 / 24;
		
		Если СтруктураНастроекАРМ.НастройкаДействиеСПросроченнымиЗаказами = 0 Тогда
			Если ДнейИзменилась > 0 Тогда 
				// Сдвигаем только минимальную дату (дата планирования)
				ДнейИзмениласьСекунд		 = ДнейИзменилась * 60 *60 *24;
				ТекЗаказ.ОтправлениеСДата	 = ТекЗаказ.ОтправлениеСДата 
				+ ?(МинДата = ТекЗаказ.ОтправлениеСДата, ДнейИзмениласьСекунд, 0);
				ТекЗаказ.ОтправлениеПоДата	 = ТекЗаказ.ОтправлениеПоДата
				+ ?(МинДата = ТекЗаказ.ОтправлениеПоДата, ДнейИзмениласьСекунд, 0);
				ТекЗаказ.ДоставкаСДата		 = ТекЗаказ.ДоставкаСДата
				+ ?(МинДата = ТекЗаказ.ДоставкаСДата, ДнейИзмениласьСекунд, 0);
				ТекЗаказ.ДоставкаПоДата	     = ТекЗаказ.ДоставкаПоДата
				+ ?(МинДата = ТекЗаказ.ДоставкаПоДата, ДнейИзмениласьСекунд, 0);
			КонецЕсли;
		Иначе
			// Перенос на одинаковое число часов для всех временных окон по заказу,
			// Переносятся заказы, у которых "Отправление с" меньше начало дня рабочей даты  
			Если ДнейИзменилась > 0 Тогда
				ДнейИзмениласьСекунд		 = ДнейИзменилась * 60 *60 *24;
				ТекЗаказ.ОтправлениеСДата	 = ТекЗаказ.ОтправлениеСДата + ДнейИзмениласьСекунд;
				ТекЗаказ.ОтправлениеПоДата	 = ТекЗаказ.ОтправлениеПоДата + ДнейИзмениласьСекунд;
				ТекЗаказ.ДоставкаСДата		 = ТекЗаказ.ДоставкаСДата + ДнейИзмениласьСекунд;
				ТекЗаказ.ДоставкаПоДата	     = ТекЗаказ.ДоставкаПоДата + ДнейИзмениласьСекунд;
			КонецЕсли;
		КонецЕсли;
		
		Если МассивДат.НайтиПоЗначению(ТекЗаказ.ОтправлениеСДата) = Неопределено Тогда
			МассивДат.Добавить(ТекЗаказ.ОтправлениеСДата);
		КонецЕсли;
		Если МассивДат.НайтиПоЗначению(ТекЗаказ.ОтправлениеПоДата) = Неопределено Тогда
			МассивДат.Добавить(ТекЗаказ.ОтправлениеПоДата);
		КонецЕсли;
		Если МассивДат.НайтиПоЗначению(ТекЗаказ.ДоставкаСДата) = Неопределено Тогда
			МассивДат.Добавить(ТекЗаказ.ДоставкаСДата);
		КонецЕсли;
		Если МассивДат.НайтиПоЗначению(ТекЗаказ.ДоставкаПоДата) = Неопределено Тогда
			МассивДат.Добавить(ТекЗаказ.ДоставкаПоДата);
		КонецЕсли;
	КонецЦикла;
	
	// Таблица маршрута ТС для пересчета метрик
	Таблицаlocation = Новый ТаблицаЗначений();
	Таблицаlocation.Колонки.Добавить("ТС");
	Таблицаlocation.Колонки.Добавить("МЛ");
	Таблицаlocation.Колонки.Добавить("ДатаПосещения");
	Таблицаlocation.Колонки.Добавить("id");
	
	ТаблицаГруппПунктов = Новый ТаблицаЗначений();
	СоответвиеЗаказов = Новый Соответствие();
	ИспользуемыеГруппыСовместимости = Новый Массив();
	// Заполняем список пунктов назначения
	Массив_locations = ЗаполнитьСписокПунктовНазначение(ДатаПланирования, ТаблицаЗаказов, СтруктураНастроекАРМ, НастройкиМаршрутизации, Таблицаlocation,
	ТаблицаГруппПунктов, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, СоответствиеГеозонПунктов, СоответвиеЗаказов, РазрешенныеТСПоЗаказам,
	ИспользуемыеГруппыСовместимости);
	
	// Заполняем параметры Сервиса планирования маршрутов
	Структура_options = ЗаполнитьСтруктуруПараметровСервисаПланированияМаршрутов(ДатаПланирования, СтруктураНастроекАРМ,
	НастройкиМаршрутизации, ТаблицаГруппПунктов, ИспользуемыеГруппыСовместимости, МассивГеозон);
	
	ИспользоватьГруппыБалансировкиМаршрутов = Константы.уатИспользоватьГруппыБалансировкиМаршрутов_уэ.Получить();
	Если ИспользоватьГруппыБалансировкиМаршрутов Тогда
		ГруппыБалансировкиМаршрутов = уатВнешнийМаршрутизаторСервер_уэ.ЗаполнитьГруппыБалансировкиМаршрутов(тблТСдляМаршрутизации);
		
		Если ГруппыБалансировкиМаршрутов.Количество() <> 0 Тогда
			Структура_options.Вставить("balanced_groups", ГруппыБалансировкиМаршрутов);
		КонецЕсли;
	КонецЕсли;
	// Заполняем список транспортных средств, доступных для планирования маршрута.
	Массив_vehicles = Новый Массив();
	
	Для Каждого ТекТС Из тблТСдляМаршрутизации Цикл
		Структура_vehicle = ЗаполнитьСтруктуруТС(ТекТС, СтруктураНастроекАРМ, НастройкиМаршрутизации,
			ТаблицаLocation, Массив_locations, ПересчетМетрик, СчДобавленныхОбъектов, флагСдвигДаты, СоответствиеГеозонТС,
			СоответвиеЗаказов, ДатаПланирования, ИспользоватьГруппыБалансировкиМаршрутов);
		Массив_vehicles.Добавить(Структура_vehicle);
	КонецЦикла;
	
	// Несколько временных окон склада, если курьер выполняет многодневный маршрут
	уатВнешнийМаршрутизаторСервер_уэ.УстановитьНесколькоВременныхОкон(ДатаПланирования, СтруктураНастроекАРМ.НастройкаКоличествоДнейПланирования, 
	флRarusVRP, МассивДат, Структура_depot, Массив_vehicles);   
	
	Если флRarusVRP Тогда
		СтруктураЗапроса = Новый Структура();
		СтруктураЗапроса.Вставить("vehicles",  Массив_vehicles);
		СтруктураЗапроса.Вставить("depot",     Структура_depot);
		СтруктураЗапроса.Вставить("options",   Структура_options);
		СтруктураЗапроса.Вставить("locations", Массив_locations);
	Иначе 
		СтруктураЗапроса = Новый Структура();
		СтруктураЗапроса = уатВнешнийМаршрутизаторСервер_уэ.УстановитьПресеты(НастройкиМаршрутизации, Структура_options, Структура_depot, Массив_vehicles, Массив_locations,, ТекстОшибки, Склад);
		Если СтруктураНастроекАРМ.ТипАвторизации = "OAuth-токен" 
			И МассивГеозон.Количество() <> 0 Тогда
			Массив_zones = уатВнешнийМаршрутизаторСервер_уэ.ЗаполнитьСписокГеозон(МассивГеозон);
			СтруктураЗапроса.Вставить("zones",  Массив_zones);
		КонецЕсли;
	КонецЕсли;
	Возврат СтруктураЗапроса;
КонецФункции

Функция ПолучитьСтруктуруЗапросаSVRP(ДатаПланирования, ТСдляМаршрутизации, ДанныеПоЗаказам, ТаблицаЗаказов, СтруктураНастроекАРМ,
	Склад, тблАдреса, ТекстОшибки, РежимОптимизацииМаршрута = Ложь, СчДобавленныхОбъектов = 0) Экспорт
	
	// Получаем экпертные настройки
	НастройкиМаршрутизации = уатЗащищенныеФункцииСервер_уэ.ПрочитатьНастройкиВнешнийМаршрутизатор(СтруктураНастроекАРМ.НастройкиОптимизацииВнешнийМаршрутизатор);
	
	флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмОптимизации = "RarusVRP"; 

	// Заполняем параметры склада 
	флагСдвигДаты   = Ложь;
	Структура_depot = ЗаполнитьСтруктуруПараметровСклада(ДатаПланирования, Склад, СтруктураНастроекАРМ,
		НастройкиМаршрутизации, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, Истина, РежимОптимизацииМаршрута);
		
	ТаблицаГруппПунктов             = Новый ТаблицаЗначений(); 
	СоответвиеЗаказов               = Новый Соответствие();
	ИспользуемыеГруппыСовместимости = Новый Массив();
	СоответствиеГеозонПунктов       = Новый Соответствие;
	РазрешенныеТСПоЗаказам          = Новый Соответствие;
	
	// Таблица маршрута ТС для пересчета метрик
	Таблицаlocation = Новый ТаблицаЗначений();
	Таблицаlocation.Колонки.Добавить("ТС");
	Таблицаlocation.Колонки.Добавить("МЛ");
	Таблицаlocation.Колонки.Добавить("ДатаПосещения");
	Таблицаlocation.Колонки.Добавить("id");
	
	// Заполняем список пунктов назначения  
	СтруктураНастроекАРМ.НастройкаАдресВыезда = Склад;
	
	Массив_locations = ЗаполнитьСписокПунктовНазначение(ДатаПланирования, ТаблицаЗаказов, СтруктураНастроекАРМ, НастройкиМаршрутизации, Таблицаlocation,
		ТаблицаГруппПунктов, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, СоответствиеГеозонПунктов, СоответвиеЗаказов, РазрешенныеТСПоЗаказам,
		ИспользуемыеГруппыСовместимости, Истина);
		
	МассивГеозон = Новый Массив();
	// Заполняем параметры Сервиса планирования маршрутов
	Структура_options = ЗаполнитьСтруктуруПараметровСервисаПланированияМаршрутов(ДатаПланирования, СтруктураНастроекАРМ,
		НастройкиМаршрутизации, ТаблицаГруппПунктов, ИспользуемыеГруппыСовместимости, МассивГеозон, Истина, РежимОптимизацииМаршрута); 
		
	СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
	
	КоэффициентЗагрузкиКузоваПоВесу   = СтруктураНастроекАРМ.Оптимизация_НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу; 
	КоэффициентЗагрузкиКузоваПоОбъему = СтруктураНастроекАРМ.Оптимизация_НастройкаПонижающийКоэффициентЗагрузкиКузоваПоОбъему;
    ВремяВыездаИзГаража               = СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВыездаИзГаража;
	ВремяВыездаТранспортныхСредств    = СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВыездаТранспортныхСредств;
	ВремяВозвратаТранспортныхСредств  = СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВозвратаТранспортныхСредств;
	УчитыватьГаражПриВозвращении      = ДанныеПоЗаказам.УчитыватьГаражВозвращения;
	ГаражВозвращения                  = ДанныеПоЗаказам.ГаражВозвращения;
	
	Массив_vehicles   = Новый Массив();
	Структура_vehicle = Новый Структура();
	Если Не РежимОптимизацииМаршрута Тогда
		ЕстьХарКиВместимости   = Ложь;
		СтруктураВместимостьТС = Новый Структура();
		Если ЗначениеЗаполнено(ТСдляМаршрутизации.Грузоподъемность) Тогда
			СтруктураВместимостьТС.Вставить("weight_kg", ТСдляМаршрутизации.Грузоподъемность);
			ЕстьХарКиВместимости = Истина;
		КонецЕсли; 
		Если ЗначениеЗаполнено(КоэффициентЗагрузкиКузоваПоВесу) 
			ИЛИ ЗначениеЗаполнено(КоэффициентЗагрузкиКузоваПоОбъему) Тогда 
			СтруктураПределыЗагрузкиТС = Новый Структура();
			Если ЗначениеЗаполнено(КоэффициентЗагрузкиКузоваПоВесу) Тогда
				СтруктураПределыЗагрузкиТС.Вставить("weight_perc", КоэффициентЗагрузкиКузоваПоВесу);
			КонецЕсли;
			Если ЗначениеЗаполнено(КоэффициентЗагрузкиКузоваПоОбъему) Тогда
				СтруктураПределыЗагрузкиТС.Вставить("volume_perc", КоэффициентЗагрузкиКузоваПоОбъему);
			КонецЕсли;
			СтруктураВместимостьТС.Вставить("limits", СтруктураПределыЗагрузкиТС);
			ЕстьХарКиВместимости = Истина;
		КонецЕсли;
		ПолезныйРазмерГлубина  = ТСдляМаршрутизации.ОбъемКузова;
		Если ПолезныйРазмерГлубина > 0 Тогда
			Если флRarusVRP Тогда
				СтруктураМетрическиеРазмерыТС = Новый Структура("height_m, width_m, depth_m", 1, 1, ПолезныйРазмерГлубина);
				СтруктураВместимостьТС.Вставить("volume", СтруктураМетрическиеРазмерыТС);
			Иначе
				СтруктураВместимостьТС.Вставить("volume_cbm", ПолезныйРазмерГлубина); 
			КонецЕсли;
			ЕстьХарКиВместимости = Истина;
		КонецЕсли;
		Если ЕстьХарКиВместимости Тогда
			Структура_vehicle.Вставить("capacity", СтруктураВместимостьТС);
		КонецЕсли;

		Структура_vehicle.Вставить("tags",            Новый Массив());
		Если флRarusVRP Тогда
			Структура_vehicle.Вставить("priority", Ложь);
		Иначе
			Структура_vehicle.Вставить("priority", 100);
		КонецЕсли;
		
		Структура_shift = Новый Структура();
		Структура_shift.Вставить("service_duration_s", Структура_depot.service_duration_s);
		Структура_shift.Вставить("penalty",            Новый Структура("out_of_time", Новый Структура("fixed, minute", 1000, 17)));
		Структура_shift.Вставить("id",                 Строка(Новый УникальныйИдентификатор()));
		
		Если ВремяВыездаИзГаража = 1 Тогда 
			СменаС  = ВремяВыездаТранспортныхСредств;
			СменаПо = ?(ВремяВозвратаТранспортныхСредств = '00010101000000', '00010101235959', ВремяВозвратаТранспортныхСредств);
			
			Если СменаПо < СменаС Тогда 
				СменаПо = СменаПо + 86400;
			ИначеЕсли флагСдвигДаты Тогда
				СменаС  = СменаС  + 86400;
				СменаПо = СменаПо + 86400;
			КонецЕсли;
			
			Структура_shift.Вставить(
				"time_window", 
				"" + Строка(День(СменаС) - 1) + "." + Формат(СменаС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
				Строка(День(СменаПо) - 1) + "." + Формат(СменаПо, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
			Структура_shift.Вставить("hard_window", СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказам);
			
		Иначе 
			Структура_shift.Вставить("time_window", "0.00:00:00-1.23:59:59");
			Структура_shift.Вставить("hard_window", СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказам);
		КонецЕсли;
		
		Массив_shifts = Новый Массив();
		Массив_shifts.Добавить(Структура_shift);
		Структура_vehicle.Вставить("shifts", Массив_shifts);
		
		Структура_vehicle.Вставить("cost",                   Новый Структура("fixed, km, hour, location", 3000, 8, 100, 0));
		Структура_vehicle.Вставить("travel_time_multiplier", 1);
		Структура_vehicle.Вставить("excluded_tags",          Новый Массив());
	КонецЕсли;
	Если УчитыватьГаражПриВозвращении
		И ЗначениеЗаполнено(ГаражВозвращения) 
		И ГаражВозвращения <> Склад Тогда 
		ДобавитьЗаездВГараж(Истина, ГаражВозвращения, СтруктураНастроекАРМ, Массив_locations, Структура_vehicle, СчДобавленныхОбъектов, Истина);
		Структура_vehicle.Вставить("return_to_depot", ДанныеПоЗаказам.ЗаездНаСкладПриВозврате);
	Иначе
		Структура_vehicle.Вставить("return_to_depot", УчитыватьГаражПриВозвращении);
	КонецЕсли;
	
	Структура_vehicle.Вставить("ref",             ?(ЗначениеЗаполнено(ТСдляМаршрутизации.ТС), ТСдляМаршрутизации.ТС.Наименование,
		Строка(Новый УникальныйИдентификатор()))); 
		
	Если флRarusVRP Тогда
		Структура_vehicle.Вставить("id",          Строка(СчДобавленныхОбъектов));
	Иначе
		Структура_vehicle.Вставить("id",          СчДобавленныхОбъектов);
	КонецЕсли;
	Массив_vehicles.Добавить(Структура_vehicle);
	
	СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
	
	МассивДат = Новый Массив();
	МассивДат.Добавить(ДатаПланирования);
	
	// Несколько временных окон склада, если курьер выполняет многодневный маршрут
	уатВнешнийМаршрутизаторСервер_уэ.УстановитьНесколькоВременныхОкон(ДатаПланирования, 1, 
		флRarusVRP, МассивДат, Структура_depot, Массив_vehicles); 
		
	Если флRarusVRP Тогда
		СтруктураЗапроса = Новый Структура();
		СтруктураЗапроса.Вставить("vehicle",  Массив_vehicles[0]);
		СтруктураЗапроса.Вставить("depot",     Структура_depot);
		СтруктураЗапроса.Вставить("options",   Структура_options);
		СтруктураЗапроса.Вставить("locations", Массив_locations);
	Иначе
		СтруктураЗапроса = уатВнешнийМаршрутизаторСервер_уэ.УстановитьПресеты(НастройкиМаршрутизации, Структура_options, Структура_depot, Массив_vehicles, Массив_locations, Истина, ТекстОшибки, Склад);
	КонецЕсли;
	
	Возврат СтруктураЗапроса;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПолучитьРаспределениеЗаказов(АдресВрХранилища, ВхЗаказы, ВхЗаказыПоКоординатам, ВхМсвТС, ВхМсвВиртТС, АдресДепо,
		НастройкаКластеризации, РежимОптимизации, ОграничениеЧасов=0, ОграничениеПоРасстоянию=0,
		МаксимальноеКоличествоЗаказовТС=0, МаксимальноеЧислоПунктов=0, ВремяВыезда='00010101000000', СжиматьЗаказы=Ложь,
		ИндивидуальныйГаражТС=Ложь, ВозвратВГаражСобственныеТС=Ложь, ВозвратВГаражПривлеченныеТС=Ложь, ВозвратВГаражВиртуальныеТС=Ложь,
		ПараметрыСжатия=Неопределено, УчитыватьОкнаПоЗаказам=Ложь, УчитыватьРазрешенныеТипыТС=Ложь, РежимВремениВыездаИзГаража=0,
		ПараметрРазмераЗаказа=0, ПриоритетыМаршрутизации=Неопределено, ИспользоватьВПриоритетеСобственныйТранспорт=Ложь,
		УчитыватьНаправленияПеревозки=Ложь, ИспользоватьХарактеристикиЗаказовНаТС=Ложь)
	
	уатТипыТочекМаршрута_Погрузка = Перечисления.уатТипыТочекМаршрута.Погрузка;
	уатТипыТочекМаршрута_Разгрузка = Перечисления.уатТипыТочекМаршрута.Разгрузка;
	
	ПоместитьВоВременноеХранилище(Новый Структура("СообщениеПользователю", НСтр("ru = 'Выполняется маршрутизация заказов'; en = 'Executing of orders routing'")), АдресВрХранилища);
	
	Если ПараметрыСжатия = Неопределено Тогда 
		ПараметрыСжатия = Новый Структура();
	КонецЕсли;
	Если Не ПараметрыСжатия.Свойство("МаксВес") Тогда 
		ПараметрыСжатия.Вставить("МаксВес", 0);
	КонецЕсли;
	Если Не ПараметрыСжатия.Свойство("МаксОбъем") Тогда 
		ПараметрыСжатия.Вставить("МаксОбъем", 0);
	КонецЕсли;
	Если Не ПараметрыСжатия.Свойство("МаксУпак") Тогда 
		ПараметрыСжатия.Вставить("МаксУпак", 0);
	КонецЕсли;
	Если Не ПараметрыСжатия.Свойство("МаксВремя") Тогда 
		ПараметрыСжатия.Вставить("МаксВремя", 0);
	КонецЕсли;
	Если Не ПараметрыСжатия.Свойство("МаксРасстояние") Тогда 
		ПараметрыСжатия.Вставить("МаксРасстояние", 0);
	КонецЕсли;
	
	ЗапросСредняяСкорость = Новый Запрос();
	ЗапросСредняяСкорость.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатСредняяСкоростьДвижения.НачалоПериода,
	|	уатСредняяСкоростьДвижения.КонецПериода,
	|	уатСредняяСкоростьДвижения.Скорость
	|ИЗ
	|	РегистрСведений.уатСредняяСкоростьДвижения КАК уатСредняяСкоростьДвижения";
	
	ТабСкоростей = ЗапросСредняяСкорость.Выполнить().Выгрузить();
	
	// Группировка входящих заказов по направлениям перевозки.
	ЗаказыПоНаправлениямПеревозки = ПолучитьЗаказыПоНаправлениямПеревозки(ВхЗаказы, ВхЗаказыПоКоординатам, 
		УчитыватьНаправленияПеревозки);
	
	КоличествоНаправленийПеревозки = ЗаказыПоНаправлениямПеревозки.Количество();
	
	// Перменная "КонечныеПулы" хранит результат распределения заказов по ТС.
	КонечныеПулы = Новый Массив();
	
	Для Каждого ТекНаправление Из ЗаказыПоНаправлениямПеревозки Цикл 
		Заказы = Новый Массив();
		Для Каждого ТекСтрока Из ТекНаправление.Заказы Цикл 
			Заказы.Добавить(ТекСтрока);
		КонецЦикла;
		
		ЗаказыПоКоординатам = Новый Массив();
		Для Каждого ТекСтрока Из ТекНаправление.ЗаказыПоКоординатам Цикл 
			ЗаказыПоКоординатам.Добавить(ТекСтрока);
		КонецЦикла;
		
		мсвТС = Новый Массив();
		Для Каждого ТекСтрока Из ВхМсвТС Цикл 
			мсвТС.Добавить(ТекСтрока);
		КонецЦикла;
		
		мсвВиртТС = Новый Массив();
		Для Каждого ТекСтрока Из ВхМсвВиртТС Цикл 
			мсвВиртТС.Добавить(ТекСтрока);
		КонецЦикла;
		
		МенеджерВТ = Новый МенеджерВременныхТаблиц();
		
		Запрос = Новый Запрос();
		Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
		
		соотПараметрыВиртТС = Новый Соответствие();
		табТСВходная = ПолучитьТаблицуВходныхТС(мсвТС, мсвВиртТС, соотПараметрыВиртТС);
		
		Запрос.УстановитьПараметр("табТСВходная",                                табТСВходная);
		Запрос.УстановитьПараметр("ИспользоватьВПриоритетеСобственныйТранспорт", ИспользоватьВПриоритетеСобственныйТранспорт);
		Запрос.УстановитьПараметр("ВозвратВГаражСобственныеТС",                  ВозвратВГаражСобственныеТС);
		Запрос.УстановитьПараметр("ВозвратВГаражПривлеченныеТС",                 ВозвратВГаражПривлеченныеТС);
		Запрос.УстановитьПараметр("ВозвратВГаражВиртуальныеТС",                  ВозвратВГаражВиртуальныеТС);
		
		Если Константы.уатЕдиницаИзмеренияВеса.Получить() = Перечисления.уатЕдиницыИзмеренияВеса.Килограмм Тогда 
			Запрос.УстановитьПараметр("КоэфГрузоподъемности", 1000);
		Иначе 
			Запрос.УстановитьПараметр("КоэфГрузоподъемности", 1);
		КонецЕсли;
		
		Если Константы.уатЕдиницаИзмеренияОбъема.Получить() = Перечисления.уатЕдиницыИзмеренияОбъема.Литр Тогда 
			Запрос.УстановитьПараметр("КоэфОбъемаКузова", 1000);
		Иначе 
			Запрос.УстановитьПараметр("КоэфОбъемаКузова", 1);
		КонецЕсли;
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	табТСВходная.ТС КАК ТС,
		|	табТСВходная.Прицеп1 КАК Прицеп1,
		|	табТСВходная.Прицеп2 КАК Прицеп2
		|ПОМЕСТИТЬ ВТ_ТСВходПараметр
		|ИЗ
		|	&табТСВходная КАК табТСВходная
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫРАЗИТЬ(ВТ_ТСВходПараметр.ТС КАК Справочник.уатТС) КАК ТС,
		|	ВЫРАЗИТЬ(ВТ_ТСВходПараметр.Прицеп1 КАК Справочник.уатТС) КАК Прицеп1,
		|	ВЫРАЗИТЬ(ВТ_ТСВходПараметр.Прицеп2 КАК Справочник.уатТС) КАК Прицеп2
		|ПОМЕСТИТЬ ВТ_ТСтипизированная
		|ИЗ
		|	ВТ_ТСВходПараметр КАК ВТ_ТСВходПараметр
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВТ_ТСтипизированная.ТС КАК Ссылка,
		|	ВТ_ТСтипизированная.ТС.Модель.Грузоподъемность * &КоэфГрузоподъемности + ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп1.Модель.Грузоподъемность, 0) * &КоэфГрузоподъемности + ВЫБОР
		|		КОГДА ВТ_ТСтипизированная.Прицеп1 = ВТ_ТСтипизированная.Прицеп2
		|			ТОГДА 0
		|		ИНАЧЕ ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп2.Модель.Грузоподъемность, 0) * &КоэфГрузоподъемности
		|	КОНЕЦ КАК Грузоподъемность,
		|	ВТ_ТСтипизированная.ТС.Модель.ОбъемКузова * &КоэфОбъемаКузова + ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп1.Модель.ОбъемКузова, 0) * &КоэфОбъемаКузова + ВЫБОР
		|		КОГДА ВТ_ТСтипизированная.Прицеп1 = ВТ_ТСтипизированная.Прицеп2
		|			ТОГДА 0
		|		ИНАЧЕ ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп2.Модель.ОбъемКузова, 0) * &КоэфОбъемаКузова
		|	КОНЕЦ КАК ОбъемКузова,
		|	ВТ_ТСтипизированная.ТС.Гараж КАК Гараж,
		|	ВТ_ТСтипизированная.ТС.Модель.МаксимальноеКоличествоУпаковок + ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп1.Модель.МаксимальноеКоличествоУпаковок, 0) + ВЫБОР
		|		КОГДА ВТ_ТСтипизированная.Прицеп1 = ВТ_ТСтипизированная.Прицеп2
		|			ТОГДА 0
		|		ИНАЧЕ ЕСТЬNULL(ВТ_ТСтипизированная.Прицеп2.Модель.МаксимальноеКоличествоУпаковок, 0)
		|	КОНЕЦ КАК МаксимальноеКоличествоУпаковок,
		|	ВЫБОР
		|		КОГДА &ИспользоватьВПриоритетеСобственныйТранспорт
		|				И ВТ_ТСтипизированная.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Собственное)
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Приоритет,
		|	ВЫБОР
		|		КОГДА ВТ_ТСтипизированная.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Собственное)
		|				И &ВозвратВГаражСобственныеТС
		|			ТОГДА ИСТИНА
		|		КОГДА ВТ_ТСтипизированная.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Привлеченное)
		|				И &ВозвратВГаражПривлеченныеТС
		|			ТОГДА ИСТИНА
		|		КОГДА ВТ_ТСтипизированная.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Виртуальное)
		|				И &ВозвратВГаражВиртуальныеТС
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ВозвратВГараж
		|ПОМЕСТИТЬ ВТ_ТС_Подготовка
		|ИЗ
		|	ВТ_ТСтипизированная КАК ВТ_ТСтипизированная";
		
		Запрос.Выполнить();
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МАКСИМУМ(ТранспортныеСредства.Грузоподъемность) КАК МаксГрузоподъемность,
		|	МАКСИМУМ(ТранспортныеСредства.ОбъемКузова) КАК МаксОбъемКузова
		|ИЗ
		|	ВТ_ТС_Подготовка КАК ТранспортныеСредства";
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда 
			МаксГрузоподъемность = Выборка.МаксГрузоподъемность;
			МаксОбъемКузова      = Выборка.МаксОбъемКузова;
		Иначе 
			МаксГрузоподъемность = 0;
			МаксОбъемКузова      = 0;
		КонецЕсли;
		
		пулы = Новый Массив();
		
		флИспользованиеКластеризации = уатЗащищенныеФункцииСервер_уэ.ПолучитьИспользованиеКластеризации();
		
		ДанныеИсходныхЗаказов = СформироватьТаблицуИсходныхЗаказов(
			Заказы, 
			ЗаказыПоКоординатам, 
			флИспользованиеКластеризации, 
			НастройкаКластеризации, 
			СжиматьЗаказы,
			АдресДепо,
			ИспользоватьХарактеристикиЗаказовНаТС
		);
		
		ДанныеПоТСИПереходам = СформироватьДанныеПоТСИПереходам(
			Запрос, 
			АдресДепо, 
			НастройкаКластеризации, 
			УчитыватьРазрешенныеТипыТС,
			МаксГрузоподъемность,
			МаксОбъемКузова, 
			ИндивидуальныйГаражТС, 
			флИспользованиеКластеризации,
			соотПараметрыВиртТС,
			ДанныеИсходныхЗаказов.МассивПунктов,
			ДанныеИсходныхЗаказов.МассивАдресов,
			ДанныеИсходныхЗаказов.НаборХарактеристик,
			ИспользоватьХарактеристикиЗаказовНаТС
		);
		
		ТаблицаИсходЗаказов                = ДанныеИсходныхЗаказов.ТаблицаЗаказов;
		СоотвТаблРасстояний                = ДанныеПоТСИПереходам.СоотвТаблРасстояний;
		СоотТипыТС                         = ДанныеПоТСИПереходам.СоотТипыТС;
		СоотРазрешенныеТипыПунктов         = ДанныеПоТСИПереходам.СоотРазрешенныеТипыПунктов;
		ТабТС                              = ДанныеПоТСИПереходам.ТабТС;
		СоотРазрешенныеТСПоХарактеристикам = ДанныеПоТСИПереходам.СоотРазрешенныеТСПоХарактеристикам;
		
		СоотРазрешенныеТСПоЗаказам = Новый Соответствие();
		
		ВекторОбход = Новый ТаблицаЗначений();
		ВекторОбход.Колонки.Добавить("Значение",        Новый ОписаниеТипов("ДокументСсылка.уатЗаказГрузоотправителя, УникальныйИдентификатор"));
		ВекторОбход.Колонки.Добавить("ОценкаПогрузка",  Новый ОписаниеТипов("Число"));
		ВекторОбход.Колонки.Добавить("ОценкаРазгрузка", Новый ОписаниеТипов("Число"));
		ВекторОбход.Колонки.Добавить("Приоритет",       Новый ОписаниеТипов("Число"));
		
		СоотвГруппЗаказов = Новый Соответствие();
		
		ТабЗаказы = Новый ТаблицаЗначений();
		ТабЗаказы.Колонки.Добавить("Ссылка",                     Новый ОписаниеТипов("УникальныйИдентификатор"));
		ТабЗаказы.Колонки.Добавить("ВесБрутто",                  Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("Объем",                      Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ПунктПогрузки",              Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения, СправочникСсылка.уатКластеры_уэ"));
		ТабЗаказы.Колонки.Добавить("ПунктРазгрузки",             Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения, СправочникСсылка.уатКластеры_уэ"));
		ТабЗаказы.Колонки.Добавить("СтоянкаПунктОтправления",    Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("СтоянкаПунктНазначения",     Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ДопСтоянкаПунктОтправления", Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ДопСтоянкаПунктНазначения",  Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("Приоритет",                  Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("АдресОтправления",           Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения"));
		ТабЗаказы.Колонки.Добавить("АдресНазначения",            Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения"));
		ТабЗаказы.Колонки.Добавить("FTL",                        Новый ОписаниеТипов("Булево"));
		ТабЗаказы.Колонки.Добавить("КоличествоУпаковок",         Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ОтправлениеС",               Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
		ТабЗаказы.Колонки.Добавить("ОтправлениеПо",              Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
		ТабЗаказы.Колонки.Добавить("ДоставкаС",                  Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
		ТабЗаказы.Колонки.Добавить("ДоставкаПо",                 Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
		ТабЗаказы.Колонки.Добавить("ЛатОтпр",                    Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ЛонОтпр",                    Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ЛатНазн",                    Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("ЛонНазн",                    Новый ОписаниеТипов("Число"));
		ТабЗаказы.Колонки.Добавить("НаборХарактеристик",         Новый ОписаниеТипов("УникальныйИдентификатор"));
		
		Если СжиматьЗаказы Тогда 
			Если ПараметрыСжатия.МаксВремя = 0 Тогда 
				ПараметрыСжатия.МаксВремя = Цел(ОграничениеЧасов / 3);
			КонецЕсли;
			Если ПараметрыСжатия.МаксРасстояние = 0 Тогда 
				ПараметрыСжатия.МаксРасстояние = Цел(ОграничениеПоРасстоянию / 3);
			КонецЕсли;
			
			Если ПараметрыСжатия.МаксВес = 0 Или ПараметрыСжатия.МаксОбъем = 0 Или ПараметрыСжатия.МаксУпак = 0 Тогда 
				ВсегоТС            = 0;
				ГрузоподъемностьТС = 0;
				ОбъемКузоваТС      = 0;
				МаксУпаковокТС     = 0;
				Для Каждого ВыборкаТС Из ТабТС Цикл 
					КолТС = соотПараметрыВиртТС.Получить(ВыборкаТС.Ссылка);
					Если КолТС = Неопределено Тогда 
						КолТС = 1;
					КонецЕсли;
					
					Для СчТС = 1 По КолТС Цикл 
						ВсегоТС            = ВсегоТС + 1;
						ГрузоподъемностьТС = ГрузоподъемностьТС + ВыборкаТС.Грузоподъемность;
						ОбъемКузоваТС      = ОбъемКузоваТС + ВыборкаТС.ОбъемКузова;
						МаксУпаковокТС     = МаксУпаковокТС + ВыборкаТС.МаксимальноеКоличествоУпаковок;
					КонецЦикла;
				КонецЦикла;
				
				Если ПараметрыСжатия.МаксВес = 0 Тогда 
					ПараметрыСжатия.МаксВес = ?(ВсегоТС=0, 0, (ГрузоподъемностьТС/ВсегоТС)/3);
				КонецЕсли;
				
				Если ПараметрыСжатия.МаксОбъем = 0 Тогда 
					ПараметрыСжатия.МаксОбъем = ?(ВсегоТС=0, 0, (ОбъемКузоваТС/ВсегоТС)/3);
				КонецЕсли;
				
				Если ПараметрыСжатия.МаксУпак = 0 Тогда 
					ПараметрыСжатия.МаксУпак  = ?(ВсегоТС=0, 0, (МаксУпаковокТС/ВсегоТС)/3);
				КонецЕсли;
			КонецЕсли;
			
			Для Каждого СтрокаЛатОтпр Из ТаблицаИсходЗаказов.Строки Цикл 
				Для Каждого СтрокаЛонОтпр Из СтрокаЛатОтпр.Строки Цикл 
					Для Каждого СтрокаЛатНазн Из СтрокаЛонОтпр.Строки Цикл 
						Для Каждого СтрокаЛонНазн Из СтрокаЛатНазн.Строки Цикл 
							Если СтрокаЛонНазн.ПунктПогрузки = СтрокаЛонНазн.ПунктРазгрузки Тогда 
								мВремяВПути = 0;
								врОбщРасстояние = 0;
								
							Иначе 
								Узел1 = СоотвТаблРасстояний.Получить(СтрокаЛонНазн.ПунктПогрузки);
								Если Узел1 = Неопределено Тогда 
									Продолжить;
								КонецЕсли;
								Узел2 = Узел1.Получить(СтрокаЛонНазн.ПунктРазгрузки);
								Если Узел2 = Неопределено Тогда 
									Продолжить;
								КонецЕсли;
								мВремяВПути     = Узел2.Время;
								врОбщРасстояние = Узел2.Расстояние;
							КонецЕсли;
							
							Для Каждого НаборГруппировка Из СтрокаЛонНазн.Строки Цикл 
								ВсегоВес   = 0;
								ВсегоОбъем = 0;
								СтоянкаПО  = 0;
								СтоянкаПН  = 0;
								мПриоритет = 0;
								мУпаковок  = 0;
								
								ТекОтправлениеС  = '00010101000000';
								ТекОтправлениеПо = '00010101235959';
								ТекДоставкаС     = '00010101000000';
								ТекДоставкаПо    = '00010101235959';
								
								ДлительностьОкнаОтправления = 0;
								ДлительностьОкнаНазначения  = 0;
								
								мсвВложенныеЗаказы = Новый Массив();
								
								Для Каждого ВыборкаЗаказы Из НаборГруппировка.Строки Цикл
									
									Если УчитыватьОкнаПоЗаказам Тогда 
										Если мсвВложенныеЗаказы.Количество() = 0 Тогда 
											ТекОтправлениеС  = ВыборкаЗаказы.ОтправлениеС;
											ТекОтправлениеПо = ВыборкаЗаказы.ОтправлениеПо;
											
											ТекДоставкаС  = ВыборкаЗаказы.ДоставкаС;
											ТекДоставкаПо = ВыборкаЗаказы.ДоставкаПо;
											
											Если ТекОтправлениеС > ТекОтправлениеПо Тогда 
												ДлительностьОкнаОтправления = (ТекОтправлениеС - ТекОтправлениеПо) / 3600;
											Иначе 
												ДлительностьОкнаОтправления = (ТекОтправлениеПо - ТекОтправлениеС) / 3600;
											КонецЕсли;
											
											Если ТекДоставкаС > ТекДоставкаПо Тогда 
												ДлительностьОкнаНазначения = (ТекДоставкаС - ТекДоставкаПо) / 3600;
											Иначе 
												ДлительностьОкнаНазначения = (ТекДоставкаПо - ТекДоставкаС) / 3600;
											КонецЕсли;
											
										Иначе 
											// Проверка на пересечение окна по заказу и текущего окна группы.
											Если Не (уатОбщегоНазначения_проф.ВремяПосещенияВПределахОкна(ВыборкаЗаказы.ОтправлениеС, ТекОтправлениеС, ТекОтправлениеПо)
													Или уатОбщегоНазначения_проф.ВремяПосещенияВПределахОкна(ВыборкаЗаказы.ОтправлениеПо, ТекОтправлениеС, ТекОтправлениеПо)) Тогда 
												ДлительностьОкнаОтправления = -1;
												
											Иначе 
												Если Не (ТекОтправлениеС <= ТекОтправлениеПо И ВыборкаЗаказы.ОтправлениеС > ВыборкаЗаказы.ОтправлениеПо) Тогда 
													ТекОтправлениеС = Макс(ТекОтправлениеС, ВыборкаЗаказы.ОтправлениеС);
												КонецЕсли;
												ТекОтправлениеПо = Мин(ТекОтправлениеПо, ВыборкаЗаказы.ОтправлениеПо);
												
												Если ТекОтправлениеС > ТекОтправлениеПо Тогда 
													ДлительностьОкнаОтправления = (ТекОтправлениеС - ТекОтправлениеПо) / 3600;
												Иначе 
													ДлительностьОкнаОтправления = (ТекОтправлениеПо - ТекОтправлениеС) / 3600;
												КонецЕсли;
											КонецЕсли;
											
											// Проверка на пересечение окна по заказу и текущего окна группы.
											Если Не (уатОбщегоНазначения_проф.ВремяПосещенияВПределахОкна(ВыборкаЗаказы.ДоставкаС, ТекДоставкаС, ТекДоставкаПо)
													Или уатОбщегоНазначения_проф.ВремяПосещенияВПределахОкна(ВыборкаЗаказы.ДоставкаПо, ТекДоставкаС, ТекДоставкаПо)) Тогда 
												ДлительностьОкнаНазначения = -1;
												
											Иначе 
												Если Не (ТекДоставкаС <= ТекДоставкаПо И ВыборкаЗаказы.ДоставкаС > ВыборкаЗаказы.ДоставкаПо) Тогда 
													ТекДоставкаС = Макс(ТекДоставкаС, ВыборкаЗаказы.ДоставкаС);
												КонецЕсли;
												ТекДоставкаПо = Мин(ТекДоставкаПо, ВыборкаЗаказы.ДоставкаПо);
												
												Если ТекДоставкаС > ТекДоставкаПо Тогда 
													ДлительностьОкнаНазначения = (ТекДоставкаС - ТекДоставкаПо) / 3600;
												Иначе 
													ДлительностьОкнаНазначения = (ТекДоставкаПо - ТекДоставкаС) / 3600;
												КонецЕсли;
											КонецЕсли;
										КонецЕсли;
									КонецЕсли;
									
									ОбщВремя = мВремяВПути
										+ ВыборкаЗаказы.ДопСтоянкаПунктОтправления
										+ ВыборкаЗаказы.СтоянкаПунктОтправления
										+ ВыборкаЗаказы.ДопСтоянкаПунктНазначения
										+ ВыборкаЗаказы.СтоянкаПунктНазначения;
										
									Если Не ВыборкаЗаказы.FTL 
											И (МаксимальноеКоличествоЗаказовТС = 0 Или мсвВложенныеЗаказы.Количество() <= МаксимальноеКоличествоЗаказовТС)
											И (ПараметрыСжатия.МаксВремя = 0 Или ОбщВремя <= ПараметрыСжатия.МаксВремя * 3600)
											И (ПараметрыСжатия.МаксРасстояние = 0 Или врОбщРасстояние <= ПараметрыСжатия.МаксРасстояние)
											И (ПараметрыСжатия.МаксВес = 0 Или ВсегоВес <= ПараметрыСжатия.МаксВес)
											И (ПараметрыСжатия.МаксОбъем = 0 Или ВсегоОбъем <= ПараметрыСжатия.МаксОбъем)
											И (ПараметрыСжатия.МаксУпак = 0 Или мУпаковок <= ПараметрыСжатия.МаксУпак)
											И ДлительностьОкнаОтправления >= 0 И ДлительностьОкнаНазначения >=0 Тогда 
										мсвВложенныеЗаказы.Добавить(Новый Структура("Заказ, Пакет", ВыборкаЗаказы.Ссылка, ВыборкаЗаказы.СтрокаПакета));
										ВсегоВес   = ВсегоВес + ВыборкаЗаказы.ВесБрутто;
										ВсегоОбъем = ВсегоОбъем + ВыборкаЗаказы.Объем;
										мПриоритет = ?(мПриоритет<ВыборкаЗаказы.Приоритет, ВыборкаЗаказы.Приоритет, мПриоритет);
										мУпаковок  = мУпаковок + ВыборкаЗаказы.КоличествоУпаковок;
										
										СтоянкаПО = СтоянкаПО + ВыборкаЗаказы.СтоянкаПунктОтправления;
										СтоянкаПН = СтоянкаПН + ВыборкаЗаказы.СтоянкаПунктНазначения;
										
									ИначеЕсли ВыборкаЗаказы.FTL Тогда 
										Если мсвВложенныеЗаказы.Количество() Тогда 
											GUIDГруппы = Новый УникальныйИдентификатор();
											НовСтр = ТабЗаказы.Добавить();
											НовСтр.Ссылка                     = GUIDГруппы;
											НовСтр.ВесБрутто                  = ВсегоВес;
											НовСтр.Объем                      = ВсегоОбъем;
											НовСтр.ПунктПогрузки              = СтрокаЛонНазн.ПунктПогрузки;
											НовСтр.ПунктРазгрузки             = СтрокаЛонНазн.ПунктРазгрузки;
											НовСтр.СтоянкаПунктОтправления    = СтоянкаПО;
											НовСтр.СтоянкаПунктНазначения     = СтоянкаПН;
											НовСтр.ДопСтоянкаПунктОтправления = ВыборкаЗаказы.ДопСтоянкаПунктОтправления;
											НовСтр.ДопСтоянкаПунктНазначения  = ВыборкаЗаказы.ДопСтоянкаПунктНазначения;
											НовСтр.Приоритет                  = мПриоритет;
											НовСтр.АдресОтправления           = ВыборкаЗаказы.АдресОтправления;
											НовСтр.АдресНазначения            = ВыборкаЗаказы.АдресНазначения;
											НовСтр.FTL                        = Ложь;
											НовСтр.КоличествоУпаковок         = мУпаковок;
											НовСтр.ОтправлениеС               = ТекОтправлениеС;
											НовСтр.ОтправлениеПо              = ТекОтправлениеПо;
											НовСтр.ДоставкаС                  = ТекДоставкаС;
											НовСтр.ДоставкаПо                 = ТекДоставкаПо;
											НовСтр.ЛатОтпр                    = ВыборкаЗаказы.ЛатОтпр;
											НовСтр.ЛонОтпр                    = ВыборкаЗаказы.ЛонОтпр;
											НовСтр.ЛатНазн                    = ВыборкаЗаказы.ЛатНазн;
											НовСтр.ЛонНазн                    = ВыборкаЗаказы.ЛонНазн;
											НовСтр.НаборХарактеристик         = НаборГруппировка.НаборХарактеристик;
											
											СоотвГруппЗаказов.Вставить(GUIDГруппы, мсвВложенныеЗаказы);
											
											Если УчитыватьРазрешенныеТипыТС Тогда 
												УстановитьРазрешенныеТСЗаказов(СоотРазрешенныеТСПоЗаказам, СоотТипыТС, СоотРазрешенныеТипыПунктов,
													GUIDГруппы, ВыборкаЗаказы.АдресОтправления, ВыборкаЗаказы.АдресНазначения);
											КонецЕсли;
											
											мЦенаПогрузка = Неопределено;
											Для Каждого ТекТС Из ТабТС Цикл 
												Если ТекТС.Гараж = СтрокаЛонНазн.ПунктПогрузки Тогда 
													Если РежимОптимизации = 0 Тогда 
														мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, 0, Мин(мЦенаПогрузка, 0));
													Иначе 
														мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, 0, Мин(мЦенаПогрузка, 0));
													КонецЕсли;
													
												Иначе 
													Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
													Если Узел1 = Неопределено Тогда 
														Прервать;
													КонецЕсли;
													Узел2 = Узел1.Получить(СтрокаЛонНазн.ПунктПогрузки);
													Если Узел2 = Неопределено Тогда 
														Прервать;
													КонецЕсли;
													Если РежимОптимизации = 0 Тогда 
														мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, Узел2.Время, Мин(мЦенаПогрузка, Узел2.Время));
													Иначе 
														мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, Узел2.Расстояние, Мин(мЦенаПогрузка, Узел2.Расстояние));
													КонецЕсли;
												КонецЕсли;
											КонецЦикла;
											
											Если мЦенаПогрузка = Неопределено Тогда 
												Продолжить;
											КонецЕсли;
											
											мЦенаРазгрузка = Неопределено;
											Для Каждого ТекТС Из ТабТС Цикл 
												Если ТекТС.Гараж = СтрокаЛонНазн.ПунктРазгрузки Тогда 
													Если РежимОптимизации = 0 Тогда 
														мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, 0, Мин(мЦенаРазгрузка, 0));
													Иначе 
														мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, 0, Мин(мЦенаРазгрузка, 0));
													КонецЕсли;
													
												Иначе 
													Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
													Если Узел1 = Неопределено Тогда 
														Прервать;
													КонецЕсли;
													Узел2 = Узел1.Получить(СтрокаЛонНазн.ПунктРазгрузки);
													Если Узел2 = Неопределено Тогда 
														Прервать;
													КонецЕсли;
													Если РежимОптимизации = 0 Тогда 
