							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			
		Иначе 
			Для Каждого ВыборкаЗаказы Из ТаблицаИсходЗаказов Цикл 
				мЦенаПогрузка = Неопределено;
				Для Каждого ТекТС Из ТабТС Цикл 
					Если ТекТС.Гараж = ВыборкаЗаказы.ПунктПогрузки Тогда 
						Если РежимОптимизации = 0 Тогда 
							мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, 0, Мин(мЦенаПогрузка, 0));
						Иначе 
							мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, 0, Мин(мЦенаПогрузка, 0));
						КонецЕсли;
						
					Иначе 
						Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
						Если Узел1 = Неопределено Тогда 
							Прервать;
						КонецЕсли;
						Узел2 = Узел1.Получить(ВыборкаЗаказы.ПунктПогрузки);
						Если Узел2 = Неопределено Тогда 
							Прервать;
						КонецЕсли;
						Если РежимОптимизации = 0 Тогда 
							мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, Узел2.Время, Мин(мЦенаПогрузка, Узел2.Время));
						Иначе 
							мЦенаПогрузка = ?(мЦенаПогрузка=Неопределено, Узел2.Расстояние, Мин(мЦенаПогрузка, Узел2.Расстояние));
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
				Если мЦенаПогрузка = Неопределено Тогда 
					Продолжить;
				КонецЕсли;
				
				мЦенаРазгрузка = Неопределено;
				Для Каждого ТекТС Из ТабТС Цикл 
					Если ТекТС.Гараж = ВыборкаЗаказы.ПунктРазгрузки Тогда 
						Если РежимОптимизации = 0 Тогда 
							мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, 0, Мин(мЦенаРазгрузка, 0));
