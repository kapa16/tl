											КонецЕсли;
											Если РежимОптимизации = 0 Тогда 
												мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, Узел2.Время, Мин(мЦенаРазгрузка, Узел2.Время));
											Иначе 
