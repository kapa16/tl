				КонецЕсли;
				
				мсвЗаказы = Новый Массив();
				мсвЗаказы.Добавить(Новый Структура("Заказ, Пакет", ВыборкаЗаказы.Ссылка, ВыборкаЗаказы.СтрокаПакета));
				
				GUIDПакета = Новый УникальныйИдентификатор();
				СоотвГруппЗаказов.Вставить(GUIDПакета, мсвЗаказы);
				
				НовСтр = ТабЗаказы.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаЗаказы,, "Ссылка");
				НовСтр.Ссылка = GUIDПакета;
				
				Если УчитыватьРазрешенныеТипыТС Тогда 
					УстановитьРазрешенныеТСЗаказов(СоотРазрешенныеТСПоЗаказам, СоотТипыТС, СоотРазрешенныеТипыПунктов,
						GUIDПакета, ВыборкаЗаказы.АдресОтправления, ВыборкаЗаказы.АдресНазначения);
				КонецЕсли;
				
				НовСтрокаОбход = ВекторОбход.Добавить();
				НовСтрокаОбход.Значение        = GUIDПакета;
				НовСтрокаОбход.ОценкаПогрузка  = мЦенаПогрузка;
				НовСтрокаОбход.ОценкаРазгрузка = мЦенаРазгрузка;
				НовСтрокаОбход.Приоритет       = ВыборкаЗаказы.Приоритет;
			КонецЦикла;
		КонецЕсли;
		
		ТабЗаказы.Индексы.Добавить("Ссылка");
		
		ВекторОбход.Сортировать("ОценкаПогрузка Возр, ОценкаРазгрузка Возр, Приоритет Убыв");
		
		ВсегоИтерацийСтатус = ВекторОбход.Количество() * КоличествоНаправленийПеревозки;
		ТекИтерацияСтатус = 0;
		
		Для Каждого ТекЭлемент Из ВекторОбход Цикл 
			ТекИтерацияСтатус = ТекИтерацияСтатус + КоличествоНаправленийПеревозки;
			ПоместитьВоВременноеХранилище(Новый Структура("СообщениеПользователю,Прогресс", НСтр("ru = 'Выполняется маршрутизация заказов'; en = 'Executing of orders routing'"), Цел(ТекИтерацияСтатус*100 / ВсегоИтерацийСтатус)), АдресВрХранилища);
			ДлительныеОперации.СообщитьПрогресс(Цел(ТекИтерацияСтатус*100 / ВсегоИтерацийСтатус), НСтр("en='Executing of orders routing';ru='Выполняется маршрутизация заказов'"));
			ТабОценок = Новый ТаблицаЗначений();
			ТабОценок.Колонки.Добавить("Значение",  Новый ОписаниеТипов("Структура"));
			ТабОценок.Колонки.Добавить("Оценка",    Новый ОписаниеТипов("Число"));
			ТабОценок.Колонки.Добавить("Приоритет", Новый ОписаниеТипов("Число"));
			
			ДанныеЗаказа = ТабЗаказы.Найти(ТекЭлемент.Значение, "Ссылка");
			
			Для Каждого ТекПул Из пулы Цикл 
				мсвРазрешенныеТС = Неопределено;
				Если УчитыватьРазрешенныеТипыТС Тогда 
					мсвРазрешенныеТС = СоотРазрешенныеТСПоЗаказам.Получить(ДанныеЗаказа.Ссылка);
				КонецЕсли;
				
				Если Не мсвРазрешенныеТС = Неопределено И мсвРазрешенныеТС.Найти(ТекПул.ТС) = Неопределено Тогда 
					Продолжить;
				КонецЕсли;
				
				мсвРазрешенныеТСПоХарактеристикам = Неопределено;
				Если ИспользоватьХарактеристикиЗаказовНаТС Тогда 
					мсвРазрешенныеТСПоХарактеристикам = СоотРазрешенныеТСПоХарактеристикам.Получить(ДанныеЗаказа.НаборХарактеристик);
				КонецЕсли;
				
				Если Не мсвРазрешенныеТСПоХарактеристикам = Неопределено И мсвРазрешенныеТСПоХарактеристикам.Найти(ТекПул.ТС) = Неопределено Тогда 
					Продолжить;
				КонецЕсли;
				
				Если МаксимальноеКоличествоЗаказовТС <> 0 И ((ТекПул.маршрут.Количество() / 2) + 1) > МаксимальноеКоличествоЗаказовТС Тогда 
					Продолжить;
				КонецЕсли;
				
				ИндВставкиПогрузки = Неопределено;
				
				ПредПул = Новый Массив();
				Для СчПоиска = 0 По ТекПул.маршрут.Количество()-1 Цикл 
