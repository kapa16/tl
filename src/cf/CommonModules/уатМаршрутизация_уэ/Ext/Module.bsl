	КонецЕсли;	
	Если ЗначениеЗаполнено(Водитель) Тогда
		 ИнформацияОВодителе = " (" + Водитель + ")";
	КонецЕсли;
	
	Если ТекТС.Свойство("ref") Тогда
		Структура_vehicle.Вставить("ref", ТекТС.ref + ИнформацияОВодителе);
		Структура_vehicle.Вставить("id",  ТекТС.GUID);
	КонецЕсли;
	
	Возврат Структура_vehicle;
	
КонецФункции

Функция ЗаполнитьСтруктуруПараметровСклада(ДатаПланирования, Склад, СтруктураНастроекАРМ, НастройкиМаршрутизации, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, РежимОптимизации = Ложь, РежимОптимизацииМаршрута = Ложь)
	
	Если РежимОптимизации Тогда
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмОптимизации = "RarusVRP";
	Иначе
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4;
	КонецЕсли;
	
	НастройкаАдресВыезда = Склад;
	
	Структура_depot = Новый Структура();

	Если РежимОптимизацииМаршрута Тогда 
		ТекОкноС  = '00010101000000';
		ТекОкноПо = '00010101235959';
	Иначе
		Если РежимОптимизации Тогда
			ТекОкноС  = СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВыездаТранспортныхСредств;
			ТекОкноПо = ?(СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВозвратаТранспортныхСредств = '00010101000000', '00010101235959', СтруктураНастроекАРМ.Оптимизация_НастройкаВремяВозвратаТранспортныхСредств);
		Иначе
			ТекОкноС  = СтруктураНастроекАРМ.НастройкаВремяВыездаТранспортныхСредств;
			ТекОкноПо = ?(СтруктураНастроекАРМ.НастройкаВремяВозвратаТранспортныхСредств = '00010101000000', '00010101235959', СтруктураНастроекАРМ.НастройкаВремяВозвратаТранспортныхСредств); 
		КонецЕсли;
	КонецЕсли;

	Если ТипЗнч(ТекОкноС) = Тип("Строка") Тогда
		Попытка
			ТекОкноС         = Дата(ТекОкноС);
			ТекОкноПо        = Дата(ТекОкноПо);
			ДатаПланирования = Дата(ДатаПланирования);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ТекОкноПо < ТекОкноС Тогда 
		ТекОкноПо     = ТекОкноПо + 86400;
		флагСдвигДаты = Истина;
	КонецЕсли;
	
	Если флагСдвигДаты Тогда
		СтруктураНастроекАРМ.Вставить("ТекОкноС", ТекОкноС);
		ДатаПланирования = НачалоДня(ДатаПланирования - 1);
	КонецЕсли;
	
	Если флRarusVRP Тогда
		Если НЕ ЗначениеЗаполнено(ТекОкноС)
			И (НЕ ЗначениеЗаполнено(ТекОкноПо)
			ИЛИ (Час(ТекОкноПо) = 23 И Минута(ТекОкноПо) = 59)) Тогда
			ТекОкноС = '00010101000000';
			ТекОкноПо = '00010102235959';
		КонецЕсли;
		Структура_depot.Вставить("Time_window_start", ТекОкноС - НачалоДня(ТекОкноС));
		Структура_depot.Вставить("Time_window_end",   ТекОкноПо - НачалоДня(ТекОкноС));
		НайденнаяСтрока = тблАдреса.Найти(Склад, "Адрес");
		Если НайденнаяСтрока = Неопределено Тогда
			Структура_depot.Вставить("point_number", 0);
		Иначе
			Структура_depot.Вставить("point_number", НайденнаяСтрока.НомерСтроки);
		КонецЕсли;
	Иначе
		Если НЕ ЗначениеЗаполнено(ТекОкноС)
			И (НЕ ЗначениеЗаполнено(ТекОкноПо)
			ИЛИ (Час(ТекОкноПо) = 23 И Минута(ТекОкноПо) = 59)) Тогда
			Структура_depot.Вставить(
			"time_window", 
			"0.00:00:00 - 1.23:59:59"
			); 
			
			Структура_depot.Вставить(
			"time_window_format", 
			"%1.00:00:00 - %2.23:59:59"
			);
		Иначе
			Структура_depot.Вставить(
			"time_window", 
			"" + Строка(День(ТекОкноС) - 1) + "." + Формат(ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
			Строка(День(ТекОкноПо) - 1) + "." + Формат(ТекОкноПо, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
			
			Структура_depot.Вставить(
			"time_window_format", 
			"%1." + Формат(ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") +
			"-%2." + Формат(ТекОкноПо, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
		КонецЕсли;
	КонецЕсли;

	Если РежимОптимизации Тогда
		Структура_depot.Вставить("hard_window", СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказам);
	Иначе
		Структура_depot.Вставить("hard_window", СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации); 
	КонецЕсли;
	 
	МассивОконЗагрузки   = Новый Массив(); 
	МассивОконРазгрузки  = Новый Массив();
	МассивОконДозагрузки = Новый Массив();
	Для Каждого ТекОкно Из НастройкиМаршрутизации.ТаблицаОконСклада Цикл   
		СтруктураДанных = Новый Структура("");
		
		ОкноС   = Дата(СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(ТекОкно.ОкноС, "T", ""), "Z", ""), ":", ""), "-", ""));
		ОкноПо  = Дата(СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(ТекОкно.ОкноПо, "T", ""), "Z", ""), ":", ""), "-", ""));
		
		флагСдвигДатыОкна = Ложь;
		Если ОкноПо < ОкноС Тогда 
			ОкноПо = ОкноПо + 86400;
			флагСдвигДатыОкна = Истина;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ОкноС)
			И (НЕ ЗначениеЗаполнено(ОкноПо)
			ИЛИ (Час(ОкноПо) = 23 И Минута(ОкноПо) = 59)) Тогда
			СтруктураДанных.Вставить(
			"time_window", 
			"0.00:00:00 - 1.23:59:59"
			); 
			
			СтруктураДанных.Вставить(
			"time_window_format", 
			"%1.00:00:00 - %2.23:59:59"
			);
		Иначе
			СтруктураДанных.Вставить(
			"time_window", 
			"" + Строка(День(ОкноС) - 1) + "." + Формат(ОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
			Строка(День(ОкноПо) - 1) + "." + Формат(ОкноПо, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
			
			СтруктураДанных.Вставить(
			"time_window_format", 
			"%1." + Формат(ОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") +
			"-%2." + Формат(ОкноПо, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
		КонецЕсли;
		
		Если ТекОкно.ТипОкна = "Окно загрузки" Тогда
			МассивОконЗагрузки.Добавить(СтруктураДанных);
			Если НЕ флагСдвигДаты 
				И флагСдвигДатыОкна Тогда
				ДатаПланирования = НачалоДня(ДатаПланирования - 1);
				флагСдвигДаты    = Истина;
			КонецЕсли;
		ИначеЕсли ТекОкно.ТипОкна = "Окно разгрузки" Тогда
			МассивОконРазгрузки.Добавить(СтруктураДанных);
		ИначеЕсли ТекОкно.ТипОкна = "Окно дозагрузки" Тогда 
			МассивОконДозагрузки.Добавить(СтруктураДанных);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивОконЗагрузки.Количество() Тогда
		Структура_depot.Вставить("time_windows_loading", Новый Структура("time_windows",
		МассивОконЗагрузки)); 
	КонецЕсли;  
	Если МассивОконРазгрузки.Количество() Тогда
		Структура_depot.Вставить("time_windows_unloading", Новый Структура("time_windows",
		МассивОконРазгрузки));
	КонецЕсли;
	Если МассивОконДозагрузки.Количество() Тогда
		Структура_depot.Вставить("time_windows_refilling", Новый Структура("time_windows,",
		МассивОконДозагрузки));
	КонецЕсли;
	
	Структура_depot.Вставить("point", Новый Структура("lat, lon", Склад.Лат, Склад.Лон));
	
	Если ТипЗнч(Склад) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда
		Структура_throughput = Новый Структура();
		
		ЕстьПропускнаяСпособность = Ложь;
		Если ЗначениеЗаполнено(Склад.ПропускнаяСпособностьСкладаТС) Тогда
			Структура_throughput.Вставить("vehicle_count", Склад.ПропускнаяСпособностьСкладаТС);
			ЕстьПропускнаяСпособность = Истина;
			
		ИначеЕсли НЕ РежимОптимизации Тогда
			Если СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоУпаковок Тогда
				Если ЗначениеЗаполнено(Склад.ПропускнаяСпособностьСкладаЕдЧ) Тогда
					Структура_throughput.Вставить("units_per_hour", Склад.ПропускнаяСпособностьСкладаЕдЧ);
					ЕстьПропускнаяСпособность = Истина;
				КонецЕсли;
			Иначе
				Если ЗначениеЗаполнено(Склад.ПропускнаяСпособностьСкладаКгЧ) Тогда
					Структура_throughput.Вставить("kg_per_hour", Склад.ПропускнаяСпособностьСкладаКгЧ);
					ЕстьПропускнаяСпособность = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ЕстьПропускнаяСпособность Тогда
			Структура_depot.Вставить("throughput", Структура_throughput);
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ РежимОптимизацииМаршрута Тогда 
		ЕстьШтрафы = Ложь;
		СтруктураШтрафов = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_outOfTime_fixed)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_outOfTime_minute) Тогда
			out_of_time = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_outOfTime_fixed) Тогда
				out_of_time.Вставить("fixed", НастройкиМаршрутизации.depotPenalty_outOfTime_fixed);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_outOfTime_minute) Тогда
				out_of_time.Вставить("minute", НастройкиМаршрутизации.depotPenalty_outOfTime_minute);
			КонецЕсли;
			СтруктураШтрафов.Вставить("out_of_time", out_of_time);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_fixed)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_kg)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_unit)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_vehicle) Тогда
			
			throughput = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_fixed) Тогда
				throughput.Вставить("fixed", НастройкиМаршрутизации.depotPenalty_throughput_fixed);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_kg) Тогда
				throughput.Вставить("kg", НастройкиМаршрутизации.depotPenalty_throughput_kg);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_unit) Тогда
				throughput.Вставить("unit", НастройкиМаршрутизации.depotPenalty_throughput_unit);
			КонецЕсли; 
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.depotPenalty_throughput_vehicle) Тогда
				throughput.Вставить("unit", НастройкиМаршрутизации.depotPenalty_throughput_vehicle);
			КонецЕсли;
			СтруктураШтрафов.Вставить("throughput", throughput);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		Если ЕстьШтрафы Тогда
			Структура_depot.Вставить("penalty", СтруктураШтрафов);
		КонецЕсли;;
		
		ТипТС = Новый Массив; //тип ТС заранее не известен
		СтоянкаПоГаражу = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяСтоянкиВПункте(НастройкаАдресВыезда, ТипТС);
		СтоянкаПоГаражуЧас = Цел(СтоянкаПоГаражу);
		СтоянкаПоГаражуМин = (СтоянкаПоГаражу - СтоянкаПоГаражуЧас) * 100;
		СтоянкаПоГаражу = СтоянкаПоГаражуЧас * 3600 + СтоянкаПоГаражуМин * 60;
		Структура_depot.Вставить("service_duration_s",  СтоянкаПоГаражу);
		Структура_depot.Вставить("flexible_start_time", НастройкиМаршрутизации.flexible_start_time);
	КонецЕсли;
    Структура_depot.Вставить("title", НастройкаАдресВыезда.Наименование);
	Структура_depot.Вставить("ref",   НастройкаАдресВыезда.Наименование); // Сноска с информацией о месте
	
	Структура_depot.Вставить("id", уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(НастройкаАдресВыезда, СчДобавленныхОбъектов));
	СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
	
	
	Возврат Структура_depot;
	
КонецФункции

Функция ЗаполнитьСтруктуруПараметровСервисаПланированияМаршрутов(ДатаПланирования, СтруктураНастроекАРМ,
	НастройкиМаршрутизации, ТаблицаГруппПунктов, ИспользуемыеГруппыСовместимости, МассивГеозон, РежимОптимизации = Ложь, РежимОптимизацииМаршрута = Ложь)
	
	ЧасовойПояс   = ?(РежимОптимизации, СтруктураНастроекАРМ.Оптимизация_НастройкаЧасовойПояс, СтруктураНастроекАРМ.НастройкаЧасовойПояс);
	
	Структура_options = Новый Структура(); 
	Структура_options.Вставить("time_zone", ЧасовойПояс);
	Если РежимОптимизацииМаршрута Тогда
		Возврат Структура_options;
	КонецЕсли;
	
	СжиматьЗаказы = ?(РежимОптимизации, СтруктураНастроекАРМ.Оптимизация_НастройкаСжиматьЗаказы, СтруктураНастроекАРМ.НастройкаСжиматьЗаказы);

	Структура_options.Вставить("routing_mode",                       НастройкиМаршрутизации.routing_mode);
	Структура_options.Вставить("weighted_drop_penalty",              НастройкиМаршрутизации.weighted_drop_penalty);
	Структура_options.Вставить("critical_lateness_risk_probability", НастройкиМаршрутизации.critical_lateness_risk_probability);
	Структура_options.Вставить("date",                               Формат(НачалоДня(ДатаПланирования), "ДФ=yyyy-MM-dd; ДП=0001-01-01"));
	Структура_options.Вставить("minimize_lateness_risk",             НастройкиМаршрутизации.minimize_lateness_risk);
	Структура_options.Вставить("restart_on_drop",                    НастройкиМаршрутизации.restart_on_drop);
	Структура_options.Вставить("merge_multiorders",                  СжиматьЗаказы);
	Структура_options.Вставить("proximity_factor",                   НастройкиМаршрутизации.proximity_factor);
	Структура_options.Вставить("global_proximity_factor",            НастройкиМаршрутизации.global_proximity_factor);
	Структура_options.Вставить("post_optimization",                  НастройкиМаршрутизации.post_optimization);
	Структура_options.Вставить("avoid_tolls",                        НастройкиМаршрутизации.avoid_tolls);
	
	Если РежимОптимизации Тогда 
		Если СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказам Тогда
			Структура_options.Вставить("penalize_late_service", СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказамНастройка = 1);
		КонецЕсли;
		Если СтруктураНастроекАРМ.НастройкаАлгоритмОптимизации = "RarusVRP" Тогда
			Если СтруктураНастроекАРМ.Оптимизация_НастройкаРежимОптимизации = 1 Тогда 
				Структура_options.Вставить("minimize", "distance");
				
			ИначеЕсли СтруктураНастроекАРМ.Оптимизация_НастройкаРежимОптимизации = 2 Тогда 
				Структура_options.Вставить("minimize", "cost");
				
			Иначе 
				Структура_options.Вставить("minimize", "time");
			КонецЕсли;
			Если ЗначениеЗаполнено(СтруктураНастроекАРМ.Оптимизация_НастройкаКоличествоДнейМаршрутизации) Тогда
				Структура_options.Вставить("maximum_time_days", СтруктураНастроекАРМ.Оптимизация_НастройкаКоличествоДнейМаршрутизации);
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.default_speed_km_h) Тогда
				Структура_options.Вставить("default_speed_km_h", НастройкиМаршрутизации.default_speed_km_h);
			КонецЕсли;
			Структура_options.Вставить("minimize", "cost");
		КонецЕсли; 
	Иначе 
		Если СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации Тогда
			Структура_options.Вставить("penalize_late_service", СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизацииНастройка = 1);
		КонецЕсли;
		Если СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4 Тогда
			Если СтруктураНастроекАРМ.НастройкаРежимОптимизации = 1 Тогда 
				Структура_options.Вставить("minimize", "distance");
				
			ИначеЕсли СтруктураНастроекАРМ.НастройкаРежимОптимизации = 2 Тогда 
				Структура_options.Вставить("minimize", "cost");
				
			Иначе 
				Структура_options.Вставить("minimize", "time");
			КонецЕсли;
			Если ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаКоличествоДнейМаршрутизации) Тогда
				Структура_options.Вставить("maximum_time_days", СтруктураНастроекАРМ.НастройкаКоличествоДнейМаршрутизации);
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.default_speed_km_h) Тогда
				Структура_options.Вставить("default_speed_km_h", НастройкиМаршрутизации.default_speed_km_h);
			КонецЕсли;
			Структура_options.Вставить("minimize", "cost");
		КонецЕсли;
	КонецЕсли;
	
	Если НастройкиМаршрутизации.quality = "manual" Тогда 
		Структура_options.Вставить("solver_time_limit_s", НастройкиМаршрутизации.solver_time_limit);
		Структура_options.Вставить("thread_count",        НастройкиМаршрутизации.thread_count);
	Иначе 
		Структура_options.Вставить("quality", НастройкиМаршрутизации.quality);
	КонецЕсли;
	
	Если СтруктураНастроекАРМ.НастройкаУчитыватьГруппыСовместимости Тогда
		НесовместимыеГруппы = уатВнешнийМаршрутизаторСервер_уэ.ПолучитьНесовместимыеГруппы(СтруктураНастроекАРМ.НастройкаУчитыватьГруппыСовместимости,
			НастройкиМаршрутизации, ИспользуемыеГруппыСовместимости);
		Структура_options.Вставить("incompatible_load_types", НесовместимыеГруппы);
	КонецЕсли;
	
	ТипАвторизации = уатЭлектронныеКартыСервер.ПолучитьНастройкуСервераКартографииМаршрутизации("Маршрутизация_ТипАвторизации");
	Если ТипАвторизации = "OAuth-токен" Тогда
		Если СтруктураНастроекАРМ.НастройкаУчетГеозон Тогда
			ТаблицаНесовместимыхГеозон = НастройкиМаршрутизации.ТаблицаНесовместимыхГеозон;
			
			НесовместимыеГеозоны = Новый Массив();
			Для Каждого ТекЭлемент Из ТаблицаНесовместимыхГеозон Цикл
				ТекНесовместимыеГеозоны = Новый Массив();
				Для Каждого ТекЗона Из ТекЭлемент Цикл
					Если СтроковыеФункцииКлиентСервер.ЭтоУникальныйИдентификатор(ТекЗона) Тогда 
						Геозона = Справочники.уатГеозоны_уэ.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекЗона));
						Если ЗначениеЗаполнено(Геозона.НомерЯндекс) Тогда 
							ТекЗона = Геозона.НомерЯндекс; 
							Если МассивГеозон.Найти(ТекЗона) = Неопределено Тогда
								МассивГеозон.Добавить(ТекЗона);
							КонецЕсли;
						Иначе 
							Если МассивГеозон.Найти(Геозона) = Неопределено Тогда
								МассивГеозон.Добавить(Геозона);
							КонецЕсли; 
						КонецЕсли;
					Иначе
						Если МассивГеозон.Найти(ТекЗона) = Неопределено Тогда
							МассивГеозон.Добавить(ТекЗона);
						КонецЕсли;
					КонецЕсли;
					ТекНесовместимыеГеозоны.Добавить(ТекЗона);
				КонецЦикла; 
				Если ТекНесовместимыеГеозоны.Количество() Тогда 
					НесовместимыеГеозоны.Добавить(ТекНесовместимыеГеозоны);
				КонецЕсли;
			КонецЦикла;
			Структура_options.Вставить("incompatible_zones", НесовместимыеГеозоны);
		Иначе 
			Если НЕ СтруктураНастроекАРМ.НастройкаИспользоватьЗакреплениеТСЗаказовНаТСзаГеозонами Тогда
				Структура_options.Вставить("ignore_zones", Истина);
			КонецЕсли;
		КонецЕсли;  
	КонецЕсли;
	
	Если ТаблицаГруппПунктов.Количество() <> 0 Тогда
		МассивГруппПунктов = Новый Массив();
		Для Каждого ТекГруппа Из ТаблицаГруппПунктов Цикл
			Если ТекГруппа.Значение.Количество() > 1 Тогда
				МассивГруппПунктов.Добавить(Новый Структура("title, location_ids, solid, dependent", ТекГруппа.Заголовок,
				ТекГруппа.Значение, ТекГруппа.Неразрывная, ТекГруппа.Неделимая));
			КонецЕсли;
		КонецЦикла;
		Если МассивГруппПунктов.Количество() <> 0 Тогда
			Структура_options.Вставить("location_groups", МассивГруппПунктов);
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(НастройкиМаршрутизации.multiordersPenalty_per_extra_visit) Тогда
		Структура_penalty_multiorders = Новый Структура("per_extra_visit",
		НастройкиМаршрутизации.multiordersPenalty_per_extra_visit);  
		Структура_penalty = Новый Структура("multiorders", Структура_penalty_multiorders);
		Структура_options.Вставить("penalty", Структура_penalty);
	КонецЕсли;
	
	Возврат Структура_options;

КонецФункции

Функция ЗаполнитьСписокПунктовНазначение(ДатаПланирования, ТаблицаЗаказов, СтруктураНастроекАРМ,
	НастройкиМаршрутизации, Таблицаlocation, ТаблицаГруппПунктов, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса,
	СоответствиеГеозон, СоответвиеЗаказов, РазрешенныеТСПоЗаказам, ИспользуемыеГруппыСовместимости, РежимОптимизации = Ложь)
	
	Если РежимОптимизации Тогда
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмОптимизации = "RarusVRP";
	Иначе
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4;
	КонецЕсли;
	
	Массив_locations = Новый Массив();
	
	// Заполняем пункты доставки (delivery_to_any)
	Если флRarusVRP Тогда
		ИдентификаторыПунктовДоставки = Новый Массив; 
		ФлагПунктыВыдачи = Ложь;
	Иначе
		ИдентификаторыПунктовДоставки = ЗаполнитьПунктыДоставки(Массив_locations, СтруктураНастроекАРМ, НастройкиМаршрутизации, СчДобавленныхОбъектов, РежимОптимизации);
		ФлагПунктыВыдачи = ИдентификаторыПунктовДоставки.Количество() <> 0;
	КонецЕсли;

	СоответствиеГруппПунктов = Новый Соответствие();
	ТаблицаГруппПунктов      = уатВнешнийМаршрутизаторСервер_уэ.ПолучитьГруппыПунктов(СтруктураНастроекАРМ.НастройкаГруппироватьПунктыВОднуМашину, НастройкиМаршрутизации, СоответствиеГруппПунктов, РежимОптимизации);
	
	СоответвиеУчтеныхГрупп = Новый Соответствие();
	Для Каждого ТекЗаказ Из ТаблицаЗаказов Цикл
		
		// Если заполнен параметр delivery_to_any, пункты назначения заказа не учитываем
		// В этом случает требуется указать пункт отправления и заполнить delivery_to_any
		//
		Если НЕ ФлагПунктыВыдачи Тогда
			Структура_location   = ЗаполнитьСтруктуруПунктаНазначенияDelivery(ДатаПланирования, ТекЗаказ, СтруктураНастроекАРМ,
				НастройкиМаршрутизации, Таблицаlocation, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, СоответствиеГеозон, 
				РазрешенныеТСПоЗаказам, ИспользуемыеГруппыСовместимости, РежимОптимизации);
				
			ТекГруппаПунктов = СоответствиеГруппПунктов.Получить(ТекЗаказ.АдресНазначения);

			Если ТекГруппаПунктов <> Неопределено Тогда
				СтрокиГруппы = ТаблицаГруппПунктов.НайтиСтроки(Новый Структура("Заголовок", ТекГруппаПунктов));
				Если СтрокиГруппы.Количество() <> 0 Тогда
					Если НЕ РежимОптимизации
						И ЗначениеЗаполнено(ТекЗаказ.location_group)
						И СтрокиГруппы[0].Значение.Количество() <> 0 Тогда
						
						// Доставка грузов неразрывно, время уже учли
						Структура_location.shared_service_duration_s = 0;
						Структура_location.service_duration_s        = 0;
					КонецЕсли;    
					
					ЭлементыГруппы = СтрокиГруппы[0].Значение;
					ЭлементыГруппы.Добавить(Структура_location.id);
					СтрокиГруппы[0].Значение = ЭлементыГруппы;
					
				КонецЕсли; 
			ИначеЕсли НЕ РежимОптимизации
				И ЗначениеЗаполнено(ТекЗаказ.location_group) Тогда
				СтрокиГруппы = ТаблицаГруппПунктов.НайтиСтроки(Новый Структура("Заголовок", ТекЗаказ.location_group));
				Если СтрокиГруппы.Количество() <> 0 Тогда
					ЭлементыГруппы = СтрокиГруппы[0].Значение;
					ЭлементыГруппы.Добавить(Структура_location.id);
					СтрокиГруппы[0].Значение    = ЭлементыГруппы; 
					
					// Доставка грузов неразрывно, время уже учли
					Структура_location.shared_service_duration_s = 0;
					Структура_location.service_duration_s        = 0;
				Иначе   
					ЭлементыГруппы = Новый Массив();
					ЭлементыГруппы.Добавить(Структура_location.id);
					
					НоваяГруппа = ТаблицаГруппПунктов.Добавить(); 
					НоваяГруппа.Заголовок   = ТекЗаказ.location_group;
					НоваяГруппа.Неразрывная = Истина;
					НоваяГруппа.Неделимая   = Истина;
					
					НоваяГруппа.Значение  = ЭлементыГруппы;
				КонецЕсли;     
			КонецЕсли;
			
			СоответвиеЗаказов.Вставить(ТекЗаказ.GUID,
				Структура_location.id);
			
			Массив_locations.Добавить(Структура_location);
			
			СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
		КонецЕсли;
		
		// Если адрес отправления заказа не является складом,
		// должны указать этот пункт и заполнить delivery_to с id адреса прибытия по этому заказу.
		// Параментр delivery_to и delivery_to_any являются взамиисключающими.
		// Заполняем депо.
		Если СтруктураНастроекАРМ.НастройкаАдресВыезда <> ТекЗаказ.АдресОтправления
			ИЛИ ФлагПунктыВыдачи 
			ИЛИ флRarusVRP Тогда
			
			Если НЕ РежимОптимизации
				И СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГруза Тогда
				ТипГабаритов = ?(ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГрузаНастройка), 
							СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГрузаНастройка, "rigid");
				Если ТипЗнч(ТекЗаказ.Груз) = Тип("СправочникСсылка.Номенклатура") Тогда
					ХарактеристикиНоменклатуры = уатОбщегоНазначения.ПолучитьВесОбъемНоменклатуры(ТекЗаказ.Груз, ТекЗаказ.Груз.ЕдиницаХраненияОстатков, ТекЗаказ.Количество);
					ПолезныйРазмерГлубина             = ХарактеристикиНоменклатуры.Длина;
					ПолезныйРазмерШирина              = ХарактеристикиНоменклатуры.Ширина;
					ПолезныйРазмерВысота              = ХарактеристикиНоменклатуры.Высота;
				ИначеЕсли ТипЗнч(ТекЗаказ.Груз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
					ПолезныйРазмерГлубина   = ТекЗаказ.Длина;
					ПолезныйРазмерШирина    = ТекЗаказ.Ширина;
					ПолезныйРазмерВысота    = ТекЗаказ.Высота;
				Иначе
					ПолезныйРазмерГлубина   = ТекЗаказ.Объем;
					ПолезныйРазмерШирина    = 1;
					ПолезныйРазмерВысота    = 1;
					ТипГабаритов = "bulk";
				КонецЕсли;

			Иначе
				ПолезныйРазмерВысота     = 1;
				ПолезныйРазмерШирина     = 1;
				ПолезныйРазмерГлубина    = ТекЗаказ.Объем;
				ТипГабаритов = "bulk";
			КонецЕсли;

			Если НЕ РежимОптимизации
				И СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоГрузов Тогда
				units = ?(СтруктураНастроекАРМ.НастройкаМаксимальноеЧислоЗаказовМаршрута = 0, 0, 1);
			Иначе
				units = ТекЗаказ.КоличествоУпаковок;
			КонецЕсли;

			Структура_locationДепо = Новый Структура;
			Структура_locationДепо.Вставить("shipment_size", 
			Новый Структура("volume, units, weight_kg", 
			Новый Структура("height_m, width_m, depth_m, type", ПолезныйРазмерВысота, ПолезныйРазмерШирина, ПолезныйРазмерГлубина, ТипГабаритов),
			units,
			ТекЗаказ.ВесБрутто
			)
			);

			СтоянкаПогрузка = ТекЗаказ.СтоянкаПунктНазначения;
			СтоянкаПогрузкаЧас = Цел(СтоянкаПогрузка);
			СтоянкаПогрузкаМин = (СтоянкаПогрузка - СтоянкаПогрузкаЧас) * 100;
			СтоянкаПогрузка = СтоянкаПогрузкаЧас * 3600 + СтоянкаПогрузкаМин * 60;
			Структура_locationДепо.Вставить("depot_duration_s", СтоянкаПогрузка);
			
			СтоянкаРазгрузка = ТекЗаказ.СтоянкаПунктОтправления;
			СтоянкаРазгрузкаЧас = Цел(СтоянкаРазгрузка);
			СтоянкаРазгрузкаМин = (СтоянкаРазгрузка - СтоянкаРазгрузкаЧас) * 100;
			СтоянкаРазгрузка = СтоянкаРазгрузкаЧас * 3600 + СтоянкаРазгрузкаМин * 60;
			Структура_locationДепо.Вставить("service_duration_s", СтоянкаРазгрузка);
				
			Если ФлагПунктыВыдачи Тогда
				Если флRarusVRP Тогда
					СекундВДне = 86400;
					Структура_locationДепо.Вставить("Time_window_start", 0);
					Структура_locationДепо.Вставить("Time_window_end", СекундВДне-1);
				Иначе
					Структура_locationДепо.Вставить("time_window", "0.00:00:00-23:59:59");
				КонецЕсли;
				Структура_locationДепо.Вставить("hard_window", Ложь);
				
				Если СтруктураНастроекАРМ.НастройкаАдресВыезда <> ТекЗаказ.АдресОтправления Тогда
					ДопСтоянкаРазгрузка = ТекЗаказ.ДопСтоянкаПунктОтправления;
					ДопСтоянкаРазгрузкаЧас = Цел(ДопСтоянкаРазгрузка);
					ДопСтоянкаРазгрузкаМин = (ДопСтоянкаРазгрузка - ДопСтоянкаРазгрузкаЧас) * 100;
					ДопСтоянкаРазгрузка = ДопСтоянкаРазгрузкаЧас * 3600 + ДопСтоянкаРазгрузкаМин * 60;
					Структура_locationДепо.Вставить("shared_service_duration_s", ДопСтоянкаРазгрузка);
				КонецЕсли;

			Иначе

				ДопСтоянкаРазгрузка		 = ТекЗаказ.ДопСтоянкаПунктОтправления;
				ДопСтоянкаРазгрузкаЧас	 = Цел(ДопСтоянкаРазгрузка);
				ДопСтоянкаРазгрузкаМин	 = (ДопСтоянкаРазгрузка - ДопСтоянкаРазгрузкаЧас) * 100;
				ДопСтоянкаРазгрузка		 = ДопСтоянкаРазгрузкаЧас * 3600 + ДопСтоянкаРазгрузкаМин * 60;
				Структура_locationДепо.Вставить("shared_service_duration_s", ДопСтоянкаРазгрузка);

				ТекОкноС  = ТекЗаказ.ОтправлениеС;
				ТекОкноПо = ?(ТекЗаказ.ОтправлениеПо = '00010101000000', '00010101235959', ТекЗаказ.ОтправлениеПо);
				
				ТекОкноС  = ТекОкноС  - НачалоДня(ТекОкноС);
				ТекОкноПо = ТекОкноПо - НачалоДня(ТекОкноПо); 
				ТекОкноС  = ?(РежимОптимизации, НачалоДня(ДатаПланирования), НачалоДня(ТекЗаказ.ОтправлениеСДата))  + ТекОкноС;
				ТекОкноПо = ?(РежимОптимизации, НачалоДня(ДатаПланирования), НачалоДня(ТекЗаказ.ОтправлениеПоДата)) + ТекОкноПо;
	 				
				Если флRarusVRP Тогда
					Структура_locationДепо.Вставить("Time_window_start", ТекОкноС - НачалоДня(ДатаПланирования));
					Структура_locationДепо.Вставить("Time_window_end",   ТекОкноПо - НачалоДня(ДатаПланирования));
				Иначе    
					Если НЕ РежимОптимизации
						И СтруктураНастроекАРМ.НастройкаВременноеОкноДействуетЕжедневно Тогда
						МассивДатПланирования = уатВнешнийМаршрутизаторСервер_уэ.ПолучитьМассивДатПланирования(ТекОкноС, ТекОкноПо);
						
						МассивОкон   = Новый Массив(); 
						ВвремяНачала    = ТекОкноС  - НачалоДня(ТекОкноС);
						ВвремяОкончания = ТекОкноПо - НачалоДня(ТекОкноПо);
						
						Для Каждого ТекДата Из МассивДатПланирования Цикл 
							МассивОкон.Добавить(Новый Структура("time_window", 
							"" + Формат(НачалоДня(ТекДата) + ВвремяНачала, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(СтруктураНастроекАРМ.НастройкаЧасовойПояс>=0, "+", "") + Формат(СтруктураНастроекАРМ.НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00") + "/" +
							Формат(НачалоДня(ТекДата) + ВвремяОкончания, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(СтруктураНастроекАРМ.НастройкаЧасовойПояс>=0, "+", "") + Формат(СтруктураНастроекАРМ.НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00")
							));
						КонецЦикла;
						Структура_locationДепо.Вставить("time_windows", МассивОкон);
					Иначе   
						НастройкаЧасовойПояс = ?(РежимОптимизации, СтруктураНастроекАРМ.Оптимизация_НастройкаЧасовойПояс, СтруктураНастроекАРМ.НастройкаЧасовойПояс);
						
						Структура_locationДепо.Вставить(
						"time_window", 
						"" + Формат(ТекОкноС, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00") + "/" +
						Формат(ТекОкноПо, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00")
						);
					КонецЕсли;
				КонецЕсли;
				
				Структура_locationДепо.Вставить("hard_window",  СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации);
				
				ЕстьШтрафы = Ложь;
				СтруктураШтрафов = Новый Структура();
				Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed)
					ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
					out_of_time = Новый Структура();
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed) Тогда
						out_of_time.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed);
					КонецЕсли;
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
						out_of_time.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_outOfTime_minute);
					КонецЕсли;
					СтруктураШтрафов.Вставить("out_of_time", out_of_time);
					ЕстьШтрафы = Истина;
				КонецЕсли;
				Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed)
					ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
					early = Новый Структура();
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed) Тогда
						early.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_early_fixed);
					КонецЕсли;
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
						early.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_early_minute);
					КонецЕсли;
					СтруктураШтрафов.Вставить("early", early);
					ЕстьШтрафы = Истина;
				КонецЕсли;
				Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed)
					ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
					late = Новый Структура();
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed) Тогда
						late.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_late_fixed);
					КонецЕсли;
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
						late.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_late_minute);
					КонецЕсли;
					СтруктураШтрафов.Вставить("late", late);
					ЕстьШтрафы = Истина;
				КонецЕсли;
				Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
					drop = Новый Структура();
					Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
						drop.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_drop);
					КонецЕсли;
					СтруктураШтрафов.Вставить("drop", НастройкиМаршрутизации.locationsPenalty_drop);
					ЕстьШтрафы = Истина;
				КонецЕсли;
				Если ЕстьШтрафы Тогда
					Структура_locationДепо.Вставить("penalty", СтруктураШтрафов);
				КонецЕсли;
				
				Если НЕ РежимОптимизации Тогда
					Если флRarusVRP Тогда
						// Для алгоритма Рарус VRP заполняются идентификаторы разрешенных ТС
						РазрешенныеТС = РазрешенныеТСПоЗаказам[ТекЗаказ.Ссылка];
						Если РазрешенныеТС <> Неопределено Тогда
							Структура_locationДепо.Вставить("AllowedVehicles", Новый Массив);
							Для Каждого ТС Из РазрешенныеТС Цикл
								Структура_locationДепо.AllowedVehicles.Добавить(ТС.GUID);
							КонецЦикла;
						КонецЕсли;
					Иначе
						// Теги используются только для Яндекса
						Структура_locationДепо.Вставить("required_tags", Новый Массив());
						
						Если СтруктураНастроекАРМ.НастройкаИспользоватьХарактеристикиЗаказовНаТС Тогда 
							Для Каждого СтрокаХарактеристики Из ТекЗаказ.Ссылка.Характеристики Цикл 
								Структура_locationДепо.required_tags.Добавить(Строка(СтрокаХарактеристики.Характеристика.УникальныйИдентификатор()));
							КонецЦикла;
						КонецЕсли;
						
						Если СтруктураНастроекАРМ.НастройкаИспользоватьЗакреплениеТСЗаказовНаТСзаГеозонами
							И НЕ СтруктураНастроекАРМ.ТипАвторизации = "OAuth-токен" Тогда
							Если СтруктураНастроекАРМ.НастройкаПривязкаКГеозоне = 0 Тогда
								Пункт = ТекЗаказ.АдресОтправления;
							Иначе
								Пункт = ТекЗаказ.АдресНазначения;
							КонецЕсли;
							мсвГеозон = СоответствиеГеозон.Получить(Пункт);
							Если мсвГеозон <> Неопределено Тогда
								Для Каждого СтрокаХарактеристики Из мсвГеозон Цикл 
									Структура_locationДепо.required_tags.Добавить(СтрокаХарактеристики);
								КонецЦикла;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				ДопСтоянкаРазгрузка = ТекЗаказ.ДопСтоянкаПунктОтправления;
				ДопСтоянкаРазгрузкаЧас = Цел(ДопСтоянкаРазгрузка);
				ДопСтоянкаРазгрузкаМин = (ДопСтоянкаРазгрузка - ДопСтоянкаРазгрузкаЧас) * 100;
				ДопСтоянкаРазгрузка = ДопСтоянкаРазгрузкаЧас * 3600 + ДопСтоянкаРазгрузкаМин * 60;
				Структура_locationДепо.Вставить("shared_service_duration_s", ДопСтоянкаРазгрузка);

			КонецЕсли;
			
			Если НЕ РежимОптимизации
				И ЗначениеЗаполнено(ТекЗаказ.location_group) Тогда 
				Если СоответвиеУчтеныхГрупп.Получить(ТекЗаказ.location_group) <> Неопределено Тогда
					Структура_locationДепо.shared_service_duration_s = 0;
					Структура_locationДепо.service_duration_s        = 0;
				Иначе
					СоответвиеУчтеныхГрупп.Вставить(ТекЗаказ.location_group, ТекЗаказ.location_group);
				КонецЕсли;
			КонецЕсли;
			
			Структура_locationДепо.Вставить("point", Новый Структура("lat, lon", ТекЗаказ.ЛатОтпр, ТекЗаказ.ЛонОтпр));
			Если флRarusVRP Тогда
				НайденнаяСтрока = тблАдреса.Найти(ТекЗаказ.АдресОтправления, "Адрес");
				Если НайденнаяСтрока = Неопределено Тогда
					Структура_locationДепо.Вставить("point_number", 0);
				Иначе
					Структура_locationДепо.Вставить("point_number", НайденнаяСтрока.НомерСтроки);
				КонецЕсли;
			КонецЕсли;      
			Структура_locationДепо.Вставить("sequence_order", ТекЗаказ.Приоритет);  
			
			Если ЗначениеЗаполнено(ТекЗаказ.Ссылка) Тогда
				Структура_locationДепо.Вставить("description",  Строка(ТекЗаказ.АдресОтправления));
				
				Если ЗначениеЗаполнено(ТекЗаказ.Ссылка.Грузоотправитель) Тогда
					Структура_locationДепо.Вставить("title", "Грузоотправитель: " + ТекЗаказ.Ссылка.Грузоотправитель);
				ИначеЕсли ЗначениеЗаполнено(ТекЗаказ.Ссылка.Контрагент) Тогда 
					Структура_locationДепо.Вставить("title", "Контрагент: " + ТекЗаказ.Ссылка.Контрагент);
				КонецЕсли;
			Конецесли;
			Структура_locationДепо.Вставить("ref",      Строка(ТекЗаказ.GUID)); 
			Если ЗначениеЗаполнено(ТекЗаказ.Ссылка) Тогда
				Структура_locationДепо.Вставить("comments", ТекЗаказ.Ссылка.КомментарийВодителю);
			КонецЕсли;
			Структура_locationДепо.Вставить("id",       уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(ТекЗаказ.АдресОтправления, СчДобавленныхОбъектов));
			Структура_locationДепо.Вставить("type",     "pickup");

			Если ФлагПунктыВыдачи Тогда
				Структура_locationДепо.Вставить("delivery_to_any",  ИдентификаторыПунктовДоставки);
				
				СоответвиеЗаказов.Вставить(ТекЗаказ.GUID,
				ИдентификаторыПунктовДоставки);
			Иначе
				// Заполняем идентификатор следующего пункта по маршруту
				Структура_locationДепо.Вставить("delivery_to",  Структура_location.id);
				
				СоответвиеЗаказов.Вставить(ТекЗаказ.GUID,
				Структура_location.id);
			КонецЕсли;
			
			Массив_locations.Добавить(Структура_locationДепо);
			
			СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Массив_locations;
	
КонецФункции

Функция ЗаполнитьСтруктуруПунктаНазначенияDelivery(ДатаПланирования, ТекЗаказ, СтруктураНастроекАРМ, НастройкиМаршрутизации,
	Таблицаlocation, флагСдвигДаты, СчДобавленныхОбъектов, тблАдреса, СоответствиеГеозон, РазрешенныеТСПоЗаказам, 
	ИспользуемыеГруппыСовместимости, РежимОптимизации = Ложь)
	
	Если РежимОптимизации Тогда
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмОптимизации = "RarusVRP";
	Иначе
		флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4;
	КонецЕсли;

	НастройкаЧасовойПояс = ?(РежимОптимизации, СтруктураНастроекАРМ.Оптимизация_НастройкаЧасовойПояс, СтруктураНастроекАРМ.НастройкаЧасовойПояс);
	
	Структура_location = Новый Структура();
	
	ТекОкноС  = ТекЗаказ.ДоставкаС;
	ТекОкноПо = ?(ТекЗаказ.ДоставкаПо = '00010101000000', '00010101235959', ТекЗаказ.ДоставкаПо);
	
	ТекОкноС  = ТекОкноС  - НачалоДня(ТекОкноС);
	ТекОкноПо = ТекОкноПо - НачалоДня(ТекОкноПо);
	ТекОкноС  = ?(РежимОптимизации, НачалоДня(ДатаПланирования), НачалоДня(ТекЗаказ.ДоставкаСДата))  + ТекОкноС;
	ТекОкноПо = ?(РежимОптимизации, НачалоДня(ДатаПланирования), НачалоДня(ТекЗаказ.ДоставкаПоДата)) + ТекОкноПо;
	
	Если флRarusVRP Тогда
		Структура_location.Вставить("Time_window_start", ТекОкноС - НачалоДня(ДатаПланирования));
		Структура_location.Вставить("Time_window_end",   ТекОкноПо - НачалоДня(ДатаПланирования));
	Иначе  
		Если НЕ РежимОптимизации
			И СтруктураНастроекАРМ.НастройкаВременноеОкноДействуетЕжедневно Тогда  
			МассивДатПланирования = уатВнешнийМаршрутизаторСервер_уэ.ПолучитьМассивДатПланирования(ТекОкноС, ТекОкноПо);
			
			МассивОкон   = Новый Массив(); 
			ВвремяНачала    = ТекОкноС  - НачалоДня(ТекОкноС);
			ВвремяОкончания = ТекОкноПо - НачалоДня(ТекОкноПо);

			Для Каждого ТекДата Из МассивДатПланирования Цикл 
				МассивОкон.Добавить(Новый Структура("time_window", 
				"" + Формат(НачалоДня(ТекДата) + ВвремяНачала, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00") + "/" +
				Формат(НачалоДня(ТекДата) + ВвремяОкончания, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00")
				));
			КонецЦикла;
			Структура_location.Вставить("time_windows", МассивОкон);
		Иначе
			Структура_location.Вставить(
			"time_window", 
			"" + Формат(ТекОкноС, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00") + "/" +
			Формат(ТекОкноПо, "ДФ=гггг-ММ-ддTЧЧ:мм:сс" + ?(НастройкаЧасовойПояс>=0, "+", "") + Формат(НастройкаЧасовойПояс, "ЧЦ=2; ЧВН=") + ":00")
			);
		КонецЕсли;
	КонецЕсли;
	
	Структура_location.Вставить("hard_window", СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации);
	
	Структура_location.Вставить("point", Новый Структура("lat, lon", ТекЗаказ.ЛатНазн, ТекЗаказ.ЛонНазн));
	
	Если флRarusVRP Тогда
		НайденнаяСтрока = тблАдреса.Найти(ТекЗаказ.АдресНазначения, "Адрес");
		Если НайденнаяСтрока = Неопределено Тогда
			Структура_location.Вставить("point_number", 0);
		Иначе
			Структура_location.Вставить("point_number", НайденнаяСтрока.НомерСтроки);
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ РежимОптимизации
		И СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГруза Тогда
		ТипГабаритов = ?(ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГрузаНастройка), 
			СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГрузаНастройка, "rigid");
		Если ТипЗнч(ТекЗаказ.Груз) = Тип("СправочникСсылка.Номенклатура") Тогда
			ХарактеристикиНоменклатуры = уатОбщегоНазначения.ПолучитьВесОбъемНоменклатуры(ТекЗаказ.Груз, ТекЗаказ.Груз.ЕдиницаХраненияОстатков, ТекЗаказ.Количество);
			ПолезныйРазмерВысота            = ХарактеристикиНоменклатуры.Высота;
			ПолезныйРазмерШирина            = ХарактеристикиНоменклатуры.Ширина;
			ПолезныйРазмерГлубина           = ХарактеристикиНоменклатуры.Длина;
		ИначеЕсли ТипЗнч(ТекЗаказ.Груз) = Тип("СправочникСсылка.уатГрузовыеМеста_уэ") Тогда
			ПолезныйРазмерВысота   = ТекЗаказ.Высота;
			ПолезныйРазмерШирина   = ТекЗаказ.Ширина;
			ПолезныйРазмерГлубина  = ТекЗаказ.Длина;
		Иначе
			ПолезныйРазмерВысота   = 1;
			ПолезныйРазмерШирина   = 1;
			ПолезныйРазмерГлубина  = ТекЗаказ.Объем;
			ТипГабаритов = "bulk";
		КонецЕсли;

	Иначе
		ПолезныйРазмерВысота  = 1;
		ПолезныйРазмерШирина  = 1;
		ПолезныйРазмерГлубина = ТекЗаказ.Объем;
		ТипГабаритов = "bulk";
	КонецЕсли;
	
	Если СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоГрузов = Неопределено Тогда
		 СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоГрузов = Истина;
	 КонецЕсли;
	 
	Если НЕ РежимОптимизации
		И СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоГрузов Тогда
		units = ?(СтруктураНастроекАРМ.НастройкаМаксимальноеЧислоЗаказовМаршрута = 0, 0, 1);
	Иначе
		units = ТекЗаказ.КоличествоУпаковок;
	КонецЕсли;

	Структура_location.Вставить("shipment_size", 
	Новый Структура("volume, units, weight_kg", 
	Новый Структура("height_m, width_m, depth_m, type", ПолезныйРазмерВысота, ПолезныйРазмерШирина, ПолезныйРазмерГлубина, ТипГабаритов),
	units,
	ТекЗаказ.ВесБрутто
	)
	); 

	ЕстьШтрафы = Ложь;
	СтруктураШтрафов = Новый Структура();
	Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed)
		ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
		out_of_time = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed) Тогда
			out_of_time.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed);
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
			out_of_time.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_outOfTime_minute);
		КонецЕсли;
		СтруктураШтрафов.Вставить("out_of_time", out_of_time);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed)
		ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
		early = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed) Тогда
			early.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_early_fixed);
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
			early.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_early_minute);
		КонецЕсли;
		СтруктураШтрафов.Вставить("early", early);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed)
		ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
		late = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed) Тогда
			late.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_late_fixed);
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
			late.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_late_minute);
		КонецЕсли;
		СтруктураШтрафов.Вставить("late", late);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
		drop = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
			drop.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_drop);
		КонецЕсли;
		СтруктураШтрафов.Вставить("drop", НастройкиМаршрутизации.locationsPenalty_drop);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЕстьШтрафы Тогда
		Структура_location.Вставить("penalty", СтруктураШтрафов);
	КонецЕсли;
	
	Если НЕ РежимОптимизации Тогда
		Если флRarusVRP Тогда
			// Для алгоритма Рарус VRP заполняются идентификаторы разрешенных ТС
			РазрешенныеТС = РазрешенныеТСПоЗаказам[ТекЗаказ.Ссылка];
			Если РазрешенныеТС <> Неопределено Тогда
				Структура_location.Вставить("AllowedVehicles", Новый Массив);
				Для Каждого ТС Из РазрешенныеТС Цикл
					Структура_location.AllowedVehicles.Добавить(ТС.GUID);
				КонецЦикла;
			КонецЕсли;
		Иначе
			// Теги используются только для Яндекса
			Структура_location.Вставить("required_tags", Новый Массив());
			
			Если СтруктураНастроекАРМ.НастройкаИспользоватьХарактеристикиЗаказовНаТС Тогда 
				Для Каждого СтрокаХарактеристики Из ТекЗаказ.Ссылка.Характеристики Цикл 
					Структура_location.required_tags.Добавить(Строка(СтрокаХарактеристики.Характеристика.УникальныйИдентификатор()));
				КонецЦикла;
			КонецЕсли;
			
			Если СтруктураНастроекАРМ.НастройкаИспользоватьЗакреплениеТСЗаказовНаТСзаГеозонами 
				И НЕ СтруктураНастроекАРМ.ТипАвторизации = "OAuth-токен" Тогда 
				Если СтруктураНастроекАРМ.НастройкаПривязкаКГеозоне = 0 Тогда
					Пункт = ТекЗаказ.АдресОтправления;
				Иначе
					Пункт = ТекЗаказ.АдресНазначения;
				КонецЕсли;
				мсвГеозон = СоответствиеГеозон.Получить(Пункт);
				Если мсвГеозон <> Неопределено Тогда
					Для Каждого СтрокаХарактеристики Из мсвГеозон Цикл 
						Структура_location.required_tags.Добавить(СтрокаХарактеристики);
					КонецЦикла;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
		
		Если СтруктураНастроекАРМ.НастройкаУчитыватьГруппыСовместимости Тогда 
			load_types = Новый Массив();
			
			Если флRarusVRP И ТекЗаказ.Ссылка.ГруппыСовместимости.Количество() > 0 Тогда
				// Для маршрутизации Рарус VRP учитывается только одна (первая) группа совместимости из Заказа на ТС
				СтрокаСовместимости = ТекЗаказ.Ссылка.ГруппыСовместимости[0];
				уатВнешнийМаршрутизаторСервер_уэ.ДобавитьГруппуСовместимостиИзСтроки(СтрокаСовместимости, load_types, ИспользуемыеГруппыСовместимости);
			ИначеЕсли ТекЗаказ.Ссылка.ГруппыСовместимости.Количество() > 0 Тогда
				Для Каждого СтрокаСовместимости Из ТекЗаказ.Ссылка.ГруппыСовместимости Цикл
					уатВнешнийМаршрутизаторСервер_уэ.ДобавитьГруппуСовместимостиИзСтроки(СтрокаСовместимости, load_types, ИспользуемыеГруппыСовместимости);
				КонецЦикла;
			ИначеЕсли ТекЗаказ.Ссылка.ГруппыСовместимости.Количество() = 0
				И Не НастройкиМаршрутизации.ПустаяГруппаСовместимостиСовместима Тогда
				СтрокаСовместимости = Новый Структура("ГруппаСовместимости", Справочники.уатГруппыСовместимости_уэ.ПустаяСсылка());
				уатВнешнийМаршрутизаторСервер_уэ.ДобавитьГруппуСовместимостиИзСтроки(СтрокаСовместимости, load_types, ИспользуемыеГруппыСовместимости);
			Иначе
				// Заказ с пустыми группами совместимости должен быть совместим со всеми другими группами совместимости.
				// Для внешних маршрутизаторов Рарус VRP и Яндекс по умолчанию это именно так, ничего делать не требуется
			КонецЕсли;
			
			Структура_location.Вставить("load_types", load_types);
		КонецЕсли;
	КонецЕсли;

	СтоянкаПогрузка = ТекЗаказ.СтоянкаПунктОтправления;
	СтоянкаПогрузкаЧас = Цел(СтоянкаПогрузка);
	СтоянкаПогрузкаМин = (СтоянкаПогрузка - СтоянкаПогрузкаЧас) * 100;
	СтоянкаПогрузка = СтоянкаПогрузкаЧас * 3600 + СтоянкаПогрузкаМин * 60;
	Структура_location.Вставить("depot_duration_s", СтоянкаПогрузка);
	
	СтоянкаРазгрузка = ТекЗаказ.СтоянкаПунктНазначения;
	СтоянкаРазгрузкаЧас = Цел(СтоянкаРазгрузка);
	СтоянкаРазгрузкаМин = (СтоянкаРазгрузка - СтоянкаРазгрузкаЧас) * 100;
	СтоянкаРазгрузка = СтоянкаРазгрузкаЧас * 3600 + СтоянкаРазгрузкаМин * 60;
	Структура_location.Вставить("service_duration_s", СтоянкаРазгрузка);
	
	ДопСтоянкаРазгрузка = ТекЗаказ.ДопСтоянкаПунктНазначения;
	ДопСтоянкаРазгрузкаЧас = Цел(ДопСтоянкаРазгрузка);
	ДопСтоянкаРазгрузкаМин = (ДопСтоянкаРазгрузка - ДопСтоянкаРазгрузкаЧас) * 100;
	ДопСтоянкаРазгрузка = ДопСтоянкаРазгрузкаЧас * 3600 + ДопСтоянкаРазгрузкаМин * 60;
	Структура_location.Вставить("shared_service_duration_s", ДопСтоянкаРазгрузка);
	
	Структура_location.Вставить("sequence_order", ТекЗаказ.Приоритет); 
	
	Если ЗначениеЗаполнено(ТекЗаказ.Ссылка) Тогда
		Структура_location.Вставить("description",  Строка(ТекЗаказ.АдресНазначения));
		
		Если ЗначениеЗаполнено(ТекЗаказ.Ссылка.Грузополучатель) Тогда
			Структура_location.Вставить("title", "Грузополучатель: " + ТекЗаказ.Ссылка.Грузополучатель); 
		ИначеЕсли ЗначениеЗаполнено(ТекЗаказ.Ссылка.Контрагент) Тогда 
			Структура_location.Вставить("title", "Контрагент: " + ТекЗаказ.Ссылка.Контрагент);
		КонецЕсли;
	Конецесли;

	Структура_location.Вставить("ref",      Строка(ТекЗаказ.GUID));
	Если ЗначениеЗаполнено(ТекЗаказ.Ссылка) Тогда
		Структура_location.Вставить("comments", ТекЗаказ.Ссылка.КомментарийВодителю);
	КонецЕсли;
	Структура_location.Вставить("id",  уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(ТекЗаказ.АдресНазначения, СчДобавленныхОбъектов));
	
	Строкаlocation = Таблицаlocation.Добавить();
	ЗаполнитьЗначенияСвойств(Строкаlocation, ТекЗаказ);
	Строкаlocation.id = Структура_location.id;
	
	Возврат Структура_location;

КонецФункции

Функция ЗаполнитьПунктыДоставки(Массив_locations, СтруктураНастроекАРМ, НастройкиМаршрутизации, СчДобавленныхОбъектов, РежимОптимизации = Ложь)
	
	ИдентификаторыПунктовВыдачи = Новый Массив();
	
	Для Каждого ТекСтрока Из НастройкиМаршрутизации.ТаблицаПунктыВыдачи Цикл 
		
		Структура_location = Новый Структура();
		
		Пункт = Справочники.уатПунктыНазначения.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекСтрока));
	
		ВремяДоступностиС  = Пункт.ВремяДоступностиС;
		ВремяДоступностиПо = Пункт.ВремяДоступностиПо;
		Если ЗначениеЗаполнено(ВремяДоступностиС)
			ИЛИ ЗначениеЗаполнено(ВремяДоступностиПо) Тогда
			Структура_location.Вставить("time_window", "0." + Формат(ВремяДоступностиС, "ДФ=ЧЧ:мм:сс; ДП=") + "-0." + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс"));
		Иначе
			Структура_location.Вставить(
			"time_window", 
			"0.00:00:00-0.23:59:59");
		КонецЕсли;
		
		Структура_location.Вставить("hard_window", СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации);

		ДопСтоянка    = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяСтоянкиВПункте(Пункт, Неопределено);
		ДопСтоянкаЧас = Цел(ДопСтоянка);
		ДопСтоянкаМин = (ДопСтоянка - ДопСтоянкаЧас) * 100;
		ДопСтоянка = ДопСтоянкаЧас * 3600 + ДопСтоянкаМин * 60;
		Структура_location.Вставить("shared_service_duration_s", ДопСтоянка);

		Структура_location.Вставить("point", Новый Структура("lat, lon", Пункт.Лат, Пункт.Лон));
		
		ЕстьШтрафы = Ложь;
		СтруктураШтрафов = Новый Структура();
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
			out_of_time = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed) Тогда
				out_of_time.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_outOfTime_fixed);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_outOfTime_minute) Тогда
				out_of_time.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_outOfTime_minute);
			КонецЕсли;
			СтруктураШтрафов.Вставить("out_of_time", out_of_time);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
			early = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_fixed) Тогда
				early.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_early_fixed);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_early_minute) Тогда
				early.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_early_minute);
			КонецЕсли;
			СтруктураШтрафов.Вставить("early", early);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed)
			ИЛИ ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
			late = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_fixed) Тогда
				late.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_late_fixed);
			КонецЕсли;
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_late_minute) Тогда
				late.Вставить("minute", НастройкиМаршрутизации.locationsPenalty_late_minute);
			КонецЕсли;
			СтруктураШтрафов.Вставить("late", late);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
			drop = Новый Структура();
			Если ЗначениеЗаполнено(НастройкиМаршрутизации.locationsPenalty_drop) Тогда
				drop.Вставить("fixed", НастройкиМаршрутизации.locationsPenalty_drop);
			КонецЕсли;
			СтруктураШтрафов.Вставить("drop", НастройкиМаршрутизации.locationsPenalty_drop);
			ЕстьШтрафы = Истина;
		КонецЕсли;
		
		Если ЕстьШтрафы Тогда
			Структура_location.Вставить("penalty", СтруктураШтрафов);
		КонецЕсли;
			
		Структура_location.Вставить("required_tags", Новый Массив());
		
		Структура_location.Вставить("ref",   Пункт.Наименование);
		Структура_location.Вставить("id",    уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(Пункт, СчДобавленныхОбъектов));
		
		ИдентификаторыПунктовВыдачи.Добавить(Структура_location.id);

		СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
		
		Структура_location.Вставить("type",  "drop_off");
		Массив_locations.Добавить(Структура_location);
	КонецЦикла;
	
	Возврат ИдентификаторыПунктовВыдачи;
	
КонецФункции

Процедура ДобавитьВыездИзГаража(НастройкаВыездИзГаража, Объект, СтруктураНастроекАРМ, Массив_locations, Структура_vehicle, СчДобавленныхОбъектов)
	Если ТипЗнч(Объект) = Тип("СправочникСсылка.уатТС") Тогда
		Пункт = Объект.Гараж;
	Иначе
		Пункт = Объект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Пункт)
		И НастройкаВыездИзГаража Тогда

		Структура_locationГараж = Новый Структура("point, ref, id, type, time_window");
		
		ВремяДоступностиС  = Пункт.ВремяДоступностиС;
		ВремяДоступностиПо = Пункт.ВремяДоступностиПо;
		Если ЗначениеЗаполнено(ВремяДоступностиС)
			ИЛИ ЗначениеЗаполнено(ВремяДоступностиПо) Тогда
			Если НЕ ЗначениеЗаполнено(ВремяДоступностиС) Тогда
				Структура_locationГараж.time_window  = "0.00:00:00-0." + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			ИначеЕсли НЕ ЗначениеЗаполнено(ВремяДоступностиПо) Тогда
				Структура_locationГараж.time_window  = "0." + Формат(ВремяДоступностиС, "ДФ=ЧЧ:мм:сс") + "-0.23:59:59" + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			Иначе
				Структура_locationГараж.time_window  = "0." + Формат(ВремяДоступностиС, "ДФ=ЧЧ:мм:сс") + "-0." + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			КонецЕсли;
		Иначе
			Структура_locationГараж.time_window               = "0.00:00:00-0.23:59:59";
		КонецЕсли;
		Структура_locationГараж.Вставить("hard_window",  СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации);
		
		Структура_locationГараж.point                     = Новый Структура("lat, lon", Пункт.Лат, Пункт.Лон);
		Структура_locationГараж.ref                       = Пункт.Наименование + " #Гараж#" + Строка(Пункт.УникальныйИдентификатор());
		Структура_locationГараж.id                        = уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(Пункт, СчДобавленныхОбъектов);
		Структура_locationГараж.type                      = "garage";
		
		ДопСтоянка    = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяСтоянкиВПункте(Пункт, Неопределено);
		ДопСтоянкаЧас = Цел(ДопСтоянка);
		ДопСтоянкаМин = (ДопСтоянка - ДопСтоянкаЧас) * 100;
		ДопСтоянка = ДопСтоянкаЧас * 3600 + ДопСтоянкаМин * 60;
		Структура_locationГараж.Вставить("shared_service_duration_s", ДопСтоянка);

		Структура_vehicle.Вставить("start_at", Структура_locationГараж.id);
		Массив_locations.Добавить(Структура_locationГараж);
		
		СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
		
	Иначе
		Структура_vehicle.Вставить("visit_depot_at_start", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьЗаездВГараж(НастройкаВозвратВГараж, Объект, СтруктураНастроекАРМ, Массив_locations, Структура_vehicle, СчДобавленныхОбъектов, РежимОптимизации = Ложь)
	Если ТипЗнч(Объект) = Тип("СправочникСсылка.уатТС") Тогда
		Пункт = Объект.Гараж;
	Иначе
		Пункт = Объект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Пункт)
		И НастройкаВозвратВГараж Тогда
		
		Структура_locationГараж = Новый Структура("point, ref, id, type, time_window");
		
		ВремяДоступностиС  = Пункт.ВремяДоступностиС;
		ВремяДоступностиПо = Пункт.ВремяДоступностиПо;
		Если ЗначениеЗаполнено(ВремяДоступностиС)
			ИЛИ ЗначениеЗаполнено(ВремяДоступностиПо) Тогда
			Если НЕ ЗначениеЗаполнено(ВремяДоступностиС) Тогда
				Структура_locationГараж.time_window  = "0.00:00:00-0." + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			ИначеЕсли НЕ ЗначениеЗаполнено(ВремяДоступностиПо) Тогда
				Структура_locationГараж.time_window  = "0." + Формат(ВремяДоступностиС, "ДФ=ЧЧ:мм:сс") + "-0.23:59:59" + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			Иначе
				Структура_locationГараж.time_window  = "0." + Формат(ВремяДоступностиС, "ДФ=ЧЧ:мм:сс") + "-0." + Формат(ВремяДоступностиПо, "ДФ=ЧЧ:мм:сс");
			КонецЕсли;
		Иначе
			Структура_locationГараж.time_window     = "0.00:00:00-0.23:59:59";
		КонецЕсли; 
		УчитыватьОкнаПоЗаказам = ?(РежимОптимизации, СтруктураНастроекАРМ.Оптимизация_НастройкаУчитыватьОкнаПоЗаказам, СтруктураНастроекАРМ.НастройкаУчитыватьОкнаПоЗаказамПриМаршрутизации);
		
		Структура_locationГараж.Вставить("hard_window",  УчитыватьОкнаПоЗаказам);
		Структура_locationГараж.point                     = Новый Структура("lat, lon", Пункт.Лат, Пункт.Лон);
		Структура_locationГараж.ref                       = Пункт.Наименование + " #Гараж#" + Строка(Пункт.УникальныйИдентификатор());
		Структура_locationГараж.id                        = уатВнешнийМаршрутизаторСервер_уэ.СформироватьИдентификаторОбъекта(Пункт, СчДобавленныхОбъектов);
		Структура_locationГараж.type                      = "garage";
		
		ДопСтоянка    = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяСтоянкиВПункте(Пункт, Неопределено);
		ДопСтоянкаЧас = Цел(ДопСтоянка);
		ДопСтоянкаМин = (ДопСтоянка - ДопСтоянкаЧас) * 100;
		ДопСтоянка = ДопСтоянкаЧас * 3600 + ДопСтоянкаМин * 60;
		Структура_locationГараж.Вставить("shared_service_duration_s", ДопСтоянка);
		
		Структура_vehicle.Вставить("finish_at", Структура_locationГараж.id);
		Массив_locations.Добавить(Структура_locationГараж);
		
		СчДобавленныхОбъектов = СчДобавленныхОбъектов + 1;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#КонецОбласти

