					КонецЕсли;
				КонецЦикла;
				
				Если ИндВставкиПогрузки = Неопределено Тогда 
					// проверить, возможно, тут надо указывать ненулевые время/расстояние
					ПредПул.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
						ДанныеЗаказа.Ссылка, ДанныеЗаказа.ПунктПогрузки, ДанныеЗаказа.АдресОтправления, ДанныеЗаказа.ЛатОтпр, ДанныеЗаказа.ЛонОтпр, уатТипыТочекМаршрута_Погрузка, 0, 0, 0));
				Иначе 
					// проверить, возможно, тут надо указывать ненулевые время/расстояние
					ПредПул.Вставить(ИндВставкиПогрузки+1, Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
						ДанныеЗаказа.Ссылка, ДанныеЗаказа.ПунктПогрузки, ДанныеЗаказа.АдресОтправления, ДанныеЗаказа.ЛатОтпр, ДанныеЗаказа.ЛонОтпр, уатТипыТочекМаршрута_Погрузка, 0, 0, 0));
				КонецЕсли;
				// проверить, возможно, тут надо указывать ненулевые время/расстояние
				ПредПул.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
					ДанныеЗаказа.Ссылка, ДанныеЗаказа.ПунктРазгрузки, ДанныеЗаказа.АдресНазначения, ДанныеЗаказа.ЛатНазн, ДанныеЗаказа.ЛонНазн, уатТипыТочекМаршрута_Разгрузка, 0, 0, 0));
				
				Для ИндЭлемент = 0 По ПредПул.Количество()-1 Цикл 
					Для ИндРазмещения = 0 По ПредПул.Количество()-1 Цикл 
						Если ИндЭлемент > 0 И ИндЭлемент = ИндРазмещения Тогда 
							Продолжить;
						КонецЕсли;
						
						НовПул = Новый Массив();
						
						Для Каждого ТекЭлемент Из ПредПул Цикл 
							НовПул.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
								ТекЭлемент.заказ, ТекЭлемент.пункт, ТекЭлемент.Адрес, ТекЭлемент.Лат, ТекЭлемент.Лон, ТекЭлемент.Операция, ТекЭлемент.Ожидание, ТекЭлемент.Время, ТекЭлемент.Расстояние));
						КонецЦикла;
						
						ДанныеЭлемента = НовПул[ИндЭлемент];
						НовПул.Удалить(ИндЭлемент);
						НовПул.Вставить(ИндРазмещения, ДанныеЭлемента);
						
						ИдентификаторПеремещенногоГруза = ДанныеЭлемента.Заказ;
						
						НовПулКоличество = НовПул.Количество();
						
						Если НовПул[НовПулКоличество-1].операция = уатТипыТочекМаршрута_Погрузка Тогда 
							Продолжить;
						КонецЕсли;
						
						флПулКорректен = Истина;
						
						Для СчПроверка1 = 0 По НовПулКоличество-2 Цикл 
							флПроверен = Ложь;
							
							Если ТабЗаказы.Найти(НовПул[СчПроверка1].заказ, "Ссылка").FTL 
									И Не (НовПул[СчПроверка1].заказ = НовПул[СчПроверка1+1].заказ
									И НовПул[СчПроверка1].операция = уатТипыТочекМаршрута_Погрузка
									И НовПул[СчПроверка1+1].операция = уатТипыТочекМаршрута_Разгрузка) Тогда 
								флПулКорректен = Ложь;
								Прервать;
								
							ИначеЕсли НовПул[СчПроверка1].Операция = уатТипыТочекМаршрута_Погрузка
								И НовПул[СчПроверка1].Заказ = ИдентификаторПеремещенногоГруза Тогда 
								Для СчПроверка2 = СчПроверка1+1 По НовПулКоличество-1 Цикл 
									Если НовПул[СчПроверка2].Заказ = ИдентификаторПеремещенногоГруза И НовПул[СчПроверка2].Операция = уатТипыТочекМаршрута_Разгрузка Тогда 
										флПроверен = Истина;
										Прервать;
									КонецЕсли;
								КонецЦикла;
								
							Иначе 
								Продолжить;
							КонецЕсли;
							
							Если Не флПроверен Тогда 
								флПулКорректен = Ложь;
								Прервать;
							КонецЕсли;
						КонецЦикла;
						
						Если Не флПулКорректен Тогда 
							Продолжить;
						КонецЕсли;
						
						Встав = Истина;
						ОбщВремя = 0;
						ОбщРасстояние = 0;
						ПредПосещенныйПункт = Неопределено;
						
						ВремяВыездаНаМаршрут = ВремяВыезда - НачалоДня(ВремяВыезда);
						Если РежимВремениВыездаИзГаража = 0 И НовПулКоличество Тогда 
							// Время следования от гаража до первого пункта.
							ПунктСтарт = ТекПул.Гараж;
							ПунктФиниш = НовПул[0].пункт;
							АдресСтарт = ТекПул.АдресГаража;
							АдресФиниш = НовПул[0].Адрес;
							
							ВремяДоПервогоПункта = 0;
							мРасстояние = 0;
							
							Если ПунктСтарт = ПунктФиниш Тогда 
								Если Не АдресСтарт = АдресФиниш Тогда 
									ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(ТекПул.ШиротаГаража, ТекПул.ДолготаГаража, НовПул[0].Лат, НовПул[0].Лон);
									ВремяДоПервогоПункта = ДанныеПоКластеру.Время;
									мРасстояние = ДанныеПоКластеру.Расстояние;
								КонецЕсли;
								
							Иначе 
								Узел1 = СоотвТаблРасстояний.Получить(ПунктСтарт);
								Если Не Узел1 = Неопределено Тогда 
									Узел2 = Узел1.Получить(ПунктФиниш);
									Если Не Узел2 = Неопределено Тогда 
										ВремяДоПервогоПункта = Узел2.Время;
										мРасстояние          = Узел2.Расстояние;
									КонецЕсли;
								КонецЕсли;
							КонецЕсли;
							
							СтрокаЗаказа = ТабЗаказы.Найти(НовПул[0].заказ, "Ссылка");
							Если Не СтрокаЗаказа = Неопределено Тогда 
								ВремяВыездаНаМаршрут = СтрокаЗаказа.ОтправлениеС - '00010101';
								
								ВремяДоПервогоПункта = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяВПутиВСекундахСУчетомСреднейСкорости(
									мРасстояние, ВремяДоПервогоПункта, ВремяВыездаНаМаршрут, ТабСкоростей);
								
								ВремяВыездаНаМаршрут = ВремяВыездаНаМаршрут - ВремяДоПервогоПункта;
							КонецЕсли;
						КонецЕсли;
						
						МаксимальныйВес   = 0;
						МаксимальныйОбъем = 0;
						ВсегоУпаковок     = 0;
						
						ТекВес      = 0;
						ТекОбъем    = 0;
						ТекУпаковок = 0;
						
						Для СчОбх = -1 По НовПулКоличество-1 Цикл
							ДопЗадержка = 0;
							
							Если СчОбх = -1 Тогда 
								ПунктСтарт = ТекПул.Гараж;
								АдресСтарт = ТекПул.АдресГаража;
								ЛатСтарт   = ТекПул.ШиротаГаража;
								ЛонСтарт   = ТекПул.ДолготаГаража;
							Иначе 
								ПунктСтарт = НовПул[СчОбх].пункт;
								АдресСтарт = НовПул[СчОбх].Адрес;
								ЛатСтарт   = НовПул[СчОбх].Лат;
								ЛонСтарт   = НовПул[СчОбх].Лон;
							КонецЕсли;
							
							Если СчОбх = НовПулКоличество-1 Тогда 
								Если Не ТекПул.ВозвратВГараж Тогда 
									Продолжить;
								КонецЕсли;
								ПунктФиниш = ТекПул.Гараж;
								АдресФиниш = ТекПул.АдресГаража;
								ЛатФиниш   = ТекПул.ШиротаГаража;
								ЛонФиниш   = ТекПул.ДолготаГаража;
							Иначе 
								ПунктФиниш = НовПул[СчОбх+1].пункт;
								АдресФиниш = НовПул[СчОбх+1].Адрес;
								ЛатФиниш   = НовПул[СчОбх+1].Лат;
								ЛонФиниш   = НовПул[СчОбх+1].Лон;
							КонецЕсли;
							
							Если ПунктСтарт = ПунктФиниш Тогда 
								Если АдресСтарт = АдресФиниш Тогда 
									мВремя = 0;
									мРасстояние = 0;
								Иначе 
									ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(ЛатСтарт, ЛонСтарт, ЛатФиниш, ЛонФиниш);
									мВремя = ДанныеПоКластеру.Время;
									мРасстояние = ДанныеПоКластеру.Расстояние;
								КонецЕсли;
								
							Иначе 
								Узел1 = СоотвТаблРасстояний.Получить(ПунктСтарт);
								Если Узел1 = Неопределено Тогда 
									Встав = Ложь;
									Прервать;
								КонецЕсли;
								Узел2 = Узел1.Получить(ПунктФиниш);
								Если Узел2 = Неопределено Тогда 
									Встав = Ложь;
									Прервать;
								КонецЕсли;
								мВремя      = Узел2.Время;
								мРасстояние = Узел2.Расстояние;
							КонецЕсли;
							
							ВремяВТочке = ВремяВыездаНаМаршрут + ОбщВремя;
							
							мВремя = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяВПутиВСекундахСУчетомСреднейСкорости(мРасстояние,
								мВремя * 3600, ВремяВТочке, ТабСкоростей);
							
							ВремяВТочке = ВремяВТочке + мВремя;
							
							Если Не СчОбх = НовПулКоличество-1 Тогда 
								СтрокаЗаказа = ТабЗаказы.Найти(НовПул[СчОбх+1].заказ, "Ссылка");
								Если Не СтрокаЗаказа = Неопределено Тогда 
									Если НовПул[СчОбх+1].Операция = уатТипыТочекМаршрута_Погрузка Тогда 
										ОжиданиеПосещения = 0;
										Если УчитыватьОкнаПоЗаказам И Не уатЗащищенныеФункцииСервер_уэ.ВремяПосещенияВСекундахВПределахОкна(
											ВремяВТочке, СтрокаЗаказа.ОтправлениеС, СтрокаЗаказа.ОтправлениеПо, ОжиданиеПосещения) Тогда 
											Встав = Ложь;
											Прервать;
										КонецЕсли;
										
										Если ОжиданиеПосещения > 0 И ПредПосещенныйПункт = СтрокаЗаказа.АдресОтправления Тогда 
											Встав = Ложь;
											Прервать;
										КонецЕсли;
										
										НовПул[СчОбх+1].Ожидание = ОжиданиеПосещения;
										НовПул[СчОбх+1].Время = мВремя;
										НовПул[СчОбх+1].Расстояние = мРасстояние;
										
										Если ОжиданиеПосещения > 0 Тогда 
											ВремяВТочке = ВремяВТочке + ОжиданиеПосещения;
											мВремя = мВремя + ОжиданиеПосещения;
										КонецЕсли;
										
										Если Не ПредПосещенныйПункт = СтрокаЗаказа.АдресОтправления Тогда 
											мВремя = мВремя + СтрокаЗаказа.ДопСтоянкаПунктОтправления;
											ВремяВТочке = ВремяВТочке + СтрокаЗаказа.ДопСтоянкаПунктОтправления;
										КонецЕсли;
										
										мВремя = мВремя + СтрокаЗаказа.СтоянкаПунктОтправления;
										ВремяВТочке = ВремяВТочке + СтрокаЗаказа.СтоянкаПунктОтправления;
										
										ПредПосещенныйПункт = СтрокаЗаказа.АдресОтправления;
										
										ТекВес      = ТекВес + СтрокаЗаказа.ВесБрутто;
										ТекОбъем    = ТекОбъем + СтрокаЗаказа.Объем;
										ТекУпаковок = ТекУпаковок + СтрокаЗаказа.КоличествоУпаковок;
										
									Иначе 
										ОжиданиеПосещения = 0;
										Если УчитыватьОкнаПоЗаказам И Не уатЗащищенныеФункцииСервер_уэ.ВремяПосещенияВСекундахВПределахОкна(
											ВремяВТочке, СтрокаЗаказа.ДоставкаС, СтрокаЗаказа.ДоставкаПо, ОжиданиеПосещения) Тогда 
											Встав = Ложь;
											Прервать;
										КонецЕсли;
										
										Если ОжиданиеПосещения > 0 И ПредПосещенныйПункт = СтрокаЗаказа.АдресНазначения Тогда 
											Встав = Ложь;
											Прервать;
										КонецЕсли;
										
										НовПул[СчОбх+1].Ожидание = ОжиданиеПосещения;
										НовПул[СчОбх+1].Время = мВремя;
										НовПул[СчОбх+1].Расстояние = мРасстояние;
										
										Если ОжиданиеПосещения > 0 Тогда 
											ВремяВТочке = ВремяВТочке + ОжиданиеПосещения;
											мВремя = мВремя + ОжиданиеПосещения;
										КонецЕсли;
										
										Если Не ПредПосещенныйПункт = СтрокаЗаказа.АдресНазначения Тогда 
											мВремя = мВремя + СтрокаЗаказа.ДопСтоянкаПунктНазначения;
											ВремяВТочке = ВремяВТочке + СтрокаЗаказа.ДопСтоянкаПунктНазначения;
										КонецЕсли;
										
										мВремя = мВремя + СтрокаЗаказа.СтоянкаПунктНазначения;
										ВремяВТочке = ВремяВТочке + СтрокаЗаказа.СтоянкаПунктНазначения;
										
										ПредПосещенныйПункт = СтрокаЗаказа.АдресНазначения;
										
										ТекВес      = ТекВес - СтрокаЗаказа.ВесБрутто;
										ТекОбъем    = ТекОбъем - СтрокаЗаказа.Объем;
										ТекУпаковок = ТекУпаковок - СтрокаЗаказа.КоличествоУпаковок;
									КонецЕсли;
									
									МаксимальныйВес   = Макс(МаксимальныйВес, ТекВес);
									МаксимальныйОбъем = Макс(МаксимальныйОбъем, ТекОбъем);
									ВсегоУпаковок     = Макс(ВсегоУпаковок, ТекУпаковок);
								КонецЕсли;
							КонецЕсли;
							
							ОбщВремя      = ОбщВремя + мВремя;
							ОбщРасстояние = ОбщРасстояние + мРасстояние;
						КонецЦикла;
						
						Если Не Встав Тогда 
							Продолжить;
						КонецЕсли;
						
						ТекОценка = ?(РежимОптимизации = 0, ОбщВремя, ОбщРасстояние);
						
						Если Не ОграничениеЧасов = 0 И ОбщВремя > ОграничениеЧасов * 3600 Тогда 
							Встав = Ложь;
							Продолжить;
						КонецЕсли;
						
						Если Не ОграничениеПоРасстоянию = 0 И ОбщРасстояние > ОграничениеПоРасстоянию Тогда 
							Встав = Ложь;
							Продолжить;
						КонецЕсли;
						
						Если Не МаксимальноеЧислоПунктов = 0 Тогда 
							мсвПунктыМаршрута = Новый Массив();
							мсвПунктыМаршрута.Добавить(ТекПул.АдресГаража);
							
							Для Каждого ТекЭлМаршрута Из НовПул Цикл 
								СтрокаТабЗаказы = ТабЗаказы.Найти(ТекЭлМаршрута.заказ, "Ссылка");
								Если Не СтрокаТабЗаказы = Неопределено Тогда 
									Если ТекЭлМаршрута.Операция = уатТипыТочекМаршрута_Погрузка Тогда 
										ТекАдресЗаказа = СтрокаТабЗаказы.АдресОтправления;
									Иначе 
										ТекАдресЗаказа = СтрокаТабЗаказы.АдресНазначения;
									КонецЕсли;
									
									Если Не мсвПунктыМаршрута[мсвПунктыМаршрута.Количество()-1] = ТекАдресЗаказа Тогда 
										мсвПунктыМаршрута.Добавить(ТекАдресЗаказа);
									КонецЕсли;
								КонецЕсли;
							КонецЦикла;
							
							Если ТекПул.ВозвратВГараж Тогда 
								Если Не мсвПунктыМаршрута[мсвПунктыМаршрута.Количество()-1] = ТекПул.АдресГаража Тогда 
									мсвПунктыМаршрута.Добавить(ТекПул.АдресГаража);
								КонецЕсли;
							КонецЕсли;
							
							Если мсвПунктыМаршрута.Количество() > МаксимальноеЧислоПунктов Тогда 
								Встав = Ложь;
								Продолжить;
							КонецЕсли;
						КонецЕсли;
						
						Если (ТекПул.ГрузоподъемностьТС <> 0 И ТекПул.ГрузоподъемностьТС < МаксимальныйВес)
								Или (ТекПул.ОбъемКузоваТС <> 0 И ТекПул.ОбъемКузоваТС < МаксимальныйОбъем) 
								Или (ТекПул.МаксимальноеКоличествоУпаковок <> 0 И ТекПул.МаксимальноеКоличествоУпаковок < ВсегоУпаковок) Тогда
							
							ТабПодходящихТС = Новый ТаблицаЗначений();
							ТабПодходящихТС.Колонки.Добавить("Ссылка",    Новый ОписаниеТипов("СправочникСсылка.уатТС"));
							ТабПодходящихТС.Колонки.Добавить("Приоритет", Новый ОписаниеТипов("Число"));
							ТабПодходящихТС.Колонки.Добавить("Порядок",   Новый ОписаниеТипов("Число"));
							
							Для Каждого ТекТС Из ТабТС Цикл 
								Если (ТекТС.Грузоподъемность <> 0 И ТекТС.Грузоподъемность < МаксимальныйВес)
										Или (ТекТС.ОбъемКузова <> 0 И ТекТС.ОбъемКузова < МаксимальныйОбъем) 
										Или (ТекТС.МаксимальноеКоличествоУпаковок <> 0 И ТекТС.МаксимальноеКоличествоУпаковок < ВсегоУпаковок) Тогда 
									Продолжить;
								КонецЕсли;
								
								Если УчитыватьРазрешенныеТипыТС Тогда 
									флТСдоступенПоТипам = Истина;
									Для Каждого ТекЭлПула Из НовПул Цикл 
										Если Не ТекЭлПула.Операция = уатТипыТочекМаршрута_Погрузка Тогда 
											Продолжить;
										КонецЕсли;
										
										мсвРазрешенныеТС = СоотРазрешенныеТСПоЗаказам.Получить(ТекЭлПула.заказ);
										Если Не мсвРазрешенныеТС = Неопределено И мсвРазрешенныеТС.Найти(ТекТС.Ссылка) = Неопределено Тогда 
											флТСдоступенПоТипам = Ложь;
											Прервать;
										КонецЕсли;
									КонецЦикла;
									
									Если Не флТСдоступенПоТипам Тогда 
										Продолжить;
									КонецЕсли;
								КонецЕсли;
								
								флРазрешеноПоХарактеристикам = Истина;
								
								Если ИспользоватьХарактеристикиЗаказовНаТС Тогда 
									Для Каждого ТекЭлПула Из НовПул Цикл 
										Если Не ТекЭлПула.Операция = уатТипыТочекМаршрута_Погрузка Тогда 
											Продолжить;
										КонецЕсли;
										
										ТекСтрокаЗаказ = ТабЗаказы.Найти(ТекЭлПула.заказ, "Ссылка");
										мсвРазрешенныеТС = СоотРазрешенныеТСПоХарактеристикам.Получить(ТекСтрокаЗаказ.НаборХарактеристик);
										Если Не мсвРазрешенныеТС = Неопределено И мсвРазрешенныеТС.Найти(ТекТС.Ссылка) = Неопределено Тогда 
											флРазрешеноПоХарактеристикам = Ложь;
											Прервать;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
								
								Если Не флРазрешеноПоХарактеристикам Тогда 
									Продолжить;
								КонецЕсли;
								
								текВремя = 0;
								текРасстояние = 0;
								
								Если ТекТС.Гараж = НовПул[0].пункт Тогда 
									Если Не ТекТС.АдресГаража = НовПул[0].Адрес Тогда 
										ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(ТекТС.ШиротаГаража, ТекТС.ДолготаГаража, НовПул[0].Лат, НовПул[0].Лон);
										текВремя = ДанныеПоКластеру.Время;
										текРасстояние = ДанныеПоКластеру.Расстояние;
									КонецЕсли;
									
								Иначе 
									Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
									Если Узел1 = Неопределено Тогда 
										Продолжить;
									КонецЕсли;
									Узел2 = Узел1.Получить(НовПул[0].пункт);
									Если Узел2 = Неопределено Тогда 
										Продолжить;
									КонецЕсли;
									текВремя = Узел2.Время;
									текРасстояние = Узел2.Расстояние;
								КонецЕсли;
								
								НовПодходящееТС = ТабПодходящихТС.Добавить();
								НовПодходящееТС.Ссылка    = ТекТС.Ссылка;
								НовПодходящееТС.Приоритет = ТекТС.Приоритет;
								НовПодходящееТС.Порядок   = ?(РежимОптимизации = 0, текВремя, текРасстояние);
							КонецЦикла;
							
							Если ТабПодходящихТС.Количество() = 0 Тогда 
								Встав = Ложь;
								Продолжить;
							КонецЕсли;
							
							ТабПодходящихТС.Сортировать("Приоритет Убыв, Порядок Возр");
							
							НовТС = ТабПодходящихТС[0].Ссылка;
						Иначе 
							НовТС = Неопределено;
						КонецЕсли;
						
						Если Встав Тогда 
							НовСтрокаОценки = ТабОценок.Добавить();
							НовСтрокаОценки.Значение = Новый Структура("Пул,НовПул,НовОценка,НовТС,ВремяВыездаНаМаршрут,МаксимальныйВес,МаксимальныйОбъем,ВсегоУпаковок",
								ТекПул,
								НовПул,
								ТекОценка,
								НовТС,
								ВремяВыездаНаМаршрут,
								МаксимальныйВес,
								МаксимальныйОбъем,
								ВсегоУпаковок
							);
							НовСтрокаОценки.Оценка = ТекОценка-ТекПул.оценка;
							НовСтрокаОценки.Приоритет = ДанныеЗаказа.Приоритет;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			
			Если ТабТС.Количество() Тогда 
				МаксимальныйВес   = ДанныеЗаказа.ВесБрутто;
				МаксимальныйОбъем = ДанныеЗаказа.Объем;
				ВсегоУпаковок     = ДанныеЗаказа.КоличествоУпаковок;
				
				СтрокаТС = Неопределено;
				
				ТабПодходящихТС = Новый ТаблицаЗначений();
				ТабПодходящихТС.Колонки.Добавить("Ссылка",    Новый ОписаниеТипов("СправочникСсылка.уатТС"));
				ТабПодходящихТС.Колонки.Добавить("Приоритет", Новый ОписаниеТипов("Число"));
				ТабПодходящихТС.Колонки.Добавить("Порядок",   Новый ОписаниеТипов("Число"));
				
				мсвРазрешенныеТС = Неопределено;
				Если УчитыватьРазрешенныеТипыТС Тогда 
					мсвРазрешенныеТС = СоотРазрешенныеТСПоЗаказам.Получить(ДанныеЗаказа.Ссылка);
				КонецЕсли;
				
				мсвРазрешенныеТСПоХарактеристикам = Неопределено;
				Если ИспользоватьХарактеристикиЗаказовНаТС Тогда 
					мсвРазрешенныеТСПоХарактеристикам = СоотРазрешенныеТСПоХарактеристикам.Получить(ДанныеЗаказа.НаборХарактеристик);
				КонецЕсли;
				
				Для Каждого ТекТС Из ТабТС Цикл 
					Если (ТекТС.Грузоподъемность <> 0 И ТекТС.Грузоподъемность < МаксимальныйВес)
							Или (ТекТС.ОбъемКузова <> 0 И ТекТС.ОбъемКузова < МаксимальныйОбъем) 
							Или (ТекТС.МаксимальноеКоличествоУпаковок <> 0 И ТекТС.МаксимальноеКоличествоУпаковок < ВсегоУпаковок) 
							Или (Не мсвРазрешенныеТС = Неопределено И мсвРазрешенныеТС.Найти(ТекТС.Ссылка) = Неопределено)
							Или (Не мсвРазрешенныеТСПоХарактеристикам = Неопределено И мсвРазрешенныеТСПоХарактеристикам.Найти(ТекТС.Ссылка) = Неопределено) Тогда 
						Продолжить;
					КонецЕсли;
					
					текВремя = 0;
					текРасстояние = 0;
					
					Если ТекТС.Гараж = ДанныеЗаказа.ПунктПогрузки Тогда 
						Если Не ТекТС.АдресГаража = ДанныеЗаказа.АдресОтправления Тогда 
							ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(ТекТС.ШиротаГаража, ТекТС.ДолготаГаража, ДанныеЗаказа.ЛатОтпр, ДанныеЗаказа.ЛонОтпр);
							текВремя = ДанныеПоКластеру.Время;
							текРасстояние = ДанныеПоКластеру.Расстояние;
						КонецЕсли;
						
					Иначе 
						Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
						Если Узел1 = Неопределено Тогда 
							Продолжить;
						КонецЕсли;
						Узел2 = Узел1.Получить(ДанныеЗаказа.ПунктПогрузки);
						Если Узел2 = Неопределено Тогда 
							Продолжить;
						КонецЕсли;
						текВремя = Узел2.Время;
						текРасстояние = Узел2.Расстояние;
					КонецЕсли;
					
					НовПодходящееТС = ТабПодходящихТС.Добавить();
					НовПодходящееТС.Ссылка    = ТекТС.Ссылка;
					НовПодходящееТС.Приоритет = ТекТС.Приоритет;
					НовПодходящееТС.Порядок = ?(РежимОптимизации = 0, текВремя, текРасстояние);
				КонецЦикла;
				
				Если Не ТабПодходящихТС.Количество() = 0 Тогда 
					ТабПодходящихТС.Сортировать("Приоритет Убыв, Порядок Возр");
					
					СтрокаТС = ТабТС.Найти(ТабПодходящихТС[0].Ссылка, "Ссылка");
					
					ОбщВремя = 0;
					ОбщРасстояние = 0;
					Встав = Истина;
					мсвПосещенныеПункты = Новый Массив();
					
					ВремяВыездаНаМаршрут = ВремяВыезда - НачалоДня(ВремяВыезда);
					Если РежимВремениВыездаИзГаража = 0 Тогда 
						// Время следования от гаража до первого пункта.
						ПунктСтарт = СтрокаТС.Гараж;
						ПунктФиниш = ДанныеЗаказа.ПунктПогрузки;
						АдресСтарт = СтрокаТС.АдресГаража;
						АдресФиниш = ДанныеЗаказа.АдресОтправления;
						
						ВремяДоПервогоПункта = 0;
						мРасстояние = 0;
						
						Если ПунктСтарт = ПунктФиниш Тогда 
							Если Не АдресСтарт = АдресФиниш Тогда 
								ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(СтрокаТС.ШиротаГаража, СтрокаТС.ДолготаГаража, ДанныеЗаказа.ЛатОтпр, ДанныеЗаказа.ЛонОтпр);
								ВремяДоПервогоПункта = ДанныеПоКластеру.Время;
								мРасстояние = ДанныеПоКластеру.Расстояние;
							КонецЕсли;
							
						Иначе 
							Узел1 = СоотвТаблРасстояний.Получить(ПунктСтарт);
							Если Не Узел1 = Неопределено Тогда 
								Узел2 = Узел1.Получить(ПунктФиниш);
								Если Не Узел2 = Неопределено Тогда 
									ВремяДоПервогоПункта = Узел2.Время;
									мРасстояние          = Узел2.Расстояние;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						
						ВремяВыездаНаМаршрут = ДанныеЗаказа.ОтправлениеС - '00010101';
						
						мВремя = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяВПутиВСекундахСУчетомСреднейСкорости(мРасстояние,
							ВремяДоПервогоПункта, ВремяВыездаНаМаршрут, ТабСкоростей);
						
						ВремяВыездаНаМаршрут = ВремяВыездаНаМаршрут - ВремяДоПервогоПункта;
					КонецЕсли;
					
					Для СчОбх = 0 По 2 Цикл
						Если СчОбх = 0 Тогда 
							ПунктСтарт = СтрокаТС.Гараж;
							ПунктФиниш = ДанныеЗаказа.ПунктПогрузки;
							АдресСтарт = СтрокаТС.АдресГаража;
							АдресФиниш = ДанныеЗаказа.АдресОтправления;
							ЛатСтарт   = СтрокаТС.ШиротаГаража;
							ЛонСтарт   = СтрокаТС.ДолготаГаража;
							ЛатФиниш   = ДанныеЗаказа.ЛатОтпр;
							ЛонФиниш   = ДанныеЗаказа.ЛонОтпр;
							
						ИначеЕсли СчОбх = 2 Тогда 
							Если Не СтрокаТС.ВозвратВГараж Тогда 
								Продолжить;
							КонецЕсли;
							ПунктСтарт = ДанныеЗаказа.ПунктРазгрузки;
							ПунктФиниш = СтрокаТС.Гараж;
							АдресСтарт = ДанныеЗаказа.АдресНазначения;
							АдресФиниш = СтрокаТС.АдресГаража;
							ЛатСтарт   = ДанныеЗаказа.ЛатНазн;
							ЛонСтарт   = ДанныеЗаказа.ЛонНазн;
							ЛатФиниш   = СтрокаТС.ШиротаГаража;
							ЛонФиниш   = СтрокаТС.ДолготаГаража;
							
						Иначе 
							ПунктСтарт = ДанныеЗаказа.ПунктПогрузки;
							ПунктФиниш = ДанныеЗаказа.ПунктРазгрузки;
							АдресСтарт = ДанныеЗаказа.АдресОтправления;
							АдресФиниш = ДанныеЗаказа.АдресНазначения;
							ЛатСтарт   = ДанныеЗаказа.ЛатОтпр;
							ЛонСтарт   = ДанныеЗаказа.ЛонОтпр;
							ЛатФиниш   = ДанныеЗаказа.ЛатНазн;
							ЛонФиниш   = ДанныеЗаказа.ЛонНазн;
						КонецЕсли;
						
						мВремя = 0;
						мРасстояние = 0;
						
						Если ПунктСтарт = ПунктФиниш Тогда 
							Если Не АдресСтарт = АдресФиниш Тогда 
								ДанныеПоКластеру = Обработки.уатАРМЛогиста_уэ.ВремяРасстояниеПоКоординатам(ЛатСтарт, ЛонСтарт, ЛатФиниш, ЛонФиниш);
								мВремя = ДанныеПоКластеру.Время;
								мРасстояние = ДанныеПоКластеру.Расстояние;
							КонецЕсли;
							
						Иначе 
							Узел1 = СоотвТаблРасстояний.Получить(ПунктСтарт);
							Если Узел1 = Неопределено Тогда 
								Встав = Ложь;
								Прервать;
							КонецЕсли;
							Узел2 = Узел1.Получить(ПунктФиниш);
							Если Узел2 = Неопределено Тогда 
								Встав = Ложь;
								Прервать;
							КонецЕсли;
							
							мВремя      = Узел2.Время;
							мРасстояние = Узел2.Расстояние;
						КонецЕсли;
						
						ВремяВТочке = ВремяВыездаНаМаршрут + ОбщВремя;
						
						мВремя = уатЗащищенныеФункцииСервер_уэ.ПолучитьВремяВПутиВСекундахСУчетомСреднейСкорости(мРасстояние,
							мВремя, ВремяВТочке, ТабСкоростей);
						
						ВремяВТочке = ВремяВТочке + мВремя;
						
						Если СчОбх = 0 Тогда 
							ВремяПунктПогрузки = мВремя;
							РасстояниеПунктПогрузки = мРасстояние;
							ОжиданиеПогрузки = 0;
							Если УчитыватьОкнаПоЗаказам И Не уатЗащищенныеФункцииСервер_уэ.ВремяПосещенияВСекундахВПределахОкна(
								ВремяВТочке, ДанныеЗаказа.ОтправлениеС, ДанныеЗаказа.ОтправлениеПо, ОжиданиеПогрузки) Тогда 
								Встав = Ложь;
								Прервать;
							КонецЕсли;
							
							Если ОжиданиеПогрузки > 0 Тогда 
								ВремяВТочке = ВремяВТочке + ОжиданиеПогрузки;
								мВремя = мВремя + ОжиданиеПогрузки;
							КонецЕсли;
							
							Если мсвПосещенныеПункты.Найти(ДанныеЗаказа.АдресОтправления) = Неопределено Тогда 
								мсвПосещенныеПункты.Добавить(ДанныеЗаказа.АдресОтправления);
								мВремя = мВремя + ДанныеЗаказа.ДопСтоянкаПунктОтправления;
								ВремяВТочке = ВремяВТочке + ДанныеЗаказа.ДопСтоянкаПунктОтправления;
							КонецЕсли;
							
							мВремя = мВремя + ДанныеЗаказа.СтоянкаПунктОтправления;
							ВремяВТочке = ВремяВТочке + ДанныеЗаказа.СтоянкаПунктОтправления;
							
						ИначеЕсли СчОбх = 1 Тогда
							ВремяПунктРазгрузки = мВремя;
							РасстояниеПунктРазгрузки = мРасстояние;
							ОжиданиеРазгрузки = 0;
							Если УчитыватьОкнаПоЗаказам И Не уатЗащищенныеФункцииСервер_уэ.ВремяПосещенияВСекундахВПределахОкна(
								ВремяВТочке, ДанныеЗаказа.ДоставкаС, ДанныеЗаказа.ДоставкаПо, ОжиданиеРазгрузки) Тогда 
								Встав = Ложь;
								Прервать;
							КонецЕсли;
							
							Если ОжиданиеРазгрузки > 0 Тогда 
								ВремяВТочке = ВремяВТочке + ОжиданиеРазгрузки;
								мВремя = мВремя + ОжиданиеРазгрузки;
							КонецЕсли;
							
							Если мсвПосещенныеПункты.Найти(ДанныеЗаказа.АдресНазначения) = Неопределено Тогда 
								мсвПосещенныеПункты.Добавить(ДанныеЗаказа.АдресНазначения);
								мВремя = мВремя + ДанныеЗаказа.ДопСтоянкаПунктНазначения;
								ВремяВТочке = ВремяВТочке + ДанныеЗаказа.ДопСтоянкаПунктНазначения;
							КонецЕсли;
							
							мВремя = мВремя + ДанныеЗаказа.СтоянкаПунктНазначения;
							ВремяВТочке = ВремяВТочке + ДанныеЗаказа.СтоянкаПунктНазначения;
						КонецЕсли;
						
						ОбщВремя      = ОбщВремя + мВремя;
						ОбщРасстояние = ОбщРасстояние + мРасстояние;
						
						Если ?(ОграничениеЧасов=0, Ложь, ОбщВремя > ОграничениеЧасов * 3600) Тогда 
							Встав = Ложь;
							Прервать;
						КонецЕсли;
						
						Если ?(ОграничениеПоРасстоянию=0, Ложь, ОбщРасстояние > ОграничениеПоРасстоянию) Тогда 
							Встав = Ложь;
							Прервать;
						КонецЕсли;
						
						Если Не Встав Тогда 
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если Не МаксимальноеЧислоПунктов = 0 Тогда 
						мсвПунктыМаршрута = Новый Массив();
						мсвПунктыМаршрута.Добавить(СтрокаТС.АдресГаража);
						
						ТекАдресЗаказа = ДанныеЗаказа.АдресОтправления;
						Если Не мсвПунктыМаршрута[мсвПунктыМаршрута.Количество()-1] = ТекАдресЗаказа Тогда 
							мсвПунктыМаршрута.Добавить(ТекАдресЗаказа);
						КонецЕсли;
						
						ТекАдресЗаказа = ДанныеЗаказа.АдресНазначения;
						Если Не мсвПунктыМаршрута[мсвПунктыМаршрута.Количество()-1] = ТекАдресЗаказа Тогда 
							мсвПунктыМаршрута.Добавить(ТекАдресЗаказа);
						КонецЕсли;
						
						Если СтрокаТС.ВозвратВГараж Тогда 
							Если Не мсвПунктыМаршрута[мсвПунктыМаршрута.Количество()-1] = СтрокаТС.АдресГаража Тогда 
								мсвПунктыМаршрута.Добавить(СтрокаТС.АдресГаража);
							КонецЕсли;
						КонецЕсли;
						
						Если мсвПунктыМаршрута.Количество() > МаксимальноеЧислоПунктов Тогда 
							Встав = Ложь;
							Продолжить;
						КонецЕсли;
					КонецЕсли;
					
					Если Встав Тогда 
						НовПул = Новый Массив();
						НовПул.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
							ДанныеЗаказа.Ссылка, ДанныеЗаказа.ПунктПогрузки, ДанныеЗаказа.АдресОтправления,
							ДанныеЗаказа.ЛатОтпр, ДанныеЗаказа.ЛонОтпр, уатТипыТочекМаршрута_Погрузка, ОжиданиеПогрузки, ВремяПунктПогрузки, РасстояниеПунктПогрузки));
						НовПул.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
							ДанныеЗаказа.Ссылка, ДанныеЗаказа.ПунктРазгрузки, ДанныеЗаказа.АдресНазначения,
							ДанныеЗаказа.ЛатНазн, ДанныеЗаказа.ЛонНазн, уатТипыТочекМаршрута_Разгрузка, ОжиданиеРазгрузки, ВремяПунктРазгрузки, РасстояниеПунктРазгрузки));
						
						НовСтрокаОценки = ТабОценок.Добавить();
						НовСтрокаОценки.Значение = Новый Структура("Пул,НовПул,НовОценка,НовТС,ВремяВыездаНаМаршрут,МаксимальныйВес,МаксимальныйОбъем,ВсегоУпаковок",
							Неопределено,
							НовПул,
							?(РежимОптимизации = 0, ОбщВремя, ОбщРасстояние),
							ТабПодходящихТС[0].Ссылка,
							ВремяВыездаНаМаршрут,
							МаксимальныйВес,
							МаксимальныйОбъем,
							ВсегоУпаковок
						);
						НовСтрокаОценки.Оценка = ?(РежимОптимизации = 0, ОбщВремя, ОбщРасстояние);
						НовСтрокаОценки.Приоритет = ДанныеЗаказа.Приоритет;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			ТабОценок.Сортировать("Оценка Возр, Приоритет Убыв");
			
			Для Каждого ТекВариант Из ТабОценок Цикл 
				Если ТекВариант.Значение.пул = Неопределено Тогда 
					СтрокаТС = ТабТС.Найти(ТекВариант.Значение.НовТС, "Ссылка");
					
					ДанныеПула = Новый Структура("ТС,ГрузоподъемностьТС,ОбъемКузоваТС,ПорядокТС,ВозвратВГараж,Гараж,АдресГаража,ШиротаГаража,ДолготаГаража,МаксимальноеКоличествоУпаковок,
						|оценка,маршрут,МаксимальныйВес,МаксимальныйОбъем,ВремяВыездаНаМаршрут,ПриоритетТС",
						СтрокаТС.Ссылка,
						СтрокаТС.Грузоподъемность,
						СтрокаТС.ОбъемКузова,
						СтрокаТС.Порядок,
						СтрокаТС.ВозвратВГараж,
						СтрокаТС.Гараж,
						СтрокаТС.АдресГаража,
						СтрокаТС.ШиротаГаража,
						СтрокаТС.ДолготаГаража,
						СтрокаТС.МаксимальноеКоличествоУпаковок,
						ТекВариант.Значение.НовОценка,
						Новый Массив(),
						ТекВариант.Значение.МаксимальныйВес,
						ТекВариант.Значение.МаксимальныйОбъем,
						ТекВариант.Значение.ВремяВыездаНаМаршрут,
						СтрокаТС.Приоритет);
						
					Для Каждого ТекЭлПула Из ТекВариант.Значение.НовПул Цикл 
						ДанныеПула.маршрут.Добавить(Новый Структура("заказ, пункт, Адрес, Лат, Лон, Операция, Ожидание, Время, Расстояние",
							ТекЭлПула.заказ,
							ТекЭлПула.пункт,
							ТекЭлПула.Адрес,
							ТекЭлПула.Лат,
							ТекЭлПула.Лон,
							ТекЭлПула.Операция,
							ТекЭлПула.Ожидание,
							ТекЭлПула.Время,
							ТекЭлПула.Расстояние));
					КонецЦикла;
					
					пулы.Добавить(ДанныеПула);
					ТабТС.Удалить(СтрокаТС);
					Прервать;
					
				Иначе
					Если Не ТекВариант.Значение.НовТС = Неопределено Тогда 
						СтрокаТС = ТабТС.Найти(ТекВариант.Значение.НовТС, "Ссылка");
						
						// вернуть старый ТС
						НовСтрТС = ТабТС.Добавить();
						НовСтрТС.Ссылка                         = ТекВариант.Значение.пул.ТС;
						НовСтрТС.Грузоподъемность               = ТекВариант.Значение.пул.ГрузоподъемностьТС;
						НовСтрТС.ОбъемКузова                    = ТекВариант.Значение.пул.ОбъемКузоваТС;
						НовСтрТС.Порядок                        = ТекВариант.Значение.пул.ПорядокТС;
						НовСтрТС.ВозвратВГараж                  = ТекВариант.Значение.пул.ВозвратВГараж;
						НовСтрТС.Гараж                          = ТекВариант.Значение.пул.Гараж;
						НовСтрТС.АдресГаража                    = ТекВариант.Значение.пул.АдресГаража;
						НовСтрТС.ШиротаГаража                   = ТекВариант.Значение.пул.ШиротаГаража;
						НовСтрТС.ДолготаГаража                  = ТекВариант.Значение.пул.ДолготаГаража;
						НовСтрТС.МаксимальноеКоличествоУпаковок = ТекВариант.Значение.пул.МаксимальноеКоличествоУпаковок;
						НовСтрТС.Приоритет                      = ТекВариант.Значение.пул.ПриоритетТС;
						
						// подставить новый в пул
						ТекВариант.Значение.пул.ТС                             = СтрокаТС.Ссылка;
						ТекВариант.Значение.пул.ГрузоподъемностьТС             = СтрокаТС.Грузоподъемность;
						ТекВариант.Значение.пул.ОбъемКузоваТС                  = СтрокаТС.ОбъемКузова;
						ТекВариант.Значение.пул.ПорядокТС                      = СтрокаТС.Порядок;
						ТекВариант.Значение.пул.ВозвратВГараж                  = СтрокаТС.ВозвратВГараж;
						ТекВариант.Значение.пул.Гараж                          = СтрокаТС.Гараж;
						ТекВариант.Значение.пул.АдресГаража                    = СтрокаТС.АдресГаража;
						ТекВариант.Значение.пул.ШиротаГаража                   = СтрокаТС.ШиротаГаража;
						ТекВариант.Значение.пул.ДолготаГаража                  = СтрокаТС.ДолготаГаража;
						ТекВариант.Значение.пул.МаксимальноеКоличествоУпаковок = СтрокаТС.МаксимальноеКоличествоУпаковок;
						ТекВариант.Значение.пул.ПриоритетТС                    = СтрокаТС.Приоритет;
						
						// удалить новый ТС из таблицы
						ТабТС.Удалить(СтрокаТС);
						
						ТабТС.Сортировать("Приоритет Убыв, Порядок Возр");
					КонецЕсли;
					
					ТекВариант.Значение.Пул.маршрут.Очистить();
					
					Для Каждого ТекСтрока Из ТекВариант.Значение.НовПул Цикл 
						ТекВариант.Значение.Пул.маршрут.Добавить(ТекСтрока);
					КонецЦикла;
					
					ТекВариант.Значение.Пул.оценка = ТекВариант.Значение.НовОценка;
					ТекВариант.Значение.Пул.МаксимальныйВес = МаксимальныйВес;
					ТекВариант.Значение.Пул.МаксимальныйОбъем = МаксимальныйОбъем;
					ТекВариант.Значение.Пул.ВремяВыездаНаМаршрут = ТекВариант.Значение.ВремяВыездаНаМаршрут;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		Для Каждого ТекПул Из пулы Цикл 
			мсвНовПул = Новый Массив();
			Для Каждого ТекМаршрут Из ТекПул.маршрут Цикл 
				мсвИсходныеЗаказы = СоотвГруппЗаказов.Получить(ТекМаршрут.заказ);
				Для СчИсхЗаказ = 0 По мсвИсходныеЗаказы.Количество() - 1 Цикл
					ТекИсхЗаказ = мсвИсходныеЗаказы[СчИсхЗаказ];
					
					Если СжиматьЗаказы Тогда 
						СтрокиЗаказа = ТаблицаИсходЗаказов.Строки.НайтиСтроки(Новый Структура("Ссылка, СтрокаПакета", ТекИсхЗаказ.Заказ, ТекИсхЗаказ.Пакет), Истина);
					Иначе 
						СтрокиЗаказа = ТаблицаИсходЗаказов.НайтиСтроки(Новый Структура("Ссылка, СтрокаПакета", ТекИсхЗаказ.Заказ, ТекИсхЗаказ.Пакет));
					КонецЕсли;
					
					Если СчИсхЗаказ = 0 Тогда 
						ТекОжидание = ТекМаршрут.Ожидание;
					Иначе 
						ТекОжидание = 0;
					КонецЕсли;
					
					мсвНовПул.Добавить(Новый Структура("заказ, Груз, Количество, Операция, Ожидание, Время, Расстояние, НомерСтроки",
						ТекИсхЗаказ.Заказ, СтрокиЗаказа[0].Груз, СтрокиЗаказа[0].Количество, ТекМаршрут.Операция, ТекОжидание,
						ТекМаршрут.Время, ТекМаршрут.Расстояние, СтрокиЗаказа[0].СтрокаПакета));
				КонецЦикла;
			КонецЦикла;
			
			// В строке каждого заказа указано время/расстояние от предыдущего пункта,
			// а должно быть время/расстояние до следующего пункта, поэтому их надо сдвинуть
			Для Сч = 0 По мсвНовПул.Количество()-2 Цикл
				ТекущаяСтрока   = мсвНовПул[Сч];
				СледующаяСтрока = мсвНовПул[Сч+1];
				ТекущаяСтрока.Время      = СледующаяСтрока.Время;
				ТекущаяСтрока.Расстояние = СледующаяСтрока.Расстояние;
			КонецЦикла;
			Если мсвНовПул.Количество() > 0 Тогда
				ПоследняяСтрока = мсвНовПул[мсвНовПул.Количество()-1];
				ПоследняяСтрока.Время      = 0;
				ПоследняяСтрока.Расстояние = 0;
			КонецЕсли;
			
			ТекПул.маршрут = мсвНовПул;
			
			// Преобразование времени из секунд в формат ЧЧ:ММ
			ТекПул.ВремяВыездаНаМаршрут = НачалоДня(ВремяВыезда) + ТекПул.ВремяВыездаНаМаршрут;
			Для Каждого ТекСтрока Из ТекПул.маршрут Цикл
				ТекСтрока.Ожидание = уатОбщегоНазначения.уатВремяВЧЧ_ММ(ТекСтрока.Ожидание);
				ТекСтрока.Время = уатОбщегоНазначения.уатВремяВЧЧ_ММ(ТекСтрока.Время);
			КонецЦикла;
			
		КонецЦикла;
		
		МенеджерВТ.Закрыть();
		
		Для Каждого СтрокаПула Из пулы Цикл 
			СтрокаПула.Вставить("НаправлениеПеревозки", ТекНаправление.НаправлениеПеревозки);
			КонечныеПулы.Добавить(СтрокаПула);
			
			МаксИндСтрок = ВхМсвТС.Количество() - 1;
			Для ИндСтроки = 0 По МаксИндСтрок Цикл 
				Если ВхМсвТС[МаксИндСтрок - ИндСтроки].ТС = СтрокаПула.ТС Тогда 
					ВхМсвТС.Удалить(МаксИндСтрок - ИндСтроки);
				КонецЕсли;
			КонецЦикла;
			
			МаксИндСтрок = ВхМсвВиртТС.Количество() - 1;
			Для ИндСтроки = 0 По МаксИндСтрок Цикл 
				Если ВхМсвВиртТС[МаксИндСтрок - ИндСтроки].ТС = СтрокаПула.ТС Тогда 
					ВхМсвВиртТС[МаксИндСтрок - ИндСтроки].КоличествоВиртуальныхТС = ВхМсвВиртТС[МаксИндСтрок - ИндСтроки].КоличествоВиртуальныхТС - 1;
					Если ВхМсвВиртТС[МаксИндСтрок - ИндСтроки].КоличествоВиртуальныхТС < 1 Тогда 
						ВхМсвВиртТС.Удалить(МаксИндСтрок - ИндСтроки);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Новый Структура("СообщениеПользователю, пулы", НСтр("ru = 'Выполняется маршрутизация заказов'; en = 'Executing of orders routing'"), КонечныеПулы), АдресВрХранилища);
	
КонецПроцедуры

Функция СформироватьТаблицуИсходныхЗаказов(мсвЗаказы, мсвЗаказыПоКоординатам, флИспользованиеКластеризации, НастройкаКластеризации,
		СжиматьЗаказы, АдресДепо, ИспользоватьХарактеристикиЗаказовНаТС)
	
	ЗаказыБезКоординат = Новый Массив();
	Для Каждого ТекЗаказ Из мсвЗаказы Цикл 
		ЗаказыБезКоординат.Добавить(ТекЗаказ.Заказ);
	КонецЦикла;
	
	ТабЗаказыПоКоординатам = Новый ТаблицаЗначений();
	ТабЗаказыПоКоординатам.Колонки.Добавить("Ссылка",                   Новый ОписаниеТипов("ДокументСсылка.уатЗаказГрузоотправителя"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ПунктПогрузки",            Новый ОписаниеТипов("СправочникСсылка.уатКластеры_уэ"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ПунктРазгрузки",           Новый ОписаниеТипов("СправочникСсылка.уатКластеры_уэ"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("Приоритет",                Новый ОписаниеТипов("Число"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("АдресОтправления",         Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("АдресНазначения",          Новый ОписаниеТипов("СправочникСсылка.уатПунктыНазначения"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ОтправлениеС",             Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ОтправлениеПо",            Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ДоставкаС",                Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ДоставкаПо",               Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Время)));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ТребованиеКТСТипМоделиТС", Новый ОписаниеТипов("СправочникСсылка.уатТипыТС"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ТребованиеКТСТипТС",       Новый ОписаниеТипов("СправочникСсылка.уатТипыТС"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ЛатОтпр",                  Новый ОписаниеТипов("Число"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ЛонОтпр",                  Новый ОписаниеТипов("Число"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ЛатНазн",                  Новый ОписаниеТипов("Число"));
	ТабЗаказыПоКоординатам.Колонки.Добавить("ЛонНазн",                  Новый ОписаниеТипов("Число"));
	
	Для Каждого ТекЗаказКоорд Из мсвЗаказыПоКоординатам Цикл 
		НовСтр = ТабЗаказыПоКоординатам.Добавить();
		НовСтр.Ссылка                   = ТекЗаказКоорд.Заказ;
		НовСтр.ПунктПогрузки            = ТекЗаказКоорд.КластерОтправления;
		НовСтр.ПунктРазгрузки           = ТекЗаказКоорд.КластерНазначения;
		НовСтр.Приоритет                = ТекЗаказКоорд.ПриоритетМаршрутизации;
		НовСтр.АдресОтправления         = ТекЗаказКоорд.АдресОтправления;
		НовСтр.АдресНазначения          = ТекЗаказКоорд.АдресНазначения;
		НовСтр.ОтправлениеС             = ТекЗаказКоорд.ОтправлениеС;
		НовСтр.ОтправлениеПо            = ТекЗаказКоорд.ОтправлениеПо;
		НовСтр.ДоставкаС                = ТекЗаказКоорд.ДоставкаС;
		НовСтр.ДоставкаПо               = ТекЗаказКоорд.ДоставкаПо;
		НовСтр.ТребованиеКТСТипМоделиТС = ТекЗаказКоорд.Заказ.ТребованиеКТС.ТипТС;
		НовСтр.ТребованиеКТСТипТС       = ТекЗаказКоорд.Заказ.ТребованиеКТСТипТС;
		НовСтр.ЛатОтпр                  = ТекЗаказКоорд.ЛатОтпр;
		НовСтр.ЛонОтпр                  = ТекЗаказКоорд.ЛонОтпр;
		НовСтр.ЛатНазн                  = ТекЗаказКоорд.ЛатНазн;
		НовСтр.ЛонНазн                  = ТекЗаказКоорд.ЛонНазн;
	КонецЦикла;
	
	ТекстОбщегоЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТабЗаказыПоКоординатам.Ссылка КАК Ссылка,
	|	ТабЗаказыПоКоординатам.ПунктПогрузки КАК ПунктПогрузки,
	|	ТабЗаказыПоКоординатам.ПунктРазгрузки КАК ПунктРазгрузки,
	|	ТабЗаказыПоКоординатам.Приоритет КАК Приоритет,
	|	ТабЗаказыПоКоординатам.АдресОтправления КАК АдресОтправления,
	|	ТабЗаказыПоКоординатам.АдресНазначения КАК АдресНазначения,
	|	ТабЗаказыПоКоординатам.ОтправлениеС КАК ОтправлениеС,
	|	ТабЗаказыПоКоординатам.ОтправлениеПо КАК ОтправлениеПо,
	|	ТабЗаказыПоКоординатам.ДоставкаС КАК ДоставкаС,
	|	ТабЗаказыПоКоординатам.ДоставкаПо КАК ДоставкаПо,
	|	ТабЗаказыПоКоординатам.ТребованиеКТСТипМоделиТС КАК ТребованиеКТСТипМоделиТС,
	|	ТабЗаказыПоКоординатам.ТребованиеКТСТипТС КАК ТребованиеКТСТипТС,
	|	ТабЗаказыПоКоординатам.ЛатОтпр КАК ЛатОтпр,
	|	ТабЗаказыПоКоординатам.ЛонОтпр КАК ЛонОтпр,
	|	ТабЗаказыПоКоординатам.ЛатНазн КАК ЛатНазн,
	|	ТабЗаказыПоКоординатам.ЛонНазн КАК ЛонНазн
	|ПОМЕСТИТЬ ВТ_ЗаказыПоКоординатам
	|ИЗ
	|	&ТабЗаказыПоКоординатам КАК ТабЗаказыПоКоординатам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказНаПеревозку.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА &флИспользованиеКластеризации
	|			ТОГДА ЕСТЬNULL(уатПривязкаПунктовОтправления.Кластер, ЗНАЧЕНИЕ(Справочник.уатКластеры_уэ.ПустаяСсылка))
	|		ИНАЧЕ ВЫРАЗИТЬ(ЗаказНаПеревозку.АдресОтправления КАК Справочник.уатПунктыНазначения)
	|	КОНЕЦ КАК ПунктПогрузки,
	|	ВЫБОР
	|		КОГДА &флИспользованиеКластеризации
	|			ТОГДА ЕСТЬNULL(уатПривязкаПунктовНазначения.Кластер, ЗНАЧЕНИЕ(Справочник.уатКластеры_уэ.ПустаяСсылка))
	|		ИНАЧЕ ВЫРАЗИТЬ(ЗаказНаПеревозку.АдресНазначения КАК Справочник.уатПунктыНазначения)
	|	КОНЕЦ КАК ПунктРазгрузки,
	|	ЗаказНаПеревозку.Приоритет КАК Приоритет,
	|	ЗаказНаПеревозку.АдресОтправления КАК АдресОтправления,
	|	ЗаказНаПеревозку.АдресНазначения КАК АдресНазначения,
	|	ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), МИНУТА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ЗаказНаПеревозку.ОтправлениеС, ДЕНЬ), ЗаказНаПеревозку.ОтправлениеС, МИНУТА)) КАК ОтправлениеС,
	|	ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), МИНУТА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ЗаказНаПеревозку.ОтправлениеПо, ДЕНЬ), ЗаказНаПеревозку.ОтправлениеПо, МИНУТА)) КАК ОтправлениеПо,
	|	ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), МИНУТА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ЗаказНаПеревозку.ДоставкаС, ДЕНЬ), ЗаказНаПеревозку.ДоставкаС, МИНУТА)) КАК ДоставкаС,
	|	ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), МИНУТА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ЗаказНаПеревозку.ДоставкаПо, ДЕНЬ), ЗаказНаПеревозку.ДоставкаПо, МИНУТА)) КАК ДоставкаПо,
	|	ЗаказНаПеревозку.ТребованиеКТС.ТипТС КАК ТребованиеКТСТипМоделиТС,
	|	ЗаказНаПеревозку.ТребованиеКТСТипТС КАК ТребованиеКТСТипТС,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЗаказНаПеревозку.АдресОтправления) = ТИП(Справочник.уатПунктыНазначения)
	|			ТОГДА ЗаказНаПеревозку.АдресОтправления.Лат
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЛатОтпр,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЗаказНаПеревозку.АдресОтправления) = ТИП(Справочник.уатПунктыНазначения)
	|			ТОГДА ЗаказНаПеревозку.АдресОтправления.Лон
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЛонОтпр,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЗаказНаПеревозку.АдресНазначения) = ТИП(Справочник.уатПунктыНазначения)
	|			ТОГДА ЗаказНаПеревозку.АдресНазначения.Лат
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЛатНазн,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЗаказНаПеревозку.АдресНазначения) = ТИП(Справочник.уатПунктыНазначения)
	|			ТОГДА ЗаказНаПеревозку.АдресНазначения.Лон
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЛонНазн
	|ПОМЕСТИТЬ ВТ_Документы
	|ИЗ
	|	Документ.уатЗаказГрузоотправителя КАК ЗаказНаПеревозку
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатПривязкаПунктовНазначенияККластерам_уэ КАК уатПривязкаПунктовОтправления
	|		ПО (&флИспользованиеКластеризации)
	|			И ЗаказНаПеревозку.АдресОтправления = уатПривязкаПунктовОтправления.ПунктНазначения
	|			И (уатПривязкаПунктовОтправления.Кластер.НастройкаКластеризации = &НастройкаКластеризации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатПривязкаПунктовНазначенияККластерам_уэ КАК уатПривязкаПунктовНазначения
	|		ПО (&флИспользованиеКластеризации)
	|			И ЗаказНаПеревозку.АдресНазначения = уатПривязкаПунктовНазначения.ПунктНазначения
	|			И (уатПривязкаПунктовНазначения.Кластер.НастройкаКластеризации = &НастройкаКластеризации)
	|ГДЕ
	|	ЗаказНаПеревозку.Ссылка В(&ЗаказыБезКоординат)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_ЗаказыПоКоординатам.Ссылка,
	|	ВТ_ЗаказыПоКоординатам.ПунктПогрузки,
	|	ВТ_ЗаказыПоКоординатам.ПунктРазгрузки,
	|	ВТ_ЗаказыПоКоординатам.Приоритет,
	|	ВТ_ЗаказыПоКоординатам.АдресОтправления,
	|	ВТ_ЗаказыПоКоординатам.АдресНазначения,
	|	ВТ_ЗаказыПоКоординатам.ОтправлениеС,
	|	ВТ_ЗаказыПоКоординатам.ОтправлениеПо,
	|	ВТ_ЗаказыПоКоординатам.ДоставкаС,
	|	ВТ_ЗаказыПоКоординатам.ДоставкаПо,
	|	ВТ_ЗаказыПоКоординатам.ТребованиеКТСТипМоделиТС,
	|	ВТ_ЗаказыПоКоординатам.ТребованиеКТСТипТС,
	|	ВТ_ЗаказыПоКоординатам.ЛатОтпр,
	|	ВТ_ЗаказыПоКоординатам.ЛонОтпр,
	|	ВТ_ЗаказыПоКоординатам.ЛатНазн,
	|	ВТ_ЗаказыПоКоординатам.ЛонНазн
	|ИЗ
	|	ВТ_ЗаказыПоКоординатам КАК ВТ_ЗаказыПоКоординатам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Документы.ПунктПогрузки КАК Пункт
	|ИЗ
	|	ВТ_Документы КАК ВТ_Документы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Документы.ПунктРазгрузки
	|ИЗ
	|	ВТ_Документы КАК ВТ_Документы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_Документы.АдресОтправления КАК Адрес
	|ИЗ
	|	ВТ_Документы КАК ВТ_Документы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Документы.АдресНазначения
	|ИЗ
	|	ВТ_Документы КАК ВТ_Документы
	|
	|ОБЪЕДИНИТЬ ВСЕ
