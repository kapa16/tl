Функция ЗаполнитьСтруктуруТС(ТекТС, СтруктураНастроекАРМ, НастройкиМаршрутизации,
	ТаблицаLocation, Массив_locations, ПересчетМетрик,
	СчДобавленныхОбъектов, флПереносДаты = Ложь, СоответствиеГеозон, СоответвиеЗаказов, ДатаПланирования, ИспользоватьГруппыБалансировкиМаршрутов = Ложь)
	
	флRarusVRP = СтруктураНастроекАРМ.НастройкаАлгоритмМаршрутизации = 4;
	
	vehiclesCompanyCost           = НастройкиМаршрутизации.vehiclesCompanyCost;
	vehiclesCompanyCost_fixed     = НастройкиМаршрутизации.vehiclesCompanyCost_fixed;
	vehiclesCompanyCost_run       = НастройкиМаршрутизации.vehiclesCompanyCost_run;
	vehiclesCompanyCost_km        = НастройкиМаршрутизации.vehiclesCompanyCost_km;
	vehiclesCompanyCost_hour      = НастройкиМаршрутизации.vehiclesCompanyCost_hour;
	vehiclesCompanyCost_location  = НастройкиМаршрутизации.vehiclesCompanyCost_location;
	
	vehiclesExternalCost          = НастройкиМаршрутизации.vehiclesExternalCost;
	vehiclesExternalCost_fixed    = НастройкиМаршрутизации.vehiclesExternalCost_fixed;
	vehiclesExternalCost_run      = НастройкиМаршрутизации.vehiclesExternalCost_run;
	vehiclesExternalCost_km       = НастройкиМаршрутизации.vehiclesExternalCost_km;
	vehiclesExternalCost_hour     = НастройкиМаршрутизации.vehiclesExternalCost_hour;
	vehiclesExternalCost_location = НастройкиМаршрутизации.vehiclesExternalCost_location;
	
	vehiclesVirtualCost           = НастройкиМаршрутизации.vehiclesVirtualCost;
	vehiclesVirtualCost_fixed     = НастройкиМаршрутизации.vehiclesVirtualCost_fixed;
	vehiclesVirtualCost_run       = НастройкиМаршрутизации.vehiclesVirtualCost_run;
	vehiclesVirtualCost_km        = НастройкиМаршрутизации.vehiclesVirtualCost_km;
	vehiclesVirtualCost_hour      = НастройкиМаршрутизации.vehiclesVirtualCost_hour;
	vehiclesVirtualCost_location  = НастройкиМаршрутизации.vehiclesVirtualCost_location;
	

	НастройкаИспользоватьВПриоритетеСобственныйТранспорт = СтруктураНастроекАРМ.НастройкаИспользоватьВПриоритетеСобственныйТранспорт;
	НастройкаИспользоватьХарактеристикиЗаказовНаТС       = СтруктураНастроекАРМ.НастройкаИспользоватьХарактеристикиЗаказовНаТС;
	НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу   = СтруктураНастроекАРМ.НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу;
	НастройкаПонижающийКоэффициентЗагрузкиКузоваПоОбъему = СтруктураНастроекАРМ.НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу;
	НастройкаМаксимальноеЧислоЗаказовМаршрута            = СтруктураНастроекАРМ.НастройкаМаксимальноеЧислоЗаказовМаршрута;
	
	НастройкаИспользоватьЗакреплениеТСЗаказовНаТСзаГеозонами = СтруктураНастроекАРМ.НастройкаИспользоватьЗакреплениеТСЗаказовНаТСзаГеозонами;

	НастройкаВыездСоСкладаСобственныеТС                  = СтруктураНастроекАРМ.НастройкаВыездСоСкладаСобственныеТС;
	НастройкаВыездСоСкладаПривлеченныеТС                 = СтруктураНастроекАРМ.НастройкаВыездСоСкладаПривлеченныеТС;
	НастройкаВыездСоСкладаВиртуальныеТС                  = СтруктураНастроекАРМ.НастройкаВыездСоСкладаВиртуальныеТС;
	НастройкаЗаездНаСкладСобственныеТС                   = СтруктураНастроекАРМ.НастройкаЗаездНаСкладСобственныеТС;
	НастройкаЗаездНаСкладПривлеченныеТС                  = СтруктураНастроекАРМ.НастройкаЗаездНаСкладПривлеченныеТС;
	НастройкаЗаездНаСкладВиртуальныеТС                   = СтруктураНастроекАРМ.НастройкаЗаездНаСкладВиртуальныеТС;
	НастройкаВыездИзГаражаСобственныеТС                  = СтруктураНастроекАРМ.НастройкаВыездИзГаражаСобственныеТС;
	НастройкаВыездИзГаражаПривлеченныеТС                 = СтруктураНастроекАРМ.НастройкаВыездИзГаражаПривлеченныеТС;
	НастройкаВыездИзГаражаВиртуальныеТС                  = СтруктураНастроекАРМ.НастройкаВыездИзГаражаВиртуальныеТС;
	НастройкаВозвратВГаражСобственныеТС                  = СтруктураНастроекАРМ.НастройкаВозвратВГаражСобственныеТС;
	НастройкаВозвратВГаражПривлеченныеТС                 = СтруктураНастроекАРМ.НастройкаВыездИзГаражаПривлеченныеТС;
	НастройкаВозвратВГаражВиртуальныеТС                  = СтруктураНастроекАРМ.НастройкаВозвратВГаражВиртуальныеТС;
	
	Структура_vehicle = Новый Структура();
	
	ТС = ТекТС.ТС;
	
	МаксимальноеЧислоЗаказовМаршрута = ?(ЗначениеЗаполнено(ТекТС.МаксимальноеКоличествоУпаковок)
	И СтруктураНастроекАРМ.НастройкаУчитыватьМаксимальноеКоличествоУпаковок = Истина,
		ТекТС.МаксимальноеКоличествоУпаковок, НастройкаМаксимальноеЧислоЗаказовМаршрута);
	capacity = Новый Массив(); 
	
	ЕстьХарКиВместимости   = Ложь;
	СтруктураВместимостьТС = Новый Структура();
	Если ЗначениеЗаполнено(МаксимальноеЧислоЗаказовМаршрута) Тогда
		СтруктураВместимостьТС.Вставить("units", МаксимальноеЧислоЗаказовМаршрута);
		ЕстьХарКиВместимости = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекТС.Грузоподъемность) Тогда
		СтруктураВместимостьТС.Вставить("weight_kg", ТекТС.Грузоподъемность);
		ЕстьХарКиВместимости = Истина;
	КонецЕсли; 
	Если ЗначениеЗаполнено(НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу) 
		ИЛИ ЗначениеЗаполнено(НастройкаПонижающийКоэффициентЗагрузкиКузоваПоОбъему) Тогда 
		СтруктураПределыЗагрузкиТС = Новый Структура();
		Если ЗначениеЗаполнено(НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу) Тогда
			СтруктураПределыЗагрузкиТС.Вставить("weight_perc", НастройкаПонижающийКоэффициентЗагрузкиКузоваПоВесу);
		КонецЕсли;
		Если ЗначениеЗаполнено(НастройкаПонижающийКоэффициентЗагрузкиКузоваПоОбъему) Тогда
			СтруктураПределыЗагрузкиТС.Вставить("volume_perc", НастройкаПонижающийКоэффициентЗагрузкиКузоваПоОбъему);
		КонецЕсли;
		СтруктураВместимостьТС.Вставить("limits", СтруктураПределыЗагрузкиТС);
		ЕстьХарКиВместимости = Истина;
	КонецЕсли;
	
	ПолезныйРазмерГлубина = ТС.ПолезныйРазмерДлина / 1000;
	ПолезныйРазмерШирина  = ТС.ПолезныйРазмерШирина / 1000;
	ПолезныйРазмерВысота  = ТС.ПолезныйРазмерВысота / 1000;
	
	Если СтруктураНастроекАРМ.НастройкаУчетЖесткихГабаритовГруза 
		И ПолезныйРазмерГлубина > 0
		И ПолезныйРазмерШирина > 0
		И ПолезныйРазмерВысота > 0 Тогда
		
		СтруктураМетрическиеРазмерыТС = Новый Структура();
		СтруктураМетрическиеРазмерыТС.Вставить("height_m", ПолезныйРазмерВысота);
		СтруктураМетрическиеРазмерыТС.Вставить("width_m",  ПолезныйРазмерШирина);
		СтруктураМетрическиеРазмерыТС.Вставить("depth_m",  ПолезныйРазмерГлубина);
		
		СтруктураВместимостьТС.Вставить("volume", СтруктураМетрическиеРазмерыТС);
		ЕстьХарКиВместимости = Истина;
	Иначе
		ПолезныйРазмерГлубина  = ТекТС.ОбъемКузова;
		Если ПолезныйРазмерГлубина > 0 Тогда
			Если флRarusVRP Тогда
				СтруктураМетрическиеРазмерыТС = Новый Структура("height_m, width_m, depth_m", 1, 1, ПолезныйРазмерГлубина);
				СтруктураВместимостьТС.Вставить("volume", СтруктураМетрическиеРазмерыТС);
			Иначе
				СтруктураВместимостьТС.Вставить("volume_cbm", ПолезныйРазмерГлубина); 
			КонецЕсли;
			ЕстьХарКиВместимости = Истина;
		КонецЕсли;
	КонецЕсли; 
	Если ЕстьХарКиВместимости Тогда
		Структура_vehicle.Вставить("capacity", СтруктураВместимостьТС);
	КонецЕсли;
	
	breaks = Новый Массив();
	Если ЗначениеЗаполнено(ТС.ОсновнойРежимРаботы) Тогда
		Для Каждого ТекСтрока Из ТС.ОсновнойРежимРаботы.Перерывы Цикл
			Часов = Час(ТекСтрока.Длительность);
			Минут = Минута(ТекСтрока.Длительность);
			Если (Часов <> 0
				ИЛИ Минут <> 0)
				И ЗначениеЗаполнено(ТекСтрока.ВремяДоПерерываМинимум)
				И ЗначениеЗаполнено(ТекСтрока.ВремяДоПерерываМаксимум) Тогда
				rest_duration_s = (Часов*3600) + (Минут*60);
				work_time_range_till_rest = Формат(ТекСтрока.ВремяДоПерерываМинимум, "ДФ=HH:mm") + "-"
					+ Формат(ТекСтрока.ВремяДоПерерываМаксимум, "ДФ=HH:mm");
				breaks.Добавить(Новый Структура("rest_duration_s, work_time_range_till_rest", rest_duration_s, work_time_range_till_rest));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если breaks.Количество() <> 0 Тогда
		Структура_vehicle.Вставить("rest_schedule", Новый Структура("breaks", breaks));
	КонецЕсли;
	
	Структура_shift = Новый Структура();
	
	НастройкаМаксимальнаяПродолжительностьСмены = СтруктураНастроекАРМ.НастройкаМаксимальнаяПродолжительностьСмены;
	Если ТипЗнч(НастройкаМаксимальнаяПродолжительностьСмены) = Тип("Строка") Тогда
		Попытка
			НастройкаМаксимальнаяПродолжительностьСмены = Дата(НастройкаМаксимальнаяПродолжительностьСмены);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТС.МаксимальнаяПродолжительностьСмены) Тогда
		Структура_shift.Вставить("max_duration_s",     ТС.МаксимальнаяПродолжительностьСмены - '00010101000000');
	ИначеЕсли ЗначениеЗаполнено(НастройкаМаксимальнаяПродолжительностьСмены) Тогда
		Структура_shift.Вставить("max_duration_s",     НастройкаМаксимальнаяПродолжительностьСмены - '00010101000000');
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТС.МаксимальныйПробегЗаСмену) Тогда
		Структура_shift.Вставить("max_mileage_km",     ТС.МаксимальныйПробегЗаСмену);
	ИначеЕсли ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаМаксимальныйПробегЗаСмену) Тогда
		Структура_shift.Вставить("max_mileage_km",     СтруктураНастроекАРМ.НастройкаМаксимальныйПробегЗаСмену);
	КонецЕсли;
	
	Структура_shift.Вставить("service_duration_s", ТС.ВремяПересменки - '00010101000000');
	Если ЗначениеЗаполнено(ТС.МинимальноеЧислоПунктов) Тогда
		Структура_shift.Вставить("minimal_stops",      ТС.МинимальноеЧислоПунктов);
	ИначеЕсли ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаМинимальноеКоличествоОстановок) Тогда 
		Структура_shift.Вставить("minimal_stops",      СтруктураНастроекАРМ.НастройкаМинимальноеКоличествоОстановок);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТС.МаксимальноеЧислоПунктов) Тогда
		Структура_shift.Вставить("maximal_stops",  ТС.МаксимальноеЧислоПунктов);
	ИначеЕсли ЗначениеЗаполнено(СтруктураНастроекАРМ.НастройкаМаксимальноеКоличествоОстановок) Тогда
		Структура_shift.Вставить("maximal_stops",  СтруктураНастроекАРМ.НастройкаМаксимальноеКоличествоОстановок);
	КонецЕсли;
	
	locationsPenalty_early_fixed   = ?(ЗначениеЗаполнено(ТС.ШтрафЗаОкноФиксирРанее), ТС.ШтрафЗаОкноФиксирРанее, НастройкиМаршрутизации.locationsPenalty_early_fixed);
	locationsPenalty_early_minute  = ?(ЗначениеЗаполнено(ТС.ШтрафЗаОкноМинутаРанее), ТС.ШтрафЗаОкноМинутаРанее, НастройкиМаршрутизации.locationsPenalty_early_minute);
	locationsPenalty_late_fixed    = ?(ЗначениеЗаполнено(ТС.ШтрафЗаОкноФиксирПозднее), ТС.ШтрафЗаОкноФиксирПозднее, НастройкиМаршрутизации.locationsPenalty_late_fixed);
	locationsPenalty_late_minute   = ?(ЗначениеЗаполнено(ТС.ШтрафЗаОкноМинутаПозднее), ТС.ШтрафЗаОкноМинутаПозднее, НастройкиМаршрутизации.locationsPenalty_late_minute);
	
	ЕстьШтрафы = Ложь;
	СтруктураШтрафов = Новый Структура();
	Если ЗначениеЗаполнено(ТС.ШтрафЗаОкноФиксир)
		ИЛИ ЗначениеЗаполнено(ТС.ШтрафЗаОкноМинута) Тогда
		out_of_time = Новый Структура();
		Если ЗначениеЗаполнено(ТС.ШтрафЗаОкноФиксир) Тогда
			out_of_time.Вставить("fixed", ТС.ШтрафЗаОкноФиксир);
		КонецЕсли;
		Если ЗначениеЗаполнено(ТС.ШтрафЗаОкноМинута) Тогда
			out_of_time.Вставить("minute", ТС.ШтрафЗаОкноМинута);
		КонецЕсли;
		СтруктураШтрафов.Вставить("out_of_time", out_of_time);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(locationsPenalty_early_fixed)
		ИЛИ ЗначениеЗаполнено(locationsPenalty_early_minute) Тогда
		early = Новый Структура();
		Если ЗначениеЗаполнено(locationsPenalty_early_fixed) Тогда
			early.Вставить("fixed", locationsPenalty_early_fixed);
		КонецЕсли;
		Если ЗначениеЗаполнено(locationsPenalty_early_minute) Тогда
			early.Вставить("minute", locationsPenalty_early_minute);
		КонецЕсли;
		СтруктураШтрафов.Вставить("early", early);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(locationsPenalty_late_fixed)
		ИЛИ ЗначениеЗаполнено(locationsPenalty_late_minute) Тогда
		late = Новый Структура();
		Если ЗначениеЗаполнено(locationsPenalty_late_fixed) Тогда
			late.Вставить("fixed", locationsPenalty_late_fixed);
		КонецЕсли;
		Если ЗначениеЗаполнено(locationsPenalty_late_minute) Тогда
			late.Вставить("minute", locationsPenalty_late_minute);
		КонецЕсли;
		СтруктураШтрафов.Вставить("late", late);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТС.ШтрафЗаНевыполнениеЗаказаФиксир)
		ИЛИ ЗначениеЗаполнено(ТС.ШтрафЗаНевыполнениеЗаказа) Тогда
		stop_lack = Новый Структура();
		Если ЗначениеЗаполнено(ТС.ШтрафЗаНевыполнениеЗаказаФиксир) Тогда
			stop_lack.Вставить("fixed", ТС.ШтрафЗаНевыполнениеЗаказаФиксир);
		КонецЕсли;
		Если ЗначениеЗаполнено(ТС.ШтрафЗаНевыполнениеЗаказа) Тогда
			stop_lack.Вставить("per_stop", ТС.ШтрафЗаНевыполнениеЗаказа);
		КонецЕсли;
		СтруктураШтрафов.Вставить("stop_lack", stop_lack);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимумаЗаказовФиксир)
		ИЛИ ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимумаЗаказов) Тогда
		stop_excess = Новый Структура();
		Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимумаЗаказовФиксир) Тогда
			stop_excess.Вставить("fixed", ТС.ШтрафЗаПревышениеМаксимумаЗаказовФиксир);
		КонецЕсли;
		Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимумаЗаказов) Тогда
			stop_excess.Вставить("per_stop", ТС.ШтрафЗаПревышениеМаксимумаЗаказов);
		КонецЕсли;
		СтруктураШтрафов.Вставить("stop_excess", stop_excess);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСменуФиксир)
		ИЛИ ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСмену) Тогда
		max_mileage = Новый Структура();
		Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСменуФиксир) Тогда
			max_mileage.Вставить("fixed", ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСменуФиксир);
		КонецЕсли;
		Если ЗначениеЗаполнено(ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСмену) Тогда
			max_mileage.Вставить("km", ТС.ШтрафЗаПревышениеМаксимальногоПробегаЗаСмену);
		КонецЕсли;
		СтруктураШтрафов.Вставить("max_mileage", max_mileage);
		ЕстьШтрафы = Истина;
	КонецЕсли;
	Если ЕстьШтрафы Тогда
		Структура_shift.Вставить("penalty", СтруктураШтрафов);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТС.ОсновнойРежимРаботы) 
		И ИспользоватьГруппыБалансировкиМаршрутов Тогда
		ГруппаБалансировкиМаршрутов = ТС.ОсновнойРежимРаботы.ГруппаБалансировкиМаршрутов;
		Если ЗначениеЗаполнено(ГруппаБалансировкиМаршрутов) Тогда
			Структура_shift.Вставить("balanced_group_id", Строка(ГруппаБалансировкиМаршрутов.УникальныйИдентификатор()));
		КонецЕсли;
	КонецЕсли;
	Структура_shift.Вставить("id",                 Строка(Новый УникальныйИдентификатор()));
	

	ОсновнойРежимРаботы = ТС.ОсновнойРежимРаботы;
	
	ВремяНачалоПоРежиму = ОсновнойРежимРаботы.НачалоРаботы;
	ВремяКонецПоРежиму  = ?(ЗначениеЗаполнено(ОсновнойРежимРаботы), ОсновнойРежимРаботы.КонецРаботы, '00010101235959'); 
	
	флагСдвигДаты       = ВремяКонецПоРежиму < ВремяНачалоПоРежиму;
	
	Если НЕ ЗначениеЗаполнено(ВремяНачалоПоРежиму)
		И (НЕ ЗначениеЗаполнено(ВремяКонецПоРежиму)
		ИЛИ (Час(ВремяКонецПоРежиму) = 23 И Минута(ВремяКонецПоРежиму) = 59)) Тогда
		
		Если СтруктураНастроекАРМ.Свойство("ТекОкноС") 
			И СтруктураНастроекАРМ.ТекОкноС > ВремяНачалоПоРежиму Тогда
			Структура_shift.Вставить(
			"time_window", 
			Строка(День(СтруктураНастроекАРМ.ТекОкноС) - 1)
			+ "." + Формат(СтруктураНастроекАРМ.ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-"
			+ "1.23:59:59"
			);
			Структура_vehicle.Вставить(
			"time_window_format", 
			"%1." + Формат(СтруктураНастроекАРМ.ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-"
			+ "%2.23:59:59"
			);
		Иначе
			Структура_shift.Вставить(
			"time_window", 
			"0.00:00:00 - 1.23:59:59"
			); 
			
			Структура_vehicle.Вставить(
			"time_window_format", 
			"%1.00:00:00 - %2.23:59:59"
			);
		КонецЕсли;
	Иначе
		ТекОкноС = ВремяНачалоПоРежиму;
		Если СтруктураНастроекАРМ.Свойство("ТекОкноС")
			И СтруктураНастроекАРМ.ТекОкноС > ВремяНачалоПоРежиму 
			И флагСдвигДаты Тогда
			ТекОкноС = СтруктураНастроекАРМ.ТекОкноС;
		КонецЕсли;
		
		Если флПереносДаты 
			И НЕ флагСдвигДаты Тогда
			Структура_shift.Вставить(
			"time_window", 
			"1." + Формат(ВремяНачалоПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
			"1." + Формат(ВремяКонецПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
			Структура_vehicle.Вставить(
			"time_window_format", 
			"%1." + Формат(ВремяНачалоПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
			"%2." + Формат(ВремяКонецПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
		Иначе
			Структура_shift.Вставить(
			"time_window", 
			"0." + Формат(ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-" +
			?(флагСдвигДаты, "1.", "0.") + Формат(ВремяКонецПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
			Структура_vehicle.Вставить(
			"time_window_format", 
			"%1." + Формат(ТекОкноС, "ДФ=HH:mm:ss; ДП=00:00:00") + "-%2." +
			Формат(ВремяКонецПоРежиму, "ДФ=HH:mm:ss; ДП=00:00:00")
			);
		КонецЕсли;
	КонецЕсли;
	
	Структура_shift.Вставить("hard_window", НЕ ТС.РазрешитьНарушениеРежимаРаботы);
	Массив_shifts = Новый Массив();
	Массив_shifts.Добавить(Структура_shift);
	Структура_vehicle.Вставить("shifts", Массив_shifts);
	Структура_vehicle.Вставить("max_runs", ?(ЗначениеЗаполнено(ТС.КоличествоЕздок), ТС.КоличествоЕздок, 0)); 
	
