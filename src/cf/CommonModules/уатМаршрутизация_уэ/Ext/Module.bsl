									Если мЦенаПогрузка = Неопределено Тогда 
										Продолжить;
									КонецЕсли;
									
									мЦенаРазгрузка = Неопределено;
									Для Каждого ТекТС Из ТабТС Цикл 
										Если ТекТС.Гараж = СтрокаЛонНазн.ПунктРазгрузки Тогда 
											Если РежимОптимизации = 0 Тогда 
												мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, 0, Мин(мЦенаРазгрузка, 0));
											Иначе 
												мЦенаРазгрузка = ?(мЦенаРазгрузка=Неопределено, 0, Мин(мЦенаРазгрузка, 0));
											КонецЕсли;
											
										Иначе 
											Узел1 = СоотвТаблРасстояний.Получить(ТекТС.Гараж);
											Если Узел1 = Неопределено Тогда 
