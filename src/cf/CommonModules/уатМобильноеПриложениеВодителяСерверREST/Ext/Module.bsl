//
// Возвращаемое значение:
//   Соответвие      - json-соответвие, сформированная на основе параметров "мсвТС" и/или "ВыбранноеТС"
//
Функция СериализоватьLoginResponse(Водитель, Знач мсвТС=Неопределено, Знач ВыбранноеТС=Неопределено) Экспорт
	
	Если НЕ мсвТС = Неопределено Тогда
		МассивТСJSON = Новый Массив();
		Для Каждого ТекТС Из мсвТС Цикл
			ТС = ?(ЗначениеЗаполнено(ТекТС.ГосударственныйНомер), ТекТС.ГосударственныйНомер, ТекТС.Наименование);
			МассивТСJSON.Добавить(Строка(ТС));
		КонецЦикла;
		
		response = Новый Соответствие(); 
		response.Вставить("cars" , МассивТСJSON);
	ИначеЕсли НЕ ВыбранноеТС = Неопределено Тогда 
		
		response = Новый Соответствие(); 
		response.Вставить("carID", Строка(ВыбранноеТС.УникальныйИдентификатор()));
		
		ТС = ?(ЗначениеЗаполнено(ВыбранноеТС.ГосударственныйНомер), ВыбранноеТС.ГосударственныйНомер, ВыбранноеТС.Наименование);
		response.Вставить("car",    Строка(ТС));
		response.Вставить("driver", Строка(уатОбщегоНазначенияТиповые.уатФамилияИнициалыФизЛица(Водитель)));
	КонецЕсли;
	ЗначениеJSON = Новый Соответствие();
	ЗначениеJSON.Вставить("responseData" , response);
	Возврат ЗначениеJSON;  
	
КонецФункции // СериализоватьLoginResponse()

