Функция ДесериализоватьUpdateTaxiOrder(Знач requestData, флОшибка) Экспорт
	
	ТабЗаказов = Новый ТаблицаЗначений;
	ТабЗаказов.Колонки.Добавить("orderRef",       Новый ОписаниеТипов("ДокументСсылка.такЗаказТакси"));
	ТабЗаказов.Колонки.Добавить("orderID",        Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабЗаказов.Колонки.Добавить("currentStatus",  Новый ОписаниеТипов("Строка"));
	ТабЗаказов.Колонки.Добавить("isPaid");
	ТабЗаказов.Колонки.Добавить("cancelled",      Новый ОписаниеТипов("Булево"));
	ТабЗаказов.Колонки.Добавить("services");
	ТабЗаказов.Колонки.Добавить("taximeter");
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(requestData);
		ТекЗаказ = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();
		
		ТекущийGUID   = Неопределено; 
		currentStatus = Неопределено; 
		isPaid        = Неопределено;
		cancelled     = Неопределено;
		массивУслуг   = Новый Массив();
		Таксометр = Новый Структура("transportingDistance,transportingDuration,waitingTime,pickupDistance,pickupDuration,pickupStartDate,waitingStartDate,factStartTime",
			0,0,0,0,0, Дата(1,1,1),Дата(1,1,1),Дата(1,1,1));
		Если ТекЗаказ.Получить("orderID") <> Неопределено Тогда
			ТекущийGUID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаказ.Получить("orderID"), флОшибка);
			
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
			КонецЕсли;
		КонецЕсли;
		Если ТекЗаказ.Получить("currentStatus") <> Неопределено Тогда
			currentStatus = ТекЗаказ.Получить("currentStatus");
		КонецЕсли;
		Если ТекЗаказ.Получить("isPaid") <> Неопределено Тогда
			isPaid = ТекЗаказ.Получить("isPaid");
		КонецЕсли; 
		Если ТекЗаказ.Получить("cancelled") <> Неопределено Тогда
			cancelled = ТекЗаказ.Получить("cancelled");
		КонецЕсли; 
		Если ТекЗаказ.Получить("services") <> Неопределено Тогда
			serviceAmount = Неопределено;
			serviceID     = Неопределено;
			serviceNumber = Неопределено;
			services      = ТекЗаказ.Получить("services");
			Для Каждого ТекУслуга Из services Цикл
				serviceAmount = Неопределено;
				serviceID     = Неопределено;
				serviceNumber = Неопределено;	
				Если ТекУслуга.Получить("serviceID") <> Неопределено Тогда
					serviceID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекУслуга.Получить("serviceID"), флОшибка);
					Если флОшибка Тогда 
						ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
					КонецЕсли;
				КонецЕсли;
				Если ТекУслуга.Получить("serviceNumber") <> Неопределено Тогда
					serviceNumber = ТекУслуга.Получить("serviceNumber");
				КонецЕсли;
				Если ТекУслуга.Получить("serviceAmount") <> Неопределено Тогда
					serviceAmount = ТекУслуга.Получить("serviceAmount");
				КонецЕсли;
				массивУслуг.Добавить(Новый Структура("serviceNumber, serviceID, serviceAmount", serviceNumber, serviceID, serviceAmount));
			КонецЦикла;
		КонецЕсли; 
		Если ТекЗаказ.Получить("taximeter") <> Неопределено Тогда 
			taximeter = ТекЗаказ.Получить("taximeter");
			Если taximeter.Получить("transportingDistance") <> Неопределено Тогда
				Таксометр.transportingDistance = taximeter.Получить("transportingDistance");
			КонецЕсли; 
			Если taximeter.Получить("transportingDuration") <> Неопределено Тогда
				Таксометр.transportingDuration = taximeter.Получить("transportingDuration");
			КонецЕсли;
			Если taximeter.Получить("waitingTime") <> Неопределено Тогда
				Таксометр.waitingTime = taximeter.Получить("waitingTime");
			КонецЕсли;
			Если taximeter.Получить("pickupDistance") <> Неопределено Тогда
				Таксометр.pickupDistance = taximeter.Получить("pickupDistance");
			КонецЕсли;
			Если taximeter.Получить("pickupDuration") <> Неопределено Тогда
				Таксометр.pickupDuration = taximeter.Получить("pickupDuration");
			КонецЕсли; 
			Если taximeter.Получить("pickupStartDate") <> Неопределено Тогда
				Таксометр.pickupStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(taximeter.Получить("pickupStartDate"), флОшибка);
			КонецЕсли;
			Если taximeter.Получить("waitingStartDate") <> Неопределено Тогда
				Таксометр.waitingStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(taximeter.Получить("waitingStartDate"), флОшибка);
			КонецЕсли;
			Если taximeter.Получить("factStartTime") <> Неопределено Тогда
				Таксометр.factStartTime = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(taximeter.Получить("factStartTime"), флОшибка);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ТекущийGUID = Неопределено Тогда  
			НовСтр = ТабЗаказов.Добавить();
			НовСтр.orderID        = ТекущийGUID;
			НовСтр.currentStatus  = currentStatus;
			НовСтр.cancelled      = cancelled;
			НовСтр.isPaid         = isPaid;
			НовСтр.services       = массивУслуг;
			НовСтр.taximeter      = Таксометр;
		КонецЕсли;
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing structures ""order"".';ru='Возникла ошибка при разборе структуры ""order"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateTaxiOrder';ru='ДесериализоватьUpdateTaxiOrder'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабЗаказов;
	КонецПопытки;
	
	Попытка
		Для Каждого ТекСтр Из ТабЗаказов Цикл 
			ТекСтр.orderRef = Документы.такЗаказТакси.ПолучитьСсылку(ТекСтр.orderID); 
			Для Каждого ТекСтр Из ТекСтр.services Цикл 
				ТекСтр.Вставить("serviceRef",  Справочники.Номенклатура.ПолучитьСсылку(ТекСтр.serviceID));
			КонецЦикла;
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while receiving document reference by GUID.';ru='Возникла ошибка при получении ссылки на документ по GUID.'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateTaxiOrder';ru='ДесериализоватьUpdateTaxiOrder'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабЗаказов;
	КонецПопытки;
	
	Возврат ТабЗаказов;
	
КонецФункции // ДесериализоватьUpdateTaxiOrder()

// Функция предназначена для преобразования xml-строки с данными о удаляемых картинках по 
// маршрутным листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о удаляемых картинках
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   массив - массив GUID удаляемых картинок
//
Функция ДесериализоватьDeleteImages(Знач requestData, флОшибка) Экспорт
	
	УдаляемыеФайлы = Новый Массив();
	
	Если ТипЗнч(requestData) = Тип("Массив") Тогда
		мсвКартинок = requestData;
	Иначе
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(requestData);
		мсвКартинок = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();  
	КонецЕсли; 
	
	Попытка
		Для Каждого ТекКартинка Из мсвКартинок Цикл  
			Если ТекКартинка.Получить("image") <> Неопределено Тогда  
				ТекущийGUID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекКартинка.Получить("image"), флОшибка);
				
				Если флОшибка Тогда 
					ВызватьИсключение НСтр("en='Error while parsing GUID in the image field.';ru='Ошибка разбора GUID в поле image.'");
				КонецЕсли;
				
				УдаляемыеФайлы.Добавить(ТекущийGUID);
			КонецЕсли;
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing the structure ""requestData"". Description of error:';ru='Возникла ошибка при разборе структуры ""requestData"". Описание ошибки:'") + Символы.ПС + ОписаниеОшибки();
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьDeleteImages';ru='ДесериализоватьDeleteImages'"), ТекстНСТР);
		флОшибка = Истина;
	КонецПопытки;
	
	Возврат УдаляемыеФайлы;
	
КонецФункции

