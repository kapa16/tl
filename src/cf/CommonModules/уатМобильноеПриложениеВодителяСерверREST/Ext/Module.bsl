// Функция предназначена для преобразования таблицы пользователей мобильного приложения в JSON
//
// Параметры:
//  ТабUsers - таблица значений - таблица, содержащая данные о пользователях мобильного приложения
//
// Возвращаемое значение:
//   Строка  - JSON, сформированная на основе параметра "ТабUsers"
//
Функция СериализоватьUsersToUpdate(Знач ВыборкаЛогин, ЕстьДанные) Экспорт

	МассивПользователей = Новый Массив();
	
	Пока ВыборкаЛогин.Следующий() Цикл 
		СтруктураДанныч = Новый Структура();
		СтруктураДанныч.Вставить("login",  ВыборкаЛогин.Логин);
		
		мВыборкаДетально = ВыборкаЛогин.Выбрать(); 
		МассивСобытий = Новый Массив();
		Пока мВыборкаДетально.Следующий() Цикл
			Если ТипЗнч(мВыборкаДетально.Объект) = Тип("ДокументСсылка.уатМаршрутныйЛист")
				И МассивСобытий.Найти("route") = Неопределено Тогда
				МассивСобытий.Добавить("route");
			ИначеЕсли ТипЗнч(мВыборкаДетально.Объект) = Тип("ДокументСсылка.уатЗаявкаНаРемонт")
				И МассивСобытий.Найти("repair") = Неопределено Тогда
				МассивСобытий.Добавить("repair");
			ИначеЕсли ТипЗнч(мВыборкаДетально.Объект) = Тип("СправочникСсылка.уатЧаты")
				И МассивСобытий.Найти("message") = Неопределено Тогда
				МассивСобытий.Добавить("message");
			ИначеЕсли ТипЗнч(мВыборкаДетально.Объект) = Тип("ДокументСсылка.уатПутевойЛист")
				И МассивСобытий.Найти("waybill") = Неопределено Тогда
				МассивСобытий.Добавить("waybill");
			ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси()
				И ТипЗнч(мВыборкаДетально.Объект) = Тип("ДокументСсылка.такЗаказТакси")
				И МассивСобытий.Найти("taxi") = Неопределено Тогда
				МассивСобытий.Добавить("taxi");
			КонецЕсли; 
			
		КонецЦикла;
		СтруктураДанныч.Вставить("events", МассивСобытий); 
		МассивПользователей.Добавить(СтруктураДанныч);
		
		ЕстьДанные = Истина;
	КонецЦикла;  
	
	мсвЭлементов = Новый Массив();
	Для Каждого ТекСтрока Из МассивПользователей Цикл 
		user = Новый Соответствие();
		user.Вставить("login",    ТекСтрока.login);
		user.Вставить("events",   ТекСтрока.events);
		мсвЭлементов.Добавить(user);
	КонецЦикла;  
	
	ЗначениеJSON = Новый Соответствие();
	ЗначениеJSON.Вставить("responseData" , мсвЭлементов);
	Возврат ЗначениеJSON;   
	
КонецФункции

// Функция предназначена для получение списка закрепленных ТС
//
// Параметры:
//  ТабVehicles - таблица значений - таблица, содержащая данные об автосервисах
//
// Возвращаемое значение:
//   Строка  - xml-структура, сформированная на основе параметра "ТабVehicles"
//
Функция СериализоватьGetStatus(Знач ТабStatus) Экспорт
	
	мсвЭлементов = Новый Массив();
	Для Каждого ТекСтр Из ТабStatus Цикл
		
		Status = Новый Соответствие();
		Status.Вставить("StatusID",   Строка(ТекСтр.Ссылка.УникальныйИдентификатор()));
		Status.Вставить("StatusName", Строка(ТекСтр.Ссылка)); 
		
		ХранилищеЦветФона = ТекСтр.ЦветФонаПоУмолчанию;
		Если Не ХранилищеЦветФона = Неопределено Тогда 
			ДанныеЦветФона = ХранилищеЦветФона.Получить();
			Если Не ДанныеЦветФона = Неопределено И ТипЗнч(ДанныеЦветФона) = Тип("Цвет") Тогда
				StatusColor = уатМобильноеПриложениеВодителяСервер.ПолучитьЦвет(ДанныеЦветФона.Красный, ДанныеЦветФона.Зеленый, ДанныеЦветФона.Синий);
			КонецЕсли;
		Иначе
			StatusColor = "#00000000";
		КонецЕсли;
		
		Status.Вставить("StatusColor", StatusColor);
		Status.Вставить("NeedComment", ?(ТекСтр.Ссылка = Справочники.уатСтатусы_уэ.Подтвержден, Ложь, Истина));
		
		мсвЭлементов.Добавить(Status);
	КонецЦикла;   
	
	response = Новый Соответствие();
	response.Вставить("Statuses" , мсвЭлементов);
	
	ЗначениеJSON = Новый Соответствие();
	ЗначениеJSON.Вставить("responseData" , response);
	Возврат ЗначениеJSON; 
	
КонецФункции // СериализоватьCarServices()

// Функция предназначена для формирования ответа web-сервера на выполнение метода "getRouteList". Формирует xml-структуру,
// содержащую данные о маршрутных листах и выполняемых по ним заданиям
//
// Параметры:
//  МаршрутныеЛисты - РезультатЗапроса - результат выполнения запроса, содержащий данные по отправляемым маршрутным листам
//
// Возвращаемое значение:
//   Строка      - xml-структура, сформированная на основе параметра "МаршрутныеЛисты"
//
Функция СериализоватьRouteList(Знач МаршрутныеЛисты) Экспорт
	
	мсвЭлементов = Новый Массив();
	Для Каждого ТекМЛ Из МаршрутныеЛисты.Строки Цикл
		routeList = Новый Соответствие();
		routeList.Вставить("ID",                Строка(ТекМЛ.МаршрутныйЛистСсылка.УникальныйИдентификатор()));
		routeList.Вставить("routeNumber",       ТекМЛ.МаршрутныйЛистНомер);
		routeList.Вставить("vehicle",           ТекМЛ.МаршрутныйЛистТС);
		routeList.Вставить("departurePlanTime", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекМЛ.МаршрутныйЛистДатаОтправленияПлан));
		routeList.Вставить("arrivalPlanTime",   уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекМЛ.МаршрутныйЛистДатаВыполненияПлан));
		routeList.Вставить("comment",           ТекМЛ.МаршрутныйЛистКомментарий); 
		routeList.Вставить("acceptStatus",      ?(ТекМЛ.ПринятВодителем = Перечисления.уатСтатусыПринятияМЛВодителем.Принят, "accepted", ""));
		routeList.Вставить("multigoShortUrl",   ТекМЛ.СсылкаMultiGo);
		
		мсвДокументов = Новый Массив();
		Для Каждого ТекДокумент Из ТекМЛ.СопроводительныеДокументы Цикл
			shippingDocument = Новый Соответствие();
			shippingDocument.Вставить("documentID",     Строка(ТекДокумент.Ссылка.УникальныйИдентификатор()));
			shippingDocument.Вставить("orderNumber",    ТекДокумент.ЗаказНомер); 
			shippingDocument.Вставить("name",           ТекДокумент.Наименование);
			shippingDocument.Вставить("number",         ТекДокумент.НомерДокумента);
			shippingDocument.Вставить("date",           уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекДокумент.ДатаДокумента));
			shippingDocument.Вставить("comment",        ТекДокумент.Комментарий); 
			shippingDocument.Вставить("typeID",         Строка(ТекДокумент.ВидДокумента.УникальныйИдентификатор()));
			shippingDocument.Вставить("processingDate", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекДокумент.ДатаОбработкиВодителемВМобильномПриложении));
			shippingDocument.Вставить("partner",        Строка(ТекДокумент.Контрагент));
			Если ЗначениеЗаполнено(ТекДокумент.ПунктНазначения) Тогда
				shippingDocument.Вставить("pointID",   Строка(ТекДокумент.ПунктНазначения.УникальныйИдентификатор()));
				shippingDocument.Вставить("pointName", Строка(ТекДокумент.ПунктНазначения));
			КонецЕсли;
			мсвДокументов.Добавить(shippingDocument);  
		КонецЦикла;
		routeList.Вставить("shippingDocuments",  мсвДокументов);
		
		мсвЗаказов = Новый Массив();
		ХешСумма       = "";
		ХешСуммаДанные = Новый ЗаписьXML;
		ХешСуммаДанные.УстановитьСтроку();
		
		НомерПункта    = 0;
		НомерСтроки    = 0;
		ТекПунктСсылка = Неопределено;   
		ВремяПоЗаказам = уатМобильноеПриложениеВодителяСервер.ПолучитьВремяОтправленияДоставкиПоЗаказам(ТекМЛ.МаршрутныйЛистСсылка);
		Для Каждого ТекЗаказ Из ТекМЛ.Строки Цикл
			order = Новый Соответствие();
			order.Вставить("orderNumber",    ТекЗаказ.ЗаказНомер);  
			
			ХешСуммаДанные.ЗаписатьБезОбработки(ТекЗаказ.ЗаказНомер);
			
			order.Вставить("partner",        ТекЗаказ.КонтрагентНаименование); 
			
			ХешСуммаДанные.ЗаписатьБезОбработки(ТекЗаказ.КонтрагентНаименование);
			
			Если ЗначениеЗаполнено(ТекЗаказ.ГрузоотправительСсылка) Тогда 
				order.Вставить("consignor", ТекЗаказ.ГрузоотправительСсылка.Наименование);
			Иначе
				order.Вставить("consignor", ТекЗаказ.КонтрагентНаименование);
			КонецЕсли;  
			order.Вставить("multigoDescription", ТекЗаказ.ОтветMultiGo);
			order.Вставить("signature",          Строка(ТекЗаказ.Подпись));
			order.Вставить("mark",               ТекЗаказ.ОценкаСервиса);  
			
			мсвКонтактов = Новый Массив();
			Если ЗначениеЗаполнено(ТекЗаказ.ТелефонКонтрагента) Или ЗначениеЗаполнено(ТекЗаказ.ПочтаКонтрагента) Тогда 
				contact = Новый Соответствие();
				contact.Вставить("ID",   Строка(ТекЗаказ.КонтрагентСсылка.УникальныйИдентификатор()));
				contact.Вставить("name", ТекЗаказ.КонтрагентКИ.Наименование); 
				Если ЗначениеЗаполнено(ТекЗаказ.ТелефонКонтрагента) Тогда 
					contact.Вставить("phone", ТекЗаказ.ТелефонКонтрагента);
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаказ.ПочтаКонтрагента) Тогда 
					contact.Вставить("email", ТекЗаказ.ПочтаКонтрагента);
				КонецЕсли;
				contact.Вставить("role", "partner");  
				мсвКонтактов.Добавить(contact);
			КонецЕсли;   
			
			КонтрагентСсылка = Неопределено;
			Если ТекЗаказ.ЗаказFTL Тогда
				ЗаполнитьКонтИнформациюFTLЗаказа(ТекЗаказ.ЗаказСсылка, ТекЗаказ.ПунктСсылка, мсвКонтактов, КонтрагентСсылка);
				Если ЗначениеЗаполнено(ТекЗаказ.ТелефонОтветственного) Или ЗначениеЗаполнено(ТекЗаказ.ПочтаОтветственного) Тогда
					contact = Новый Соответствие();
					contact.Вставить("ID",   Строка(ТекЗаказ.ОтветственныйПоЗаказу.УникальныйИдентификатор()));
					contact.Вставить("name", ТекЗаказ.ОтветственныйПоЗаказу.Наименование); 
					Если ЗначениеЗаполнено(ТекЗаказ.ТелефонОтветственного) Тогда 
						contact.Вставить("phone", ТекЗаказ.ТелефонОтветственного);
					КонецЕсли;
					Если ЗначениеЗаполнено(ТекЗаказ.ПочтаОтветственного) Тогда 
						contact.Вставить("email", ТекЗаказ.ПочтаОтветственного);
					КонецЕсли;
					contact.Вставить("role", "responsible");  
					мсвКонтактов.Добавить(contact);
				КонецЕсли;
			Иначе
				Если ЗначениеЗаполнено(ТекЗаказ.ТелефонГрузоотправителя) Или ЗначениеЗаполнено(ТекЗаказ.ПочтаГрузоотправителя) Тогда 
					contact = Новый Соответствие();
					contact.Вставить("ID",   Строка(ТекЗаказ.ГрузоотправительСсылка.УникальныйИдентификатор()));
					contact.Вставить("name", ТекЗаказ.ГрузоотправительКИ.Наименование); 
					Если ЗначениеЗаполнено(ТекЗаказ.ТелефонГрузоотправителя) Тогда 
						contact.Вставить("phone", ТекЗаказ.ТелефонГрузоотправителя);
					КонецЕсли;
					Если ЗначениеЗаполнено(ТекЗаказ.ПочтаГрузоотправителя) Тогда 
						contact.Вставить("email", ТекЗаказ.ПочтаГрузоотправителя);
					КонецЕсли;
					contact.Вставить("role", "sender");  
					мсвКонтактов.Добавить(contact); 
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ТекЗаказ.ТелефонГрузополучателя) Или ЗначениеЗаполнено(ТекЗаказ.ПочтаГрузополучателя) Тогда
					contact = Новый Соответствие();
					contact.Вставить("ID",   Строка(ТекЗаказ.ГрузополучательСсылка.УникальныйИдентификатор()));
					contact.Вставить("name", ТекЗаказ.ГрузополучательКИ.Наименование); 
					Если ЗначениеЗаполнено(ТекЗаказ.ТелефонГрузополучателя) Тогда 
						contact.Вставить("phone", ТекЗаказ.ТелефонГрузополучателя);
					КонецЕсли;
					Если ЗначениеЗаполнено(ТекЗаказ.ПочтаГрузополучателя) Тогда 
						contact.Вставить("email", ТекЗаказ.ПочтаГрузополучателя);
					КонецЕсли;
					contact.Вставить("role", "receiver");  
					мсвКонтактов.Добавить(contact); 
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ТекЗаказ.ТелефонОтветственного) Или ЗначениеЗаполнено(ТекЗаказ.ПочтаОтветственного) Тогда 
					contact = Новый Соответствие();
					contact.Вставить("ID",   Строка(ТекЗаказ.ОтветственныйПоЗаказу.УникальныйИдентификатор()));
					contact.Вставить("name", ТекЗаказ.ОтветственныйПоЗаказу.Наименование); 
					Если ЗначениеЗаполнено(ТекЗаказ.ТелефонОтветственного) Тогда 
						contact.Вставить("phone", ТекЗаказ.ТелефонОтветственного);
					КонецЕсли;
					Если ЗначениеЗаполнено(ТекЗаказ.ПочтаОтветственного) Тогда 
						contact.Вставить("email", ТекЗаказ.ПочтаОтветственного);
					КонецЕсли;
					contact.Вставить("role", "responsible");  
					мсвКонтактов.Добавить(contact);
				КонецЕсли;
			КонецЕсли;
			order.Вставить("contacts",  мсвКонтактов); 
			Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
				order.Вставить("consignee", КонтрагентСсылка.Наименование);
			ИначеЕсли ЗначениеЗаполнено(ТекЗаказ.ГрузополучательСсылка) Тогда 
				order.Вставить("consignee", ТекЗаказ.ГрузополучательСсылка.Наименование);
			Иначе
				order.Вставить("consignee", ТекЗаказ.КонтрагентНаименование);
			КонецЕсли;
			order.Вставить("operation", уатМобильноеПриложениеВодителяСервер.СериализоватьТипТочкиМаршрута(ТекЗаказ.ТипТочкиМаршрута, ТекЗаказ.ПунктЭтоГараж));
			
			Если ТекЗаказ.Строки.Количество() > 0 Тогда  
				Если НЕ ЗначениеЗаполнено(ТекЗаказ.Строки[0].ЗаказНомер) Тогда
					order.Вставить("skipPoint", ?(ТекЗаказ.СлужебныйТипПункта, 1, 0));
				Иначе
					order.Вставить("skipPoint", 0); 
				КонецЕсли;
			Иначе
				order.Вставить("skipPoint", ?(ТекЗаказ.СлужебныйТипПункта, 1, 0)); 
			КонецЕсли;  
			
			Если ТекПунктСсылка <> ТекЗаказ.ПунктСсылка Тогда
				НомерПункта    = НомерПункта + 1;
				ТекПунктСсылка = ТекЗаказ.ПунктСсылка;
			КонецЕсли; 
			
			point = Новый Соответствие();
			Если ТипЗнч(ТекПунктСсылка) = Тип("СправочникСсылка.уатПунктыНазначения") Тогда
				point.Вставить("pointID", Строка(ТекПунктСсылка.УникальныйИдентификатор()));
			Иначе
				point.Вставить("pointID", "00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			point.Вставить("pointNumber", НомерПункта); 
			
			ХешСуммаДанные.ЗаписатьБезОбработки(Формат(НомерПункта, "ЧН=0; ЧГ=0"));
			
			point.Вставить("pointName",   ТекЗаказ.ПунктНаименование);
			
			ХешСуммаДанные.ЗаписатьБезОбработки(ТекЗаказ.ПунктНаименование);
			
			point.Вставить("address",      ТекЗаказ.ПунктАдрес);
			point.Вставить("lat",          ТекЗаказ.ПунктШирота);
			point.Вставить("lon",          ТекЗаказ.ПунктДолгота);
			point.Вставить("acceptance",   ТекЗаказ.СоздаватьСкладскойАкт); 
			point.Вставить("searchRadius", ТекЗаказ.ПунктРадиусПоиска);  
			order.Вставить("point", point);
			
			Если уатЗащищенныеФункцииСервер.ВариантПоставкиКОРП() Тогда 
				ЗаписатьБлокProductivity(order, ТекЗаказ);
			КонецЕсли;
			
			order.Вставить("stayDuration", СериализоватьВремяЧисломЧЧММ(ТекЗаказ.ВремяСтоянки)); 
			order.Вставить("arrivalPlan",  уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.ПрибытиеПлан)); 
			
			ХешСуммаДанные.ЗаписатьБезОбработки(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.ПрибытиеПлан));
			
			order.Вставить("arrivalFact",   уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.ПрибытиеФакт));
			order.Вставить("departurePlan", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.УбытиеПлан));
			
			ХешСуммаДанные.ЗаписатьБезОбработки(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.УбытиеПлан));
			
			order.Вставить("departureFact", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекЗаказ.УбытиеФакт));
			
			Если ТекЗаказ.ТипТочкиМаршрута = ПредопределенноеЗначение("Перечисление.уатТипыТочекМаршрута.Погрузка") Тогда 
				ОкноС  = ВремяПоЗаказам.Получить(НомерСтроки).ОтправлениеС;
				ОкноПо = ВремяПоЗаказам.Получить(НомерСтроки).ОтправлениеПо;
			Иначе 
				ОкноС  = ВремяПоЗаказам.Получить(НомерСтроки).ДоставкаС;
				ОкноПо = ВремяПоЗаказам.Получить(НомерСтроки).ДоставкаПо;
			КонецЕсли;
			ОкноС  = Дата('00010101') + (ОкноС - НачалоДня(ОкноС));
			ОкноПо = Дата('00010101') + (ОкноПо - НачалоДня(ОкноПо));
			НомерСтроки = НомерСтроки + 1;
			
			Если ЗначениеЗаполнено(ОкноС) 
				ИЛИ ЗначениеЗаполнено(ОкноПо) Тогда 
				order.Вставить("timeWindowStart", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ОкноС)); 
				order.Вставить("timeWindowEnd",   уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ОкноПо));
			КонецЕсли;
			
			мсвГрузов = Новый Массив();
			Для Каждого ТекНоменклатура Из ТекЗаказ.Строки Цикл 
				item = Новый Соответствие();
				item.Вставить("ID",          ТекНоменклатура.ГУИДСтроки);
				item.Вставить("line",        ТекНоменклатура.НомерСтроки);
				item.Вставить("name",        ТекНоменклатура.Номенклатура);
				item.Вставить("unit",        ТекНоменклатура.ЕдиницаИзмерения);
				item.Вставить("amount",      ТекНоменклатура.Количество);
				item.Вставить("amountPlace", ТекНоменклатура.КоличествоМест);
				item.Вставить("weight",      ТекНоменклатура.ВесБрутто);
				item.Вставить("volume",      ТекНоменклатура.Объем);
				item.Вставить("isDone",      ТекНоменклатура.Выполнен);
				мсвГрузов.Добавить(item);
			КонецЦикла;
			order.Вставить("items",        мсвГрузов);
			order.Вставить("orderComment", ТекЗаказ.КомментарийПоЗаказу);

			мсвЗаказов.Добавить(order);
		КонецЦикла; 
		routeList.Вставить("orders",  мсвЗаказов);
		
		ХешСуммаДанные = ХешСуммаДанные.Закрыть();
		ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.CRC32);
		ХешированиеДанных.Добавить(ХешСуммаДанные); 
		
		routeList.Вставить("routeVersion",  ХешированиеДанных.ХешСумма);
		мсвЭлементов.Добавить(routeList);
	КонецЦикла;
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , мсвЭлементов);
	Возврат responseData;

КонецФункции // СериализоватьRouteList()

// Функция предназначена для получение путевых листов
//
// Параметры:
//  ТабVehicles - таблица значений - таблица, содержащая данные об автосервисах
//
// Возвращаемое значение:
//   Строка  - xml-структура, сформированная на основе параметра "ТабVehicles"
//
Функция СериализоватьWaybills(Знач Waybill, СоответвиеПрицепов) Экспорт
	
	СоответвиеРеквизитовЭПЛ = уатМобильноеПриложениеВодителяСервер.ЗаполнитьРеквизитыЭПЛ(Waybill);
	
	мсвЭлементов = Новый Массив();
	Пока Waybill.Следующий() Цикл
		текWaybill = Новый Соответствие();
		текWaybill.Вставить("orderID", Строка(Waybill.Ссылка.УникальныйИдентификатор()));
		
		QR       = Ложь;
		SignedT1 = 0;
		SignedT2 = 0;
		SignedT3 = 0;
		SignedT4 = 0;
		SignedT5 = 0;
		SignedT6 = 0;
		ElectronicWaybillCreated = 0;
		QRCodeValidFrom          = Неопределено;
		QRCodeValidUntil         = Неопределено;     
		ТекРеквизитыЭПЛ = СоответвиеРеквизитовЭПЛ.Получить(Waybill.Ссылка); 
		Если ТекРеквизитыЭПЛ <> Неопределено Тогда 
			Если ТекРеквизитыЭПЛ.Свойство("QR") Тогда
				QR = ТекРеквизитыЭПЛ.QR;
			КонецЕсли;
			Если ТекРеквизитыЭПЛ.Свойство("ElectronicWaybillCreated") Тогда
				ElectronicWaybillCreated = ТекРеквизитыЭПЛ.ElectronicWaybillCreated;
			КонецЕсли; 
			Если ТекРеквизитыЭПЛ.Свойство("SignedT1") Тогда
				SignedT1 = ТекРеквизитыЭПЛ.SignedT1;
			КонецЕсли; 
			Если ТекРеквизитыЭПЛ.Свойство("SignedT2") Тогда
				SignedT2 = ТекРеквизитыЭПЛ.SignedT2;
			КонецЕсли;
			Если ТекРеквизитыЭПЛ.Свойство("SignedT3") Тогда
				SignedT3 = ТекРеквизитыЭПЛ.SignedT3;
			КонецЕсли; 
			Если ТекРеквизитыЭПЛ.Свойство("SignedT4") Тогда
				SignedT4 = ТекРеквизитыЭПЛ.SignedT4;
			КонецЕсли;  
			Если ТекРеквизитыЭПЛ.Свойство("SignedT5") Тогда
				SignedT5 = ТекРеквизитыЭПЛ.SignedT5;
			КонецЕсли;
			Если ТекРеквизитыЭПЛ.Свойство("SignedT6") Тогда
				SignedT6 = ТекРеквизитыЭПЛ.SignedT6;
			КонецЕсли; 
			Если ТекРеквизитыЭПЛ.Свойство("QRCodeValidFrom") Тогда
				QRCodeValidFrom = ТекРеквизитыЭПЛ.QRCodeValidFrom;
			КонецЕсли; 
			Если ТекРеквизитыЭПЛ.Свойство("QRCodeValidUntil") Тогда
				QRCodeValidUntil = ТекРеквизитыЭПЛ.QRCodeValidUntil;
			КонецЕсли;
		КонецЕсли; 
		текWaybill.Вставить("QR", QR);  
		текWaybill.Вставить("ElectronicWaybillCreated", ElectronicWaybillCreated);
		текWaybill.Вставить("SignedT1", SignedT1);
		текWaybill.Вставить("SignedT2", SignedT2);
		текWaybill.Вставить("SignedT3", SignedT3);
		текWaybill.Вставить("SignedT4", SignedT4);
		текWaybill.Вставить("SignedT5", SignedT5);
		текWaybill.Вставить("SignedT6", SignedT6);
		
		Если QRCodeValidFrom <> Неопределено Тогда
			текWaybill.Вставить("QRCodeValidFrom", QRCodeValidFrom);
		КонецЕсли;
		Если QRCodeValidUntil <> Неопределено Тогда
			текWaybill.Вставить("QRCodeValidUntil", QRCodeValidUntil);
		КонецЕсли;
		
		текWaybill.Вставить("status",            Строка(?(Waybill.ЗакрытВодителем, Нстр("en = 'Closed'; ru = 'Закрыт'"), Нстр("en = 'Open'; ru = 'Открыт'"))));
		текWaybill.Вставить("editable",          ?(Waybill.ЗакрытВодителем, Ложь, Истина));
		текWaybill.Вставить("orderNumber",       Строка(Waybill.Номер));
		текWaybill.Вставить("waybillStartDate",  уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(Waybill.ДатаВыезда));
		текWaybill.Вставить("waybillFinishDate", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(Waybill.ДатаВозвращения));
		текWaybill.Вставить("vehicleID",         Строка(Waybill.ТС.УникальныйИдентификатор()));
		текWaybill.Вставить("vehicleName",       Строка(Waybill.ТСНаименование));
		текWaybill.Вставить("waybillType",       Строка(Waybill.ВидПЛ));
		текWaybill.Вставить("driver",            Строка(Waybill.Водитель));
		
		мсвТС = Новый Массив();
		МассивПрицепов = СоответвиеПрицепов.Получить(Waybill.Ссылка);
		Если МассивПрицепов <> Неопределено Тогда
			Для Каждого ТекПрицеп Из МассивПрицепов Цикл  
				vehicle = Новый Соответствие();
				vehicle.Вставить("vehicleID",   Строка(ТекПрицеп.ТС.УникальныйИдентификатор()));
				vehicle.Вставить("vehicleName", Строка(ТекПрицеп.ТСНаименование)); 
				vehicle.Вставить("trailer",     Истина);
				vehicle.Вставить("fuelTank",    ТекПрицеп.НаличиеТопливногоБака); 
				мсвТС.Добавить(vehicle);
			КонецЦикла; 
		КонецЕсли;
		текWaybill.Вставить("vehicles",           мсвТС);
		текWaybill.Вставить("odometerDeparture",  Waybill.СпидометрВыезда);
		текWaybill.Вставить("odometerReturn",     Waybill.СпидометрВозвращения);  
		
		ОстатокТопливаВыезд   = 0;
		ОстатокТопливаВозврат = 0;
		ВыдатьКоличествоГорючего = 0;
		Для Каждого ТекРасход Из Waybill.Ссылка.РасходГСМ Цикл
			Если Waybill.ТС = ТекРасход.ТС И Waybill.ТранспортноеСредствоМодельОсновноеТопливо = ТекРасход.ГСМ Тогда
				ОстатокТопливаВыезд   = ТекРасход.ОстатокПриВыезде;
				ОстатокТопливаВозврат = ТекРасход.ОстатокПриВозвращении;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		текWaybill.Вставить("remainOfFuelDeparture", ОстатокТопливаВыезд);
		текWaybill.Вставить("remainOfFuelReturn",    ОстатокТопливаВозврат); 
		
		мсвЗаправки = Новый Массив();
		Заправки = Waybill.Выбрать();
		Пока Заправки.Следующий() Цикл
			Если НЕ ЗначениеЗаполнено(Заправки.Заправка) Тогда
				Продолжить;
			КонецЕсли; 
			fueling = Новый Соответствие();
			fueling.Вставить("fuellingID",   Строка(Заправки.Заправка.УникальныйИдентификатор()));
			fueling.Вставить("lineNumber",   Заправки.НомерСтроки);
			fueling.Вставить("gasStationID", Строка(Заправки.АЗС.УникальныйИдентификатор()));
			fueling.Вставить("gasStation",   Строка(Заправки.АЗС));
			fueling.Вставить("vehicleID",    Строка(Заправки.ЗаправкаТС.УникальныйИдентификатор()));
			fueling.Вставить("vehicleName",  Строка(Заправки.ЗаправкаТСНаименование));
			Попытка
				ИмяПеречисления = Заправки.ВидДвиженияГСМ.Метаданные().Имя;
				
				ИндексЗначенияПеречисления = Перечисления[ИмяПеречисления].Индекс(Заправки.ВидДвиженияГСМ);
				
				ИмяЗначенияПеречисления = Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления[ИндексЗначенияПеречисления].Имя;
				
				fueling.Вставить("fuellingTypeID", Строка(ИмяЗначенияПеречисления));
			Исключение
				fueling.Вставить("fuellingTypeID", "");
			КонецПопытки; 
			fueling.Вставить("fuellingType", Строка(Заправки.ВидДвиженияГСМ));
			fueling.Вставить("fuelID",       Строка(Заправки.ГСМ.УникальныйИдентификатор())); 
			fueling.Вставить("fuel",         Строка(Заправки.ГСМ));
			fueling.Вставить("fuellingDate", уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(Заправки.ДатаЗаправки));
			fueling.Вставить("fuelCardID",   Строка(Заправки.ПластиковаяКарта.УникальныйИдентификатор()));
			fueling.Вставить("fuelCard",     Строка(Заправки.ПластиковаяКарта));
			fueling.Вставить("quantity",     Заправки.Количество);
			ВыдатьКоличествоГорючего = ВыдатьКоличествоГорючего + Заправки.Количество;
			
			fueling.Вставить("sum", Заправки.Сумма);
			
			мсвЗаправки.Добавить(fueling);
		КонецЦикла;
		текWaybill.Вставить("fueling",      мсвЗаправки);
		текWaybill.Вставить("fuelQuantity", ВыдатьКоличествоГорючего);
		
		мсвЭлементов.Добавить(текWaybill);
	КонецЦикла;
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , мсвЭлементов);
	Возврат responseData;

КонецФункции // СериализоватьCarServices()

// Функция предназначена для получение заявок на ремонт по ТС
//
// Параметры:
//  ТабVehicles - таблица значений - таблица, содержащая данные об автосервисах
//
// Возвращаемое значение:
//   Строка  - xml-структура, сформированная на основе параметра "ТабVehicles"
//
Функция СериализоватьOrdersForRepair(Знач OrdersForRepair) Экспорт
	
	мсвЭлементов = Новый Массив();
	Для Каждого ТекСтр Из OrdersForRepair Цикл
		OrderForRepair = Новый Соответствие();
		OrderForRepair.Вставить("orderID",          Строка(ТекСтр.Ссылка.УникальныйИдентификатор()));
		OrderForRepair.Вставить("status",           Строка(ТекСтр.СтатусВыполненияИмяПредопределенныхДанных));
		OrderForRepair.Вставить("driverStatusID",   Строка(ТекСтр.СтатусПодтвержденияВодителем.УникальныйИдентификатор()));
		OrderForRepair.Вставить("driverStatusName", Строка(ТекСтр.СтатусПодтвержденияВодителем));
		OrderForRepair.Вставить("driverComment",    Строка(ТекСтр.КомментарийВодителя));
		OrderForRepair.Вставить("statusName",       Строка(ТекСтр.СтатусВыполнения));
		OrderForRepair.Вставить("editable",         ?(ТекСтр.СтатусВыполнения = Справочники.уатСтатусы_уэ.Новый
			И НЕ ТекСтр.ДругойВодитель, Истина, Ложь));
		OrderForRepair.Вставить("orderNumber",       Строка(ТекСтр.Номер));
		OrderForRepair.Вставить("repairStartDate",   уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекСтр.ДатаНачала));
		OrderForRepair.Вставить("repairFinishDate",  уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(ТекСтр.ДатаОкончания)); 
		OrderForRepair.Вставить("vehicleID",         Строка(ТекСтр.ТС.УникальныйИдентификатор())); 
		OrderForRepair.Вставить("vehicleName",       Строка(ТекСтр.ТСНаименование));
		OrderForRepair.Вставить("driver",            Строка(ТекСтр.Водитель)); 
		OrderForRepair.Вставить("repairTypeID",      Строка(ТекСтр.ВидОбслуживания.УникальныйИдентификатор())); 
		OrderForRepair.Вставить("repairTypeName",    Строка(ТекСтр.ВидОбслуживания)); 
		OrderForRepair.Вставить("RepairMethod",      ?(ТекСтр.СпособРемонта = Перечисления.уатСпособыРемонта.Автосервис, 0, 1)); 
		Если НЕ ЗначениеЗаполнено(ТекСтр.Контрагент) Тогда
			OrderForRepair.Вставить("carServiceID",  "00000000-0000-0000-0000-000000000000");
		Иначе
			OrderForRepair.Вставить("carServiceID",  Строка(ТекСтр.Контрагент.УникальныйИдентификатор()));
		КонецЕсли; 
		OrderForRepair.Вставить("carServiceName",    Строка(ТекСтр.Контрагент));
		OrderForRepair.Вставить("carServiceAddress", Строка(ТекСтр.МестоРемонта));
		OrderForRepair.Вставить("repairReason",      Строка(ТекСтр.ПричинаОбращения));
		
		мсвРабот = Новый Массив();
		Для Каждого ТекСтрРаботы Из ТекСтр.Работы Цикл
			мсвРабот.Добавить(Строка(ТекСтрРаботы.Работа));
		КонецЦикла;
		OrderForRepair.Вставить("works",      мсвРабот);
		мсвЗапчастей = Новый Массив();
		Для Каждого ТекСтрРаботы Из ТекСтр.Материалы Цикл
			мсвРабот.Добавить(Строка(ТекСтрРаботы.Номенклатура));
		КонецЦикла;
		OrderForRepair.Вставить("carParts",   мсвЗапчастей);

		мсвЭлементов.Добавить(OrderForRepair);
	КонецЦикла;

	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , мсвЭлементов);
	Возврат responseData;
	
КонецФункции // СериализоватьCarServices()

// Функция предназначена для формирования ответа web-сервера на выполнение метода "SendImage". Формирует xml-структуру,
// содержащую данные о созданных картинках
//
// Параметры:
//  СозданныеФайлы - массив - массив уникальных идентификаторов
//
// Возвращаемое значение:
//   Строка      - xml-структура, сформированная на основе параметра "СозданныеФайлы"
//
Функция СериализоватьSendImage(Знач СозданныеФайлы) Экспорт
	
	ТекФайл = Новый Соответствие();
	Если СозданныеФайлы.Количество() > 0 Тогда 
		ТекФайл.Вставить("image", Строка(СозданныеФайлы[0]));
	КонецЕсли;
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , ТекФайл);
	Возврат responseData;

КонецФункции

Функция СериализоватьGetMileageConsumptionMonitoring(odometerDeparture, remainOfFuelDeparture) Экспорт
	
	СтруктураДанных = Новый Соответствие();
	СтруктураДанных.Вставить("odometerDeparture" ,     odometerDeparture);
	СтруктураДанных.Вставить("remainOfFuelDeparture" , remainOfFuelDeparture); 
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , СтруктураДанных);
	Возврат responseData;
		
КонецФункции

Функция СериализоватьGetWaybillPDF(Знач ФайлДляПередачи) Экспорт
	
	СтруктураДанных = Новый Соответствие();
	СтруктураДанных.Вставить("WaybillPDF" , Base64Строка(ФайлДляПередачи));
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , СтруктураДанных);
	Возврат responseData;
	
КонецФункции

Функция СериализоватьGetQRcode(Знач Картинка) Экспорт
	
	СтруктураДанных = Новый Соответствие();
	СтруктураДанных.Вставить("image" , СтрЗаменить(Картинка, Символы.ПС, ""));
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , СтруктураДанных);
	Возврат responseData;
	
КонецФункции

Функция СериализоватьTaxiOrders(Знач TaxiOrders, ОтправлятьАдресНазначенияВОткрытыхЗаказах, ОдинЗаказ = Ложь) Экспорт
	
	// Начало "OrdersForRepairs"
	мсвЭлементов = Новый Массив(); 
	текOrder     = Новый Соответствие();
	Пока TaxiOrders.Следующий() Цикл
		текOrder = Новый Соответствие();
		Если TaxiOrders.ЕстьТаксометр Тогда
			Таксометр = Новый Структура("transportingDistance,transportingDuration,waitingTime,pickupDistance,pickupDuration,pickupStartDate,waitingStartDate,factStartTime");
			Таксометр.transportingDistance = TaxiOrders.ТаксометрПробегПоПоездке;
			Таксометр.transportingDuration = ?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяПоПоездке), 0, TaxiOrders.ТаксометрВремяПоПоездке * 60);
			Таксометр.waitingTime          = ?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяОжидания), 0, TaxiOrders.ТаксометрВремяОжидания * 60);
			Таксометр.pickupDistance       = TaxiOrders.ТаксометрПробегПодачи;
			Таксометр.pickupDuration       = ?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяПодачи), 0, TaxiOrders.ТаксометрВремяПодачи * 60);
			Таксометр.pickupStartDate      = уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаНаПодачу);
			Таксометр.waitingStartDate     = уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаОжидания);
			Таксометр.factStartTime        = уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаПоездки);
			
			текOrder.Вставить("taximeter", Таксометр);
		КонецЕсли;
		текOrder.Вставить("orderID",     Строка(TaxiOrders.Ссылка.УникальныйИдентификатор()));
		текOrder.Вставить("orderNumber", Строка(TaxiOrders.Номер));
		текOrder.Вставить("timeStart",   уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяПодачи)); 
		текOrder.Вставить("latStart",    TaxiOrders.ЛатПодачи); 
		текOrder.Вставить("lonStart",    TaxiOrders.ЛонПодачи);
		
		Если (TaxiOrders.openOrder 
			И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
			ИЛИ НЕ TaxiOrders.openOrder Тогда
			текOrder.Вставить("latEnd",    ?(НЕ ЗначениеЗаполнено(TaxiOrders.ЛатНазначения), 0, TaxiOrders.ЛатНазначения)); 
			текOrder.Вставить("lonEnd",    ?(НЕ ЗначениеЗаполнено(TaxiOrders.ЛонНазначения), 0, TaxiOrders.ЛонНазначения));  

			adrEnd = Строка(TaxiOrders.АдресНазначения);
			Если ЗначениеЗаполнено(TaxiOrders.КомментарийНазначения) тогда
				adrEnd = adrEnd + " (" + TaxiOrders.КомментарийНазначения + ")";
			КонецЕсли;
			текOrder.Вставить("adrEnd",    adrEnd);
		КонецЕсли;
		
		adrStart = Строка(TaxiOrders.АдресПодачи);
		Если ЗначениеЗаполнено(TaxiOrders.КомментарийПодачи) тогда
			adrStart = adrStart + " (" + TaxiOrders.КомментарийПодачи + ")";
		КонецЕсли;
		текOrder.Вставить("adrStart",    adrStart);
		
		СправочникФормаОплаты = TaxiOrders.ФормаОплаты;
		Если СправочникФормаОплаты.ФормаОплаты = Перечисления.уатФормыОплаты.Наличные Тогда
			paymentType = "cash"; 
		Иначе
			paymentType = "card";
		КонецЕсли;
		текOrder.Вставить("paymentType",        Строка(paymentType));
		
		СтруктураОбъектовНастроек = Новый Структура;
		СтруктураОбъектовНастроек.Вставить("Организация",   TaxiOrders.Ссылка.Организация);
		СтруктураОбъектовНастроек.Вставить("Подразделение", TaxiOrders.Ссылка.Подразделение);

		changeMainServices = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ИспользоватьДанныеТаксометраВодительУАТДляПересчетаУслуг); 
		текOrder.Вставить("changeMainServices", changeMainServices);

		changeAdditionalServices = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.РазрешитьПересчетДополнительныхУслугВодительУАТ);  
		текOrder.Вставить("changeAdditionalServices", changeAdditionalServices);
		текOrder.Вставить("openOrder",                TaxiOrders.openOrder);
		текOrder.Вставить("currentStatus",            уатМобильноеПриложениеВодителяСервер.ПолучитьИмяСтатусаЗаказаТакси(TaxiOrders.Статус));
		текOrder.Вставить("notes",                    TaxiOrders.ПримечаниеДиспетчеру);
	
		distance = ?(ЗначениеЗаполнено(TaxiOrders.КоличествоКмФакт), TaxiOrders.КоличествоКмФакт,  TaxiOrders.КоличествоКм);
		
		текOrder.Вставить("distance",  distance);

		duration = ?(ЗначениеЗаполнено(TaxiOrders.КоличествоМинФакт), TaxiOrders.КоличествоМинФакт,  TaxiOrders.КоличествоМин);
		текOrder.Вставить("duration",       duration);
		текOrder.Вставить("factStartTime",  уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяПодачиФактическое));
		текOrder.Вставить("factEndTime",    уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяОкончанияФактическое));
		текOrder.Вставить("isPaid",         TaxiOrders.Оплачено);
		текOrder.Вставить("waitingTime",    TaxiOrders.ВремяОжиданияОбщее);
		
		текOrder.Вставить("waitingTime",    TaxiOrders.ВремяОжиданияОбщее);
		
		contacts = Новый Массив();
		
		customerName  = TaxiOrders.ЗаказчикНаименование;
		customerPhone = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		TaxiOrders.Заказчик, 
		Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента
		);
		
		ДанныеКонтакта = Новый Соответствие();
		ДанныеКонтакта.Вставить("name",  Строка(customerName));
		ДанныеКонтакта.Вставить("phone", Строка(customerPhone));
		ДанныеКонтакта.Вставить("role", "customer");
		contacts.Добавить(ДанныеКонтакта);
		
		Если ЗначениеЗаполнено(TaxiOrders.КонтактноеЛицо) Тогда 
			Если ТипЗнч(TaxiOrders.КонтактноеЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
				Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				TaxiOrders.КонтактноеЛицо, 
				Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
				); 
			Иначе 
				Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				TaxiOrders.КонтактноеЛицо, 
				Справочники.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица
				);
			КонецЕсли;    
			ДанныеКонтакта = Новый Соответствие();
			ДанныеКонтакта.Вставить("name",  Строка(TaxiOrders.КонтактноеЛицоНаименование));
			ДанныеКонтакта.Вставить("phone", Строка(Телефон));
			ДанныеКонтакта.Вставить("role", "contact");
			contacts.Добавить(ДанныеКонтакта);
		КонецЕсли; 
		
		Если TaxiOrders.ЗаказчикЮрФизЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
			customerName  = TaxiOrders.ЗаказчикНаименование;
			customerPhone = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			TaxiOrders.Заказчик, 
			Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента
			);
			
			ДанныеКонтакта = Новый Соответствие();
			ДанныеКонтакта.Вставить("name",  Строка(customerName));
			ДанныеКонтакта.Вставить("phone", Строка(customerPhone));
			ДанныеКонтакта.Вставить("role", "passenger");
			contacts.Добавить(ДанныеКонтакта);
		Иначе
			Если ЗначениеЗаполнено(TaxiOrders.Пассажир) Тогда
				Если ТипЗнч(TaxiOrders.Пассажир) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
					Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
					TaxiOrders.Пассажир, 
					Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
					); 
				Иначе 
					Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
					TaxiOrders.Пассажир, 
					Справочники.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица
					);
				КонецЕсли;

				ДанныеКонтакта = Новый Соответствие();
				ДанныеКонтакта.Вставить("name",  Строка(TaxiOrders.Пассажир));
				ДанныеКонтакта.Вставить("phone", Строка(Телефон));
				ДанныеКонтакта.Вставить("role", "passenger");
				contacts.Добавить(ДанныеКонтакта);
			КонецЕсли; 
		КонецЕсли;
		текOrder.Вставить("contacts",    contacts);
		
		carriageRequirements = Новый Массив();
		Для Каждого ТекХарактеристика Из TaxiOrders.Ссылка.ТребованияКПеревозке Цикл 
			ДанныеЭлемента = Новый Соответствие();
			ДанныеЭлемента.Вставить("requirementID",   Строка(ТекХарактеристика.Характеристика.УникальныйИдентификатор()));
			ДанныеЭлемента.Вставить("requirementName", Строка(ТекХарактеристика.Характеристика));
			carriageRequirements.Добавить(ДанныеЭлемента);
		КонецЦикла;
		текOrder.Вставить("carriageRequirements",    carriageRequirements); 
		
		discountSum = 0;
		
		services = Новый Массив();
		
		НомерСтроки = 1;
		Для Каждого ТекУслуга Из TaxiOrders.Ссылка.Услуги Цикл  
			discountSum = discountSum + ТекУслуга.СуммаСкидки; 
			
			ДанныеЭлемента = Новый Соответствие(); 
			ДанныеЭлемента.Вставить("serviceNumber", НомерСтроки);    
			ДанныеЭлемента.Вставить("serviceID",     Строка(ТекУслуга.Номенклатура.УникальныйИдентификатор()));
			ДанныеЭлемента.Вставить("serviceName",   Строка(ТекУслуга.Номенклатура)); 
			ДанныеЭлемента.Вставить("serviceAmount", ТекУслуга.Количество); 
			Если (TaxiOrders.openOrder 
				И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
				ИЛИ НЕ TaxiOrders.openOrder Тогда
				
				ДанныеЭлемента.Вставить("servicePrice", ТекУслуга.Цена);
				ДанныеЭлемента.Вставить("serviceSum",   ТекУслуга.Сумма);
			КонецЕсли;
			Если ТекУслуга.Трансфер Тогда
				ДанныеЭлемента.Вставить("serviceType", "transfer");
			ИначеЕсли ТекУслуга.Тариф.МетодРасчета = Перечисления.уатМетодыРасчетаПоТарифам.ФиксированнойСуммой Тогда
				ДанныеЭлемента.Вставить("serviceType", "fixed");
			ИначеЕсли ТекУслуга.Тариф.МетодРасчета = Перечисления.уатМетодыРасчетаПоТарифам.ПоПараметруВыработки Тогда
				Если ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ПробегОбщий Тогда
					ДанныеЭлемента.Вставить("serviceType", "distance");
				ИначеЕсли ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ВремяВРаботе Тогда
					ДанныеЭлемента.Вставить("serviceType", "time");
				ИначеЕсли ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ВремяОжидания Тогда
					ДанныеЭлемента.Вставить("serviceType", "waitingTime"); 
				Иначе
					ДанныеЭлемента.Вставить("serviceType", "additional");
				КонецЕсли;
			Иначе   
				ДанныеЭлемента.Вставить("serviceType", "additional");
			КонецЕсли;
			ДанныеЭлемента.Вставить("time", ТекУслуга.Тариф.ПараметрВыработки.Временный);
			services.Добавить(ДанныеЭлемента);
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		текOrder.Вставить("services",    services);
		текOrder.Вставить("discountSum", discountSum);
		
		Если (TaxiOrders.openOrder 
			И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
			ИЛИ НЕ TaxiOrders.openOrder Тогда 
			// Сумма со скидкой 
			текOrder.Вставить("sum",      TaxiOrders.СуммаДокумента + discountSum);
			текOrder.Вставить("totalSum", TaxiOrders.СуммаДокумента);
		КонецЕсли;
		
		мсвЭлементов.Добавить(текOrder);
	КонецЦикла;
	
	Если НЕ ОдинЗаказ Тогда
		responseData = Новый Соответствие();
		responseData.Вставить("responseData" , мсвЭлементов);
		Возврат responseData; 
	Иначе
		responseData = Новый Соответствие();
		responseData.Вставить("responseData" , текOrder);
		Возврат responseData;
	КонецЕсли;
	
КонецФункции // СериализоватьCarServices()

// Функция предназначена для преобразования времени в числовом формате (где целая часть представляет собой количество 
// часов, а дробная - количество минут), используемого в конфигурации, в число секунд.
//
// Параметры:
//  ВремяЧЧММ - дата - дата во внутреннем формате 1С
//
// Возвращаемое значение:
//   Число    - количество секунд, сформированное из переданного времени
//
Функция СериализоватьВремяЧисломЧЧММ(Знач ВремяЧЧММ)
	
	Минуты = (ВремяЧЧММ - Цел(ВремяЧЧММ))*100;
	Часы   = Цел(ВремяЧЧММ);
	
	Секунд = Минуты*60 + Часы*3600;
	
	Возврат Секунд;
	
КонецФункции // СериализоватьВремяЧисломЧЧММ()

// Функция предназначена для получения информации о версии конфигурации и параметров работы мобильного приложения
//
// Параметры:
//  responseData - соответвие - json-соответвие, выходные данные, содержимое определяется контекстом выполняемого метода
//  resultCode   - число  - код результата выполнения
//
// Возвращаемое значение:
//   Булево      - истина - метод выполнен успешно;
//               - ложь   - при выполнении метода возникла ошибка
//
Функция ОбработатьМетодGet1CInfo(responseData, resultCode) Экспорт
	
	// Заполним версию ИБ
	ОписаниеУАТ = Новый Структура("Имя, Версия, ТребуемыеПодсистемы", "", "", Новый Массив);
	// Заполение данных по подсистеме УАТ
	уатОбновлениеИнформационнойБазы.ПриДобавленииПодсистемы(ОписаниеУАТ);
	
	baseInfo = Новый Соответствие();
	baseInfo.Вставить("ver", ОбновлениеИнформационнойБазыСлужебный.ВерсияИБ(ОписаниеУАТ.Имя));
	
	// Заполним хранимые параметры МП
	стрПараметрыМобильногоПриложения = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьПараметрыДляМобильногоПриложения();
	
	Для Каждого ТекПараметр Из стрПараметрыМобильногоПриложения Цикл 
		Если ТипЗнч(ТекПараметр.Значение) = Тип("Булево")
			ИЛИ ТипЗнч(ТекПараметр.Значение) = Тип("Число") Тогда 
			baseInfo.Вставить(ТекПараметр.Ключ, ТекПараметр.Значение);
		Иначе 
			baseInfo.Вставить(ТекПараметр.Ключ, Строка(ТекПараметр.Значение));
		КонецЕсли;
	КонецЦикла;
	
	response = Новый Соответствие(); 
	response.Вставить("baseInfo" , baseInfo);
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , response);
	
	resultCode = 0;
	resultDescription = "Ок";
		
	Возврат Истина;
	
КонецФункции // ОбработатьМетодGet1CInfo()

// Функция предназначена для получения настроек для работы мобильного приложения
//
// Параметры:
//  responseData - строка - строка XML, выходные данные, содержимое определяется контекстом выполняемого метода
//  resultCode   - число  - код результата выполнения
//
// Возвращаемое значение:
//   Булево      - истина - метод выполнен успешно;
//               - ложь   - при выполнении метода возникла ошибка
//
Функция ОбработатьМетодGetSettings(responseData, resultCode, ДанныеАвторизации, стрНастройкиМобильногоПриложения) Экспорт
	
	settings = Новый Соответствие();
	Для Каждого ТекНастройка Из стрНастройкиМобильногоПриложения Цикл 
		Если ТипЗнч(ТекНастройка.Значение) = Тип("Булево")
			ИЛИ ТипЗнч(ТекНастройка.Значение) = Тип("Число") Тогда 
			settings.Вставить(ТекНастройка.Ключ, ТекНастройка.Значение); 
		Иначе 
			settings.Вставить(ТекНастройка.Ключ, Строка(ТекНастройка.Значение));
		КонецЕсли;
	КонецЦикла;
	
	response = Новый Соответствие();
	response.Вставить("settings" , settings);
	
	responseData = Новый Соответствие();
	responseData.Вставить("responseData" , response);
	
	resultCode = 0;
	
	Возврат Истина;
	
КонецФункции // ОбработатьМетодGetSettings()

Процедура ЗаполнитьКонтИнформациюFTLЗаказа(ЗаказСсылка, ПунктСсылка, мсвКонтактов, КонтрагентСсылка = Неопределено)
	
	стрНастройкиВидовКонтактнойИнформации = уатОбщегоНазначенияПовтИсп_проф.ПолучитьНастройкиВидовКонтактнойИнформации();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",        ЗаказСсылка);
	Запрос.УстановитьПараметр("ПунктСсылка",   ПунктСсылка);
	
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииТелефонКонтрагента",     стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииТелефонКонтрагента);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииEmailКонтрагента",       стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииEmailКонтрагента);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииТелефонКонтактногоЛица", стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииТелефонКонтактногоЛица);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииEmailКонтактногоЛица",   стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииEmailКонтактногоЛица);

	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.ОтправительПолучатель КАК КонтрагентСсылка,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.КонтактноеЛицо КАК КонтактноеЛицоСсылка,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.НомерСтроки КАК НомерСтроки,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.ТипТочкиМаршрута КАК ТипТочкиМаршрута
	               |ПОМЕСТИТЬ ВТ_Заказ
	               |ИЗ
	               |	Документ.уатЗаказГрузоотправителя.ПромежуточныеПункты КАК уатЗаказГрузоотправителяПромежуточныеПункты
	               |ГДЕ
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.Ссылка = &Ссылка
	               |	И уатЗаказГрузоотправителяПромежуточныеПункты.Пункт = &ПунктСсылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВТ_Заказ.КонтрагентСсылка КАК КонтрагентСсылка,
	               |	ВТ_Заказ.КонтактноеЛицоСсылка КАК КонтактноеЛицоСсылка,
	               |	ВТ_Заказ.НомерСтроки КАК НомерСтроки,
	               |	ВТ_Заказ.ТипТочкиМаршрута КАК ТипТочкиМаршрута
	               |ИЗ
	               |	ВТ_Заказ КАК ВТ_Заказ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВТ_Заказ.КонтрагентСсылка КАК КонтрагентСсылка,
	               |	ВТ_Заказ.КонтактноеЛицоСсылка КАК КонтактноеЛицоСсылка,
	               |	ВЫБОР
	               |		КОГДА КИ_ТелефоныКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |			ТОГДА ВЫБОР
	               |					КОГДА КИ_ТелефоныОснКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |						ТОГДА ЕСТЬNULL(КИ_ТелефоныКонтрагентов.Представление, """")
	               |					ИНАЧЕ КИ_ТелефоныОснКонтЛицКонтрагентов.Представление
	               |				КОНЕЦ
	               |		ИНАЧЕ КИ_ТелефоныКонтЛицКонтрагентов.Представление
	               |	КОНЕЦ КАК ТелефонКонтрагента,
	               |	ВЫБОР
	               |		КОГДА КИ_ПочтаКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |			ТОГДА ВЫБОР
	               |					КОГДА КИ_ПочтаОснКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |						ТОГДА ЕСТЬNULL(КИ_ПочтаКонтрагентов.Представление, """")
	               |					ИНАЧЕ КИ_ПочтаОснКонтЛицКонтрагентов.Представление
	               |				КОНЕЦ
	               |		ИНАЧЕ КИ_ПочтаКонтЛицКонтрагентов.Представление
	               |	КОНЕЦ КАК ПочтаКонтрагента,
	               |	ВТ_Заказ.НомерСтроки КАК НомерСтроки
	               |ИЗ
	               |	ВТ_Заказ КАК ВТ_Заказ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ТелефоныКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтактноеЛицоСсылка = КИ_ТелефоныКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ПочтаКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтактноеЛицоСсылка = КИ_ПочтаКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ПочтаКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ТелефоныОснКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка.ОсновноеКонтактноеЛицо = КИ_ТелефоныОснКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныОснКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныОснКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ_ТелефоныКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка = КИ_ТелефоныКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтрагента)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ПочтаОснКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка.ОсновноеКонтактноеЛицо = КИ_ПочтаОснКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ПочтаОснКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаОснКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ_ПочтаКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка = КИ_ПочтаКонтрагентов.Ссылка
	               |			И (КИ_ПочтаКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтрагента)";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Выборка          = РезультатЗапроса[1].Выбрать();
	ВыборкаКИ        = РезультатЗапроса[2].Выгрузить();
	
	Пока Выборка.Следующий() Цикл
		СтруктураКИ = уатМобильноеПриложениеВодителяСервер.ЗаполнитьКИМЛFTL(ВыборкаКИ, Выборка);
		
		КонтрагентСсылка = Выборка.КонтрагентСсылка;
		Если ЗначениеЗаполнено(СтруктураКИ.ТелефонКонтрагента) Или ЗначениеЗаполнено(СтруктураКИ.ПочтаКонтрагента) Тогда
			contact = Новый Соответствие();
			Попытка
				contact.Вставить("ID", Строка(Выборка.КонтрагентСсылка.УникальныйИдентификатор()));
			Исключение
				contact.Вставить("ID", Строка(Новый УникальныйИдентификатор));
			КонецПопытки;
			Если ЗначениеЗаполнено(Выборка.КонтактноеЛицоСсылка) Тогда 
				contact.Вставить("name", Выборка.КонтактноеЛицоСсылка.Наименование);
			ИначеЕсли ЗначениеЗаполнено(Выборка.КонтрагентСсылка.ОсновноеКонтактноеЛицо) Тогда
				contact.Вставить("name", Выборка.КонтрагентСсылка.ОсновноеКонтактноеЛицо.Наименование);
			Иначе 
				contact.Вставить("name", Выборка.КонтрагентСсылка.Наименование);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураКИ.ТелефонКонтрагента) Тогда 
				contact.Вставить("phone", СтруктураКИ.ТелефонКонтрагента);
			КонецЕсли;
			Если ЗначениеЗаполнено(СтруктураКИ.ПочтаКонтрагента) Тогда 
				contact.Вставить("email", СтруктураКИ.ПочтаКонтрагента);
			КонецЕсли; 
			Если Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка
				ИЛИ Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.ДополнительнаяПогрузка Тогда
				contact.Вставить("role", "sender");
			ИначеЕсли Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Разгрузка
				ИЛИ Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.ДополнительнаяРазгрузка Тогда
				contact.Вставить("role", "receiver");
			Иначе
				contact.Вставить("role", "partner");
			КонецЕсли;  
			мсвКонтактов.Добавить(contact);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура ЗаписатьБлокProductivity(order, СтрокаЗаказа)
	
	Если НЕ ЗначениеЗаполнено(СтрокаЗаказа.ПараметрВыработки1)
		И НЕ ЗначениеЗаполнено(СтрокаЗаказа.ПараметрВыработки2) Тогда 
		Возврат;
	КонецЕсли;
	
	Если СтрокаЗаказа.Строки.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрВыработки1 = СтрокаЗаказа.ПараметрВыработки1;
	ПараметрВыработки2 = СтрокаЗаказа.ПараметрВыработки2;
	
	productivity = Новый Массив();
	Если НЕ ПараметрВыработки1 = Неопределено Тогда
		item = Новый Соответствие();
		item.Вставить("ID",     Строка(ПараметрВыработки1.УникальныйИдентификатор()));
		item.Вставить("name",   ПараметрВыработки1.Наименование);
		item.Вставить("isBool", ПараметрВыработки1.ОтображениеВВидеФлага);
		item.Вставить("item",   СтрокаЗаказа.Выработка1);
		productivity.Добавить(item);
	КонецЕсли;
	Если НЕ ПараметрВыработки2 = Неопределено Тогда
		item = Новый Соответствие();
		item.Вставить("ID",     Строка(ПараметрВыработки2.УникальныйИдентификатор()));
		item.Вставить("name",   ПараметрВыработки2.Наименование);
		item.Вставить("isBool", ПараметрВыработки2.ОтображениеВВидеФлага);
		item.Вставить("item",   СтрокаЗаказа.Выработка2);
		productivity.Добавить(item);
	КонецЕсли;

	order.Вставить("productivity", productivity);
	
КонецПроцедуры


