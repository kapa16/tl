
#Область СлужебныйПрограммныйИнтерфейс

Процедура ОтправитьСообщение(commandName, ДополнительныеПараметры = Неопределено) Экспорт
	
	ВремяНачалаЗапроса = ТекущаяУниверсальнаяДатаВМиллисекундах();  
	
	WebSocketКлиент = WebSocketКлиенты.НайтиПоКлючу("ВодительУАТ");
	Если WebSocketКлиент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	WebSocketКлиентСоединение  = WebSocketКлиент.ПолучитьТекущееСоединение();  
	Если WebSocketКлиентСоединение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекСостояниеСоединения = WebSocketКлиент.ПолучитьСостояниеСоединения();
	Если ТекСостояниеСоединения <> СостояниеWebSocketСоединения.Открыто Тогда
		Возврат;
	КонецЕсли;
	
	responseData = Новый Соответствие;
	responseData.Вставить("responseData", Новый Соответствие); 
	
	resultCode        = 0;
	resultDescription = "";  
	commandName       = commandName;
	requestData       = "";
	loginData         = "";
	
	Попытка
		уатМобильноеПриложениеВодителяСервер.ОбработатьМетодExecuteCommand(loginData, commandName, requestData, responseData, resultCode, resultDescription, Перечисления.уатСпособыРеализацииВебСервиса.REST, ДополнительныеПараметры);
	Исключение
		resultCode        = 29999;
		resultDescription = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьОписаниеКодаОшибки(resultCode, "ru");
	КонецПопытки;
	
	responseData.Вставить("commandName",       commandName);
	responseData.Вставить("resultCode",        resultCode);
	responseData.Вставить("resultDescription", resultDescription);
	
	Data = Новый Соответствие;
	Data.Вставить("id",                "00000000-0000-0000-0000-000000000000");  
	Data.Вставить("data",              responseData);
	Data.Вставить("time1C",            ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачалаЗапроса);  
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Истина);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, Data);
	ДанныеОтветаJSON = ЗаписьJSON.Закрыть();
	
	WebSocketКлиентСоединение.ОтправитьСообщение(ДанныеОтветаJSON);
	
	Параметры = Новый Структура();
	Параметры.Вставить("Сообщение", ДанныеОтветаJSON);  
	Параметры.Вставить("Описание",  commandName); 
	Параметры.Вставить("Команда",   commandName);
	
	Обработчик = "ПриОтправкеСообщения";
	Если resultCode <> 0 Тогда
		Параметры.Вставить("Код",   resultCode);
		Обработчик = "ПриОшибке";
	КонецЕсли;
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог(Обработчик, WebSocketКлиентСоединение.Ключ,, Параметры); 
	
КонецПроцедуры

Процедура ПодключитьЗакрытьСоединениеСервер(WebSocketКлюч = "ВодительУАТ", ApiKey = "", ИмяПользователяИнформационнойБазы = "") Экспорт
	
	WebSocketКлиент = WebSocketКлиенты.НайтиПоКлючу(WebSocketКлюч);
	Если WebSocketКлиент = Неопределено Тогда
		Если НЕ ЗначениеЗаполнено(ApiKey) Тогда
			ТекстОшибки = НСтр("ru = 'Заполните API ключ базы''");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			Возврат;
		КонецЕсли; 
		
		WebSocketКлиент = WebSocketКлиенты.СоздатьКлиента(Метаданные.WebSocketКлиенты.уатВодительУАТ, "ВодительУАТ");
		Если WebSocketКлиент = Неопределено Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	ТекСостояниеСоединения = WebSocketКлиент.ПолучитьСостояниеСоединения();
	Если ТекСостояниеСоединения = СостояниеWebSocketСоединения.Открыто
		ИЛИ ТекСостояниеСоединения = СостояниеWebSocketСоединения.Открывается Тогда
		WebSocketКлиент.Отключить();
	Иначе     
		WebSocketКлиент.URLСервера                        = ПолучитьURLСервера();
		WebSocketКлиент.ПодключатьАвтоматически           = Истина;
		WebSocketКлиент.ИмяПользователяИнформационнойБазы = ИмяПользователяИнформационнойБазы;

		WebSocketКлиент.Записать();
		WebSocketКлиент.Подключить();
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСостояниеСоединения() Экспорт
	WebSocketКлиент = WebSocketКлиенты.НайтиПоКлючу("ВодительУАТ");  
	Если WebSocketКлиент = Неопределено Тогда
		Возврат "Закрыто";
	КонецЕсли;
	ТекСостояниеСоединения = WebSocketКлиент.ПолучитьСостояниеСоединения(); 
	Если ТекСостояниеСоединения = СостояниеWebSocketСоединения.Открыто Тогда
		СостояниеСоединения = "Открыто";
	ИначеЕсли ТекСостояниеСоединения = СостояниеWebSocketСоединения.Открывается Тогда
		СостояниеСоединения = "Открывается";  
	ИначеЕсли ТекСостояниеСоединения = СостояниеWebSocketСоединения.Закрыто Тогда
		СостояниеСоединения = "Закрыто"; 
	ИначеЕсли ТекСостояниеСоединения = СостояниеWebSocketСоединения.Закрывается Тогда
		СостояниеСоединения = "Закрывается";  
	Иначе
		СостояниеСоединения = "";
	КонецЕсли;
	Возврат СостояниеСоединения;
КонецФункции

Функция ПараметрыСоединения(Соединение) Экспорт
	
	СтруктураСоединение = Новый Структура;
	СтруктураСоединение.Вставить("URLСервера", Соединение.URLСервера);
	СтруктураСоединение.Вставить("ИмяПользователяИнформационнойБазы", Соединение.ИмяПользователяИнформационнойБазы);  
	СтруктураСоединение.Вставить("Модуль", Соединение.Обработчики.Модуль); 
	СтруктураСоединение.Вставить("ОбработчикЗакрытияСоединения", Соединение.Обработчики.ОбработчикЗакрытияСоединения); 
	СтруктураСоединение.Вставить("ОбработчикОткрытияСоединения", Соединение.Обработчики.ОбработчикОткрытияСоединения); 
	СтруктураСоединение.Вставить("ОбработчикОшибки", Соединение.Обработчики.ОбработчикОшибки); 
	СтруктураСоединение.Вставить("ОбработчикПолученияСообщения", Соединение.Обработчики.ОбработчикПолученияСообщения); 
	СтруктураСоединение.Вставить("Заголовки", Соединение.Параметры.Заголовки);

	СоединениеJSON = ЗаписатьДанныеВJSON(,СтруктураСоединение).Результат;
	
	Параметры = Новый Структура;
	Параметры.Вставить("Соединение",СоединениеJSON);
	Возврат Параметры;
	
КонецФункции

Функция ПараметрыКлиента(Клиент) Экспорт
	
	СтруктураКлиент = Новый Структура;
	СтруктураКлиент.Вставить("URLСервера", Клиент.URLСервера);
	СтруктураКлиент.Вставить("ИмяПользователяИнформационнойБазы", Клиент.ИмяПользователяИнформационнойБазы);
	СтруктураКлиент.Вставить("Заголовки", Клиент.ПараметрыСоединения.Заголовки);
	СтруктураКлиент.Вставить("МетаданныеИмя", Клиент.Метаданные.Имя);
	//СтруктураКлиент.Вставить("МетаданныеЗаголовки", Клиент.Метаданные.Заголовки);
	СтруктураКлиент.Вставить("МетаданныеURLСервера", Клиент.Метаданные.URLСервера);
	КлиентJSON = ЗаписатьДанныеВJSON(,СтруктураКлиент).Результат;
	
	Параметры = Новый Структура;
	Параметры.Вставить("Клиент", КлиентJSON);
	
	Возврат Параметры;
КонецФункции

Процедура ЗаписатьВЛог(Обработчик, Ключ, Логин = "", Параметры = Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ уатМобильноеПриложениеВодителяСерверПовтИсп.ВестиЛогWSМПВУАТ() Тогда 
		Возврат;
	КонецЕсли;  
	
	Дата = ТекущаяДатаСеанса();
	Если Не ЗначениеЗаполнено(Параметры) Тогда 
		Параметры = Новый Структура;
	КонецЕсли;	
	
	БылаОшибка = Ложь;

	Попытка
		
		НаборЗаписей = РегистрыСведений.уатЛогиОблачногоСервераПриложения.СоздатьНаборЗаписей(); 
		НаборЗаписей.Заполнить(Неопределено);
		НаборЗаписей.Отбор.Дата.Установить(Дата);
		НаборЗаписей.Отбор.Обработчик.Установить(Обработчик);
		НаборЗаписей.Отбор.Ключ.Установить(Ключ);
		НаборЗаписей.Отбор.Логин.Установить(Логин); 
		Если Параметры.Свойство("Команда") Тогда
			НаборЗаписей.Отбор.Команда.Установить(Параметры.Команда);
		Иначе  
			НаборЗаписей.Отбор.Команда.Установить("");
		КонецЕсли;
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.уатЛогиОблачногоСервераПриложения");
		ЭлементБлокировки.УстановитьЗначение("Дата",        Дата);
		ЭлементБлокировки.УстановитьЗначение("Обработчик",  Обработчик); 
		ЭлементБлокировки.УстановитьЗначение("Ключ",        Ключ); 
		ЭлементБлокировки.УстановитьЗначение("Логин",       Логин);
		Если Параметры.Свойство("Команда") Тогда 
			ЭлементБлокировки.УстановитьЗначение("Команда", Параметры.Команда);
		Иначе
			ЭлементБлокировки.УстановитьЗначение("Команда", "");
		КонецЕсли; 
		НачатьТранзакцию();
		Блокировка.Заблокировать();
		
		НаборЗаписей.Прочитать();	
		
		
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗаписьРегистра = НаборЗаписей.Добавить();
			
			НоваяЗаписьРегистра.Дата 		= Дата;
			НоваяЗаписьРегистра.Обработчик 	= Обработчик;
			НоваяЗаписьРегистра.Ключ 		= Ключ;	
		Иначе
			НоваяЗаписьРегистра = НаборЗаписей[0];
		КонецЕсли;
		
		СообщениеХранилищеЗначения = "";
		Для Каждого текПараметр Из Параметры Цикл 
			Если текПараметр.Ключ = "Сообщение" Тогда
				 СообщениеХранилищеЗначения = текПараметр.Значение;
			КонецЕсли;
			НоваяЗаписьРегистра[текПараметр.Ключ] = текПараметр.Значение;	
			
		КонецЦикла;
		Попытка
			Сжатие = Новый СжатиеДанных(9);
			НоваяЗаписьРегистра.СообщениеХранилищеЗначения = Новый ХранилищеЗначения(СообщениеХранилищеЗначения, Сжатие);
		Исключение 
		КонецПопытки;
		НаборЗаписей.Записать(); 
		ЗафиксироватьТранзакцию();  
		
	Исключение	
		ОтменитьТранзакцию();
		
		БылаОшибка = Истина;
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ИмяСобытияВЖурналеРегистрации = НСтр("en='WS mobile app of the driver.';ru='WS мобильное приложение водителя.'");
		ЗаписьЖурналаРегистрации(ИмяСобытияВЖурналеРегистрации, УровеньЖурналаРегистрации.Информация,,,ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Если БылаОшибка Тогда     
		ИмяСобытияВЖурналеРегистрации = НСтр("en='WS mobile app of the driver.';ru='WS мобильное приложение водителя.'");
		ЗаписьЖурналаРегистрации(ИмяСобытияВЖурналеРегистрации, УровеньЖурналаРегистрации.Ошибка,,,ТекстОшибки);
	КонецЕсли;	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура ПриПолученииСообщения(Соединение, Сообщение, ВремяНачалаЗапроса) Экспорт
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(Сообщение);
		Response = ПрочитатьJSON(ЧтениеJSON, Истина); 
		ЧтениеJSON.Закрыть();
	Исключение
		ИмяСобытияВЖурналеРегистрации = НСтр("en='WS mobile app of the driver.';ru='WS мобильное приложение водителя.'");
		ЗаписьЖурналаРегистрации(ИмяСобытияВЖурналеРегистрации, УровеньЖурналаРегистрации.Ошибка,,,Сообщение); 
		Возврат;
	КонецПопытки;  
	
	ИмяСобытияВЖурналеРегистрации = НСтр("en='WS mobile app of the driver.';ru='WS мобильное приложение водителя.'");
	ЗаписьЖурналаРегистрации(ИмяСобытияВЖурналеРегистрации, УровеньЖурналаРегистрации.Информация,,,Сообщение); 
	
	id          = Response.Получить("id");
	data        = Response.Получить("data");
	commandName = data.Получить("commandName");
	loginData   = data.Получить("loginData");
	requestData = data.Получить("requestData");   

	
	Параметры = уатМобильноеПриложениеВодителяСерверREST.ПараметрыСоединения(Соединение); 
	Параметры.Вставить("Сообщение" ,Сообщение); 
	Параметры.Вставить("Описание",  commandName);
	Параметры.Вставить("Команда",   commandName);
	
	Логин = "";
	Если loginData.Получить("login") <> Неопределено Тогда 
		Логин = loginData.Получить("login");
		Параметры.Вставить("Логин",  Логин);
	КонецЕсли;
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог("ПриПолученииСообщения", Соединение.Ключ, Логин, Параметры);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Истина);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, loginData);
	loginData = ЗаписьJSON.Закрыть();
	
	Если ТипЗнч(requestData) = Тип("Соответствие") Тогда
		ЗаписьJSON = Новый ЗаписьJSON;
		ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Истина);
		ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
		ЗаписатьJSON(ЗаписьJSON, requestData);
		requestData = ЗаписьJSON.Закрыть(); 
	КонецЕсли;
	
	responseData = Новый Соответствие;
	responseData.Вставить("responseData", Новый Соответствие);
	
	resultCode          = 0;
	resultDescription   = "";   
	resultDescription1С = ""; 
	
	Попытка
		уатМобильноеПриложениеВодителяСервер.ОбработатьМетодExecuteCommand(loginData, commandName, requestData, responseData, resultCode, resultDescription, Перечисления.уатСпособыРеализацииВебСервиса.REST);
	Исключение
		resultCode          = 29999;
		resultDescription   = уатМобильноеПриложениеВодителяСерверПовтИсп.ПолучитьОписаниеКодаОшибки(resultCode, "ru");
		resultDescription1С = ОписаниеОшибки();
	КонецПопытки; 
	
	responseData.Вставить("commandName",         commandName);
	responseData.Вставить("resultCode",          resultCode);
	responseData.Вставить("resultDescription",   resultDescription); 
	responseData.Вставить("resultDescription1С", resultDescription1С);
	responseData.Вставить("time1C",              ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачалаЗапроса);
	
	
	Data = Новый Соответствие;
	Data.Вставить("id",                id);  
	Data.Вставить("data",              responseData);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Истина);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, Data);
	ДанныеОтветаJSON = ЗаписьJSON.Закрыть();
	
	Соединение.ОтправитьСообщение(ДанныеОтветаJSON);
	
	Параметры = Новый Структура();
	Параметры.Вставить("Сообщение", ДанныеОтветаJSON);
	Параметры.Вставить("Описание",  commandName);
	Параметры.Вставить("Команда",   commandName);
	Параметры.Вставить("Логин",     Логин);
	уатМобильноеПриложениеВодителяСерверREST.ЗаписатьВЛог("ПриОтправкеСообщения", Соединение.Ключ, Логин, Параметры);

КонецПроцедуры

Функция ЗаполнитьЗаголовкиПодключения() Экспорт    
		
	ПараметрыСоединенияЗаголовки = Новый Структура();
	
	СтрокаСоединения = СтрокаСоединенияИнформационнойБазы();
	ПараметрыСоединенияЗаголовки.Вставить("InfoBaseConnection", ЗакодироватьЗаголовокПодключения(СтрокаСоединения));
	ПараметрыСоединенияЗаголовки.Вставить("InfoBaseID",         ЗакодироватьЗаголовокПодключения(СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы()));  

	АдресСервера = "127.0.0.1";
	Попытка  
		ПараметрыПодключения = ОбщегоНазначенияКлиентСервер.ПолучитьПараметрыПодключенияИзСтрокиСоединенияИнформационнойБазы(СтрокаСоединения);
		Если ПараметрыПодключения.ВариантРаботыИнформационнойБазы = 0 Тогда // Файловая 
			АдресСервера = "127.0.0.1";
		Иначе
			РезультатДоступностиРесурса = ПолучениеФайловИзИнтернетаСлужебный.ПроверитьДоступностьСервера(ПараметрыПодключения.ИмяСервера1СПредприятия); 
			Если РезультатДоступностиРесурса.Доступен Тогда
				Журнал = РезультатДоступностиРесурса.ЖурналДиагностики; 
				
				НачальныйНомер = СтрНайти(Журнал, "[") + 1;
				КонечныйНомер  = СтрНайти(Журнал, "]"); 
				ЧислоСимволов  = КонечныйНомер - НачальныйНомер;
				АдресСервера = Сред(Журнал, НачальныйНомер, ЧислоСимволов);
			Иначе
				АдресСервера = ПараметрыПодключения.ИмяСервера1СПредприятия;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	ПараметрыСоединенияЗаголовки.Вставить("ServerIP",  ЗакодироватьЗаголовокПодключения(АдресСервера));
	Возврат ПараметрыСоединенияЗаголовки;
КонецФункции

Функция ЗакодироватьЗаголовокПодключения(Заголовок) Экспорт
   Возврат СтрЗаменить(СтрЗаменить(Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(Заголовок)),Символы.ПС,""),Символы.ВК,"");
