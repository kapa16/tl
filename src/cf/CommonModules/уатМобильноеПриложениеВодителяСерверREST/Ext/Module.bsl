					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			Для Каждого ТекСтрока Из табСтрок Цикл 
				НовСтр = ТабМЛ.Добавить();
				НовСтр.routeListID      = ТекущийGUIDМЛ;
				НовСтр.arrivalFact      = ДатаПрибытияФакт;
				НовСтр.departureFact    = ДатаУбытияФакт; 
				НовСтр.arrivalFactUTC   = ДатаПрибытияФактUTC;
				НовСтр.departureFactUTC = ДатаУбытияФактUTC;
				НовСтр.isDone           = флВыполнен;
				НовСтр.orderResult      = РезультатВыполнения;
				НовСтр.productivityID1  = Выработка1;
				НовСтр.productivityVal1 = ЗначВыработки1;
				НовСтр.productivityID2  = Выработка2;
				НовСтр.productivityVal2 = ЗначВыработки2;
				НовСтр.lineID           = ТекСтрока.lineID;
				НовСтр.fact_accepted    = ТекСтрока.fact_accepted;
				НовСтр.fact_amount      = ТекСтрока.fact_amount;
				НовСтр.fact_amountPlace = ТекСтрока.fact_amountPlace;
				НовСтр.fact_weight      = ТекСтрока.fact_weight;
				НовСтр.fact_volume      = ТекСтрока.fact_volume;
				НовСтр.fact_reason      = ТекСтрока.fact_reason; 
				НовСтр.signature        = Подпись; 
				НовСтр.mark             = Оценка;
			КонецЦикла; 
			
			мсвДокументов = ТекМЛ.Получить("shippingDocuments");
			Если мсвДокументов <> Неопределено Тогда
				Для Каждого ТекДокумент Из мсвДокументов Цикл 
					documentID      = Неопределено;
					newDocument     = Неопределено; 
					processingDate  = Неопределено;
					pointID         = Неопределено;
					typeID          = Неопределено;
					nameDocument    = Неопределено;
					numberDocument  = Неопределено;
					dateDocument    = Неопределено;
					commentDocument = Неопределено;
					partner         = Неопределено;
					
					Если ТекДокумент.Получить("documentID") <> Неопределено Тогда  
						documentID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекДокумент.Получить("documentID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
						КонецЕсли;
					КонецЕсли;
					Если ТекДокумент.Получить("new") <> Неопределено Тогда  
						newDocument = ТекДокумент.Получить("new");
					КонецЕсли;
					Если ТекДокумент.Получить("processingDate") <> Неопределено Тогда  
						processingDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекДокумент.Получить("processingDate"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field processingDate';ru='Ошибка разбора поля processingDate'");
						КонецЕсли;
					КонецЕсли;
					Если ТекДокумент.Получить("pointID") <> Неопределено Тогда  
						Если ЗначениеЗаполнено(ТекДокумент.Получить("pointID")) Тогда
							pointID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекДокумент.Получить("pointID"), флОшибка);
							Если флОшибка Тогда 
								ВызватьИсключение НСтр("en='Error parsing pointID';ru='Ошибка разбора pointID'");
							КонецЕсли; 
						Иначе
							pointID = "";
						КонецЕсли;
					КонецЕсли;
					Если ТекДокумент.Получить("typeID") <> Неопределено Тогда  
						typeID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекДокумент.Получить("typeID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing typeID';ru='Ошибка разбора typeID'");
						КонецЕсли;
					КонецЕсли;
					Если ТекДокумент.Получить("name") <> Неопределено Тогда  
						nameDocument = ТекДокумент.Получить("name");
					КонецЕсли;
					Если ТекДокумент.Получить("number") <> Неопределено Тогда  
						numberDocument = ТекДокумент.Получить("number");
					КонецЕсли;
					Если ТекДокумент.Получить("date") <> Неопределено Тогда  
						dateDocument = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекДокумент.Получить("date"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field date';ru='Ошибка разбора поля date'");
						КонецЕсли;
					КонецЕсли;
					Если ТекДокумент.Получить("comment") <> Неопределено Тогда  
						commentDocument = ТекДокумент.Получить("comment");
					КонецЕсли; 
					Если ТекДокумент.Получить("partner") <> Неопределено Тогда  
						partner = ТекДокумент.Получить("partner");
					КонецЕсли;
					Если НЕ documentID = Неопределено Тогда
						НоваяСтрока = табСД.Добавить(); 
						НоваяСтрока.ownerID        = ТекущийGUIDМЛ;
						НоваяСтрока.documentID     = documentID;
						НоваяСтрока.new            = newDocument;
						НоваяСтрока.processingDate = processingDate;
						НоваяСтрока.pointID        = pointID;
						НоваяСтрока.typeID         = typeID;
						НоваяСтрока.name           = nameDocument;
						НоваяСтрока.number         = numberDocument;
						НоваяСтрока.date           = dateDocument;
						НоваяСтрока.comment        = commentDocument;
						НоваяСтрока.partner        = partner;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing structures ""routeLists"".';ru='Возникла ошибка при разборе структуры ""routeLists"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateOrders';ru='ДесериализоватьUpdateOrders'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабМЛ;
	КонецПопытки;
	
	Попытка
		Для Каждого ТекСтр Из ТабМЛ Цикл 
			ТекСтр.routeListRef = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекСтр.routeListID);
			
			Если ЗначениеЗаполнено(ТекСтр.orderResult) Тогда 
				ТекСтр.orderResultRef = Справочники.уатПричиныЗакрытияЗаказов.ПолучитьСсылку(ТекСтр.orderResult);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекСтр.productivityID1) Тогда 
				ТекСтр.productivityRef1 = Справочники.уатПараметрыВыработки.ПолучитьСсылку(ТекСтр.productivityID1);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекСтр.productivityID2) Тогда 
				ТекСтр.productivityRef2 = Справочники.уатПараметрыВыработки.ПолучитьСсылку(ТекСтр.productivityID2);
			КонецЕсли;
			
		КонецЦикла;
		Для Каждого ТекСД Из ТабСД Цикл
			ТекСД.ownerRef    = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекСД.ownerID);
			ТекСД.pointRef    = Справочники.уатПунктыНазначения.ПолучитьСсылку(ТекСД.pointID); 
			ТекСД.typeRef     = Справочники.уатВидыСопроводительныхДокументов.ПолучитьСсылку(ТекСД.typeID);  
			ТекСД.documentRef = Справочники.уатСопроводительныеДокументы.ПолучитьСсылку(ТекСД.documentID);
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while receiving document reference by GUID.';ru='Возникла ошибка при получении ссылки на документ по GUID.'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateOrders';ru='ДесериализоватьUpdateOrders'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабМЛ;
	КонецПопытки;
	
	Возврат ТабМЛ;
	
КонецФункции // ДесериализоватьUpdateOrders()

// Функция предназначена для преобразования xml-строки с сообщениями об опоздании от водителя в структуру 1С
//
// Параметры:
//  LateArrival - строка - строка XML, содержащая данные о сообщениях об опоздании от водителя с мобильного устройства
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   структура - структура, полученная на основе параметра "LateArrival", содержащая ключи:
//               - pointName   - имя пункта;
//               - lateArrival - время опоздания, минут;
//               - comment     - текст пояснения.
//
Функция ДесериализоватьLateArrival(Знач LateArrival, флОшибка) Экспорт
	
	стрРезультат = Новый Структура("pointName, lateArrival, comment, orderRef", "", "", "", "");
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(LateArrival);
	ТекСообщение = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	Если ТекСообщение.Получить("pointName") <> Неопределено Тогда  
		стрРезультат.pointName = ТекСообщение.Получить("pointName");
	КонецЕсли; 
	Если ТекСообщение.Получить("lateArrival") <> Неопределено Тогда  
		стрРезультат.lateArrival = ТекСообщение.Получить("lateArrival");
	КонецЕсли;
	Если ТекСообщение.Получить("comment") <> Неопределено Тогда  
		стрРезультат.comment = ТекСообщение.Получить("comment");
	КонецЕсли; 
	Если ТекСообщение.Получить("taxiOrderID") <> Неопределено Тогда  
		ТекущийGUID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("taxiOrderID"), флОшибка);
		Если флОшибка Тогда 
			ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
		КонецЕсли; 
		orderRef = Документы["такЗаказТакси"].ПолучитьСсылку(ТекущийGUID);
		
		стрРезультат.orderRef = orderRef;
	КонецЕсли;

	Возврат стрРезультат;
	
КонецФункции // ДесериализоватьLateArrival()

// Функция предназначена для преобразования xml-строки с данными о картинках по 
// маршрутным листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о картинках
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица данных
//
Функция ДесериализоватьImage(Знач requestData, флОшибка) Экспорт
	
	ТабФайлов = Новый ТаблицаЗначений();
	
	ТабФайлов.Колонки.Добавить("ДокументСсылка",  Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист, ДокументСсылка.уатЗаявкаНаРемонт, ДокументСсылка.уатПутевойЛист, СправочникСсылка.уатСопроводительныеДокументы"));

	ТабФайлов.Колонки.Добавить("GUIDСтроки",      Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабФайлов.Колонки.Добавить("ДанныеФайла",     Новый ОписаниеТипов("ДвоичныеДанные"));
	ТабФайлов.Колонки.Добавить("РасширениеФайла", Новый ОписаниеТипов("Строка"));
	
	Если ТипЗнч(requestData) = Тип("Строка") Тогда
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(requestData);
		ТекСообщение = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();
	Иначе
		ТекСообщение = requestData; 
	КонецЕсли;
	
	ТекСтрока = ТабФайлов.Добавить();
	Если ТекСообщение.Получить("routeList") <> Неопределено Тогда  
		ТекущийGUIDМЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("routeList"), флОшибка);
		Если флОшибка Тогда 
			ВызватьИсключение НСтр("en='Error parsing the GUID in the routeList field.';ru='Ошибка разбора GUID в поле docID.'");
		КонецЕсли;
		
		ТекСтрока.ДокументСсылка = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекущийGUIDМЛ);
	КонецЕсли;
	Если ТекСообщение.Получить("docID") <> Неопределено Тогда  
		ТекущийGUIDДокумента = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("docID"), флОшибка);
		
		ТекСтрока.ДокументСсылка = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекущийGUIDДокумента);
		Если ТекСтрока.ДокументСсылка.ПолучитьОбъект() = Неопределено Тогда
			ТекСтрока.ДокументСсылка = Документы.уатПутевойЛист.ПолучитьСсылку(ТекущийGUIDДокумента);
			Если ТекСтрока.ДокументСсылка.ПолучитьОбъект() = Неопределено Тогда
				ТекСтрока.ДокументСсылка = Документы.уатЗаявкаНаРемонт.ПолучитьСсылку(ТекущийGUIDДокумента);
				Если ТекСтрока.ДокументСсылка.ПолучитьОбъект() = Неопределено Тогда
					ТекСтрока.ДокументСсылка = Справочники.уатСопроводительныеДокументы.ПолучитьСсылку(ТекущийGUIDДокумента);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	Если ТекСообщение.Получить("item") <> Неопределено Тогда  
		ТекСтрока.GUIDСтроки = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("item"), флОшибка);
		Если флОшибка Тогда 
			ВызватьИсключение НСтр("en='Error parsing GUID in the item.';ru='Ошибка разбора GUID в поле item.'");
		КонецЕсли;
	КонецЕсли;
	Если ТекСообщение.Получить("imageSrc") <> Неопределено Тогда  
		ТекСтрока.ДанныеФайла = Base64Значение(ТекСообщение.Получить("imageSrc"));
	КонецЕсли; 
	Если ТекСообщение.Получить("fileExt") <> Неопределено Тогда  
		ТекСтрока.РасширениеФайла = СокрЛП(НРег(ТекСообщение.Получить("fileExt")));
		Если Лев(ТекСтрока.РасширениеФайла, 1) = "." Тогда 
			ТекСтрока.РасширениеФайла = Прав(ТекСтрока.РасширениеФайла, СтрДлина(ТекСтрока.РасширениеФайла)-1);
		КонецЕсли;
	КонецЕсли; 
	Если Не ЗначениеЗаполнено(ТекСтрока.РасширениеФайла) Тогда 
		ТекСтрока.РасширениеФайла = "jpg";
	КонецЕсли;
		
	Возврат ТабФайлов;
	
КонецФункции

