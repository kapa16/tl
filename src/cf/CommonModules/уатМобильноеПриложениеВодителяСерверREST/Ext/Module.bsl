// Функция предназначена для преобразования массива чатов мобильного приложения в json-соответвие
//
// Параметры:
//  МассивКонтактов - массив - массив, содержащая данные о чатах мобильного приложения
//
// Возвращаемое значение:
//   Строка  - json-соответвие, сформированная на основе параметра "МассивКонтактов"
//
Функция СериализоватьChats(МассивКонтактов, ЧатВодителя) Экспорт
	
	мсвКонтактовJSON = Новый Массив();
	Для Каждого ТекКонтакт Из МассивКонтактов Цикл 
		contact = Новый Соответствие();
		contact.Вставить("contactName", ТекКонтакт.Наименование); 
		contact.Вставить("contactID",   Строка(ТекКонтакт.УникальныйИдентификатор()));
		
		мсвКонтактовJSON.Добавить(contact);
	КОнецЦикла;
				
	chat = Новый Соответствие();
	chat.Вставить("chatName", ЧатВодителя.Наименование);
	chat.Вставить("chatID",   Строка(ЧатВодителя.УникальныйИдентификатор()));
	chat.Вставить("contacts", мсвКонтактовJSON);
	
	мсвЧатов = Новый Массив();
	мсвЧатов.Добавить(chat);

	response = Новый Соответствие();
	response.Вставить("chats" , мсвЧатов);
	
	ЗначениеJSON = Новый Соответствие();
	ЗначениеJSON.Вставить("responseData" , response);
	Возврат ЗначениеJSON;
КонецФункции

