//
Функция ДесериализоватьGetMileageConsumptionMonitoring(Знач requestData, флОшибка) Экспорт
	
	стрРезультат = Новый Структура("ДатаВыезда, ПЛ", Неопределено, Неопределено);
	
	Если Не ЗначениеЗаполнено(requestData) Тогда 
		Возврат стрРезультат;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Если Response.Получить("waybillStartDate") <> Неопределено Тогда
		стрРезультат.ДатаВыезда = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("waybillStartDate"), флОшибка);
	КонецЕсли;
	Если Response.Получить("waybillID") <> Неопределено Тогда  
		ПЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("waybillID"), флОшибка);
		стрРезультат.ПЛ = Документы.уатПутевойЛист.ПолучитьСсылку(ПЛ);
	КонецЕсли;
 	Возврат стрРезультат;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с параметрами отбора.
//
// Параметры:
//  requestData   - строка - строка XML, содержащая данные для отбора сообщений
//  флОшибка - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Структура - параметры отбора, полученные на основе параметра "requestData"
//
Функция ДесериализоватьGetWaybillPDF(Знач requestData, флОшибка) Экспорт
	
	ПЛ = Неопределено;
	Если Не ЗначениеЗаполнено(requestData) Тогда 
		Возврат ПЛ;
	КонецЕсли;  
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Если Response.Получить("waybillID") <> Неопределено Тогда
		ПЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("waybillID"), флОшибка);
		ПЛ = Документы.уатПутевойЛист.ПолучитьСсылку(ПЛ);
	КонецЕсли;
	 
	Возврат ПЛ;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с параметрами отбора.
//
// Параметры:
//  requestData   - строка - строка XML, содержащая данные для отбора сообщений
//  флОшибка - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Структура - параметры отбора, полученные на основе параметра "requestData"
//
Функция ДесериализоватьGetQRcode(Знач requestData, флОшибка) Экспорт
	
	ДокументСсылка = Документы.уатПутевойЛист.ПустаяСсылка(); 
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть(); 
	
	Попытка
		Если Response.Получить("docID") <> Неопределено Тогда
			ТекущийGUIDПЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("docID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing the GUID in the routeList field.';ru='Ошибка разбора GUID в поле docID.'");
			КонецЕсли;
			
			ДокументСсылка = Документы.уатПутевойЛист.ПолучитьСсылку(ТекущийGUIDПЛ);
		КонецЕсли;
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing the structure ""requestData"". Description of error:';ru='Возникла ошибка при разборе структуры ""requestData"". Описание ошибки:'") + Символы.ПС + ОписаниеОшибки();
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьQR';ru='ДесериализоватьQR'"), ТекстНСТР); 
		флОшибка = Истина;
	КонецПопытки;
	Возврат ДокументСсылка;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с данными о изменяемых строках заданий по 
// путевым листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о изменяемых заданиях
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица данных, содержащая ссылку на маршрутные листы, строки заданий и изменяемые данные
//
Функция ДесериализоватьUpdateWaybill(Знач requestData, флОшибка) Экспорт
	
	СтрПЛ = Новый Структура("Ссылка, ЗакрытВодителем, ДатаВыезда, ДатаВозвращения, СпидометрВозвращения,
	|ОстатокТопливаВозврат, Прицепы, Заправки");
	СтрПЛ.Заправки = Новый Массив();
	СтрПЛ.Прицепы  = Новый Массив();
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть(); 
	
	Попытка
		Если Response.Получить("orderID") <> Неопределено Тогда
			СтрПЛ.Ссылка = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("orderID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field orderID';ru='Ошибка разбора поля orderID'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("closeWaybill") <> Неопределено Тогда
			СтрПЛ.ЗакрытВодителем = Response.Получить("closeWaybill");
		КонецЕсли;
		Если Response.Получить("waybillStartDate") <> Неопределено Тогда
			СтрПЛ.ДатаВыезда = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("waybillStartDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field waybillStartDate';ru='Ошибка разбора поля waybillStartDate'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("waybillFinishDate") <> Неопределено Тогда
			СтрПЛ.ДатаВозвращения = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("waybillFinishDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field waybillFinishDate';ru='Ошибка разбора поля waybillFinishDate'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("odometerReturn") <> Неопределено Тогда
			Попытка
				СтрПЛ.СпидометрВозвращения = Response.Получить("odometerReturn");
			Исключение
			КонецПопытки;
		КонецЕсли; 
		Если Response.Получить("remainOfFuelReturn") <> Неопределено Тогда
			Попытка
				СтрПЛ.ОстатокТопливаВозврат = Response.Получить("remainOfFuelReturn");
			Исключение
			КонецПопытки;
		КонецЕсли; 
		Если Response.Получить("fueling") <> Неопределено Тогда
			мсвЗаправок = Response.Получить("fueling");
			Для Каждого ТекЗаправка Из мсвЗаправок Цикл   
				СтруктураЗаправки = Новый Структура("fuellingID, fuellingNewID, gasStationID, vehicle, fuellingTypeID, fuelsID, fuellingDate,
						|fuelCardID, quantity, sum, lineNumber, ПометкаНаУдаление");
				Если ТекЗаправка.Получить("fuellingID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingID")) Тогда
						СтруктураЗаправки.fuellingID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuellingID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingID';ru='Ошибка разбора поля fuellingID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				Если ТекЗаправка.Получить("fuellingNewID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingNewID")) Тогда
						СтруктураЗаправки.fuellingNewID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuellingNewID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingNewID';ru='Ошибка разбора поля fuellingNewID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("gasStationID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("gasStationID")) Тогда
						СтруктураЗаправки.gasStationID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("gasStationID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field gasStationID';ru='Ошибка разбора поля gasStationID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;  
				Если ТекЗаправка.Получить("vehicleID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("vehicleID")) Тогда
						СтруктураЗаправки.vehicle = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("vehicleID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuellingTypeID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingTypeID")) Тогда
						Попытка
							СтруктураЗаправки.fuellingTypeID = Перечисления.уатВидыДвиженияГСМ[ТекЗаправка.Получить("fuellingTypeID")];
						Исключение
							флОшибка = Истина;
						КонецПопытки;
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingTypeID';ru='Ошибка разбора поля fuellingTypeID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuelsID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuelsID")) Тогда
						СтруктураЗаправки.fuelsID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuelsID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuelsID';ru='Ошибка разбора поля fuelsID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuellingDate") <> Неопределено Тогда
					СтруктураЗаправки.fuellingDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаправка.Получить("fuellingDate"), флОшибка);
					Если флОшибка Тогда 
						ВызватьИсключение НСтр("en='Error parsing field fuellingDate';ru='Ошибка разбора поля fuellingDate'");
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuelCardID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuelCardID")) Тогда
						СтруктураЗаправки.fuelCardID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuelCardID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuelCardID';ru='Ошибка разбора поля fuelCardID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				Если ТекЗаправка.Получить("quantity") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.quantity = ТекЗаправка.Получить("quantity");
					Исключение
					КонецПопытки;
				КонецЕсли;
				Если ТекЗаправка.Получить("sum") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.sum = ТекЗаправка.Получить("sum");
					Исключение
					КонецПопытки;
				КонецЕсли; 
				Если ТекЗаправка.Получить("lineNumber") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.lineNumber = ТекЗаправка.Получить("lineNumber");
					Исключение
					КонецПопытки;
				КонецЕсли;
				Если ТекЗаправка.Получить("deleted") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("deleted")) Тогда
						СтруктураЗаправки.ПометкаНаУдаление = ТекЗаправка.Получить("deleted");
					КонецЕсли;
				КонецЕсли;
				СтрПЛ.Заправки.Добавить(СтруктураЗаправки);
			КонецЦикла;
		КонецЕсли; 
		Если Response.Получить("vehicles") <> Неопределено Тогда
			мсвТС = Response.Получить("vehicles");
			Для Каждого ТекТС Из мсвТС Цикл   
				СтруктураПрицепов = Новый Структура("vehicle");
				Если ТекЗаправка.Получить("vehicleID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("vehicleID")) Тогда
						СтруктураПрицепов.vehicle = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("vehicleID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				СтрПЛ.Прицепы.Добавить(СтруктураПрицепов);
			КонецЦикла;
		КонецЕсли;

	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing structures ""AddOrderForRepair"".';ru='Возникла ошибка при разборе структуры ""AddOrderForRepair"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateOrderForRepair';ru='ДесериализоватьUpdateOrderForRepair'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат СтрПЛ;
	КонецПопытки;
		
	Попытка
		Если ЗначениеЗаполнено(СтрПЛ.Ссылка) Тогда 
			СтрПЛ.Ссылка = Документы.уатПутевойЛист.ПолучитьСсылку(СтрПЛ.Ссылка);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрПЛ.Заправки) Тогда
			Для Каждого ТекЗаправка Из СтрПЛ.Заправки Цикл
				СтруктураЗаправки = Новый Структура("fuellingID, fuellingNewID, gasStationID, vehicle, fuellingTypeID, fuelsID, fuellingDate,
						|fuelCardID, quantity, sum");
				Если ЗначениеЗаполнено(ТекЗаправка.fuellingID) Тогда 
					ТекЗаправка.fuellingID = Документы.уатЗаправкаГСМ.ПолучитьСсылку(ТекЗаправка.fuellingID);
				Иначе
					ТекЗаправка.fuellingID = Документы.уатЗаправкаГСМ.ПустаяСсылка();
				КонецЕсли; 
				Если ЗначениеЗаполнено(ТекЗаправка.fuellingNewID) Тогда 
					ТекЗаправка.fuellingNewID = Документы.уатЗаправкаГСМ.ПолучитьСсылку(ТекЗаправка.fuellingNewID);
				Иначе
					ТекЗаправка.fuellingNewID = Документы.уатЗаправкаГСМ.ПустаяСсылка();
				КонецЕсли; 
				Если ЗначениеЗаполнено(ТекЗаправка.vehicle) Тогда 
					ТекЗаправка.vehicle = Справочники.уатТС.ПолучитьСсылку(ТекЗаправка.vehicle);
				Иначе
					ТекЗаправка.vehicle = Справочники.уатТС.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.gasStationID) Тогда 
					ТекЗаправка.gasStationID = Справочники.уатАЗС.ПолучитьСсылку(ТекЗаправка.gasStationID);
				Иначе
					ТекЗаправка.gasStationID = Справочники.уатАЗС.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.fuelsID) Тогда 
					ТекЗаправка.fuelsID = Справочники.Номенклатура.ПолучитьСсылку(ТекЗаправка.fuelsID);
				Иначе
					ТекЗаправка.fuelsID = Справочники.Номенклатура.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.fuelCardID) Тогда 
					ТекЗаправка.fuelCardID = Справочники.уатПластиковыеКарты.ПолучитьСсылку(ТекЗаправка.fuelCardID);
				Иначе
					ТекЗаправка.fuelCardID = Справочники.уатПластиковыеКарты.ПустаяСсылка();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрПЛ.Прицепы) Тогда
			Для Каждого ТекПрицеп Из СтрПЛ.Прицепы Цикл
				СтруктураПрицепов = Новый Структура("vehicle");
				Если ЗначениеЗаполнено(ТекПрицеп.vehicle) Тогда 
					ТекПрицеп.vehicle = Справочники.уатТС.ПолучитьСсылку(ТекПрицеп.vehicle);
				Иначе
					ТекПрицеп.vehicle = Справочники.уатТС.ПустаяСсылка();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while receiving document reference by GUID.';ru='Возникла ошибка при получении ссылки на документ по GUID.'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateWaybill';ru='ДесериализоватьUpdateWaybill'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат СтрПЛ;
	КонецПопытки;
	
	Возврат СтрПЛ;
	
КонецФункции // ДесериализоватьUpdateOrders()

// Функция предназначена для преобразования xml-строки с данными о изменяемых строках заданий по 
// путевым листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о изменяемых заданиях
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица данных, содержащая ссылку на маршрутные листы, строки заданий и изменяемые данные
//
Функция ДесериализоватьAddWaybill(Знач requestData, флОшибка) Экспорт
	
	СтрПЛ = Новый Структура("Дата, ТранспортноеСредство, ВидПЛ, ЗакрытВодителем, ДатаВыезда, ДатаВозвращения,
	|СпидометрВозвращения, СпидометрВыезда, ОстатокТопливаВыезд, ОстатокТопливаВозврат, Прицепы, Заправки, Ссылка");
	СтрПЛ.Заправки = Новый Массив();
	СтрПЛ.Прицепы  = Новый Массив();
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть(); 
	
	Попытка
		Если Response.Получить("vehicleID") <> Неопределено Тогда
			СтрПЛ.ТранспортноеСредство = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("vehicleID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("orderID") <> Неопределено Тогда
			СтрПЛ.Ссылка = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("orderID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field orderID';ru='Ошибка разбора поля orderID'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("Date") <> Неопределено Тогда
			СтрПЛ.Дата = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("Date"), флОшибка); 
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field Date';ru='Ошибка разбора поля Date'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("waybillTypeID") <> Неопределено Тогда
			Попытка
				СтрПЛ.ВидПЛ = Перечисления.уатВидыПЛ[Response.Получить("waybillTypeID")];
			Исключение
				флОшибка = Истина;
			КонецПопытки;
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field waybillTypeID';ru='Ошибка разбора поля waybillTypeID'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("odometerDeparture") <> Неопределено Тогда
			СтрПЛ.СпидометрВыезда = Response.Получить("odometerDeparture");
		КонецЕсли; 
		Если Response.Получить("remainOfFuelDeparture") <> Неопределено Тогда
			СтрПЛ.ОстатокТопливаВыезд = Response.Получить("remainOfFuelDeparture");
		КонецЕсли;
		Если Response.Получить("closeWaybill") <> Неопределено Тогда
			СтрПЛ.ЗакрытВодителем = Response.Получить("closeWaybill");
		КонецЕсли;
		Если Response.Получить("waybillStartDate") <> Неопределено Тогда
			СтрПЛ.ДатаВыезда = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("waybillStartDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field waybillStartDate';ru='Ошибка разбора поля waybillStartDate'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("waybillFinishDate") <> Неопределено Тогда
			СтрПЛ.ДатаВозвращения = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("waybillFinishDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field waybillFinishDate';ru='Ошибка разбора поля waybillFinishDate'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("odometerReturn") <> Неопределено Тогда
			Попытка
				СтрПЛ.СпидометрВозвращения = Response.Получить("odometerReturn");
			Исключение
			КонецПопытки;
		КонецЕсли; 
		Если Response.Получить("remainOfFuelReturn") <> Неопределено Тогда
			Попытка
				СтрПЛ.ОстатокТопливаВозврат = Response.Получить("remainOfFuelReturn");
			Исключение
			КонецПопытки;
		КонецЕсли; 
		Если Response.Получить("fueling") <> Неопределено Тогда
			мсвЗаправок = Response.Получить("fueling");
			Для Каждого ТекЗаправка Из мсвЗаправок Цикл   
				СтруктураЗаправки = Новый Структура("fuellingID, fuellingNewID, gasStationID, vehicle, fuellingTypeID, fuelsID, fuellingDate,
						|fuelCardID, quantity, sum, lineNumber, ПометкаНаУдаление");
				Если ТекЗаправка.Получить("fuellingID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingID")) Тогда
						СтруктураЗаправки.fuellingID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuellingID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingID';ru='Ошибка разбора поля fuellingID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				Если ТекЗаправка.Получить("fuellingNewID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingNewID")) Тогда
						СтруктураЗаправки.fuellingNewID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuellingNewID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingNewID';ru='Ошибка разбора поля fuellingNewID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("gasStationID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("gasStationID")) Тогда
						СтруктураЗаправки.gasStationID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("gasStationID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field gasStationID';ru='Ошибка разбора поля gasStationID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;  
				Если ТекЗаправка.Получить("vehicleID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("vehicleID")) Тогда
						СтруктураЗаправки.vehicle = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("vehicleID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuellingTypeID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuellingTypeID")) Тогда
						Попытка
							СтруктураЗаправки.fuellingTypeID = Перечисления.уатВидыДвиженияГСМ[ТекЗаправка.Получить("fuellingTypeID")];
						Исключение
							флОшибка = Истина;
						КонецПопытки;
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuellingTypeID';ru='Ошибка разбора поля fuellingTypeID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuelsID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuelsID")) Тогда
						СтруктураЗаправки.fuelsID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuelsID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuelsID';ru='Ошибка разбора поля fuelsID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuellingDate") <> Неопределено Тогда
					СтруктураЗаправки.fuellingDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаправка.Получить("fuellingDate"), флОшибка);
					Если флОшибка Тогда 
						ВызватьИсключение НСтр("en='Error parsing field fuellingDate';ru='Ошибка разбора поля fuellingDate'");
					КонецЕсли;
				КонецЕсли;
				Если ТекЗаправка.Получить("fuelCardID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("fuelCardID")) Тогда
						СтруктураЗаправки.fuelCardID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаправка.Получить("fuelCardID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field fuelCardID';ru='Ошибка разбора поля fuelCardID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				Если ТекЗаправка.Получить("quantity") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.quantity = ТекЗаправка.Получить("quantity");
					Исключение
					КонецПопытки;
				КонецЕсли;
				Если ТекЗаправка.Получить("sum") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.sum = ТекЗаправка.Получить("sum");
					Исключение
					КонецПопытки;
				КонецЕсли; 
				Если ТекЗаправка.Получить("lineNumber") <> Неопределено Тогда
					Попытка
						СтруктураЗаправки.lineNumber = ТекЗаправка.Получить("lineNumber");
					Исключение
					КонецПопытки;
				КонецЕсли;
				Если ТекЗаправка.Получить("deleted") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекЗаправка.Получить("deleted")) Тогда
						СтруктураЗаправки.ПометкаНаУдаление = ТекЗаправка.Получить("deleted");
					КонецЕсли;
				КонецЕсли;
				СтрПЛ.Заправки.Добавить(СтруктураЗаправки);
			КонецЦикла;
		КонецЕсли; 
		Если Response.Получить("vehicles") <> Неопределено Тогда
			мсвТС = Response.Получить("vehicles");
			Для Каждого ТекТС Из мсвТС Цикл   
				СтруктураПрицепов = Новый Структура("vehicle");
				Если ТекТС.Получить("vehicleID") <> Неопределено Тогда
					Если ЗначениеЗаполнено(ТекТС.Получить("vehicleID")) Тогда
						СтруктураПрицепов.vehicle = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекТС.Получить("vehicleID"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
				СтрПЛ.Прицепы.Добавить(СтруктураПрицепов);
			КонецЦикла;
		КонецЕсли;

	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing structures ""AddOrderForRepair"".';ru='Возникла ошибка при разборе структуры ""AddOrderForRepair"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateOrderForRepair';ru='ДесериализоватьUpdateOrderForRepair'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат СтрПЛ;
	КонецПопытки;

	Попытка 
		Если ЗначениеЗаполнено(СтрПЛ.Ссылка) Тогда 
			СтрПЛ.Ссылка = Документы.уатПутевойЛист.ПолучитьСсылку(СтрПЛ.Ссылка);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрПЛ.ТранспортноеСредство) Тогда 
			СтрПЛ.ТранспортноеСредство = Справочники.уатТС.ПолучитьСсылку(СтрПЛ.ТранспортноеСредство);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрПЛ.Заправки) Тогда
			Для Каждого ТекЗаправка Из СтрПЛ.Заправки Цикл
				СтруктураЗаправки = Новый Структура("fuellingID, fuellingNewID, gasStationID, vehicle, fuellingTypeID, fuelsID, fuellingDate,
						|fuelCardID, quantity, sum");
				Если ЗначениеЗаполнено(ТекЗаправка.fuellingID) Тогда 
					ТекЗаправка.fuellingID = Документы.уатЗаправкаГСМ.ПолучитьСсылку(ТекЗаправка.fuellingID);
				Иначе
					ТекЗаправка.fuellingID = Документы.уатЗаправкаГСМ.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.fuellingNewID) Тогда 
					ТекЗаправка.fuellingNewID = Документы.уатЗаправкаГСМ.ПолучитьСсылку(ТекЗаправка.fuellingNewID);
				Иначе
					ТекЗаправка.fuellingNewID = Документы.уатЗаправкаГСМ.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.vehicle) Тогда 
					ТекЗаправка.vehicle = Справочники.уатТС.ПолучитьСсылку(ТекЗаправка.vehicle);
				Иначе
					ТекЗаправка.vehicle = Справочники.уатТС.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.gasStationID) Тогда 
					ТекЗаправка.gasStationID = Справочники.уатАЗС.ПолучитьСсылку(ТекЗаправка.gasStationID);
				Иначе
					ТекЗаправка.gasStationID = Справочники.уатАЗС.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.fuelsID) Тогда 
					ТекЗаправка.fuelsID = Справочники.Номенклатура.ПолучитьСсылку(ТекЗаправка.fuelsID);
				Иначе
					ТекЗаправка.fuelsID = Справочники.Номенклатура.ПустаяСсылка();
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекЗаправка.fuelCardID) Тогда 
					ТекЗаправка.fuelCardID = Справочники.уатПластиковыеКарты.ПолучитьСсылку(ТекЗаправка.fuelCardID);
				Иначе
					ТекЗаправка.fuelCardID = Справочники.уатПластиковыеКарты.ПустаяСсылка();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли; 
		Если ЗначениеЗаполнено(СтрПЛ.Прицепы) Тогда
			Для Каждого ТекПрицеп Из СтрПЛ.Прицепы Цикл
				СтруктураПрицепов = Новый Структура("vehicle");
				Если ЗначениеЗаполнено(ТекПрицеп.vehicle) Тогда 
					ТекПрицеп.vehicle = Справочники.уатТС.ПолучитьСсылку(ТекПрицеп.vehicle);
				Иначе
					ТекПрицеп.vehicle = Справочники.уатТС.ПустаяСсылка();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while receiving document reference by GUID.';ru='Возникла ошибка при получении ссылки на документ по GUID.'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьAddWaybill';ru='ДесериализоватьAddWaybill'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат СтрПЛ;
	КонецПопытки;
	
	Возврат СтрПЛ;
	
КонецФункции // ДесериализоватьAddWaybill()

// Функция предназначена для преобразования xml-строки с данными о изменяемых строках заданий по 
// заказам на ремонт
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о изменяемых заданиях
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица данных, содержащая ссылку на маршрутные листы, строки заданий и изменяемые данные
//
Функция ДесериализоватьAddOrderForRepair(Знач requestData, флОшибка) Экспорт
	
	СтрЗР = Новый Структура("Дата, ДатаНачала, ДатаОкончания, ТС, Контрагент, ПричинаОбращения, ВидРемонта, СтатусПодтвержденияВодителем, КомментарийВодителя, Ссылка");
	СтрЗР.Дата = ТекущаяДатаСеанса();
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть(); 
	
	Попытка
		Если Response.Получить("Date") <> Неопределено Тогда
			СтрЗР.Дата = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("Date"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field Date';ru='Ошибка разбора поля Date'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("orderID") <> Неопределено Тогда
			СтрЗР.Ссылка = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("orderID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field Date';ru='Ошибка разбора поля Date'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("repairStartDate") <> Неопределено Тогда
			СтрЗР.ДатаНачала = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("repairStartDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field repairStartDate';ru='Ошибка разбора поля repairStartDate'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("driverStatusID") <> Неопределено Тогда
			СтрЗР.СтатусПодтвержденияВодителем = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("driverStatusID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field driverStatusID';ru='Ошибка разбора поля driverStatusID'");
			КонецЕсли;
		КонецЕсли;
		Если Response.Получить("driverComment") <> Неопределено Тогда
			СтрЗР.КомментарийВодителя = Response.Получить("driverComment");
		КонецЕсли;
		Если Response.Получить("repairFinishDate") <> Неопределено Тогда
			СтрЗР.ДатаОкончания = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("repairFinishDate"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field repairFinishDate';ru='Ошибка разбора поля repairFinishDate'");
			КонецЕсли;
		КонецЕсли; 
		Если Response.Получить("vehicleID") <> Неопределено Тогда
			СтрЗР.ТС = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(Response.Получить("vehicleID"), флОшибка);
			Если флОшибка Тогда 
				ВызватьИсключение НСтр("en='Error parsing field vehicleID';ru='Ошибка разбора поля vehicleID'");
			КонецЕсли;
