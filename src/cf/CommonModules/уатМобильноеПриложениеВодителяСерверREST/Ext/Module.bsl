// Функция предназначена для разбора строки логина и формирования на её основе структуры
//
// Параметры:
//  loginData            - соответвие - соответвие, содержащие структуру логина пользователя мобильного приложения
//  resultCode           - число      - код результата выполнения метода
//  стрДанныеАвторизации - структура  - структура, полученная на основе параметра "loginData"
//
// Возвращаемое значение:
//   Булево - истина - метод выполнен успешно;
//          - ложь   - при выполнении метода возникла ошибка
//
Функция ДесериализоватьLoginData(Знач loginData, resultCode, стрДанныеАвторизации) Экспорт

	стрДанныеАвторизации = Новый Структура(
		"login, pass, trackerID, carID, car, addData, carNum", 
		"", 
		"", 
		"", 
		"", 
		Справочники.уатТС.ПустаяСсылка(),
		Новый Структура()
	);
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(loginData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	Если Response.Получить("login") <> Неопределено Тогда
		стрДанныеАвторизации.login     = Response.Получить("login");
	КонецЕсли;
	Если Response.Получить("pass") <> Неопределено Тогда
		стрДанныеАвторизации.pass     = Response.Получить("pass");
	КонецЕсли;
	Если Response.Получить("trackerID") <> Неопределено Тогда
		стрДанныеАвторизации.trackerID = Response.Получить("trackerID");
	КонецЕсли;
	Если Response.Получить("carID") <> Неопределено Тогда
		стрДанныеАвторизации.carID     = Response.Получить("carID");
	КонецЕсли; 

	Если ЗначениеЗаполнено(стрДанныеАвторизации.carID) Тогда
		строкаID = СокрЛП(стрДанныеАвторизации.carID);
		Если СтрДлина(строкаID) = 36 И СтрЧислоВхождений(строкаID, "-") = 4 Тогда 
			Попытка
				УникальныйИдентификаторТС = Новый УникальныйИдентификатор(строкаID);
				ТСОб = Справочники.уатТС.ПолучитьСсылку(УникальныйИдентификаторТС).ПолучитьОбъект();
			Исключение
				ТСОб = Неопределено;
			КонецПопытки;
			
			Если Не ТСОб = Неопределено Тогда 
				стрДанныеАвторизации.car = ТСОб.Ссылка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
	resultCode = 0;
	
	Возврат Истина;
	
КонецФункции // ДесериализоватьLoginData()

Функция ДесериализоватьrequestData(requestData) Экспорт
	
	стрДанныеrequestData = Новый Структура(
		"carNum, pushID, OSVersion, DeviceModel", 
		"",
		"",
		"",
		""
	);
	
	Если НЕ ЗначениеЗаполнено(requestData) Тогда
		Возврат стрДанныеrequestData;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(requestData);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	Request = Response.Получить("request");
	Если Request.Получить("carNum") <> Неопределено Тогда
		стрДанныеrequestData.carNum      = Request.Получить("carNum");
	КонецЕсли;
	Если Request.Получить("pushID") <> Неопределено Тогда
		стрДанныеrequestData.pushID      = Request.Получить("pushID");
	КонецЕсли;
	Если Request.Получить("OSVersion") <> Неопределено Тогда
		стрДанныеrequestData.OSVersion   = Request.Получить("OSVersion");
	КонецЕсли;
	Если Request.Получить("DeviceModel") <> Неопределено Тогда
		стрДанныеrequestData.DeviceModel = Request.Получить("DeviceModel");
	КонецЕсли;

	Возврат стрДанныеrequestData;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с координатами положения мобильного устройства
// в таблицу значений 1С
//
// Параметры:
//  VehiclePositions - строка - строка JSON, содержащая данные о местоположении мобильного устройства
//  флОшибка         - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица местоположений, полученная на основе параметра "VehiclePositions"
//
Функция ДесериализоватьVehiclePositions(Знач requestData, флОшибка) Экспорт
	
	ТабКоординат = Новый ТаблицаЗначений;
	
	ТабКоординат.Колонки.Добавить("Дата",         Новый ОписаниеТипов("Дата"));
	ТабКоординат.Колонки.Добавить("Лат",          Новый ОписаниеТипов("Число"));
	ТабКоординат.Колонки.Добавить("Лон",          Новый ОписаниеТипов("Число"));
	ТабКоординат.Колонки.Добавить("Алт",          Новый ОписаниеТипов("Число"));
	ТабКоординат.Колонки.Добавить("Скорость",     Новый ОписаниеТипов("Число"));
	ТабКоординат.Колонки.Добавить("Направление",  Новый ОписаниеТипов("Строка"));
	ТабКоординат.Колонки.Добавить("ЧасовойПояс",  Новый ОписаниеТипов("Число"));
	ТабКоординат.Колонки.Добавить("ДатаВремяUTC", Новый ОписаниеТипов("Дата"));
	
	Таксометр = Новый Структура("ДокументСсылка,transportingDistance,transportingDuration,waitingTime,pickupDistance,pickupDuration,pickupStartDate,waitingStartDate,factStartTime",
		Неопределено,0,0,0,0,0, Дата(1,1,1),Дата(1,1,1),Дата(1,1,1));
	
	Попытка
		Если ТипЗнч(requestData) = Тип("Строка") Тогда
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(requestData);
			Response = ПрочитатьJSON(ЧтениеJSON, Истина);
			ЧтениеJSON.Закрыть();
			
			positions = Response.Получить("positions"); 
		Иначе
			positions = requestData.Получить("positions"); 
		КонецЕсли;  
		Для Каждого ТекСтрока Из positions Цикл 
			Если ТекСтрока.Получить("datetime") <> Неопределено Тогда
				НовСтрока = ТабКоординат.Добавить();
				НовСтрока.Дата = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСтрока.Получить("datetime"), флОшибка);
				Если флОшибка Тогда 
					ВызватьИсключение НСтр("en='Error deserializing a datetime field';ru='Ошибка десериализации поля datetime'");
				КонецЕсли; 
				Если ТекСтрока.Получить("datetimeUTC") <> Неопределено Тогда
					НовСтрока.ДатаВремяUTC = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСтрока.Получить("datetimeUTC"), флОшибка);
					Если флОшибка Тогда 
						ВызватьИсключение НСтр("en='Error deserializing a datetimeUTC field';ru='Ошибка десериализации поля datetimeUTC'");
					КонецЕсли;
				КонецЕсли;
				Если ТекСтрока.Получить("lat") <> Неопределено Тогда
					НовСтрока.Лат  = ТекСтрока.Получить("lat");
				КонецЕсли;
				Если ТекСтрока.Получить("lon") <> Неопределено Тогда
					НовСтрока.Лон  = ТекСтрока.Получить("lon");
				КонецЕсли;
				Если ТекСтрока.Получить("speed") <> Неопределено Тогда
					НовСтрока.Скорость = ТекСтрока.Получить("speed");
				КонецЕсли; 
				Если ТекСтрока.Получить("alt") <> Неопределено Тогда
					НовСтрока.Алт = ТекСтрока.Получить("alt");
				КонецЕсли;
				Если ТекСтрока.Получить("direction") <> Неопределено Тогда
					НовСтрока.Направление = ТекСтрока.Получить("direction");
				КонецЕсли;
				Если ТекСтрока.Получить("timeZone") <> Неопределено Тогда
					НовСтрока.ЧасовойПояс  = ТекСтрока.Получить("timeZone");
				КонецЕсли;
			Иначе
				docType = "taxi";
				Если ТекСтрока.Получить("docType") <> Неопределено Тогда
					docType = ТекСтрока.Получить("docType");
				КонецЕсли;
				Если ТекСтрока.Получить("docID") <> Неопределено Тогда
					ТекущийGUID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСтрока.Получить("docID"), флОшибка); 
					Если docType = "taxi" Тогда
						ДокументСсылка = Документы["такЗаказТакси"].ПолучитьСсылку(ТекущийGUID); 
						Таксометр.ДокументСсылка = ДокументСсылка; 
					КонецЕсли;
				КонецЕсли;
				Если ТекСтрока.Получить("transportingDistance") <> Неопределено Тогда
					Таксометр.transportingDistance = ТекСтрока.Получить("transportingDistance");
				КонецЕсли; 
				Если ТекСтрока.Получить("transportingDuration") <> Неопределено Тогда
					Таксометр.transportingDuration = ТекСтрока.Получить("transportingDuration");
				КонецЕсли;
				Если ТекСтрока.Получить("waitingTime") <> Неопределено Тогда
					Таксометр.waitingTime = ТекСтрока.Получить("waitingTime");
				КонецЕсли;
				Если ТекСтрока.Получить("pickupDistance") <> Неопределено Тогда
					Таксометр.pickupDistance = ТекСтрока.Получить("pickupDistance");
				КонецЕсли;
				Если ТекСтрока.Получить("pickupDuration") <> Неопределено Тогда
					Таксометр.pickupDuration = ТекСтрока.Получить("pickupDuration");
				КонецЕсли;
				Если ТекСтрока.Получить("pickupStartDate") <> Неопределено Тогда
					Таксометр.pickupStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСтрока.Получить("pickupStartDate"), флОшибка);
				КонецЕсли;
				Если ТекСтрока.Получить("waitingStartDate") <> Неопределено Тогда
					Таксометр.waitingStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСтрока.Получить("waitingStartDate"), флОшибка);
				КонецЕсли;
				Если ТекСтрока.Получить("factStartTime") <> Неопределено Тогда
					Таксометр.factStartTime = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСтрока.Получить("factStartTime"), флОшибка);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	Исключение
		ТекстНСТР = НСтр("en='An error occurred while parsing the structure of ""positions"".';ru='Возникла ошибка при разборе структуры ""positions"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьVehiclePositions';ru='ДесериализоватьVehiclePositions'"), ТекстНСТР);
		флОшибка = Истина;
	КонецПопытки;
	
	ДанныеРезультат = Новый Структура("ТабКоординат, Таксометр", ТабКоординат, Таксометр);
	Возврат ДанныеРезультат;
	
КонецФункции // ДесериализоватьVehiclePositions()

// Функция предназначена для преобразования xml-строки с координатами положения мобильного устройства
// в таблицу значений 1С
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о местоположении мобильного устройства
//
// Возвращаемое значение:
//   Строка - ВидДвиженияГСМ
//
Функция ДесериализоватьGetGasStations(Знач requestData) Экспорт
	
	ВидДвиженияГСМ = "";
	Если ЗначениеЗаполнено(requestData) Тогда  
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(requestData);
		Response = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();
		
		fuellingTypeID = Response.Получить("fuellingTypeID");  
		Попытка
			ВидДвиженияГСМ = Строка(fuellingTypeID);
		Исключение 
			ВидДвиженияГСМ = "";
		КонецПопытки;
	КонецЕсли; 
	Возврат ВидДвиженияГСМ;
	
КонецФункции // ДесериализоватьGetGasStations()

// Функция предназначена для преобразования xml-строки с параметрами отбора сообщений водителей и диспетчеров.
//
// Параметры:
//  Filter   - строка - строка XML, содержащая данные для отбора сообщений
//  флОшибка - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Структура - параметры отбора, полученные на основе параметра "Filter"
//
Функция ДесериализоватьGetMessages(Знач Filter, флОшибка) Экспорт
	
	ПараметрыОтбора = Новый Структура("НачалоПериода, КонецПериода, КоличествоСообщений, Чат");
	
	Если Не ЗначениеЗаполнено(Filter) Тогда 
		Возврат ПараметрыОтбора;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(Filter);
	Response = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Если Response.Получить("limit") <> Неопределено Тогда
		ПараметрыОтбора.КоличествоСообщений = Response.Получить("limit");
	КонецЕсли;
	Если Response.Получить("startDate") <> Неопределено Тогда
		ПараметрыОтбора.НачалоПериода       = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("startDate"), Ложь);
	КонецЕсли;
	Если Response.Получить("endDate") <> Неопределено Тогда
		ПараметрыОтбора.КонецПериода        = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(Response.Получить("endDate"), Ложь); 
	КонецЕсли;
	Если Response.Получить("chatID") <> Неопределено Тогда
		Попытка
			ПараметрыОтбора.Чат = Справочники.уатЧаты.ПолучитьСсылку(Новый УникальныйИдентификатор(Response.Получить("chatID")));
		Исключение
			ПараметрыОтбора.Чат = Справочники.уатЧаты.ОбщийЧат;
		КонецПопытки;
	КонецЕсли;
	
	Возврат ПараметрыОтбора;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с сообщениями водителя в таблицу значений 1С
//
// Параметры:
//  Messages - строка - строка XML, содержащая данные о сообщениях водителя с мобильного устройства
//  флОшибка - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица сообщений, полученная на основе параметра "Messages"
//
Функция ДесериализоватьMessages(Знач Messages, флОшибка) Экспорт
	
	ТабСообщений = Новый ТаблицаЗначений;
	
	ТабСообщений.Колонки.Добавить("Дата",  Новый ОписаниеТипов("Дата"));
	ТабСообщений.Колонки.Добавить("Текст", Новый ОписаниеТипов("Строка"));
	ТабСообщений.Колонки.Добавить("ИдентификаторЧата",       Новый ОписаниеТипов("Строка"));
	ТабСообщений.Колонки.Добавить("ИдентификаторСообщения",  Новый ОписаниеТипов("Строка"));
	ТабСообщений.Колонки.Добавить("Чат",  Новый ОписаниеТипов("СправочникСсылка.уатЧаты"));
	
	Если ТипЗнч(Messages) = Тип("Массив") Тогда
		мсвСообщений = Messages;
	Иначе
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(Messages);
		мсвСообщений = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();  
	КонецЕсли;

	Для Каждого ТекСообщение Из мсвСообщений Цикл
		НовСтрока = ТабСообщений.Добавить();
		Если ТекСообщение.Получить("message") <> Неопределено Тогда
			НовСтрока.Текст = ТекСообщение.Получить("message");
		КонецЕсли;
		Если ТекСообщение.Получить("time") <> Неопределено Тогда
			НовСтрока.Дата  = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСообщение.Получить("time"), Ложь);
		КонецЕсли;
		Если ТекСообщение.Получить("chatID") <> Неопределено Тогда  
			НовСтрока.ИдентификаторЧата = ТекСообщение.Получить("chatID");
			Попытка
				НовСтрока.Чат = Справочники.уатЧаты.ПолучитьСсылку(Новый УникальныйИдентификатор(НовСтрока.ИдентификаторЧата));
			Исключение
				НовСтрока.Чат = Справочники.уатЧаты.ОбщийЧат;
			КонецПопытки;
		КонецЕсли;
		Если ТекСообщение.Получить("guid") <> Неопределено Тогда
			НовСтрока.ИдентификаторСообщения = ТекСообщение.Получить("guid");
		КонецЕсли;
	КонецЦикла;
 	ТабСообщений.Сортировать("Дата");
	
	Возврат ТабСообщений;
	
КонецФункции // ДесериализоватьMessages()

// Функция предназначена для преобразования xml-строки с сообщениями водителя в таблицу значений 1С
//
// Параметры:
//  Messages - строка - строка XML, содержащая данные о сообщениях водителя с мобильного устройства
//  флОшибка - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица сообщений, полученная на основе параметра "Messages"
//
Функция ДесериализоватьStatusMessages(Знач Messages, флОшибка) Экспорт
	
	ТабСообщений = Новый ТаблицаЗначений;
	
	ТабСообщений.Колонки.Добавить("ИдентификаторСообщения",  Новый ОписаниеТипов("Строка"));
	ТабСообщений.Колонки.Добавить("Прочитано",               Новый ОписаниеТипов("Булево"));
	ТабСообщений.Колонки.Добавить("ДатаПрочтения",           Новый ОписаниеТипов("Дата"));
	
	Если ТипЗнч(Messages) = Тип("Массив") Тогда
		мсвСообщений = Messages;
	Иначе
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(Messages);
		мсвСообщений = ПрочитатьJSON(ЧтениеJSON, Истина);
		ЧтениеJSON.Закрыть();  
	КонецЕсли;
	
	Для Каждого ТекСообщение Из мсвСообщений Цикл
		НовСтрока = ТабСообщений.Добавить();
		Если ТекСообщение.Получить("dateRead") <> Неопределено Тогда
			НовСтрока.ДатаПрочтения = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСообщение.Получить("dateRead"), Ложь);
		КонецЕсли;
		Если ТекСообщение.Получить("guid") <> Неопределено Тогда  
			НовСтрока.ИдентификаторСообщения = ТекСообщение.Получить("guid");
		КонецЕсли;
		Если ТекСообщение.Получить("read") <> Неопределено Тогда
			НовСтрока.Прочитано = ТекСообщение.Получить("read");
		КонецЕсли;
	КонецЦикла;

	Возврат ТабСообщений;
	
КонецФункции // ДесериализоватьStatusMessages()

Функция ДесериализоватьAcceptStatus(Знач Messages, флОшибка) Экспорт
	
	СтруктураРезультат = Новый Структура("МЛ, Дата, Статус");
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(Messages);
	ТекСообщение = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	Если ТекСообщение.Получить("ID") <> Неопределено Тогда
		ТекущийGUIDМЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("ID"), флОшибка);
		СтруктураРезультат.МЛ = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекущийGUIDМЛ);
	КонецЕсли;
	Если ТекСообщение.Получить("Date") <> Неопределено Тогда  
		СтруктураРезультат.Дата = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСообщение.Получить("Date"), флОшибка);
	КонецЕсли;
	Если ТекСообщение.Получить("AcceptStatus") <> Неопределено Тогда
		AcceptStatus = ТекСообщение.Получить("AcceptStatus"); 
		Если AcceptStatus = "accepted" Тогда
			Статус = Перечисления.уатСтатусыПринятияМЛВодителем.Принят;
		ИначеЕсли AcceptStatus = "not accepted" Тогда
			Статус = Перечисления.уатСтатусыПринятияМЛВодителем.Отклонен;
		Иначе
			Статус = Перечисления.уатСтатусыПринятияМЛВодителем.НеУстановлено;
		КонецЕсли;
		СтруктураРезультат.Статус = Статус;
	КонецЕсли;
	
	Возврат СтруктураРезультат;
	
КонецФункции

Функция ДесериализоватьNextPoint(Знач Messages, флОшибка) Экспорт
	
	СтруктураДанных = Новый Структура("ДокументСсылка, ПунктСсылка, НомерПункта, ДатаВыбораВодителем");
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(Messages);
	ТекСообщение = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	Если ТекСообщение.Получить("docID") <> Неопределено Тогда  
		ТекущийGUIDМЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("docID"), флОшибка);
		МЛ = Документы.уатМаршрутныйЛист.ПолучитьСсылку(ТекущийGUIDМЛ);
		СтруктураДанных.ДокументСсылка = МЛ;
	КонецЕсли;
	Если ТекСообщение.Получить("pointID") <> Неопределено Тогда  
		ТекущийGUIDПункта = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекСообщение.Получить("pointID"), флОшибка);
		Пункт = Справочники.уатПунктыНазначения.ПолучитьСсылку(ТекущийGUIDПункта);
		СтруктураДанных.ПунктСсылка = Пункт;
	КонецЕсли;
	Если ТекСообщение.Получить("pointNumber") <> Неопределено Тогда  
		СтруктураДанных.НомерПункта = Число(ТекСообщение.Получить("pointNumber"));
	КонецЕсли; 
	Если ТекСообщение.Получить("date") <> Неопределено Тогда  
		СтруктураДанных.ДатаВыбораВодителем = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекСообщение.Получить("date"), флОшибка);
	КонецЕсли;

	Возврат СтруктураДанных;
	
КонецФункции

// Функция предназначена для преобразования xml-строки с данными о изменяемых строках заданий по 
// маршрутным листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о изменяемых заданиях
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   Таблица значений - таблица данных, содержащая ссылку на маршрутные листы, строки заданий и изменяемые данные
//
Функция ДесериализоватьUpdateOrders(Знач requestData, флОшибка, ТабСД = Неопределено) Экспорт
	
	ТабМЛ = Новый ТаблицаЗначений;
	ТабМЛ.Колонки.Добавить("routeListRef",     Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист"));
	ТабМЛ.Колонки.Добавить("routeListID",      Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабМЛ.Колонки.Добавить("arrivalFact",      Новый ОписаниеТипов("Дата"));
	ТабМЛ.Колонки.Добавить("departureFact",    Новый ОписаниеТипов("Дата"));
	ТабМЛ.Колонки.Добавить("arrivalFactUTC",   Новый ОписаниеТипов("Дата"));
	ТабМЛ.Колонки.Добавить("departureFactUTC", Новый ОписаниеТипов("Дата"));
	ТабМЛ.Колонки.Добавить("isDone",           Новый ОписаниеТипов("Булево"));
	ТабМЛ.Колонки.Добавить("lineID",           Новый ОписаниеТипов("Строка"));
	ТабМЛ.Колонки.Добавить("orderResult",      Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабМЛ.Колонки.Добавить("orderResultRef",   Новый ОписаниеТипов("СправочникСсылка.уатПричиныЗакрытияЗаказов"));
	ТабМЛ.Колонки.Добавить("productivityID1",  Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабМЛ.Колонки.Добавить("productivityRef1", Новый ОписаниеТипов("СправочникСсылка.уатПараметрыВыработки"));
	ТабМЛ.Колонки.Добавить("productivityVal1", Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("productivityID2",  Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабМЛ.Колонки.Добавить("productivityRef2", Новый ОписаниеТипов("СправочникСсылка.уатПараметрыВыработки"));
	ТабМЛ.Колонки.Добавить("productivityVal2", Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_accepted",    Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_amount",      Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_amountPlace", Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_weight",      Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_volume",      Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("fact_reason",      Новый ОписаниеТипов("Строка")); 
	ТабМЛ.Колонки.Добавить("mark",             Новый ОписаниеТипов("Число"));
	ТабМЛ.Колонки.Добавить("signature",        Новый ОписаниеТипов("Строка"));
	
	ТабСтрок = Новый ТаблицаЗначений;
	ТабСтрок.Колонки.Добавить("lineID",           Новый ОписаниеТипов("Строка"));
	ТабСтрок.Колонки.Добавить("fact_accepted",    Новый ОписаниеТипов("Число"));
	ТабСтрок.Колонки.Добавить("fact_amount",      Новый ОписаниеТипов("Число"));
	ТабСтрок.Колонки.Добавить("fact_amountPlace", Новый ОписаниеТипов("Число"));
	ТабСтрок.Колонки.Добавить("fact_weight",      Новый ОписаниеТипов("Число"));
	ТабСтрок.Колонки.Добавить("fact_volume",      Новый ОписаниеТипов("Число"));
	ТабСтрок.Колонки.Добавить("fact_reason",      Новый ОписаниеТипов("Строка"));
	
	ТабСД = Новый ТаблицаЗначений; 
	ТабСД.Колонки.Добавить("ownerID",              Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабСД.Колонки.Добавить("documentID",           Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабСД.Колонки.Добавить("new",                  Новый ОписаниеТипов("Булево"));
	ТабСД.Колонки.Добавить("processingDate",       Новый ОписаниеТипов("Дата"));
	ТабСД.Колонки.Добавить("pointID",              Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабСД.Колонки.Добавить("typeID",               Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабСД.Колонки.Добавить("name",                 Новый ОписаниеТипов("Строка"));
	ТабСД.Колонки.Добавить("partner",              Новый ОписаниеТипов("Строка"));
	ТабСД.Колонки.Добавить("number",               Новый ОписаниеТипов("Строка"));
	ТабСД.Колонки.Добавить("date",                 Новый ОписаниеТипов("Дата"));
	ТабСД.Колонки.Добавить("comment",              Новый ОписаниеТипов("Строка"));
	ТабСД.Колонки.Добавить("ownerRef");
	ТабСД.Колонки.Добавить("documentRef");
	ТабСД.Колонки.Добавить("pointRef");
	ТабСД.Колонки.Добавить("typeRef");
	
	Попытка  
		Если ТипЗнч(requestData) = Тип("Строка") Тогда
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(requestData);
			мсвМЛ = ПрочитатьJSON(ЧтениеJSON, Истина);
			ЧтениеJSON.Закрыть();
		Иначе 
			мсвМЛ = requestData;
		КонецЕсли;
		
		Для Каждого ТекМЛ Из мсвМЛ Цикл
			ТекущийGUIDМЛ       = Неопределено;
			ДатаПрибытияФакт    = Неопределено;
			ДатаУбытияФакт      = Неопределено;
			ДатаПрибытияФактUTC = Неопределено;
			ДатаУбытияФактUTC   = Неопределено;
			флВыполнен          = Неопределено;
			Оценка              = Неопределено; 
			Подпись             = Неопределено;
			ТабСтрок.Очистить();
			РезультатВыполнения = Неопределено;
			Выработка1          = Неопределено;
			Выработка2          = Неопределено;
			ЗначВыработки1      = Неопределено;
			ЗначВыработки2      = Неопределено;
			Если ТекМЛ.Получить("ID") <> Неопределено Тогда  
				ТекущийGUIDМЛ = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекМЛ.Получить("ID"), флОшибка);
				
				Если флОшибка Тогда 
					ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
				КонецЕсли;
			КонецЕсли;
			мсвЗаказов = ТекМЛ.Получить("orders");
			Если мсвЗаказов <> Неопределено Тогда
				Для Каждого ТекЗаказ Из мсвЗаказов Цикл
					Если ТекЗаказ.Получить("arrivalFact") <> Неопределено Тогда  
						ДатаПрибытияФакт = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаказ.Получить("arrivalFact"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field arrivalFact';ru='Ошибка разбора поля arrivalFact'");
						КонецЕсли;
					КонецЕсли;
					Если ТекЗаказ.Получить("departureFact") <> Неопределено Тогда  
						ДатаУбытияФакт = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаказ.Получить("departureFact"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field departureFact';ru='Ошибка разбора поля departureFact'");
						КонецЕсли;
					КонецЕсли;
					Если ТекЗаказ.Получить("arrivalFactUTC") <> Неопределено Тогда  
						ДатаПрибытияФактUTC = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаказ.Получить("arrivalFactUTC"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field arrivalFactUTC';ru='Ошибка разбора поля arrivalFactUTC'");
						КонецЕсли;
					КонецЕсли;
					Если ТекЗаказ.Получить("departureFactUTC") <> Неопределено Тогда  
						ДатаУбытияФактUTC = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ТекЗаказ.Получить("departureFactUTC"), флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field departureFactUTC';ru='Ошибка разбора поля departureFactUTC'");
						КонецЕсли;
					КонецЕсли;
					Если ТекЗаказ.Получить("isDone") <> Неопределено Тогда  
						флВыполнен = ТекЗаказ.Получить("isDone");
					КонецЕсли; 
					Если ТекЗаказ.Получить("signature") <> Неопределено Тогда  
						Подпись = ТекЗаказ.Получить("signature");
					КонецЕсли;
					Если ТекЗаказ.Получить("mark") <> Неопределено Тогда  
						Оценка = ТекЗаказ.Получить("mark");
					КонецЕсли;
					Если ТекЗаказ.Получить("orderResult") <> Неопределено Тогда  
						РезультатВыполнения = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекЗаказ.Получить("orderResult"), флОшибка);
						
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Parse error orderResult';ru='Ошибка разбора orderResult'");
						КонецЕсли;
					КонецЕсли;  
					мсвВыработки = ТекЗаказ.Получить("productivity"); 
					Если ТекЗаказ.Получить("productivity") <> Неопределено Тогда
						Для Каждого ТекВыработка Из мсвВыработки Цикл
							Если ТекВыработка.Получить("ID") <> Неопределено Тогда  
								Если Выработка1 = Неопределено Тогда 
									Выработка1 = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекВыработка.Получить("ID"), флОшибка);
								Иначе 
									Выработка2 = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекВыработка.Получить("ID"), флОшибка);
								КонецЕсли; 
								Если флОшибка Тогда 
									ВызватьИсключение НСтр("en='Error parsing the productivity field';ru='Ошибка разбора поля productivity'");
								КонецЕсли;
							КонецЕсли;
							Если ТекВыработка.Получить("value") <> Неопределено Тогда   
								Если ЗначВыработки1 = Неопределено Тогда 
									ЗначВыработки1 = ТекВыработка.Получить("value");
								Иначе 
									ЗначВыработки2 = ТекВыработка.Получить("value");
								КонецЕсли; 
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					
					мсвГрузов = ТекЗаказ.Получить("items"); 
					Если мсвГрузов <> Неопределено Тогда
						Для Каждого ТекГруз Из мсвГрузов Цикл 
							fact_accepted = Неопределено;
							КоличествоФакт = Неопределено;
							КоличествоМестФакт = Неопределено;
							ВесФакт = Неопределено;
							ОбъемФакт = Неопределено;
							ПричинаРасхожденияФакт = Неопределено;
							itemID = Неопределено;
							
							Если ТекГруз.Получить("ID") <> Неопределено Тогда  
								itemID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ТекГруз.Получить("ID"), флОшибка);
								Если флОшибка Тогда 
									ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
								КонецЕсли;
							КонецЕсли;
							Если ТекГруз.Получить("fact_accepted") <> Неопределено Тогда  
								fact_accepted = ТекГруз.Получить("fact_accepted");
							КонецЕсли;
							Если ТекГруз.Получить("fact_amount") <> Неопределено Тогда  
								КоличествоФакт = ТекГруз.Получить("fact_amount");
							КонецЕсли;
							Если ТекГруз.Получить("fact_amountPlace") <> Неопределено Тогда  
								КоличествоМестФакт = ТекГруз.Получить("fact_amountPlace");
							КонецЕсли;
							Если ТекГруз.Получить("fact_weight") <> Неопределено Тогда  
								ВесФакт = ТекГруз.Получить("fact_weight");
							КонецЕсли;
							Если ТекГруз.Получить("fact_volume") <> Неопределено Тогда  
								ОбъемФакт = ТекГруз.Получить("fact_volume");
							КонецЕсли; 
							Если ТекГруз.Получить("fact_reason") <> Неопределено Тогда  
								ПричинаРасхожденияФакт = ТекГруз.Получить("fact_reason");
							КонецЕсли;
							Если НЕ itemID = Неопределено Тогда
								НоваяСтрока = табСтрок.Добавить();
								НоваяСтрока.lineID           = itemID;
								НоваяСтрока.fact_accepted    = fact_accepted;
								НоваяСтрока.fact_amount      = КоличествоФакт;
								НоваяСтрока.fact_amountPlace = КоличествоМестФакт;
								НоваяСтрока.fact_weight      = ВесФакт;
								НоваяСтрока.fact_volume      = ОбъемФакт;
								НоваяСтрока.fact_reason      = ПричинаРасхожденияФакт;
							КонецЕсли;
