КонецФункции // ЭтоФоновоеЗадание()

// Регистрирует ошибку в журнале регистрации, пойманную в обработчиках события.
//
Процедура ОбработатьОшибку(ПричинаОшибки, ВидОшибки="ПоддержкаОтраслевыхРешений", Данные=Неопределено, ПолноеОписаниеОшибки=ЛОЖЬ, ОтправитьОшибку=ИСТИНА) Экспорт
	
	Если ТипЗнч(ПричинаОшибки)=Тип("ИнформацияОбОшибке") Тогда
		Если ПолноеОписаниеОшибки Тогда
			Комментарий = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ПричинаОшибки);
		Иначе
			Комментарий = ОбработкаОшибок.КраткоеПредставлениеОшибки(ПричинаОшибки);
		КонецЕсли;
	Иначе
		Комментарий = СокрЛП(ПричинаОшибки);
	КонецЕсли;
	
	ИмяОперации = "ЦентрМониторинга."+ВидОшибки+".Ошибка";
	ИмяСобытия  = "Центр мониторинга."+ВидОшибки;
	
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, Данные, Комментарий);
	
	Если ОтправитьОшибку Тогда
		ЦентрМониторинга.ЗаписатьОперациюБизнесСтатистики(ИмяОперации, 1, Комментарий);
	КонецЕсли;
	
КонецПроцедуры // ОбработатьОшибку()

// Выполняет корректировку типовых форм на предмет указания компании разработчика и сведения об отправке статистики
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения - форма мониторинга центра мониторинга.
//
Процедура НастроитьЭлементыТиповыхФорм(Форма) Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрНайти(ВРег(Форма.ИмяФормы), ВРег("ИнтернетПоддержкаИСервисы")) > 0 Тогда
		
		Элемент = Форма.Элементы.ЦентрМониторингаРазрешитьОтправлятьДанные.СписокВыбора[0];
		Элемент.Представление = НСтр("ru = 'Разрешить автоматическую отправку сведений об использовании программы в фирму ""1С-Рарус""'");
		
		ВариантРазрешенияОтправкиДанныхНаТиповойАдрес(Форма);
		
	ИначеЕсли СтрНайти(ВРег(Форма.ИмяФормы), ВРег("ОтправкаКонтактнойИнформации")) > 0 Тогда
		
		// Предоставим возможность администратору удалить регистрационную информацию
		Элемент = Форма.Элементы.Найти("ФормаОтказаться");
		Если Элемент<>Неопределено И РольДоступна("ПолныеПрава") Тогда
			Элемент.Видимость = ИСТИНА;
			Элемент.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
		КонецЕсли;
		
	ИначеЕсли СтрНайти(ВРег(Форма.ИмяФормы), ВРег("НастройкиЦентраМониторинга")) > 0 Тогда
		
		// Если заполнен идентификатор, включаем видимость команды
		Форма.КоманднаяПанель.ПодчиненныеЭлементы.ФормаПолучитьИдентификатор.Видимость =
			Не ПустаяСтрока(Форма.Идентификатор);
		
		// Меняем заголовок команды
		ЗаголовокКоманды = ?(Форма.КоманднаяПанель.ПодчиненныеЭлементы.ФормаПолучитьИдентификатор.Видимость,
			НСтр("ru = 'Отправить пакет статистики'", ОбщегоНазначения.КодОсновногоЯзыка()),
			НСтр("ru = 'Получить идентификатор'", ОбщегоНазначения.КодОсновногоЯзыка()));
		
		// Устанавливаем новый заголовок команды
		Форма.КоманднаяПанель.ПодчиненныеЭлементы.ФормаПолучитьИдентификатор.Заголовок =
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1", ЗаголовокКоманды);
		
	КонецЕсли;
	
	ИзменитьПолучателяСтатистическойИнформации(Форма, "ЦентрМониторингаРазрешитьОтправлятьДанные");
	ИзменитьПолучателяСтатистическойИнформации(Форма, "РазрешитьОтправкуСтатистики");
	ИзменитьПолучателяСтатистическойИнформации(Форма, "Сообщение");
	ИзменитьПолучателяСтатистическойИнформации(Форма, "Заголовок");
	ИзменитьПолучателяСтатистическойИнформации(Форма, "ОтправлятьИнформациюОбОшибкахРасширеннаяПодсказка");
	ИзменитьПолучателяСтатистическойИнформации(Форма, "ПередачаСведенийВЦентрМониторингаФайловыйРежим");
	
КонецПроцедуры // НастроитьЭлементыТиповыхФорм()

Процедура ВариантРазрешенияОтправкиДанныхНаТиповойАдрес(Форма)
	
	// Определим индекс нового варианта отправки
	ИндексВарианта = 9;
	
	// Упростим обращение к элементам формы
	Элементы = Форма.Элементы;
	
	// Создаем группу для размещения копмплетка элементов управления
	ГруппаТиповой = Элементы.Добавить("ГруппаТиповой", Тип("ГруппаФормы"), Элементы.ГруппаРазрешитьОтправлятьДанные);
	ГруппаТиповой.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаТиповой.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаТиповой.ОтображатьЗаголовок = ЛОЖЬ;
	
	// Вносим отступ
	ДекорацияТиповой = Элементы.Добавить("ДекорацияТиповой", Тип("ДекорацияФормы"), ГруппаТиповой);
	ДекорацияТиповой.Ширина = 1;
	ДекорацияТиповой.Высота = 1;
	
	// Элемент управления нового варианты работы
	ЭлементТиповой = Элементы.Добавить("ЦентрМониторингаРазрешитьТиповой", Тип("ПолеФормы"), ГруппаТиповой);
	ЭлементТиповой.ПутьКДанным        = "ЦентрМониторингаРазрешитьОтправлятьДанные";
	ЭлементТиповой.Вид                = ВидПоляФормы.ПолеПереключателя;
	ЭлементТиповой.ВидПереключателя   = ВидПереключателя.Переключатель;
	ЭлементТиповой.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ЭлементТиповой.СписокВыбора.Добавить(ИндексВарианта, НСтр("ru = 'Разрешить отправку сведений в фирму ""1С""'"));
	ЭлементТиповой.УстановитьДействие("ПриИзменении", "РазрешитьОтправлятьДанныеСтороннемуПриИзменении");
	
	// Проверим текущие настройки и произведем их корректировку
	Если Форма.ЦентрМониторингаРазрешитьОтправлятьДанные = 1 Тогда
		
		ПараметрыСервиса = Новый Структура("Сервер,СерверТиповой");
		ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыСервиса);
		
		Если ВРег(СокрЛП(ПараметрыСервиса.Сервер))=ВРег(СокрЛП(ПараметрыСервиса.СерверТиповой)) Тогда
			Форма.ЦентрМониторингаРазрешитьОтправлятьДанные = ИндексВарианта;
			Элементы.ЦентрМониторингаАдресСервиса.Доступность = ЛОЖЬ;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры // ВариантРазрешенияОтправкиДанныхНаТиповойАдрес()

Процедура ИзменитьПолучателяСтатистическойИнформации(Форма, ИмяПоля)
	
	Элемент = Форма.Элементы.Найти(ИмяПоля);
	Если Элемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент.Заголовок = СтрЗаменить(Элемент.Заголовок, "1С", "1С-Рарус");
	Элемент.Заголовок = СтрЗаменить(Элемент.Заголовок, "1C", "1C-Rarus");
	
КонецПроцедуры // ИзменитьПолучателяСтатистическойИнформации()

Процедура ДобавитьОписаниеКонтакта(Контакты, Заголовок, Значение) Экспорт
	
	ОписаниеКонтакта = Новый Структура();
	ОписаниеКонтакта.Вставить("Заголовок", Заголовок);
	ОписаниеКонтакта.Вставить("Значение",  Значение);
	
	Контакты.Добавить(ОписаниеКонтакта);
	
КонецПроцедуры // ДобавитьОписаниеКонтакта()

Процедура ДобавитьОписаниеСайта(Сайты, Адрес, Подсказка) Экспорт
	
	ГиперссылкаЦвет  = ОбщегоНазначенияВызовСервера.ЦветСтиля("ГиперссылкаЦвет");
	ГиперссылкаШрифт = Новый Шрифт(,,,, Истина);
	
	ОписаниеСсылки = Новый ФорматированнаяСтрока(Адрес, ГиперссылкаШрифт, ГиперссылкаЦвет,, Адрес);
	ОписаниеСайта  = Новый ФорматированнаяСтрока(ОписаниеСсылки, Подсказка);
	
	Сайты.Добавить(ОписаниеСайта);
	
КонецПроцедуры // ДобавитьОписаниеСайта()

#КонецОбласти

#Область ПараметрыЦентраМониторинга

// Производит очистку настроек центра мониторинга, но сохраняет идентификаторы базы
//
Процедура ОчиститьПараметрыЦентраМониторинга() Экспорт
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	Блокировка = Новый БлокировкаДанных;
	Блокировка.Добавить("Константа.ПараметрыЦентраМониторинга");
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка.Заблокировать();
		
		// Получаем значения параметров.
		ПараметрыЦентраМониторинга = Новый Структура();
		ПараметрыЦентраМониторинга.Вставить("ИдентификаторИнформационнойБазы");
		ПараметрыЦентраМониторинга.Вставить("ИдентификаторИнформационнойБазыПостоянный");
		ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
		
		Хранилище = Новый ХранилищеЗначения(ПараметрыЦентраМониторинга, Новый СжатиеДанных(9));
		Константы.ПараметрыЦентраМониторинга.Установить(Хранилище);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ПричинаОшибки = ИнформацияОбОшибке();
		ОтменитьТранзакцию();
		ОбработатьОшибку(ПричинаОшибки);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры // ОчиститьПараметрыЦентраМониторинга()

// Выполняет проверку режима и адреса отправки статистики
//
// Возвращаемое значение:
//  Булево - признак отправки статистики
//
Функция ВключенаОтправкаСтатистики(ПроверитьТиповой=ЛОЖЬ) Экспорт
	
	// Формируем перечень получаемых параметров.
	ПараметрыСервиса = Новый Структура;
	ПараметрыСервиса.Вставить("ВключитьЦентрМониторинга");
	ПараметрыСервиса.Вставить("ЦентрОбработкиИнформацииОПрограмме");
	
	ПараметрыСервиса.Вставить("Сервер");
	ПараметрыСервиса.Вставить("АдресРесурса");
	ПараметрыСервиса.Вставить("АдресРесурсаДляДампов");
	ПараметрыСервиса.Вставить("Порт");
	ПараметрыСервиса.Вставить("ЗащищенноеСоединение");
	
	// Получаем значения параметров.
	ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыСервиса);
	
	// Если не включена отправка вовсе, на этом проверку можно завершить.
	Если НЕ(ПараметрыСервиса.ВключитьЦентрМониторинга ИЛИ ПараметрыСервиса.ЦентрОбработкиИнформацииОПрограмме) Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Проверяем создано ли регламентное задание.
	СборИОтправкаСтатистики = ЦентрМониторингаСлужебный.ПолучитьРегламентноеЗаданиеВнешнийВызов("СборИОтправкаСтатистики", ЛОЖЬ);
	Если СборИОтправкаСтатистики=Неопределено ИЛИ НЕ СборИОтправкаСтатистики.Использование Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Если статистика отправляется на основной сервер, то проверку можно завершить.
	Если ПараметрыСервиса.ВключитьЦентрМониторинга Тогда
		Возврат ИСТИНА;
	КонецЕсли;
	
	// Определим целевые значения параметров подключения к сервису.
	ПараметрыПоУмолчанию = ЦентрМониторингаСлужебный.ПолучитьПараметрыПоУмолчаниюВнешнийВызов();
	
	// Формируем представление адреса текущего
	СервисТекущий = Новый Массив();
	СервисТекущий.Добавить(СокрЛП(ПараметрыСервиса.Сервер));
	СервисТекущий.Добавить(СокрЛП(ПараметрыСервиса.АдресРесурса));
	СервисТекущий.Добавить(Формат(ПараметрыСервиса.Порт, "ЧГ=0"));
	ВРегАдресТекущий = ВРег(СтрСоединить(СервисТекущий));
	
	// Формируем представление адреса базового
	СервисБазовый = Новый Массив();
	СервисБазовый.Добавить(СокрЛП(ПараметрыПоУмолчанию.Сервер));
	СервисБазовый.Добавить(СокрЛП(ПараметрыПоУмолчанию.АдресРесурса));
	СервисБазовый.Добавить(Формат(ПараметрыПоУмолчанию.Порт, "ЧГ=0"));
	ВРегАдресБазовый = ВРег(СтрСоединить(СервисБазовый));
	
	Если ВРегАдресТекущий=ВРегАдресБазовый Тогда
		Возврат ИСТИНА;
	КонецЕсли;
	
	Если НЕ ПроверитьТиповой Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Формируем представление адреса типового
	СервисТиповой = Новый Массив();
	СервисТиповой.Добавить(СокрЛП(ПараметрыПоУмолчанию.СерверТиповой));
	СервисТиповой.Добавить(СокрЛП(ПараметрыПоУмолчанию.АдресРесурсаТиповой));
	СервисТиповой.Добавить(Формат(ПараметрыПоУмолчанию.ПортТиповой, "ЧГ=0"));
	ВРегАдресТиповой = ВРег(СтрСоединить(СервисТиповой));
	
	Возврат (ВРегАдресТекущий=ВРегАдресТиповой);
	
КонецФункции // ВключенаОтправкаСтатистики()

// Включает отправку статистики на сервер разработчика
//
// Параметры:
//  РегистрацияПродукта	 - Булево	 - признак согласия пользователя на отправку контактной информации
//  ОтправитьОперативно	 - Булево	 - оперативная отправка статистики
//  Сервер				 - Строка	 - сервер статистики
// 
// Возвращаемое значение:
//  Структура - измененные параметры центра мониторинга
//
Функция ВключитьОтправкуСтатистики(РегистрацияПродукта=ЛОЖЬ, ОтправитьОперативно=ЛОЖЬ, Сервер=Неопределено) Экспорт
	
	// Определим целевые значения параметров сервер.
	ПараметрыОтправки = Новый Структура();
	ПараметрыОтправки.Вставить("ВключитьЦентрМониторинга",           ПустаяСтрока(Сервер));
	ПараметрыОтправки.Вставить("ЦентрОбработкиИнформацииОПрограмме", НЕ ПустаяСтрока(Сервер));
	
	// Сбрасываем настройки отправки в значение по умолчанию.
	ПараметрыСервераПоУмолчанию(ПараметрыОтправки);
	
	// Устанавливаем параметры переданного сервера.
	Если НЕ ПустаяСтрока(Сервер) Тогда
		ПараметрыОтправки.Вставить("Сервер", Сервер);
	КонецЕсли;
	
	// Настройки сбора статистической информации.
	ПараметрыОтправки.Вставить("РегистрироватьИнформациюОСистеме",                ИСТИНА);
	ПараметрыОтправки.Вставить("РегистрироватьВерсииПодсистем",                   ЛОЖЬ);
	ПараметрыОтправки.Вставить("РегистрироватьБизнесСтатистику",                  ИСТИНА);
	ПараметрыОтправки.Вставить("РегистрироватьСтатистикуКонфигурации",            ИСТИНА);
	ПараметрыОтправки.Вставить("РегистрироватьНастройкуКонфигурации",             ИСТИНА);
	ПараметрыОтправки.Вставить("РегистрироватьПроизводительность",                ИСТИНА);
	ПараметрыОтправки.Вставить("РегистрироватьПроизводительностьТехнологическую", ИСТИНА);
	
	// Настройки отправки сведений о регистрации продукта.
	Если РегистрацияПродукта Тогда
		ПараметрыОтправки.Вставить("ЗапросКонтактнойИнформации", 1);
	КонецЕсли;
	ПараметрыОтправки.Вставить("КонтактнаяИнформацияИзменена", ИСТИНА);
	
	// Настройки интервалов сбора сведений и обмена сообщениями.
	Если ОтправитьОперативно Тогда
		
		// Выгружаем всю накопленную бизнес статистику
		ПараметрыОтправки.Вставить("ДатаКрайнегоПакета", Дата(1,1,1));
		
		// Установим признаки необходимости расчета показателей при ближайшем обмене
		СледующееФормирование = ТекущаяУниверсальнаяДата();
		ПараметрыОтправки.Вставить("СтатистикаКонфигурацииСледующееФормирование",    СледующееФормирование);
		ПараметрыОтправки.Вставить("БизнесСтатистикаСледующееФормирование",          СледующееФормирование);
		ПараметрыОтправки.Вставить("РегистрацияДамповСледующееФормирование",         СледующееФормирование);
		ПараметрыОтправки.Вставить("ОтправкаДанныхСледующееФормирование",            СледующееФормирование);
		ПараметрыОтправки.Вставить("ИдентификаторКонфигурацииСледующееФормирование", СледующееФормирование);
		
		// Параметры статистики разделяемые по областям данных.
		ПараметрыОтраслевойПоддержки = Новый Структура();
		ПараметрыОтраслевойПоддержки.Вставить("РазмерДанныхТаблицСледующееФормирование", СледующееФормирование);
		ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчетаСледующееФормирование", СледующееФормирование);
		УстановитьПараметрыОтраслевойПоддержки(ПараметрыОтраслевойПоддержки);
		
	КонецЕсли;
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения.
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат ПараметрыОтправки;
	КонецЕсли;
	
	// Помещаем параметры в константу.
	ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыОтправки);
	
	// Получим и настроим регламентное задание, отвечающее за сбор и отправку статистики.
	СборИОтправкаСтатистики = ЦентрМониторингаСлужебный.ПолучитьРегламентноеЗаданиеВнешнийВызов("СборИОтправкаСтатистики", ИСТИНА);
	Если НЕ СборИОтправкаСтатистики.Использование Тогда
		СборИОтправкаСтатистики.Использование = ИСТИНА;
		СборИОтправкаСтатистики.Записать();
		ЦентрМониторингаСлужебный.УстановитьРасписаниеПоУмолчаниюВнешнийВызов(СборИОтправкаСтатистики);
	КонецЕсли;
	
	// Возвращаем набор измененных параметров.
	Возврат ПараметрыОтправки;
	
КонецФункции // ВключитьОтправкуСтатистики()

#КонецОбласти

#Область СбореПоказателейСтатистики

Функция ИдентификаторБизнесРолиПользователя(Пользователь = Неопределено) Экспорт
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.АвторизованныйПользователь();
	КонецЕсли;
	
	Если Пользователи.ЭтоПолноправныйПользователь(Пользователь, Истина, Ложь) Тогда
		БизнесРольПользователя = "Администратор";
		Возврат ОбщегоНазначения.КонтрольнаяСуммаСтрокой(БизнесРольПользователя);
	КонецЕсли;
	
	БизнесРольПользователя = "ПрочийПользователь";
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.ПриПолученииБизнесРолиПользователя(БизнесРольПользователя, Пользователь);
	
	Возврат ОбщегоНазначения.КонтрольнаяСуммаСтрокой(БизнесРольПользователя);
	
КонецФункции // ИдентификаторБизнесРолиПользователя()

Функция КлючДанныхЗамеровСтатистики(ТипЗаписи, ИмяОперации, Параметры)
	
	// Попытаемся получить ключ данных от отраслевого решения.
	КлючДанных = Неопределено;
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.ПриПолученииКлючаДанныхЗамеровСтатистики(КлючДанных, ТипЗаписи, ИмяОперации, Параметры);
	
	Если КлючДанных <> Неопределено Тогда
		Возврат КлючДанных;
	КонецЕсли;
	
	// Макисмальная длина строкового ключа данных - 100 символов,
	// как в измерении "Ключ" регистра сведений "ЗамерыСтатистики".
	// Формат ключа: <ПрефиксВидаКлюча> + <ДанныеКлюча>.
	// Длина ПрефиксВидаКлюча - 1 символ, ДанныеКлюча - до 99 символов.
	
	ПрефиксВидаКлюча = "0";
	
	// ПрефиксВидаКлюча = "0": данные ключа содержат до трех строк фиксированной длины 32 символа -
	// MD5 хешей или уникальных идентификаторов с удаленными дефисами.
	// Каждая из этих строк предваряется односимвольным префиксом, указывающими на тип передаваемых в строке данных.
	// Формат данных ключа: <ПрефиксТипа1> + <Строка1> [ + ПрефиксТипа2> + <Строка2> [ + <ПрефиксТипа3> + <Строка3>]]
	
	ПрефиксТипаДанных = "1";
	
	// ПрефиксТипаДанных = "0": передается идентификатор пользователя ИБ.
	// ПрефиксТипаДанных = "1": передается идентификатор бизнес роли пользователя.
	
	КлючДанных = ПрефиксВидаКлюча + ПрефиксТипаДанных + Параметры.БизнесРольПользователя;
	Возврат КлючДанных;
	
КонецФункции // КлючДанныхЗамеровСтатистики()

// Определяет тип работы СУБД
//
// Параметры:
//  ИмяТипаСУБД - Строка - строковое представление типа СУБД.
//
// Возвращаемое значение:
//  Число - индекс типа СУБД
//
Функция ОпределитьТипСУБД(ИмяТипаСУБД="") Экспорт
	
	// Определим идентификаторы типов.
	ТипФайловаяБаза = 0;
	ТипMicrosoftSQL = 1;
	ТипPostgreSQL   = 2;
	ТипIBMDB2       = 3;
	ТипOracle       = 4;
	
	// Определим представления типов СУБД.
	ИмяФайловаяБаза = НСтр("ru = 'Файловая база'");
	ИмяMicrosoftSQL = "Microsoft SQL";
	ИмяPostgreSQL   = "Postgre SQL";
	ИмяIBMDB2       = "IBM DB2";
	ИмяOracle       = "Oracle Database";
	
	// Проверим параметры подключения соединения сервера к базе данных.
	ПараметрыСоединенияБазы = СтрРазделить(ВРег(СтрокаСоединенияИнформационнойБазы()), ";", ЛОЖЬ);
	Для каждого ТекущийПараметр Из ПараметрыСоединенияБазы Цикл
		КлючЗначение = СтрРазделить(СокрЛП(ТекущийПараметр), "=");
		Если КлючЗначение.Количество() < 2 Тогда
			Продолжить;
		ИначеЕсли СокрЛП(КлючЗначение[0]) = "FILE" Тогда
			ИмяТипаСУБД = ИмяФайловаяБаза;
			Возврат ТипФайловаяБаза;
		КонецЕсли;
		
	КонецЦикла;
	
	// Проверим порядок сортировки значения NULL в текущей СУБД.
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	NULL КАК ПолеСортировки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПолеСортировки УБЫВ";
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Если Выборка.ПолеСортировки = 1 Тогда
		
		// IBM DB2 не поддерживает конструкцию [...] в шаблоне операции ПОДОБНО.
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Т.Поле1 КАК Поле1
		|ИЗ
		|	(ВЫБРАТЬ
		|		""12456"" КАК Поле1) КАК Т
		|ГДЕ
		|	Т.Поле1 ПОДОБНО ""12[34]%""";
		
		Попытка
			Запрос = Новый Запрос(ТекстЗапроса);
			Если Запрос.Выполнить().Пустой() Тогда
				ИмяТипаСУБД = ИмяIBMDB2;
				Возврат ТипIBMDB2;
			Иначе
				ИмяТипаСУБД = ИмяMicrosoftSQL;
				Возврат ТипMicrosoftSQL;
			КонецЕсли;
		Исключение
			ИмяТипаСУБД = ИмяIBMDB2;
			Возврат ТипIBMDB2;
		КонецПопытки;
		
	Иначе
		
		// Oracle Database не поддерживает использование внутри оператора В вложенного запроса с модификатором ПЕРВЫЕ,
		// если внутри вложенного запроса есть обращения к полям внешнего запроса.
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Таблица.Поле1 КАК Поле1,
		|	Таблица.Поле2 КАК Поле2
		|ПОМЕСТИТЬ Таблица
		|ИЗ
		|	&Таблица КАК Таблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таблица1.Поле1 КАК Поле1
		|ИЗ
		|	Таблица КАК Таблица1
		|ГДЕ
		|	Таблица1.Поле1 В
		|			(ВЫБРАТЬ ПЕРВЫЕ 10
		|				Таблица2.Поле2 КАК Поле2
		|			ИЗ
		|				Таблица КАК Таблица2
		|			ГДЕ
		|				Таблица2.Поле2 = Таблица1.Поле1
		|			УПОРЯДОЧИТЬ ПО
		|				Поле2)";
		
		// Подготавливаем данные.
		ТаблицаДанных= Новый ТаблицаЗначений();
		ТаблицаДанных.Колонки.Добавить("Поле1", Новый ОписаниеТипов("Число"));
		ТаблицаДанных.Колонки.Добавить("Поле2", Новый ОписаниеТипов("Число"));
		
		НоваяСтрока = ТаблицаДанных.Добавить();
		НоваяСтрока.Поле1 = 1;
		НоваяСтрока.Поле2 = 2;
		
		НоваяСтрока = ТаблицаДанных.Добавить();
		НоваяСтрока.Поле1 = 2;
		НоваяСтрока.Поле2 = 3;
		
		НоваяСтрока = ТаблицаДанных.Добавить();
		НоваяСтрока.Поле1 = 5;
		НоваяСтрока.Поле2 = 5;
		
		// Проверяем.
		Попытка
			Запрос = Новый Запрос(ТекстЗапроса);
			Запрос.УстановитьПараметр("Таблица", ТаблицаДанных);
			Если Запрос.Выполнить().Пустой() Тогда
				ИмяТипаСУБД = ИмяOracle;
				Возврат ТипOracle;
			Иначе
				ИмяТипаСУБД = ИмяPostgreSQL;
				Возврат ТипPostgreSQL;
			КонецЕсли;
		Исключение
			ИмяТипаСУБД = ИмяOracle;
			Возврат ТипOracle;
		КонецПопытки;
		
	КонецЕсли;
	
КонецФункции // ОпределитьТипСУБД()

// Производит получение и кеширование параметров системы, которые невозможно получить в фоновом задании.
//
Процедура ОбновитьПараметрыПоДаннымСеанса(ПриоритетныйРежим=ЛОЖЬ) Экспорт
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Получим параметры выполнения обработчика.
	ПараметрыОтраслевойПоддержки = ПолучитьПараметрыОтраслевойПоддержки();
	ВремяСобытия                 = ТекущаяУниверсальнаяДата();
	
	// Расcчитаем маркеры изменения интервалов времени.
	ПоследняяПроверкаДанныхСеанса = МИН(ВремяСобытия, ПараметрыОтраслевойПоддержки.ПоследняяПроверкаДанныхСеанса);
	ИзменениеЧаса   = (НачалоЧаса  (ПоследняяПроверкаДанныхСеанса) <> НачалоЧаса  (ВремяСобытия));
	ИзменениеДня    = (НачалоДня   (ПоследняяПроверкаДанныхСеанса) <> НачалоДня   (ВремяСобытия));
	ИзменениеНедели = (НачалоНедели(ПоследняяПроверкаДанныхСеанса) <> НачалоНедели(ВремяСобытия));
	
	// Подготовим структуру для фиксации измененных параметров.
	ПараметрыДляЗаписи = Новый Структура();
	
	// При изменении интервала, обновляем параметры.
	Если ИзменениеЧаса Тогда
		ПараметрыДляЗаписи.Вставить("ПоследняяПроверкаДанныхСеанса", ВремяСобытия);
	КонецЕсли;
	
	// Получаем состояние системы защиты.
	Если ИзменениеДня ИЛИ ПриоритетныйРежим ИЛИ ПараметрыОтраслевойПоддержки.ПараметрыЛицензий=Неопределено Тогда
		
		ПараметрыЛицензий    = Новый Массив();
		НайденаСистемаЗащиты = ЛОЖЬ;
		
		// При работе со внешними копонентами могут произойти разные внештатные ситуации.
		пр_ПоддержкаОтраслевыхРешений.ПолучитьПараметрыЛицензий(пр_ПоддержкаОтраслевыхРешений, ПараметрыЛицензий, НайденаСистемаЗащиты);
		
		Если НайденаСистемаЗащиты ИЛИ ПараметрыОтраслевойПоддержки.ПараметрыЛицензий=Неопределено Тогда
			ПараметрыДляЗаписи.Вставить("ПараметрыЛицензий",    ПараметрыЛицензий);
			ПараметрыДляЗаписи.Вставить("НайденаСистемаЗащиты", НайденаСистемаЗащиты);
		КонецЕсли;
		
	КонецЕсли;
	
	// Корректируем ключевую регистрационную информацию.
	Если (ИзменениеДня ИЛИ ПриоритетныйРежим) И ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей") Тогда
		
		КонтактнаяИнформацияИзменена = ЛОЖЬ;
		
		// Получаем данные из безопасного хранилища.
		МодульИнтернетПоддержкаПользователей = ОбщегоНазначения.ОбщийМодуль("ИнтернетПоддержкаПользователей");
		ИДПодсистемыИПП = МодульИнтернетПоддержкаПользователей.ИдентификаторПодсистемы();
		ХранилищеДанных = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ИДПодсистемыИПП, "regnumber,inn,kpp,login");
		
		// Получим параметры регистрации продукта
		РегистрацияПродукта = ПараметрыОтраслевойПоддержки.РегистрацияПродукта;
		
		// Проверяем корректность заполнения контактной информации.
		Если ПустаяСтрока(РегистрацияПродукта.РегНомер) И ХранилищеДанных.regnumber<>Неопределено Тогда
			РегистрацияПродукта.РегНомер = ХранилищеДанных.regnumber;
			КонтактнаяИнформацияИзменена = ИСТИНА;
		КонецЕсли;
		Если ПустаяСтрока(РегистрацияПродукта.ИНН) И ХранилищеДанных.inn<>Неопределено Тогда
			РегистрацияПродукта.ИНН      = ХранилищеДанных.inn;
			КонтактнаяИнформацияИзменена = ИСТИНА;
		КонецЕсли;
		Если ПустаяСтрока(РегистрацияПродукта.КПП) И ХранилищеДанных.kpp<>Неопределено Тогда
			РегистрацияПродукта.КПП      = ХранилищеДанных.kpp;
			КонтактнаяИнформацияИзменена = ИСТИНА;
		КонецЕсли;
		Если ПустаяСтрока(РегистрацияПродукта.ИТС) И ХранилищеДанных.login<>Неопределено Тогда
			РегистрацияПродукта.ИТС      = ХранилищеДанных.login;
			КонтактнаяИнформацияИзменена = ИСТИНА;
		КонецЕсли;
		
		Если КонтактнаяИнформацияИзменена Тогда
			ЗаписатьРегистрациюПродукта(РегистрацияПродукта);
		КонецЕсли;
		
	КонецЕсли;
	
	// Записываем измененные параметры в константу.
	Если ПараметрыДляЗаписи.Количество() > 0 Тогда
		УстановитьПараметрыОтраслевойПоддержки(ПараметрыДляЗаписи);
	КонецЕсли;
	
КонецПроцедуры // ОбновитьПараметрыПоДаннымСеанса()

// Производит получение сведений об используемых лицензиях в продукте
//
// Параметры:
//  МодульОбработчика	 - ФормаКлиентскогоПриложения	 - форма настройки центра мониторинга
//  ПараметрыЛицензий	 - СписокЗначений				 - список систем защиты программного продукта
//  НайденаСистемаЗащиты - Булево						 - признак наличия системы защиты
// 
// Возвращаемое значение:
//  Соответствие - Параметры лицензирования
//
Функция ПолучитьПараметрыЛицензий(МодульОбработчика, ПараметрыЛицензий = Неопределено, НайденаСистемаЗащиты = ЛОЖЬ) Экспорт
	
	// Последовательно собираем сведения о лицензиях со всех систем защиты.
	Если ПараметрыЛицензий = Неопределено Тогда
		ПараметрыЛицензий = Новый Соответствие();
	КонецЕсли;
	
	// Наличие системы защиты определим по отклику из соответсвующих модулей.
	НайденаСистемаЗащиты = ЛОЖЬ;
	
	// Получаем параметры лицензий защиты.
	Попытка
		ПолучитьПараметрыЛицензийРАРУС(МодульОбработчика, ПараметрыЛицензий, НайденаСистемаЗащиты);
	Исключение
		ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.РАРУС");
	КонецПопытки;
	
	// Получаем параметры лицензий защиты СЛК (Библиотека функциональных подсистем).
	Попытка
		ПолучитьПараметрыЛицензийСЛК_БФП(МодульОбработчика, ПараметрыЛицензий, НайденаСистемаЗащиты);
	Исключение
		ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.СЛК_БФП");
	КонецПопытки;
	
	// Получаем параметры лицензий защиты СЛК (библиотека от Катран).
	Попытка
		ПолучитьПараметрыЛицензийСЛК_Катран(МодульОбработчика, ПараметрыЛицензий, НайденаСистемаЗащиты);
	Исключение
		ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.СЛК_Катран");
	КонецПопытки;
	
	// Возвращаем собранную коллекцию.
	Возврат ПараметрыЛицензий;
	
КонецФункции // ПолучитьПараметрыЛицензий()

Процедура ПолучитьПараметрыЛицензийРАРУС(МодульОбработчика, ПараметрыЛицензий, ЕстьСистемаЗащиты)
	
	// Проверим наличие в конфигурации ключевого общего модуля.
	Если Метаданные.ОбщиеМодули.Найти("ЛицензированиеСервер") = Неопределено
			ИЛИ Метаданные.ОбщиеМодули.Найти("ЛицензированиеПоддержка") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим, запущена ли система защиты
	Если Метаданные.ПараметрыСеанса.Найти("СписокСертификатов") <> Неопределено Тогда
		Попытка
			СписокСертификатов = ПараметрыСеанса.СписокСертификатов.Получить();
			Если СписокСертификатов=Неопределено ИЛИ СписокСертификатов.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.РАРУС");
		КонецПопытки;
	КонецЕсли;
	
	// Получим перечень продуктов, используемых в конфигурации.
	МодульЛицензированиеПоддержка = ОбщегоНазначения.ОбщийМодуль("ЛицензированиеПоддержка");
	Попытка
		СписокРешений = МодульЛицензированиеПоддержка.СписокРешений();
	Исключение
		Попытка
			СписокРешений = МодульЛицензированиеПоддержка.ПолучитьСписокРешений();
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.РАРУС");
			Возврат;
		КонецПопытки;
	КонецПопытки;
	
	// Инициализируем переменные.
	ОписаниеОшибки = "";
	КодОшибки      = 0;
	
	// Определим имя защищенной обработки.
	Для каждого Решение Из СписокРешений Цикл
		
		// Если найдено хоть одно решение, то установим признак наличия системы защиты
		ЕстьСистемаЗащиты = ИСТИНА;
		
		// Получим защищенную обработку и активную копоненту защиты.
		Попытка
			Обработка = ОбщегоНазначения.ОбщийМодуль("ЛицензированиеСервер").ПолучитьЗащищеннуюОбработку(Решение.Ключ, ОписаниеОшибки, КодОшибки);
			Если Обработка = Неопределено ИЛИ Обработка.Компонента = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.РАРУС");
			Продолжить;
		КонецПопытки;
		Компонента = Обработка.Компонента;
		
		// Получим версию защиты.
		ВерсияЗащиты = Компонента.Версия;
		
		// Определим тип ключа и режим работы системы защиты РАРУС.
		// 1 - аппаратный (версия 1);
		// 2 - программный 1С-Рарус;
		// 3 - аппаратный (версия 2);
		// 4 - программный СЛК;
		Попытка
			
			ТипКлючаЗащиты = 0;
			Если НЕ Компонента.ПолучитьТипКлючаЗащиты(ТипКлючаЗащиты) Тогда
				ОписаниеОшибки = Компонента.ОписаниеОшибки;
				ТипКлючаЗащиты = 0;
			КонецЕсли;
			
		Исключение
			ПричинаОшибки  = ИнформацияОбОшибке();
			ОписаниеОшибки = КраткоеПредставлениеОшибки(ПричинаОшибки);
		КонецПопытки;
		
		// Получаем параметры ключа СЛК
		Если ТипКлючаЗащиты = 0 ИЛИ ТипКлючаЗащиты = 4 Тогда
			
			Попытка
				Параметры = Неопределено;
				Если Компонента.ПолучитьПараметрыКлючаСЛК(Решение.Ключ, Параметры) Тогда
					
					Если ТипЗнч(Параметры)=Тип("Строка") Тогда
						ЧтениеJSON = Новый ЧтениеJSON;
						ЧтениеJSON.УстановитьСтроку(Параметры);
						Параметры = ПрочитатьJSON(ЧтениеJSON);
						ЧтениеJSON.Закрыть();
					КонецЕсли;
					
					МодульОбработчика.ПриПолученииПараметровЛицензии(
						ПараметрыЛицензий, 2, Компонента.ИдентификаторПродукта, Решение.Значение,
						Параметры, ВерсияЗащиты);
					Продолжить;
					
				Иначе
					ОписаниеОшибки = Компонента.ОписаниеОшибки;
					ТипКлючаЗащиты = -4;
				КонецЕсли;
			Исключение
				ПричинаОшибки  = ИнформацияОбОшибке();
				ОписаниеОшибки = КраткоеПредставлениеОшибки(ПричинаОшибки);
				ТипКлючаЗащиты = -4;
			КонецПопытки;
			
		КонецЕсли;
		
		// Получаем параметры ключа
		Если ТипКлючаЗащиты <> 4 Тогда
			
			// Формируем структуру параметров лицензии по формату.
			Параметры = Новый Структура("Type,Enabled,Blocked,Workable,Version,KeyNo,KeyID,KeyType,ServiceType,LicenceCount,BlankKeyNo,ActivationCode,ExpireDate,DaysLeft,Expired,Counters,Flags,ProductName,ArticleName,Счетчик2,Счетчик3,ВсегоЗаМесто,СвободноЗаМесто,ВсегоЗаСессию,СвободноЗаСессию,ОписаниеОшибки");
			
			// Читаем параметры из копоненты.
			Если Компонента.ПолучитьПараметрыКлючаЗащиты(Параметры.ВсегоЗаМесто, Параметры.СвободноЗаМесто, Параметры.ВсегоЗаСессию, Параметры.СвободноЗаСессию, Параметры.Flags, Параметры.Counters, Параметры.Счетчик2, Параметры.Счетчик3, Параметры.ExpireDate, Параметры.KeyType, Параметры.KeyNo, Параметры.BlankKeyNo, Параметры.ActivationCode, Параметры.ArticleName) Тогда
				
				// Заполняем рассчетные параметры.
				Если ТипКлючаЗащиты=0 Тогда
					Параметры.Type = ?(Параметры.KeyNo = Параметры.BlankKeyNo, "Virtual", "USB");
				КонецЕсли;
				Параметры.Enabled      = ИСТИНА;
				Параметры.Blocked      = ЛОЖЬ;
				Параметры.Workable     = ИСТИНА;
				Параметры.Version      = Формат(ТипКлючаЗащиты, "ЧН=0; ЧГ=0");
				Параметры.KeyID        = Компонента.ИдентификаторПродукта;
				Параметры.KeyType      = ?(Параметры.KeyType=1, 3, 5);
				Параметры.ServiceType  = 0;
				Параметры.LicenceCount = МАКС(Параметры.ВсегоЗаМесто, Параметры.ВсегоЗаСессию);
				Если ЗначениеЗаполнено(Параметры.ExpireDate) И Параметры.ExpireDate > Дата(1980, 1, 1) Тогда
					Параметры.DaysLeft = Цел((НачалоДня(Параметры.ExpireDate) - НачалоДня(ТекущаяДатаСеанса())) / 24 / 60 / 60);
					Параметры.Expired  = (НачалоДня(Параметры.ExpireDate) < НачалоДня(ТекущаяДатаСеанса()));
				Иначе
					Параметры.Expired  = ЛОЖЬ;
				КонецЕсли;
				Параметры.ProductName = Решение.Значение;
				
				// Возможно при вызове предыдущих методов компоненты были ошибки, включим их в пакет
				Параметры.ОписаниеОшибки = ОписаниеОшибки;
				
				// Вызываем обработчик чтения лицензии.
				МодульОбработчика.ПриПолученииПараметровЛицензии(ПараметрыЛицензий, 1, Компонента.ИдентификаторПродукта, Решение.Значение, Параметры, ВерсияЗащиты);
				
			Иначе
				ОписаниеОшибки = Компонента.ОписаниеОшибки;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // ПолучитьПараметрыЛицензийРАРУС()

Процедура ПолучитьПараметрыЛицензийСЛК_БФП(МодульОбработчика, ПараметрыЛицензий, ЕстьСистемаЗащиты)
	
	// Определим параметры получения данных лицензий.
	ПоВсемСериям    = ИСТИНА;
	ТолькоДоступные = ЛОЖЬ;
	
	// Проверим наличие в конфигурации общего модуля из библиотеки БФП.
	Если Метаданные.ОбщиеМодули.Найти("слкМенеджерЗащитыПовтИсп") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	МодульМенеджерЗащиты = ОбщегоНазначения.ОбщийМодуль("слкМенеджерЗащитыПовтИсп");
	
	// Проверим, запущена ли система защиты
	Если Метаданные.ПараметрыСеанса.Найти("слкМенеджерЗащиты") <> Неопределено Тогда
		Попытка
			СписокСерийЗащиты = СтрЗаменить(СтрЗаменить(ПараметрыСеанса.слкМенеджерЗащиты,",","") ,";","");
			Если ПустаяСтрока(СписокСерийЗащиты) Тогда
				Возврат;
			КонецЕсли;
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.СЛК_БФП");
		КонецПопытки;
	КонецЕсли;
	
	// Найдем серию активной лицензии
	Для Каждого ЭлементЗащиты Из МодульМенеджерЗащиты.ПолучитьМенеджерЗащиты(ИСТИНА) Цикл
		
		// Если найдено хоть одно решение, то установим признак наличия системы защиты
		ЕстьСистемаЗащиты = ИСТИНА;
		
		// Получаем центральный объект системы защиты СЛК.
		Попытка
			МенеджерОбъектов = МодульМенеджерЗащиты.МенеджерОбъектовСерииЗащиты(ЭлементЗащиты.Ключ);
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.СЛК_БФП");
			Продолжить;
		КонецПопытки;
		
		// Проверяем, удалось ли подключиться к менеджеру защиты.
		Если МенеджерОбъектов = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Получим версию защиты
		ИнформациюОСервере = МенеджерОбъектов.ПолучитьИнформациюОСервере();
		ВерсияЗащиты = ?(ИнформациюОСервере=Неопределено ИЛИ НЕ ИнформациюОСервере.Свойство("Version"), "", ИнформациюОСервере.Version);
		
		// Получаем лицензии доступные по текущей серии.
		Лицензии = МенеджерОбъектов.ПопыткаПолучитьЛицензии(ПоВсемСериям, ТолькоДоступные);
		Если Лицензии=Неопределено Тогда
			ОписаниеОшибки = МенеджерОбъектов.ПолучитьОписаниеОшибки();
			Продолжить;
		КонецЕсли;
		
		// Вносим сведения о лицензиях в нашу коллекцию.
		Для каждого Параметры Из Лицензии Цикл
			МодульОбработчика.ПриПолученииПараметровЛицензии(ПараметрыЛицензий, 3, ЭлементЗащиты.Ключ, ЭлементЗащиты.Значение.Наименование, Параметры, ВерсияЗащиты);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры // ПолучитьПараметрыЛицензийСЛК_БФП()

Процедура ПолучитьПараметрыЛицензийСЛК_Катран(МодульОбработчика, ПараметрыЛицензий, ЕстьСистемаЗащиты)
	
	// Определим параметры получения данных лицензий.
	ПоВсемСериям    = ИСТИНА;
	ТолькоДоступные = ЛОЖЬ;
	
	// Если конфигурация построена на базе библиотеки Катран, то достаточно вызвать служебную функцию.
	Если Метаданные.ОбщиеМодули.Найти("СЛКПовтИсп") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем центральный объект системы защиты СЛК.
	Попытка
		МенеджерОбъектов = ОбщегоНазначения.ОбщийМодуль("СЛКПовтИсп").МенеджерОбъектов();
	Исключение
		ОбработатьОшибку(ИнформацияОбОшибке(), "ПараметрыЛицензий.СЛК_Катран");
		Возврат;
	КонецПопытки;
	
	// Проверяем, удалось ли подключиться к менеджеру защиты.
	Если МенеджерОбъектов = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	// Менеджер защиты есть, установим признак наличия системы защиты
	ЕстьСистемаЗащиты = ИСТИНА;
	
	// Получим версию защиты
	ИнформациюОСервере = МенеджерОбъектов.ПолучитьИнформациюОСервере();
	ВерсияЗащиты = ?(ИнформациюОСервере = Неопределено ИЛИ НЕ ИнформациюОСервере.Свойство("Version"), "", ИнформациюОСервере.Version);
	
	// Получаем лицензии доступные по текущей серии.
	Лицензии = МенеджерОбъектов.ПопыткаПолучитьЛицензии(ПоВсемСериям, ТолькоДоступные);
	Если Лицензии = Неопределено Тогда
		ОписаниеОшибки = МенеджерОбъектов.ПолучитьОписаниеОшибки();
		Возврат;
	КонецЕсли;
	
	// Вносим сведения о лицензиях в нашу коллекцию.
	Для каждого Параметры Из Лицензии Цикл
		МодульОбработчика.ПриПолученииПараметровЛицензии(ПараметрыЛицензий, 3, Параметры.KeyID, "", Параметры, ВерсияЗащиты);
	КонецЦикла;
	
КонецПроцедуры // ПолучитьПараметрыЛицензийСЛК_Катран()

Процедура РегистрироватьРазмерДанныхТаблицИнформационнойБазы() Экспорт
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Метод актуален только для платформы версии 8.3.15 и выше.
	ТехническиеПараметры = Новый СистемнаяИнформация;
	МожноПолучитьРазмер  = (ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ТехническиеПараметры.ВерсияПриложения, "8.3.15.1489") >= 0);
	
	ВидСтатистикиРазмер = 9;
	НулеваяОбласть      = РегистрыСведений.ОбластиСтатистики.ПолучитьСсылку("0", ИСТИНА);
	
	СтруктураБазыДанных  = ПолучитьСтруктуруХраненияБазыДанных(, ЛОЖЬ);
	ВидыКлючевыхТаблиц   = Новый Структура("Основная,Main,ТабличнаяЧасть,TabularSection");
	МассивИменМетаданных = Новый Массив;
	ИтоговыйРазмерБазы   = 0;
	
	НаборЗаписей = РегистрыСведений.СтатистикаКонфигурации.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ВидСтатистики.Установить(ВидСтатистикиРазмер);
	НаборЗаписей.Отбор.ИдентификаторОбластиСтатистики.Установить(НулеваяОбласть);
	
	ОбработанныеТаблицы = Новый Соответствие();
	
	Для каждого ОписаниеТаблицы Из СтруктураБазыДанных Цикл
		
		Если ПустаяСтрока(ОписаниеТаблицы.Метаданные) ИЛИ ПустаяСтрока(СтрЗаменить(ОписаниеТаблицы.ИмяТаблицы,".","")) Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ВидыКлючевыхТаблиц.Свойство(ОписаниеТаблицы.Назначение) Тогда
			Продолжить;
		КонецЕсли;
		
		// Одному объекту метаданных может соответствовать несколько таблиц БД
		Если ОбработанныеТаблицы[ОписаниеТаблицы.Метаданные]<>Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОбработанныеТаблицы.Вставить(ОписаниеТаблицы.Метаданные, 0);
		
		// Стандартные табличные части могут быть не найдены
		ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ОписаниеТаблицы.Метаданные);
		Если ОбъектМетаданных=Неопределено Тогда
			Продолжить;
		КонецЕсли;
		РазмерТаблицы = 0;
		
		// Получаем значение размера таблицы
		Если МожноПолучитьРазмер Тогда
			
			МассивИменМетаданных.Очистить();
			МассивИменМетаданных.Добавить(ОбъектМетаданных);
			
			Попытка
				РазмерТаблицы = Вычислить("ПолучитьРазмерДанныхБазыДанных(Новый Массив(), МассивИменМетаданных)");
			Исключение
				ОбработатьОшибку(ИнформацияОбОшибке(), "СобратьОтраслевуюСтатистику");
			КонецПопытки;
			
		КонецЕсли;
		
		// Добавляем запись в регистр сведений "Статистика конфигурации".
		Запись = НаборЗаписей.Добавить();
		Запись.ВидСтатистики                  = ВидСтатистикиРазмер;
		Запись.ИдентификаторОбластиСтатистики = НулеваяОбласть;
		Запись.ОперацияСтатистики             = ЦентрМониторингаПовтИсп.ПолучитьСсылкуОперацииСтатистики(ОписаниеТаблицы.ИмяТаблицы);
		Запись.Значение                       = РазмерТаблицы;
		
		ИтоговыйРазмерБазы = ИтоговыйРазмерБазы + РазмерТаблицы;
		
	КонецЦикла;
	
	НаборЗаписей.ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов");
	НаборЗаписей.ОбменДанными.Загрузка = ИСТИНА;
	НаборЗаписей.ОбменДанными.Получатели.АвтоЗаполнение = ЛОЖЬ;
	НаборЗаписей.Записать(ИСТИНА);
	
КонецПроцедуры // РегистрироватьРазмерДанныхТаблицИнформационнойБазы()

Процедура ИсправитьКоличествоЗаписейТаблицИнформационнойБазы() Экспорт
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	ВидСтатистикиРазмер = 0;
	НулеваяОбласть      = РегистрыСведений.ОбластиСтатистики.ПолучитьСсылку("0", ИСТИНА);
	
	// Создаем запрос для поиска отсутствующих записей
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтатистикаКонфигурацииВид9.ОперацияСтатистики КАК ОперацияСтатистики
	|ИЗ
	|	РегистрСведений.СтатистикаКонфигурации КАК СтатистикаКонфигурацииВид9
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатистикаКонфигурации КАК СтатистикаКонфигурацииВид1
	|		ПО (СтатистикаКонфигурацииВид1.ВидСтатистики = 1)
	|			И СтатистикаКонфигурацииВид9.ИдентификаторОбластиСтатистики = СтатистикаКонфигурацииВид1.ИдентификаторОбластиСтатистики
	|			И СтатистикаКонфигурацииВид9.ОперацияСтатистики = СтатистикаКонфигурацииВид1.ОперацияСтатистики
	|ГДЕ
	|	СтатистикаКонфигурацииВид9.ВидСтатистики = 9
	|	И СтатистикаКонфигурацииВид9.ИдентификаторОбластиСтатистики = &НулеваяОбласть
	|	И СтатистикаКонфигурацииВид1.Значение ЕСТЬ NULL";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("НулеваяОбласть", НулеваяОбласть);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ОперацияСтатистики) Тогда
			Продолжить;
		КонецЕсли;
		
		Запись = РегистрыСведений.СтатистикаКонфигурации.СоздатьМенеджерЗаписи();
		Запись.ВидСтатистики                  = ВидСтатистикиРазмер;
		Запись.ИдентификаторОбластиСтатистики = НулеваяОбласть;
		Запись.ОперацияСтатистики             = Выборка.ОперацияСтатистики;
		Запись.Значение                       = 0;
		Запись.Записать(ИСТИНА);
		
	КонецЦикла;
	
КонецПроцедуры // ИсправитьКоличествоЗаписейТаблицИнформационнойБазы()

Процедура ИсправитьФункциональныеОпцииИнформационнойБазы() Экспорт
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	ВидСтатистикиОпции = 1;
	НулеваяОбласть     = РегистрыСведений.ОбластиСтатистики.ПолучитьСсылку("0", ИСТИНА);
	
	Для Каждого ФункциональнаяОпция Из Метаданные.ФункциональныеОпции Цикл
		
		Если НЕ Метаданные.Константы.Содержит(ФункциональнаяОпция.Хранение) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяКонстанты = ФункциональнаяОпция.Хранение.Имя;
		ТипЗначения  = Новый ОписаниеТипов(ФункциональнаяОпция.Хранение.Тип);
		
		Если НЕ ТипЗначения.СодержитТип(Тип("Булево")) ИЛИ Константы[ИмяКонстанты].Получить()=ИСТИНА Тогда
			Продолжить;
		КонецЕсли;
		
		// Дополним типовой функционал перечнем выключенных функциональных опций.
		Запись = РегистрыСведений.СтатистикаКонфигурации.СоздатьМенеджерЗаписи();
		Запись.ВидСтатистики                  = ВидСтатистикиОпции;
		Запись.ИдентификаторОбластиСтатистики = НулеваяОбласть;
		Запись.ОперацияСтатистики             = ЦентрМониторингаПовтИсп.ПолучитьСсылкуОперацииСтатистики(ИмяКонстанты);
		Запись.Значение                       = 0;
		Запись.Записать(ИСТИНА);
		
	КонецЦикла;
	
КонецПроцедуры // ИсправитьФункциональныеОпцииИнформационнойБазы()

Процедура РегистрироватьНачалоВеденияУчета(ПараметрыДляЗаписи) Экспорт
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОперацииСтатистики.Наименование КАК НаименованиеОперацииСтатистики,
	|	СтатистикаКонфигурации.Значение КАК Значение,
	|	ЛОЖЬ КАК ЭтоРегистрНакопления
	|ИЗ
	|	РегистрСведений.СтатистикаКонфигурации КАК СтатистикаКонфигурации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОперацииСтатистики КАК ОперацииСтатистики
	|		ПО СтатистикаКонфигурации.ОперацияСтатистики = ОперацииСтатистики.ИдентификаторОперации
	|ГДЕ
	|	СтатистикаКонфигурации.ВидСтатистики = 0
	|	И СтатистикаКонфигурации.Значение >= 100
	|
	|УПОРЯДОЧИТЬ ПО
	|	Значение УБЫВ";
	Запрос = Новый Запрос(ТекстЗапроса);
	
	КоличествоЗаписей = 0;
	ИтогоЗаписей      = 0;
	ШаблонЗапроса = 
	"ОБЪЕДИНИТЬ ВЫБРАТЬ
	|	ПервыеОперации.Регистратор,
	|	ПервыеОперации.Период
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1000
	|		Таблица.Регистратор КАК Регистратор,
	|		Таблица.Период КАК Период
	|	ИЗ
	|		$Таблица$ КАК Таблица
	|	ГДЕ
	|		Таблица.Период > ДАТАВРЕМЯ(1980, 1, 1)
	|		И Таблица.Регистратор.Проведен
	|	
	|	УПОРЯДОЧИТЬ ПО
	|		Период) КАК ПервыеОперации
	|
	|";
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ //";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() И КоличествоЗаписей < 10000 Цикл
		
		// Найдем объект метаданных текущей таблицы.
		ОбъектМетаданных = ПолучитьОбъектМетаданных(Выборка.НаименованиеОперацииСтатистики);
		Если ОбъектМетаданных=Неопределено ИЛИ НЕ Метаданные.РегистрыНакопления.Содержит(ОбъектМетаданных) Тогда
			Продолжить;
		КонецЕсли;
		
		// Формируем текст запроса к таблице регистра.
		ТекстЗапроса = ТекстЗапроса + СтрЗаменить(ШаблонЗапроса, "$Таблица$", Выборка.НаименованиеОперацииСтатистики);
		
		// Больше 10 тыс. записей рассматривать совсем избыточно.
		КоличествоЗаписей = КоличествоЗаписей + МИН(Выборка.Значение, 1000);
		ИтогоЗаписей      = ИтогоЗаписей + Выборка.Значение;
		
	КонецЦикла;
	
	// Если по всем регистрам насчитывается менее 1000 записей, то начала ведения учета определять нет смысла.
	Если КоличествоЗаписей<1000 Тогда
		Возврат;
	КонецЕсли;
	
	// Устанавливаем новый текст запроса.
	Запрос.Текст = ТекстЗапроса +
	"УПОРЯДОЧИТЬ ПО
	|	Период";
	
	// Если удалось собрать менее 1000 записей, то начала ведения учета определять нет смысла.
	ВсеЗаписи = Запрос.Выполнить().Выгрузить();
	Если ВсеЗаписи.Количество() < 1000 Тогда
		Возврат;
	КонецЕсли;
	
	// Получим медиану набора данных.
	НомерСреднейСтрокиВыборки = Окр(ВсеЗаписи.Количество() / 2, 0, РежимОкругления.Окр15как20);
	НачалоВеденияУчета = ВсеЗаписи[НомерСреднейСтрокиВыборки].Период;
	
	// Помещаем в параметры рассчитанную дату
	ПараметрыДляЗаписи.Вставить("НачалоВеденияУчета", НачалоВеденияУчета);
	
КонецПроцедуры // РегистрироватьНачалоВеденияУчета()

Функция ПолучитьОбъектМетаданных(НаименованиеТаблицы)
	
	ЭлементыИмени = СтрРазделить(НаименованиеТаблицы, ".", ЛОЖЬ);
	ПолноеИмя     = "";
	
	Если ЭлементыИмени.Количество() = 2 Тогда
		ПолноеИмя = СокрЛП(ЭлементыИмени[0]) + "." + СокрЛП(ЭлементыИмени[1]);
	ИначеЕсли ЭлементыИмени.Количество()=3 Тогда
		ПолноеИмя = СокрЛП(ЭлементыИмени[0]) + "." + СокрЛП(ЭлементыИмени[1]) + ".ТабличнаяЧасть." + СокрЛП(ЭлементыИмени[2]);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
	
	Возврат ОбъектМетаданных;
	
КонецФункции // ПолучитьОбъектМетаданных()

Процедура ЗаписатьЗамерыБизнесСтатистики(ПараметрыПоддержки)
	
	Для каждого ГруппаЗамеров Из ПараметрыПоддержки.Замеры Цикл
		Для каждого Замер Из ГруппаЗамеров.Значение Цикл
			
			ПериодЗаписи = Замер.ПериодЗаписи;
			ТипЗаписи    = Замер.ТипЗаписи;
			Ключ         = Замер.Ключ;
			ИмяОперации  = Замер.ИмяОперации;
			Значение     = Замер.Значение;
			Замещать     = Замер.Замещать;
			
			Если Ключ=Неопределено Тогда
				Ключ = КлючДанныхЗамеровСтатистики(ТипЗаписи, ИмяОперации, ПараметрыПоддержки);
			КонецЕсли;
			
			ОперацияСтатистики = ЦентрМониторингаПовтИсп.ПолучитьСсылкуОперацииСтатистики(ИмяОперации);
			РегистрыСведений.ЗамерыСтатистики.ЗаписатьОперациюБизнесСтатистики(ПериодЗаписи, ТипЗаписи, Ключ, ОперацияСтатистики, Значение, Замещать);
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры // ЗаписатьЗамерыБизнесСтатистики()

Процедура ЗаписатьНомерСеансаРабочегоМеста() Экспорт
	
	// Если запущено не из сеанса пользователя, то регистрировать не нужно.
	Если ЭтоФоновоеЗадание() Тогда
		Возврат;
	КонецЕсли;
	
	// Выполняем операцию под полными правами.
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Получим параметры текущего сеанса пользователя.
	ТекущийСеанс = ПолучитьДанныеТекущегоСеансаПользователя();
	
	// Производим поиск записи о прежнем сеансе с налогичным номером.
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ХешНаименования", ТекущийСеанс.ИдентификаторСеанса);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОперацииСтатистики.ИдентификаторОперации КАК ИдентификаторОперации
	|ИЗ
	|	РегистрСведений.ОперацииСтатистики КАК ОперацииСтатистики
	|ГДЕ
	|	ОперацииСтатистики.ХешНаименования = &ХешНаименования";
	
	Попытка
		
		// Производим удаление неактуальных записей.
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Запись = РегистрыСведений.ОперацииСтатистики.СоздатьМенеджерЗаписи();
			Запись.ИдентификаторОперации = Выборка.ИдентификаторОперации;
			Запись.ХешНаименования       = ТекущийСеанс.ИдентификаторСеанса;
			Запись.Удалить();
		КонецЦикла;
		
		// Помещаем новую запись с текущем номером сеанса.
		Запись = РегистрыСведений.ОперацииСтатистики.СоздатьМенеджерЗаписи();
		Запись.ИдентификаторОперации            = ТекущийСеанс.ИдентификаторКлиента;
		Запись.ХешНаименования                  = ТекущийСеанс.ИдентификаторСеанса;
		Запись.Наименование                     = ТекущийСеанс.НаименованиеРабочегоМеста;
		Запись.КоличествоУникальныхКомментариев = ТекущийСеанс.ТипПриложения;
		Запись.Записать();
		
	Исключение
		
		ОбработатьОшибку(ИнформацияОбОшибке());
		
	КонецПопытки;
	
КонецПроцедуры // ЗаписатьНомерСеансаРабочегоМеста()

Процедура ЗаписатьАктивностьРабочихМест(ПриоритетныйРежим=ЛОЖЬ, АдресХранилища=Неопределено) Экспорт
	
	// Выполняем операцию под полными правами.
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем параметры для регистрации текущего замера.
	СистемнаяИнформация   = Новый СистемнаяИнформация();
	ИдентификаторКлиента  = СистемнаяИнформация.ИдентификаторКлиента;
	ТипЗаписи             = 7;
	ПериодЗаписи          = ТекущаяУниверсальнаяДата();
	ИнтервалЗаписи        = 5*60;
	ОперацияСтатистики    = ЦентрМониторингаПовтИсп.ПолучитьСсылкуОперацииСтатистики("СтатистикаКлиента.АктивныхРабочихМест");
	ИдентификаторыСеансов = Новый Массив();
	
	// Массив имен приложений, используемый для фильтрации.
	ИменаПриложений = Новый Массив();
	ИменаПриложений.Добавить(ВРег("1CV8"));
	ИменаПриложений.Добавить(ВРег("1CV8C"));
	ИменаПриложений.Добавить(ВРег("WebClient"));
	ИменаПриложений.Добавить(ВРег("MobileClient"));
	
	// Составим перечень сеансов относящихся к работе пользователей.
	Для Каждого Сеанс Из ПолучитьСеансыИнформационнойБазы() Цикл
		Если ИменаПриложений.Найти(ВРег(Сеанс.ИмяПриложения)) <> Неопределено Тогда
			ИдентификаторыСеансов.Добавить("SESSION#" + Формат(Сеанс.НомерСеанса, "ЧН=0; ЧГ="));
		КонецЕсли;
	КонецЦикла;
	
	// Могут быть ситуации когда все сеансы служебные, а функция вызвана, например, из сеанса веб-сервиса.
	Если ИдентификаторыСеансов.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим необходимость внесения новых замеров.
	Если ПриоритетныйРежим Тогда
		ПоискЗаписей = Неопределено;
	Иначе
		
		// Формируем запрос поиска записей с датами позднее чем граница интервала.
		ПоискЗаписей = Новый Запрос();
		ПоискЗаписей.УстановитьПараметр("ТипЗаписи",          ТипЗаписи);
		ПоискЗаписей.УстановитьПараметр("ПериодЗаписи",       ПериодЗаписи-ИнтервалЗаписи);
		ПоискЗаписей.УстановитьПараметр("ОперацияСтатистики", ОперацияСтатистики);
		ПоискЗаписей.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗамерыСтатистики.ПериодЗаписи КАК ПериодЗаписи
		|ИЗ
		|	РегистрСведений.ЗамерыСтатистики КАК ЗамерыСтатистики
		|ГДЕ
		|	ЗамерыСтатистики.ТипЗаписи = &ТипЗаписи
		|	И ЗамерыСтатистики.ПериодЗаписи >= &ПериодЗаписи
		|	И ЗамерыСтатистики.ОперацияСтатистики = &ОперацияСтатистики";
		
		// Если прошло более 5 минут, добавляем запись.
		Если НЕ ПоискЗаписей.Выполнить().Пустой() Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировкиПериодЗаписи = Блокировка.Добавить("РегистрСведений.ЗамерыСтатистики");
		ЭлементБлокировкиПериодЗаписи.УстановитьЗначение("ТипЗаписи",          ТипЗаписи);
		ЭлементБлокировкиПериодЗаписи.УстановитьЗначение("ОперацияСтатистики", ОперацияСтатистики);
		
		Блокировка.Заблокировать();
		
		// Повторная проверка наличия записи.
		Если (НЕ ПриоритетныйРежим) И (НЕ ПоискЗаписей.Выполнить().Пустой()) Тогда
			Возврат;
		КонецЕсли;
		
		// Получим перечень активных рабочих мест и количество запущенных на них сеансов.
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ИдентификаторыСеансов", ИдентификаторыСеансов);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОперацииСтатистики.ИдентификаторОперации КАК ИдентификаторКлиента,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОперацииСтатистики.ХешНаименования) КАК КоличествоСеансов
		|ИЗ
		|	РегистрСведений.ОперацииСтатистики КАК ОперацииСтатистики
		|ГДЕ
		|	ОперацииСтатистики.ХешНаименования В(&ИдентификаторыСеансов)
		|
		|СГРУППИРОВАТЬ ПО
		|	ОперацииСтатистики.ИдентификаторОперации";
		
		НаборЗаписей = РегистрыСведений.ЗамерыСтатистики.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипЗаписи.Установить(ТипЗаписи);
		НаборЗаписей.Отбор.ПериодЗаписи.Установить(ПериодЗаписи);
		НаборЗаписей.Отбор.ОперацияСтатистики.Установить(ОперацияСтатистики);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Запись = НаборЗаписей.Добавить();
			Запись.ТипЗаписи             = ТипЗаписи;
			Запись.ПериодЗаписи          = ПериодЗаписи;
			Запись.Ключ                  = Выборка.ИдентификаторКлиента;
			Запись.ОперацияСтатистики    = ОперацияСтатистики;
			Запись.ЗначениеОперации      = Выборка.КоличествоСеансов;
			Запись.ИдентификаторУдаления = ПериодЗаписи;
			
		КонецЦикла;
		
		Если НаборЗаписей.Количество()=0 Тогда
			ОтменитьТранзакцию();
			ОбработатьОшибку(НСтр("ru='В регистре ОперацииСтатистики не найдены записи о текущих сеансах'"));
			Возврат;
		КонецЕсли;
		
		НаборЗаписей.Записать(ИСТИНА);
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		Причина = ИнформацияОбОшибке();
		ОтменитьТранзакцию();
		ОбработатьОшибку(Причина);
		
	КонецПопытки;
	
КонецПроцедуры

Функция ПолучитьДанныеТекущегоСеансаПользователя()
	
	// Выполняем операцию под полными правами.
	УстановитьПривилегированныйРежим(Истина);
	
	// Получим данные о рабочем месте.
	СистемнаяИнформация  = Новый СистемнаяИнформация();
	
	// Инициализируем основные параметры.
	ТекущийСеанс = Новый Структура();
	ТекущийСеанс.Вставить("ИдентификаторКлиента", СистемнаяИнформация.ИдентификаторКлиента);
	ТекущийСеанс.Вставить("ПрограммаПросмотра",   СистемнаяИнформация.ИнформацияПрограммыПросмотра);
	ТекущийСеанс.Вставить("ВерсияОС",             СистемнаяИнформация.ВерсияОС);
	ТекущийСеанс.Вставить("ТипПлатформы",         СистемнаяИнформация.ТипПлатформы);
	ТекущийСеанс.Вставить("НомерСеанса",          НомерСеансаИнформационнойБазы());
	ТекущийСеанс.Вставить("ИдентификаторСеанса",  "SESSION#" + Формат(ТекущийСеанс.НомерСеанса, "ЧН=0; ЧГ="));
	
	// Инициализируем параметры, получаемые из соединения.
	ТекущийСеанс.Вставить("IPАдресКлиента",  "");
	ТекущийСеанс.Вставить("ИмяКомпьютера",   "");
	ТекущийСеанс.Вставить("ИмяПриложения",   "");
	ТекущийСеанс.Вставить("НачалоСеанса",    '00010101');
	ТекущийСеанс.Вставить("НомерСоединения", 0);
	ТекущийСеанс.Вставить("Пользователь",    Неопределено);
	
	// Найдем текущий сеанс в списке соединений информационной базы и получим дополнительные параметры.
	Для каждого Сеанс Из ПолучитьСеансыИнформационнойБазы() Цикл
		Если Сеанс.НомерСеанса = ТекущийСеанс.НомерСеанса Тогда
			ЗаполнитьЗначенияСвойств(ТекущийСеанс, Сеанс);
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Определим тип приложения.
	ТекущийСеанс.Вставить("ТипПриложения", ПолучитьИндексИмениПриложения(ТекущийСеанс.ИмяПриложения));
	
	// Произведем формирование наименования рабочего места.
	НаименованиеРабочегоМеста = Новый Массив();
	НаименованиеРабочегоМеста.Добавить("РабочееМесто");
	
	Если ТекущийСеанс.Пользователь <> Неопределено И НЕ ПустаяСтрока(ТекущийСеанс.Пользователь.Имя) Тогда
		НаименованиеРабочегоМеста.Добавить(СтрЗаменить(ТекущийСеанс.Пользователь.Имя, ".", "_"));
	Иначе
		НаименованиеРабочегоМеста.Добавить(НСтр("ru = 'Неавторизованный'"));
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекущийСеанс.НачалоСеанса) Тогда
		НаименованиеРабочегоМеста.Добавить(Формат(ТекущийСеанс.НачалоСеанса, "ДФ=yyyy-MM-dd"));
	Иначе
		НаименованиеРабочегоМеста.Добавить(Формат(ТекущаяДатаСеанса(),       "ДФ=yyyy-MM-dd"));
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекущийСеанс.ИмяПриложения) Тогда
		НаименованиеРабочегоМеста.Добавить(ТекущийСеанс.ИмяПриложения);
	Иначе
		НаименованиеРабочегоМеста.Добавить(ТекущийСеанс.ТипПлатформы);
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекущийСеанс.ИмяКомпьютера) Тогда
		НаименованиеРабочегоМеста.Добавить(СтрЗаменить(ТекущийСеанс.ИмяКомпьютера, ".", "_"));
	ИначеЕсли НЕ ПустаяСтрока(ТекущийСеанс.ПрограммаПросмотра) Тогда
		НаименованиеРабочегоМеста.Добавить(СтрЗаменить(ТекущийСеанс.ПрограммаПросмотра, ".", "_"));
	ИначеЕсли НЕ ПустаяСтрока(ТекущийСеанс.IPАдресКлиента) Тогда
		НаименованиеРабочегоМеста.Добавить("IP_"+СтрЗаменить(ТекущийСеанс.IPАдресКлиента, ".", "_"));
	Иначе
		НаименованиеРабочегоМеста.Добавить(СтрЗаменить(ТекущийСеанс.ВерсияОС, ".", "_"));
	КонецЕсли;
	
	ТекущийСеанс.Вставить("НаименованиеРабочегоМеста", СтрСоединить(НаименованиеРабочегоМеста, "."));
	
	// Возвращаем собранные сведения.
	Возврат ТекущийСеанс;
	
КонецФункции // ПолучитьДанныеТекущегоСеансаПользователя()

