#Область ПрограммныйИнтерфейс

// Записывает операцию бизнес статистики.
//
// Параметры:
//  ИмяОперации	- Строка	- имя операции статистики, в случае отсутствия создается новое.
//  Значение	- Число		- количественное значение операции статистики.
//
Процедура ЗаписатьОперациюБизнесСтатистики(ИмяОперации, Значение = 1) Экспорт
	
	ПараметрыЗамеров = СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере(Ложь).Получить("ПоддержкаОтраслевыхРешений");
	Если НЕ ПараметрыЗамеров.ВыполнятьЗамеры Тогда
		Возврат;
	КонецЕсли;
	
	ПериодЗаписи       = ТекущаяУниверсальнаяДата();
	ТипЗаписи          = 8;
	Ключ               = КлючДанныхЗамеровСтатистики(ТипЗаписи, ИмяОперации, ПараметрыЗамеров);
	ОперацияСтатистики = ЦентрМониторингаПовтИсп.ПолучитьСсылкуОперацииСтатистики(ИмяОперации);
	Замещать           = Истина;
	
	РегистрыСведений.ЗамерыСтатистики.ЗаписатьОперациюБизнесСтатистики(ПериодЗаписи, ТипЗаписи, Ключ, ОперацияСтатистики, Значение, Замещать);
	
КонецПроцедуры // ЗаписатьОперациюБизнесСтатистики()

// Возвращает номер версии подсистемы "Поддержка отраслевых решений".
//
// Возвращаемое значение:
//  Строка.
//
Функция ВерсияПодсистемы() Экспорт
	
	Версия = СокрЛП(Метаданные.Подсистемы.пр_ПоддержкаОтраслевыхРешений.Комментарий);
	Возврат Версия;
	
КонецФункции // ВерсияПодсистемы()

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Вызывается с периодичностью 20 минут для из глобального обработчика ожидания по необходимости, но не чаще раза в 60 сек,
// для получения данных с клиента, а также возврате результата на клиент, если нужно.
//
// Параметры:
//  Параметры - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, полученного с клиента.
//    * Значение - Произвольный - значение параметра, полученного с клиента.
//  Результаты - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, возвращаемого на клиент.
//    * Значение - Произвольный - значение параметра, возвращаемого на клиент.
//
Процедура ПриПериодическойЗаписиДанныхЗамеровСтатистики(ПараметрыПоддержки, АдресХранилища=Неопределено) Экспорт
	
	// Запишем все работающие сейчас сеансы пользователей.
	ЗаписатьАктивностьРабочихМест();
	
	// Производим запись накопленных замеров бизнес-статистики.
	ЗаписатьЗамерыБизнесСтатистики(ПараметрыПоддержки);
	
КонецПроцедуры // ПриПериодическойЗаписиДанныхЗамеровСтатистики()

// Вызывается из метода ПолучитьПараметрыЛицензий после чтения параметров лицензии
//
// Параметры:
//	ПараметрыЛицензий - ФормаКлиентскогоПриложения - форма регистрации программного продукта
//	ТипСистемыЗащиты - СписокЗначений - список систем защиты программного продукта
//	Идентификатор - Строка - идентификатор
//	Наименование - Строка - наименование программного продукта
//	Параметры - Стркетура - параметры лицензирования
//	ВерсияКомпоненты - Строка - версия компоненты защиты
//
Процедура ПриПолученииПараметровЛицензии(ПараметрыЛицензий, ТипСистемыЗащиты, Идентификатор, Наименование, Параметры, ВерсияКомпоненты) Экспорт
	
	ПараметрыЛицензий.Добавить(Новый Структура("Type,Product,Description,Properties,Version", ТипСистемыЗащиты, Идентификатор, Наименование, Параметры, ВерсияКомпоненты));
	
КонецПроцедуры // ПриПолученииПараметровЛицензии()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПараметрыПодсистемыПоддержки

// Получает параметры подсистемы отраслевой поддержки решений.
//
// Параметры:
//    Параметры - Структура - где ключи необходимые параметры, значения которых необходимо получить.
//
// Возвращаемое значение:
//    Структура - значения параметров.
//
Функция ПолучитьПараметрыОтраслевойПоддержки(Параметры = Неопределено) Экспорт
	
	ПараметрыПоУмолчанию = ПараметрыПоддержкиПоУмолчанию();
	ПараметрыКонстанты   = Константы.пр_ПараметрыОтраслевойПоддержки.Получить().Получить();
	
	Если ПараметрыКонстанты = Неопределено Тогда
		ПараметрыКонстанты = ПараметрыПоУмолчанию;
	Иначе
		Для Каждого ТекПараметр Из ПараметрыПоУмолчанию Цикл
			Если НЕ ПараметрыКонстанты.Свойство(ТекПараметр.Ключ) Тогда
				ПараметрыКонстанты.Вставить(ТекПараметр.Ключ, ТекПараметр.Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Параметры = Неопределено Тогда
		Параметры = ПараметрыКонстанты;
		Возврат Параметры;
	КонецЕсли;
	
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		Для Каждого ТекПараметр Из Параметры Цикл
			Параметры[ТекПараметр.Ключ] = ПараметрыКонстанты[ТекПараметр.Ключ];
		КонецЦикла;
	ИначеЕсли ТипЗнч(Параметры) = Тип("Строка") Тогда
		Параметры = ПараметрыКонстанты[Параметры];
	КонецЕсли;
	
	Возврат Параметры;
	
КонецФункции // ПолучитьПараметрыОтраслевойПоддержки()

// Устанавливает параметры отраслевой поддержки решений.
//
// Параметры:
//    Параметры - Структура - необходимые параметры, значения которых необходимо получить.
//
Процедура УстановитьПараметрыОтраслевойПоддержки(НовыеПараметры) Экспорт
	
	Блокировка = Новый БлокировкаДанных;
	Блокировка.Добавить("Константа.пр_ПараметрыОтраслевойПоддержки");
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка.Заблокировать();
		Параметры = ПолучитьПараметрыОтраслевойПоддержки();
		
		Для Каждого ТекПараметр Из НовыеПараметры Цикл
			Если НЕ Параметры.Свойство(ТекПараметр.Ключ) Тогда
				Параметры.Вставить(ТекПараметр.Ключ);
			КонецЕсли;
			
			Параметры[ТекПараметр.Ключ] = ТекПараметр.Значение;
		КонецЦикла;
		
		Хранилище = Новый ХранилищеЗначения(Параметры, Новый СжатиеДанных(9));
		Константы.пр_ПараметрыОтраслевойПоддержки.Установить(Хранилище);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ПричинаОшибки = ИнформацияОбОшибке();
		ОтменитьТранзакцию();
		ОбработатьОшибку(ПричинаОшибки);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры // УстановитьПараметрыОтраслевойПоддержки()

// Возвращает настройки подсистемы поддержки со значениями по умолчанию.
//
Функция ПараметрыПоддержкиПоУмолчанию()
	
	Сутки = 24*60*60;
	
	// Создаем структуру параметров и устанавливаем ключевые свойства.
	//
	ПараметрыОтраслевойПоддержки = Новый Структура;
	ПараметрыОтраслевойПоддержки.Вставить("НаименованиеБазы", "");
	
	// Параметры регистрации программного продукта.
	//
	РегистрацияПродукта = Новый Структура();
	РегистрацияПродукта.Вставить("РегНомер",         "");
	РегистрацияПродукта.Вставить("ИНН",              "");
	РегистрацияПродукта.Вставить("КПП",              "");
	РегистрацияПродукта.Вставить("ИТС",              "");
	РегистрацияПродукта.Вставить("Аккаунт",          "");
	РегистрацияПродукта.Вставить("КонтактноеЛицо",   "");
	РегистрацияПродукта.Вставить("ЭлектроннаяПочта", "");
	РегистрацияПродукта.Вставить("НомерТелефона",    "");
	РегистрацияПродукта.Вставить("Партнер",          "");
	РегистрацияПродукта.Вставить("ДатаПриобретения", "");
	РегистрацияПродукта.Вставить("СогласиеДано",     ЛОЖЬ);
	РегистрацияПродукта.Вставить("Автор",            "");
	РегистрацияПродукта.Вставить("ДатаИзменения",    Дата(1,1,1));
	ПараметрыОтраслевойПоддержки.Вставить("РегистрацияПродукта", РегистрацияПродукта);
	
	// Параметры лицензирования информационной базы.
	//
	ПараметрыОтраслевойПоддержки.Вставить("ПоследняяПроверкаДанныхСеанса", Дата(1,1,1));
	ПараметрыОтраслевойПоддержки.Вставить("ПараметрыЛицензий",             Неопределено);
	ПараметрыОтраслевойПоддержки.Вставить("НайденаСистемаЗащиты",          ЛОЖЬ);
	
	// Параметры сбора статистики разделяемые по областям
	//
	ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчетаСледующееФормирование",        Дата(1,1,1));
	ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчетаПериодФормирования",           90*Сутки);
	ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчета",                             Дата(1,1,1));
	ПараметрыОтраслевойПоддержки.Вставить("РазмерДанныхТаблицСледующееФормирование",        Дата(1,1,1));
	ПараметрыОтраслевойПоддержки.Вставить("РазмерДанныхТаблицПериодФормирования",           30*Сутки);
	
	Возврат ПараметрыОтраслевойПоддержки;
	
КонецФункции // ПараметрыПоддержкиПоУмолчанию()

