// Производит получение и корректировку параметров регистрации продукта.
//
Функция ПрочитатьРегистрациюПродукта() Экспорт
	
	РегистрацияПродуктаПоУмолчанию = ПараметрыПоддержкиПоУмолчанию().РегистрацияПродукта;
	РегистрацияПродуктаКонстанта   = ПолучитьПараметрыОтраслевойПоддержки("РегистрацияПродукта");
	
	Если ТипЗнч(РегистрацияПродуктаКонстанта)=Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(РегистрацияПродуктаПоУмолчанию, РегистрацияПродуктаКонстанта);
	КонецЕсли;
	
	Возврат РегистрацияПродуктаПоУмолчанию;
	
КонецФункции // ПрочитатьРегистрациюПродукта()

// Производит запись регистрационных данных с отметкой авторства изменений.
//
Функция ЗаписатьРегистрациюПродукта(НовыеПараметрыРегистрации) Экспорт
	
	// Получим шаблонные параметры регистрации и заполним переданными данными
	РегистрацияПродукта = ПараметрыПоддержкиПоУмолчанию().РегистрацияПродукта;
	ЗаполнитьЗначенияСвойств(РегистрацияПродукта, НовыеПараметрыРегистрации);
	
	// Производим корректировку автора регистрационных данных
	РегистрацияПродукта.Вставить("Автор",         СокрЛП(ПолноеИмяПользователя()));
	РегистрацияПродукта.Вставить("ДатаИзменения", ТекущаяДатаСеанса());
	
	// Производим запись параметров в константу
	ПараметрыОтраслевойПоддержки = Новый Структура();
	ПараметрыОтраслевойПоддержки.Вставить("РегистрацияПродукта", РегистрацияПродукта);
	УстановитьПараметрыОтраслевойПоддержки(ПараметрыОтраслевойПоддержки);
	
	// В режиме разделенной информационной базы ничего не меняем
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат РегистрацияПродукта;
	КонецЕсли;
	
	// Получим развернутое представление контактной информации
	ШаблонПредставления  = "Рег.номер: %1; ИНН: %2; ИТС: %3; rarus.ru: %4; Руководитель: %5; Телефон: %6; Эл.почта: %7";
	КонтактнаяИнформация = СтрШаблон(ШаблонПредставления, РегистрацияПродукта.РегНомер, РегистрацияПродукта.ИНН,
	    РегистрацияПродукта.ИТС, РегистрацияПродукта.Аккаунт, 
	    РегистрацияПродукта.КонтактноеЛицо, РегистрацияПродукта.НомерТелефона, РегистрацияПродукта.ЭлектроннаяПочта);
	
	// Обновляем параметры Центра мониторинга
	ПараметрыЦентраМониторинга = Новый Структура();
	ПараметрыЦентраМониторинга.Вставить("КонтактнаяИнформацияИзменена",        ИСТИНА);
	ПараметрыЦентраМониторинга.Вставить("ЗапросКонтактнойИнформации",          1);
	ПараметрыЦентраМониторинга.Вставить("КонтактнаяИнформация",                КонтактнаяИнформация);
	ПараметрыЦентраМониторинга.Вставить("ЛогинПортала",                        СокрЛП(РегистрацияПродукта.ИТС));
	ПараметрыЦентраМониторинга.Вставить("КонтактнаяИнформацияКомментарий",     НСтр("ru = 'Регистрация продукта'"));
	ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	
	Возврат РегистрацияПродукта;
	
КонецФункции // ЗаписатьРегистрациюПродукта()

// Производит проверку корректности заполнения регистрационных данных
//
// Параметры:
//  РегНомер - Строка - Регистрационный номер продукта.
//  ИНН		 - Строка - ИНН пользователя программного продукта.
// 
// Возвращаемое значение:
//  Булево - Признак корректного заполнения всех регистрационных данных.
//
Функция РегистрационныеДанныеЗаполнены(РегНомер="", ИНН="") Экспорт
	
	// Читаем сохраненные регистрационные данных из параметров
	РегистрацияПродукта = ПрочитатьРегистрациюПродукта();
	
	// Выполняем проверки заполненности ключевых параметров
	Если НЕ РегистрацияПродукта.Свойство("РегНомер", РегНомер) ИЛИ ПустаяСтрока(РегНомер) Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	Если НЕ РегистрацияПродукта.Свойство("ИНН", ИНН) ИЛИ ПустаяСтрока(ИНН) Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Выполняем проверку возможности отправки контактной информации
	ЗапросКонтактнойИнформации = ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов("ЗапросКонтактнойИнформации");
	Если ЗапросКонтактнойИнформации<>1 Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Все проверки пройдены успешно
	Возврат ИСТИНА;
	
КонецФункции // РегистрационныеДанныеЗаполнены()

#КонецОбласти

#Область ОбщегоНазначения

