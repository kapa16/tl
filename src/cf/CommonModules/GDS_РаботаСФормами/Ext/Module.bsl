	КнопкаЗаполненияМатериалов = ТекущаяФорма.Элементы.Добавить("ЗаполнитьИзБухгалтерии", Тип("КнопкаФормы"), ТекущаяФорма.Элементы.ЗаполнитьМатериалы);
	КнопкаЗаполненияМатериалов.ИмяКоманды = "ЗаполнитьИзБухгалтерии";
	
	КнопкаЗаполненияМатериалов = ТекущаяФорма.Элементы.Добавить("ЗаполнитьИзБухгалтерии1", Тип("КнопкаФормы"), ТекущаяФорма.Элементы.Материалы.КоманднаяПанель);
	КнопкаЗаполненияМатериалов.ИмяКоманды = "ЗаполнитьИзБухгалтерии";
