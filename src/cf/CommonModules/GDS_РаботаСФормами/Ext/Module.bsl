Процедура ДобавитьРеквизитыНаФорму(Форма) Экспорт 
	
	#Область Справочники	
	
	#Область ФизическиеЛица							
	Если Форма.ИмяФормы = "Справочник.Должности.Форма.ФормаЭлемента" Тогда	
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_ЯвляетсяВодительскойДолжностью",  Форма, , 2, "Объект.GDS_ЯвляетсяВодительскойДолжностью", , , Форма.Элементы.Страницы); 
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_КатегорияВоинскогоУчета", Форма, , 1, "Объект.GDS_КатегорияВоинскогоУчета", , , Форма.Элементы.Страницы); 
		Возврат;
	КонецЕсли;
	#КонецОбласти
		
	#Область ДоговорыКонтрагентов							
	Если Форма.ИмяФормы = "Справочник.ДоговорыКонтрагентов.Форма.ФормаЭлемента" Тогда	
		// ИнтеграцияС1СДокументооборотом
		ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПриСозданииНаСервере(Форма);
		// Конец ИнтеграцияС1СДокументооборотом
		Возврат;
	КонецЕсли;
	#КонецОбласти  

	#Область уатРегистрационныеДокументы							
	Если Форма.ИмяФормы = "Справочник.уатРегистрационныеДокументы.Форма.ФормаЭлемента" Тогда	
		// ИнтеграцияС1СДокументооборотом
		ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПриСозданииНаСервере(Форма);
		// Конец ИнтеграцияС1СДокументооборотом
		Возврат;
	КонецЕсли;
	#КонецОбласти
	
	#Область уатОбъектыСтроительства
	Если Форма.ИмяФормы = "Справочник.уатОбъектыСтроительства.Форма.ФормаЭлемента" Тогда	
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_МаршрутПоУмолчанию",, "Маршрут по умолчанию",1, "Объект.GDS_МаршрутПоУмолчанию",,,);
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_НаправлениеПоУмолчанию",, "Направление по умолчанию",1, "Объект.GDS_НаправлениеПоУмолчанию",,,);
		Возврат;
	КонецЕсли;
	#КонецОбласти
	#Область Склады
	Если Форма.ИмяФормы = "Справочник.Склады.Форма.ФормаЭлемента" Тогда	
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_ТС",, "ТС",1, "Объект.GDS_ТС",,,);
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_Контрагент",, "Контрагент",1, "Объект.GDS_Контрагент",,,);
		Возврат;
	КонецЕсли;
	#КонецОбласти
	#КонецОбласти

	#Область Документы	
	
	#Область уатПутевойЛист							
	Если Форма.ИмяФормы = "Документ.уатПутевойЛист.Форма.ФормаДокумента" Тогда	
		СтруктураСвойств = Новый Структура;
		СтруктураСвойств.Вставить("РастягиватьПоГоризонтали",Ложь); 
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(Форма, "GDS_НомерПутевогоЛиста", Форма.Элементы.ГруппаНомерДата, , 1, "Объект.GDS_НомерПутевогоЛиста", СтруктураСвойств, , ); 
		
		СтруктураСвойств = Новый Структура;
		СтруктураСвойств.Вставить("ОтображатьЗаголовок", Ложь);
		GDS_МодульДинамическогоФормированияИнтерфейса.СздГруппаОбычная(Форма, "GDS_Группа_Организация", Форма.Элементы.ГруппаШапкаПравая, , 3, 1, , СтруктураСвойств, );                                                                                                                       
		
		Форма.Элементы.Переместить(Форма.Элементы.Организация, Форма.Элементы.GDS_Группа_Организация);

		СтруктураСвойств = Новый Структура;
		GDS_МодульДинамическогоФормированияИнтерфейса.СздДекорацияНадпись(Форма, "GDS_ОригиналДокуумента", Форма.Элементы.GDS_Группа_Организация, , , ); 
		GDS_МодульДинамическогоФормированияИнтерфейса.СоздатьКоманду(Форма, "ПодборМЛ", "Подбор М/Л", "ДПЛ_ПодборПЛ");
		GDS_МодульДинамическогоФормированияИнтерфейса.СздКнопка(Форма, "ПодборМЛ", Форма.Элементы.Задание.КоманднаяПанель, "Подбор М/Л", "ПодборМЛ", 1);
		GDS_МодульДинамическогоФормированияИнтерфейса.СздКолонкаТаблицыФормы(Форма, "GDS_МаршрутныйЛист",Форма.Элементы.Задание,, "Маршрутный лист", "Объект.Задание.GDS_МаршрутныйЛист",,,,,Форма.Элементы.ЗаданиеГруппаПодразделение);
		Возврат;
	КонецЕсли;
	#КонецОбласти  
	
	#КонецОбласти
	
КонецПроцедуры

