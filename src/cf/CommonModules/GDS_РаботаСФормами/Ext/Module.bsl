Функция ПолучитьДанныеИз1СБухгалтерии(РемонтныйЛист) Экспорт
		
	СоединениеWS = GDS_ФункцииОбмена.ПолучитьДанныеОWS_БП();
		
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	ИтогВыборки.ЗаявкаНаРемонт,
	                      |	ИтогВыборки.РЛ
	                      |ИЗ
	                      |	(ВЫБРАТЬ
	                      |		уатРемонтныйЛист.ЗаявкаНаРемонт КАК ЗаявкаНаРемонт,
	                      |		уатРемонтныйЛист.Ссылка КАК РЛ
	                      |	ИЗ
	                      |		Документ.уатРемонтныйЛист КАК уатРемонтныйЛист
	                      |	ГДЕ
	                      |		уатРемонтныйЛист.Ссылка = &Ссылка
	                      |	
	                      |	ОБЪЕДИНИТЬ ВСЕ
	                      |	
	                      |	ВЫБРАТЬ
	                      |		уатРемонтныйЛистРаботы.ЗаявкаНаРемонт,
	                      |		уатРемонтныйЛистРаботы.Ссылка
	                      |	ИЗ
	                      |		Документ.уатРемонтныйЛист.Работы КАК уатРемонтныйЛистРаботы
	                      |	ГДЕ
	                      |		уатРемонтныйЛистРаботы.Ссылка = &Ссылка) КАК ИтогВыборки
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	ИтогВыборки.ЗаявкаНаРемонт,
	                      |	ИтогВыборки.РЛ");
						  
	Запрос.УстановитьПараметр("Ссылка",РемонтныйЛист.Ссылка);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	ТаблицаНеобходимыхДанных = РемонтныйЛист.Материалы.Выгрузить();
	ТаблицаНеобходимыхДанных.Очистить();
	
	Пока Результат.Следующий() Цикл
		Если ТипЗнч(Результат.РЛ) = ТипЗнч(Документы.уатРемонтныйЛист.ПустаяСсылка()) Тогда
			Данные = СоединениеWS.ВернутьДанныеПоЗапросу("ЗапросНоменклатурыПоРЛ",строка(Результат.РЛ.УникальныйИдентификатор()));
			
			Если НЕ ЗначениеЗаполнено(Данные.Получить()) Тогда
				Сообщить(Строка(Результат.РЛ) + " не найден в 1С Бухгалтерия!!!");
				Возврат 0;
			КонецЕсли;
		КонецЕсли;
		
		XML_Строка 				= Данные.Получить();
		СписокПолученныхДанных 	= GDS_ФункцииОбмена.РазобратьПолученныеДанные(XML_Строка);
		СписокНоменклатуры 		= СписокПолученныхДанных[0].Значение.Номенклатура;
		
		Если СписокНоменклатуры = "" Тогда
			Данные = СоединениеWS.ВернутьДанныеПоЗапросу("ЗапросНоменклатурыПоЗаявке",строка(Результат.ЗаявкаНаРемонт.УникальныйИдентификатор()));
			XML_Строка 				= Данные.Получить();
			СписокПолученныхДанных 	= GDS_ФункцииОбмена.РазобратьПолученныеДанные(XML_Строка);
			СписокНоменклатуры 		= СписокПолученныхДанных[0].Значение.Номенклатура;
			
			Если СписокНоменклатуры = "" Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Для Каждого Запись из СписокНоменклатуры Цикл
			СтрокаИзБухгалтерии = Запись.Значение;
			строка = ТаблицаНеобходимыхДанных.Добавить();
			строка.Номенклатура     = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаИзБухгалтерии.Номенклатура));
			строка.Количество       = СтрокаИзБухгалтерии.КоличествоОстаток;
			строка.Сумма            = СтрокаИзБухгалтерии.СуммаОстаток;
			строка.Цена             = ?(Строка.Количество <> 0,Строка.Сумма / строка.Количество,строка.Сумма);
			строка.ЕдиницаИзмерения = Строка.Номенклатура.ЕдиницаХраненияОстатков;
		КонецЦикла;	
	КонецЦикла;
	
	ТаблицаНеобходимыхДанных.Свернуть("Номенклатура,ЕдиницаИзмерения, Цена","Количество,Сумма");

	Возврат ТаблицаНеобходимыхДанных;
	
КонецФункции

