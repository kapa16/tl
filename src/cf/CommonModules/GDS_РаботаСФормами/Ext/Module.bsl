	ТекущаяФорма.Элементы.ГруппаШины.ПодчиненныеЭлементы.Шины.КоманднаяПанель.ПодчиненныеЭлементы.ШиныМастерУстановкиШин.Видимость = Ложь;
	
	Если ТекущаяФорма.Объект.Ссылка.Пустая() Тогда
		ТекущаяФорма.Объект.ДатаОкончания = Дата(1,1,1);
	КонецЕсли;
	
	СтруктураРеквизитов = Новый Структура();
	СтруктураРеквизитов.Вставить("ПП_МЧ_ВО1", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_МЧ_ВО2", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_МЧ_ВО3", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_МЧ_ВО4", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_МЧ_ВО5", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	
	СтруктураРеквизитов.Вставить("ПП_Одометр_ВО1", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_Одометр_ВО2", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
	СтруктураРеквизитов.Вставить("ПП_Одометр_ВО3", GDS_МодульДинамическогоФормированияИнтерфейса.ОписаниеТипаЧисло(10, 2));
