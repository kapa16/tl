
Процедура ОбработкаФормыСправочникаТС(ФормаТС) Экспорт
		
    GDS_МодульДинамическогоФормированияИнтерфейса.СздГруппаОбычная(ФормаТС, "GDS_ГруппаТопливо", ФормаТС.Элементы.ГруппаДопПараметрыШапкаКолонкаЛевая,"Топливо");
    GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ФормаТС, "GDS_ОбъемБака", ФормаТС.Элементы.GDS_ГруппаТопливо, "Объем бака", 1, "Объект.GDS_ОбъемБака");

	
	ФормаТС.Элементы.ДатаВводаВЭксплуатацию.Доступность = РольДоступна("GDS_ИзменениеПараметровТС") Или РольДоступна("ПолныеПрава");
	ФормаТС.Элементы.ДатаВыбытия.Доступность 			= РольДоступна("GDS_ИзменениеПараметровТС") Или РольДоступна("ПолныеПрава");	
	
	Если НЕ GDS_ДополнительныеФункции.ПроверитьДоступностьРоли("GDS_СотрудникиМеКаМи") Тогда
		GDS_МодульДинамическогоФормированияИнтерфейса.СздГруппаОбычная(ФормаТС, "GDS_ГруппаПринадлежностьТС", ФормаТС.Элементы.ГруппаОсновнаяКолонкаЛевая,"Владелец ТС");
		СобытияЭлемента = Новый Структура("ПриИзменении", "ДТК_GDS_ПривлеченныйТранспортПриИзмененииПосле");
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПолеФлажок(ФормаТС, "GDS_ПривлеченныйТранспорт", ФормаТС.Элементы.GDS_ГруппаПринадлежностьТС, "Привлеченный транспорт", 1, "Объект.GDS_ПривлеченныйТранспорт",,СобытияЭлемента);
	    ФормаТС.Элементы.Переместить(ФормаТС.Элементы.ВладелецТС2, ФормаТС.Элементы.GDS_ГруппаПринадлежностьТС);
		ФормаТС.Элементы.Переместить(ФормаТС.Элементы.ТипВладенияТС, ФормаТС.Элементы.GDS_ГруппаПринадлежностьТС);
        GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ФормаТС, "GDS_Собственник", ФормаТС.Элементы.GDS_ГруппаПринадлежностьТС, "Собственник", 1, "Объект.GDS_СобственникТС");
        GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ФормаТС, "GDS_ОснованиеВладения", ФормаТС.Элементы.GDS_ГруппаПринадлежностьТС, "Основание", 1, "Объект.GDS_ОснованиеВладения");
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаФормыДокументаРемонтныйЛист(ТекущаяФорма) Экспорт
	
	ДФИ = GDS_МодульДинамическогоФормированияИнтерфейса;
	Элементы = ТекущаяФорма.Элементы;
	
	ТекущаяФорма.Элементы.Страницы.ПодчиненныеЭлементы.ГруппаОсновное.ПодчиненныеЭлементы.ГруппаОсновноеКолонки.Видимость = Ложь;
	
	ПолеВвода = ТекущаяФорма.Элементы.Добавить("ПУ", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаЛеваяКолонка);
	ПолеВвода.Вид 					= ВидПоляФормы.ПолеВвода; 
	ПолеВвода.ПутьКДанным 			= "Объект.GDS_ПУ";
	ПолеВвода.ПоложениеЗаголовка 	= ПоложениеЗаголовкаЭлементаФормы.Верх;
	ПолеВвода.ЦветТекстаЗаголовка 	= WebЦвета.Красный;
	ПолеВвода.ВысотаЗаголовка 		= 0;
	ПолеВвода.Заголовок 			= "ПУ на котором был выполнен ремонт";
	
	НоваяГруппа 					= ТекущаяФорма.Элементы.Вставить("ГруппаНаработок", Тип("ГруппаФормы"), ТекущаяФорма.Элементы.ГруппаОсновное,ТекущаяФорма.Элементы.ГруппаВидыРемонта);
	НоваяГруппа.Вид 				= ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппа.Отображение 		= ОтображениеОбычнойГруппы.Нет;
	НоваяГруппа.Заголовок 			= "Текущие показания наработки";
	НоваяГруппа.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
	
	ГруппаНаработок = ТекущаяФорма.Элементы.Добавить("ГруппаТекущиеПоказанияНаработки", Тип("ГруппаФормы"), ТекущаяФорма.Элементы.ГруппаНаработок);
	ГруппаНаработок.Вид 		= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНаработок.Отображение = ОтображениеОбычнойГруппы.Нет;
	
	ПолеВвода = ТекущаяФорма.Элементы.Добавить("ТекущиеПоказанияОдометра", Тип("ПолеФормы"), ГруппаНаработок);
	ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным 		= "Объект.GDS_ТекущаяНаработкаОдометр";
	ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Верх;
	ПолеВвода.ВысотаЗаголовка 	= 0;
	
	ПолеВвода = ТекущаяФорма.Элементы.Добавить("ТекущиеПоказанияМЧ_ДВС", Тип("ПолеФормы"), ГруппаНаработок);
	ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным 		= "Объект.GDS_ТекущаяНаработкаМЧ_ДВС";
	ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Верх;
	ПолеВвода.ВысотаЗаголовка 	= 0;
	
	ПолеВвода = ТекущаяФорма.Элементы.Добавить("ТекущаеПоказанияМЧ_ВО", Тип("ПолеФормы"), ГруппаНаработок);
	ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным 		= "Объект.GDS_ТекущаяНаработкаМЧ_ВО";
	ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Верх;
	ПолеВвода.ВысотаЗаголовка 	= 0;
	
	ГруппаВидРемонта4 = ТекущаяФорма.Элементы.Добавить("ГруппаВидРем4", Тип("ГруппаФормы"), ТекущаяФорма.Элементы.Группа3);
	ГруппаВидРемонта4.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВидРемонта4.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаВидРемонта4.ОтображатьЗаголовок 	= Ложь;
	
	ДекорВидРемонта4 = ТекущаяФорма.Элементы.Добавить("ДекорацияВидРем4", Тип("ДекорацияФормы"), ТекущаяФорма.Элементы.ГруппаВидРем4);
	ДекорВидРемонта4.Вид 		= ВидДекорацииФормы.Надпись;
	ДекорВидРемонта4.Заголовок 	= "Вид ремонта 4:";
	ДекорВидРемонта4.Ширина 	= 10;
	
	СтруктураСвойств = Новый Структура("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	СобытияЭлемента = Новый Структура("ПриИзменении", "Расш1_GDS_ВидОбслуживания4ПриИзмененииПосле");
	Если ТекущаяФорма.ИмяФормы = "Документ.уатРемонтныйЛист.Форма.ФормаДокумента" Тогда
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ТекущаяФорма, "ВидОбслуживания4", ТекущаяФорма.Элементы.ГруппаВидРем4,"", 1, "Объект.GDS_ВидОбслуживания4", СтруктураСвойств, СобытияЭлемента); 	
	КонецЕсли;
	
	//ПолеВвода = ТекущаяФорма.Элементы.Добавить("ВидОбслуживания4", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаВидРем4);
	//ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	//ПолеВвода.ПутьКДанным 		= "Объект.GDS_ВидОбслуживания4";
	//ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Нет;
	//ПолеВвода.ВысотаЗаголовка 	= 0;
	
	ГруппаВидРемонта5 = ТекущаяФорма.Элементы.Добавить("ГруппаВидРем5", Тип("ГруппаФормы"), ТекущаяФорма.Элементы.Группа3);
	ГруппаВидРемонта5.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВидРемонта5.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаВидРемонта5.ОтображатьЗаголовок 	= Ложь;
	
	НоваяГруппа 			= ТекущаяФорма.Элементы.Вставить("ГосудНомер", Тип("ДекорацияФормы"), ТекущаяФорма.Элементы.ГруппаТС,ТекущаяФорма.Элементы.ТСМодель);
	НоваяГруппа.Вид 		= ВидДекорацииФормы.Надпись;
	НоваяГруппа.Заголовок	= "Гос. № " + ТекущаяФорма.Объект.ТС.ГосударственныйНомер;
	НоваяГруппа.Шрифт 		= Новый Шрифт(,,Истина);
	
	ДекорВидРемонта5 = ТекущаяФорма.Элементы.Добавить("ДекорацияВидРем5", Тип("ДекорацияФормы"), ТекущаяФорма.Элементы.ГруппаВидРем5);
	ДекорВидРемонта5.Вид 		= ВидДекорацииФормы.Надпись;
	ДекорВидРемонта5.Заголовок 	= "Вид ремонта 5:";
	ДекорВидРемонта5.Ширина 	= 10;
	
	СтруктураСвойств = Новый Структура("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	СобытияЭлемента = Новый Структура("ПриИзменении", "Расш1_GDS_ВидОбслуживания5ПриИзмененииПосле");
	Если ТекущаяФорма.ИмяФормы = "Документ.уатРемонтныйЛист.Форма.ФормаДокумента" Тогда
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ТекущаяФорма, "ВидОбслуживания5", ТекущаяФорма.Элементы.ГруппаВидРем5,"", 1, "Объект.GDS_ВидОбслуживания5", СтруктураСвойств, СобытияЭлемента); 	
	КонецЕсли;
	
	//ПолеВвода = ТекущаяФорма.Элементы.Добавить("ВидОбслуживания5", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаВидРем5);
	//ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	//ПолеВвода.ПутьКДанным 		= "Объект.GDS_ВидОбслуживания5";
	//ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Нет;
	//ПолеВвода.ВысотаЗаголовка 	= 0;
	
	ПолеВвода = ТекущаяФорма.Элементы.Вставить("СкладВБП", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаМатериалы,ТекущаяФорма.Элементы.Материалы);
	ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным 		= "Объект.GDS_СкладВБП";
	ПолеВвода.ВысотаЗаголовка 	= 0;
	ПолеВвода.Заголовок			= "МОЛ";
	
	ГруппаСчетчикМЧ_ВО = ТекущаяФорма.Элементы.Добавить("ГруппаСчетчикМЧ_ВО", Тип("ГруппаФормы"), ТекущаяФорма.Элементы.ГруппаИзмененныеПоказанияПриборов);
	ГруппаСчетчикМЧ_ВО.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаСчетчикМЧ_ВО.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаСчетчикМЧ_ВО.ОтображатьЗаголовок 	= Ложь;
	
	ПолеФлажка = ТекущаяФорма.Элементы.Добавить("СчетчикМЧ_ВО", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаСчетчикМЧ_ВО);
	ПолеФлажка.Вид 				= ВидПоляФормы.ПолеФлажка;
	ПолеФлажка.ПутьКДанным 		= "Объект.GDS_СчетчикМЧ_ВО";
	ПолеФлажка.ВысотаЗаголовка 	= 0;
	ПолеФлажка.УстановитьДействие("ПриИзменении", "GDS_СчетчикМЧ_ВОПриИзменении");
	
	ПолеВвода = ТекущаяФорма.Элементы.Добавить("ПоказанияСчетчикаМЧ_ВО", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаСчетчикМЧ_ВО);
	ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным 		= "Объект.GDS_ПоказанияСчетчикаМЧ_ВО";
	ПолеВвода.Доступность 		= ТекущаяФорма.Объект.GDS_СчетчикМЧ_ВО;
	ПолеВвода.ВысотаЗаголовка 	= 0;
	
	//ПолеВвода = ТекущаяФорма.Элементы.Добавить("СсылкаНаВидеоФайл", Тип("ПолеФормы"), ТекущаяФорма.Элементы.ГруппаОсновное);
	//ПолеВвода.Вид 				= ВидПоляФормы.ПолеВвода;
	//ПолеВвода.ПутьКДанным 		= "Объект.GDS_СсылкаНаВидеоФайл";
	//ПолеВвода.ПоложениеЗаголовка= ПоложениеЗаголовкаЭлементаФормы.Верх;
	//ПолеВвода.ВысотаЗаголовка 	= 0;
	
	СтруктураСвойств = Новый Структура("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Верх);
	Если ТекущаяФорма.ИмяФормы = "Документ.уатРемонтныйЛист.Форма.ФормаДокумента" Тогда
		GDS_МодульДинамическогоФормированияИнтерфейса.СздПоле(ТекущаяФорма, "СсылкаНаВидеоФайл", ТекущаяФорма.Элементы.ГруппаОсновное,"", 1, "Объект.GDS_СсылкаНаВидеоФайл", СтруктураСвойств); 
	КонецЕсли;
	
	//ТекущаяФорма.Элементы.ГруппаКузовныеЭлементы.Видимость 	= Ложь;
