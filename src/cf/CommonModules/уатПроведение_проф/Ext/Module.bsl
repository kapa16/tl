// Выполняет движения регистра сведений уатДатыДвиженияТоваровНаСкладах.
//
// Параметры:
//  ДополнительныеСвойства	 - 	 - 
//  Движения				 - 	 - 
//  Отказ					 - 	 - 
//
Процедура ОтразитьДатыДвиженияТоваровНаСкладах(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	ТаблицаДвижения = Неопределено;
	Если уатОбщегоНазначения.ЭтоВнешнееСоединение() Тогда
		МассивСтрокДвижения = Неопределено;
		СтруктураТаблицыДляДвижений = Новый Структура;
		Если ДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаПартии") Тогда
			ТаблицаПартии = уатОбщегоНазначенияСервер.ПреобразоватьТаблицувМассивСтрок(ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПартии);
			Если ТаблицаПартии.Количество() > 0 Тогда
				СтруктураТаблицыДляДвижений.Вставить("ТаблицаПартии", ТаблицаПартии);
			КонецЕсли;
		КонецЕсли;
		Если ДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаТоварыВЯчейках") Тогда
			ТаблицаТоварыВЯчейках = уатОбщегоНазначенияСервер.ПреобразоватьТаблицувМассивСтрок(ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаТоварыВЯчейках);
			Если ТаблицаТоварыВЯчейках.Количество() > 0 Тогда
				СтруктураТаблицыДляДвижений.Вставить("ТаблицаТоварыВЯчейках", ТаблицаТоварыВЯчейках);
			КонецЕсли;
		КонецЕсли;
		ДопСвойства = Новый Структура("ТаблицыДляДвижений", СтруктураТаблицыДляДвижений);
		уатЗащищенныеФункцииВызовСервера_проф.ПолучитьДатыДвиженияТоваровНаСкладах(МассивСтрокДвижения, ДопСвойства);
		ТаблицаДвижения = уатОбщегоНазначенияСервер.ПреобразоватьМассивСтрокВТаблицу(МассивСтрокДвижения);
	Иначе
		уатЗащищенныеФункцииСервер_проф.ПолучитьДатыДвиженияТоваровНаСкладах(ТаблицаДвижения, ДополнительныеСвойства);
	КонецЕсли;
	
	Если Отказ ИЛИ ТаблицаДвижения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаДвижения.Колонки.ВидДвижения.Имя = "ВидДвиженияНакопления";
	ТаблицаДвижения.Колонки.Добавить("ВидДвижения", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыДвиженийПриходРасход"));
	Для Каждого ТекСтрока Из ТаблицаДвижения Цикл	
		ТекСтрока.ВидДвижения = ?(ТекСтрока.ВидДвиженияНакопления = ВидДвиженияНакопления.Приход,
			Перечисления.ВидыДвиженийПриходРасход.Приход, Перечисления.ВидыДвиженийПриходРасход.Расход);
	КонецЦикла;
	ТаблицаДвижения.Колонки.Удалить("ВидДвиженияНакопления");
		
	ДвиженияРегистр = Движения.уатДатыДвиженияТоваровНаСкладах;
	ДвиженияРегистр.Записывать = Истина;
	ДвиженияРегистр.Загрузить(ТаблицаДвижения);
	
КонецПроцедуры

