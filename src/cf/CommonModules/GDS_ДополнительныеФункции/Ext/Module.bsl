&НаСервере
Функция ПолучитьПоследниеПоказанияНаработкиПоТС(ТС, ВидОбслуживания, ПериодДанных) Экспорт
	
	Показания = Новый Структура;
	Показания.Вставить("МЧВО", 0);
	Показания.Вставить("Одометр", 0);
	Показания.Вставить("МЧДВС", 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	GDS_ВыработкаПоПоследнемуТОСрезПоследних.МЧВО КАК МЧВО,
	|	GDS_ВыработкаПоПоследнемуТОСрезПоследних.Одометр КАК Одометр,
	|	GDS_ВыработкаПоПоследнемуТОСрезПоследних.МЧДВС КАК МЧДВС
	|ИЗ
	|	РегистрСведений.GDS_ВыработкаПоПоследнемуТО.СрезПоследних(
	|			&Период,
	|			ТранспортноеСредство = &ТранспортноеСредство
	|				И ВидОбслуживания = &ВидОбслуживания) КАК GDS_ВыработкаПоПоследнемуТОСрезПоследних";
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТС);
	Запрос.УстановитьПараметр("ВидОбслуживания", ВидОбслуживания);
	Запрос.УстановитьПараметр("Период", ПериодДанных);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Показания.МЧВО = Выборка.МЧВО;
		Показания.Одометр = Выборка.Одометр;
		Показания.МЧДВС = Выборка.МЧДВС;
	КонецЕсли;
	
	Возврат Показания;
	
КонецФункции

&НаСервере
Функция ВернутьСреднююЦенуНоменклатуры(Номенклатура) Экспорт 
	
	//Если GDS_ФункцииОбмена.ПроверкаНаРабочуюБД() Тогда
		СоединениеWS = GDS_ФункцииОбмена.ПолучитьДанныеОWS_БП();
		
		Данные = СоединениеWS.ВернутьДанныеПоЗапросу("Номенклатура",строка(Номенклатура.Ссылка.УникальныйИдентификатор()));
		
		XML_Строка = Данные.Получить();
		
		СписокПолученныхДанных = GDS_ФункцииОбмена.РазобратьПолученныеДанные(XML_Строка);
		
		ЦенаНоменклатуры = СписокПолученныхДанных[0].Значение.Цена;
		
		Если ЦенаНоменклатуры = "" Тогда
			Возврат 0;	
		КонецЕсли;
		
		Возврат Число(ЦенаНоменклатуры);
	//КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПоказатьВременнуюТаблицу(МенеджерВременныхТаблиц, ИмяВременнойТаблици) Экспорт
 	  
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	| *
	|ИЗ
	| ВременнаяТаблица КАК ВременнаяТаблица";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВременнаяТаблица", ИмяВременнойТаблици); 
	ВременнаяТаблица = Запрос.Выполнить().Выгрузить(); 
	
	Возврат ВременнаяТаблица; 
	
	// Пример
	//GDS_ДополнительныеФункции.ПоказатьВременнуюТаблицу(Запрос.МенеджерВременныхТаблиц,"ВТНачисления") Результат.НайтиСтроки(Новый Структура("ФизическоеЛицо", Справочники.ФизическиеЛица.НайтиПоНаименованию("Белоус Ирина Александровна")))

КонецФункции

&НаСервере
Функция ПечатьИзВПФ(ИмяВПФ, ИмяМакета, МассивОбъектов, ПараметрыПечати) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	СсылкаНаВПФ = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию(ИмяВПФ);

	Если СсылкаНаВПФ.Пустая() Тогда
	    Сообщить("В справочнике ""Дополнительные отчеты и обработки"" не найдена внешнюю печатную форму с наименованием '" + ИмяВПФ + "'");
	    Возврат ТабличныйДокумент;
	КонецЕсли;
	
	Попытка
	    ОбработкаОбъект = ДополнительныеОтчетыИОбработки.ОбъектВнешнейОбработки(СсылкаНаВПФ);
	Исключение
	    Сообщить("Не удалось напечатать """ + ИмяВПФ + "'"". Ошибка создания объекта дополнительной ПФ");
	    Возврат ТабличныйДокумент;
	КонецПопытки;
	
	ОбъектыПечати = Новый СписокЗначений;
	ОбъектыПечати.Добавить(МассивОбъектов);
	
	КоллекцияПечатныхФорм = УправлениеПечатью.ПодготовитьКоллекциюПечатныхФорм(ИмяМакета);
	//ПараметрыВывода = УправлениеПечатью.ПодготовитьСтруктуруПараметровВывода();
	
	Попытка
		ТабличныйДокумент = ОбработкаОбъект.СформироватьПечатнуюФорму(МассивОбъектов, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыПечати);
	Исключение
		Сообщить("Не удалось напечатать """ + ИмяВПФ + "'""." + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки; 
	
    Возврат ТабличныйДокумент;
	
КонецФункции

