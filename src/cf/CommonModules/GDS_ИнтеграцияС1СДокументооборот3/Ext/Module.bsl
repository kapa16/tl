Функция ВыполнитьПодключениеКДокументообороту()
	
	УстановитьПривилегированныйРежим(Истина);
	ИмяПользователя = Константы.ИнтеграцияС1СДокументооборотИмяПользователяДляОбмена.Получить();
	Пароль = Константы.ИнтеграцияС1СДокументооборотПарольДляОбмена.Получить();
	Если Не ЗначениеЗаполнено(ИмяПользователя) Тогда // прочтем настройки из пользовательского хранилища.
		
		ПарольСохранен = Ложь;
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ПрочитатьНастройкиАвторизацииИзХранилищаОбщихНастроек(
			ИмяПользователя,
			Пароль,
			ПарольСохранен);
		
		Если Не ЗначениеЗаполнено(ИмяПользователя) Тогда
			
			ЗаписьЖурналаРегистрации(
				ИнтеграцияС1СДокументооборотБазоваяФункциональность.ИмяСобытияЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,,,
				НСтр("ru = 'Для пользователя регламентного задания обмена не указано имя пользователя 1С:Документооборота'",
					ОбщегоНазначения.КодОсновногоЯзыка()));
			
			Возврат Ложь;
			
		КонецЕсли;
		
		Если ПарольСохранен <> Истина Тогда
			
			ЗаписьЖурналаРегистрации(
				ИнтеграцияС1СДокументооборотБазоваяФункциональность.ИмяСобытияЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,,,
				НСтр("ru = 'Для пользователя регламентного задания обмена не сохранен пароль 1С:Документооборота'",
					ОбщегоНазначения.КодОсновногоЯзыка()));
			
			Возврат Ложь;
			
		КонецЕсли;
		
		// Перенесем настройки в константы.
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СохранитьНастройкиАвторизацииДляОбмена(
			ИмяПользователя,
			Пароль);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УдалитьНастройкиАвторизацииИзХранилищаОбщихНастроек();
		
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьНастройкиАвторизацииВПараметрыСеанса(
		ИмяПользователя,
		Пароль,
		Ложь,
		Ложь);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьВерсиюСервисаВПараметрыСеанса();
	
	Возврат Истина;
	
КонецФункции

Функция ДанныеОбновляемогоОбъектаДляОтправкиВДО(Прокси, Ссылка)
	
	МассивДанных = Новый Массив;
	СписокОбъектовИС = Новый Массив;
	СвязанныеОбъектыДО = Новый Соответствие;
	
	ЗапросИзменения = Новый Запрос;
	ЗапросИзменения.Текст =
		"ВЫБРАТЬ
		|	СУ_СписокДокументовЭДО.Ссылка КАК Объект,
		|	ЕСТЬNULL(ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО, """") КАК ИдентификаторОбъектаДО,
		|	ЕСТЬNULL(ОбъектыИнтегрированныеС1СДокументооборотом.ТипОбъектаДО, """") КАК ТипОбъектаДО
		|ИЗ
		|	Справочник.СУ_СписокДокументовЭДО КАК СУ_СписокДокументовЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
		|		ПО СУ_СписокДокументовЭДО.Ссылка = ОбъектыИнтегрированныеС1СДокументооборотом.Объект
		|ГДЕ
		|	СУ_СписокДокументовЭДО.Ссылка = &Ссылка";
	ЗапросИзменения.УстановитьПараметр("Ссылка", Ссылка);
	
	ВыборкаОбъекты = ЗапросИзменения.Выполнить().Выбрать();
	
	Если ВыборкаОбъекты.Следующий() Тогда
		Если ЗначениеЗаполнено(ВыборкаОбъекты.ИдентификаторОбъектаДО)Тогда
			СвязанныйОбъект = Новый Структура("ТипОбъектаДО, ИдентификаторОбъектаДО",
				ВыборкаОбъекты.ТипОбъектаДО,
				ВыборкаОбъекты.ИдентификаторОбъектаДО);
			СписокОбъектовИС.Добавить(ВыборкаОбъекты.Объект);
			СвязанныеОбъектыДО.Вставить(ВыборкаОбъекты.Объект, СвязанныйОбъект);
		КонецЕсли;
	КонецЕсли;
	
	ТребуютсяПечатныеФормы = ИнтеграцияС1СДокументооборот3.ДоступенФункционалФайлов();

	ПодходящиеПравилаИнтеграции = ИнтеграцияС1СДокументооборот3ВызовСервера.ПодходящиеПравилаИнтеграции(
		СписокОбъектовИС,
		Истина);
	СоответствиеПравилЗагрузкиВДООбъектамИС = ИнтеграцияС1СДокументооборот3.СоответствиеПравилЗагрузкиВДООбъектамИС(
		Прокси,
		СписокОбъектовИС,
		ПодходящиеПравилаИнтеграции);
	ПредварительныеДанные = ИнтеграцияС1СДокументооборот3.ПредварительныеДанныеДляВыгрузкиВДО(
		Прокси,
		СписокОбъектовИС,
		СоответствиеПравилЗагрузкиВДООбъектамИС,,
		ТребуютсяПечатныеФормы);
	СоответствиеСпискаВыраженийОбъектамИС = ПредварительныеДанные.СоответствиеСпискаВыраженийОбъектамИС;
	
	Для Каждого ОбъектИС Из СписокОбъектовИС Цикл
		
		ПравилоЗагрузкиВДО = СоответствиеПравилЗагрузкиВДООбъектамИС[ОбъектИС];
		Если ПравилоЗагрузкиВДО = Неопределено Тогда
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Для объекта ""%1"" (%2) не найдены подходящие правила интеграции с 1С:Документооборот.
				|Обратитесь к системному администратору'"),
				ОбъектИС,
				ТипЗнч(ОбъектИС));
				
			ВызватьИсключение(ТекстОшибки, КатегорияОшибки.ОшибкаХранимыхДанных, , 
				НСтр("ru = 'Необходимо проверить правила интеграции с Документооборотом'"));
		КонецЕсли;
		
		ИнтегрированныйОбъект = Новый Структура("Объект", ОбъектИС);
		ИнтегрированныйОбъект.Вставить("ТипОбъектаДО", СвязанныеОбъектыДО[ОбъектИС].ТипОбъектаДО);
		ИнтегрированныйОбъект.Вставить("ИдентификаторОбъектаДО", СвязанныеОбъектыДО[ОбъектИС].ИдентификаторОбъектаДО);
		ИнтегрированныйОбъект.Вставить("СписокВыгружаемыхТЧ", ПредварительныеДанные.СоответствиеСпискаВыгружаемыхТЧОбъектамИС[ОбъектИС]);
		ИнтегрированныйОбъект.Вставить("СписокВыражений", СоответствиеСпискаВыраженийОбъектамИС[ОбъектИС]);
		ИнтегрированныйОбъект.Вставить("ПравилоЗагрузкиВДО", ПравилоЗагрузкиВДО);
		ИнтегрированныйОбъект.Вставить("ТребуютсяПечатныеФормы", ТребуютсяПечатныеФормы);
		Если ТребуютсяПечатныеФормы Тогда
			ИнтегрированныйОбъект.Вставить("ПечатныеФормы", ПредварительныеДанные.СоответствиеПечатныхФормОбъектамИС[ОбъектИС]);
			ИнтегрированныйОбъект.Вставить("ТипыФайловПечатныхФорм", ПредварительныеДанные.ТипыФайловПечатныхФорм[ОбъектИС]);
		КонецЕсли;
		
		МассивДанных.Добавить(ИнтегрированныйОбъект);
		
	КонецЦикла;
	
	Возврат МассивДанных;
	
КонецФункции

Процедура ЗаполнитьРезультатПоОтветуДО(ДанныеОбработки, Результат, РодительскийПроцесс = "")
	Если ДанныеОбработки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Процесс Из ДанныеОбработки.actionsRows.rows Цикл
		Если Не Процесс.actionsRows = Неопределено Тогда
			ЗаполнитьРезультатПоОтветуДО(Процесс, Результат, Процесс.presentation);
		КонецЕсли;
		
		ПредставлениеСотрудника = Процесс.employeesPresentation;
		Если Не ЗначениеЗаполнено(ПредставлениеСотрудника) Тогда 
			Продолжить;
		КонецЕсли;
		
		ДанныеСотрудника = ДанныеСотрудникаИзПредставленияДО(ПредставлениеСотрудника);
		
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Должность                      = ДанныеСотрудника.Должность;
		НоваяСтрока.Исполнитель                    = ДанныеСотрудника.ФИО;
		НоваяСтрока.ПолноеПредставлениеИсполнителя = ПредставлениеСотрудника;
		НоваяСтрока.РезультатСогласования          = Процесс.statePresentation;
		НоваяСтрока.ДатаИсполнения                 = Процесс.statusDate;
		НоваяСтрока.РезультатВыполнения            = Процесс.comment;
		НоваяСтрока.Подразделение                  = ДанныеСотрудника.Подразделение;
		НоваяСтрока.ТочкаМаршрута                  = Процесс.presentation;
		НоваяСтрока.РодительскийПроцесс            = РодительскийПроцесс;
		НоваяСтрока.ИдентификаторТочкиМаршрута     = Процесс.additionalFields.id;
		НоваяСтрока.Выполнено                      = Ложь;
		Если Процесс.additionalFields.state = "Completed" Тогда
			НоваяСтрока.Выполнено = Истина; 
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ДанныеСотрудникаИзПредставленияДО(Представление)
	
	Результат = Новый Структура;
	Результат.Вставить("ФИО", "");
	Результат.Вставить("Подразделение", "");
	Результат.Вставить("Должность", "");
	
	ПозицияОткрывающейСкобки = СтрНайти(Представление, "(");
	Если ПозицияОткрывающейСкобки > 0 Тогда
		ПозицияЗапятойПослеСкобки = СтрНайти(Представление, ",", , ПозицияОткрывающейСкобки);
		
		Если ПозицияЗапятойПослеСкобки = 0 Тогда
			ПозицияЗапятойПослеСкобки = ПозицияОткрывающейСкобки;
		КонецЕсли;
		
		ПозицияЗакрывающейСкобки = СтрНайти(Представление, ")", , ПозицияЗапятойПослеСкобки); 
		
		Результат.ФИО = СокрЛП(Лев(Представление, ПозицияОткрывающейСкобки - 1));
		Результат.Подразделение = СокрЛП(Сред(Представление, ПозицияОткрывающейСкобки + 1, ПозицияЗапятойПослеСкобки - ПозицияОткрывающейСкобки - 1));
		Результат.Должность = СокрЛП(Сред(Представление, ПозицияЗапятойПослеСкобки + 1, ПозицияЗакрывающейСкобки - ПозицияЗапятойПослеСкобки - 1)); 
	Иначе 
		Результат.ФИО = Представление;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НовыйТаблицаСогласования()
	
	ТаблицаСогласования = Новый ТаблицаЗначений;
	ТаблицаСогласования.Колонки.добавить("Должность"); 
	ТаблицаСогласования.Колонки.добавить("Подразделение"); 
