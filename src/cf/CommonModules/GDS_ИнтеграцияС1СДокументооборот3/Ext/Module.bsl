
#Область СлужебныйПрограммныйИнтерфейс

Процедура GDS_ОбновлениеОбработокИзДокументооборота() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.ЗаполнениеКонтрагентовНаМониторингеСПАРКРиски);
	
	ОбъектыДляОбновления = ОбъектыДляОбновленияОбработкиИзДокументооборота();
	Пока ОбъектыДляОбновления.Следующий() Цикл
		
		Попытка
			ЗаписатьОбработкуДокументооборота(ОбъектыДляОбновления.Объект);
		Исключение
			
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Ошибка обновления обработки из Документооборота'"),
				УровеньЖурналаРегистрации.Ошибка,
				ОбъектыДляОбновления.Объект.Ссылка.Метаданные(),
				ОбъектыДляОбновления.Объект,
				ТекстОшибки
			);
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьОбработкуДокументооборота(ОбъектИС, ТекущаяОбработка = Неопределено) Экспорт
	
	Если ТекущаяОбработка = Неопределено Тогда
		ТекущаяОбработка = ТекущаяОбработка(ОбъектИС);
	КонецЕсли;
	
	РегистрыСведений.GDS_ОбработкаВДокументообороте.Очистить(ОбъектИС);
	
	Если ТекущаяОбработка.ОбработкаПрервана Тогда
		ТочкаМаршрута = Справочники.GDS_ТочкиМаршрутаСогласования.НайтиСоздать("Обработка прервана");
		Результат = Справочники.GDS_РезультатыВыполненияТочкиМаршрутаОбработкиДО.НайтиСоздать("Не согласовано");
		
		Обработка = НовыйОбработкаДокументооборота();
		Обработка.Объект = ОбъектИС;
		Обработка.ТочкаМаршрута = ТочкаМаршрута;
		Обработка.Выполнено = Истина;
		Обработка.Результат = Результат;
		Обработка.Исполнитель = ТекущаяОбработка.ПрервалОбработку;
		Обработка.Комментарий = ТекущаяОбработка.ПричинаПрерывания;
		Обработка.Дата = ТекущаяОбработка.ДатаЗавершения;
		
		РегистрыСведений.GDS_ОбработкаВДокументообороте.Записать(Обработка);
		
	КонецЕсли;
	
	Порядок = 0;
	Для Каждого СтрокаОбработки Из ТекущаяОбработка.Согласования Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаОбработки.ДатаИсполнения) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрокаОбработки.РезультатСогласования = "Пропущено" Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеТочкиМаршрута = СтрокаОбработки.ТочкаМаршрута;
		Если ЗначениеЗаполнено(СтрокаОбработки.РодительскийПроцесс) Тогда
			НаименованиеТочкиМаршрута = СтрокаОбработки.РодительскийПроцесс;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(НаименованиеТочкиМаршрута) Тогда
			Продолжить;
		КонецЕсли;
		
		ТочкаМаршрута = Справочники.GDS_ТочкиМаршрутаСогласования.НайтиСоздать(НаименованиеТочкиМаршрута);
		Результат = Справочники.GDS_РезультатыВыполненияТочкиМаршрутаОбработкиДО.НайтиСоздать(СтрокаОбработки.РезультатСогласования);
		Порядок = Порядок + 1;
		
		Обработка = НовыйОбработкаДокументооборота();
		Обработка.Объект = ОбъектИС;
		Обработка.ТочкаМаршрута = ТочкаМаршрута;
		Обработка.Дата = СтрокаОбработки.ДатаИсполнения;
		Обработка.Выполнено = СтрокаОбработки.Выполнено;
		Обработка.Результат = Результат;
		Обработка.Комментарий = СтрокаОбработки.РезультатВыполнения;
		Обработка.Исполнитель = СтрокаОбработки.ПолноеПредставлениеИсполнителя;
		Обработка.Порядок = Порядок;
		Обработка.ИдентификаторТочкиМаршрута = СтрокаОбработки.ИдентификаторТочкиМаршрута;
		
		РегистрыСведений.GDS_ОбработкаВДокументообороте.Записать(Обработка);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОбъектыДляОбновленияОбработкиИзДокументооборота() Экспорт

	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыИнтегрированныеС1СДокументооборотом.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияСогласованияВДокументообороте КАК СостоянияСогласованияВДокументообороте
	|		ПО ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО = СостоянияСогласованияВДокументообороте.ИдентификаторОбъектаДО
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_ОбработкаВДокументообороте КАК GDS_ОбработкаВДокументообороте
	|		ПО ОбъектыИнтегрированныеС1СДокументооборотом.Объект = GDS_ОбработкаВДокументообороте.Объект
	|ГДЕ
	|	ЕСТЬNULL(GDS_ОбработкаВДокументообороте.ДатаОбновления, ДАТАВРЕМЯ(1, 1, 1)) < СостоянияСогласованияВДокументообороте.ДатаУстановки
	|
	|СГРУППИРОВАТЬ ПО
	|	ОбъектыИнтегрированныеС1СДокументооборотом.Объект";
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Функция ПодготовитьСогласования(ПредметСогласования) Экспорт
	
	Результат = ТекущаяОбработка(ПредметСогласования);
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(Результат.Согласования);
	
КонецФункции

Функция ТекущаяОбработка(ПредметСогласования) Экспорт
	
	Ответ = ТекущаяОбработкаОбъектаДО(ПредметСогласования);
	
	Результат = Новый Структура;
	Результат.Вставить("ДатаЗавершения", Дата(1, 1, 1));
	Результат.Вставить("ОбработкаПрервана", Ложь);
	Результат.Вставить("ПрервалОбработку", "");
	Результат.Вставить("ПричинаПрерывания", "");
	Результат.Вставить("Согласования", НовыйТаблицаСогласования()); 
	
	Если Ответ = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.ДатаЗавершения = Ответ.endDate;
	
	Если Ответ.interrupted <> Неопределено Тогда
		Результат.ОбработкаПрервана = Истина;
		Результат.ПрервалОбработку = Ответ.interrupted.objectID.presentation;
		Результат.ПричинаПрерывания = Ответ.terminationReason;
	КонецЕсли;
	
	ЗаполнитьРезультатПоОтветуДО(Ответ.objectProcessing, Результат.Согласования); 
	
	Возврат Результат;
	
КонецФункции

Функция ОбработкаАтивна(ОбъектИС) Экспорт
	
	ТекущийСтатус = СтатусОбработкиДО(ОбъектИС);
	Если ТекущийСтатус = "Выполняется" 
		Или ТекущийСтатус = "Завершена" Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция СтатусОбработкиДО(ОбъектИС)
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	Если Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		ВызватьИсключение НСтр("ru = 'Работа с 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	ПредметВДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ОбъектИС);
	Если ПредметВДО = Неопределено Тогда
		ВызватьИсключение ("Не найден объект в ДО");
	КонецЕсли;
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	Запрос = ИнтеграцияС1СДокументооборот3.ТекущаяОбработкаОбъектаЗапрос(Прокси, ПредметВДО.id, ПредметВДО.type);
	Ответ = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьЗапрос(Прокси, Запрос);
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, Ответ);
	
	СостояниеОбработки = Неопределено;
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.СвойствоУстановлено(Ответ, "objectProcessing") Тогда
		СостояниеОбработки = Ответ.objectProcessing.state; // Executing, Stopped, Completed, Terminated или пусто
		ДатаИзменения = Ответ.objectProcessing.stateChangeDate;
	КонецЕсли;
	
	ТекущийСтатус = "Не запущена";
	Если СостояниеОбработки = Неопределено Или СостояниеОбработки = "" Или СостояниеОбработки = "Terminated" Тогда
		ТекущийСтатус = "Не запущена";
	ИначеЕсли СостояниеОбработки = "Executing" Тогда
		ТекущийСтатус = "Выполняется";
	ИначеЕсли СостояниеОбработки = "Stopped" Тогда
		ТекущийСтатус = "Остановлена";
	ИначеЕсли СостояниеОбработки = "Completed" Тогда
		ТекущийСтатус = "Завершена";
	КонецЕсли;
	
	Возврат ТекущийСтатус;
	
КонецФункции

Функция ТекущееСостояниеОбработкиДО(Документ) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Статус", "");
	Результат.Вставить("Исполнитель", "");
	Результат.Вставить("Комментарий", "");
	Результат.Вставить("ДатаУстановкиСтатуса", Дата(1, 1, 1));
	
	ДанныеОбработки = ТекущаяОбработка(Документ);
	
	Если ДанныеОбработки.ОбработкаПрервана Тогда
		Результат.Статус = "Обработка прервна";
		Результат.Исполнитель = ДанныеОбработки.ПрервалОбработку;
		Результат.Комментарий = ДанныеОбработки.ПричинаПрерывания;
		Результат.ДатаУстановкиСтатуса = ДанныеОбработки.ДатаЗавершения;
	КонецЕсли;
	
	Согласования = ДанныеОбработки.Согласования;
	
	Если Согласования.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Согласования.Сортировать("ДатаИсполнения Убыв");
	ТекущееСостояние = Согласования[0];
	
	Статус = ТекущееСостояние.РезультатСогласования;
	Если Статус = "На согласовании" Тогда
		СтрокиТочкиМаршрута = СтрРазделить(ТекущееСостояние.ТочкаМаршрута, " ");
		СтрокиТочкиМаршрута.Удалить(1);
		СтрокиТочкиМаршрута.Удалить(0);
		ДолжностьРодительныйПадеж = СтрСоединить(СтрокиТочкиМаршрута, " ");
		Статус = СтрШаблон("%1 у %2", Статус, СокрЛП(ДолжностьРодительныйПадеж));
	КонецЕсли;
	
	Результат.Статус = Статус;
	Результат.Исполнитель = ТекущееСостояние.ПолноеПредставлениеИсполнителя;
	Результат.ДатаУстановкиСтатуса = ТекущееСостояние.ДатаИсполнения;
	
	Возврат Результат;
	
КонецФункции 

Функция ТекущаяОбработкаОбъектаДО(Объект) Экспорт
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	Если Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		ВызватьИсключение НСтр("ru = 'Работа с 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	Если Не ВыполнитьПодключениеКДокументообороту() Тогда
		ВызватьИсключение НСтр("ru = 'Не выполнено подключениек 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	ПредметВДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(Объект);
	
	Если ПредметВДО = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	Запрос = ИнтеграцияС1СДокументооборот3.ТекущаяОбработкаОбъектаЗапрос(Прокси, ПредметВДО.id, ПредметВДО.type);
	
	Ответ = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьЗапрос(Прокси, Запрос);
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, Ответ); 
	
	Возврат Ответ;
	
КонецФункции

Процедура ОбновитьОбъектДО(ОбъектИС) Экспорт
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	Если Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		ВызватьИсключение НСтр("ru = 'Работа с 1С:Документооборот версии 3.0'");
	КонецЕсли;

	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	МассивДанных = ДанныеОбновляемогоОбъектаДляОтправкиВДО(Прокси, ОбъектИС);
	
	ИмяЗапроса = "DMUpdateFromIncomingDataRequest";
	Запрос = ИнтеграцияС1СДокументооборотБазоваяФункциональность.СоздатьОбъект(Прокси, ИмяЗапроса);
	СписокОбъектов = Запрос.objects; // СписокXDTO
	
	КонтрольОтправкиФайлов = ИнтеграцияС1СДокументооборотБазоваяФункциональность.КонтрольОтправкиФайлов();
	Для Каждого ОбъектДО Из МассивДанных Цикл
		
		ОбъектXDTO = ИнтеграцияС1СДокументооборот3Обмен.ПолучитьXDTOИзмененийИзОбъекта(
			Прокси,
			ОбъектДО,
			КонтрольОтправкиФайлов);
			
		СписокОбъектов.Добавить(ОбъектXDTO);
			
	КонецЦикла;
	
	Ответ = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьЗапрос(Прокси, Запрос);
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, Ответ); 
	
КонецПроцедуры

Процедура ПерезапуститьОбработкуДО(Объект, ТекущееСостояние, Причина) Экспорт
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	Если Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		ВызватьИсключение НСтр("ru = 'Работа с 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	ПредметВДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(Объект);
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	ДанныеОбработки = ИнтеграцияС1СДокументооборот3КлиентСервер.ДанныеОбработки(ПредметВДО.id, ПредметВДО.type, ТекущееСостояние, Причина);
	Запрос = ИнтеграцияС1СДокументооборот3.ПерезапуститьОбработкуЗапрос(Прокси, ДанныеОбработки);
	
	Ответ = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьЗапрос(Прокси, Запрос);
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, Ответ); 
	
КонецПроцедуры

Функция ПрерватьОбработкуДО(ОбъектИС, ТекущееСостояние = "", Причина = "") Экспорт
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	Если Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		ВызватьИсключение НСтр("ru = 'Работа с 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	ПредметВДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ОбъектИС);
	Если ПредметВДО = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Не объект не найден в 1С:Документооборот версии 3.0'");
	КонецЕсли;
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	ДанныеОбработки = ИнтеграцияС1СДокументооборот3КлиентСервер.ДанныеОбработки(ПредметВДО.id, ПредметВДО.type, ТекущееСостояние, Причина);
	Запрос = ИнтеграцияС1СДокументооборот3.ПрерватьОбработкуЗапрос(Прокси, ДанныеОбработки);
	
	Ответ = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьЗапрос(Прокси, Запрос);
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, Ответ); 
	
	ОбработкаПрервана = Истина;
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, Ответ, "DMError") Тогда
		ОбработкаПрервана = Ложь;
		
		ТекстОшибки = СокрЛП(Ответ.description);
		
		ЗаписьЖурналаРегистрации(
			ИнтеграцияС1СДокументооборотБазоваяФункциональность.ИмяСобытияЖурналаРегистрации(Ответ.subject),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстОшибки);
	Иначе
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ПриИзмененииСостоянияСогласования(
			ПредметВДО.id,
			ПредметВДО.type,
			Неопределено,
			Ложь,
			ОбъектИС
		);
	КонецЕсли;
	
	Возврат ОбработкаПрервана;
	
КонецФункции

Функция ОтправитьВДокументооборот(ОбъектИС) Экспорт
	
	РезультатОтправкиВДО = Ложь;
	
	Если Не ВыполнитьПодключениеКДокументообороту() Тогда
		Возврат РезультатОтправкиВДО;
	КонецЕсли;
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	
	Если Настройки.ИспользоватьИнтеграциюДО2 Тогда
		
		МодульИнтеграцияС1СДокументооборот = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборот");
		МодульИнтеграцияС1СДокументооборотВызовСервера = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборотВызовСервера");
		
	ИначеЕсли Настройки.ИспользоватьИнтеграциюДО3 Тогда
		
		МодульИнтеграцияС1СДокументооборот = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборот3");
		МодульИнтеграцияС1СДокументооборотВызовСервера = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборот3ВызовСервера");
		
	КонецЕсли;
	
	ОбъектДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ОбъектИС);
	
	Если ОбъектДО = Неопределено Тогда//не нашли наш объект	
		Если Настройки.ИспользоватьИнтеграциюДО2 Тогда
			Правила = МодульИнтеграцияС1СДокументооборотВызовСервера.ПодходящиеПравила(ОбъектИС);
		ИначеЕсли Настройки.ИспользоватьИнтеграциюДО3 Тогда
			Правила = МодульИнтеграцияС1СДокументооборотВызовСервера.ПодходящиеПравилаИнтеграцииОбъекта(ОбъектИС);
		КонецЕсли;
		
		Если Правила.Количество()=0 тогда
			Возврат РезультатОтправкиВДО;
		конецЕсли;
		
		ДействующееПравило = Правила[0];
		
		ОбъектДО = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СоздатьОбъектДОПоПравилу(ОбъектИС, ДействующееПравило.Ссылка);
		
		Если ТипЗнч(ОбъектДО) = Тип("Строка") Тогда
			ЗаписьЖурналаРегистрации("Отправка в Документооборот", УровеньЖурналаРегистрации.Ошибка, ОбъектИС.Метаданные(), ОбъектИС, ОбъектДО);
			Возврат РезультатОтправкиВДО;
		КонецЕсли;
		
		ПрисоединенныеФайлы = Новый Массив;
		РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(ОбъектИС, ПрисоединенныеФайлы);
		ФайлыДляДО = Новый СписокЗначений;
		ФайлыДляДО.ЗагрузитьЗначения(ПрисоединенныеФайлы);
		
		Если ПрисоединенныеФайлы.Количество() > 0 Тогда
			МодульИнтеграцияС1СДокументооборотВызовСервера.ПеренестиФайлыИСвДО(ФайлыДляДО, ОбъектДО.id, ОбъектДО.type, ОбъектИС);
		КонецЕсли;
		
	КонецЕсли;
	
	ТекстОшибки = "";
	РезультатОтправкиВДО = ИнтеграцияС1СДокументооборот3ВызовСервера.НачатьОбработку(ОбъектДО, Ложь, ТекстОшибки);
	
	Если СтрНачинаетсяС(ТекстОшибки, "Обработка уже была начата ранее. Текущее состояние обработки: Выполняется") Тогда
		РезультатОтправкиВДО = Истина;
	КонецЕсли;
	
	Возврат РезультатОтправкиВДО;
	
КонецФункции

Функция ТекущийСтатусДокументаДО(ОбъектИС, ТекущаяОбработка = Неопределено) Экспорт
	
	ТекущийСтатус = "НаСогласовании";
	
	Если ТекущаяОбработка = Неопределено Тогда
		ТекущаяОбработка = ТекущаяОбработка(ОбъектИС);
	КонецЕсли;
	
	ЗаписатьОбработкуДокументооборота(ОбъектИС, ТекущаяОбработка);
	
	Если ТекущаяОбработка.ОбработкаПрервана Тогда
		ТекущийСтатус = "Отклонен";
	КонецЕсли;
	
	Для Каждого СтрокаОбработки Из ТекущаяОбработка.Согласования Цикл
		
		Если СтрНайти(НРег(СтрокаОбработки.ТочкаМаршрута), "ознаком") > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаОбработки.РезультатСогласования = "Пропущено" Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущийСтатус = СтрокаОбработки.РезультатСогласования;
		
		Если Не СтрокаОбработки.Выполнено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТекущийСтатус;
	
КонецФункции

#КонецОбласти

