Функция ПолучитьIDТерминалаТС(ТС) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	GDS_ДанныеИзАвтографаПоТС.ID_ТС КАК ID_Терминала,
	|	GDS_ДанныеИзАвтографаПоТС.ID_Схема КАК ID_Схема
	|ИЗ
	|	РегистрСведений.GDS_ДанныеИзАвтографаПоТС КАК GDS_ДанныеИзАвтографаПоТС
	|ГДЕ
	|	GDS_ДанныеИзАвтографаПоТС.ТранспортноеСредство = &ТранспортноеСредство";
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТС);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Массив = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Массив.Добавить(ВыборкаДетальныеЗаписи.ID_Терминала);
		Массив.Добавить(ВыборкаДетальныеЗаписи.ID_Схема);
	КонецЦикла;
	
	Возврат Массив;
