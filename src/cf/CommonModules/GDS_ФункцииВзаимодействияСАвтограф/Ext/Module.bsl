	СписокМашин.Колонки.Добавить("СерНомер");
	СписокМашин.Колонки.Добавить("Делитель");
	СписокМашин.Колонки.Добавить("Guid");
	СписокМашин.Колонки.Добавить("ГосНомер");

	Токен = "";
	ИдентификаторСхемы = "";
	АдресСервера = "https://glonass.mecamineft.com";
	ИмяФайлаОтвета = КаталогВременныхФайлов() + "Response.json";
	
	ПолучитьТокенНаСервере(Токен,ИдентификаторСхемы,АдресСервера,ИмяФайлаОтвета);	
		
	Если НЕ ЗначениеЗаполнено(Токен) Тогда
		Сообщить("Нет данных о токене для авторизации на сайте!");
		
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	СтрокаЗапроса = "/ServiceJSON/EnumSchemas";
	
	Заголовки = Новый Соответствие;
   	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("AG-TOKEN", Токен);
	
	Схемы = ОтправитьЗапросСервер(СтрокаЗапроса, Заголовки,ЛОЖЬ,ЛОЖЬ,АдресСервера,ИмяФайлаОтвета); 	

	для каждого СхемаНужнаяОрганизация из Схемы цикл
		Попытка
			Если СхемаНужнаяОрганизация.Name = "МеКаМинефть + Ситэк-Транс" Тогда
				СтрокаЗапроса = "/ServiceJSON/EnumDevices?schemaID=" + СхемаНужнаяОрганизация.ID;
		
				Заголовки = Новый Соответствие;
			   	Заголовки.Вставить("Content-Type", "application/json");
				Заголовки.Вставить("AG-TOKEN", Токен);

				Приборы = ОтправитьЗапросСервер(СтрокаЗапроса, Заголовки,ЛОЖЬ,ЛОЖЬ,АдресСервера,ИмяФайлаОтвета);	
				//ДеревоТС = РеквизитФормыВЗначение("ТабТС");
				Сообщение = Новый СообщениеПользователю;
				ИдентификаторыТС = "";
				МассивИдентификаторовТС = Новый Массив;

				Если Приборы = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				НомерС = 0;
				Сч = 1;
				
				Для каждого Сп Из Приборы.Items Цикл			// Приборы
					ДелительР = "";
					
					Если Сп.TripSplitters.Количество() > 0 Тогда
						Для каждого СДелит Из Сп.TripSplitters Цикл
							ДелительР = ДелительР + СДелит.Name + " - " + СДелит.ID + ",";
						КонецЦикла; 	
					КонецЕсли;
					
					НомерС = НомерС + 1;
					
					НС = СписокМашин.Добавить();
					НС.НомерСтроки  = НомерС;
					НС.Группа		= Сп.Name;
					НС.ID			= Сп.ID;
					НС.СхемаNet		= СхемаНужнаяОрганизация.Name;
					НС.СхемаID		= СхемаНужнаяОрганизация.ID;
					НС.СерНомер		= Число(Сп.Serial);
					НС.Делитель 	= ДелительР;
					ИдентификаторыТС = ?(ИдентификаторыТС = "", Сп.ID, ИдентификаторыТС + "," + Сп.ID);
					
					Если Сч = 30 Тогда
						МассивИдентификаторовТС.Добавить(ИдентификаторыТС);
						ИдентификаторыТС = "";
						Сч = 0;
					КонецЕсли;
					
					// Получим гос. номера ТС
					Для каждого Стр Из сп.Properties Цикл
						Если Стр.name = "VehicleRegNumber" Тогда
						    НС.ГосНомер = Стр.Value;
						КонецЕсли;
					КонецЦикла; 
					
					Сч = Сч + 1;
				КонецЦикла; 
			КонецЕсли;
		исключение
		конецПопытки
	конецЦикла;
	
	Возврат СписокМашин;
	
КонецФункции

