	СтрокаДаты = Формат(ДатаUTC, "ДФ=""ггггММдд'-'ЧЧммсс""");
	
	Возврат СтрокаДаты;

КонецФункции

Функция ПолучитьIDТранспорта(ТС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДанныеДляЧтенияИнформацииИзАвтографа.ID_Автограф КАК ID,
	|	ДанныеДляЧтенияИнформацииИзАвтографа.ID_схема КАК ID_схема
	|ИЗ
	|	РегистрСведений.GDS_ДанныеДляЧтенияИнформацииИзАвтографа.СрезПоследних КАК ДанныеДляЧтенияИнформацииИзАвтографа
	|ГДЕ
	|	ДанныеДляЧтенияИнформацииИзАвтографа.ТС.ГосударственныйНомер = &ТС";
	Запрос.УстановитьПараметр("ТС", ТС.Наименование);
	Выборка = Запрос.Выполнить().Выбрать();
	Массив = Новый Массив;
	Если Выборка.Следующий() Тогда
		Массив.Добавить(Выборка.ID);
		Массив.Добавить(Выборка.ID_схема);
		Возврат Массив;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьIDТС(ТС, ТаблицаID)
	Массив = Новый Массив();
	Для Каждого Строка Из ТаблицаID["Items"] Цикл
		Если Строка["Name"] = ТС Тогда
			Массив.Добавить(Строка["ID"]);
			Если Массив.Количество() = 2 Тогда
				Возврат Массив;		
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Массив
КонецФункции

