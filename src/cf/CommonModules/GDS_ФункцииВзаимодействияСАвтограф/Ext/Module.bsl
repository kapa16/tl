
Процедура ПолучениеИнформацииОТранспортныхСредствахИзАвтограф() Экспорт
	
	ДанныеОМашинах = GDS_ФункцииВзаимодействияСАвтограф.ПолучитьДанныеПоМашинам();
	
	Запрос = Новый Запрос ("ВЫБРАТЬ
	                       |	уатТС.Ссылка
	                       |ИЗ
	                       |	Справочник.уатТС КАК уатТС
	                       |ГДЕ
	                       |	уатТС.ГосударственныйНомер ПОДОБНО &ГосударственныйНомер
	                       |	И НЕ уатТС.ПометкаУдаления");
	
	НабЗаписей = РегистрыСведений.GDS_ДанныеДляЧтенияИнформацииИзАвтографа.СоздатьНаборЗаписей();
	НабЗаписей.Записать();
	
	Для Каждого Машина из ДанныеОМашинах Цикл
		ГосНомер = СокрЛП(Машина.ГосНомер);
								
		Если НЕ ЗначениеЗаполнено(ГосНомер) Тогда
			Продолжить;
		КонецЕсли;
		
		ТС = ПоискМашиныПоГосНомеру(ГосНомер,Запрос);					
					
		Если НЕ ЗначениеЗаполнено(ТС) Тогда
			Продолжить;
		КонецЕсли;
		
		НабЗаписей.Отбор.ТС.Установить(ТС);
		НабЗаписей.Прочитать();
		
		Попытка
			Если ЗначениеЗаполнено(НабЗаписей[0].ТС) Тогда
				Продолжить;
			КонецЕсли;
		Исключение
			
		КонецПопытки;
		
		НЗ = НабЗаписей.Добавить();
		НЗ.Период				 = Дата("20240101");
		НЗ.ТС              		 = ТС;
		НЗ.НаименованиеИзАвтограф= Машина.Группа;
		НЗ.ID_Автограф    		 = Машина.ID;
		НЗ.ID_Схема       	 	 = Машина.СхемаID;
		НЗ.СерийныйНомер   		 = Число(Машина.СерНомер);
		НЗ.ГосНомерИзАвтограф 	 = Машина.ГосНомер;
		
		НабЗаписей.Записать();
	КонецЦикла;
		
КонецПроцедуры

Процедура ПолучитьДанныеИзПОАвтограф(ДатаЗапроса = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ДатаЗапроса) Тогда
		ДатаЗапроса = НачалоДня(НачалоДня(ТекущаяДата())-864000);
	Иначе
		ДатаЗапроса = НачалоДня(ДатаЗапроса);
	КонецЕсли;	
	
	ЗапросДокумента = Новый Запрос("ВЫБРАТЬ
	                      |	GDS_ДанныеИзАвтограф.Ссылка
	                      |ИЗ
	                      |	Документ.GDS_ДанныеИзАвтограф КАК GDS_ДанныеИзАвтограф
	                      |ГДЕ
	                      |	GDS_ДанныеИзАвтограф.Дата = &ДатаЗапроса
	                      |	И НЕ GDS_ДанныеИзАвтограф.ПометкаУдаления
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	GDS_ДанныеИзАвтограф.Ссылка");
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних.ТС,
	                      |	GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних.СерийныйНомер,
	                      |	GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних.ID_Автограф,
	                      |	GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних.ID_схема,
	                      |	GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних.Делитель Как РасчетныйБак
	                      |ИЗ
	                      |	РегистрСведений.GDS_ДанныеДляЧтенияИнформацииИзАвтографа.СрезПоследних(&ДатаЗапроса, ) КАК GDS_ДанныеДляЧтенияИнформацииИзАвтографаСрезПоследних");
	
	ДокументОбъект = ВернутьДокументДляЗаполнения(ЗапросДокумента,НачалоДня(ДатаЗапроса));
				
	Запрос.УстановитьПараметр("ДатаЗапроса",ДатаЗапроса);
	
	ВыборкаТС = Запрос.Выполнить().Выбрать();
	
	ТЗ_ИзАвтографа = Запрос.Выполнить().Выгрузить(); 
	
	ДокументОбъект.Рейсы.Очистить();
	ДокументОбъект.Сливы.Очистить();
	ДокументОбъект.Заправки.Очистить();
	
	Токен = "";
	ИдентификаторСхемы = "";
	АдресСервера = "http://glonass.mecamineft.com";
	ИмяФайлаОтвета = КаталогВременныхФайлов() + "Response.json";
	ПолучитьТокенНаСервере(Токен,ИдентификаторСхемы,АдресСервера,ИмяФайлаОтвета);
	Делитель = -1;
	
	Если НЕ ЗначениеЗаполнено(Токен) Тогда
		Сообщить("Нет данных о токене для авторизации на сайте!");
		
		Возврат;
	КонецЕсли;
	
	МассивСписковТС = Новый Массив;
	СписокТС = "";
	Сч = 1;
	
	Пока ВыборкаТС.Следующий() Цикл
		СписокТС = ?(СписокТС = "", ВыборкаТС.ID_Автограф, СписокТС + "," + ВыборкаТС.ID_Автограф);
		Сч = Сч + 1;
		
		Если Сч = 41 Тогда
			МассивСписковТС.Добавить(СписокТС); 
			СписокТС = "";
			Сч = 1;
		КонецЕсли; 
		
		ID_схема = ВыборкаТС.ID_схема;
	КонецЦикла;	
	
	ДатаНачалаСтрокой = ПреобразоватьДатуВСтроку(НачалоДня(ДокументОбъект.Дата));
	ДатаОкончанияСтрокой = ПреобразоватьДатуВСтроку(КонецДня(ДокументОбъект.Дата));
	
	Если СписокТС <> "" Тогда
		МассивСписковТС.Добавить(СписокТС);
	КонецЕсли;
	
	Для Каждого СписокТС ИЗ МассивСписковТС Цикл
		Попыток = 0;
		~ПробуемЕщеРаз:
		КомандаWindows = "Timeout /T " + Формат(1, "ЧГ=0") + " /NoBreak";
		ЗапуститьПриложение(КомандаWindows,,Истина);
		
		СтрокаЗапроса = "/ServiceJSON/GetTrips?schemaID=" + ID_схема + 
						"&IDs=" + СписокТС + 
						"&SD=" + ДатаНачалаСтрокой + 
						"&ED=" + ДатаОкончанияСтрокой + 
						"&tripSplitterIndex=" + Делитель;
			
		Заголовки = Новый Соответствие;
	   	Заголовки.Вставить("Content-Type", "application/json");
		Заголовки.Вставить("AG-TOKEN", Токен);
		
		СтруктураДанныхПоРейсам = ОтправитьЗапросСервер(СтрокаЗапроса, Заголовки, Ложь, Истина,АдресСервера,ИмяФайлаОтвета);
		
		Если СтруктураДанныхПоРейсам = Неопределено Тогда
			Если Попыток < 10 Тогда
				Попыток = Попыток + 1;
				Перейти ~ПробуемЕщеРаз;       
			КонецЕсли;
			//Сообщить("Проблема! Нет данных из Автографа по машине " + ВыборкаТС.ТС);
			//Большая проблема. Опять что то не так.
			ДокументОбъект.Рейсы.Очистить();
			ДокументОбъект.Сливы.Очистить();
			ДокументОбъект.Заправки.Очистить();   
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			ДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			
			Возврат;
		КонецЕсли;
		
		СчРейсов = 1;
		
		Для каждого СтрИД Из СтруктураДанныхПоРейсам Цикл
			Отбор = Новый Структура;
			Отбор.Вставить("СерийныйНомер",СтрИД.Значение["Serial"]);
			НайденныеСтроки = ТЗ_ИзАвтографа.НайтиСтроки(Отбор);
			ТС_тек = НайденныеСтроки[0].ТС;
			
			Для каждого Рейс ИЗ СтрИД.Значение["Trips"] Цикл
				НС 		= ДокументОбъект.Рейсы.Добавить(); 
				Заправки= ДокументОбъект.Заправки.Добавить();	
				Сливы 	= ДокументОбъект.Сливы.Добавить();	
				
				НС.СерНомер = СтрИД.Значение["Serial"];
				НС.ТС		= ТС_тек;
				Сливы.ТС	= ТС_тек;
				Заправки.ТС	= ТС_тек;
				
				СчРейсов = СчРейсов + 1;
				
				Для каждого Мест из СтрИД.Значение["Total"] Цикл
					Если Мест.Ключ = "CurrLocation" Тогда
						НС.ГеоЗона = Мест.Value;
					КонецЕсли;
				КонецЦикла;
				
				Для Каждого Ср ИЗ Рейс["Total"] Цикл					
					ИмяКолонки = СтрЗаменить(Ср.Ключ, " ", "_");
					
					Если Ср.Ключ = "DateTime First" Тогда
						ДатаСтр = СтрЗаменить(Ср.Value,":","");
						ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
						ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
						
						Попытка
							НС.НачРейса = Дата(ДатаСтр);
							Сливы.Начало = Дата(ДатаСтр);
							Заправки.Начало = Дата(ДатаСтр);
						Исключение
							Сообщить("Не верно указана дата: " + ДатаСтр);
						КонецПопытки;	
					ИначеЕсли Ср.Ключ = "DateTime Last" Тогда
						ДатаСтр = СтрЗаменить(Ср.Value,":","");
						ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
						ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
						
						Попытка
							НС.КонРейса = Дата(ДатаСтр);
							Сливы.Окончание = Дата(ДатаСтр);
							Заправки.Окончание = Дата(ДатаСтр);
						Исключение
							Сообщить("Не верно указана дата: " + ДатаСтр);
						КонецПопытки;
					ИначеЕсли Ср.Ключ = "TotalDuration" Тогда					
						НС.ВремяРейса = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));	
					ИначеЕсли Ср.Ключ = "MoveDuration" Тогда					
						НС.ВремяДвижения = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));	
					ИначеЕсли Ср.Ключ = "ParkDuration" Тогда					
						НС.ВремяНаОстановках = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));	
					ИначеЕсли Ср.Ключ = "TotalDistance" Тогда
						НС.Пробег = Формат(Ср.Value,"ЧДЦ=2");	
					ИначеЕсли Ср.Ключ = "ParkCount" Тогда
						НС.КолВоОстановок = Ср.Value;	
					ИначеЕсли Ср.Ключ = "MaxSpeed" Тогда
						НС.СкорМакс = Ср.Value;	
					ИначеЕсли Ср.Ключ = "AverageSpeed" Тогда
						НС.СредняяСкорость = Ср.Value;	
					ИначеЕсли Ср.Ключ = "FirstLocation" Тогда
						НС.МестоположениеНач = Ср.Value;	
					ИначеЕсли Ср.Ключ = "LastLocation" Тогда
						НС.МестоположениеКон = Ср.Value;	
					ИначеЕсли Ср.Ключ = "DWebastoON_dur" и Ср.Value <> "00:00:00" Тогда
						НС.РаботаВебасты = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DWebastoON_dist" Тогда
						НС.ПробегСВебастой = Ср.Value;
					ИначеЕсли Ср.Ключ = "DWebastoF_ON_time" Тогда
						Если ЗначениеЗаполнено(Ср.Value) Тогда
							ДатаСтр = СтрЗаменить(Ср.Value,":","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
							ДатаСтр = СтрЗаменить(ДатаСтр,".","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							Дата = Дата(ДатаСтр);
						Иначе
						    Дата = Дата(1,1,1);
						КонецЕсли;	
						
						НС.ДатаВремяВклВебаста = Дата;//?(ЗначениеЗаполнено(Ср.Value),Дата(Ср.Value),Неопределено);
					ИначеЕсли Ср.Ключ = "DWebastoL_OFF_time" Тогда
						Если ЗначениеЗаполнено(Ср.Value) Тогда
							ДатаСтр = СтрЗаменить(Ср.Value,":","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
							ДатаСтр = СтрЗаменить(ДатаСтр,".","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							Дата = Дата(ДатаСтр);
						Иначе
						    Дата = Дата(1,1,1);
						КонецЕсли;	
						
						НС.ДатаВремяВыклВебаста = Дата;//?(ЗначениеЗаполнено(Ср.Value),Дата(Ср.Value),Неопределено);
					ИначеЕсли Ср.Ключ = "DDryerF_ON_time" Тогда
						Если ЗначениеЗаполнено(Ср.Value) Тогда
							ДатаСтр = СтрЗаменить(Ср.Value,":","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
							ДатаСтр = СтрЗаменить(ДатаСтр,".","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							Дата = Дата(ДатаСтр);
						Иначе
						    Дата = Дата(1,1,1);
						КонецЕсли;	
						
						НС.ДатаВремяВклФена = Дата;//?(ЗначениеЗаполнено(Ср.Value),Дата(Ср.Value),Неопределено);		
					ИначеЕсли Ср.Ключ = "DDryerL_OFF_time" Тогда
						Если ЗначениеЗаполнено(Ср.Value) Тогда
							ДатаСтр = СтрЗаменить(Ср.Value,":","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"-","");
							ДатаСтр = СтрЗаменить(ДатаСтр,"T","");
							ДатаСтр = СтрЗаменить(ДатаСтр,".","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							ДатаСтр = СтрЗаменить(ДатаСтр," ","");
							Дата = Дата(ДатаСтр);
						Иначе
						    Дата = Дата(1,1,1);
						КонецЕсли;	
						
						НС.ДатаВремяВыклФена = Дата;//?(ЗначениеЗаполнено(Ср.Value),Дата(Ср.Value),Неопределено);
					ИначеЕсли Ср.Ключ = "EngineMainMotohours" Тогда
						НС.МЧДвигателяШасси = Формат(Час(Дата("00010101"+СтрЗаменить(Ср.Value,":",""))),"ЧДЦ=1");////Формат(Число(Ср.Value)/3600,"ЧДЦ=1");	
					ИначеЕсли Ср.Ключ = "EngineMainMHOnParks" Тогда
						НС.МЧДвигателяНаОстановкахШасси = Формат(Час(Дата("00010101"+СтрЗаменить(Ср.Value,":",""))),"ЧДЦ=1");// Формат(Число(Ср.Value)/3600,"ЧДЦ=1");
					ИначеЕсли Ср.Ключ = "EngineMainMHInMove" Тогда
						НС.МЧДвигателяВДвиженииНаШасси = Формат(Час(Дата("00010101"+СтрЗаменить(Ср.Value,":",""))),"ЧДЦ=1");//Формат(Число(Ср.Value)/3600,"ЧДЦ=1");
					ИначеЕсли Ср.Ключ = "TankMainFuelLevel First" Тогда
						НС.КолВоТопливаНаНач = Ср.Value;	
					ИначеЕсли Ср.Ключ = "TankMainFuelLevel Last" Тогда
						НС.КолВоТопливаНаКон = Ср.Value;
					ИначеЕсли Ср.Ключ = "TankMainFuelUpVol Diff" Тогда
						НС.ОбъемВсехЗаправок = Ср.Value;						
						Заправки.Значение = Ср.Value;		
					ИначеЕсли Ср.Ключ = "TankMainFuelDnVol Diff" Тогда
						НС.ОбъемВсехСливов = Ср.Value;
						Сливы.Значение = Ср.Value;
					ИначеЕсли Ср.Ключ = "TankMainFuelUpCount" Тогда
						НС.КолВоВсехЗаправок = Ср.Value;
					ИначеЕсли Ср.Ключ = "TankMainFuelDnCount" Тогда
						НС.КолВоВсехСливов = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsum" Тогда
						НС.ОбщийРасходТоплива = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsumP" Тогда
						НС.ОбщийРасходНаОстановкахДвижении = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsumPPerHour" Тогда
						НС.РасходНаОстановкахЗаЧас = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsumPPerMH" Тогда
						НС.РасходНаОстановкахЗаМотоЧас = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsumM" Тогда
						НС.РасходТопливаВДвижении = Ср.Value;
					ИначеЕсли Ср.Ключ = "EngineMainFuelConsumMPer100km" Тогда
						НС.РасходНа100км = Ср.Value;
					ИначеЕсли Ср.Ключ = "DKOMON_dur" Тогда
						НС.ВремяРаботыВО = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineMainLs1000ON_dur" Тогда
						НС.ВремяРаботыДвигателяДо1000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineMainLs1000ON_dist" Тогда
						НС.ПробегСОборотамиДо1000 = Ср.Value;
					ИначеЕсли Ср.Ключ = "DREngineMainGt1000Ls2000ON_dur" Тогда
						НС.ВремяРаботыДвигателяОт1000До2000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineMainGt1000Ls2000ON_dist" Тогда
						НС.ПробегНаОборотахОт1000До2000 = Ср.Value;
					ИначеЕсли Ср.Ключ = "DREngineMainGt2000ON_dur" Тогда
						НС.ВремяРаботыДвигателяБолее2000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineMainGt2000ON_dist" Тогда
						НС.ПробегНаОборотахБолее2000 = Ср.Value;
					ИначеЕсли Ср.Ключ = "DREngineVOLs1000ON_dur" Тогда
						НС.ВремяРаботыВОДо1000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineVOLs1000ON_dist" Тогда
						НС.ПробегСОборотамиВОДо1000 = Ср.Value;
					ИначеЕсли Ср.Ключ = "DREngineVOGt1000Ls2000ON_dur" Тогда
						НС.ВремяРаботыВОот1000до2000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineVOGt1000Ls2000ON_dist" Тогда
						НС.ПробегСОборотамиВОот1000до2000 = Ср.Value;
					ИначеЕсли Ср.Ключ = "DREngineVOGt2000ON_dur" Тогда
						НС.ВремяРаботыВОболее2000 = Дата("00010101"+СтрЗаменить(Ср.Value,":",""));//Дата(1,1,1) + Число(Ср.Value);
					ИначеЕсли Ср.Ключ = "DREngineVOGt2000ON_dist" Тогда
						НС.ПробегСОборотамиВОболее2000 = Ср.Value;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	НашТекущийИндекс = ДокументОбъект.Заправки.Количество()-1;
	
	Пока НашТекущийИндекс >= 0 Цикл
		Если ДокументОбъект.Заправки[НашТекущийИндекс].Значение = 0 Тогда
		     ДокументОбъект.Заправки.Удалить(НашТекущийИндекс);
		КонецЕсли;
		 
		НашТекущийИндекс = НашТекущийИндекс - 1;
	КонецЦикла;	
	
	НашТекущийИндекс = ДокументОбъект.Сливы.Количество()-1;
	
	Пока НашТекущийИндекс >= 0 Цикл
		Если ДокументОбъект.Сливы[НашТекущийИндекс].Значение = 0 Тогда
		     ДокументОбъект.Сливы.Удалить(НашТекущийИндекс);
		 КонецЕсли;
		 
		НашТекущийИндекс = НашТекущийИндекс - 1;
	КонецЦикла;	
	
	ДокументОбъект.Записать();
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Функция ПолучитьДанныеПоМашинам() Экспорт
	
	СписокМашин  = Новый ТаблицаЗначений;
	СписокМашин.Колонки.Добавить("НомерСтроки");
	СписокМашин.Колонки.Добавить("ID");
	СписокМашин.Колонки.Добавить("Группа");
	СписокМашин.Колонки.Добавить("СхемаNet");
