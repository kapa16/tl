// Функция - Получить массив имен реквизитов для выбора ГМ
// 
// Возвращаемое значение:
//   - Массив - Коллекция имен реквизитов
//
Процедура ПечатьЗаказЗаявка_ВыборЗаказа(ЭтотОбъект, МассивОбъектов, Источник, ТипПФ) Экспорт
	мсвРейсов          = Новый Массив();
	мсвОбъектовЗаказ   = Новый Массив();
	СоответвиеЗаказов  = Новый Соответствие();
	Для Каждого ТекМЛ Из МассивОбъектов Цикл
		мсвЗаказов = уатОбменСГИСЭПД.ПолучитьСвязанныеРейсыЗаказЗаявка(ТекМЛ);
		Для Каждого ТекЗаказ Из мсвЗаказов Цикл
			Если мсвЗаказов.Количество() > 1 Тогда
				СтруктураРейса = Новый Структура("Заказ,МаршрутныйЛист", ТекЗаказ, ТекМЛ);
				мсвРейсов.Добавить(СтруктураРейса);
			Иначе
				мсвОбъектовЗаказ.Добавить(ТекЗаказ);
			КонецЕсли; 
			СоответвиеЗаказов.Вставить(ТекЗаказ, ТекМЛ);
		КонецЦикла;
	КонецЦикла;	
	Если мсвРейсов.Количество() <> 0 Тогда
		флВыборОператору = Ложь;
		Если ТипПФ = "Оператор" Или ТипПФ = "ОператорОдин" Тогда
			флВыборОператору = Истина;
		КонецЕсли;
		ПараметрыФормыВыбора = Новый Структура("флВыборЭПД, мсвМаршрутныеЛистыИЗаказы, ТипЭПД, флВыборОператору",
			Истина, мсвРейсов, "ПФ_MXL_уатЗаказЗаявка", флВыборОператору);
			
		ПараметрыОповещения = Новый Структура("ТипПФ, МассивОбъектов, СоответвиеЗаказов",
			ТипПФ, мсвОбъектовЗаказ, СоответвиеЗаказов);
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораЗаказа", ЭтотОбъект, ПараметрыОповещения);
		ОткрытьФорму("Документ.уатТТД.Форма.ФормаВыборЗаказа", ПараметрыФормыВыбора, ЭтотОбъект,,,, Оповещение);
	Иначе 
		ПечатьЗаказЗаявка_ВыполнитьКомандуПечати(ЭтотОбъект, мсвОбъектовЗаказ, Источник, СоответвиеЗаказов, ТипПФ);
	КонецЕсли;
КонецПроцедуры

Процедура ПечатьЗаказЗаявка_ВыполнитьКомандуПечати(ЭтотОбъект, МассивОбъектов, Источник, СоответвиеЗаказов, ТипПФ) Экспорт 
	Если ТипПФ = "Грузоотправитель" Тогда
		ИмяМакета = "ЗаказЗаявкаОтГрузоотправителя";
	ИначеЕсли ТипПФ = "Перевозчик" Тогда
		ИмяМакета = "ЗаказЗаявкаОтПеревозчика";
	ИначеЕсли ТипПФ = "Оператор" Тогда
		ИмяМакета = "ЗаявкаОператору";
	ИначеЕсли ТипПФ = "ОператорОдин" Тогда
		ИмяМакета = "ЗаявкаОператоруОдин";
	КонецЕсли;
	ДопПараметрыПечати = Новый Структура();
	ДопПараметрыПечати.Вставить("СоответвиеЗаказов", СоответвиеЗаказов);

	Если Источник = "ЗаказПеревозичку" Тогда
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
		"Документ.уатЗаказПеревозчику_уэ", 
		ИмяМакета, 
		МассивОбъектов, 
		ЭтотОбъект, 
		ДопПараметрыПечати
		);
	Иначе
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
		"Документ.уатМаршрутныйЛист", 
		ИмяМакета, 
		МассивОбъектов, 
		ЭтотОбъект, 
		ДопПараметрыПечати
		);
	КонецЕсли;
КонецПроцедуры

Процедура ПечатьЕдиныйТранспортныйДокумент_ВыполнитьКомандуПечати(ЭтотОбъект, МассивОбъектов, ПараметрыПечати) Экспорт 
	ИмяМакета = "ЕдиныйТранспортныйДокумент";
	
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
	"Документ.уатЗаказГрузоотправителя", 
	ИмяМакета, 
	МассивОбъектов, 
	ЭтотОбъект, 
	ПараметрыПечати
	);
	
КонецПроцедуры


#Область СлужебныеПроцедурыИФункцииЭТН

Функция ИмяДокумента(ИмяФормы)
	
	МассивЧастейИмениФормы = СтрРазделить(ИмяФормы, ".");
	ИмяОбъекта = МассивЧастейИмениФормы[1];
	
	Возврат ИмяОбъекта;
	
КонецФункции
	
#КонецОбласти 

#Область СлужебныеПроцедурыИФункцииЭПЛ

Функция СформироватьМассивЭДДляПодписи(мсвПутевыхЛистов, Титул, СостоянияПодписейПЛ, СоответвиеПЛЭД, ОшибкиЗаполнения, ЕстьОшибки, ТитулЭПЛ, РезультатПроведения = Неопределено)
	
	мсвДокументовДляПодписи = Новый Массив();
	
	ОшибкиЗаполнения.Очистить();
	Для Каждого ТекПЛ Из мсвПутевыхЛистов Цикл

		СостояниеПодписейПЛ = СостоянияПодписейПЛ.Получить(ТекПЛ);
		ДанныеЭПЛ           = СоответвиеПЛЭД.Получить(ТекПЛ); 
		ЕстьЭПЛ             = ДанныеЭПЛ <> Неопределено;
		Если ЕстьЭПЛ Тогда
			ТекЭПЛ = ДанныеЭПЛ.ЭПЛ;
		Иначе
			ТекЭПЛ = Неопределено;
		КонецЕсли;
		
		Если Титул = "Диспетчер"
			И (НЕ ЕстьЭПЛ ИЛИ
			(ЕстьЭПЛ И НЕ ДанныеЭПЛ.Титул2Подписан И ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 1)
			И НЕ ДанныеЭПЛ.Титул1Подписан)) Тогда
			ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул1");
			
			ДопПараметры = Новый Структура();
			ДопПараметры.Вставить("РезультатПроведенияОсмотра", ПредопределенноеЗначение("Справочник.уатСтатусы_уэ.Новый"));
			
			ЭПЛ = уатОбменСГИСЭПДКлиент.ОформитьЭПЛ(ТекПЛ,
				ТитулЭПЛ, ТекЭПЛ, ДопПараметры, ЕстьОшибки);
			Если ЗначениеЗаполнено(ЭПЛ) Тогда
				НоваяСтрокаОшибок = ОшибкиЗаполнения.Добавить();
				НоваяСтрокаОшибок.Текст = СтрШаблон(Нстр("ru = 'Ошибки заполнения %1 (Оформление):'; en = 'Filling errors %1 (Formation):'"), ЭПЛ);
				Если ОбменСГИСЭПДКлиент.ЗаполнитьТаблицуОшибокЭПД(ЭПЛ, ОшибкиЗаполнения, Ложь) Тогда
					ОбработатьТаблицуОшибок(ОшибкиЗаполнения, ЭПЛ, ТекПЛ);
					ЕстьОшибки = Истина;
				Иначе
					мсвДокументовДляПодписи.Добавить(ЭПЛ);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ЕстьЭПЛ И СтрНайти(Титул, "Медработник") <> 0
			И ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 2) Тогда 
			Водитель = 1;
			Если ДанныеЭПЛ.Титул1Подписан 
				И НЕ ДанныеЭПЛ.Титул2Подписан  
				И Титул = "МедработникВодитель1" Тогда 
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул2");
			ИначеЕсли ДанныеЭПЛ.Титул5Подписан
				И НЕ ДанныеЭПЛ.Титул6Подписан 
				И Титул = "МедработникЗаездВодитель1" Тогда
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул6");
			ИначеЕсли ДанныеЭПЛ.Титул1Подписан 
				И (НЕ ДанныеЭПЛ.Титул2Водитель2Подписан
				ИЛИ НЕ ЗначениеЗаполнено(ДанныеЭПЛ.Титул2Водитель2))
				И Титул = "МедработникВодитель2" Тогда
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул2");
				Водитель = 2;
			ИначеЕсли ДанныеЭПЛ.Титул5Подписан
				И (НЕ ДанныеЭПЛ.Титул6Водитель2Подписан
				ИЛИ НЕ ЗначениеЗаполнено(ДанныеЭПЛ.Титул6Водитель2))
				И Титул = "МедработникЗаездВодитель2" Тогда
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул6");
				Водитель = 2;
			Иначе
				Продолжить;
			Конецесли;
			ДопПараметры = Новый Структура("Водитель,РезультатПроведенияОсмотра,Заключение");
			ДопПараметры.Вставить("Водитель", Водитель);
			РезультатПроведения.Свойство("РезультатПроведенияОсмотра", ДопПараметры.РезультатПроведенияОсмотра);
			РезультатПроведения.Свойство("Заключение",                 ДопПараметры.Заключение);
			
			ЭПЛ = уатОбменСГИСЭПДКлиент.ОформитьЭПЛ(ТекПЛ,
				ТитулЭПЛ, ТекЭПЛ, ДопПараметры, ЕстьОшибки);
			Если ЗначениеЗаполнено(ЭПЛ) Тогда
				НоваяСтрокаОшибок = ОшибкиЗаполнения.Добавить();
				НоваяСтрокаОшибок.Текст = СтрШаблон(Нстр("ru = 'Ошибки заполнения %1 (Медосмотр):'; en = 'Errors in filling %1 (Medical examination):'"), ЭПЛ);
				Если ОбменСГИСЭПДКлиент.ЗаполнитьТаблицуОшибокЭПД(ЭПЛ, ОшибкиЗаполнения, Ложь) Тогда
					ОбработатьТаблицуОшибок(ОшибкиЗаполнения, ЭПЛ, ТекПЛ);
					ЕстьОшибки = Истина;
				Иначе
					мсвДокументовДляПодписи.Добавить(ЭПЛ);
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ЕстьЭПЛ И Титул = "Контролер"
			И ДанныеЭПЛ.Титул1Подписан
			И НЕ ДанныеЭПЛ.Титул3Подписан
			И ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 4) Тогда

			ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул3");
			ДопПараметры = Новый Структура();
			ДопПараметры.Вставить("РезультатПроведенияОсмотра", РезультатПроведения.РезультатПроведенияОсмотра);
			ЭПЛ = уатОбменСГИСЭПДКлиент.ОформитьЭПЛ(ТекПЛ,
				ТитулЭПЛ, ТекЭПЛ, ДопПараметры, ЕстьОшибки);
			Если ЗначениеЗаполнено(ЭПЛ) Тогда
				НоваяСтрокаОшибок = ОшибкиЗаполнения.Добавить();
				НоваяСтрокаОшибок.Текст = СтрШаблон(Нстр("ru = 'Ошибки заполнения %1 (Предрейсовый контроль):'; en = 'Errors filling %1 (Pre-trip inspection):'"), ЭПЛ);
				Если ОбменСГИСЭПДКлиент.ЗаполнитьТаблицуОшибокЭПД(ЭПЛ, ОшибкиЗаполнения, Ложь) Тогда
					ОбработатьТаблицуОшибок(ОшибкиЗаполнения, ЭПЛ, ТекПЛ);
					ЕстьОшибки = Истина;
				Иначе
					мсвДокументовДляПодписи.Добавить(ЭПЛ);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ЕстьЭПЛ И СтрНайти(Титул, "УполномоченныйНаПроставлениеОдометра") <> 0
			И ДанныеЭПЛ.Титул2Подписан
			И ДанныеЭПЛ.ТитулВыпускРезультатПроведенияПредсменногоКонтроля <> "2"
			И ДанныеЭПЛ.Титул3Подписан 
			И ОбменСГИСЭПДКлиентСервер.ВхождениеРоли(ДанныеЭПЛ.РольУчастника, 8) Тогда
			
			Если НЕ ДанныеЭПЛ.Титул4Подписан
				И Титул = "УполномоченныйНаПроставлениеОдометраВыезд" Тогда 
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул4");
			ИначеЕсли НЕ ДанныеЭПЛ.Титул5Подписан 
				И Титул = "УполномоченныйНаПроставлениеОдометраЗаезд" Тогда
				ТитулЭПЛ = ПредопределенноеЗначение("Перечисление.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул5");
			Иначе
				Продолжить;
			Конецесли;
			
			ЭПЛ = уатОбменСГИСЭПДКлиент.ОформитьЭПЛ(ТекПЛ,
				ТитулЭПЛ, ТекЭПЛ, ДопПараметры, ЕстьОшибки);
			Если ЗначениеЗаполнено(ЭПЛ) Тогда
				НоваяСтрокаОшибок = ОшибкиЗаполнения.Добавить();
				НоваяСтрокаОшибок.Текст = СтрШаблон(Нстр("ru = 'Ошибки заполнения %1 (Показания одометра):'; en = '%1 Filling Errors (Odometer Readings):'"), ЭПЛ);
				Если ОбменСГИСЭПДКлиент.ЗаполнитьТаблицуОшибокЭПД(ЭПЛ, ОшибкиЗаполнения, Ложь) Тогда
					ОбработатьТаблицуОшибок(ОшибкиЗаполнения, ЭПЛ, ТекПЛ);
					ЕстьОшибки = Истина;
				Иначе
					мсвДокументовДляПодписи.Добавить(ЭПЛ);
				КонецЕсли;
			КонецЕсли;


		КонецЕсли;
	КонецЦикла;
	
	Возврат мсвДокументовДляПодписи;
	
КонецФункции

Процедура ОбработатьТаблицуОшибок(ОшибкиЗаполнения, ЭПЛ, ТекПЛ)
	ТекПЛДанные = уатОбщегоНазначенияТиповые.ПолучитьЗначенияРеквизитов(ТекПЛ, "ВидСообщения,ВидПеревозки,ТранспортноеСредство,Организация,
	|Водитель1,Водитель2");
	Для Каждого ТекОшибка Из ОшибкиЗаполнения Цикл 
		ТекОшибка.ОбъектПерехода = ЭПЛ;
		Если НЕ ЗначениеЗаполнено(ТекОшибка.Текст) Тогда 
			ТекОшибка.Текст = Нстр("ru = 'Перейти в форму документа'; en = 'Go to the document form'");
		КонецЕсли;  
		Если СтрНайти(ТекОшибка.Узел, "//Файл/Документ/ПодпИнфСоб/ФИО/Фамилия") <> 0 Тогда
			ТекОшибка.Текст = ТекОшибка.Текст + " " + "(требуется выбрать настройки обмена)";
			НастроитьОбменСКонтрагентом(ЭПЛ); 
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/ПодпИнфСоб/ФИО/Имя") <> 0 Тогда
			ТекОшибка.Текст = ТекОшибка.Текст + " " + "(требуется выбрать настройки обмена)";
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвТС/ТС") <> 0 Тогда
			ТекОшибка.ОбъектПерехода = ТекПЛДанные.ТранспортноеСредство;
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвТС/Прицеп[") <> 0 Тогда
			Попытка
				НомерПрицепа = СтрЗаменить(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвТС/Прицеп[", "");
				КонецИндекса = СтрНайти(НомерПрицепа, "]");
				НомерПрицепа = Лев(СтрЗаменить(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвТС/Прицеп[", ""), КонецИндекса-1);
				НомерПрицепа = Число(НомерПрицепа);
				ТекОшибка.ОбъектПерехода = уатОбменСГИСЭПД.ПолучитьПрицепПЛ(ТекПЛ, НомерПрицепа);
			Исключение 
				Продолжить;
			КонецПопытки;
			
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвВодит[") <> 0 Тогда
			Попытка
				НомерВодителя = СтрЗаменить(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвВодит[", "");
				КонецИндекса  = СтрНайти(НомерВодителя, "]");
				НомерВодителя = Лев(СтрЗаменить(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвВодит[", ""), КонецИндекса-1);
				НомерВодителя = Число(НомерВодителя);
				ТекОшибка.ОбъектПерехода = ?(НомерВодителя = 0, ТекПЛДанные.Водитель1, ТекПЛДанные.Водитель2);
			Исключение 
				ТекОшибка.ОбъектПерехода = ТекПЛДанные.Водитель1;
			КонецПопытки;

		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/ВидСообщ") <> 0 Тогда
			Если ЗначениеЗаполнено(ТекПЛДанные.ВидСообщения) Тогда
				ТекОшибка.ОбъектПерехода = ТекПЛДанные.ВидСообщения;
			Иначе
				ТекОшибка.ОбъектПерехода = ТекПЛ;
			КонецЕсли; 
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/ВидПрв") <> 0 Тогда
			Если ЗначениеЗаполнено(ТекПЛДанные.ВидПеревозки) Тогда
				ТекОшибка.ОбъектПерехода = ТекПЛДанные.ВидПеревозки;
			Иначе
				ТекОшибка.ОбъектПерехода = ТекПЛ;
			КонецЕсли;
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвЛицПЛ") <> 0 Тогда
			Если СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвЛицПЛ/Адрес") <> 0 Тогда
				ТекОшибка.Текст = ТекОшибка.Текст + " " + Нстр("ru = 'в юридическом адресе организации'; en = 'at the legal address of the organization'");
			ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвЛицПЛ/Контакт/Тлф") <> 0 Тогда
				ТекОшибка.Текст = ТекОшибка.Текст + " " + Нстр("ru = 'в юридическом адресе организации'; en = 'at the legal address of the organization'");
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекПЛДанные.Организация) Тогда
				ТекОшибка.ОбъектПерехода = ТекПЛДанные.Организация;
			Иначе
				ТекОшибка.ОбъектПерехода = ТекПЛ;
			КонецЕсли;
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфСоб/СвВодит") <> 0 Тогда
			
			Если ЗначениеЗаполнено(ТекПЛДанные.Водитель1)
				И НЕ ЗначениеЗаполнено(ТекПЛДанные.Водитель2) Тогда
				ТекОшибка.ОбъектПерехода = ТекПЛДанные.Водитель1;
			Иначе
				ТекОшибка.ОбъектПерехода = ТекПЛ;
			КонецЕсли; 
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфМО/СвМедРаб") <> 0 Тогда
			ТекстОшибки = уатОбменСГИСЭПД.ПолучитьТекстОшибкиЗаполненияСвМедРаб(ТекПЛ, ЭПЛ);
			 
			ТекОшибка.Текст = ТекОшибка.Текст + " " + ТекстОшибки;
			ТекОшибка.ОбъектПерехода = ТекПЛ;
			
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфМО/СвМедОрг") <> 0 Тогда
			ТекОшибка.ОбъектПерехода = ТекПЛ;  
			
		ИначеЕсли СтрНайти(ТекОшибка.Узел, "//Файл/Документ/СодИнфТехСост/СвОтвЛиц") <> 0 Тогда
			ТекОшибка.Текст = ТекОшибка.Текст + " " + Нстр("ru = 'ответственного за состояние ТС при выезде'; en = 'responsible for the condition of the vehicle upon departure'");
			ТекОшибка.ОбъектПерехода = ТекПЛ;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ИмяОбъектаФормы(ИмяФормы)
	
	МассивЧастейИмениФормы = СтрРазделить(ИмяФормы, ".");
	ИмяОбъекта = МассивЧастейИмениФормы[0] + "." + МассивЧастейИмениФормы[1];
	
	Возврат ИмяОбъекта;
	
КонецФункции

Процедура НастроитьОбменСКонтрагентом(ЭПЛ)  
	МассивНастроек = Новый Массив;
	
	СтрутураЭПЛ = уатОбщегоНазначенияТиповые.ПолучитьЗначенияРеквизитов(ЭПЛ,
		"ВидДокумента,СсылкаТитулОформлениеОформитель,СсылкаТитулОформлениеМедорганизация");
	КлючНастроекОтправкиМед = НастройкиЭДОКлиентСервер.НовыйКлючНастроекОтправки();
	КлючНастроекОтправкиМед.ВидДокумента = СтрутураЭПЛ.ВидДокумента;
	КлючНастроекОтправкиМед.Отправитель  = СтрутураЭПЛ.СсылкаТитулОформлениеОформитель;
	Если ЗначениеЗаполнено(СтрутураЭПЛ.СсылкаТитулОформлениеМедорганизация) Тогда
		КлючНастроекОтправкиМед.Получатель = СтрутураЭПЛ.СсылкаТитулОформлениеМедорганизация; 	
	Иначе
		КлючНастроекОтправкиМед.Получатель = СтрутураЭПЛ.СсылкаТитулОформлениеОформитель;
	КонецЕсли;
	ПараметрыНастройкиОбменаСКонтрагентом = НастройкиЭДОКлиент.НовыеПараметрыНастройкиОбменаСКонтрагентом();
	ПараметрыНастройкиОбменаСКонтрагентом.НастройкаОдногоДокумента = Истина;
	
	МассивНастроек.Добавить(КлючНастроекОтправкиМед);
	НастройкиОтправки = НастройкиОтправкиЭДОСлужебныйВызовСервера.НастройкиОтправки(МассивНастроек[0]);
	Если НастройкиОтправки = Неопределено Тогда	
		НастройкиЭДОКлиент.НастроитьОбменСКонтрагентом(МассивНастроек[0],,ПараметрыНастройкиОбменаСКонтрагентом);
	КонецЕсли;
	
КонецПроцедуры

