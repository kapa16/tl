#Область ПрограммныйИнтерфейс

// Процедура, вызываемая из одноименного обработчика события формы.
//
// Параметры:
//  Форма                - ФормаКлиентскогоПриложения - Форма контактов службы поддержки.
//  Отказ                - Булево - Признак отказа от создания формы.
//  СтандартнаяОбработка - Булево - Признак выполнения стандартной (системной) обработки события.
//
Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка) Экспорт
	
	// Производим корректировку служебных форм.
	пр_ПоддержкаОтраслевыхРешений.НастроитьЭлементыТиповыхФорм(Форма);
	
	// Произведем сбор необходимых показателей в контексте сеанса пользователя.
	пр_ПоддержкаОтраслевыхРешений.ОбновитьПараметрыПоДаннымСеанса();
	
	// Вызываем переопределяемый обработчик.
	пр_ПоддержкаОтраслевыхРешенийПереопределяемый.ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры // ПриСозданииНаСервере()

// Обработчик события получения параметров центра мониторинга по умолчанию
//
Функция ПриПолученииПараметровЦентраМониторинга(Параметры) Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат Параметры;
	КонецЕсли;
	Сутки = 24*60*60;
	
	// Сохраним параметры подключения к типовому серверу
	Параметры.Вставить("СерверТиповой",                Параметры.Сервер);
	Параметры.Вставить("ПортТиповой",                  Параметры.Порт);
	Параметры.Вставить("АдресРесурсаТиповой",          Параметры.АдресРесурса);
	Параметры.Вставить("АдресРесурсаДляДамповТиповой", Параметры.АдресРесурсаДляДампов);
	
	// Переопределим параметры отправки данных
	пр_ПоддержкаОтраслевыхРешений.ПараметрыСервераПоУмолчанию(Параметры);
	
	// Определим режим по умолчанию.
	Параметры.Вставить("ВключитьЦентрМониторинга",           Истина);
	Параметры.Вставить("ЦентрОбработкиИнформацииОПрограмме", Ложь);
	
	// Встроим параметры, которых нет в прежних версиях БСП.
	Если НЕ Параметры.Свойство("ИдентификаторИнформационнойБазыПостоянный") Тогда
		Параметры.Вставить("ИдентификаторИнформационнойБазыПостоянный", Неопределено);
	КонецЕсли;
	Если НЕ Параметры.Свойство("ОзнакомительныйПакетОтправлен") Тогда
		Параметры.Вставить("ОзнакомительныйПакетОтправлен", ИСТИНА);
	КонецЕсли;
	Если НЕ Параметры.Свойство("КонтактнаяИнформацияИзменена") Тогда
		Параметры.Вставить("КонтактнаяИнформацияИзменена", ИСТИНА);
	КонецЕсли;
	
	// Корректируем параметры по-умолчанию отправки минимальных сведений о системе.
	Параметры.Вставить("РегистрироватьИнформациюОСистеме", ИСТИНА);
	Параметры.Вставить("РегистрироватьВерсииПодсистем",    ЛОЖЬ);
	
	// Корректируем параметры по-умолчанию сбора статистики конфигурации.
	Параметры.Вставить("РегистрироватьСтатистикуКонфигурации",     ИСТИНА);
	Параметры.Вставить("СтатистикаКонфигурацииПериодФормирования", 7*Сутки);
	Параметры.Вставить("СтатистикаКонфигурацииПериодОтправки",     7*Сутки);
	Параметры.Вставить("ОтправкаДанныхПериодФормирования",         7*Сутки);
	
	// Корректируем параметры по-умолчанию сбора бизнес статистики.
	Параметры.Вставить("БизнесСтатистикаПериодФормирования", 3600);
	Параметры.Вставить("ПериодАгрегацииМалый",               600);
	Параметры.Вставить("ПериодАгрегации",                    3600);
	Параметры.Вставить("ПериодУдаления",                     Сутки);
	
	// Параметры отраслевой статистики.
	Параметры.Вставить("ИдентификаторКонфигурацииСледующееФормирование", Дата(1,1,1));
	
	// Поддерживаем возможность использования в расширении
	Возврат Параметры;
	
КонецФункции // ПриПолученииПараметровЦентраМониторинга()

// Обработчик события сбора статистики конфигурации
//
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения.
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	ПриоритетныйРежим = (НЕ пр_ПоддержкаОтраслевыхРешений.ЭтоФоновоеЗадание());
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Получим настройки центра мониторинга.
	ПараметрыЦентраМониторинга = Новый Структура();
	ПараметрыЦентраМониторинга.Вставить("РегистрироватьСтатистикуКонфигурации");
	ПараметрыЦентраМониторинга.Вставить("СтатистикаКонфигурацииСледующееФормирование");
	ПараметрыЦентраМониторинга.Вставить("ОтправкаДанныхСледующееФормирование");
	ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	
	// Получаем параметры зависимые от разделения на области данных.
	ПараметрыОтраслевойПоддержки = Новый Структура();
	ПараметрыОтраслевойПоддержки.Вставить("РазмерДанныхТаблицСледующееФормирование");
	ПараметрыОтраслевойПоддержки.Вставить("РазмерДанныхТаблицПериодФормирования");
	ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчетаСледующееФормирование");
	ПараметрыОтраслевойПоддержки.Вставить("НачалоВеденияУчетаПериодФормирования");
	пр_ПоддержкаОтраслевыхРешений.ПолучитьПараметрыОтраслевойПоддержки(ПараметрыОтраслевойПоддержки);
	
	// Подготовим структуру для накопления измененных параметров.
	ПараметрыДляЗаписи = Новый Структура();
	
	// Зафиксируем время запуска процесса
	ДатаЗапуска = ТекущаяУниверсальнаяДата();
	
	// Обновим сведения о размере таблиц информационной базы.
	Если ПараметрыЦентраМониторинга.РегистрироватьСтатистикуКонфигурации И ДатаЗапуска >= ПараметрыОтраслевойПоддержки.РазмерДанныхТаблицСледующееФормирование Тогда
		
		Попытка
			
			// Регистрируем размеры таблиц.
			пр_ПоддержкаОтраслевыхРешений.РегистрироватьРазмерДанныхТаблицИнформационнойБазы();
			
			// Устанавливаем следующую дату актуализации.
			ПараметрыДляЗаписи.Вставить("РазмерДанныхТаблицСледующееФормирование", ДатаЗапуска + ПараметрыОтраслевойПоддержки.РазмерДанныхТаблицПериодФормирования);
			
		Исключение
			пр_ПоддержкаОтраслевыхРешений.ОбработатьОшибку(ИнформацияОбОшибке(), "СобратьОтраслевуюСтатистику");
		КонецПопытки;
		
	КонецЕсли;
	
	// Исправим записи в регистре статистики.
	Если ПараметрыЦентраМониторинга.РегистрироватьСтатистикуКонфигурации И ДатаЗапуска >= ПараметрыЦентраМониторинга.СтатистикаКонфигурацииСледующееФормирование Тогда
		
		Попытка
			пр_ПоддержкаОтраслевыхРешений.ИсправитьКоличествоЗаписейТаблицИнформационнойБазы();
		Исключение
			пр_ПоддержкаОтраслевыхРешений.ОбработатьОшибку(ИнформацияОбОшибке(), "СобратьОтраслевуюСтатистику");
		КонецПопытки;
		
		Попытка
			пр_ПоддержкаОтраслевыхРешений.ИсправитьФункциональныеОпцииИнформационнойБазы();
		Исключение
			пр_ПоддержкаОтраслевыхРешений.ОбработатьОшибку(ИнформацияОбОшибке(), "СобратьОтраслевуюСтатистику");
		КонецПопытки;
		
	КонецЕсли;
	
	// Обновим сведения о размере таблиц информационной базы.
	Если ПараметрыЦентраМониторинга.РегистрироватьСтатистикуКонфигурации И ДатаЗапуска >= ПараметрыОтраслевойПоддержки.НачалоВеденияУчетаСледующееФормирование Тогда
		
		Попытка
			
			// Получаем дату начала ведения учета.
			пр_ПоддержкаОтраслевыхРешений.РегистрироватьНачалоВеденияУчета(ПараметрыДляЗаписи);
			
			// Устанавливаем следующую дату актуализации.
			ПараметрыДляЗаписи.Вставить("НачалоВеденияУчетаСледующееФормирование", ДатаЗапуска + ПараметрыОтраслевойПоддержки.НачалоВеденияУчетаПериодФормирования);
			
		Исключение
			пр_ПоддержкаОтраслевыхРешений.ОбработатьОшибку(ИнформацияОбОшибке(), "СобратьОтраслевуюСтатистику");
		КонецПопытки;
		
	КонецЕсли;
	
	// Сохраняем измененные параметры.
	Если ПараметрыДляЗаписи.Количество() > 0 Тогда
		пр_ПоддержкаОтраслевыхРешений.УстановитьПараметрыОтраслевойПоддержки(ПараметрыДляЗаписи);
	КонецЕсли;
	
	// Если процесс выполняется в сеансе пользователя, то обновим данные клиента.
	Если ПриоритетныйРежим И ДатаЗапуска >= ПараметрыЦентраМониторинга.ОтправкаДанныхСледующееФормирование Тогда
		пр_ПоддержкаОтраслевыхРешений.ОбновитьПараметрыПоДаннымСеанса(ИСТИНА);
	КонецЕсли;
	
КонецПроцедуры // ПриСбореПоказателейСтатистикиКонфигурации()

// Обработчик события возникающего перед формированием тестового или ознакомительного пакета.
//   Тестовый пакет отправляется один раз до включения отправки статистики. После включения отправка не осуществляется.
//   Ознакомительный пакет - это первый пакет после включения отправки или смене идентификатора.
//   Ознакомительный и тестовые пакеты содержат минимум сведений. Сбор и расчет статистики не производится.
//
// Параметры:
//  ПараметрыВыполнения        - Структура:
//   * Итератор                - Число - при вызове извне должен быть равен 0.
//   * ОтправкаТестовогоПакета - Булево.
//   * ПолучениеИдентификатора - Булево.
//
Процедура ПриОтправкеТестовогоПакета(ПараметрыВыполнения=Неопределено) Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	// Последующие действия выполняем только при отправке ознакомительного пакета
	Если ПараметрыВыполнения<>Неопределено И ПараметрыВыполнения.ПолучениеИдентификатора<>ИСТИНА Тогда
		Возврат;
	КонецЕсли;
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Проверим состояние центра мониторинга
	Если НЕ пр_ПоддержкаОтраслевыхРешений.ВключенаОтправкаСтатистики(ИСТИНА) Тогда
		пр_ПоддержкаОтраслевыхРешений.ВключитьОтправкуСтатистики(ЛОЖЬ);
	КонецЕсли;
	
	// Технические сведения о система отправляем всегда
	ЦентрМониторингаСлужебный.УстановитьПараметрЦентраМониторингаВнешнийВызов("ОзнакомительныйПакетОтправлен", ЛОЖЬ);
	
КонецПроцедуры // ПриОтправкеТестовогоПакета()

// Обработчик события формирования пакета для отправки на сервер статистики
//
Функция ПриФормированииПакетаДляОтправки(ПакетДанных, Параметры) Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат ПакетДанных;
	КонецЕсли;
	
	// Выполняем операцию под полными правами.
	Если БезопасныйРежим()=ИСТИНА Тогда
		УстановитьОтключениеБезопасногоРежима(ИСТИНА);
	КонецЕсли;
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	// Получим настройки центра мониторинга и поддержки отраслевых решений.
	ПараметрыОтраслевойПоддержки = пр_ПоддержкаОтраслевыхРешений.ПолучитьПараметрыОтраслевойПоддержки();
	ПараметрыЦентраМониторинга   = ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов();
	
	// Определим режим выполнения обработчика.
	ПриоритетныйРежим = (НЕ пр_ПоддержкаОтраслевыхРешений.ЭтоФоновоеЗадание());
	ПолученоСогласие  = (ПараметрыЦентраМониторинга.ЗапросКонтактнойИнформации=1);
	ВключенаОтправка  = (ПараметрыЦентраМониторинга.ВключитьЦентрМониторинга ИЛИ ПараметрыЦентраМониторинга.ЦентрОбработкиИнформацииОПрограмме);
	
	// Извлечем переданные параметры формирования пакета
	ДатаЗапуска    = Параметры.ДатаЗапуска;
	ДатаНачала     = Параметры.ДатаНачала;
	ДатаОкончания  = Параметры.ДатаОкончания;
	ПериодУдаления = Параметры.ПериодУдаления;
	
	// Замещаем в пакете секцию информации о системе
	ПакетДанных.Вставить("info", пр_ПоддержкаОтраслевыхРешений.ПолучитьИнформациюОСистеме(ВключенаОтправка, ПолученоСогласие));
	
	// Расширяем секцию статистических сведений о таблицах базы.
	Если ПараметрыЦентраМониторинга.РегистрироватьСтатистикуКонфигурации И ПакетДанных.Свойство("config") И ТипЗнч(ПакетДанных["config"])=Тип("Структура") Тогда
		
		// Включаем информацию о дате начала ведения учета.
		ПакетДанных["config"].Вставить("StartOfAccounting", ПараметрыОтраслевойПоддержки.НачалоВеденияУчета);
		
		// Признак блокировки работы с внешними ресурсами.
		ПакетДанных["config"].Вставить("ExternalResourcesIsBlocked", РегламентныеЗаданияСервер.РаботаСВнешнимиРесурсамиЗаблокирована());
		
		// Корректируем секцию сведений об использовании объектов базы данных
		Секция = пр_ПоддержкаОтраслевыхРешений.ПолучитьСтатистикуИспользованияОбъектовБазыДанных();
		ПакетДанных["config"].Вставить("columns",           Секция["columns"]);
		ПакетДанных["config"].Вставить("columnsValueIndex", Секция["columnsValueIndex"]);
		ПакетДанных["config"].Вставить("rows",              Секция["rows"]);
		
	КонецЕсли;
	
	// Расширяем секцию бизнес-статистики.
	Если ПараметрыЦентраМониторинга.РегистрироватьБизнесСтатистику И ПакетДанных.Свойство("business") И ТипЗнч(ПакетДанных["business"])=Тип("Структура") Тогда
		ПакетДанных["business"].Вставить("OperationStatisticsClientGrouped", пр_ПоддержкаОтраслевыхРешений.ПолучитьСгруппированныеЗамеры(ДатаНачала, ДатаОкончания));
		ПакетДанных["business"].Вставить("OperationStatisticsClientUnique",  пр_ПоддержкаОтраслевыхРешений.ПолучитьУникальныеЗамеры(ДатаНачала, ДатаОкончания));
		ПакетДанных["business"].Вставить("OperationStatisticsWorkStation",   пр_ПоддержкаОтраслевыхРешений.ПолучитьАктивностьРабочихМест(ДатаНачала, ДатаОкончания));
	КонецЕсли;
	
	// Размещаем секцию информации о продукте.
	ПакетДанных.Вставить("product", пр_ПоддержкаОтраслевыхРешений.ПолучитьИнформациюОПродукте());
	
	// В каждый 10-й пакет будем включать информацию об идентификаторе конфигурации.
	Если ПараметрыЦентраМониторинга.ОзнакомительныйПакетОтправлен И (ПараметрыЦентраМониторинга.НомерКрайнегоПакета < 4 ИЛИ ДатаЗапуска >= ПараметрыЦентраМониторинга.ИдентификаторКонфигурацииСледующееФормирование ИЛИ ПриоритетныйРежим) Тогда
		ПакетДанных["product"].Вставить("ConfigurationID", ПолучитьИдентификаторКонфигурации());
		ПараметрыЦентраМониторинга.ИдентификаторКонфигурацииСледующееФормирование = ДатаЗапуска + ПараметрыЦентраМониторинга.ОтправкаДанныхПериодФормирования * 10;
		ЦентрМониторингаСлужебный.УстановитьПараметрЦентраМониторингаВнешнийВызов("ИдентификаторКонфигурацииСледующееФормирование", ПараметрыЦентраМониторинга.ИдентификаторКонфигурацииСледующееФормирование);
	КонецЕсли;
	
	// Размещаем секцию информации о состоянии защиты.
	ПакетДанных.Вставить("protection", ПараметрыОтраслевойПоддержки.ПараметрыЛицензий);
	
	// Размещаем секцию регламентных заданий.
	Если ПараметрыЦентраМониторинга.РегистрироватьНастройкуКонфигурации Тогда
		ПакетДанных.Вставить("scheduledJobs", пр_ПоддержкаОтраслевыхРешений.ПолучитьРегламентныеЗадания(ДатаНачала, ДатаОкончания));
	КонецЕсли;
	
	// Информация для регистрации продукта.
	Если ПолученоСогласие И (ПараметрыЦентраМониторинга.КонтактнаяИнформацияИзменена ИЛИ ПриоритетныйРежим) Тогда
		
		// Проверяем наличие серкции contacts в пакете.
		Если НЕ ПакетДанных.Свойство("contacts") ИЛИ ПакетДанных["contacts"]=Неопределено Тогда
			ПакетДанных.Вставить("contacts", Новый Структура);
		КонецЕсли;
		
		// Вносим данные для регистрации базы в личном кабинете.
		РегистрацияПродукта = пр_ПоддержкаОтраслевыхРешений.ПрочитатьРегистрациюПродукта();
		ПакетДанных["contacts"].Вставить("dbName",       ПараметрыОтраслевойПоддержки.НаименованиеБазы);
		ПакетДанных["contacts"].Вставить("regNumber",    РегистрацияПродукта.РегНомер);
		ПакетДанных["contacts"].Вставить("inn",          РегистрацияПродукта.ИНН);
		ПакетДанных["contacts"].Вставить("kpp",          РегистрацияПродукта.КПП);
		ПакетДанных["contacts"].Вставить("its",          РегистрацияПродукта.ИТС);
		ПакетДанных["contacts"].Вставить("account",      РегистрацияПродукта.Аккаунт);
		ПакетДанных["contacts"].Вставить("user",         РегистрацияПродукта.КонтактноеЛицо);
		ПакетДанных["contacts"].Вставить("email",        РегистрацияПродукта.ЭлектроннаяПочта);
		ПакетДанных["contacts"].Вставить("phone",        РегистрацияПродукта.НомерТелефона);
		ПакетДанных["contacts"].Вставить("seller",       РегистрацияПродукта.Партнер);
		ПакетДанных["contacts"].Вставить("purchase",     РегистрацияПродукта.ДатаПриобретения);
		ПакетДанных["contacts"].Вставить("author",       РегистрацияПродукта.Автор);
		ПакетДанных["contacts"].Вставить("dateModified", РегистрацияПродукта.ДатаИзменения);
		
	КонецЕсли;
	
	// Обращения в службу технической поддержки.
	Если ПолученоСогласие И Метаданные.РегистрыСведений.Найти("пр_ОбращенияВСлужбуПоддержки") <> Неопределено Тогда
		МодульОбращенияВСлужбуПоддержки = ОбщегоНазначения.ОбщийМодуль("РегистрыСведений.пр_ОбращенияВСлужбуПоддержки");
		МодульОбращенияВСлужбуПоддержки.ОтправитьОбращенияПользователейВСлужбуТехническойПоддержки(ПакетДанных);
	КонецЕсли;
	
	// Поддерживаем возможность использования в расширении
	Возврат ПакетДанных;
	
КонецФункции // ПриФормированииПакетаДляОтправки()

// Обработчик события обработки получения ответа от сервера статистики после отправки пакета
//
Функция ПриПолученииОтветаОтСервера(ПакетОтвета, ПараметрыЦентраМониторинга) Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат ПараметрыЦентраМониторинга;
	КонецЕсли;
	
	// Корректируем настройки отправки статистики
	ПараметрыЦентраМониторинга.Вставить("РегистрироватьИнформациюОСистеме",     ИСТИНА);
	ПараметрыЦентраМониторинга.Вставить("РегистрироватьВерсииПодсистем",        ЛОЖЬ);
	ПараметрыЦентраМониторинга.Вставить("РегистрироватьСтатистикуКонфигурации", ИСТИНА);
	
	// Период формирования и отправки статистики должен совпадать с периодом отправки пакета.
	ПериодОтправки = Неопределено;
	Задержка       = 60;
	Если ПараметрыЦентраМониторинга.Свойство("ОтправкаДанныхПериодФормирования", ПериодОтправки) И ЗначениеЗаполнено(ПериодОтправки) Тогда
		ПараметрыЦентраМониторинга.Вставить("СтатистикаКонфигурацииПериодФормирования", ПериодОтправки-Задержка);
		ПараметрыЦентраМониторинга.Вставить("СтатистикаКонфигурацииПериодОтправки",     ПериодОтправки-Задержка);
	КонецЕсли;
	
	// Обновляем параметры центра мониторинга.
	ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	
	// Получим номера и статусы обработки обращений пользователей
	Если Метаданные.РегистрыСведений.Найти("пр_ОбращенияВСлужбуПоддержки") <> Неопределено Тогда
		МодульОбращенияВСлужбуПоддержки = ОбщегоНазначения.ОбщийМодуль("РегистрыСведений.пр_ОбращенияВСлужбуПоддержки");
		МодульОбращенияВСлужбуПоддержки.ПолучитьСтатусОбработкиОбращенийПользователей(ПакетОтвета);
	КонецЕсли;
	
	// Поддерживаем возможность использования в расширении
	Возврат ПараметрыЦентраМониторинга;
	
КонецФункции // ПриПолученииОтветаОтСервера()

// Выполняет обработку события ПриИзменении() элементов формы БСП ЦентрМониторингаРазрешитьОтправлятьДанные,
// ЦентрМониторингаРазрешитьОтправлятьДанныеСтороннему, ЦентрМониторингаЗапретитьОтправлятьДанные панели
// администрирования "Интернет-поддержка и сервисы" БСП и БИП.
//
Функция ПриИзмененииРазрешенияОтправкиДанных(Форма, Элемент, ПараметрыОперации) Экспорт
	
	// Обработаем только выбор нового и базового варианта
	Если НЕ(Форма.ЦентрМониторингаРазрешитьОтправлятьДанные=9 ИЛИ Форма.ЦентрМониторингаРазрешитьОтправлятьДанные=0) Тогда
		Возврат ЛОЖЬ;
	КонецЕсли;
	
	// Получаем настройки подсистемы по умолчанию
	ПараметрыЦентраМониторинга = ЦентрМониторингаСлужебный.ПолучитьПараметрыПоУмолчаниюВнешнийВызов();
	
	// Устанавливаем параметры сервера
	Если Форма.ЦентрМониторингаРазрешитьОтправлятьДанные=0 Тогда
		ПараметрыСервиса = Новый Структура();
		ПараметрыСервиса.Вставить("ВключитьЦентрМониторинга",           ИСТИНА);
		ПараметрыСервиса.Вставить("ЦентрОбработкиИнформацииОПрограмме", ЛОЖЬ);
		ПараметрыСервиса.Вставить("Сервер",                ПараметрыЦентраМониторинга.Сервер);
		ПараметрыСервиса.Вставить("Порт",                  ПараметрыЦентраМониторинга.Порт);
		ПараметрыСервиса.Вставить("АдресРесурса",          ПараметрыЦентраМониторинга.АдресРесурса);
		ПараметрыСервиса.Вставить("АдресРесурсаДляДампов", ПараметрыЦентраМониторинга.АдресРесурсаДляДампов);
		ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыСервиса);
	ИНАЧЕ
		ПараметрыСервиса = Новый Структура();
		ПараметрыСервиса.Вставить("ВключитьЦентрМониторинга",           ЛОЖЬ);
		ПараметрыСервиса.Вставить("ЦентрОбработкиИнформацииОПрограмме", ИСТИНА);
		ПараметрыСервиса.Вставить("Сервер",                ПараметрыЦентраМониторинга.СерверТиповой);
		ПараметрыСервиса.Вставить("Порт",                  ПараметрыЦентраМониторинга.ПортТиповой);
		ПараметрыСервиса.Вставить("АдресРесурса",          ПараметрыЦентраМониторинга.АдресРесурсаТиповой);
		ПараметрыСервиса.Вставить("АдресРесурсаДляДампов", ПараметрыЦентраМониторинга.АдресРесурсаДляДамповТиповой);
		ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыСервиса);
	КонецЕсли;
	
	// Производим формирование представления типового адреса
	Если ПараметрыСервиса.Порт = 80 Тогда
		Схема = "http://";
		Порт  = "";
	ИначеЕсли ПараметрыСервиса.Порт = 443 Тогда
		Схема = "https://";
		Порт = "";
	Иначе
		Схема = "http://";
		Порт = ":" + Формат(ПараметрыСервиса.Порт, "ЧН=0; ЧГ=");
	КонецЕсли;
	Форма.ЦентрМониторингаАдресСервиса = Схема + ПараметрыСервиса.Сервер + Порт + "/" + ПараметрыСервиса.АдресРесурса;
	
	// Обновим доступность элементов интерфейса
	РазрешенДоступКИнтернетСервисам = ОбщегоНазначения.РазрешенДоступКИнтернетСервисам();
	Форма.Элементы.ЦентрМониторингаАдресСервиса.Доступность = ЛОЖЬ;
	Форма.Элементы.ЦентрМониторингаНастройки   .Доступность = РазрешенДоступКИнтернетСервисам;
	
	// Выполним операции предусмотренные при смене режима работы
	Если РазрешенДоступКИнтернетСервисам Тогда
		РезультатЗапуска = ЦентрМониторингаСлужебный.ЗапускОтправкиОзнакомительногоПакета();
		РегЗадание       = ЦентрМониторингаСлужебный.ПолучитьРегламентноеЗаданиеВнешнийВызов("СборИОтправкаСтатистики", Истина);
		ЦентрМониторингаСлужебный.УстановитьРасписаниеПоУмолчаниюВнешнийВызов(РегЗадание);
	Иначе
		РезультатЗапуска = Неопределено;
		ЦентрМониторингаСлужебный.УдалитьРегламентноеЗаданиеВнешнийВызов("СборИОтправкаСтатистики");
		ЦентрМониторингаСлужебный.ОтключитьРегистрациюСобытий();
	КонецЕсли;
	ПараметрыОперации.Вставить("РезультатЗапуска", РезультатЗапуска);
	
	// Возвращаем признак успешной обработки события
	Возврат ИСТИНА;
	
КонецФункции // ПриИзмененииРазрешенияОтправкиДанных()

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Позволяет задать значения параметров, необходимых для работы клиентского кода
// при запуске конфигурации (в обработчиках событий ПередНачаломРаботыСистемы и ПриНачалеРаботыСистемы) 
// без дополнительных серверных вызовов. 
// Для получения значений этих параметров из клиентского кода
// см. СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиентаПриЗапуске.
//
// Важно: недопустимо использовать команды сброса кэша повторно используемых модулей, 
// иначе запуск может привести к непредсказуемым ошибкам и лишним серверным вызовам.
//
// Параметры:
//   Параметры - Структура - имена и значения параметров работы клиента при запуске, которые необходимо задать.
//                           Для установки параметров работы клиента при запуске:
//                           Параметры.Вставить(<ИмяПараметра>, <код получения значения параметра>);
//
Процедура ПриДобавленииПараметровРаботыКлиентаПриЗапуске(Параметры) Экспорт
	
	КлючПараметров = "ПоддержкаОтраслевыхРешений";
	
	// Инициализируем параметры подсистемы для клиента.
	ПараметрыПоддержки = Новый Структура();
	Параметры.Вставить(КлючПараметров, ПараметрыПоддержки);
	
	// Помещаем основные параметры сервера.
	ВыполнятьЗамеры = (НЕ ОбщегоНазначения.РазделениеВключено()) И ЦентрМониторинга.ЗаписыватьОперацииБизнесСтатистики();
	ПараметрыПоддержки.Вставить("ВыполнятьЗамеры", ВыполнятьЗамеры);
	ПараметрыПоддержки.Вставить("ПериодЗаписи",    1200);
	ПараметрыПоддержки.Вставить("КлючСеанса",      Новый УникальныйИдентификатор());
	
	// Получим идентификатор текущего пользователя
	ТекущийПользователь = Пользователи.АвторизованныйПользователь();
	ИдентификаторПользователяИБ = Строка(ТекущийПользователь.ИдентификаторПользователяИБ);
	ПараметрыПоддержки.Вставить("ИдентификаторПользователяИБ", ИдентификаторПользователяИБ);
	
	// Определим роль пользователя
	БизнесРольПользователя = пр_ПоддержкаОтраслевыхРешений.ИдентификаторБизнесРолиПользователя(ТекущийПользователь);
	ПараметрыПоддержки.Вставить("БизнесРольПользователя", БизнесРольПользователя);
	
	// Производим инициализацию параметров клиента.
	СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере(Ложь);
	
	// Поместим базовые параметры работы подсистемы в серверные параметры сеанса.
	УстановитьОтключениеБезопасногоРежима(Истина);
	УстановитьПривилегированныйРежим(Истина);
	ПараметрыКлиента = Новый Соответствие(ПараметрыСеанса.ПараметрыКлиентаНаСервере);
	ПараметрыКлиента.Вставить(КлючПараметров, Новый ФиксированнаяСтруктура(ПараметрыПоддержки));
	ПараметрыСеанса.ПараметрыКлиентаНаСервере = Новый ФиксированноеСоответствие(ПараметрыКлиента);
	УстановитьПривилегированныйРежим(Ложь);
	УстановитьОтключениеБезопасногоРежима(Ложь);
	
	// При запуске приложения необходимо произвести регистрацию некоторой бизнес статистики.
	Если ВыполнятьЗамеры Тогда
		
		// Запишем сведения о текущем сеансе.
		пр_ПоддержкаОтраслевыхРешений.ЗаписатьНомерСеансаРабочегоМеста();
		
		// Запишем все активные сеансы.
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне();
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Центр мониторинга.Периодическая запись накопленных замеров отраслевой бизнес-статистики'");
		ПараметрыВыполнения.ЗапуститьВФоне      = ИСТИНА;
		ПараметрыВыполнения.КлючФоновогоЗадания = ПараметрыПоддержки.КлючСеанса;
		
		ИмяОбработчика = "пр_ПоддержкаОтраслевыхРешений.ЗаписатьАктивностьРабочихМест";
		Результат = ДлительныеОперации.ВыполнитьВФоне(ИмяОбработчика, ИСТИНА, ПараметрыВыполнения);
		
	КонецЕсли;
	
КонецПроцедуры // ПриДобавленииПараметровРаботыКлиентаПриЗапуске()

// Вызывается из глобального обработчика ожидания по необходимости, но не чаще раза в 60 сек,
// для получения данных с клиента, а также возврате результата на клиент, если нужно.
//
// Параметры:
//  Параметры - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, полученного с клиента.
//    * Значение - Произвольный - значение параметра, полученного с клиента.
//  Результаты - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, возвращаемого на клиент.
//    * Значение - Произвольный - значение параметра, возвращаемого на клиент.
//
Процедура ПриПериодическомПолученииДанныхКлиентаНаСервере(Параметры=Неопределено, Результаты=Неопределено) Экспорт
	
	КлючПараметров = "ПоддержкаОтраслевыхРешений";
	
	// Производим обновление отраслевых параметров на основании данных сеанса.
	пр_ПоддержкаОтраслевыхРешений.ОбновитьПараметрыПоДаннымСеанса(ЛОЖЬ);
	
	// Проверим, наступило ли время периодической записи данных.
	ПараметрыПоддержки = Параметры.Получить(КлючПараметров);
	Если ПараметрыПоддержки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из анализа.
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	// Операции записи бизнес статистики проводим только если включен сбор.
	Если НЕ ПараметрыПоддержки.ВыполнятьЗамеры Тогда
		Возврат;
	КонецЕсли;
	
	// Вызываем обработчик записи собранных данных.
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне();
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Центр мониторинга.Периодическая запись накопленных замеров отраслевой бизнес-статистики'");
	ПараметрыВыполнения.ЗапуститьВФоне      = ИСТИНА;
	ПараметрыВыполнения.КлючФоновогоЗадания = ПараметрыПоддержки.КлючСеанса;
	
	ИмяОбработчика = "пр_ПоддержкаОтраслевыхРешений.ПриПериодическойЗаписиДанныхЗамеровСтатистики";
	Результат = ДлительныеОперации.ВыполнитьВФоне(ИмяОбработчика, ПараметрыПоддержки, ПараметрыВыполнения);
	
	// Возвращаем статус обработки занных замеров.
	Результаты.Вставить(КлючПараметров, Результат);
	
КонецПроцедуры // ПриПериодическомПолученииДанныхКлиентаНаСервере()

// Вызывается при установке блокировки работы с внешними ресурсами,
// при старте регламентного задания в копии информационной базы или интерактивно.
//
// Позволяет отключить произвольные механизмы, работа
// которых в копии информационной базы недопустима.
//
Процедура ПриЗапретеРаботыСВнешнимиРесурсами() Экспорт
	
	// Проверим наличие подсистемы в конфигурации
	Если НЕ ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РегламентныеЗадания") Тогда
		Возврат;
	КонецЕсли;
	МодульБлокировкаРаботыСВнешнимиРесурсами = ОбщегоНазначения.ОбщийМодуль("БлокировкаРаботыСВнешнимиРесурсами");
	
	// Обработаем только если администратором принято окончательное решение о блокировке.
	ПараметрыБлокировки = МодульБлокировкаРаботыСВнешнимиРесурсами.СохраненныеПараметрыБлокировки();
	Если НЕ ПараметрыБлокировки.РаботаСВнешнимиРесурсамиЗаблокирована=ИСТИНА Тогда
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.ПакетыДляОтправки.Очистить();
	
	ПараметрыЦентраМониторинга = Новый Структура();
	ПараметрыЦентраМониторинга.Вставить("ИдентификаторИнформационнойБазы", Новый УникальныйИдентификатор());
	ПараметрыЦентраМониторинга.Вставить("НомерКрайнегоПакета",             0);
	ПараметрыЦентраМониторинга.Вставить("ТестовыйПакетОтправлен",          ЛОЖЬ);
	ПараметрыЦентраМониторинга.Вставить("ОзнакомительныйПакетОтправлен",   ЛОЖЬ);
	
	ЦентрМониторингаСлужебный.УстановитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	
КонецПроцедуры // ПриЗапретеРаботыСВнешнимиРесурсами()

// Обработчик обновления настроек отправки статистики при переходе на новый релиз
//
Процедура ПриОбновленииИнформационнойБазы() Экспорт
	
	// Если включено разделение по областям данных, значит это база с особым обслуживанием, исключаем из рассмотрения
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	// Получим текущие настройки.
	ПараметрыЦентраМониторинга = Новый Структура();
	ПараметрыЦентраМониторинга.Вставить("ВключитьЦентрМониторинга");
	ПараметрыЦентраМониторинга.Вставить("ЦентрОбработкиИнформацииОПрограмме");
	ЦентрМониторингаСлужебный.ПолучитьПараметрыЦентраМониторингаВнешнийВызов(ПараметрыЦентраМониторинга);
	
	// Если подсистема отключена, то обновлять параметры нет необходимости.
	Если Не(ПараметрыЦентраМониторинга.ВключитьЦентрМониторинга ИЛИ ПараметрыЦентраМониторинга.ЦентрОбработкиИнформацииОПрограмме) Тогда
		ЦентрМониторингаСлужебный.УстановитьПараметрЦентраМониторингаВнешнийВызов("ТестовыйПакетОтправлен", ЛОЖЬ);
		Возврат;
	КонецЕсли;
	
	// Получим идентификатор информационной базы.
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено);
	ПараметрыПроцедуры = Новый Структура("Итератор,ОтправкаТестовогоПакета,ПолучениеИдентификатора", 0, Ложь, Истина);
	ЦентрМониторингаСлужебный.ОтправитьТестовыйПакет(ПараметрыПроцедуры, АдресРезультата);
	
КонецПроцедуры // ПриОбновленииИнформационнойБазы()

