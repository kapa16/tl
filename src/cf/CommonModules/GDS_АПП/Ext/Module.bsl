	|	GDS_СведенияОЧекЛисте.Комментарий КАК Комментарий,
	|	ВЫБОР
	|		КОГДА GDS_СведенияОЧекЛисте.Вложение = ЗНАЧЕНИЕ(Перечисление.GDS_ПризнакВложения.Присутствует)
	|			ТОГДА ""Да""
	|		ИНАЧЕ ""Нет""
	|	КОНЕЦ КАК Вложение
	|ПОМЕСТИТЬ ВТ_СведенияПроверки
	|ИЗ
	|	ВТ_ПунктыПроверки КАК ВТ_ПунктыПроверки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_СведенияОЧекЛисте КАК GDS_СведенияОЧекЛисте
	|		ПО (GDS_СведенияОЧекЛисте.Пункт = ВТ_ПунктыПроверки.Ссылка)
	|			И (GDS_СведенияОЧекЛисте.Идентификатор = ВТ_ПунктыПроверки.УИНСообщения)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Техника.Идентификатор КАК Идентификатор,
	|	ВТ_Техника.ГосНомер КАК ГосНомер,
	|	ВТ_Техника.Авто КАК Авто,
	|	ВТ_Техника.ВидМодели КАК ВидМодели,
	|	ВТ_Техника.МотоЧасыТО КАК МотоЧасыТО,
	|	ВТ_Техника.МотоЧасыФакт КАК МотоЧасыФакт,
	|	ВТ_Техника.Пробег КАК Пробег,
	|	ВТ_Техника.ОстатокТоплива КАК ОстатокТоплива,
	|	ВТ_Техника.ПУ КАК ПУ,
	|	ВТ_Техника.Флот КАК Флот,
	|	ВТ_Техника.Ответственный КАК Ответственный,
	|	ВТ_Техника.НомерПлатона КАК НомерПлатона,
	|	ВТ_Техника.Дата КАК Дата,
	|	ВТ_Техника.ДатаСервиса КАК ДатаСервиса,
	|	ВТ_Техника.Комментарий КАК Комментарий
	|ИЗ
	|	ВТ_Техника КАК ВТ_Техника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СведенияПроверки.УИНСообщения КАК УИНСообщения,
	|	ВТ_СведенияПроверки.Ссылка КАК Пункт,
	|	ВТ_СведенияПроверки.ВидМодели КАК ВидМодели,
	|	ВТ_СведенияПроверки.СостояниеПроверки КАК СостояниеПроверки,
	|	ВТ_СведенияПроверки.Комментарий КАК Комментарий,
	|	ВТ_СведенияПроверки.Вложение КАК Вложение
	|ИЗ
	|	ВТ_СведенияПроверки КАК ВТ_СведенияПроверки";
	
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	Запрос.УстановитьПараметр("ДатаАнализа", КонецДня(ТекущаяДата()));
	
	Результат = Запрос.ВыполнитьПакет(); 
	КоличествоЗапросов = Результат.Количество();

	ПервыйДокумент = Истина;
	
	ВыборкаТС = Результат[КоличествоЗапросов - 2].Выбрать();
	
	ТЗ_СведенияТехники = Результат[КоличествоЗапросов - 1].Выгрузить();
	
	Пока ВыборкаТС.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		// Запомним номер строки с которой начали выводить текущий документ
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если ВыборкаТС.ВидМодели = Перечисления.GDS_ВидМоделиТС.Автотранспорт Тогда
			
			ОбластьЗаголовок.Параметры.ID = ВыборкаТС.Идентификатор;
			
			ОбластьЗаголовок.Параметры.Дата				= ВыборкаТС.Дата;
			ОбластьЗаголовок.Параметры.ПУ				= ВыборкаТС.ПУ;
			ОбластьЗаголовок.Параметры.Флот				= ВыборкаТС.Флот;
			ОбластьЗаголовок.Параметры.Ответственный	= ВыборкаТС.Ответственный;
			
			ТабличныйДокумент.Вывести(ОбластьЗаголовок);
			
			ОбластьШапкаТС.Параметры.Авто				= ВыборкаТС.Авто;
			ОбластьШапкаТС.Параметры.ГосНомер			= ВыборкаТС.ГосНомер;
			ОбластьШапкаТС.Параметры.МотоЧасыТО			= ВыборкаТС.МотоЧасыТО;
			ОбластьШапкаТС.Параметры.МотоЧасыФакт		= ВыборкаТС.МотоЧасыФакт;
			ОбластьШапкаТС.Параметры.Пробег				= ВыборкаТС.Пробег;
			ОбластьШапкаТС.Параметры.ОстатокТоплива		= ВыборкаТС.ОстатокТоплива;
			
			Если ЗначениеЗаполнено(ВыборкаТС.НомерПлатона) Тогда
				ШаблонПлатон = СтрШаблон("Платон №: %1",ВыборкаТС.НомерПлатона);
				ОбластьШапкаТС.Параметры.Номер_Платона		= ШаблонПлатон;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьШапкаТС);
			ТабличныйДокумент.Вывести(ОбластьШапкаНеисправность);
			
			Отбор = Новый Структура("ВидМодели", ВыборкаТС.ВидМодели);
			МассивСтрок = ТЗ_СведенияТехники.НайтиСтроки(Отбор);
			
			Для Каждого Стр Из МассивСтрок Цикл
				ОбластьСтрокаНеисправность.Параметры.Пункт = Стр.Пункт;
				ОбластьСтрокаНеисправность.Параметры.Состояние = Стр.СостояниеПроверки;
				ОбластьСтрокаНеисправность.Параметры.Комментарий = Стр.Комментарий;
				ОбластьСтрокаНеисправность.Параметры.Вложение = Стр.Вложение;
				
				ТабличныйДокумент.Вывести(ОбластьСтрокаНеисправность);
			КонецЦикла;
			
			Если ЗначениеЗаполнено(ВыборкаТС.Комментарий) Тогда
				КомментарийШаблон = СтрШаблон("Комментарий: %1", ВыборкаТС.Комментарий);
				
				ОбластьПодвалТС.Параметры.Комментарий = КомментарийШаблон;
				ТабличныйДокумент.Вывести(ОбластьПодвалТС);
			КонецЕсли;
			
		ИначеЕсли ВыборкаТС.ВидМодели = Перечисления.GDS_ВидМоделиТС.Прицеп Тогда
			
			//ОбластьШапкаПрицеп.Параметры.Авто				= ВыборкаТС.Авто;
			ОбластьШапкаПрицеп.Параметры.ГосНомер			= ВыборкаТС.ГосНомер;
			ОбластьШапкаПрицеп.Параметры.МотоЧасыТО			= ВыборкаТС.МотоЧасыТО;
			ОбластьШапкаПрицеп.Параметры.МотоЧасыФакт		= ВыборкаТС.МотоЧасыФакт;
			ОбластьШапкаПрицеп.Параметры.Пробег				= ВыборкаТС.Пробег;
			ОбластьШапкаПрицеп.Параметры.ОстатокТоплива		= ВыборкаТС.ОстатокТоплива;
			
			ТабличныйДокумент.Вывести(ОбластьШапкаПрицеп);
			
			ТабличныйДокумент.Вывести(ОбластьШапкаНеисправность);
			
			Отбор = Новый Структура("ВидМодели", ВыборкаТС.ВидМодели);
			МассивСтрок = ТЗ_СведенияТехники.НайтиСтроки(Отбор);
			
			Для Каждого Стр Из МассивСтрок Цикл
				ОбластьСтрокаНеисправность.Параметры.Пункт = Стр.Пункт;
				ОбластьСтрокаНеисправность.Параметры.Состояние = Стр.СостояниеПроверки;
				ОбластьСтрокаНеисправность.Параметры.Комментарий = Стр.Комментарий;
				ОбластьСтрокаНеисправность.Параметры.Вложение = Стр.Вложение;
				
				ТабличныйДокумент.Вывести(ОбластьСтрокаНеисправность);
			КонецЦикла;
			
			Если ЗначениеЗаполнено(ВыборкаТС.Комментарий) Тогда
				КомментарийШаблон = СтрШаблон("Комментарий: %1", ВыборкаТС.Комментарий);
				
				ОбластьПодвалПрицеп.Параметры.Комментарий = КомментарийШаблон;
				ТабличныйДокумент.Вывести(ОбластьПодвалПрицеп);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ВернутьСведенияТехника(Идентификатор, ВидМодели)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.УИНСообщения КАК УИНСообщения,
		|	GDS_ПунктыПроверкиТС.Ссылка КАК Ссылка,
		|	GDS_ПунктыПроверкиТС.ВидМодели КАК ВидМодели
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		|	РегистрСведений.GDS_ОчередьСообщенийЧекЛист.СрезПоследних(&ДатаАнализа, ) КАК GDS_ОчередьСообщенийЧекЛистСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.GDS_ПунктыПроверкиТС КАК GDS_ПунктыПроверкиТС
		|		ПО (ИСТИНА)
		|ГДЕ
		|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.УИНСообщения = &Идентификатор
		|	И GDS_ПунктыПроверкиТС.ВидМодели = &ВидМодели
		|	И НЕ GDS_ПунктыПроверкиТС.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.УИНСообщения КАК УИНСообщения,
		|	ВременнаяТаблица.Ссылка КАК Пункт,
		|	ВременнаяТаблица.ВидМодели КАК ВидМодели,
		|	GDS_СведенияОЧекЛисте.СостояниеПроверки КАК СостояниеПроверки,
		|	GDS_СведенияОЧекЛисте.Комментарий КАК Комментарий,
		|	ВЫБОР
		|		КОГДА GDS_СведенияОЧекЛисте.Вложение = ЗНАЧЕНИЕ(Перечисление.GDS_ПризнакВложения.Присутствует)
		|			ТОГДА ""Да""
		|		ИНАЧЕ ""Нет""
		|	КОНЕЦ КАК Вложение
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_СведенияОЧекЛисте КАК GDS_СведенияОЧекЛисте
		|		ПО (GDS_СведенияОЧекЛисте.Пункт = ВременнаяТаблица.Ссылка)
		|			И (GDS_СведенияОЧекЛисте.Идентификатор = ВременнаяТаблица.УИНСообщения)";
	
	Запрос.УстановитьПараметр("ДатаАнализа", КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ВидМодели", ВидМодели);
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ВернутьСведенияПрицеп(Идентификатор, ВидМодели)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.УИНСообщения КАК УИНСообщения,
		|	GDS_ПунктыПроверкиТС.Ссылка КАК Ссылка,
		|	GDS_ПунктыПроверкиТС.ВидМодели КАК ВидМодели
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
