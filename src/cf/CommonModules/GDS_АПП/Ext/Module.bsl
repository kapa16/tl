
#Область РаботаРегламентныхЗаданий

Процедура GDS_ЗагрузкаДанныхИзСервисаАПП() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.GDS_ЗагрузкаДанныхИзСервисаАПП);
	
	НастройкиОбмена = НастройкиПодключения(Перечисления.GDS_МетодыАутентификации.OAuth2);
	
	Для каждого НастройкаКабинета из НастройкиОбмена цикл
		
		ИНН = СокрЛП(НастройкаКабинета.ИНН_Организации);
		
		GDS_КоннекторАПП.ОбработатьСообщения(ИНН);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура GDS_СозданиеАктовПриемаПередачи() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.GDS_СозданиеАктовПриемаПередачи);
	
	#Область АвторизацияДокументооборот
	
	Настройки = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ИспользоватьИнтеграцию();
	
	Если Не Настройки.ИспользоватьИнтеграциюДО2 И Не Настройки.ИспользоватьИнтеграциюДО3 Тогда
		УзелДокументооборота = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.УзелДокументооборота();
		ПланыОбмена.УдалитьРегистрациюИзменений(УзелДокументооборота);
		Возврат;
	КонецЕсли;
	
	// Прочтем настройки авторизации и установим их в параметры сеанса. Константы могут быть недоступны.
	УстановитьПривилегированныйРежим(Истина);
	ИмяПользователя = Константы.ИнтеграцияС1СДокументооборотИмяПользователяДляОбмена.Получить();
	Пароль = Константы.ИнтеграцияС1СДокументооборотПарольДляОбмена.Получить();
	Если Не ЗначениеЗаполнено(ИмяПользователя) Тогда // Прочтем настройки из пользовательского хранилища.
		
		ПарольСохранен = Ложь;
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ПрочитатьНастройкиАвторизацииИзХранилищаОбщихНастроек(
		ИмяПользователя,
		Пароль,
		ПарольСохранен);
		
		Если Не ЗначениеЗаполнено(ИмяПользователя) Тогда
			
			ЗаписьЖурналаРегистрации(
			ИнтеграцияС1СДокументооборотБазоваяФункциональность.ИмяСобытияЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,,
			НСтр("ru = 'Для пользователя регламентного задания обмена не указано имя пользователя 1С:Документооборота'",
			ОбщегоНазначения.КодОсновногоЯзыка()));
			
			Возврат;
			
		КонецЕсли;
		
		Если ПарольСохранен <> Истина Тогда
			
			ЗаписьЖурналаРегистрации(
			ИнтеграцияС1СДокументооборотБазоваяФункциональность.ИмяСобытияЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,,
			НСтр("ru = 'Для пользователя регламентного задания обмена не сохранен пароль 1С:Документооборота'",
			ОбщегоНазначения.КодОсновногоЯзыка()));
			
			Возврат;
			
		КонецЕсли;
		
		// Перенесем настройки в константы.
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СохранитьНастройкиАвторизацииДляОбмена(
		ИмяПользователя,
		Пароль);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УдалитьНастройкиАвторизацииИзХранилищаОбщихНастроек();
		
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьНастройкиАвторизацииВПараметрыСеанса(
	ИмяПользователя,
	Пароль,
	Ложь,
	Ложь);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.УстановитьВерсиюСервисаВПараметрыСеанса();
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	Если Прокси = Неопределено Тогда
		// Сервис не доступен.
		Возврат;
	КонецЕсли;
	
	Если Настройки.ИспользоватьИнтеграциюДО2 Тогда
		
		// Проверим поддержку синхронизации.
		Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("1.3.2.3.CORP") Тогда
			Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("") Тогда
				// Сервис доступен, но версия младше требуемой.
				УзелДокументооборота = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.УзелДокументооборота();
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелДокументооборота);
			КонецЕсли;
			Возврат;
		КонецЕсли;
		
		МодульИнтеграцияС1СДокументооборотОбмен = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборотОбмен");
		
	ИначеЕсли Настройки.ИспользоватьИнтеграциюДО3 Тогда
		
		МодульИнтеграцияС1СДокументооборот3Обмен = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборот3Обмен");
		
	КонецЕсли;
	
	#КонецОбласти
	
	ПодготовитьДанныеДляОтправки();
	ОтправитьДанные();
	
КонецПроцедуры

Процедура ПодготовитьДанныеДляОтправки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	GDS_ДанныеАПП.Идентификатор КАК Идентификатор,
	|	GDS_ДанныеАПП.Данные КАК Данные
	|ИЗ
	|	РегистрСведений.GDS_ДанныеАПП КАК GDS_ДанныеАПП
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_ДокументыАПП КАК GDS_ДокументыАПП
	|		ПО GDS_ДанныеАПП.Идентификатор = GDS_ДокументыАПП.Идентификатор
	|ГДЕ
	|	GDS_ДокументыАПП.Документ ЕСТЬ NULL";
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ИдентификаторСообщения = Выборка.Идентификатор;
		
		Попытка
			ДанныеАПП = Выборка.Данные.Получить();
			
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("Организация", Справочники.Организации.ОрганизацияПоУмолчанию());
			
			Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАПП.Подразделение.Ид));
			ДанныеЗаполнения.Вставить("Подразделение", Подразделение);
			
			ПУ = Справочники.уатКолонны.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАПП.ПУ.Ид));
			ДанныеЗаполнения.Вставить("ПУ", ПУ);
			ДанныеЗаполнения.Вставить("ДатаОсмотра", ДанныеАПП.ДатаОсмотра);//дата и время
			
			ТС = Справочники.уатТС.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАПП.ТС.Ид));
			ДанныеЗаполнения.Вставить("ТС", ТС);
			
			ДанныеЗаполнения.Вставить("Одометр", ДанныеАПП.ТС.МотоЧасыФакт);//одометр
			ДанныеЗаполнения.Вставить("ОдометрТО", ДанныеАПП.ТС.МотоЧасыТО);
			ДанныеЗаполнения.Вставить("ОстатокТоплива", ДанныеАПП.ТС.ОстатокТоплива);
			ДанныеЗаполнения.Вставить("Платон", ДанныеАПП.ТС.ПлатонНомер);
			ДанныеЗаполнения.Вставить("Пробег", ДанныеАПП.ТС.Пробег);
			ДанныеЗаполнения.Вставить("Замечания", ДанныеАПП.ТС.Комментарий);
			
			ДанныеЗаполнения.Вставить("Прицеп");
			ДанныеЗаполнения.Вставить("СтрокаПрицеп", ДанныеАПП.ПрицепОборудование.ГосНомер);
			ДанныеЗаполнения.Вставить("ОдометрПрицеп", ДанныеАПП.ПрицепОборудование.МотоЧасыФакт);
			ДанныеЗаполнения.Вставить("ОдометрПрицепТО", ДанныеАПП.ПрицепОборудование.МотоЧасыТО);
			ДанныеЗаполнения.Вставить("ПробегПрицеп", ДанныеАПП.ПрицепОборудование.Пробег);
			ДанныеЗаполнения.Вставить("ОстатокТопливаПрицеп", ДанныеАПП.ПрицепОборудование.ОстатокТоплива);
			ДанныеЗаполнения.Вставить("ПримечаниеКСостояниюПрицепа", ДанныеАПП.ПрицепОборудование.Комментарий);
			
			ДанныеЗаполнения.Вставить("Сдал");
			ДанныеЗаполнения.Вставить("Принял");
			ДанныеЗаполнения.Вставить("ОсмотрПровел");
			ДанныеЗаполнения.Вставить("СтрокаПринял", ДанныеАПП.Принял);
			
			Логин = ИмяСлужебногоПользователяАктыПриемаПередачи();
			СлужебныйПользователь = Пользователи.НайтиПоИмени(Логин);
			
			ДанныеЗаполнения.Вставить("Ответственный", СлужебныйПользователь);
			ДанныеЗаполнения.Вставить("Комментарий");
			
			//тч проверки - ответы
			ДанныеЗаполнения.Вставить("ЭлементыПроверки", ДанныеАПП.ЭлементыПроверки);
			
			ДокументАПП = Документы.GDS_АктПриемаПередачиТС.СоздатьДокумент();
			ДокументАПП.Заполнить(ДанныеЗаполнения);
			ДокументАПП.Записать(РежимЗаписиДокумента.Запись);
			
			МенеджерЗаписи = РегистрыСведений.GDS_ДокументыАПП.СоздатьМенеджерЗаписи();
			
			МенеджерЗаписи.Идентификатор = ИдентификаторСообщения;
			МенеджерЗаписи.Документ = ДокументАПП.Ссылка;
			
			МенеджерЗаписи.Записать();
			
			//++Временно
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	GDS_ФайлыАПП.Идентификатор КАК Идентификатор,
			|	GDS_ФайлыАПП.ИдентификаторФайла КАК ИдентификаторФайла,
			|	GDS_ФайлыАПП.ДатаФайла КАК ДатаФайла,
			|	GDS_ФайлыАПП.Имя КАК Имя,
			|	GDS_ФайлыАПП.Размер КАК Размер,
			|	GDS_ФайлыАПП.Расширение КАК Расширение,
			|	GDS_ФайлыАПП.ДвоичныеДанныеФайла КАК ДвоичныеДанныеФайла
			|ИЗ
			|	РегистрСведений.GDS_ФайлыАПП КАК GDS_ФайлыАПП
			|ГДЕ
			|	GDS_ФайлыАПП.Идентификатор = &Идентификатор";
			
			Запрос.УстановитьПараметр("Идентификатор", ИдентификаторСообщения);
			
			ПрисоединенныеФайлы = Запрос.Выполнить().Выгрузить();
			
			//ЗАПУСТИТЬ НА СОГЛАСОВАНИЕ В ДОКУМЕНТООБОРООТ
			ОтправитьДанныеВДокументооборот(ДокументАПП.Ссылка, ПрисоединенныеФайлы);
			
		Исключение
			
			ТекстСообщенияОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			
			ЗаписьЖурналаРегистрации(
				ИмяСобытияЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.РегистрыСведений.GDS_ДанныеАПП,
				Строка(ИдентификаторСообщения),
				ТекстСообщенияОбОшибке);
			
			МенеджерЗаписи = РегистрыСведений.GDS_ОчередьСообщенийАПП.СоздатьМенеджерЗаписи();
			//МенеджерЗаписи.ИнтегрированнаяСистема = Выборка.ИнтегрированнаяСистема;
			МенеджерЗаписи.МоментВремени = ТекущаяУниверсальнаяДатаВМиллисекундах();
			МенеджерЗаписи.Идентификатор = ИдентификаторСообщения;
			МенеджерЗаписи.Данные        = Выборка.Данные;
			МенеджерЗаписи.Прочитать();
			//МенеджерЗаписи.КоличествоПопытокОтправки = МенеджерЗаписи.КоличествоПопытокОтправки + 1;
			МенеджерЗаписи.ТекстСообщенияОбОшибке = ТекстСообщенияОбОшибке;
			МенеджерЗаписи.Записать();
			
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

