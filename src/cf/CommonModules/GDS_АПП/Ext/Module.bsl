Процедура GDS_СоздатьЗадачиПоЧекЛистам() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.GDS_СоздатьЗадачиПоЧекЛистам);
		
	ТЧ_Обработки = ПолучитьДанныеДляОбработки();
	
	Для Каждого СтрОбработки Из ТЧ_Обработки Цикл
		
		ДанныеЧекЛиста = СтрОбработки.ДанныеТС.Получить();
		
		ФайлыЧекЛистов = СтрОбработки.ДопДанные.Получить();
		
		СписокФайлов = Новый Массив;
	//	Если ФайлыЧекЛистов.Количество()>1 Тогда
			Для Каждого СтрФайл Из ФайлыЧекЛистов Цикл
				
				НазваниеФайла = СтрФайл.Получить("filename");
				НазваниеПроблемы = СтрФайл.Получить("hiddenFieldId");
				ДД_Файла = СтрФайл.Получить("DD_Files");
				
				Адрес = ПоместитьВоВременноеХранилище(ДД_Файла);
				
				ДобавитьФайлДляПрсоединения(СписокФайлов, НазваниеФайла, НазваниеПроблемы, Адрес, Справочники.РолиФайлов.НайтиПоНаименованию("Дополнительные"));
				
			КонецЦикла;
			
		ТабличныйДокумент = ПодготовитьПечатнуюФормуЧекЛиста(СтрОбработки.УИНСообщения);
		
		ИмяФайла = "ЧекЛист";
		
		ИмяВременнойПапки = ПолучитьИмяВременногоФайла();
		
		СоздатьКаталог(ИмяВременнойПапки);
		
		ИмяФайлаСРасширением = ИмяФайла + ".pdf";
		
		ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ИмяВременнойПапки) + ИмяФайлаСРасширением;
		
		ТабличныйДокумент.Записать(ПолноеИмяФайла, ТипФайлаТабличногоДокумента.PDF_A_1);

		ДвоичныеДанные = Новый ДвоичныеДанные(ПолноеИмяФайла);
		ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, Новый УникальныйИдентификатор);
		
		ДобавитьФайлДляПрсоединения(СписокФайлов, ИмяФайлаСРасширением, ИмяФайла, ПутьВоВременномХранилище, Справочники.РолиФайлов.НайтиПоНаименованию("Основной"));
		
		УдалитьФайлы(ИмяВременнойПапки);
		
	//	КонецЕсли;
	
	ДанныеПроблем = ПодготовитьДанныеОПроблемах(СтрОбработки.УИНСообщения);
	
	СоздатьДокументПоЧекЛисту(СтрОбработки, СписокФайлов, ДанныеПроблем);
		
	КонецЦикла;
	
КонецПроцедуры

