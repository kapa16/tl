Функция РазборЧерезРегулярноеВыражение(СтрокаПоиска)
	
	НеисправностиТехники = Новый ТаблицаЗначений;
	НеисправностиТехники.Колонки.Добавить("Неисправность");
	НеисправностиТехники.Колонки.Добавить("ПричиныНеисправности");
	НеисправностиТехники.Колонки.Добавить("Ответственный");
	
	НеисправностиКомментарий = Новый ТаблицаЗначений;
	
	НеисправностиКомментарий.Колонки.Добавить("Наименование");
	НеисправностиКомментарий.Колонки.Добавить("Комментарий");
	
	СтрокаРегулярноеВыражение = """([^""]*?) \{радиокнопка\}""\s*:\s*""Неисправно""";;
	СтрокаРегулярноеВыражениеv2 = "([^""]*?) \{комментарий\}""\s*:\s*""([^""]*)";;
	
	МассивНеисправно = СтрНайтиВсеПоРегулярномуВыражению(СтрокаПоиска, СтрокаРегулярноеВыражение,,Истина);
	Для Каждого СтрМ Из МассивНеисправно Цикл
		ГруппаМ = СтрМ.ПолучитьГруппы();
		
		НоваяСтрока = НеисправностиТехники.Добавить();
		НоваяСтрока.Неисправность = ГруппаМ[0].Значение;
	КонецЦикла;
	
	МассивКомментарий = СтрНайтиВсеПоРегулярномуВыражению(СтрокаПоиска, СтрокаРегулярноеВыражениеv2,,Истина);
	Для Каждого СтрМ Из МассивКомментарий Цикл
		ГруппаМ = СтрМ.ПолучитьГруппы();
		
		НоваяСтрока = НеисправностиКомментарий.Добавить();
		НоваяСтрока.Наименование = ГруппаМ[0].Значение;
		НоваяСтрока.Комментарий  = ГруппаМ[1].Значение
	КонецЦикла;
	
	Для Каждого СтрНеисправности Из НеисправностиТехники Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("Наименование",СтрНеисправности.Неисправность);
		
		МассивСтрок = НеисправностиКомментарий.НайтиСтроки(Отбор);
		Если МассивСтрок.Количество() = 1 Тогда
			ИндексСтроки = НеисправностиТехники.Индекс(СтрНеисправности);
			СтрокаТЧ = НеисправностиТехники.Получить(ИндексСтроки);
			
			СтрокаТЧ.ПричиныНеисправности = МассивСтрок[0].Комментарий;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НеисправностиТехники;
	
//ТЧ_Параметры = Новый ТаблицаЗначений;
	//ТЧ_Параметры.Колонки.Добавить("НаименованиеПроблемы");
	//ТЧ_Параметры.Колонки.Добавить("Значение");
	//ТЧ_Параметры.Колонки.Добавить("Комментарий");
	
КонецФункции

Функция СоздатьДокументПредприятия(ДанныеЧекЛиста, ОписаниеПроблем)
	
	ВнДок					= Справочники.ДокументыПредприятия.СоздатьЭлемент();
	
	//ШаблонДокумента = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ШаблонДокумента", Справочники.ШаблоныДокументов.ПустаяСсылка());
	
	ВнДок.Шаблон			= Справочники.ШаблоныДокументов.НайтиПоНаименованию("Чек лист ТС");
	ВнДок.ВидДокумента		= Справочники.ВидыДокументов.НайтиПоНаименованию("Чек лист ТС");
//	ВнДок.Тематика			= Тематика;

    МассивОписание = СтрРазделить(ДанныеЧекЛиста.Описание,"/");
	
	ДанныеТС = ДанныеЧекЛиста.ДанныеТС.Получить();
	
	СтруктураТС = ДанныеТС.Получить("СтруктураТС");
	
	ДатаСервиса	= СтруктураТС.ДатаСервиса;
	ПУ			= СтруктураТС.ПУ;
	Флот		= СтруктураТС.Флот;
	ГосНомер	= СтруктураТС.ГосНомер;
	
	ШаблонСодержания = СтрШаблон("Авто: %1 Пользователь: %2", СтруктураТС.Авто+Символы.ПС, СтруктураТС.Ответственный);

	
	Содержание = ШаблонСодержания
	+Символы.ПС
	+Символы.ПС
	+ОписаниеПроблем;
	
	Наименование  = МассивОписание[1];
	//Ответственный = "";
	Подготовил    = Справочники.Сотрудники.НайтиПоНаименованию("WebServices");
	Подразделение = Справочники.СтруктураПредприятия.НайтиПоКоду("00-000899");//...Системное подразделение
	Организация   = Справочники.Организации.НайтиПоРеквизиту("ИНН",ДанныеЧекЛиста.ИНН);
	
	ТекущийПользователь = Подготовил;
	
	ВнДок.Заголовок			= Наименование;  
	ВнДок.Наименование 		= Наименование;
	
	Если ЗначениеЗаполнено(Содержание) Тогда
		ВнДок.Содержание = Содержание;
	КонецЕсли; 
	
	//ВнДок.Ответственный			= Ответственный;
	ВнДок.Подготовил			= Подготовил;
	ВнДок.Подразделение			= Подразделение;
	
	ВнДок.ДатаСоздания			= ТекущаяДатаСеанса();
	//ВнДок.Комментарий			= Комментарий;
	
	ВнДок.Организация			= Организация;
	
	ВнДок.РегистрационныйНомер	= "";
	ВнДок.ЧисловойНомер			= 0;
	ВнДок.ДатаРегистрации		= '00010101';
	
	ВнДок.Создал				= Подготовил;
	
	ВнДок.Зарегистрировал		= Справочники.Сотрудники.ПустаяСсылка();		
	ВнДок.КоличествоЭкземпляров	= 1;
	ВнДок.КоличествоЛистов		= 1;
	ВнДок.КоличествоПриложений	= 0;
	ВнДок.ЛистовВПриложениях	= 0;
	ВнДок.Дело					= Справочники.ДелаХраненияДокументов.ПустаяСсылка();
	ВнДок.СрокИсполнения		= '00010101';
	
	//ВнДок.Проект			= РаботаСПроектами.ПолучитьПроектПоУмолчанию();
	ВнДок.ФормаДокумента	= Перечисления.ВариантыФормДокументов.Электронная;
	ВнДок.Записать();
	
	//Получить дополнительные реквизиты
	ДопРеквизиты = УправлениеСвойствами.СвойстваОбъекта(ВнДок.Ссылка, Истина);
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Свойство", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения"));
	ТЗ.Колонки.Добавить("Значение");
	
	Если ДопРеквизиты.Количество() > 0 Тогда
		Для Каждого СтрДоп Из ДопРеквизиты Цикл			
			Если СтрДоп.Наименование = "Дата" Тогда	
				НовСтр = ТЗ.Добавить();
				НовСтр.Свойство = СтрДоп;
				НовСтр.Значение = ДатаСервиса;	
			ИначеЕсли СтрДоп.Наименование = "ПУ" Тогда	
				НовСтр = ТЗ.Добавить();
				НовСтр.Свойство = СтрДоп;
				НовСтр.Значение = ПУ;
			ИначеЕсли СтрДоп.Наименование = "Флот" Тогда	
				НовСтр = ТЗ.Добавить();
				НовСтр.Свойство = СтрДоп;
				НовСтр.Значение = Флот;
			ИначеЕсли СтрДоп.Наименование = "ГосНомер" Тогда	
				НовСтр = ТЗ.Добавить();
				НовСтр.Свойство = СтрДоп;
				НовСтр.Значение = ГосНомер;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
		
	УправлениеСвойствами.ЗаписатьСвойстваУОбъекта(ВнДок.Ссылка,ТЗ);
	
	//Состояние документа проект
	//Делопроизводство.ЗаписатьСостояниеДокумента(ВнДок.Ссылка, ТекущаяДатаСеанса(), Перечисления.СостоянияДокументов.Проект, ТекущийПользователь);
	
	Возврат ВнДок.Ссылка;
КонецФункции

Функция ПодготовитьДанныеОПроблемах(Идентификатор)

	МассивИтог = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	GDS_СведенияОЧекЛисте.Пункт КАК Пункт,
		|	GDS_СведенияОЧекЛисте.ВидМодели КАК ВидМодели,
		|	GDS_СведенияОЧекЛисте.СостояниеПроверки КАК СостояниеПроверки,
		|	GDS_СведенияОЧекЛисте.Комментарий КАК Комментарий
		|ИЗ
		|	РегистрСведений.GDS_СведенияОЧекЛисте КАК GDS_СведенияОЧекЛисте
		|ГДЕ
		|	GDS_СведенияОЧекЛисте.Идентификатор = &Идентификатор
		|	И (GDS_СведенияОЧекЛисте.СостояниеПроверки = ЗНАЧЕНИЕ(Перечисление.GDS_СостояниеПроверки.Неисправно)
		|			ИЛИ GDS_СведенияОЧекЛисте.СостояниеПроверки = ЗНАЧЕНИЕ(Перечисление.GDS_СостояниеПроверки.Отсутствует)
		|			ИЛИ GDS_СведенияОЧекЛисте.Комментарий <> """")
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидМодели
		|ИТОГИ ПО
		|	ВидМодели
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаВидМодели = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВидМодели.Следующий() Цикл
		ИтоговыйФормат = "";
		
		НаименованиеПроблемы = Строка(ВыборкаВидМодели.ВидМодели);
		
		ВыборкаДетальныеЗаписи = ВыборкаВидМодели.Выбрать();

		МассивПроблем = Новый Массив;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ШаблонПроблем = СтрШаблон("%1:%2 - %3",ВыборкаДетальныеЗаписи.Пункт, ВыборкаДетальныеЗаписи.СостояниеПроверки, ВыборкаДетальныеЗаписи.Комментарий);
			
			МассивПроблем.Добавить(ШаблонПроблем);
		КонецЦикла;
		
		ОписаниеПроблем = СтрСоединить(МассивПроблем, Символы.ПС);
		
		ИтоговыйФормат = СтрШаблон("%1: %2", НаименованиеПроблемы,Символы.ПС+ОписаниеПроблем);
		
		МассивИтог.Добавить(ИтоговыйФормат);
		
	КонецЦикла;
	
	СтрокаИтог = СтрСоединить(МассивИтог, Символы.ПС+Символы.ПС);
	
	Возврат СтрокаИтог;
	//МассивПроблем = ОбщегоНазначения.ТаблицаЗначенийВМассив();
	
КонецФункции

Функция ПолучитьДанныеДляОбработки()
	
	Запрос = Новый Запрос; 
	
	Запрос.УстановитьПараметр("ДатаАнализа", КонецДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("Статус", Перечисления.ЛК_СтатусСообщения.Ожидает);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.ИНН КАК ИНН,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.ИсточникСообщения КАК ИсточникСообщения,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.Описание КАК Описание,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.Статус КАК Статус,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.Сообщение КАК Сообщение,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.УИНСообщения КАК УИНСообщения,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.ДанныеТС КАК ДанныеТС,
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.ДопДанные КАК ДопДанные
	|ИЗ
	|	РегистрСведений.GDS_ОчередьСообщенийЧекЛист.СрезПоследних(&ДатаАнализа, ) КАК GDS_ОчередьСообщенийЧекЛистСрезПоследних
	|ГДЕ
	|	GDS_ОчередьСообщенийЧекЛистСрезПоследних.Статус = &Статус"; 
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ДобавитьФайлДляПрсоединения(СписокФайлов, ПолноеИмя, НазваниеФайла, Адрес, РольФайла)
	ПараметрыДобавления = Новый Структура;
	
	Если РольФайла = Справочники.РолиФайлов.НайтиПоНаименованию("Дополнительные") Тогда
		Если СтрНайти(НазваниеФайла, "вложение")>0 Тогда
		Иначе
			НазваниеФайла = "Фото сотрудника";
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыДобавления.Вставить("НазваниеФайла", НазваниеФайла);
	ПараметрыДобавления.Вставить("Расширение", ПолучитьРасширениеИмениФайла(ПолноеИмя));
	ПараметрыДобавления.Вставить("Размер", );
	ПараметрыДобавления.Вставить("АдресХранилищаФайла", Адрес);
	ПараметрыДобавления.Вставить("РольФайла", РольФайла);
	
	СписокФайлов.Добавить(ПараметрыДобавления);
КонецПроцедуры

Функция ПолучитьРасширениеИмениФайла(Знач ИмяФайла) Экспорт
	
	РасширениеФайла = "";
	МассивСтрок = СтрРазделить(ИмяФайла, ".", Ложь);
