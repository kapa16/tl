Функция ИмяСлужебногоПользователяАктыПриемаПередачи()
	
	Возврат "WebServices";
	
КонецФункции

Функция ИмяСобытияЖурналаРегистрации()
	
	Возврат НСтр("ru = 'Подготовка данных акта-приема передачи'",
		ОбщегоНазначения.КодОсновногоЯзыка());
	
КонецФункции

Процедура ОтправитьДанныеВДокументооборот(ПриложениеСсылка, ПрисоединенныеФайлы)
	
	Попытка
		
		Правила = ИнтеграцияС1СДокументооборот3ВызовСервера.ПодходящиеПравилаИнтеграцииОбъекта(ПриложениеСсылка); 
		Правило = Правила[0];
		
		РезультатСоздать = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ДанныеОбъектаДОПоВнешнемуОбъекту(ПриложениеСсылка);
		
		Если РезультатСоздать = Неопределено Тогда
			РезультатСоздать = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СоздатьОбъектДОПоПравилу(ПриложениеСсылка, Правило);
		КонецЕсли;
		
		РольФайла = "a9bf92f1-4fd8-11ef-b84c-00155d002503";//Дополнительный УИН из Документооборота
		
		Если ПрисоединенныеФайлы.Количество() > 0 Тогда
			Для каждого Стр Из ПрисоединенныеФайлы Цикл
				Наименование       = Стр.Имя;
				Расширение         = Стр.Расширение;

				ДвоичныеДанныеФайла = Стр.ДвоичныеДанныеФайла.Получить();//РаботаСФайлами.ДвоичныеДанныеФайла(ПрисоединенныйФайл);
				
				АдресДвоичныеДанныеФайла = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла);
				
				СтруктураДанныхФайла = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеФайла(Наименование, РезультатСоздать.id, РезультатСоздать.type, Расширение, РольФайла);
				СтруктураДанныхФайла.Размер = ДвоичныеДанныеФайла.Размер();

				ПараметрыСоздания = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.НовыеПараметрыСозданияФайла(СтруктураДанныхФайла);
				ПараметрыСоздания.АдресВременногоХранилищаФайла = АдресДвоичныеДанныеФайла;
				
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.СоздатьФайлВДокументообороте(ПараметрыСоздания,РезультатСоздать.id,РезультатСоздать.type,РезультатСоздать.name);
			КонецЦикла;
			
		КонецЕсли;
		
		ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьОбновитьДанныеСвязанныхОбъектов();
		
		ТекстОшибки = "";
		
		РезультатЗапуска = ИнтеграцияС1СДокументооборот3ВызовСервера.НачатьОбработку(РезультатСоздать,ТекстОшибки);
		
	Исключение
		РезультатЗапускаПроцесса = Ложь;
	КонецПопытки;
	
КонецПроцедуры

Функция НастройкиПодключения(МетодАутентификации)
	
	Запрос = Новый Запрос; 
	
	Запрос.УстановитьПараметр("МетодАутентификации", МетодАутентификации);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	GDS_НастройкиПодключенияАПП.ИНН_Организации КАК ИНН_Организации,
