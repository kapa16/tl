		КонецЕсли;
		Пункт4_1 = ПунктПодачи;
		Пункт4_2 = ДатаПодачи;
		Пункт6_1 = ПунктВыгрузки;
		Пункт6_2 = ДатаВыгрузки;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Область2_6"); 
