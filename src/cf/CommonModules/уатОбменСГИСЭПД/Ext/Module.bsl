				НомерСтроки = НомерСтроки + 1;
			КонецЦикла;
		Иначе
			ПунктПодачи   = ВыборкаТекущийДокумент.АдресОтправления;
			ДатаПодачи    = ВыборкаТекущийДокумент.ОтправлениеС;
			ПунктВыгрузки = ВыборкаТекущийДокумент.АдресНазначения;
