	Выборка = Запрос.Выполнить().Выгрузить();
	
	ПервыйДокумент = Истина;
	Для Каждого ВыборкаТекущийДокумент Из Выборка Цикл 
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли; 
		
		ПервыйДокумент = Ложь; 
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_уатЗаказГрузоотправителя_ЗаказЗаявка";
		Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_уатЗаказЗаявка");
		
		ТекстЗаголовка = "";
		Пункт1         = ""; 
		Пункт2         = "";
		Пункт2_1       = "";
		Пункт3         = "";
		Пункт3_1       = "";
		Пункт3_2       = "";
		Пункт4_1       = "";
		Пункт4_2       = "";
		Пункт6_1       = "";
		Пункт6_2       = "";
		
		ТекстЗаголовка = ?(ВыборкаТекущийДокумент.ТипДокументаЗаказЗаявка = "2", "Заявка", "Заказ");
		Пункт1         = уатОбщегоНазначенияТиповые.уатСформироватьЗаголовокДокумента(ВыборкаТекущийДокумент.Заказ, ""); // Заголовок заказа
		Пункт2         = уатОбщегоНазначенияТиповыеСервер.ОписаниеОрганизации(
			уатОбщегоНазначенияСервер.СведенияОЮрФизЛице(ВыборкаТекущийДокумент.Грузоотправитель, ВыборкаТекущийДокумент.Дата), // Грузоотправитель
			"ПолноеНаименование,ЮридическийАдрес,Телефоны,ИНН");
		// Лицо уполномоченное грузоотправителем на заполнение и подписание заказа (заявки)
		Если ТипЗнч(ВыборкаТекущийДокумент.УЛГрузоотправителя) = Тип("СправочникСсылка.Пользователи") Тогда  
			СведенияОФизЛице = СведенияОФизЛице(ВыборкаТекущийДокумент.УЛГрузоотправителя, ВыборкаТекущийДокумент.Дата);
			Пункт2_1 = СведенияОФизЛице.ФИО;
			Если ЗначениеЗаполнено(СведенияОФизЛице.ЮридическийАдрес) Тогда
				Пункт2_1 = Пункт2_1 + ", " + СведенияОФизЛице.ЮридическийАдрес;
			КонецЕсли;
			Если ЗначениеЗаполнено(СведенияОФизЛице.Телефоны) Тогда
				Телефоны  = НСтр("en='tel:';ru='тел.:'") + " " + СведенияОФизЛице.Телефоны;
				Пункт2_1 = Пункт2_1 + ", " + Телефоны;
			КонецЕсли;
			Если ЗначениеЗаполнено(СведенияОФизЛице.ИНН) Тогда
				ДанныеИНН  = НСтр("en='TIN';ru='ИНН'") + " " + СведенияОФизЛице.ИНН;
				Пункт2_1 = Пункт2_1 + ", " + ДанныеИНН;
			КонецЕсли;
		Иначе
			Пункт2_1 = уатОбщегоНазначенияТиповыеСервер.ОписаниеОрганизации(
			уатОбщегоНазначенияСервер.СведенияОЮрФизЛице(ВыборкаТекущийДокумент.УЛГрузоотправителя, ВыборкаТекущийДокумент.Дата),
			"ПолноеНаименование,ЮридическийАдрес,Телефоны,ИНН");
		КонецЕсли;
		Пункт3 = уатОбщегоНазначенияТиповыеСервер.ОписаниеОрганизации(
			уатОбщегоНазначенияСервер.СведенияОЮрФизЛице(ВыборкаТекущийДокумент.Перевозчик, ВыборкаТекущийДокумент.Дата), // Перевозчик
			"ПолноеНаименование,ЮридическийАдрес,Телефоны,ИНН"); 
		// Ответственный за организацию перевозки со стороны перевозчика	
		СведенияОФизЛице = СведенияОФизЛице(ВыборкаТекущийДокумент.УЛПеревозчика, ВыборкаТекущийДокумент.Дата);
		Пункт3_1 = СведенияОФизЛице.ФИО;
