		ОбластьМакета.Параметры.Пункт2         = Пункт2;
		ОбластьМакета.Параметры.Пункт2_1       = Пункт2_1;
		ОбластьМакета.Параметры.Пункт3         = Пункт3;
		ОбластьМакета.Параметры.Пункт3_1       = Пункт3_1;
		ОбластьМакета.Параметры.Пункт3_2       = Пункт3_2;
		ОбластьМакета.Параметры.Пункт4_1       = Пункт4_1;
		ОбластьМакета.Параметры.Пункт4_2       = Пункт4_2;
		ОбластьМакета.Параметры.Пункт6_1       = Пункт6_1;
		ОбластьМакета.Параметры.Пункт6_2       = Пункт6_2;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Область5");
		ТабличныйДокумент.Вывести(ОбластьМакета); 
		
		Если ВыборкаТекущийДокумент.FTL Тогда
			ОбластьСтрокиПП = Макет.ПолучитьОбласть("Область5_Строки");
			
			НомерСтроки   = 1;
			НомерСтрокиПП = 1;
			флЕстьПунктПогрузки = Ложь;
			Для Каждого ТекПункт Из ВыборкаТекущийДокумент.ПромежуточныеПункты Цикл
				Если (ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка
					И НЕ флЕстьПунктПогрузки)
					ИЛИ (ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Разгрузка
					И НомерСтроки = ПунктВыгрузкиНомерСтроки) Тогда
					флЕстьПунктПогрузки = Истина;
					НомерСтроки         = НомерСтроки + 1;
					Продолжить;
				КонецЕсли; 
				ОбластьСтрокиПП.Параметры.Пункт5_1 = НомерСтрокиПП;
				ОбластьСтрокиПП.Параметры.Пункт5_2 = ТекПункт.Пункт;
				ОбластьСтрокиПП.Параметры.Пункт5_3 = ТекПункт.ПрибытиеПлан;
				ОбластьСтрокиПП.Параметры.Пункт5_4 = ТекПункт.ОтправительПолучатель;
				ОбластьСтрокиПП.Параметры.Пункт5_5 = ТекПункт.ТипТочкиМаршрута;

				ТабличныйДокумент.Вывести(ОбластьСтрокиПП);
				НомерСтроки   = НомерСтроки + 1;
				НомерСтрокиПП = НомерСтрокиПП + 1;
			КонецЦикла;
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("Область5_Строки");
			ТабличныйДокумент.Вывести(ОбластьМакета);
		КонецЕсли; 
		
		Если Константы.уатЕдиницаИзмеренияВеса.Получить() = Перечисления.уатЕдиницыИзмеренияВеса.Килограмм Тогда 
			КоэфВеса = 1;
		Иначе 
			КоэфВеса = 1000;
		КонецЕсли;
		
		Если Константы.уатЕдиницаИзмеренияОбъема.Получить() = Перечисления.уатЕдиницыИзмеренияОбъема.Литр Тогда 
			КоэфОбъема = 1000;
		Иначе 
			КоэфОбъема = 1;
		КонецЕсли;
		ВесБрутто = ВыборкаТекущийДокумент.ВесБрутто * КоэфВеса;
		Объем     = ВыборкаТекущийДокумент.Объем / КоэфОбъема;
		СтрокаГабаритов = ?(ЗначениеЗаполнено(ВесБрутто), Строка(ВесБрутто) + " кг", "");
		Если ЗначениеЗаполнено(Объем) Тогда
			СтрокаГабаритов = ?(ЗначениеЗаполнено(СтрокаГабаритов), СтрокаГабаритов + ", ", "") + Строка(Объем) + " м3"; 
		КонецЕсли;
		Пункт9  = "";
		Пункт11 = "";
		Пункт14 = "";
		Пункт15 = "";
		
		ТребованиякТС = "";
		Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТребованиеКТС) Тогда
			ТребованиякТС = ВыборкаТекущийДокумент.ТребованиеКТС;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТребованиеКТСТипТС) Тогда
			ТребованиякТС = ?(ЗначениеЗаполнено(ТребованиякТС), ТребованиякТС + ", ", "") + ВыборкаТекущийДокумент.ТребованиеКТСТипТС;
		КонецЕсли; 
		ТипВладенияТС          = "";
		ГосНомерТС             = ""; 
		СтрокаХарактеристикиТС = "";
		Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТС) Тогда
			ТипВладенияТС = ВыборкаТекущийДокумент.ТСТипВладенияТС; 
			Если ТипВладенияТС = Перечисления.уатТипыВладенияТС.Собственность Тогда
				ТипВладенияТС = 1;
			ИначеЕсли ТипВладенияТС = Перечисления.уатТипыВладенияТС.Аренда Тогда
				ТипВладенияТС = 2;
			ИначеЕсли ТипВладенияТС = Перечисления.уатТипыВладенияТС.Лизинг Тогда
				ТипВладенияТС = 3;
			Иначе
				ТипВладенияТС = "";
			КонецЕсли;
			ГосНомерТС = ВыборкаТекущийДокумент.ТСГосударственныйНомер; 
			МодельТС   = ВыборкаТекущийДокумент.ТСМодель;
			СтрокаХарактеристикиТС = "Модель " + Строка(МодельТС); 
			Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСТип) Тогда
				СтрокаХарактеристикиТС = СтрокаХарактеристикиТС + ", тип " + ВыборкаТекущийДокумент.ТСТип;
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСМарка) Тогда
				СтрокаХарактеристикиТС = СтрокаХарактеристикиТС + ", марка " + ВыборкаТекущийДокумент.ТСМарка;
			КонецЕсли; 
			Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСГрузоподъемность)
				ИЛИ ЗначениеЗаполнено(ВыборкаТекущийДокумент.МодельТСГрузоподъемность) Тогда
				Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСГрузоподъемность) Тогда
					Грузоподъемность = "грузоподъемность" + " " + ВыборкаТекущийДокумент.ТСГрузоподъемность + " т";
				Иначе
					Грузоподъемность = "грузоподъемность" + " " + ВыборкаТекущийДокумент.МодельТСГрузоподъемность + " т";
				КонецЕсли;
				СтрокаХарактеристикиТС = СтрокаХарактеристикиТС + ", " + Грузоподъемность;
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСОбъемКузова)
				ИЛИ ЗначениеЗаполнено(ВыборкаТекущийДокумент.МодельТСОбъемКузова) Тогда
				Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.ТСОбъемКузова) Тогда
					ОбъемКузова = "вместимость" + " " + ВыборкаТекущийДокумент.ТСОбъемКузова + " м3";
				Иначе
					ОбъемКузова = "вместимость" + " " + ВыборкаТекущийДокумент.МодельТСОбъемКузова + " м3";
				КонецЕсли;
				СтрокаХарактеристикиТС = СтрокаХарактеристикиТС + ", " + ОбъемКузова;
			КонецЕсли;
		КонецЕсли;
		КонтактноеЛицоЗаказчика = "";
		Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика) Тогда
			Если ТипЗнч(ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика) = Тип("Строка") Тогда
				КонтактноеЛицоЗаказчика = ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика;
			Иначе
				КонтактноеЛицоЗаказчика = ?(ЗначениеЗаполнено(ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика.Должность),
				ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика.Должность + ", ", "") +
				уатОбщегоНазначенияТиповые.уатФамилияИнициалыФизЛица(, 
				ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика.Фамилия,
				ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика.Имя,
				ВыборкаТекущийДокумент.КонтактноеЛицоЗаказчика.Отчество);
			КонецЕсли
		КонецЕсли;
		КонтактноеЛицоПеревозчика = "";
        Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.УЛПеревозчика) Тогда
			КонтактноеЛицоПеревозчика =
				уатОбщегоНазначенияТиповые.уатФамилияИнициалыФизЛица(ВыборкаТекущийДокумент.УЛПеревозчика.ФизическоеЛицо);
		КонецЕсли;
		
		мВалютаУпрУчета = Константы.ВалютаУправленческогоУчета.Получить();
		СтоимостьУслугПеревозки = ПолучитьСтоимостьПеревозкиЗаказЗаявка(ВыборкаТекущийДокумент.Заказ, ВыборкаТекущийДокумент.Рейс, ТипПФ);
		Если ВыборкаТекущийДокумент.ВалютаДокумента = мВалютаУпрУчета Тогда
			СтоимостьУслугПеревозкиПредставление = СтоимостьУслугПеревозки;
		Иначе 
			Если ЗначениеЗаполнено(ВыборкаТекущийДокумент.Рейс) Тогда
				ТекВалютаДокумента = ВыборкаТекущийДокумент.ВалютаДокументаРейс;
				ТекДатаКурса       = ВыборкаТекущийДокумент.ДатаРейса;
			Иначе
				ТекВалютаДокумента = ВыборкаТекущийДокумент.ВалютаДокумента;
				ТекДатаКурса       = ВыборкаТекущийДокумент.Дата;
			КонецЕсли;
			СтоимостьУслугПеревозкиПредставление = уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(СтоимостьУслугПеревозки,
				мВалютаУпрУчета, ТекВалютаДокумента,
				ТекДатаКурса, ТекДатаКурса,,,,
				Новый Структура("Документ, БазоваяВалюта, ДатаКурса", ВыборкаТекущийДокумент.Заказ, ТекВалютаДокумента, ТекДатаКурса)); 	 
		КонецЕсли;
			
		ОбластьМакета = Макет.ПолучитьОбласть("Область7_18");
		ОбластьМакета.Параметры.Пункт7    = ВыборкаТекущийДокумент.ОписаниеГруза;
		ОбластьМакета.Параметры.Пункт8_1  = ?(ЗначениеЗаполнено(ВыборкаТекущийДокумент.КоличествоМест), Строка(ВыборкаТекущийДокумент.КоличествоМест) + " упак.", "");
		ОбластьМакета.Параметры.Пункт8_2  = СтрокаГабаритов;
		ОбластьМакета.Параметры.Пункт9    = Пункт9;
		ОбластьМакета.Параметры.Пункт10   = ТребованиякТС;
		ОбластьМакета.Параметры.Пункт10_1 = СтрокаХарактеристикиТС;
		ОбластьМакета.Параметры.Пункт10_2 = ГосНомерТС;
		ОбластьМакета.Параметры.Пункт10_3 = ТипВладенияТС;
		ОбластьМакета.Параметры.Пункт11   = Пункт11;
		ОбластьМакета.Параметры.Пункт14   = Пункт14;
		ОбластьМакета.Параметры.Пункт15   = Пункт15;
		ОбластьМакета.Параметры.Пункт16   = СтоимостьУслугПеревозкиПредставление;
		ОбластьМакета.Параметры.Пункт17   = КонтактноеЛицоЗаказчика;
		ОбластьМакета.Параметры.Пункт18   = КонтактноеЛицоПеревозчика;
		ТабличныйДокумент.Вывести(ОбластьМакета);

	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#Область ПрограммныйИнтерфейсЭТН

Процедура ДобавитьДокументОснование(ЭПЛ, ДокументОснованиеСсылка) Экспорт
	
	Если ТипЗнч(ДокументОснованиеСсылка) = Тип("Массив") Тогда
		Если ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектроннаяТранспортнаяНакладная")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйПутевойЛист")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйЗаказЗаявка") Тогда
			ЭПЛОбъект = ЭПЛ.ПолучитьОбъект();
		Иначе
			ЭПЛОбъект = ЭПЛ;
		КонецЕсли;
		Для Каждого ТекДокумент Из ДокументОснованиеСсылка Цикл
			НайденныйДокумент = ЭПЛОбъект.ДокументыОснования.Найти(ТекДокумент, "ДокументОснование");
			Если НайденныйДокумент = Неопределено Тогда
				НоваяСтрокаОснований = ЭПЛОбъект.ДокументыОснования.Добавить();
				НоваяСтрокаОснований.ДокументОснование = ТекДокумент;
			КонецЕсли;
		КонецЦикла;
		Если ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектроннаяТранспортнаяНакладная")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйПутевойЛист") 
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйЗаказЗаявка") Тогда
			ЭПЛОбъект.Записать();
		КонецЕсли;
	Иначе
		Если ДокументОснованиеСсылка.Пустая() Тогда
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектроннаяТранспортнаяНакладная")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйПутевойЛист")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйЗаказЗаявка") Тогда
			ЭПЛОбъект = ЭПЛ.ПолучитьОбъект();
		Иначе
			ЭПЛОбъект = ЭПЛ;
			
		КонецЕсли;
		НайденныйДокумент = ЭПЛОбъект.ДокументыОснования.Найти(ДокументОснованиеСсылка, "ДокументОснование");
		Если НайденныйДокумент = Неопределено Тогда
			НоваяСтрокаОснований = ЭПЛОбъект.ДокументыОснования.Добавить();
			НоваяСтрокаОснований.ДокументОснование = ДокументОснованиеСсылка;
		КонецЕсли;
		Если ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектроннаяТранспортнаяНакладная")
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйПутевойЛист") 
			ИЛИ ТипЗнч(ЭПЛ) = Тип("ДокументСсылка.ЭлектронныйЗаказЗаявка") Тогда
			ЭПЛОбъект.Записать();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьСвязанныеРейсы(Ссылка, ТипЭПД) Экспорт
	
	МассивРейсов = Новый Массив();
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.уатЗаказГрузоотправителя") Тогда
		Если Ссылка.Мультимодальный
			И НЕ Ссылка.ЭтоЭтап Тогда 
			Запрос = Новый Запрос();
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	уатЭтапыМультимодальныхПеревозок_уэ.НомерЭтапа КАК НомерЭтапа,
			               |	уатЭтапыМультимодальныхПеревозок_уэ.Этап КАК Этап
			               |ИЗ
			               |	РегистрСведений.уатЭтапыМультимодальныхПеревозок_уэ КАК уатЭтапыМультимодальныхПеревозок_уэ
			               |ГДЕ
			               |	уатЭтапыМультимодальныхПеревозок_уэ.ЗаказГрузоотправителя = &ЗаказГрузоотправителя
			               |	И НЕ уатЭтапыМультимодальныхПеревозок_уэ.Этап.ПометкаУдаления
			               |
			               |УПОРЯДОЧИТЬ ПО
			               |	НомерЭтапа";
			Запрос.УстановитьПараметр("ЗаказГрузоотправителя", Ссылка);
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				ТекМассивРейсов = ПолучитьСвязанныеРейсы(Выборка.Этап, ТипЭПД); 
				Для Каждого ТекСтрока Из ТекМассивРейсов Цикл
					МассивРейсов.Добавить(ТекСтрока);
				КонецЦикла;
			КонецЦикла; 
			Возврат МассивРейсов;
		КонецЕсли;
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СвязанныеДокументы.Ссылка КАК МаршрутныйЛист,
		|	&Ссылка КАК Заказ
		|ПОМЕСТИТЬ втМЛЗаказ
		|ИЗ
		|	КритерийОтбора.СвязанныеДокументы(&Ссылка) КАК СвязанныеДокументы
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ЗакрытиеЗаказовНаТСПутевымиЛистами
		|				ТОГДА ТИПЗНАЧЕНИЯ(СвязанныеДокументы.Ссылка) = ТИП(Документ.уатПутевойЛист)
		|			ИНАЧЕ ТИПЗНАЧЕНИЯ(СвязанныеДокументы.Ссылка) = ТИП(Документ.уатМаршрутныйЛист)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СвязанныеДокументы.Ссылка) = ТИП(Документ.уатЗаказПеревозчику_уэ)
		|		КОНЕЦ
		|	И СвязанныеДокументы.Ссылка.ПометкаУдаления = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втМЛЗаказ.Заказ КАК Заказ,
		|	ЕСТЬNULL(уатЗаказГрузоотправителя.FTL, ЛОЖЬ) КАК FTL,
		|	втМЛЗаказ.МаршрутныйЛист КАК МаршрутныйЛист
		|ИЗ
		|	втМЛЗаказ КАК втМЛЗаказ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
		|		ПО втМЛЗаказ.Заказ = уатЗаказГрузоотправителя.Ссылка";
		Запрос.УстановитьПараметр("Ссылка", Ссылка);   
		
		Если ТипЭПД = Тип("ДокументСсылка.ЭлектронныйЗаказЗаявка") Тогда
			ЗакрытиеЗаказовНаТСПутевымиЛистами = Ложь;
		Иначе
			ЗакрытиеЗаказовНаТСПутевымиЛистами = Константы.уатЗакрытиеЗаказовНаТСПутевымиЛистами.Получить();
		КонецЕсли;
		Запрос.УстановитьПараметр("ЗакрытиеЗаказовНаТСПутевымиЛистами", ЗакрытиеЗаказовНаТСПутевымиЛистами);
		
		Результат       = Запрос.Выполнить();
		тзРейсыИЗаказы  = Результат.Выгрузить();
		КоличествоСтрок = тзРейсыИЗаказы.Количество(); 
		
		Если Ссылка.FTL Тогда
			// Создаются отдельные ТТД на грузы с разными пунктами отправления / назначения
			ЗапросFTL = Новый Запрос;
			ЗапросFTL.Текст = ГрузыFTLЗаказовТекстЗапроса();
			ЗапросFTL.УстановитьПараметр("ЗаказСсылка", Ссылка);
			РезультатЗапроса = ЗапросFTL.Выполнить(); 
			Если НЕ РезультатЗапроса.Пустой() Тогда
				ТаблицаГрузов = РезультатЗапроса.Выгрузить();
				Для Каждого ТекСтрока Из ТаблицаГрузов Цикл
					СтруктураРейса = Новый Структура("Заказ,МаршрутныйЛист,Груз,МассивГрузов,ПунктОтправления,ПунктНазначения,Грузоотправитель,Грузополучатель,
					|Количество,КоличествоМест,КоличествоТоваров,КоличествоГрузовыхМест,ВесБрутто,Объем,Цена,Сумма");
					ЗаполнитьЗначенияСвойств(СтруктураРейса, ТекСтрока);
					Попытка
						МассивГрузов = Новый Массив();
						МассивГрузов.Добавить(СтруктураРейса.Груз);
						СтруктураРейса.МассивГрузов = МассивГрузов;
					Исключение
					КонецПопытки;
					Если КоличествоСтрок = 0 Тогда
						СтруктураРейса.МаршрутныйЛист = Документы.уатМаршрутныйЛист.ПустаяСсылка();
					ИначеЕсли КоличествоСтрок = 1 Тогда
						Рейс = тзРейсыИЗаказы[0].МаршрутныйЛист;
						Если ТипЗнч(Рейс) = Тип("ДокументСсылка.уатМаршрутныйЛист") Тогда
							Если ЗначениеЗаполнено(ТекСтрока.Груз) Тогда
