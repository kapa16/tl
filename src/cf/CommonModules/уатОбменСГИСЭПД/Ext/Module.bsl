		Водитель1 = ПолучитьПараметрыВодителяДляПечатиЗаказЗаявка(ВыборкаТекущийДокумент.Водитель1, ВыборкаТекущийДокумент.Дата);
		Водитель2 = ПолучитьПараметрыВодителяДляПечатиЗаказЗаявка(ВыборкаТекущийДокумент.Водитель2, ВыборкаТекущийДокумент.Дата);
		Пункт3_2  = Водитель1 + ?(ЗначениеЗаполнено(Водитель2), "; " + Водитель2, "");  

		ПунктПодачи              = "";
		ДатаПодачи               = "";
		ПунктВыгрузки            = "";
		ДатаВыгрузки             = "";
		ПунктВыгрузкиНомерСтроки = 1;
		Если ВыборкаТекущийДокумент.FTL Тогда 
			НомерСтроки = 1;
			Для Каждого ТекПункт Из ВыборкаТекущийДокумент.ПромежуточныеПункты Цикл
				Если ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка 
					И НЕ ЗначениеЗаполнено(ПунктПодачи) Тогда
					ПунктПодачи = ТекПункт.Пункт;
					ДатаПодачи  = ТекПункт.ПрибытиеПлан;
