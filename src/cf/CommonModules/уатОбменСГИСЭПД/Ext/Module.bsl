Функция СведенияОФизЛице(ОбъектСсылка, ДатаФормирования)

	Сведения = Новый Структура("ФИО, ИНН, Телефоны, ЮридическийАдрес");
	
	Если ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.Пользователи")
		ИЛИ ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		ФизЛицо      = ОбъектСсылка.ФизическоеЛицо;
		Сведения.ФИО = уатОбщегоНазначения.уатФИОСотрудникаПолноеСтрокой(ФизЛицо, ДатаФормирования);
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		ФизЛицо = ОбъектСсылка.ФизическоеЛицо;
		Сведения.ФИО = уатОбщегоНазначения.уатФИОСотрудникаПолноеСтрокой(ОбъектСсылка, ДатаФормирования);
	Иначе
		Возврат Сведения;
	КонецЕсли;
	Сведения.ИНН = ФизЛицо.ИНН;
	
	Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
	ФизЛицо, 
	Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
	);
	Если НЕ ЗначениеЗаполнено(Телефоны) Тогда
		Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		ФизЛицо, 
		Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица
		);
	КонецЕсли;
	Сведения.Телефоны = Телефоны;
	
	Сведения.ЮридическийАдрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
	ФизЛицо, 
	Справочники.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица
	);
	
	Возврат Сведения;

КонецФункции // СведенияОЮрФизЛице()

// Функция получает значение для реквизита СтоимостьПеревозки из регистров
Функция ПолучитьСтоимостьПеревозкиЗаказЗаявка(Заказ, МаршрутныйЛист, ТипПФ)
	
	Запрос = Новый Запрос();
	Если ТипПФ = "Грузоотправитель" Тогда
		ИспользоватьПлановыеУслуги = ПолучитьФункциональнуюОпцию("уатИспользоватьПлановыеУслуги_уэ");
		Если ИспользоватьПлановыеУслуги Тогда
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	уатРасходыОбороты.СуммаУпрОборот КАК Сумма
			|ИЗ
			|	РегистрНакопления.уатПлановыеУслуги_уэ.Обороты(
			|			,
			|			,
			|			,
			|			ПолучательУслуг = ЗНАЧЕНИЕ(Перечисление.уатПолучателиУслуг.НашаОрганизация)
			|				И ЗаказНаТС = &Заказ) КАК уатРасходыОбороты";
		Иначе
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	уатРасходыОбороты.СуммаУпрПриход КАК Сумма
			|ИЗ
			|	РегистрНакопления.уатРасходы.Обороты(, , , Заказ = &Заказ) КАК уатРасходыОбороты"; 
		КонецЕсли;
	Иначе
		ИспользоватьПлановыеУслуги = ПолучитьФункциональнуюОпцию("уатИспользоватьПлановыеУслуги_уэ");
		Если ИспользоватьПлановыеУслуги Тогда
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	уатРасходыОбороты.СуммаУпрОборот КАК Сумма
			|ИЗ
			|	РегистрНакопления.уатПлановыеУслуги_уэ.Обороты(
			|			,
			|			,
			|			,
			|			ПолучательУслуг = ЗНАЧЕНИЕ(Перечисление.уатПолучателиУслуг.Контрагент)
			|				И ЗаказНаТС = &Заказ) КАК уатРасходыОбороты";
		Иначе
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	уатДоходыОбороты.СуммаУпрПриход КАК Сумма
			|ИЗ
			|	РегистрНакопления.уатДоходы.Обороты(, , , Заказ = &Заказ) КАК уатДоходыОбороты";
		КонецЕсли;
	КонецЕсли;
	Запрос.УстановитьПараметр("Заказ", Заказ);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Сумма;
	Иначе 
		Возврат 0;
	КонецЕсли;
КонецФункции

// Возвращает параметры водителя
// 
Функция ПолучитьПараметрыВодителяДляПечатиЗаказЗаявка(ВодительСсылка, ДатаФормирования)
	
	ВодительПФ = "";
	Если ЗначениеЗаполнено(ВодительСсылка) Тогда
		ДанныеВодитель1 = уатОбщегоНазначения.уатФИОСотрудникаПолноеСтрокой(ВодительСсылка, ДатаФормирования);
		ВодительПФ      = ДанныеВодитель1;
		// Удостоверение
		мВодУдСерия      = "";
		мВодУдНомер      = "";
		мВодУдКат        = "";
		мВодУдДатаВыдачи = Дата(1,1,1);
		уатОбщегоНазначения.уатУдостоверениеВодителя(ВодительСсылка, мВодУдСерия, мВодУдНомер, мВодУдКат, мВодУдДатаВыдачи); 
		ДанныеУдостоверения = мВодУдСерия + " " + мВодУдНомер;
		Если ЗначениеЗаполнено(мВодУдДатаВыдачи) Тогда
			ДанныеУдостоверения = ДанныеУдостоверения + " выдано " + Формат(мВодУдДатаВыдачи, "ДФ=dd.MM.yy");
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеУдостоверения) Тогда
			ДанныеУдостоверения = "водит.удост. №" + ДанныеУдостоверения;
			ВодительПФ          = ВодительПФ + ", " + ДанныеУдостоверения;
		КонецЕсли;
		
		ДанныеИНН = "";
		Телефоны  = "";
		Если ТипЗнч(ВодительСсылка) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ДанныеИНН = ВодительСсылка.ИНН;
			
			Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			ВодительСсылка, 
			Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
			);
			Если НЕ ЗначениеЗаполнено(Телефоны) Тогда
				Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				ВодительСсылка, 
				Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица
				);
			КонецЕсли;
		Иначе 
			ФизическоеЛицо = ВодительСсылка.ФизическоеЛицо;
			ДанныеИНН      = ФизическоеЛицо.ИНН; 
			
			Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			ФизическоеЛицо, 
			Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
			);
			Если НЕ ЗначениеЗаполнено(Телефоны) Тогда
				Телефоны = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				ФизическоеЛицо, 
				Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица
				);
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеИНН) Тогда
			ДанныеИНН  = НСтр("en='TIN';ru='ИНН'") + " " + ДанныеИНН;
			ВодительПФ = ВодительПФ + ", " + ДанныеИНН;
		КонецЕсли;
		Если ЗначениеЗаполнено(Телефоны) Тогда
			Телефоны  = НСтр("en='tel:';ru='тел.:'") + " " + Телефоны;
			ВодительПФ = ВодительПФ + ", " + Телефоны;
		КонецЕсли;
	КонецЕсли;
	Возврат ВодительПФ;
	
КонецФункции        

