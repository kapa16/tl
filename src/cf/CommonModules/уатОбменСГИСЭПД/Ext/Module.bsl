Функция ПодготовитьДанныеДляСозданияЭлектронныхПутевыхЛистов(ДокументОснование, ДопДанные)
	
	ИмяДокумента = "ЭлектронныйПутевойЛист";
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("Ссылка",  ДокументОснование); 
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	Запрос.Текст = ПолучитьТекстЗапросаДляСозданияЭлектронныхПутевыхЛистов();

	ДанныеЗаполнения = Запрос.ВыполнитьПакет()[2].Выбрать();
	ДанныеЗаполнения.Следующий();
	
	ДанныеПоДокументамОснованиям = Новый Структура(); 
	ДанныеПоДокументамОснованиям.Вставить("Организация",                      ДанныеЗаполнения.Оформитель);
	ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулОформлениеОформитель",  ДанныеЗаполнения.Оформитель);
	Если НЕ СинхронизацияЭДО.ЕстьУчетныеЗаписи(
		ДанныеПоДокументамОснованиям.СсылкаТитулОформлениеОформитель) Тогда
		ДанныеПоДокументамОснованиям.Вставить("ОформительНеПодключен", Истина);
	КонецЕсли;
	РеквизитыУчастника = ПолучитьРеквизитыУчастника(ДанныеПоДокументамОснованиям.СсылкаТитулОформлениеОформитель,
	"ТитулОформлениеОформитель");  
	ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, РеквизитыУчастника, Истина);
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеНомерПутевогоЛиста", ДанныеЗаполнения.Номер);
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеДатаПутевогоЛиста",  ДанныеЗаполнения.Дата);  
	
	
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеСведенияОВидеПеревозки", ?(ЗначениеЗаполнено(ДанныеЗаполнения.ВидПеревозки),
		ДанныеЗаполнения.ВидПеревозки, "СН")); 
		
	Если ЗначениеЗаполнено(ДанныеЗаполнения.ТипПеревозки) И ДанныеЗаполнения.ВидПеревозки = "КП" Тогда
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеВидКоммерческойПеревозки", ДанныеЗаполнения.ТипПеревозки);
	КонецЕсли;
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеВидСообщения", ?(ЗначениеЗаполнено(ДанныеЗаполнения.ВидСообщения),
		ДанныеЗаполнения.ВидСообщения, "Г"));
		
	ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулОформлениеМедорганизация",   ДанныеЗаполнения.Медорганизация);
	Если ЗначениеЗаполнено(ДанныеЗаполнения.Медорганизация)
		И НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
		ДанныеПоДокументамОснованиям.СсылкаТитулОформлениеМедорганизация) Тогда
		ДанныеПоДокументамОснованиям.Вставить("МедорганизацияНеПодключена", Истина);
	КонецЕсли; 
	ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулОформлениеТехконтроль",   ДанныеЗаполнения.КонтрольТранспорта);
	Если ЗначениеЗаполнено(ДанныеЗаполнения.КонтрольТранспорта)
		И НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
		ДанныеПоДокументамОснованиям.СсылкаТитулОформлениеТехконтроль) Тогда
		ДанныеПоДокументамОснованиям.Вставить("ТехконтрольНеПодключен", Истина);
	КонецЕсли; 
	
	ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулОформлениеПоказанияОдометра",   ДанныеЗаполнения.ПоказанияОдометра);
	Если ЗначениеЗаполнено(ДанныеЗаполнения.ПоказанияОдометра)
		И НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
		ДанныеПоДокументамОснованиям.СсылкаТитулОформлениеПоказанияОдометра) Тогда
		ДанныеПоДокументамОснованиям.Вставить("ПоказанияОдометраНеПодключен", Истина);
	КонецЕсли;
	
	Если ДанныеПоДокументамОснованиям.Свойство("ОформительНеПодключен")
		ИЛИ ДанныеПоДокументамОснованиям.Свойство("МедорганизацияНеПодключена")
		ИЛИ ДанныеПоДокументамОснованиям.Свойство("ТехконтрольНеПодключен")
		ИЛИ ДанныеПоДокументамОснованиям.Свойство("ПоказанияОдометраНеПодключен")Тогда
		Возврат ДанныеПоДокументамОснованиям;
	КонецЕсли;
	
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеОбязательностьМедОсмотраПосле", ?(ДанныеЗаполнения.ОбязательныйПослерейсовыйМедосмотр,
		"1", "2"));  
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеПризнакФормированияПутевогоЛистаНаОдинДень",
		?(НачалоДня(ДанныеЗаполнения.ДействителенДо) = НачалоДня(ДанныеЗаполнения.Дата), "1", "2"));
		
	Если ДанныеПоДокументамОснованиям.ТитулОформлениеПризнакФормированияПутевогоЛистаНаОдинДень = "1" Тогда
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован", НачалоДня(ДанныеЗаполнения.Дата));
	Иначе
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеДатаНачалаСрокаИспользованияПутевогоЛиста",    НачалоДня(ДанныеЗаполнения.Дата));
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста", НачалоДня(ДанныеЗаполнения.ДействителенДо));
	КонецЕсли;
	
	// Водители
	ГруппаДанных            = "Водитель";
	ОписаниеРеквизитовФормы = ДопДанные.ОписаниеРеквизитовФормыВодитель;
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеВодители", Новый Массив());
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения.Водитель1) Тогда
		СтруктураВодитель = Новый Структура("Ссылка, ФИО, ИНН, ФизическоеЛицо");
		СтруктураВодитель.Ссылка         = ДанныеЗаполнения.Водитель1;
		СтруктураВодитель.ФИО            = ДанныеЗаполнения.Водитель1ФИО;
		СтруктураВодитель.ИНН            = ДанныеЗаполнения.Водитель1ИНН;
		СтруктураВодитель.ФизическоеЛицо = ДанныеЗаполнения.Водитель1ФизическоеЛицо;
		
		НоваяСтрока = ЗаполнитьСотрудника(СтруктураВодитель, ИмяДокумента, ГруппаДанных, ОписаниеРеквизитовФормы);
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.НомерВУ) Тогда
			НоваяСтрока.НомерВУ = "Не заполнено";
		Конецесли;
		НоваяСтрока.Вставить("ХранимыеДанныеВодитель", НоваяСтрока.ХранимыеДанные);
		НоваяСтрока.Вставить("ИдентификаторСтроки",    Строка(Новый УникальныйИдентификатор()));  
		НоваяСтрока.Удалить("ХранимыеДанные");   
		
		ДанныеПоДокументамОснованиям.ТитулОформлениеВодители.Добавить(НоваяСтрока);
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ДанныеЗаполнения.Водитель2) Тогда
		СтруктураВодитель = Новый Структура("Ссылка, ФИО, ИНН, ФизическоеЛицо");
		СтруктураВодитель.Ссылка         = ДанныеЗаполнения.Водитель2;
		СтруктураВодитель.ФИО            = ДанныеЗаполнения.Водитель2ФИО;
		СтруктураВодитель.ИНН            = ДанныеЗаполнения.Водитель2ИНН;
		СтруктураВодитель.ФизическоеЛицо = ДанныеЗаполнения.Водитель2ФизическоеЛицо;
		
		НоваяСтрока = ЗаполнитьСотрудника(СтруктураВодитель, ИмяДокумента, ГруппаДанных, ОписаниеРеквизитовФормы);
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.НомерВУ) Тогда
			НоваяСтрока.НомерВУ = "Не заполнено";
		Конецесли;
		НоваяСтрока.Вставить("ХранимыеДанныеВодитель", НоваяСтрока.ХранимыеДанные);
		НоваяСтрока.Вставить("ИдентификаторСтроки",    Строка(Новый УникальныйИдентификатор()));  
		НоваяСтрока.Удалить("ХранимыеДанные");
		
		ДанныеПоДокументамОснованиям.ТитулОформлениеВодители.Добавить(НоваяСтрока);
		
	КонецЕсли;
		
	// Прицепы
	МассивПрицепов          = Новый Массив(); 
	ГруппаДанных            = "Прицеп";
	ОписаниеРеквизитовФормы = ДопДанные.ОписаниеРеквизитовФормыПрицеп;
	
	ВыборкаПрицеп = Запрос.ВыполнитьПакет()[3].Выбрать(); 
	Пока ВыборкаПрицеп.Следующий() Цикл   
		СтруктураТС = Новый Структура("Ссылка, СТС, VIN, ГосударственныйНомер, Марка, Модель, Грузоподъемность, ОбъемКузова, ВидТС, ТипВладенияТС");
		СтруктураТС.Ссылка               = ВыборкаПрицеп.Прицеп;
		СтруктураТС.СТС                  = СтрЗаменить(ВыборкаПрицеп.ПрицепСТС, " ", "");
		СтруктураТС.VIN                  = ВыборкаПрицеп.ПрицепVIN;
		СтруктураТС.ГосударственныйНомер = ВыборкаПрицеп.ПрицепГосударственныйНомер;
		СтруктураТС.Марка                = ВыборкаПрицеп.ПрицепМарка;
		СтруктураТС.Грузоподъемность     = ВыборкаПрицеп.ПрицепГрузоподъемность;
		СтруктураТС.ОбъемКузова          = ВыборкаПрицеп.ПрицепОбъемКузова;
		СтруктураТС.ВидТС                = ВыборкаПрицеп.ПрицепВидТС;
		СтруктураТС.ТипВладенияТС        = ВыборкаПрицеп.ПрицепТипВладенияТС;
		СтруктураТС.Модель               = ВыборкаПрицеп.ПрицепМодель;

		НоваяСтрокаПрицеп = ЗаполнитьТС(СтруктураТС, ИмяДокумента, ГруппаДанных, ОписаниеРеквизитовФормы);
		НоваяСтрокаПрицеп.Вставить("ХранимыеДанныеПрицеп",   НоваяСтрокаПрицеп.ХранимыеДанные);
		НоваяСтрокаПрицеп.Вставить("ИдентификаторСтроки",    Строка(Новый УникальныйИдентификатор()));
		НоваяСтрокаПрицеп.Удалить("ХранимыеДанные");
		
		МассивПрицепов.Добавить(НоваяСтрокаПрицеп);
	КонецЦикла;
	ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеПрицепы", МассивПрицепов);
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения.ТС) Тогда
		СтруктураТС = Новый Структура("Ссылка, СТС, VIN, ГосударственныйНомер, Марка, Модель, Грузоподъемность, ОбъемКузова, ВидТС, ТипВладенияТС");
		СтруктураТС.Ссылка               = ДанныеЗаполнения.ТС;
		СтруктураТС.СТС                  = СтрЗаменить(ДанныеЗаполнения.ТССТС, " ", "");
		СтруктураТС.VIN                  = ДанныеЗаполнения.ТСVIN;
		СтруктураТС.ГосударственныйНомер = ДанныеЗаполнения.ТСГосударственныйНомер;
		СтруктураТС.Марка                = ДанныеЗаполнения.ТСМарка;
		СтруктураТС.Грузоподъемность     = ДанныеЗаполнения.ТСГрузоподъемность;
		СтруктураТС.ОбъемКузова          = ДанныеЗаполнения.ТСОбъемКузова;
		СтруктураТС.ВидТС                = ДанныеЗаполнения.ТСВидТС;
		СтруктураТС.ТипВладенияТС        = ДанныеЗаполнения.ТСТипВладенияТС;
		СтруктураТС.Модель               = ДанныеЗаполнения.ТСМодель;
		
		ГруппаДанных            = "ТранспортноеСредствоЭПЛ";
		ОписаниеРеквизитовФормы = ДопДанные.ОписаниеРеквизитовФормыТС;
		ДанныеТС = ЗаполнитьТС(СтруктураТС, ИмяДокумента, ГруппаДанных, ОписаниеРеквизитовФормы, МассивПрицепов);
		ДанныеТС.Вставить("ХранимыеДанныеТитулОформлениеТранспортноеСредство", ДанныеТС.ХранимыеДанные);
		ДанныеТС.Удалить("ХранимыеДанные");
		
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, ДанныеТС, Истина);
		
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеТранспортноеСредствоТип",                  ДанныеТС.Тип);
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеТранспортноеСредствоМарка",                ДанныеТС.Марка);
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеТранспортноеСредствоМодель",               ДанныеТС.Модель);
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеТранспортноеСредствоРегистрационныйНомер", ДанныеТС.РегистрационныйНомер); 
		ДанныеПоДокументамОснованиям.Вставить("ТитулОформлениеТранспортноеСредствоИнвентарныйНомер",     "");

	КонецЕсли;
 
	
	Возврат ДанныеПоДокументамОснованиям;
	
КонецФункции

Функция ПолучитьТекстЗапросаДляСозданияЭлектронныхПутевыхЛистов()

	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатПутевойЛист.Номер КАК Номер,
	               |	уатПутевойЛист.Дата КАК Дата,
	               |	уатПутевойЛист.ВидПеревозки.ВидПеревозкиДляЭПЛ КАК ВидПеревозки,
	               |	уатПутевойЛист.ВидПеревозки.ТипПеревозки КАК ТипПеревозки,
	               |	уатПутевойЛист.ВидСообщения.ВидCообщенияДляЭПЛ КАК ВидСообщения,
	               |	уатПутевойЛист.Организация КАК Оформитель,
	               |	уатПутевойЛист.Медорганизация КАК Медорганизация,
	               |	уатПутевойЛист.КонтрольТранспорта КАК КонтрольТранспорта,
	               |	уатПутевойЛист.ПоказанияОдометра КАК ПоказанияОдометра,
	               |	уатПутевойЛист.ТранспортноеСредство КАК ТС,
	               |	уатПутевойЛист.Водитель1 КАК Водитель1,
	               |	уатПутевойЛист.Водитель2 КАК Водитель2,
	               |	уатПутевойЛист.ОбязательныйПослерейсовыйМедосмотр КАК ОбязательныйПослерейсовыйМедосмотр,
	               |	уатПутевойЛист.ДействителенДо КАК ДействителенДо,
	               |	уатПутевойЛист.ДатаВыезда КАК ДатаВыезда,
	               |	уатПутевойЛист.ДатаВозвращения КАК ДатаВозвращения,
	               |	уатПутевойЛист.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ втЗначенияЗаполнения
	               |ИЗ
	               |	Документ.уатПутевойЛист КАК уатПутевойЛист
	               |ГДЕ
	               |	уатПутевойЛист.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатРегистрационныеДокументы.ВладелецДокументов КАК ВладелецДокументов,
	               |	МАКСИМУМ(уатРегистрационныеДокументы.Серия + уатРегистрационныеДокументы.Номер) КАК Номер
	               |ПОМЕСТИТЬ втСТС
	               |ИЗ
	               |	Справочник.уатРегистрационныеДокументы КАК уатРегистрационныеДокументы
	               |ГДЕ
	               |	уатРегистрационныеДокументы.ВидДокумента = ЗНАЧЕНИЕ(Справочник.уатВидыДокументов.СТС)
	               |	И уатРегистрационныеДокументы.Статус = ЗНАЧЕНИЕ(Перечисление.уатСтатусыДействия.Действует)
	               |	И НЕ уатРегистрационныеДокументы.ПометкаУдаления
	               |	И ВЫБОР
	               |			КОГДА уатРегистрационныеДокументы.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ уатРегистрационныеДокументы.ДатаОкончания >= &ТекДата
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА уатРегистрационныеДокументы.ДатаВыдачи = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ уатРегистрационныеДокументы.ДатаВыдачи <= &ТекДата
	               |		КОНЕЦ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	уатРегистрационныеДокументы.ВладелецДокументов
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	втЗначенияЗаполнения.Номер КАК Номер,
	               |	втЗначенияЗаполнения.Дата КАК Дата,
	               |	втЗначенияЗаполнения.ВидПеревозки КАК ВидПеревозки,
	               |	втЗначенияЗаполнения.ВидСообщения КАК ВидСообщения,
	               |	втЗначенияЗаполнения.ТипПеревозки КАК ТипПеревозки,
	               |	втЗначенияЗаполнения.Оформитель КАК Оформитель,
	               |	втЗначенияЗаполнения.Медорганизация КАК Медорганизация,
	               |	втЗначенияЗаполнения.КонтрольТранспорта КАК КонтрольТранспорта,
	               |	втЗначенияЗаполнения.ПоказанияОдометра КАК ПоказанияОдометра,
	               |	втЗначенияЗаполнения.Водитель1 КАК Водитель1,
	               |	втЗначенияЗаполнения.Водитель1.ФизическоеЛицо.ФИО КАК Водитель1ФИО,
	               |	втЗначенияЗаполнения.Водитель1.ФизическоеЛицо.ИНН КАК Водитель1ИНН,
	               |	втЗначенияЗаполнения.Водитель1.ФизическоеЛицо КАК Водитель1ФизическоеЛицо,
	               |	втЗначенияЗаполнения.Водитель2 КАК Водитель2,
	               |	втЗначенияЗаполнения.Водитель2.ФизическоеЛицо.ФИО КАК Водитель2ФИО,
	               |	втЗначенияЗаполнения.Водитель2.ФизическоеЛицо.ИНН КАК Водитель2ИНН,
	               |	втЗначенияЗаполнения.Водитель2.ФизическоеЛицо КАК Водитель2ФизическоеЛицо,
	               |	втЗначенияЗаполнения.ТС КАК ТС,
	               |	втЗначенияЗаполнения.ТС.VIN КАК ТСVIN,
	               |	втЗначенияЗаполнения.ТС.ТипТС.Наименование КАК ТСТип,
	               |	втЗначенияЗаполнения.ТС.Модель.Наименование КАК ТСМодель,
	               |	втЗначенияЗаполнения.ТС.Марка.Наименование КАК ТСМарка,
	               |	втЗначенияЗаполнения.ТС.ГосударственныйНомер КАК ТСГосударственныйНомер,
	               |	ВЫБОР
	               |		КОГДА втЗначенияЗаполнения.ТС.Грузоподъемность = 0
	               |			ТОГДА втЗначенияЗаполнения.ТС.Модель.Грузоподъемность
	               |		ИНАЧЕ втЗначенияЗаполнения.ТС.Грузоподъемность
	               |	КОНЕЦ КАК ТСГрузоподъемность,
	               |	ВЫБОР
	               |		КОГДА втЗначенияЗаполнения.ТС.ОбъемКузова = 0
	               |			ТОГДА втЗначенияЗаполнения.ТС.Модель.ОбъемКузова
	               |		ИНАЧЕ втЗначенияЗаполнения.ТС.ОбъемКузова
	               |	КОНЕЦ КАК ТСОбъемКузова,
	               |	втСТС.Номер КАК ТССТС,
	               |	втЗначенияЗаполнения.ТС.ТипТС.ВидТС КАК ТСВидТС,
	               |	втЗначенияЗаполнения.ТС.ТипВладенияТС КАК ТСТипВладенияТС,
	               |	втЗначенияЗаполнения.ОбязательныйПослерейсовыйМедосмотр КАК ОбязательныйПослерейсовыйМедосмотр,
	               |	втЗначенияЗаполнения.ДействителенДо КАК ДействителенДо,
	               |	втЗначенияЗаполнения.ДатаВыезда КАК ДатаВыезда,
	               |	втЗначенияЗаполнения.ДатаВозвращения КАК ДатаВозвращения,
	               |	втЗначенияЗаполнения.Ссылка КАК Ссылка
	               |ИЗ
	               |	втЗначенияЗаполнения КАК втЗначенияЗаполнения
	               |		ЛЕВОЕ СОЕДИНЕНИЕ втСТС КАК втСТС
	               |		ПО втЗначенияЗаполнения.ТС = втСТС.ВладелецДокументов
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	уатПутевойЛистПрицепы.ТС КАК Прицеп,
	               |	уатПутевойЛистПрицепы.ТС.VIN КАК ПрицепVIN,
	               |	уатПутевойЛистПрицепы.ТС.Модель.Наименование КАК ПрицепМодель,
	               |	уатПутевойЛистПрицепы.ТС.Марка.Наименование КАК ПрицепМарка,
	               |	уатПутевойЛистПрицепы.ТС.ГосударственныйНомер КАК ПрицепГосударственныйНомер,
	               |	ВЫБОР
	               |		КОГДА уатПутевойЛистПрицепы.ТС.Грузоподъемность = 0
	               |			ТОГДА уатПутевойЛистПрицепы.ТС.Модель.Грузоподъемность
	               |		ИНАЧЕ уатПутевойЛистПрицепы.ТС.Грузоподъемность
	               |	КОНЕЦ КАК ПрицепГрузоподъемность,
	               |	ВЫБОР
	               |		КОГДА уатПутевойЛистПрицепы.ТС.ОбъемКузова = 0
	               |			ТОГДА уатПутевойЛистПрицепы.ТС.Модель.ОбъемКузова
	               |		ИНАЧЕ уатПутевойЛистПрицепы.ТС.ОбъемКузова
	               |	КОНЕЦ КАК ПрицепОбъемКузова,
	               |	втСТС.Номер КАК ПрицепСТС,
	               |	уатПутевойЛистПрицепы.ТС.ТипТС.ВидТС КАК ПрицепВидТС,
	               |	уатПутевойЛистПрицепы.ТС.ТипВладенияТС КАК ПрицепТипВладенияТС
	               |ИЗ
	               |	втЗначенияЗаполнения КАК втЗначенияЗаполнения
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатПутевойЛист.Прицепы КАК уатПутевойЛистПрицепы
	               |			ЛЕВОЕ СОЕДИНЕНИЕ втСТС КАК втСТС
	               |			ПО уатПутевойЛистПрицепы.ТС = втСТС.ВладелецДокументов
	               |		ПО втЗначенияЗаполнения.Ссылка = уатПутевойЛистПрицепы.Ссылка
	               |ГДЕ
	               |	(уатПутевойЛистПрицепы.ТС.Модель.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМоделейТС.Прицеп)
	               |			ИЛИ уатПутевойЛистПрицепы.ТС.Модель.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМоделейТС.Автотранспорт))";
	
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти  

#Область СлужебныеПроцедурыИФункцииЭЗЗ

Функция ПолучитьИмяФайлаЭЗЗ(Шаблон, ИдГрузоотправителя, ИдПеревозчика, НаличиеДругихПолучателей = Ложь)
	
	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	
	Результат = Шаблон;
	Результат = СтрЗаменить(Результат, "ИдГО",  ИдГрузоотправителя);
	Результат = СтрЗаменить(Результат, "ИдПЕР", ИдПеревозчика);
	Результат = СтрЗаменить(Результат, "GGGGMMDD", Формат(ТекущаяДатаСеанса, "ДФ=ггггММдд"));
	Результат = СтрЗаменить(Результат, "ГУИДФайла", Строка(Новый УникальныйИдентификатор()));
	Результат = СтрЗаменить(Результат, "НалДр", ?(НаличиеДругихПолучателей = Истина, "1", "0"));
	
	Возврат Результат;
	
КонецФункции

Функция ЗначенияЗаполненияЭЗЗ()

	ЗначенияЗаполнения = Новый Структура();
	ЗначенияЗаполнения.Вставить("ТитулГрузоотправителяСодержаниеОперации", 
		"Предоставление заказа и заявки на перевозку груза автомобильным транспортом");
	ЗначенияЗаполнения.Вставить("ТитулГрузоотправителяУказанияВОтношенииВыполненияНормПеревозки", 
		"Отсутствуют");
	ЗначенияЗаполнения.Вставить("ТитулГрузоотправителяТребованияТранспортногоСредстваДляПищевыхПродуктов", 
		"Отсутствуют");
	ЗначенияЗаполнения.Вставить("ТитулГрузоотправителяФункция", "Заказ");
	
	Возврат ЗначенияЗаполнения
	
КонецФункции

Функция ПодготовитьДанныеДляСозданияЭЗЗ(ЗаказНаТС, Рейс, МассивЗаказов, ДопДанные)
	
	ИмяДокумента = "ЭлектронныйЗаказЗаявка";
	
	тзРейсы = Новый ТаблицаЗначений();
	тзРейсы.Колонки.Добавить("Заказ", Новый ОписаниеТипов("ДокументСсылка.уатЗаказГрузоотправителя"));
	тзРейсы.Колонки.Добавить("Рейс",  Новый ОписаниеТипов("ДокументСсылка.уатМаршрутныйЛист, ДокументСсылка.уатЗаказПеревозчику_уэ"));
	
	Для Каждого ТекДокумент Из МассивЗаказов Цикл 
		Если ТипЗнч(ТекДокумент) = Тип("ДокументСсылка.уатЗаказГрузоотправителя") Тогда
			НоваяСтрока = тзРейсы.Добавить();
			НоваяСтрока.Заказ = ТекДокумент;
		КонецЕСли;
		Если ЗначениеЗаполнено(Рейс) Тогда
			НоваяСтрока.Рейс  = Рейс;
		КонецЕСли;
	КонецЦикла;
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("тзРейсы",  тзРейсы);
	Запрос.Текст = ПолучитьТекстЗапросаДляЭЗЗ();
	
	ДанныеПоДокументамОснованиям = Новый Структура();
		
	тзДанныеЗаполнения = Запрос.Выполнить().Выгрузить();
	Если тзДанныеЗаполнения.Количество() = 0 Тогда
		Возврат ДанныеПоДокументамОснованиям;
	Иначе
		ДанныеЗаполнения = тзДанныеЗаполнения[0];
	КонецЕсли;
	
	
	ДанныеПоДокументамОснованиям.Вставить("Организация", ДанныеЗаполнения.Организация); 
	ДанныеПоДокументамОснованиям.Вставить("Дата",        ДанныеЗаполнения.Дата);
	
	ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяЗаказНомер",             ДанныеЗаполнения.Номер);
	ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяЗаказДата",              ДанныеЗаполнения.Дата);
	ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяФункция",                ?(ДанныеЗаполнения.ТипДокументаЗаказЗаявка = "2", "Заявка", "Заказ"));

	Если ДанныеЗаполнения.ВариантПоДоверенностиЗаГрузоотправителя Тогда
		Грузоотправитель = ДанныеЗаполнения.Контрагент;
		
		// Составитель документа
		ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулГрузоотправителяСоставитель", ДанныеЗаполнения.Организация);
		РеквизитыУчастника = ПолучитьРеквизитыУчастника(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяСоставитель,
		"ТитулГрузоотправителяПредставительГрузоотправителя");  
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, РеквизитыУчастника, Истина); 
		
		Если ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяСоставитель) = Тип("СправочникСсылка.Контрагенты") Тогда
			Если НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяСоставитель) Тогда
				ДанныеПоДокументамОснованиям.Вставить("СоставительНеПодключен", Истина);
			КонецЕсли;
		Иначе
			Если НЕ СинхронизацияЭДО.ЕстьУчетныеЗаписи(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяСоставитель) Тогда
				ДанныеПоДокументамОснованиям.Вставить("СоставительНеПодключен", Истина);
			КонецЕсли;
		КонецЕсли;

	Иначе
		Грузоотправитель = ДанныеЗаполнения.Организация;
	КонецЕсли;
	
	// Грузоотправитель
	Если ТипЗнч(Грузоотправитель) = Тип("СправочникСсылка.Контрагенты")
		ИЛИ ТипЗнч(Грузоотправитель) = Тип("СправочникСсылка.Организации") Тогда
		ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулГрузоотправителяГрузоотправитель", Грузоотправитель);  
		РеквизитыУчастника = ПолучитьРеквизитыУчастника(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель,
		"ТитулГрузоотправителяГрузоотправитель");  
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, РеквизитыУчастника, Истина);
		Если ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) = Тип("СправочникСсылка.Контрагенты") Тогда
			Если НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) Тогда
				ДанныеПоДокументамОснованиям.Вставить("ГрузоотправительНеПодключен", Истина);
			КонецЕсли;
		Иначе
			Если НЕ СинхронизацияЭДО.ЕстьУчетныеЗаписи(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) Тогда
				ДанныеПоДокументамОснованиям.Вставить("ГрузоотправительНеПодключен", Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	// Перевозчик
	Если ЗначениеЗаполнено(Рейс)
		И ЗначениеЗаполнено(ДанныеЗаполнения.Перевозчик) Тогда
		ДанныеПоДокументамОснованиям.Вставить("СсылкаТитулГрузоотправителяПеревозчик", ДанныеЗаполнения.Перевозчик);
		РеквизитыУчастника = ПолучитьРеквизитыУчастника(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяПеревозчик,
		"ТитулГрузоотправителяПеревозчик");  
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, РеквизитыУчастника, Истина);
		
		Если ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяПеревозчик) = Тип("СправочникСсылка.Контрагенты") Тогда
			Если НЕ ИнтерфейсДокументовЭДО.ЕстьНастройкиПоКонтрагенту(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяПеревозчик) Тогда
				ДанныеПоДокументамОснованиям.Вставить("ПеревозчикНеПодключен", Истина);
			КонецЕсли;
		Иначе
			Если НЕ СинхронизацияЭДО.ЕстьУчетныеЗаписи(
				ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяПеревозчик) Тогда
				ДанныеПоДокументамОснованиям.Вставить("ПеревозчикНеПодключен", Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	// Договор 
	Если ЗначениеЗаполнено(ДанныеЗаполнения.ДоговорКонтрагента) Тогда
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяДоговорНаименование", ДанныеЗаполнения.ДоговорКонтрагентаНаименование);
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяДоговорНомер",        ДанныеЗаполнения.ДоговорКонтрагентаНомер);
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяДоговорДата",         ДанныеЗаполнения.ДоговорКонтрагентаДата);
	КонецЕсли; 
	
	// Сторона подписавшая документ 
	Если ЗначениеЗаполнено(Грузоотправитель)
		И (ТипЗнч(Грузоотправитель) = Тип("СправочникСсылка.Организации") 
		ИЛИ ТипЗнч(Грузоотправитель) = Тип("СправочникСсылка.Контрагенты")) Тогда
		ОписаниеРеквизитовФормы = ДопДанные.ОписаниеРеквизитовФормыСторонаПодписавшаяДокумент;
		ДанныеСторонаПодписавшаяДокумент = ЗаполнитьСторонуПодписавшуюДокумент(Грузоотправитель, ИмяДокумента, "СторонаПодписавшаяДокумент", ОписаниеРеквизитовФормы);
		
		НоваяСтрока = ЗначенияЗаполненияТитулГрузоотправителяСторонаПодписавшаяДокумент();
		НоваяСтрока.ИдентификаторСтроки                      = Строка(Новый УникальныйИдентификатор());
		НоваяСтрока.ХранимыеДанныеСторонаПодписавшаяДокумент = ДанныеСторонаПодписавшаяДокумент.ХранимыеДанные;
		Если ТипЗнч(Грузоотправитель) = Тип("СправочникСсылка.Организации") Тогда
			НоваяСтрока.ЮЛ_ИНН = Грузоотправитель.ИНН;
		Иначе
			Если Грузоотправитель.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
				НоваяСтрока.ФЛ_ИНН = Грузоотправитель.ИНН;
			Иначе
				НоваяСтрока.ЮЛ_ИНН = Грузоотправитель.ИНН; 
			КонецЕсли;
		КонецЕсли;
		МассивСторон = Новый Массив();
		МассивСторон.Добавить(НоваяСтрока); 
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяДоговорРеквизитыСторон", МассивСторон);
	КонецЕсли;  
	
	// Требования к ТС  
	Если ЗначениеЗаполнено(ДанныеЗаполнения.ТребованиеКТСТипТС) Тогда
		ГруппаДанных            = "ТитулГрузоотправителяПараметрыТранспортногоСредства";
		ОписаниеГруппыДанных = ОбменСГИСЭПДКлиентСервер.ОписаниеГруппыДанных(ГруппаДанных, "Документ.ЭлектронныйЗаказЗаявка");

		ОписаниеРеквизитовФормы = ДопДанные.ОписаниеРеквизитовФормыТС;
		ДанныеТС = ЗаполнитьТС(ДанныеЗаполнения.ТребованиеКТСТипТС, ИмяДокумента, ОписаниеГруппыДанных.Тип, ОписаниеРеквизитовФормы,, ДанныеЗаполнения.ТребованиеКТС.СпособПогрузки);
		ДанныеТС.Вставить("ХранимыеДанные" + ГруппаДанных, ДанныеТС.ХранимыеДанные);
		ДанныеТС.Удалить("ХранимыеДанные"); 
		
		МассивПолей = Новый Массив();
		Для Каждого ТекСтрока Из ДанныеТС Цикл
			Если СтрНайти(ТекСтрока.Ключ, ГруппаДанных) = 0 Тогда 
				МассивПолей.Добавить(ТекСтрока);
			КонецЕсли;
		КонецЦикла;
		Для Каждого ТекСтрока Из МассивПолей Цикл
			ДанныеТС.Вставить(ГруппаДанных + ТекСтрока.Ключ, ТекСтрока.Значение);
			ДанныеТС.Удалить(ТекСтрока.Ключ);
		КонецЦикла;
		
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, ДанныеТС, Истина);
	КонецЕсли;
	
	// Пункты
	ПунктПодачи              = "";
	ДатаПодачи               = "";
	ПредельнаяДатаПодачи     = "";
	МассивПунктов            = Новый Массив(); 
	Если ЗначениеЗаполнено(ЗаказНаТС) Тогда
		Если ДанныеЗаполнения.FTL Тогда 
			НомерСтроки = 1;
			Для Каждого ТекПункт Из ДанныеЗаполнения.ПромежуточныеПункты Цикл 
				ЭтоПунктПодачи = Истина;
				Если ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка 
					И НЕ ЗначениеЗаполнено(ПунктПодачи) Тогда
					ПунктПодачи          = ТекПункт.ПунктЗначениеАдреса;
					ДатаПодачи           = ТекПункт.ПрибытиеПлан;
					ПредельнаяДатаПодачи = ТекПункт.УбытиеПлан;
				КонецЕсли;
				
				Если ТекПункт.ТипТочкиМаршрута <> Перечисления.уатТипыТочекМаршрута.ПромежуточныйПункт Тогда
					НоваяСтрока = ЗначенияЗаполненияТитулГрузоотправителяПунктыПогрузкиВыгрузки();
					НоваяСтрока.НомерПп                                 = НомерСтроки;
					НоваяСтрока.ИдентификаторСтроки                     = Строка(Новый УникальныйИдентификатор());
					НоваяСтрока.Операция                                = ?(ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка
					ИЛИ ТекПункт.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.ДополнительнаяПогрузка, "Погрузка", "Выгрузка");
					НоваяСтрока.ДатаИВремяПогрузкиВыгрузки              = ТекПункт.ПрибытиеПлан;
					НоваяСтрока.КрайнееВремяПодачиТС                    = ТекПункт.УбытиеПлан;
					
					СтруктураАдреса = Новый Структура();
					ДополнитьСтруктуру(НоваяСтрока, 
					ДанныеЗаполненияАдрес(ТекПункт.ПунктЗначениеАдреса, "АдресПунктаПогрузки",
					СтруктураАдреса, Ложь),
					Истина);
					НоваяСтрока.ПредставлениеАдресПунктаПогрузки   = Строка(ТекПункт.Пункт); 
					Если НоваяСтрока.Операция = "Погрузка" Тогда 
						Если ЭтоПунктПодачи Тогда
							НоваяСтрока.ВладелецПунктаПогрузкиНаименование      = Строка(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель);
							Если ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) = Тип("СправочникСсылка.Контрагенты")
								ИЛИ ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) = Тип("СправочникСсылка.Организации") Тогда
								НоваяСтрока.ВладелецПунктаПогрузкиИНН = ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель.ИНН;
							КонецЕсли;
						Иначе
							НоваяСтрока.ВладелецПунктаПогрузкиНаименование = Строка(ТекПункт.ОтправительПолучатель);
							Если ТипЗнч(ТекПункт.ОтправительПолучатель) = Тип("СправочникСсылка.Контрагенты") Тогда
								НоваяСтрока.ВладелецПунктаПогрузкиИНН = ТекПункт.ОтправительПолучатель.ИНН;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли; 
					МассивПунктов.Добавить(НоваяСтрока);
					НомерСтроки = НомерСтроки + 1;
				КонецЕсли;
			КонецЦикла;
		Иначе
			ПунктПодачи          = ДанныеЗаполнения.АдресОтправленияЗначениеАдреса;
			ДатаПодачи           = ДанныеЗаполнения.ОтправлениеС; 
			ПредельнаяДатаПодачи = ДанныеЗаполнения.ОтправлениеПо;
			ПунктВыгрузки        = ДанныеЗаполнения.АдресНазначенияЗначениеАдреса;
			ДатаВыгрузки         = ДанныеЗаполнения.ДоставкаС; 
			ДатаВыгрузкиКрайняя  = ДанныеЗаполнения.ДоставкаПо;
			
			НоваяСтрока = ЗначенияЗаполненияТитулГрузоотправителяПунктыПогрузкиВыгрузки();
			НоваяСтрока.НомерПп                                 = 1;
			НоваяСтрока.ИдентификаторСтроки                     = Строка(Новый УникальныйИдентификатор());
			НоваяСтрока.Операция                                = "Погрузка";
			НоваяСтрока.ДатаИВремяПогрузкиВыгрузки              = ДатаПодачи;
			НоваяСтрока.КрайнееВремяПодачиТС                    = ПредельнаяДатаПодачи;
			
			НоваяСтрока.ВладелецПунктаПогрузкиНаименование      = Строка(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель);
			Если ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) = Тип("СправочникСсылка.Контрагенты")
				ИЛИ ТипЗнч(ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель) = Тип("СправочникСсылка.Организации") Тогда
				НоваяСтрока.ВладелецПунктаПогрузкиИНН = ДанныеПоДокументамОснованиям.СсылкаТитулГрузоотправителяГрузоотправитель.ИНН;
			КонецЕсли;
						
			СтруктураАдреса = Новый Структура();
			ДополнитьСтруктуру(НоваяСтрока, 
			ДанныеЗаполненияАдрес(ПунктПодачи, "АдресПунктаПогрузки",
			СтруктураАдреса, Ложь),
			Истина);
			НоваяСтрока.ПредставлениеАдресПунктаПогрузки        = Строка(ДанныеЗаполнения.АдресОтправления);
			МассивПунктов.Добавить(НоваяСтрока);
			
			НоваяСтрока = ЗначенияЗаполненияТитулГрузоотправителяПунктыПогрузкиВыгрузки();
			НоваяСтрока.НомерПп                                 = 2;
			НоваяСтрока.ИдентификаторСтроки                     = Строка(Новый УникальныйИдентификатор());
			НоваяСтрока.Операция                                = "Выгрузка";
			НоваяСтрока.ДатаИВремяПогрузкиВыгрузки              = ДатаВыгрузки;
			НоваяСтрока.КрайнееВремяПодачиТС                    = ДатаВыгрузкиКрайняя;
			
			СтруктураАдреса = Новый Структура();
			ДополнитьСтруктуру(НоваяСтрока, 
			ДанныеЗаполненияАдрес(ПунктВыгрузки, "АдресПунктаПогрузки",
			СтруктураАдреса, Ложь),
			Истина);
			НоваяСтрока.ПредставлениеАдресПунктаПогрузки        = Строка(ДанныеЗаполнения.АдресНазначения);
			МассивПунктов.Добавить(НоваяСтрока);
		КонецЕсли;
		
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяЗаявленныеДатаВремяПодачи",                ДатаПодачи);
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяЗаявленныеДатаВремяПодачиИспользуетсяUTC", Истина); 
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяПредельныеДатаВремяПодачи",                ПредельнаяДатаПодачи);
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяПредельныеДатаВремяПодачиИспользуетсяUTC", Истина); 
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяАдресаПунктовПогрузкиИВыгрузки",           МассивПунктов);
		
		СтруктураАдреса = Новый Структура();
		ДополнитьСтруктуру(ДанныеПоДокументамОснованиям, 
		ДанныеЗаполненияАдрес(ПунктПодачи, "ТитулГрузоотправителяАдресПогрузки",
		СтруктураАдреса, Ложь),
		Истина);
		
		// Грузы  
		Если Константы.уатЕдиницаИзмеренияВеса.Получить() = Перечисления.уатЕдиницыИзмеренияВеса.Килограмм Тогда 
			КоэфВеса = 1;
		Иначе 
			КоэфВеса = 1000;
		КонецЕсли;
		
		Если Константы.уатЕдиницаИзмеренияОбъема.Получить() = Перечисления.уатЕдиницыИзмеренияОбъема.Литр Тогда 
			КоэфОбъема = 1000;
		Иначе 
			КоэфОбъема = 1;
		КонецЕсли;
		МассивГрузов = Новый Массив();
		Для Каждого ТекГруз Из тзДанныеЗаполнения Цикл
			ВесНетто  = ТекГруз.ВесБрутто * КоэфВеса; // Реквизит ВесБрутто, но реально это вес нетто
			Объем     = ТекГруз.Объем / КоэфОбъема;
			ВесТары   = ТекГруз.ВесТары * КоэфВеса;
			
			НоваяСтрока = ЗначенияЗаполненияТитулГрузоотправителяГрузыЭЗЗ();
			НоваяСтрока.ИдентификаторСтроки                     = Строка(Новый УникальныйИдентификатор());
			НоваяСтрока.ОтгрузочноеНаименованиеГруза            = ТекГруз.ОписаниеГруза;
			НоваяСтрока.КоличествоГрузовыхМест                  = ТекГруз.КоличествоМест;
			НоваяСтрока.ОбъемГруза                              = Объем; 
			НоваяСтрока.МассаБрутто = ВесНетто + ?(ВесТары, ВесТары, 0);
			НоваяСтрока.МассаНетто  = ВесНетто; 
			
			МассивГрузов.Добавить(НоваяСтрока);
		КонецЦикла;
		ДанныеПоДокументамОснованиям.Вставить("ТитулГрузоотправителяГрузы", МассивГрузов);
	КонецЕсли;

	Возврат ДанныеПоДокументамОснованиям;
	
КонецФункции

Функция ПолучитьТекстЗапросаДляЭЗЗ()

	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	тзРейсы.Заказ КАК Заказ,
	               |	тзРейсы.Рейс КАК Рейс
	               |ПОМЕСТИТЬ втРейсы
	               |ИЗ
	               |	&тзРейсы КАК тзРейсы
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	втРейсы.Заказ КАК Заказ,
	               |	втРейсы.Рейс КАК Рейс,
	               |	уатМаршрутныйЛист.ТС КАК ТС,
	               |	уатМаршрутныйЛист.Водитель1 КАК Водитель1,
	               |	уатМаршрутныйЛист.Водитель2 КАК Водитель2,
	               |	уатМаршрутныйЛист.Контрагент КАК Контрагент,
	               |	уатМаршрутныйЛист.Ответственный КАК Ответственный,
	               |	уатМаршрутныйЛист.Организация КАК Организация,
	               |	уатМаршрутныйЛист.ВалютаДокумента КАК ВалютаДокумента,
	               |	уатМаршрутныйЛист.Дата КАК Дата
	               |ПОМЕСТИТЬ втВыборка
	               |ИЗ
	               |	втРейсы КАК втРейсы
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	               |		ПО втРейсы.Рейс = уатМаршрутныйЛист.Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	втРейсы.Заказ,
	               |	втРейсы.Рейс,
	               |	уатЗаказПеревозчику_уэ.ТС,
	               |	уатЗаказПеревозчику_уэ.Водитель,
	               |	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка),
	               |	уатЗаказПеревозчику_уэ.Контрагент,
	               |	уатЗаказПеревозчику_уэ.Ответственный,
	               |	уатЗаказПеревозчику_уэ.Организация,
	               |	уатЗаказПеревозчику_уэ.ВалютаДокумента,
	               |	уатЗаказПеревозчику_уэ.Дата
	               |ИЗ
	               |	втРейсы КАК втРейсы
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.уатЗаказПеревозчику_уэ КАК уатЗаказПеревозчику_уэ
	               |		ПО втРейсы.Рейс = уатЗаказПеревозчику_уэ.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	втВыборка.Контрагент КАК Перевозчик,
	               |	МАКСИМУМ(Контрагенты.Ссылка) КАК Контрагент
	               |ПОМЕСТИТЬ втПеревозчики
	               |ИЗ
	               |	втВыборка КАК втВыборка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО втВыборка.Контрагент.ИНН = Контрагенты.ИНН
	               |			И (НЕ Контрагенты.ПометкаУдаления)
	               |			И (Контрагенты.ИНН <> """")
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	втВыборка.Контрагент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатЗаказГрузоотправителя.Ссылка КАК Заказ,
	               |	втВыборка.Рейс КАК Рейс,
	               |	уатЗаказГрузоотправителя.Номер КАК Номер,
	               |	уатЗаказГрузоотправителя.Дата КАК Дата,
	               |	уатЗаказГрузоотправителя.Организация КАК Организация,
	               |	уатЗаказГрузоотправителя.Грузоотправитель КАК Грузоотправитель,
	               |	ВЫБОР
	               |		КОГДА уатЗаказГрузоотправителя.Организация.ИНН = уатЗаказГрузоотправителя.Контрагент.ИНН
	               |				ИЛИ ТИПЗНАЧЕНИЯ(уатЗаказГрузоотправителя.Контрагент) = ТИП(Справочник.ПодразделенияОрганизаций)
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК ВариантПоДоверенностиЗаГрузоотправителя,
	               |	ЕСТЬNULL(втВыборка.Организация, ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)) КАК ОрганизацияРейс,
	               |	уатЗаказГрузоотправителя.Контрагент КАК Контрагент,
	               |	ЕСТЬNULL(втВыборка.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК КонтрагентРейс,
	               |	уатЗаказГрузоотправителя.Ответственный КАК Ответственный,
	               |	уатЗаказГрузоотправителя.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	уатЗаказГрузоотправителя.ДоговорКонтрагента.Наименование КАК ДоговорКонтрагентаНаименование,
	               |	уатЗаказГрузоотправителя.ДоговорКонтрагента.Номер КАК ДоговорКонтрагентаНомер,
	               |	уатЗаказГрузоотправителя.ДоговорКонтрагента.Дата КАК ДоговорКонтрагентаДата,
	               |	уатЗаказГрузоотправителя.ДоговорКонтрагента.ТипДокументаЗаказЗаявка КАК ТипДокументаЗаказЗаявка,
	               |	уатЗаказГрузоотправителя.АдресОтправления КАК АдресОтправления,
	               |	уатЗаказГрузоотправителя.АдресНазначения КАК АдресНазначения,
	               |	уатЗаказГрузоотправителя.АдресОтправления.ЗначениеАдреса КАК АдресОтправленияЗначениеАдреса,
	               |	уатЗаказГрузоотправителя.АдресНазначения.ЗначениеАдреса КАК АдресНазначенияЗначениеАдреса,
	               |	уатЗаказГрузоотправителя.ОтправлениеС КАК ОтправлениеС,
	               |	уатЗаказГрузоотправителя.ОтправлениеПо КАК ОтправлениеПо,
	               |	уатЗаказГрузоотправителя.ДоставкаС КАК ДоставкаС,
	               |	уатЗаказГрузоотправителя.ДоставкаПо КАК ДоставкаПо,
	               |	уатЗаказГрузоотправителя.НазваниеГруза КАК ОписаниеГруза,
	               |	уатЗаказГрузоотправителя.КоличествоМест КАК КоличествоМест,
	               |	уатЗаказГрузоотправителя.ВесБрутто КАК ВесБрутто,
	               |	уатЗаказГрузоотправителя.Объем КАК Объем,
	               |	уатЗаказГрузоотправителя.ТребованиеКТС КАК ТребованиеКТС,
	               |	уатЗаказГрузоотправителя.ТребованиеКТСТипТС КАК ТребованиеКТСТипТС,
	               |	уатЗаказГрузоотправителя.КонтактноеЛицоЗаказчика КАК КонтактноеЛицоЗаказчика,
	               |	уатЗаказГрузоотправителя.FTL КАК FTL,
	               |	втВыборка.ТС КАК ТС,
	               |	втВыборка.ТС.ГосударственныйНомер КАК ТСГосударственныйНомер,
	               |	втВыборка.ТС.ТипВладенияТС КАК ТСТипВладенияТС,
	               |	втВыборка.ТС.ТипТС.Наименование КАК ТСТип,
	               |	втВыборка.ТС.Модель КАК ТСМодель,
	               |	втВыборка.ТС.Марка КАК ТСМарка,
	               |	втВыборка.ТС.Грузоподъемность КАК ТСГрузоподъемность,
	               |	втВыборка.ТС.Модель.Грузоподъемность КАК МодельТСГрузоподъемность,
	               |	втВыборка.ТС.ОбъемКузова КАК ТСОбъемКузова,
	               |	втВыборка.ТС.Модель.ОбъемКузова КАК МодельТСОбъемКузова,
	               |	втВыборка.Водитель1 КАК Водитель1,
	               |	втВыборка.Водитель2 КАК Водитель2,
	               |	уатЗаказГрузоотправителя.ПромежуточныеПункты.(
	               |		НомерСтроки КАК НомерСтроки,
	               |		Пункт КАК Пункт,
	               |		ТипТочкиМаршрута КАК ТипТочкиМаршрута,
	               |		ОтправительПолучатель КАК ОтправительПолучатель,
	               |		ПрибытиеПлан КАК ПрибытиеПлан,
	               |		УбытиеПлан КАК УбытиеПлан,
	               |		Пункт.ЗначениеАдреса КАК ПунктЗначениеАдреса
	               |	) КАК ПромежуточныеПункты,
	               |	уатЗаказГрузоотправителя.ВалютаДокумента КАК ВалютаДокумента,
	               |	втВыборка.ВалютаДокумента КАК ВалютаДокументаРейс,
	               |	втВыборка.Дата КАК ДатаРейса,
	               |	ВЫБОР
	               |		КОГДА ТИПЗНАЧЕНИЯ(втВыборка.Контрагент) = ТИП(Справочник.Организации)
	               |			ТОГДА ЕСТЬNULL(втПеревозчики.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка))
	               |		ИНАЧЕ втВыборка.Контрагент
	               |	КОНЕЦ КАК Перевозчик,
	               |	уатЗаказГрузоотправителя.ВесТары КАК ВесТары
	               |ИЗ
	               |	втРейсы КАК втРейсы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ втВыборка КАК втВыборка
	               |			ЛЕВОЕ СОЕДИНЕНИЕ втПеревозчики КАК втПеревозчики
	               |			ПО втВыборка.Контрагент = втПеревозчики.Перевозчик
	               |		ПО втРейсы.Заказ = втВыборка.Заказ
	               |			И втРейсы.Рейс = втВыборка.Рейс
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
	               |		ПО втРейсы.Заказ = уатЗаказГрузоотправителя.Ссылка";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ИдентификаторОтправителяЭЗЗ(Объект)

	Результат = Неопределено;
	
	ТипОрганизация = ОбменСГИСЭПДВызовСервера.ПолучитьТипОрганизация();
	Если (ЗначениеЗаполнено(Объект.СсылкаТитулГрузоотправителяСоставитель) 
		И ТипЗнч(Объект.СсылкаТитулГрузоотправителяСоставитель) = ТипОрганизация)
		ИЛИ ТипЗнч(Объект.СсылкаТитулГрузоотправителяГрузоотправитель) = ТипОрганизация Тогда
		Результат = Объект.ИдентификаторГрузоотправителя;
	Иначе
		Результат = Объект.ИдентификаторПеревозчика;	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

