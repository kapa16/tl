Функция ПолучитьQRЭПЛ(ЭПЛ, Отправитель, УИДМинтранс) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ЭПЛ", ЭПЛ);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	               |	уатСвязанныеДокументыЭПД.QR КАК QR
	               |ИЗ
	               |	РегистрСведений.уатСвязанныеДокументыЭПД КАК уатСвязанныеДокументыЭПД
	               |ГДЕ
	               |	уатСвязанныеДокументыЭПД.ЭПД = &ЭПЛ";
	Выборка = Запрос.Выполнить().Выбрать(); 

	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.QR) Тогда
			Возврат Выборка.QR;
		КонецЕсли;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Отправитель", Отправитель);
	Запрос.Текст = "ВЫБРАТЬ
	|	ТокеныАвторизацииЭПД.Токен КАК Токен
	|ИЗ
	|	РегистрСведений.ТокеныАвторизацииЭПД КАК ТокеныАвторизацииЭПД
	|ГДЕ
	|	ТокеныАвторизацииЭПД.Отправитель = &Отправитель";
	
	Выборка = Запрос.Выполнить().Выбрать();

	Base64QR = "";
	Если Выборка.Следующий() Тогда
		Попытка
			ДвоичныеДанныеQR = ОбменСГИСЭПД.ПолучитьQRКодОтОператора(Отправитель, УИДМинтранс, Выборка.Токен);
			Base64QR         = Base64Строка(ДвоичныеДанныеQR);
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если ЗначениеЗаполнено(Base64QR) Тогда
		НаборЗаписей = РегистрыСведений.уатСвязанныеДокументыЭПД.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ЭПД.Установить(ЭПЛ); 
		НаборЗаписей.Прочитать();
		
		Для Каждого Запись из НаборЗаписей Цикл
			Запись.QR = Base64QR;
		КонецЦикла; 
		НаборЗаписей.Записать(); 
	КонецЕсли;
	Возврат СтрЗаменить(Base64QR, Символы.ПС, "");
	
КонецФункции

Функция ПолучитьQRЭПЛДлительнаяОперация(СтруктураПараметров, АдресХранилища = Неопределено) Экспорт
	
	Base64QR = ПолучитьQRЭПЛ(СтруктураПараметров.ЭПЛ, СтруктураПараметров.Отправитель, СтруктураПараметров.УИДМинтранс); 
	
	Просрочен = Ложь;
	Если ЗначениеЗаполнено(Base64QR) Тогда 
		СтруктураРеквизитов = Неопределено;
		ОбменСГИСЭПД.ЗаполнитьТаблицуЗначенийРеквизитов(СтруктураПараметров.ЭПЛ, СтруктураПараметров.ЭПЛ.Организация, СтруктураРеквизитов);
		ВыбранныйТитул = Перечисления.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул1;
		РеквизитыТекущейВерсииТитула = ОбменСГИСЭПД.ПолучитьВерсиюТитулаДокумента(СтруктураРеквизитов, ВыбранныйТитул, 0);
		
		ДатаОкончанияСрокаИспользованияПутевогоЛиста = Дата(1,1,1);
		Если РеквизитыТекущейВерсииТитула.Свойство("ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста") Тогда
			ДатаОкончанияСрокаИспользованияПутевогоЛиста = РеквизитыТекущейВерсииТитула.ТитулОформлениеДатаОкончанияСрокаИспользованияПутевогоЛиста;
			Если НЕ ЗначениеЗаполнено(ДатаОкончанияСрокаИспользованияПутевогоЛиста)
				И РеквизитыТекущейВерсииТитула.Свойство("ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован") Тогда
				ДатаОкончанияСрокаИспользованияПутевогоЛиста = РеквизитыТекущейВерсииТитула.ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован;
			КонецЕсли;
		ИначеЕсли РеквизитыТекущейВерсииТитула.Свойство("ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован") Тогда
			ДатаОкончанияСрокаИспользованияПутевогоЛиста = РеквизитыТекущейВерсииТитула.ТитулОформлениеДатаВТечениеКоторойПутевойЛистМожетБытьИспользован;
		КонецЕсли;
		Просрочен = НЕ НачалоДня(ДатаОкончанияСрокаИспользованияПутевогоЛиста) >= НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;
	
	Если АдресХранилища <> Неопределено Тогда
		ПоместитьВоВременноеХранилище(Новый Структура("ЕстьQR, Просрочен", ЗначениеЗаполнено(Base64QR), Просрочен), АдресХранилища);
	КонецЕсли; 
	
КонецФункции

Процедура СохранитьQRЭПЛ(ДвоичныеДанныеQR, Отправитель, УИДМинтранс) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("УИДМинтранс", УИДМинтранс);
	Запрос.УстановитьПараметр("ИдентификаторОформителя", Отправитель);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	               |	уатСвязанныеДокументыЭПД.ЭПД КАК ЭПД
	               |ИЗ
	               |	РегистрСведений.уатСвязанныеДокументыЭПД КАК уатСвязанныеДокументыЭПД
	               |ГДЕ
	               |	уатСвязанныеДокументыЭПД.ЭПД.УИДМинтранс = &УИДМинтранс
	               |	И уатСвязанныеДокументыЭПД.ЭПД.ИдентификаторОформителя = &ИдентификаторОформителя";
	Выборка = Запрос.Выполнить().Выбрать(); 

	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.ЭПД) Тогда
			Base64QR = Base64Строка(ДвоичныеДанныеQR);
			Если ЗначениеЗаполнено(Base64QR) Тогда
				НаборЗаписей = РегистрыСведений.уатСвязанныеДокументыЭПД.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ЭПД.Установить(Выборка.ЭПД); 
				НаборЗаписей.Прочитать();
				
				Для Каждого Запись из НаборЗаписей Цикл
					Запись.QR = Base64QR;
				КонецЦикла; 
				НаборЗаписей.Записать(); 
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьПрицепПЛ(ТекПЛ, НомерПрицепа) Экспорт
	Возврат ТекПЛ.Прицепы[НомерПрицепа].ТС;
КонецФункции

Функция ПолучитьТекстОшибкиЗаполненияСвМедРаб(ТекПЛ, ЭПЛ) Экспорт
	ТекстОшибки = ""; 
	СтруктураРеквизитов = Неопределено;
	ОбменСГИСЭПД.ЗаполнитьТаблицуЗначенийРеквизитов(ЭПЛ, ЭПЛ.Организация, СтруктураРеквизитов);

	Если ЗначениеЗаполнено(ЭПЛ.ТитулВыездИдентификаторФайла) Тогда
		ВыбранныйТитул = Перечисления.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул6;
	Иначе
		ВыбранныйТитул = Перечисления.ТипыЭлементовРегламентаЭДО.ЭПЛ_Титул2;
	КонецЕсли; 
	РеквизитыТекущейВерсииТитула = ОбменСГИСЭПД.ПолучитьВерсиюТитулаДокумента(СтруктураРеквизитов, ВыбранныйТитул, 0);
	МедРаботник = "";  
	Если РеквизитыТекущейВерсииТитула.Свойство("ТитулМедосмотрШтатныйМедработникФамилия") Тогда
		МедРаботник = РеквизитыТекущейВерсииТитула.ТитулМедосмотрШтатныйМедработникФамилия + " "
			+ РеквизитыТекущейВерсииТитула.ТитулМедосмотрШтатныйМедработникИмя + " "
			+ РеквизитыТекущейВерсииТитула.ТитулМедосмотрШтатныйМедработникОтчество;
	КонецЕсли;
	ТекстОшибки = Нстр("ru = 'лицензии на осуществление медицинской деятельности'; en = 'licenses for medical activities'") + 
		?(ЗначениеЗаполнено(МедРаботник), " (" + МедРаботник + ")", "");
	Возврат ТекстОшибки;
КонецФункции

