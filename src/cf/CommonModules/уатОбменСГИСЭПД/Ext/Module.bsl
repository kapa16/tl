	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.ПрицепСамосвал,   Нстр("ru = 'Специальный прицеп'; en = 'Special trailer'"));  
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.ПрицепЦистерна,   Нстр("ru = 'Специальный прицеп'; en = 'Special trailer'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.Рефрижератор,     Нстр("ru = 'Специальный грузовой автомобиль'; en = 'Special cargo vehicle'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.Самосвал,         Нстр("ru = 'Специальный грузовой автомобиль'; en = 'Special cargo vehicle'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.СедельныйТягач,   Нстр("ru = 'Седельный тягач'; en = 'Tractor'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.Специальный,      Нстр("ru = 'Специальный грузовой автомобиль'; en = 'Special cargo vehicle'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.Цистерна,         Нстр("ru = 'Специальный грузовой автомобиль'; en = 'Special cargo vehicle'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.Строительный,     Нстр("ru = 'Специальный грузовой автомобиль'; en = 'Special cargo vehicle'"));
	СоответвиеТипов.Вставить(Перечисления.уатВидыТС.ПустаяСсылка(),   Нстр("ru = 'Грузовой автомобиль общего назначения'; en = 'General purpose truck'"));
	
