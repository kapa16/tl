Функция СериализоватьTaxiOrders(Знач TaxiOrders, ОтправлятьАдресНазначенияВОткрытыхЗаказах, ОдинЗаказ = Ложь) Экспорт
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("UTF-8");
	
	// Начало "response"
	ЗаписьXML.ЗаписатьНачалоЭлемента("response");

	// Начало "OrdersForRepairs"
	Если НЕ ОдинЗаказ Тогда
		ЗаписьXML.ЗаписатьНачалоЭлемента("orders");
	КонецЕсли;
	
	Пока TaxiOrders.Следующий() Цикл
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("order");
		
		Если TaxiOrders.ЕстьТаксометр Тогда
			ЗаписьXML.ЗаписатьНачалоЭлемента("taximeter");
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("transportingDistance");
			ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.ТаксометрПробегПоПоездке, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("transportingDuration");
			ЗаписьXML.ЗаписатьТекст(Формат(?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяПоПоездке), 0, TaxiOrders.ТаксометрВремяПоПоездке * 60), "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("waitingTime");
			ЗаписьXML.ЗаписатьТекст(Формат(?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяОжидания), 0, TaxiOrders.ТаксометрВремяОжидания * 60), "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("pickupDistance");
			ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.ТаксометрПробегПодачи, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("pickupDuration");
			ЗаписьXML.ЗаписатьТекст(Формат(?(НЕ ЗначениеЗаполнено(TaxiOrders.ТаксометрВремяПодачи), 0, TaxiOrders.ТаксометрВремяПодачи * 60), "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("pickupStartDate");
			ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаНаПодачу));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("waitingStartDate");
			ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаОжидания));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("factStartTime");
			ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ТаксометрДатаНачалаПоездки));
			ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("orderID");
		ЗаписьXML.ЗаписатьТекст(Строка(TaxiOrders.Ссылка.УникальныйИдентификатор()));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("orderNumber");
		ЗаписьXML.ЗаписатьТекст(Строка(TaxiOrders.Номер));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("timeStart");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяПодачи));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("latStart");
		ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.ЛатПодачи, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("lonStart");
		ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.ЛонПодачи, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		Если (TaxiOrders.openOrder 
			И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
			ИЛИ НЕ TaxiOrders.openOrder Тогда
			ЗаписьXML.ЗаписатьНачалоЭлемента("latEnd");
			ЗаписьXML.ЗаписатьТекст(Формат(?(НЕ ЗначениеЗаполнено(TaxiOrders.ЛатНазначения), 0, TaxiOrders.ЛатНазначения), "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("lonEnd");
			ЗаписьXML.ЗаписатьТекст(Формат(?(НЕ ЗначениеЗаполнено(TaxiOrders.ЛонНазначения), 0, TaxiOrders.ЛонНазначения), "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			adrEnd = Строка(TaxiOrders.АдресНазначения);
			Если ЗначениеЗаполнено(TaxiOrders.КомментарийНазначения) тогда
				adrEnd = adrEnd + " (" + TaxiOrders.КомментарийНазначения + ")";
			КонецЕсли;
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("adrEnd");
			ЗаписьXML.ЗаписатьТекст(adrEnd);
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		adrStart = Строка(TaxiOrders.АдресПодачи);
		Если ЗначениеЗаполнено(TaxiOrders.КомментарийПодачи) тогда
			adrStart = adrStart + " (" + TaxiOrders.КомментарийПодачи + ")";
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("adrStart");
		ЗаписьXML.ЗаписатьТекст(adrStart);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		СправочникФормаОплаты = TaxiOrders.ФормаОплаты;
		Если СправочникФормаОплаты.ФормаОплаты = Перечисления.уатФормыОплаты.Наличные Тогда
			paymentType = "cash"; 
		Иначе
			paymentType = "card";
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("paymentType");
		ЗаписьXML.ЗаписатьТекст(Строка(paymentType));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		СтруктураОбъектовНастроек = Новый Структура;
		СтруктураОбъектовНастроек.Вставить("Организация",   TaxiOrders.Ссылка.Организация);
		СтруктураОбъектовНастроек.Вставить("Подразделение", TaxiOrders.Ссылка.Подразделение);
		
		changeMainServices = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.ИспользоватьДанныеТаксометраВодительУАТДляПересчетаУслуг); 
		ЗаписьXML.ЗаписатьНачалоЭлемента("changeMainServices");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(changeMainServices));
		ЗаписьXML.ЗаписатьКонецЭлемента();

		changeAdditionalServices = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, ПланыВидовХарактеристик.уатПраваИНастройки.РазрешитьПересчетДополнительныхУслугВодительУАТ);
		ЗаписьXML.ЗаписатьНачалоЭлемента("changeAdditionalServices");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(changeAdditionalServices));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("openOrder");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(TaxiOrders.openOrder));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("currentStatus");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.ПолучитьИмяСтатусаЗаказаТакси(TaxiOrders.Статус));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("notes");
		ЗаписьXML.ЗаписатьТекст(TaxiOrders.ПримечаниеДиспетчеру);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		distance = ?(ЗначениеЗаполнено(TaxiOrders.КоличествоКмФакт), TaxiOrders.КоличествоКмФакт,  TaxiOrders.КоличествоКм);
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("distance");
		ЗаписьXML.ЗаписатьТекст(Формат(distance, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		duration = ?(ЗначениеЗаполнено(TaxiOrders.КоличествоМинФакт), TaxiOrders.КоличествоМинФакт,  TaxiOrders.КоличествоМин); 
		ЗаписьXML.ЗаписатьНачалоЭлемента("duration");
		ЗаписьXML.ЗаписатьТекст(Формат(duration, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("factStartTime");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяПодачиФактическое));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("factEndTime");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьДатаВремя(TaxiOrders.ВремяОкончанияФактическое));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("isPaid");
		ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(TaxiOrders.Оплачено));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("waitingTime");
		ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.ВремяОжиданияОбщее, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("contacts");
		
		customerName  = TaxiOrders.ЗаказчикНаименование;
		customerPhone = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		TaxiOrders.Заказчик, 
		Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента
		);
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("contact");
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("name");
		ЗаписьXML.ЗаписатьТекст(Строка(customerName));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("phone");
		ЗаписьXML.ЗаписатьТекст(Строка(customerPhone));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("role");
		ЗаписьXML.ЗаписатьТекст("customer");
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		Если ЗначениеЗаполнено(TaxiOrders.КонтактноеЛицо) Тогда 
			Если ТипЗнч(TaxiOrders.КонтактноеЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
				Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				TaxiOrders.КонтактноеЛицо, 
				Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
				); 
			Иначе 
				Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				TaxiOrders.КонтактноеЛицо, 
				Справочники.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица
				);
			КонецЕсли;
			ЗаписьXML.ЗаписатьНачалоЭлемента("contact");
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("name");
			ЗаписьXML.ЗаписатьТекст(Строка(TaxiOrders.КонтактноеЛицоНаименование));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("phone");
			ЗаписьXML.ЗаписатьТекст(Строка(Телефон));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("role");
			ЗаписьXML.ЗаписатьТекст("contact");
			ЗаписьXML.ЗаписатьКонецЭлемента(); 
			
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		Если TaxiOrders.ЗаказчикЮрФизЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
			customerName  = TaxiOrders.ЗаказчикНаименование;
			customerPhone = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			TaxiOrders.Заказчик, 
			Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента
			);
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("contact");
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("name");
			ЗаписьXML.ЗаписатьТекст(Строка(customerName));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("phone");
			ЗаписьXML.ЗаписатьТекст(Строка(customerPhone));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("role");
			ЗаписьXML.ЗаписатьТекст("passenger");
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьКонецЭлемента();
		Иначе
			Если ЗначениеЗаполнено(TaxiOrders.Пассажир) Тогда 
				ЗаписьXML.ЗаписатьНачалоЭлемента("contact");
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("name");
				ЗаписьXML.ЗаписатьТекст(Строка(TaxiOrders.Пассажир));
				ЗаписьXML.ЗаписатьКонецЭлемента();
				
				Если ТипЗнч(TaxiOrders.Пассажир) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
					Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
					TaxiOrders.Пассажир, 
					Справочники.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица
					); 
				Иначе 
					Телефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
					TaxiOrders.Пассажир, 
					Справочники.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица
					);
				КонецЕсли;
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("phone");
				ЗаписьXML.ЗаписатьТекст(Строка(Телефон));
				ЗаписьXML.ЗаписатьКонецЭлемента();
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("role");
				ЗаписьXML.ЗаписатьТекст("passenger");
				ЗаписьXML.ЗаписатьКонецЭлемента();
				
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЕсли; 
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("carriageRequirements");
		Для Каждого ТекХарактеристика Из TaxiOrders.Ссылка.ТребованияКПеревозке Цикл  
			ЗаписьXML.ЗаписатьНачалоЭлемента("requirement");
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("requirementID");
			ЗаписьXML.ЗаписатьТекст(Строка(ТекХарактеристика.Характеристика.УникальныйИдентификатор()));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("requirementName");
			ЗаписьXML.ЗаписатьТекст(Строка(ТекХарактеристика.Характеристика));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЦикла;
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		discountSum = 0;
		ЗаписьXML.ЗаписатьНачалоЭлемента("services");
		
		НомерСтроки = 1;
		Для Каждого ТекУслуга Из TaxiOrders.Ссылка.Услуги Цикл  
			discountSum = discountSum + ТекУслуга.СуммаСкидки;
			ЗаписьXML.ЗаписатьНачалоЭлемента("service");
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("serviceNumber");
			ЗаписьXML.ЗаписатьТекст(Формат(НомерСтроки, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("serviceID");
			ЗаписьXML.ЗаписатьТекст(Строка(ТекУслуга.Номенклатура.УникальныйИдентификатор()));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("serviceName");
			ЗаписьXML.ЗаписатьТекст(Строка(ТекУслуга.Номенклатура));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("serviceAmount");
			ЗаписьXML.ЗаписатьТекст(Формат(ТекУслуга.Количество, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();   
			
			Если (TaxiOrders.openOrder 
				И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
				ИЛИ НЕ TaxiOrders.openOrder Тогда
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("servicePrice");
				ЗаписьXML.ЗаписатьТекст(Формат(ТекУслуга.Цена, "ЧРД=.; ЧН=0; ЧГ=0"));
				ЗаписьXML.ЗаписатьКонецЭлемента();
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("serviceSum");
				ЗаписьXML.ЗаписатьТекст(Формат(ТекУслуга.Сумма, "ЧРД=.; ЧН=0; ЧГ=0"));
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЕсли;   
			
			Если ТекУслуга.Трансфер Тогда
				ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
				ЗаписьXML.ЗаписатьТекст(Строка("transfer"));
				ЗаписьXML.ЗаписатьКонецЭлемента(); 
			ИначеЕсли ТекУслуга.Тариф.МетодРасчета = Перечисления.уатМетодыРасчетаПоТарифам.ФиксированнойСуммой Тогда
				ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
				ЗаписьXML.ЗаписатьТекст(Строка("fixed"));
				ЗаписьXML.ЗаписатьКонецЭлемента();
			ИначеЕсли ТекУслуга.Тариф.МетодРасчета = Перечисления.уатМетодыРасчетаПоТарифам.ПоПараметруВыработки Тогда
				Если ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ПробегОбщий Тогда
					ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
					ЗаписьXML.ЗаписатьТекст(Строка("distance"));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				ИначеЕсли ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ВремяВРаботе Тогда
					ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
					ЗаписьXML.ЗаписатьТекст(Строка("time"));
					ЗаписьXML.ЗаписатьКонецЭлемента(); 
				ИначеЕсли ТекУслуга.Тариф.ПараметрВыработки = Справочники.уатПараметрыВыработки.ВремяОжидания Тогда
					ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
					ЗаписьXML.ЗаписатьТекст(Строка("waitingTime"));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				Иначе 
					ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
					ЗаписьXML.ЗаписатьТекст(Строка("additional"));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				КонецЕсли;
			Иначе  
				ЗаписьXML.ЗаписатьНачалоЭлемента("serviceType");
				ЗаписьXML.ЗаписатьТекст(Строка("additional"));
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЕсли;   
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("time");
			ЗаписьXML.ЗаписатьТекст(уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(ТекУслуга.Тариф.ПараметрВыработки.Временный));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьКонецЭлемента(); 
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("discountSum");
		ЗаписьXML.ЗаписатьТекст(Формат(discountSum, "ЧРД=.; ЧН=0; ЧГ=0"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		Если (TaxiOrders.openOrder 
			И ОтправлятьАдресНазначенияВОткрытыхЗаказах)
			ИЛИ НЕ TaxiOrders.openOrder Тогда 
			// Сумма со скидкой
			ЗаписьXML.ЗаписатьНачалоЭлемента("sum");
			ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.СуммаДокумента + discountSum, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("totalSum");
			ЗаписьXML.ЗаписатьТекст(Формат(TaxiOrders.СуммаДокумента, "ЧРД=.; ЧН=0; ЧГ=0"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьКонецЭлемента(); 
		
	КонецЦикла;
	
	Если НЕ ОдинЗаказ Тогда
		ЗаписьXML.ЗаписатьКонецЭлемента();
	КонецЕсли;
	
	// Конец "response"
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции // СериализоватьCarServices()

// Функция предназначена для преобразования времени в числовом формате (где целая часть представляет собой количество 
// часов, а дробная - количество минут), используемого в конфигурации, в число секунд.
//
// Параметры:
//  ВремяЧЧММ - дата - дата во внутреннем формате 1С
//
// Возвращаемое значение:
//   Число    - количество секунд, сформированное из переданного времени
//
Функция СериализоватьВремяЧисломЧЧММ(Знач ВремяЧЧММ)
	
	Минуты = (ВремяЧЧММ - Цел(ВремяЧЧММ))*100;
	Часы   = Цел(ВремяЧЧММ);
	
	Секунд = Минуты*60 + Часы*3600;
	
	Возврат Формат(Секунд, "ЧН=0; ЧГ=0");
	
КонецФункции // СериализоватьВремяЧисломЧЧММ()

Процедура ЗаполнитьКонтИнформациюFTLЗаказа(ЗаказСсылка, ПунктСсылка, ЗаписьXML, КонтрагентСсылка = Неопределено)
	
	стрНастройкиВидовКонтактнойИнформации = уатОбщегоНазначенияПовтИсп_проф.ПолучитьНастройкиВидовКонтактнойИнформации();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",        ЗаказСсылка);
	Запрос.УстановитьПараметр("ПунктСсылка",   ПунктСсылка);
	
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииТелефонКонтрагента",     стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииТелефонКонтрагента);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииEmailКонтрагента",       стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииEmailКонтрагента);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииТелефонКонтактногоЛица", стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииТелефонКонтактногоЛица);
	Запрос.УстановитьПараметр("ВидКонтактнойИнформацииEmailКонтактногоЛица",   стрНастройкиВидовКонтактнойИнформации.видКонтактнойИнформацииEmailКонтактногоЛица);

	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.ОтправительПолучатель КАК КонтрагентСсылка,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.КонтактноеЛицо КАК КонтактноеЛицоСсылка,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.НомерСтроки КАК НомерСтроки,
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.ТипТочкиМаршрута КАК ТипТочкиМаршрута
	               |ПОМЕСТИТЬ ВТ_Заказ
	               |ИЗ
	               |	Документ.уатЗаказГрузоотправителя.ПромежуточныеПункты КАК уатЗаказГрузоотправителяПромежуточныеПункты
	               |ГДЕ
	               |	уатЗаказГрузоотправителяПромежуточныеПункты.Ссылка = &Ссылка
	               |	И уатЗаказГрузоотправителяПромежуточныеПункты.Пункт = &ПунктСсылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВТ_Заказ.КонтрагентСсылка КАК КонтрагентСсылка,
	               |	ВТ_Заказ.КонтактноеЛицоСсылка КАК КонтактноеЛицоСсылка,
	               |	ВТ_Заказ.НомерСтроки КАК НомерСтроки,
	               |	ВТ_Заказ.ТипТочкиМаршрута КАК ТипТочкиМаршрута
	               |ИЗ
	               |	ВТ_Заказ КАК ВТ_Заказ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВТ_Заказ.КонтрагентСсылка КАК КонтрагентСсылка,
	               |	ВТ_Заказ.КонтактноеЛицоСсылка КАК КонтактноеЛицоСсылка,
	               |	ВЫБОР
	               |		КОГДА КИ_ТелефоныКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |			ТОГДА ВЫБОР
	               |					КОГДА КИ_ТелефоныОснКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |						ТОГДА ЕСТЬNULL(КИ_ТелефоныКонтрагентов.Представление, """")
	               |					ИНАЧЕ КИ_ТелефоныОснКонтЛицКонтрагентов.Представление
	               |				КОНЕЦ
	               |		ИНАЧЕ КИ_ТелефоныКонтЛицКонтрагентов.Представление
	               |	КОНЕЦ КАК ТелефонКонтрагента,
	               |	ВЫБОР
	               |		КОГДА КИ_ПочтаКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |			ТОГДА ВЫБОР
	               |					КОГДА КИ_ПочтаОснКонтЛицКонтрагентов.Представление ЕСТЬ NULL
	               |						ТОГДА ЕСТЬNULL(КИ_ПочтаКонтрагентов.Представление, """")
	               |					ИНАЧЕ КИ_ПочтаОснКонтЛицКонтрагентов.Представление
	               |				КОНЕЦ
	               |		ИНАЧЕ КИ_ПочтаКонтЛицКонтрагентов.Представление
	               |	КОНЕЦ КАК ПочтаКонтрагента,
	               |	ВТ_Заказ.НомерСтроки КАК НомерСтроки
	               |ИЗ
	               |	ВТ_Заказ КАК ВТ_Заказ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ТелефоныКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтактноеЛицоСсылка = КИ_ТелефоныКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ПочтаКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтактноеЛицоСсылка = КИ_ПочтаКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ПочтаКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ТелефоныОснКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка.ОсновноеКонтактноеЛицо = КИ_ТелефоныОснКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныОснКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныОснКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ_ТелефоныКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка = КИ_ТелефоныКонтрагентов.Ссылка
	               |			И (КИ_ТелефоныКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	               |			И (КИ_ТелефоныКонтрагентов.Вид = &ВидКонтактнойИнформацииТелефонКонтрагента)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КИ_ПочтаОснКонтЛицКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка.ОсновноеКонтактноеЛицо = КИ_ПочтаОснКонтЛицКонтрагентов.Ссылка
	               |			И (КИ_ПочтаОснКонтЛицКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаОснКонтЛицКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтактногоЛица)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ_ПочтаКонтрагентов
	               |		ПО ВТ_Заказ.КонтрагентСсылка = КИ_ПочтаКонтрагентов.Ссылка
	               |			И (КИ_ПочтаКонтрагентов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	               |			И (КИ_ПочтаКонтрагентов.Вид = &ВидКонтактнойИнформацииEmailКонтрагента)";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Выборка          = РезультатЗапроса[1].Выбрать();
	ВыборкаКИ        = РезультатЗапроса[2].Выгрузить();
	
	Пока Выборка.Следующий() Цикл
		СтруктураКИ = уатМобильноеПриложениеВодителяСервер.ЗаполнитьКИМЛFTL(ВыборкаКИ, Выборка);
		
		КонтрагентСсылка = Выборка.КонтрагентСсылка;
		Если ЗначениеЗаполнено(СтруктураКИ.ТелефонКонтрагента) Или ЗначениеЗаполнено(СтруктураКИ.ПочтаКонтрагента) Тогда 
			// Начало "contact"
			ЗаписьXML.ЗаписатьНачалоЭлемента("contact");
			Попытка
				ЗаписьXML.ЗаписатьАтрибут("ID", Строка(Выборка.КонтрагентСсылка.УникальныйИдентификатор()));
			Исключение
				ЗаписьXML.ЗаписатьАтрибут("ID", Строка(Новый УникальныйИдентификатор));
			КонецПопытки;
		
			// Начало "name"			
			ЗаписьXML.ЗаписатьНачалоЭлемента("name");
			Если ЗначениеЗаполнено(Выборка.КонтактноеЛицоСсылка) Тогда 
				ЗаписьXML.ЗаписатьТекст(Выборка.КонтактноеЛицоСсылка.Наименование);
			ИначеЕсли ЗначениеЗаполнено(Выборка.КонтрагентСсылка.ОсновноеКонтактноеЛицо) Тогда
				ЗаписьXML.ЗаписатьТекст(Выборка.КонтрагентСсылка.ОсновноеКонтактноеЛицо.Наименование);
			Иначе 
				ЗаписьXML.ЗаписатьТекст(Выборка.КонтрагентСсылка.Наименование);
			КонецЕсли;

			// Конец "name"
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			Если ЗначениеЗаполнено(СтруктураКИ.ТелефонКонтрагента) Тогда 
				// Начало "phone"
				ЗаписьXML.ЗаписатьНачалоЭлемента("phone");
				ЗаписьXML.ЗаписатьТекст(СтруктураКИ.ТелефонКонтрагента);
				// Конец "phone"
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураКИ.ПочтаКонтрагента) Тогда 
				// Начало "email"
				ЗаписьXML.ЗаписатьНачалоЭлемента("email");
				ЗаписьXML.ЗаписатьТекст(СтруктураКИ.ПочтаКонтрагента);
				// Конец "email"
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЕсли;
			
			// Начало "role"
			ЗаписьXML.ЗаписатьНачалоЭлемента("role");
			
			Если Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Погрузка
				ИЛИ Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.ДополнительнаяПогрузка Тогда
				ЗаписьXML.ЗаписатьТекст("sender");
			ИначеЕсли Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.Разгрузка
				ИЛИ Выборка.ТипТочкиМаршрута = Перечисления.уатТипыТочекМаршрута.ДополнительнаяРазгрузка Тогда
				ЗаписьXML.ЗаписатьТекст("receiver");
			Иначе
				ЗаписьXML.ЗаписатьТекст("partner");
			КонецЕсли;
			// Конец "role"
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			// Конец "contact"
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура ЗаписатьБлокProductivity(ЗаписьXML, СтрокаЗаказа)
	
	Если НЕ ЗначениеЗаполнено(СтрокаЗаказа.ПараметрВыработки1)
		И НЕ ЗначениеЗаполнено(СтрокаЗаказа.ПараметрВыработки2) Тогда 
		Возврат;
	КонецЕсли;
	
	Если СтрокаЗаказа.Строки.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрВыработки1 = СтрокаЗаказа.ПараметрВыработки1;
	ПараметрВыработки2 = СтрокаЗаказа.ПараметрВыработки2;
	
	// Начало "productivity"
	ЗаписьXML.ЗаписатьНачалоЭлемента("productivity");
	
	Если НЕ ПараметрВыработки1 = Неопределено Тогда 
		// Начало "item"
		ЗаписьXML.ЗаписатьНачалоЭлемента("item");
		
		ЗаписьXML.ЗаписатьАтрибут("ID",     Строка(ПараметрВыработки1.УникальныйИдентификатор()));
		ЗаписьXML.ЗаписатьАтрибут("name",   ПараметрВыработки1.Наименование);
		ЗаписьXML.ЗаписатьАтрибут("isBool", уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(ПараметрВыработки1.ОтображениеВВидеФлага));
		
		ЗаписьXML.ЗаписатьТекст(Формат(СтрокаЗаказа.Выработка1, "ЧРД=.; ЧН=0; ЧГ=0"));
		
		// Конец "item"
		ЗаписьXML.ЗаписатьКонецЭлемента();
	КонецЕсли;
	
	Если Не ПараметрВыработки2 = Неопределено Тогда 
		// Начало "item"
		ЗаписьXML.ЗаписатьНачалоЭлемента("item");
		
		ЗаписьXML.ЗаписатьАтрибут("ID",     Строка(ПараметрВыработки2.УникальныйИдентификатор()));
		ЗаписьXML.ЗаписатьАтрибут("name",   ПараметрВыработки2.Наименование);
		ЗаписьXML.ЗаписатьАтрибут("isBool", уатМобильноеПриложениеВодителяСервер.СериализоватьБулево(ПараметрВыработки2.ОтображениеВВидеФлага));
		
		ЗаписьXML.ЗаписатьТекст(Формат(СтрокаЗаказа.Выработка2, "ЧРД=.; ЧН=0; ЧГ=0"));
		
		// Конец "item"
		ЗаписьXML.ЗаписатьКонецЭлемента();
	КонецЕсли;
	
	// Конец "productivity"
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

#КонецОбласти

