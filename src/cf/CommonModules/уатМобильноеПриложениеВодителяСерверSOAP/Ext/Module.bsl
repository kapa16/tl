						КонецЕсли;
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("cancelled") Тогда 
						cancelled = уатМобильноеПриложениеВодителяСервер.ДесериализоватьБулево(ЧтениеXML.Значение, флОшибка);
						Если флОшибка Тогда 
							ВызватьИсключение НСтр("en='Error parsing field cancelled';ru='Ошибка разбора поля cancelled'");
						КонецЕсли;
					КонецЕсли;				
				КонецЦикла;
			
			ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента И НРег(ЧтениеXML.Имя) = НРег("services") Тогда 
				serviceAmount = Неопределено;
				serviceID     = Неопределено;
				serviceNumber = Неопределено;
				Пока Не (ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента И НРег(ЧтениеXML.Имя) = НРег("services")) И ЧтениеXML.Прочитать() Цикл
					Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента И НРег(ЧтениеXML.Имя) = НРег("service") Тогда
						serviceAmount = Неопределено;
						serviceID     = Неопределено;
						serviceNumber = Неопределено;
						Пока ЧтениеXML.ПрочитатьАтрибут() Цикл
							Если НРег(ЧтениеXML.Имя) = НРег("serviceID") Тогда
								serviceID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ЧтениеXML.Значение, флОшибка);
								Если флОшибка Тогда 
									ВызватьИсключение НСтр("en='Error parsing GUID';ru='Ошибка разбора GUID'");
								КонецЕсли; 
							ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("serviceAmount") Тогда
								serviceAmount = Число(ЧтениеXML.Значение);
							ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("serviceNumber") Тогда
								serviceNumber = Число(ЧтениеXML.Значение);
							КонецЕсли;
						КонецЦикла;

					ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента И НРег(ЧтениеXML.Имя) = НРег("service")
						И Не serviceID = Неопределено Тогда 
						массивУслуг.Добавить(Новый Структура("serviceID, serviceAmount, serviceNumber",
						serviceID, serviceAmount, serviceNumber));
					КонецЕсли;
				КонецЦикла;
			ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента И НРег(ЧтениеXML.Имя) = НРег("taximeter") Тогда 
				Пока ЧтениеXML.ПрочитатьАтрибут() Цикл
					Если НРег(ЧтениеXML.Имя) = НРег("transportingDistance") Тогда 
						Таксометр.transportingDistance = Число(ЧтениеXML.Значение);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("transportingDuration") Тогда 
						Таксометр.transportingDuration = Число(ЧтениеXML.Значение);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("waitingTime") Тогда 
						Таксометр.waitingTime = Число(ЧтениеXML.Значение);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("pickupDistance") Тогда 
						Таксометр.pickupDistance = Число(ЧтениеXML.Значение);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("pickupDuration") Тогда 
						Таксометр.pickupDuration = Число(ЧтениеXML.Значение);	
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("pickupStartDate") Тогда 
						Таксометр.pickupStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ЧтениеXML.Значение, флОшибка);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("waitingStartDate") Тогда 
						Таксометр.waitingStartDate = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ЧтениеXML.Значение, флОшибка);
					ИначеЕсли НРег(ЧтениеXML.Имя) = НРег("factStartTime") Тогда 
						Таксометр.factStartTime = уатМобильноеПриложениеВодителяСервер.ДесериализоватьДатаВремя(ЧтениеXML.Значение, флОшибка);
					КонецЕсли; 
				КонецЦикла;
			ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента И НРег(ЧтениеXML.Имя) = НРег("order") Тогда
				Если НЕ ТекущийGUID = Неопределено Тогда  
					НовСтр = ТабЗаказов.Добавить();
					НовСтр.orderID        = ТекущийGUID;
					НовСтр.currentStatus  = currentStatus;
					НовСтр.cancelled      = cancelled;
					НовСтр.isPaid         = isPaid;
					НовСтр.services       = массивУслуг;
					НовСтр.taximeter      = Таксометр;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing structures ""order"".';ru='Возникла ошибка при разборе структуры ""order"".'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateTaxiOrder';ru='ДесериализоватьUpdateTaxiOrder'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабЗаказов;
	КонецПопытки;
	
	Попытка
		Для Каждого ТекСтр Из ТабЗаказов Цикл 
			ТекСтр.orderRef = Документы.такЗаказТакси.ПолучитьСсылку(ТекСтр.orderID); 
			Для Каждого ТекСтр Из ТекСтр.services Цикл 
				ТекСтр.Вставить("serviceRef",  Справочники.Номенклатура.ПолучитьСсылку(ТекСтр.serviceID));
			КонецЦикла;
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while receiving document reference by GUID.';ru='Возникла ошибка при получении ссылки на документ по GUID.'");
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьUpdateTaxiOrder';ru='ДесериализоватьUpdateTaxiOrder'"), ТекстНСТР);
		флОшибка = Истина;
		
		Возврат ТабЗаказов;
	КонецПопытки;
	
	Возврат ТабЗаказов;
	
КонецФункции // ДесериализоватьUpdateTaxiOrder()

// Функция предназначена для преобразования xml-строки с данными о удаляемых картинках по 
// маршрутным листам
//
// Параметры:
//  requestData - строка - строка XML, содержащая данные о удаляемых картинках
//  флОшибка    - булево - признак наличия ошибки при десериализации
//
// Возвращаемое значение:
//   массив - массив GUID удаляемых картинок
//
Функция ДесериализоватьDeleteImages(Знач requestData, флОшибка) Экспорт
	
	УдаляемыеФайлы = Новый Массив();
	
	ЧтениеXML = Новый ЧтениеXML;
	
	Попытка
		ЧтениеXML.УстановитьСтроку(requestData);
		
		Пока ЧтениеXML.Прочитать() Цикл 
			Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента И НРег(ЧтениеXML.Имя) = НРег("image") Тогда
				ЧтениеXML.Прочитать();
				
				ТекущийGUID = уатМобильноеПриложениеВодителяСервер.ДесериализоватьGUID(ЧтениеXML.Значение, флОшибка);
				Если флОшибка Тогда 
					ВызватьИсключение НСтр("en='Error while parsing GUID in the image field.';ru='Ошибка разбора GUID в поле image.'");
				КонецЕсли;
				
				УдаляемыеФайлы.Добавить(ТекущийGUID);
			КонецЕсли;
		КонецЦикла;
		
	Исключение
		ТекстНСТР = НСтр("en='Error occurred while parsing the structure ""requestData"". Description of error:';ru='Возникла ошибка при разборе структуры ""requestData"". Описание ошибки:'") + Символы.ПС + ОписаниеОшибки();
		ЗаписатьСообщениеОбОшибке(НСтр("en='ДесериализоватьDeleteImages';ru='ДесериализоватьDeleteImages'"), ТекстНСТР);
		флОшибка = Истина;
	КонецПопытки;
	
	Возврат УдаляемыеФайлы;
	
КонецФункции

