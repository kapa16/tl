	|		ПО уатТТДСтоимость.ПутЛист = уатПутевойЛистПрицепы.Ссылка
	|ГДЕ
	|	уатТТДСтоимость.Ссылка В(&мсвТТД)";
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиКОРП() Тогда
		Запрос.Текст = Запрос.Текст + "
