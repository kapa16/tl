	МассивКолонокСоставПланаПериод.Добавить(ИмяТЧ + "." + ИмяТЧ + "Сумма_Всего");
	МассивКолонокСоставПланаПериод.Добавить(ИмяТЧ + "." + ИмяТЧ + "Цена_Всего");
	
