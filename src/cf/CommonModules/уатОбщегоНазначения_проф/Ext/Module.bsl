Процедура ДобавитьЭлементСоставПланаПериоды(Элементы, Родитель, ИмяКолонки, ИмяДействия = "", Ширина = 8, ИмяТЧ = "СоставПланаПериоды", ТолькоПросмотр = Ложь)
	
	НовыйЭлемент = Элементы.Добавить(ИмяТЧ + ИмяКолонки, Тип("ПолеФормы"), Родитель);
	НовыйЭлемент.Вид         = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = ИмяТЧ + "."+ ИмяТЧ + ИмяКолонки;
	НовыйЭлемент.Ширина      = Ширина;
	НовыйЭлемент.АвтоМаксимальнаяШирина = Истина;
	НовыйЭлемент.ТолькоПросмотр = ТолькоПросмотр;
	
	Если ИмяКолонки = "КоличествоСводноеФакт_Всего" Тогда
		НовыйЭлемент.ЦветФона = ЦветаСтиля.уатИтогиФонГруппы;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяДействия) Тогда
		НовыйЭлемент.УстановитьДействие("ПриИзменении", ИмяДействия);
	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьУсловноеОформлениеНедовыполнениеПлана(ЭтотОбъект, ИмяТЧ)
	
	Элементы = ЭтотОбъект.Элементы;
	
	ЭлементУсловногоОформления = ЭтотОбъект.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Меньше;
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(ИмяТЧ + "." + ИмяТЧ + "КоличествоСводноеФакт_Всего");
	ЭлементОтбора.ПравоеЗначение = Новый ПолеКомпоновкиДанных(ИмяТЧ + "." + ИмяТЧ + "КоличествоСводноеПлан_Всего");
	
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных(ИмяТЧ + "КоличествоСводноеПлан_Всего");
	ОформляемоеПоле.Использование = Истина;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255, 54, 54));
	ЭлементУсловногоОформления.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	ЭлементУсловногоОформления.ИдентификаторПользовательскойНастройки = "Предустановленный_ЦветаСводногоКоличестваНедовыполнениеПлана" + ИмяТЧ;
	ЭлементУсловногоОформления.Представление = НСтр("en='Total amount color';ru='Цвет сводного количества (недовыполнение плана)'");
	
КонецПроцедуры

