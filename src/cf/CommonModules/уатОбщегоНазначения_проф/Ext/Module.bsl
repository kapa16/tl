// Возвращает признак расчетов с контрагентами
//
Функция ЕстьРасчетыСКонтрагентами(ВидОперации = Неопределено) Экспорт
	
	Если ВидОперации = Неопределено Тогда 
		Возврат Ложь;
	Иначе
		Возврат ВидОперации = Перечисления.уатВидыОперацийРКО.ОплатаПоставщику
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийРКО.ПрочиеРасчетыСКонтрагентами
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПКО.ОплатаПокупателя
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПКО.ПрочиеРасчетыСКонтрагентами
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПлатежноеПоручениеИсходящее.ОплатаПоставщику
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПлатежноеПоручениеИсходящее.ПрочиеРасчетыСКонтрагентами
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийЗаявкиНаРасходование.ОплатаПоставщику
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийЗаявкиНаРасходование.ПрочиеРасчетыСКонтрагентами
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПлатежноеПоручениеВходящее.ОплатаПокупателя
		ИЛИ ВидОперации = Перечисления.уатВидыОперацийПлатежноеПоручениеВходящее.ПрочиеРасчетыСКонтрагентами
		
	КонецЕсли;
	
КонецФункции // ЕстьРасчетыСКонтрагентами()

Функция ПолучитьДолгиПоКонтрагенту(Контагент, Дата = Неопределено) Экспорт
	
	мЗапрос = Новый Запрос;
	мЗапрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	уатВзаиморасчетыСКонтрагентамиОстатки.ДоговорКонтрагента,
	|	уатВзаиморасчетыСКонтрагентамиОстатки.СуммаВзаиморасчетовОстаток КАК Сумма
	|ИЗ
	|	РегистрНакопления.уатВзаиморасчетыСКонтрагентами.Остатки(&ДатаКон, Контрагент = &Контрагент) КАК уатВзаиморасчетыСКонтрагентамиОстатки
	|ГДЕ
	|	уатВзаиморасчетыСКонтрагентамиОстатки.СуммаВзаиморасчетовОстаток > 0";
	
	Если НЕ ЗначениеЗаполнено(Дата) тогда
		мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст,"&ДатаКон","");
	Иначе
		мЗапрос.УстановитьПараметр("ДатаКон",Конецдня(Дата));
	КонецЕсли;
	мЗапрос.УстановитьПараметр("Контрагент",Контагент);
	Возврат мЗапрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПревышениеДопустимогоДолга(ДоговорКонтрагента, ДокументСсылка = Неопределено) Экспорт
	
	флОтказ = Ложь;
	
	Если ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		ТекДолг = уатОбщегоНазначенияТиповые_проф.ТекущийДолг(ДоговорКонтрагента, Неопределено, Неопределено);
		Если ДоговорКонтрагента.КонтролироватьСуммуЗадолженности И ТекДолг > ДоговорКонтрагента.ДопустимаяСуммаЗадолженности тогда
			ТекстНСТР = НСтр(
				"en='The current debt of сounterparty ""%1"" (%2%4) exceeds the allowable value (%3%4).';"
				"ru='Текущий долг контрагента ""%1"" (%2%4) превышает допустимую сумму (%3%4).'");
			ТекстНСТР = СтрШаблон(ТекстНСТР, ДоговорКонтрагента.Владелец, ТекДолг,
				ДоговорКонтрагента.ДопустимаяСуммаЗадолженности,
				ДоговорКонтрагента.ВалютаВзаиморасчетов);
			уатОбщегоНазначенияТиповые.СообщитьОбОшибке(ТекстНСТР, флОтказ, , СтатусСообщения.Важное);
			
			Если НЕ ДоговорКонтрагента.ЗапрещатьПроведениеПриЗадолженности 
				ИЛИ НЕ ТребуетсяЗапрещатьПроведениеПриЗадолженности(ДокументСсылка) Тогда
				флОтказ = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат флОтказ;
КонецФункции

Функция ТребуетсяЗапрещатьПроведениеПриЗадолженности(ДокументСсылка) 
	Если ДокументСсылка <> Неопределено Тогда
		Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.уатМаршрутныйЛист") Тогда
			Если ДокументСсылка.Статус = "Новый"
				ИЛИ ДокументСсылка.Статус = "" Тогда
				Возврат Ложь;
			КонецЕсли;
		ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.уатЗаказГрузоотправителя") Тогда
			Запрос = Новый Запрос();
			Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
			
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	уатЗаказГрузоотправителя.Ссылка КАК Заказ
			|ПОМЕСТИТЬ ВРТ_Документы
			|ИЗ
			|	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
			|ГДЕ
			|	уатЗаказГрузоотправителя.Ссылка = &Ссылка
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	уатЭтапыМультимодальныхПеревозок_уэ.Этап
			|ИЗ
			|	РегистрСведений.уатЭтапыМультимодальныхПеревозок_уэ КАК уатЭтапыМультимодальныхПеревозок_уэ
			|ГДЕ
			|	уатЭтапыМультимодальныхПеревозок_уэ.ЗаказГрузоотправителя = &Ссылка
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	Заказ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	уатСтатусыГрузов_уэСрезПоследних.Период КАК Период,
			|	уатСтатусыГрузов_уэСрезПоследних.ГрузовоеМесто КАК ГрузовоеМесто,
			|	уатСтатусыГрузов_уэСрезПоследних.Статус КАК Статус
			|ИЗ
			|	РегистрСведений.уатСтатусыГрузов_уэ.СрезПоследних(
			|			,
			|			Заказ В
			|				(ВЫБРАТЬ
			|					ВТ.Заказ
			|				ИЗ
			|					ВРТ_Документы КАК ВТ)) КАК уатСтатусыГрузов_уэСрезПоследних
			|
			|УПОРЯДОЧИТЬ ПО
			|	ГрузовоеМесто,
			|	Период УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	уатЗаказГрузоотправителя.Ссылка КАК Ссылка,
			|	уатЗаказГрузоотправителя.Мультимодальный КАК Мультимодальный,
			|	уатЗаказГрузоотправителя.ЭтоЭтап КАК ЭтоЭтап
			|ПОМЕСТИТЬ ВТ_ТекущийЗаказ
			|ИЗ
			|	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
			|ГДЕ
			|	уатЗаказГрузоотправителя.Ссылка = &Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	уатЭтапыМультимодальныхПеревозок_уэ.Этап КАК Этап
			|ПОМЕСТИТЬ ВТ_ЭтапыМультимодальныхПеревозок
			|ИЗ
			|	РегистрСведений.уатЭтапыМультимодальныхПеревозок_уэ КАК уатЭтапыМультимодальныхПеревозок_уэ
			|ГДЕ
			|	уатЭтапыМультимодальныхПеревозок_уэ.ЗаказГрузоотправителя = &Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВЫБОР
			|		КОГДА уатЗаказГрузоотправителя.Мультимодальный
			|				И НЕ уатЗаказГрузоотправителя.ЭтоЭтап
			|			ТОГДА ЕСТЬNULL(СтатусРодительскогоЗаказа.СтатусЭтапа, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый))
			|		ИНАЧЕ ВЫБОР
			|				КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый))) > 1
			|					ТОГДА ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Составной)
			|				ИНАЧЕ МАКСИМУМ(ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый)))
			|			КОНЕЦ
			|	КОНЕЦ КАК СтатусЗаказа
			|ИЗ
			|	ВТ_ТекущийЗаказ КАК уатЗаказГрузоотправителя
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСтатусыГрузов_уэ.СрезПоследних(, Заказ = &Ссылка) КАК уатСтатусыГрузов_уэСрезПоследних
			|		ПО (уатСтатусыГрузов_уэСрезПоследних.Заказ = уатЗаказГрузоотправителя.Ссылка),
			|	(ВЫБРАТЬ
			|		ВЫБОР
			|			КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый))) > 1
			|				ТОГДА ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Составной)
			|			ИНАЧЕ МАКСИМУМ(ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый)))
			|		КОНЕЦ КАК СтатусЭтапа
			|	ИЗ
			|		ВТ_ЭтапыМультимодальныхПеревозок КАК уатЭтапыМультимодальныхПеревозок_уэ
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСтатусыГрузов_уэ.СрезПоследних(
			|					,
			|					Заказ В
			|						(ВЫБРАТЬ
			|							ВТ_ЭтапыМультимодальныхПеревозок.Этап
			|						ИЗ
			|							ВТ_ЭтапыМультимодальныхПеревозок)) КАК уатСтатусыГрузов_уэСрезПоследних
			|			ПО уатЭтапыМультимодальныхПеревозок_уэ.Этап = уатСтатусыГрузов_уэСрезПоследних.Заказ) КАК СтатусРодительскогоЗаказа
			|
			|СГРУППИРОВАТЬ ПО
			|	уатЗаказГрузоотправителя.Мультимодальный,
			|	уатЗаказГрузоотправителя.ЭтоЭтап,
			|	СтатусРодительскогоЗаказа.СтатусЭтапа";
			
			РезультатЗапроса = Запрос.ВыполнитьПакет();
			ВыборкаДокумент = РезультатЗапроса[4].Выбрать();
			Если ВыборкаДокумент.Следующий() Тогда 
				СтатусДокумента = ВыборкаДокумент.СтатусЗаказа;
			Иначе 
				СтатусДокумента = Справочники.уатСтатусы_уэ.Новый;
			КонецЕсли;
			Если СтатусДокумента = Справочники.уатСтатусы_уэ.Новый
				ИЛИ СтатусДокумента = Справочники.уатСтатусы_уэ.Отклонен Тогда
				Возврат Ложь;
			КонецЕсли; 
		ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси()
			И ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.такЗаказТакси") Тогда
			Если ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Новый 
				ИЛИ ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Отклонен 
				ИЛИ ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Нераспределенный
				ИЛИ ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Предварительный Тогда
				Возврат Ложь;
			КонецЕсли; 
		ИначеЕсли уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси()
			И ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.такАрендаТС") Тогда
			Если ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Новый 
				ИЛИ ДокументСсылка.Статус = Справочники.уатСтатусы_уэ.Отклонен Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	Возврат Истина;
КонецФункции

// Возвращает список заказов для выбора в поле Сделка документов Поступление, Реализация, ПКО, РКО, ППВ, ППИ
//
Функция ПолучитьЗаказыПоДоговору(Договор, ПолучательКонтрагент = Неопределено) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	уатПредоставленныеУслугиОбороты.ЗаказНаТС КАК ЗаказНаТС
	|ИЗ
	|	РегистрНакопления.уатПредоставленныеУслуги.Обороты(
	|			,
	|			,
	|			Регистратор,
	|			ДоговорКонтрагента = &ДоговорКонтрагента
	|				И ПолучательУслуг = &ПолучательУслуг) КАК уатПредоставленныеУслугиОбороты");
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	Если ПолучательКонтрагент = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ПолучательУслуг = &ПолучательУслуг", "");
	Иначе
		Запрос.УстановитьПараметр("ПолучательУслуг", ?(ПолучательКонтрагент,
			Перечисления.уатПолучателиУслуг.Контрагент, Перечисления.уатПолучателиУслуг.НашаОрганизация));
	КонецЕсли;
	
	мсвЗаказы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ЗаказНаТС");
	
	Возврат мсвЗаказы;
КонецФункции

// Возвращает список заказов по текущей сделке Расшифровки
// для выбора в табличной части Заказы на ТС документов ПКО, РКО, ППВ, ППИ
//
Функция ПолучитьЗаказыВСделке(Сделка) Экспорт
	
	Если ТипЗнч(Сделка) = Тип("ДокументСсылка.уатПоступлениеТоваровУслуг")
		ИЛИ ТипЗнч(Сделка) = Тип("ДокументСсылка.уатСчетНаОплатуПоставщика") Тогда
		ИмяКолонкиЗаказ = "ЗаказНаТС";
	ИначеЕсли ТипЗнч(Сделка) = Тип("ДокументСсылка.уатРеализацияУслуг")
		ИЛИ ТипЗнч(Сделка) = Тип("ДокументСсылка.уатСчетНаОплатуПокупателю") Тогда
		ИмяКолонкиЗаказ = "Заказ";
	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	
	тблУслугиСвернутая = Сделка.Услуги.Выгрузить();
	тблУслугиСвернутая.Свернуть(ИмяКолонкиЗаказ);
	
	мсвЗаказы = тблУслугиСвернутая.ВыгрузитьКолонку(ИмяКолонкиЗаказ);
	ИндексПустойЗаказ = мсвЗаказы.Найти(Документы.уатЗаказГрузоотправителя.ПустаяСсылка());
	Если ИндексПустойЗаказ <> Неопределено Тогда
		мсвЗаказы.Удалить(ИндексПустойЗаказ);
	КонецЕсли;
	
	Возврат мсвЗаказы;
	
КонецФункции

// Рассчитывает сумму строки в валюте взаиморасчетов. Используется при формировании движений по регистру Взаиморасчеты
//
Функция СуммаВзаиморасчетовСтроки(СуммаСтроки, СуммаВалютнаяСтроки, ВалютаСтроки, ДополнительныеСвойства) Экспорт
	Если НЕ ДополнительныеСвойства.Свойство("ОкруглятьРезультат") Тогда
		ДополнительныеСвойства.Вставить("ОкруглятьРезультат", Истина);
	КонецЕсли;
	
	флСтандартныйПересчетПоКурсам = Ложь;
	Если ДополнительныеСвойства.МноговалютныйУчет Тогда
		Если ДополнительныеСвойства.ВалютаВзаиморасчетов = ДополнительныеСвойства.ВалютаДокумента Тогда
			Рез = СуммаСтроки;
		ИначеЕсли ДополнительныеСвойства.ВалютаВзаиморасчетов = ВалютаСтроки Тогда
			Рез = СуммаВалютнаяСтроки;
		ИначеЕсли ДополнительныеСвойства.Свойство("КроссКурсВзаиморасчетов") Тогда
			Рез = СуммаСтроки * ДополнительныеСвойства.КроссКурсВзаиморасчетов;
		Иначе
			флСтандартныйПересчетПоКурсам = Истина;
		КонецЕсли;
	Иначе
		Если ДополнительныеСвойства.ВалютаВзаиморасчетов = ДополнительныеСвойства.ВалютаДокумента Тогда
			Рез = СуммаСтроки;
		Иначе
			флСтандартныйПересчетПоКурсам = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если флСтандартныйПересчетПоКурсам Тогда
		Рез = уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(СуммаСтроки,
			ДополнительныеСвойства.ВалютаДокумента,    ДополнительныеСвойства.ВалютаВзаиморасчетов,
			ДополнительныеСвойства.КурсДокумента,      ДополнительныеСвойства.КурсВзаиморасчетов,
			ДополнительныеСвойства.КратностьДокумента, ДополнительныеСвойства.КратностьВзаиморасчетов,
			ДополнительныеСвойства.ОкруглятьРезультат,
			ДополнительныеСвойства.ДопПараметрыКурсаВалюты);
	КонецЕсли;
		
	Возврат Рез;
КонецФункции

// Рассчитывает сумму строки в валюте упр. учета. Используется при формировании движений по регистру Взаиморасчеты
//
Функция СуммаУпрСтроки(СуммаСтроки, СуммаВалютнаяСтроки, ВалютаСтроки, ДополнительныеСвойства) Экспорт
	Если НЕ ДополнительныеСвойства.Свойство("ОкруглятьРезультат") Тогда
		ДополнительныеСвойства.Вставить("ОкруглятьРезультат", Истина);
	КонецЕсли;
			
	Если ДополнительныеСвойства.ВалютаУпрУчета = ДополнительныеСвойства.ВалютаДокумента Тогда
		Рез = СуммаСтроки;
	ИначеЕсли ДополнительныеСвойства.ВалютаУпрУчета = ВалютаСтроки Тогда
		Рез = СуммаВалютнаяСтроки;
	Иначе
		Рез = уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(СуммаСтроки,
			ДополнительныеСвойства.ВалютаДокумента,    ДополнительныеСвойства.ВалютаУпрУчета,
			ДополнительныеСвойства.КурсДокумента,      ДополнительныеСвойства.КурсУпр,
			ДополнительныеСвойства.КратностьДокумента, ДополнительныеСвойства.КратностьУпр,
			ДополнительныеСвойства.ОкруглятьРезультат,
			ДополнительныеСвойства.ДопПараметрыКурсаВалюты);
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

// Рассчитывает итоговую сумму взаиморасчетов по документу
//
Функция СуммаВзаиморасчетовДокумента(ДокументОбъект, Знач ПараметрыОтносительныеКурсы = Неопределено) Экспорт
	Рез = 0;
	
	Если ЗначениеЗаполнено(ДокументОбъект.ВалютаВзаиморасчетов) Тогда
		ВалютаВзаиморасчетов = ДокументОбъект.ВалютаВзаиморасчетов;
	Иначе
		ВалютаВзаиморасчетов = ДокументОбъект.ДоговорКонтрагента.ВалютаВзаиморасчетов;
	КонецЕсли;
	ДатаКурса = ?(ДокументОбъект.ДатаКурса = '00010101', ДокументОбъект.Дата, ДокументОбъект.ДатаКурса);
	СтруктураКурсаВзаиморасчетов = уатОбщегоНазначенияТиповые.ПолучитьКурсВалюты(ВалютаВзаиморасчетов, ДатаКурса,
		?(ПараметрыОтносительныеКурсы = Неопределено, ДокументОбъект, ПараметрыОтносительныеКурсы));
	
	СтруктураДополнительныеСвойства = Новый Структура;
	СтруктураДополнительныеСвойства.Вставить("МноговалютныйУчет",       ПолучитьФункциональнуюОпцию("уатМноговалютныйУчет"));
	СтруктураДополнительныеСвойства.Вставить("КроссКурсВзаиморасчетов", ?(ДокументОбъект.КроссКурс = 0, 1, ДокументОбъект.КроссКурс));
	СтруктураДополнительныеСвойства.Вставить("ВалютаВзаиморасчетов",    ВалютаВзаиморасчетов);
	СтруктураДополнительныеСвойства.Вставить("КурсВзаиморасчетов",      СтруктураКурсаВзаиморасчетов.Курс);
	СтруктураДополнительныеСвойства.Вставить("КратностьВзаиморасчетов", СтруктураКурсаВзаиморасчетов.Кратность);
	СтруктураДополнительныеСвойства.Вставить("ВалютаДокумента",         ДокументОбъект.ВалютаДокумента);
	СтруктураДополнительныеСвойства.Вставить("КурсДокумента",           ДокументОбъект.КурсВзаиморасчетов);
	СтруктураДополнительныеСвойства.Вставить("КратностьДокумента",      ДокументОбъект.КратностьВзаиморасчетов);
	СтруктураДополнительныеСвойства.Вставить("ДопПараметрыКурсаВалюты", ДокументОбъект);
	
	Если ТипЗнч(ДокументОбъект) <> Тип("ДокументОбъект.уатЗаказПоставщику") Тогда
		Для Каждого ТекСтрока Из ДокументОбъект.Услуги Цикл
			ТекСумма = ТекСтрока.Сумма;
			ТекСуммаВалютная = ТекСтрока.СуммаВалютная;
			Если ДокументОбъект.УчитыватьНДС И НЕ ДокументОбъект.СуммаВключаетНДС Тогда
				ТекСумма = ТекСумма + ТекСтрока.СуммаНДС;
				ТекСуммаВалютная = ТекСуммаВалютная + ТекСтрока.СуммаНДСвалютная;
			КонецЕсли;
			
			Рез = Рез + СуммаВзаиморасчетовСтроки(ТекСумма, ТекСуммаВалютная, ТекСтрока.Валюта, СтруктураДополнительныеСвойства);
		КонецЦикла;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПоступлениеТоваровУслуг")
		Или ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатЗаказПоставщику") Тогда
		Для Каждого ТекСтрока Из ДокументОбъект.Товары Цикл
			ТекСумма = ТекСтрока.Сумма;
			Если ДокументОбъект.УчитыватьНДС И НЕ ДокументОбъект.СуммаВключаетНДС Тогда
				ТекСумма = ТекСумма + ТекСтрока.СуммаНДС;
			КонецЕсли;
			
			Рез = Рез + СуммаВзаиморасчетовСтроки(ТекСумма, ТекСумма,
				ДокументОбъект.ВалютаДокумента, СтруктураДополнительныеСвойства);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

// Заполняет БанковскийСчетОрганизации при вводе денежных документов на основании накладных
//
// Параметры:
//  ДокументОбъект - ДокументОбъект - документ ПКО, РКО, ППВ, ППИ
//
Процедура ЗаполнитьБанковскийСчетКассуПриВводеНаОсновании(ДокументОбъект, ДанныеЗаполнения = Неопределено) Экспорт
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПлатежноеПоручениеВходящее")
		И ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатРеализацияУслуг") Тогда
		ДокументОбъект.БанковскийСчет = ДанныеЗаполнения.БанковскийСчетОрганизации;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПлатежноеПоручениеВходящее")
		И ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатСчетНаОплатуПокупателю") Тогда
		ДокументОбъект.БанковскийСчет = ДанныеЗаполнения.СтруктурнаяЕдиница;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПлатежноеПоручениеИсходящее")
		И ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.уатСчетНаОплатуПоставщика") Тогда
		ДокументОбъект.БанковскийСчет = ДанныеЗаполнения.СтруктурнаяЕдиница;
	КонецЕсли;
		
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("БанковскийСчет", ДокументОбъект.Метаданные())
		И (НЕ ЗначениеЗаполнено(ДокументОбъект.БанковскийСчет)
		ИЛИ ДокументОбъект.БанковскийСчет.ВалютаДенежныхСредств <> ДокументОбъект.ВалютаДокумента)
		И ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
		
		//Если ЗначениеЗаполнено(ДокументОбъект.БанковскийСчет)
		//	И ДокументОбъект.БанковскийСчет.ВалютаДенежныхСредств = ДокументОбъект.ВалютаДокумента
		//	ИЛИ НЕ ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
		//	Возврат;
		//КонецЕсли;
		
		Если ДокументОбъект.Организация.ОсновнойБанковскийСчет.ВалютаДенежныхСредств = ДокументОбъект.ВалютаДокумента Тогда
			ДокументОбъект.БанковскийСчет = ДокументОбъект.Организация.ОсновнойБанковскийСчет;
		Иначе
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	БанковскиеСчета.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.БанковскиеСчета КАК БанковскиеСчета
			|ГДЕ
			|	БанковскиеСчета.Владелец = &Организация
			|	И НЕ БанковскиеСчета.ПометкаУдаления
			|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаДенежныхСредств");
			Запрос.УстановитьПараметр("Организация", ДокументОбъект.Организация);
			Запрос.УстановитьПараметр("ВалютаДенежныхСредств", ДокументОбъект.ВалютаДокумента);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ДокументОбъект.БанковскийСчет = Выборка.Ссылка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Касса", ДокументОбъект.Метаданные())
		И (НЕ ЗначениеЗаполнено(ДокументОбъект.Касса)
		ИЛИ ДокументОбъект.Касса.ВалютаДенежныхСредств <> ДокументОбъект.ВалютаДокумента)
		И ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
		
		ОсновнаяКасса = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(
			ДокументОбъект.Организация, "ОсновнаяКасса");
		
		Если ОсновнаяКасса.ВалютаДенежныхСредств = ДокументОбъект.ВалютаДокумента Тогда
			ДокументОбъект.Касса = ОсновнаяКасса;
		Иначе
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Кассы.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Владелец = &Организация
			|	И НЕ Кассы.ПометкаУдаления
			|	И Кассы.ВалютаДенежныхСредств = &ВалютаДенежныхСредств");
			Запрос.УстановитьПараметр("Организация", ДокументОбъект.Организация);
			Запрос.УстановитьПараметр("ВалютаДенежныхСредств", ДокументОбъект.ВалютаДокумента);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ДокументОбъект.Касса = Выборка.Ссылка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПлатежныйКалендарь

// Получает плановую дату платежа из регистра сведений "Даты Платежей"
// для отображения в документах Поступление товаров и услуг и Реализация услуг
//
Функция ДатаПлатежаПоРегистру(мсвСделки, ЭтапОплаты, ПолучательУслугНашаОрганизация = Ложь) Экспорт
	// удаление незаполненных сделок из отбора для ускорения запроса
	Сч = мсвСделки.Количество()-1;
	Пока Сч >= 0 Цикл
		Если НЕ ЗначениеЗаполнено(мсвСделки[Сч]) Тогда
			мсвСделки.Удалить(Сч);
		КонецЕсли;
		
		Сч = Сч - 1;
	КонецЦикла;
	
	Если ПолучательУслугНашаОрганизация Тогда
		ПолучательУслуг = Перечисления.уатПолучателиУслуг.НашаОрганизация;
	Иначе
		ПолучательУслуг = Перечисления.уатПолучателиУслуг.Контрагент;
	КонецЕсли;
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	уатДатыПлатежей.ДатаПлатежа КАК ДатаПлатежа,
	|	уатДатыПлатежей.ЗаказНаТС.Номер КАК ЗаказНаТСНомер,
	|	уатДатыПлатежей.ЗаказНаТС.Дата КАК ЗаказНаТСДата
	|ИЗ
	|	РегистрСведений.уатДатыПлатежей КАК уатДатыПлатежей
	|ГДЕ
	|	уатДатыПлатежей.Сделка В (&мсвСделки)
	|	И уатДатыПлатежей.ПолучательУслуг = &ПолучательУслуг
	|	И уатДатыПлатежей.ЭтапОплаты = &ЭтапОплаты");
	Запрос.УстановитьПараметр("мсвСделки", мсвСделки);
	Запрос.УстановитьПараметр("ПолучательУслуг", ПолучательУслуг);
	Запрос.УстановитьПараметр("ЭтапОплаты", ЭтапОплаты);
		
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 0 Тогда
		Возврат '00010101';
	ИначеЕсли Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		Возврат Выборка.ДатаПлатежа;
	Иначе
		ДатыСтрока = "";
		Пока Выборка.Следующий() Цикл
			ДатыСтрока = ДатыСтрока + "
				|Заказ на ТС №" + Выборка.ЗаказНаТСНомер + " от " + Формат(Выборка.ЗаказНаТСДата, "ДФ=dd.MM.yyyy")
				+ " - " + Формат(Выборка.ДатаПлатежа, "ДФ=dd.MM.yyyy");
		КонецЦикла;
		ДатыСтрока = Сред(ДатыСтрока, 2);
		Возврат ДатыСтрока;
	КонецЕсли;
КонецФункции

// Возвращает флаг наличия другой накладной / счета на оплату с указанной вручную датой платежа
// по этому же заказу, договору и этапу.
// Проверяется наличие счета для текущей накладной, или накладной для текущего счета при ведении 
// взаиморасчетов "По заказам"
//
// Параметры:
//  ДокументОбъект	 - ДокументОбъект.уатРеализацияУслуг, ДокументОбъект.уатСчетНаОплатуПокупателю - документ
//  ТекстСообщения	 - Строка - возвращаемый текст сообщения об ошибке
// 
// Возвращаемое значение:
//  Булево - Истина, если существует другой документ с указанием ручной даты платежа
//
Функция НайтиДубльНакладнойСчетаПоРучнойДатеПлатежа(ДокументОбъект, ТекстСообщения)
	Рез = Ложь;
	
	// Проверка только по заказам, т.к. только по ним можно ввести ручную дату и в счете на оплату, и в накладной
	Если ДокументОбъект.ДоговорКонтрагента.ВедениеВзаиморасчетов <> Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказамНаТС Тогда
		Возврат Рез;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатРеализацияУслуг") Тогда
		ВидДокумента = 1;
		ДатаПлатежа = ДокументОбъект.ДатаПлатежа;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПоступлениеТоваровУслуг") Тогда
		ВидДокумента = 2;
		ДатаПлатежа = ДокументОбъект.ДатаПлатежа;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатСчетНаОплатуПокупателю") Тогда
		ВидДокумента = 3;
		ДатаПлатежа = ДокументОбъект.ДатаОплаты;
	Иначе
		ВидДокумента = 4;
		ДатаПлатежа = ДокументОбъект.ДатаОплаты;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаПлатежа) Тогда
		Возврат Рез;
	КонецЕсли;
	
	мсвЗаказыТС = Новый Массив;
	Для Каждого ТекСтрока Из ДокументОбъект.Услуги Цикл
		Если ВидДокумента = 1 ИЛИ ВидДокумента = 3 Тогда
			Если ЗначениеЗаполнено(ТекСтрока.Заказ) И мсвЗаказыТС.Найти(ТекСтрока.Заказ) = Неопределено Тогда
				мсвЗаказыТС.Добавить(ТекСтрока.Заказ);
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(ТекСтрока.Заказ) И мсвЗаказыТС.Найти(ТекСтрока.ЗаказНаТС) = Неопределено Тогда
				мсвЗаказыТС.Добавить(ТекСтрока.ЗаказНаТС);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ВидДокумента = 1 Тогда //реализация - ищем счета на оплату покупателю
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатСчетНаОплатуПокупателюУслуги.Ссылка КАК Ссылка,
		|	уатСчетНаОплатуПокупателюУслуги.Заказ КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатСчетНаОплатуПокупателю.Услуги КАК уатСчетНаОплатуПокупателюУслуги
		|ГДЕ
		|	НЕ уатСчетНаОплатуПокупателюУслуги.Ссылка.ПометкаУдаления
		|	И уатСчетНаОплатуПокупателюУслуги.Заказ В (&мсвЗаказыТС)
		|	И уатСчетНаОплатуПокупателюУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатСчетНаОплатуПокупателюУслуги.Ссылка.ДатаОплаты <> ДАТАВРЕМЯ(1,1,1)");
		
	ИначеЕсли ВидДокумента = 2 Тогда //поступление - ищем счета на оплату поставщика
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатСчетНаОплатуПоставщикаУслуги.Ссылка КАК Ссылка,
		|	уатСчетНаОплатуПоставщикаУслуги.ЗаказНаТС КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатСчетНаОплатуПоставщика.Услуги КАК уатСчетНаОплатуПоставщикаУслуги
		|ГДЕ
		|	НЕ уатСчетНаОплатуПоставщикаУслуги.Ссылка.ПометкаУдаления
		|	И уатСчетНаОплатуПоставщикаУслуги.ЗаказНаТС В (&мсвЗаказыТС)
		|	И уатСчетНаОплатуПоставщикаУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатСчетНаОплатуПоставщикаУслуги.Ссылка.ДатаОплаты <> ДАТАВРЕМЯ(1,1,1)");
		
	ИначеЕсли ВидДокумента = 3 Тогда //счет на оплату покупателю - ищем реализации
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатРеализацияУслугУслуги.Ссылка КАК Ссылка,
		|	уатРеализацияУслугУслуги.Заказ КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатРеализацияУслуг.Услуги КАК уатРеализацияУслугУслуги
		|ГДЕ
		|	уатРеализацияУслугУслуги.Ссылка.Проведен
		|	И уатРеализацияУслугУслуги.Заказ В(&мсвЗаказыТС)
		|	И уатРеализацияУслугУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатРеализацияУслугУслуги.Ссылка.ДатаПлатежа <> ДАТАВРЕМЯ(1, 1, 1)");
		
	Иначе //счет на оплату поставщика - ищем поступления
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатПоступлениеТоваровУслугУслуги.Ссылка КАК Ссылка,
		|	уатПоступлениеТоваровУслугУслуги.ЗаказНаТС КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатПоступлениеТоваровУслуг.Услуги КАК уатПоступлениеТоваровУслугУслуги
		|ГДЕ
		|	уатПоступлениеТоваровУслугУслуги.Ссылка.Проведен
		|	И уатПоступлениеТоваровУслугУслуги.ЗаказНаТС В (&мсвЗаказыТС)
		|	И уатПоступлениеТоваровУслугУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатПоступлениеТоваровУслугУслуги.Ссылка.ДатаПлатежа <> ДАТАВРЕМЯ(1,1,1)");
				
	КонецЕсли;
	
	Запрос.УстановитьПараметр("мсвЗаказыТС",        мсвЗаказыТС);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДокументОбъект.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ТекущийДокумент",    ДокументОбъект.Ссылка);
		
	тблВведенныеДокументы = Запрос.Выполнить().Выгрузить();
	
	Для Каждого ТекЗаказНаТС Из мсвЗаказыТС Цикл
		мсвДругиеДокументы = тблВведенныеДокументы.НайтиСтроки(Новый Структура("ЗаказНаТС", ТекЗаказНаТС));
		Если мсвДругиеДокументы.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстСообщения = СтрШаблон("По заказу ""%1"", договору ""%2""%3 уже введен ""%4"" с указанной вручную датой платежа!",
			ТекЗаказНаТС,
			ДокументОбъект.ДоговорКонтрагента,
			?(ЗначениеЗаполнено(ДокументОбъект.ЭтапОплаты), " и этапу оплаты", ""),
			мсвДругиеДокументы[0].Ссылка);
			
		Рез = Истина;
	КонецЦикла;
	
	Возврат Рез;
КонецФункции

// Возвращает флаг наличия другой накладной / счета на оплату с указанным этапом платежа.
//  Функция вызывается при проверке заполнения при записи накладных / счетов
//  для обеспечения наличия не более одной накладной с указанным этапом оплаты по Заказу/Договору
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.уатРеализацияУслуг, ДокументОбъект.уатПоступлениеТоваровУслуг,
//		ДокументОбъект.уатСчетНаОплатуПокупателю, ДокументОбъект.уатСчетНаОплатуПоставщика - документ
//  ТекстСообщения - Строка - возвращаемый текст сообщения об ошибке
// 
// Возвращаемое значение:
//  Булево - Истина, если существует другой документ с указанным этапом оплаты
//
Функция НайтиДубльНакладнойСчетаПоЭтапуОплаты(ДокументОбъект, ТекстСообщения) Экспорт
	Рез = Ложь;

	Если ДокументОбъект.ДоговорКонтрагента.ГрафикОплаты.Количество() = 0 Тогда
		Возврат Рез;
	КонецЕсли;
		
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатРеализацияУслуг") Тогда
		ВидДокумента = 1;
		ДатаПлатежа = ДокументОбъект.ДатаПлатежа;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатПоступлениеТоваровУслуг") Тогда
		ВидДокумента = 2;
		ДатаПлатежа = ДокументОбъект.ДатаПлатежа;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.уатСчетНаОплатуПокупателю") Тогда
		ВидДокумента = 3;
		ДатаПлатежа = ДокументОбъект.ДатаОплаты;
	Иначе
		ВидДокумента = 4;
		ДатаПлатежа = ДокументОбъект.ДатаОплаты;
	КонецЕсли;
		
	мсвЗаказыТС = Новый Массив;
	Для Каждого ТекСтрока Из ДокументОбъект.Услуги Цикл
		Если ВидДокумента = 1 ИЛИ ВидДокумента = 3 Тогда
			Если ЗначениеЗаполнено(ТекСтрока.Заказ) И мсвЗаказыТС.Найти(ТекСтрока.Заказ) = Неопределено Тогда
				мсвЗаказыТС.Добавить(ТекСтрока.Заказ);
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(ТекСтрока.ЗаказНаТС) И мсвЗаказыТС.Найти(ТекСтрока.ЗаказНаТС) = Неопределено Тогда
				мсвЗаказыТС.Добавить(ТекСтрока.ЗаказНаТС);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ВидДокумента = 1 Тогда //реализация
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатРеализацияУслугУслуги.Ссылка КАК Ссылка,
		|	уатРеализацияУслугУслуги.Заказ КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатРеализацияУслуг.Услуги КАК уатРеализацияУслугУслуги
		|ГДЕ
		|	уатРеализацияУслугУслуги.Ссылка.Проведен
		|	И уатРеализацияУслугУслуги.Заказ В(&мсвЗаказыТС)
		|	И уатРеализацияУслугУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатРеализацияУслугУслуги.Ссылка.ЭтапОплаты = &ЭтапОплаты
		|	И уатРеализацияУслугУслуги.Ссылка <> &ТекущийДокумент");
	ИначеЕсли ВидДокумента = 2 Тогда //поступление
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатПоступлениеТоваровУслугУслуги.Ссылка КАК Ссылка,
		|	уатПоступлениеТоваровУслугУслуги.ЗаказНаТС КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатПоступлениеТоваровУслуг.Услуги КАК уатПоступлениеТоваровУслугУслуги
		|ГДЕ
		|	уатПоступлениеТоваровУслугУслуги.Ссылка.Проведен
		|	И уатПоступлениеТоваровУслугУслуги.ЗаказНаТС В (&мсвЗаказыТС)
		|	И уатПоступлениеТоваровУслугУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатПоступлениеТоваровУслугУслуги.Ссылка.ЭтапОплаты = &ЭтапОплаты
		|	И уатПоступлениеТоваровУслугУслуги.Ссылка <> &ТекущийДокумент");
	ИначеЕсли ВидДокумента = 3 Тогда //счет на оплату покупателю
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатСчетНаОплатуПокупателюУслуги.Ссылка КАК Ссылка,
		|	уатСчетНаОплатуПокупателюУслуги.Заказ КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатСчетНаОплатуПокупателю.Услуги КАК уатСчетНаОплатуПокупателюУслуги
		|ГДЕ
		|	НЕ уатСчетНаОплатуПокупателюУслуги.Ссылка.ПометкаУдаления
		|	И уатСчетНаОплатуПокупателюУслуги.Заказ В (&мсвЗаказыТС)
		|	И уатСчетНаОплатуПокупателюУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатСчетНаОплатуПокупателюУслуги.Ссылка.ЭтапОплаты = &ЭтапОплаты
		|	И уатСчетНаОплатуПокупателюУслуги.Ссылка <> &ТекущийДокумент");
	Иначе //счет на оплату поставщика
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	уатСчетНаОплатуПоставщикаУслуги.Ссылка КАК Ссылка,
		|	уатСчетНаОплатуПоставщикаУслуги.ЗаказНаТС КАК ЗаказНаТС
		|ИЗ
		|	Документ.уатСчетНаОплатуПоставщика.Услуги КАК уатСчетНаОплатуПоставщикаУслуги
		|ГДЕ
		|	НЕ уатСчетНаОплатуПоставщикаУслуги.Ссылка.ПометкаУдаления
		|	И уатСчетНаОплатуПоставщикаУслуги.ЗаказНаТС В (&мсвЗаказыТС)
		|	И уатСчетНаОплатуПоставщикаУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И уатСчетНаОплатуПоставщикаУслуги.Ссылка.ЭтапОплаты = &ЭтапОплаты
		|	И уатСчетНаОплатуПоставщикаУслуги.Ссылка <> &ТекущийДокумент");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("мсвЗаказыТС",        мсвЗаказыТС);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДокументОбъект.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ТекущийДокумент",    ДокументОбъект.Ссылка);
	Запрос.УстановитьПараметр("ЭтапОплаты",         
		?(ЗначениеЗаполнено(ДатаПлатежа) И НЕ ЗначениеЗаполнено(ДокументОбъект.ЭтапОплаты),
		Справочники.уатЭтапыОплаты.ПроизвольнаяОплата, ДокументОбъект.ЭтапОплаты));
	
	тблВведенныеДокументы = Запрос.Выполнить().Выгрузить();
	
	Для Каждого ТекЗаказНаТС Из мсвЗаказыТС Цикл
		мсвДругиеДокументы = тблВведенныеДокументы.НайтиСтроки(Новый Структура("ЗаказНаТС", ТекЗаказНаТС));
		Если мсвДругиеДокументы.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстСообщения = СтрШаблон("По заказу ""%1"", договору ""%2""%3 уже введен ""%4""!",
			ТекЗаказНаТС,
			ДокументОбъект.ДоговорКонтрагента,
			?(ЗначениеЗаполнено(ДокументОбъект.ЭтапОплаты), " и этапу оплаты", ""),
			мсвДругиеДокументы[0].Ссылка);
			
		Рез = Истина;
	КонецЦикла;
	
	// Если по этапам дублей нет, то проверяем по указанию ручных дат по каждому этапу оплаты только в одном документе.
	// Пока проверка отключена - дублей по ПК не возникнет, при указании нескольких дат в ПК попадет минимальная.
	// Но по логике такого быть не должно, планируют оплату по заказу либо только в счетах, либо только в накладных.
	//Если НЕ Рез Тогда
	// okoe: пока оставлена заглушка
	Если Ложь Тогда
		Рез = НайтиДубльНакладнойСчетаПоРучнойДатеПлатежа(ДокументОбъект, ТекстСообщения);
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

// Выполняется проверка наличия предоплат по условиям договора
Процедура ПроверкаПредоплатыПоЗаказам(МаршрутныйЛист, Отказ) Экспорт
	Если НЕ ПолучитьФункциональнуюОпцию("уатИспользоватьПлатежныйКалендарь") Тогда
		Возврат;
	КонецЕсли;
	
	мсвЗаказы = Новый Массив;
	Для Каждого ТекСтрока Из МаршрутныйЛист.Заказы Цикл
		Если ТекСтрока.Выполнен И мсвЗаказы.Найти(ТекСтрока.ЗаказГрузоотправителя) = Неопределено Тогда
			мсвЗаказы.Добавить(ТекСтрока.ЗаказГрузоотправителя);
		КонецЕсли;
	КонецЦикла;
	
	мсвСостояниеОплатыПоЗаказам = СостояниеОплатыПоДокументам(мсвЗаказы);
	Для Каждого ПараметрыЗаказа Из мсвСостояниеОплатыПоЗаказам Цикл
		Если ПараметрыЗаказа.ПроцентПредоплаты > 0 И ПараметрыЗаказа.СуммаОплатыФакт < ПараметрыЗаказа.СуммаПредоплаты Тогда
			ТекстСообщения = СтрШаблон("Недостаточно оплаты для отправки ""%1"": оплачено %2 %3(%4), требуется %5 %3(%6)",
				ПараметрыЗаказа.Документ,
				Формат(ПараметрыЗаказа.СуммаОплатыФакт, "ЧДЦ=2; ЧН=0"),
				ПараметрыЗаказа.Валюта,
				"" + Окр(ПараметрыЗаказа.ПроцентОплатыФакт) + "%",
				Формат(ПараметрыЗаказа.СуммаПредоплаты, "ЧДЦ=2; ЧН=0"),
				"" + Окр(ПараметрыЗаказа.ПроцентПредоплаты) + "%");
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция СостояниеОплатыПоДокументам(Знач мсвДокументы) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	ВалютаУпр = Константы.ВалютаУправленческогоУчета.Получить();
	флЕстьПустойЗаказ = Ложь;
	
	// главный цикл расчета статуса оплаты документа
	мсвРез = Новый Массив;
	Для Каждого ТекДокумент Из мсвДокументы Цикл
		ВалютаРегл = уатОбщегоНазначенияТиповые.ВалютаРегламентированногоУчета(ТекДокумент.Организация);
	
		Рез = Новый Структура("Документ, Сумма, ПроцентПредоплаты, СуммаПредоплаты, Валюта, СуммаОплатыФакт, ПроцентОплатыФакт",
			ТекДокумент, 0, 0, 0, ТекДокумент.ВалютаДокумента, 0, 0);
		
		ИмяДокумента = ТекДокумент.Метаданные().Имя;
		Если ИмяДокумента = "уатЗаказГрузоотправителя" Тогда
			Рез.ПроцентПредоплаты = 0;
			Для Каждого ТекСтрокаЭтап Из ТекДокумент.ДоговорКонтрагента.ГрафикОплаты Цикл
				Если ТекСтрокаЭтап.ЭтапОплаты.ВариантОтсчета = Перечисления.уатВариантыОтсчетаДатыПлатежа.ДоОтправленияПоЗаказу Тогда
					Рез.ПроцентПредоплаты = Рез.ПроцентПредоплаты + ТекСтрокаЭтап.ЭтапОплаты.Процент;
				КонецЕсли;
			КонецЦикла;
			
			мсвЗаказы = Новый Массив;
			Если ЗначениеЗаполнено(ТекДокумент) Тогда
				Если мсвЗаказы.Найти(ТекДокумент) = Неопределено Тогда
					мсвЗаказы.Добавить(ТекДокумент);
				КонецЕсли;
			Иначе
				флЕстьПустойЗаказ = Истина;
			КонецЕсли;
			// для мультимодальных заказов нужно добавить подчиненные этапы
			ДобавитьЭтапыМультимодальногоЗаказа(мсвЗаказы);
						
			Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	уатПредоставленныеУслугиОбороты.Валюта КАК Валюта,
			|	уатПредоставленныеУслугиОбороты.СуммаОборот КАК СуммаПриход,
			|	уатПредоставленныеУслугиОбороты.СуммаРеглОборот КАК СуммаПриходРегл,
			|	0 КАК СуммаРасход,
			|	0 КАК СуммаРасходУпр
			|ИЗ
			|	РегистрНакопления.уатПредоставленныеУслуги.Обороты(
			|			,
			|			,
			|			,
			|			ЗаказНаТС В (&мсвЗаказы) И ПолучательУслуг = ЗНАЧЕНИЕ(Перечисление.уатПолучателиУслуг.Контрагент)) КАК уатПредоставленныеУслугиОбороты
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	уатРасчетыПоДокументамОбороты.Валюта,
			|	0,
			|	0,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходОборот,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходУпрОборот
			|ИЗ
			|	РегистрНакопления.уатРасчетыПоДокументам.Обороты(
			|			,
			|			,
			|			,
			|			ЗаказНаТС В (&мсвЗаказы) И ПолучательУслуг = ЗНАЧЕНИЕ(Перечисление.уатПолучателиУслуг.Контрагент)) КАК уатРасчетыПоДокументамОбороты");
			Запрос.УстановитьПараметр("мсвЗаказы", мсвЗаказы);
			ВыборкаДанные = Запрос.Выполнить().Выбрать();
			
		ИначеЕсли СтрНайти("уатРеализацияУслуг, уатПоступлениеТоваровУслуг, уатСчетНаОплатуПокупателю, уатСчетНаОплатуПоставщика", ИмяДокумента) <> 0 Тогда
			мсвСделки = Новый Массив;
			Если ИмяДокумента = "уатСчетНаОплатуПокупателю" ИЛИ ИмяДокумента = "уатСчетНаОплатуПоставщика" Тогда
				Если ТекДокумент.ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам Тогда
					мсвСделки.Добавить(ТекДокумент);
				ИначеЕсли ТекДокумент.ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным Тогда
					мсвСделки = НакладныеДляСчетаНаОплату(ТекДокумент);
				Иначе
					ДобавитьЗаказыИзСчетаНакладной(ТекДокумент, мсвСделки);
					ДобавитьЭтапыМультимодальногоЗаказа(мсвСделки);
				КонецЕсли;
			Иначе // накладная
				Если ТекДокумент.ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам Тогда
					мсвСделки.Добавить(ТекДокумент.Сделка);
				ИначеЕсли ТекДокумент.ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоНакладным Тогда
					мсвСделки.Добавить(ТекДокумент);
				Иначе
					ДобавитьЗаказыИзСчетаНакладной(ТекДокумент, мсвСделки);
					ДобавитьЭтапыМультимодальногоЗаказа(мсвСделки);
				КонецЕсли;
			КонецЕсли;
						
			Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	ДокументНакладнаяСчет.ВалютаДокумента КАК Валюта,
			|	ДокументНакладнаяСчет.СуммаДокумента КАК СуммаПриход,
			|	0 КАК СуммаПриходРегл,
			|	0 КАК СуммаРасход,
			|	0 КАК СуммаРасходУпр
			|ИЗ
			|	Документ.уатСчетНаОплатуПокупателю КАК ДокументНакладнаяСчет
			|ГДЕ
			|	ДокументНакладнаяСчет.Ссылка = &Документ
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	уатРасчетыПоДокументамОбороты.Валюта,
			|	0,
			|	0,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходОборот,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходУпрОборот
			|ИЗ
			|	РегистрНакопления.уатРасчетыПоДокументам.Обороты(
			|			,
			|			,
			|			,
			|			Сделка В (&мсвСделки)
			|				И ПолучательУслуг = &ПолучательУслуг
			|				И ЭтапОплаты = &ЭтапОплаты) КАК уатРасчетыПоДокументамОбороты");
			Запрос.УстановитьПараметр("Документ",  ТекДокумент);
			Запрос.УстановитьПараметр("мсвСделки", мсвСделки);
			Если ИмяДокумента = "уатПоступлениеТоваровУслуг" ИЛИ ИмяДокумента = "уатСчетНаОплатуПоставщика" Тогда
				Запрос.УстановитьПараметр("ПолучательУслуг", Перечисления.уатПолучателиУслуг.НашаОрганизация);
			Иначе
				Запрос.УстановитьПараметр("ПолучательУслуг", Перечисления.уатПолучателиУслуг.Контрагент);
			КонецЕсли;
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.уатСчетНаОплатуПокупателю", "Документ." + ИмяДокумента);
			Если ЗначениеЗаполнено(ТекДокумент.ЭтапОплаты) Тогда
				Запрос.УстановитьПараметр("ЭтапОплаты", ТекДокумент.ЭтапОплаты);
			Иначе
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЭтапОплаты = &ЭтапОплаты", "ИСТИНА");
			КонецЕсли;
			ВыборкаДанные = Запрос.Выполнить().Выбрать();
			
		ИначеЕсли ИмяДокумента = "такАрендаТС" Тогда
			Рез.ПроцентПредоплаты = 0;
			
			мсвЗаказы = Новый Массив;
			Если ЗначениеЗаполнено(ТекДокумент) Тогда
				Если мсвЗаказы.Найти(ТекДокумент) = Неопределено Тогда
					мсвЗаказы.Добавить(ТекДокумент);
				КонецЕсли;
			Иначе
				флЕстьПустойЗаказ = Истина;
			КонецЕсли;
						
			Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	уатПредоставленныеУслугиОбороты.Валюта КАК Валюта,
			|	уатПредоставленныеУслугиОбороты.СуммаОборот КАК СуммаПриход,
			|	уатПредоставленныеУслугиОбороты.СуммаРеглОборот КАК СуммаПриходРегл,
			|	0 КАК СуммаРасход,
			|	0 КАК СуммаРасходУпр
			|ИЗ
			|	РегистрНакопления.уатПредоставленныеУслуги.Обороты(
			|			,
			|			,
			|			,
			|			ЗаказНаТС В (&мсвЗаказы) И ПолучательУслуг = &ПолучательУслуг) КАК уатПредоставленныеУслугиОбороты
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	уатРасчетыПоДокументамОбороты.Валюта,
			|	0,
			|	0,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходОборот,
			|	уатРасчетыПоДокументамОбороты.СуммаРасходУпрОборот
			|ИЗ
			|	РегистрНакопления.уатРасчетыПоДокументам.Обороты(
			|			,
			|			,
			|			,
			|			ЗаказНаТС В (&мсвЗаказы) И ПолучательУслуг = &ПолучательУслуг) КАК уатРасчетыПоДокументамОбороты");
			Запрос.УстановитьПараметр("мсвЗаказы", мсвЗаказы);
			Запрос.УстановитьПараметр("ПолучательУслуг",
				?(ТекДокумент.ВидАрендодателя = Перечисления.уатПолучателиУслуг.НашаОрганизация,
				Перечисления.уатПолучателиУслуг.Контрагент,
				Перечисления.уатПолучателиУслуг.НашаОрганизация));
			ВыборкаДанные = Запрос.Выполнить().Выбрать();
			
		Иначе
			мсвРез.Добавить(Рез);
			Продолжить;
			
		КонецЕсли;
		
		СуммаВыставленныхУслуг = 0;
		СуммаОплатыФакт = 0;
		Пока ВыборкаДанные.Следующий() Цикл
			Если ВыборкаДанные.Валюта = ТекДокумент.ВалютаДокумента Тогда
				СуммаВыставленныхУслуг = СуммаВыставленныхУслуг + ВыборкаДанные.СуммаПриход;
			ИначеЕсли ТекДокумент.ВалютаДокумента = ВалютаРегл И ВыборкаДанные.СуммаПриходРегл > 0 Тогда
				СуммаВыставленныхУслуг = СуммаВыставленныхУслуг + ВыборкаДанные.СуммаПриходРегл;
			Иначе
				СуммаВыставленныхУслуг = СуммаВыставленныхУслуг + уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(
					ВыборкаДанные.СуммаПриход,
					ВыборкаДанные.Валюта, ТекДокумент.ВалютаДокумента,
					ТекДокумент.Дата, ТекДокумент.Дата,,,,ТекДокумент);
			КонецЕсли;
			Если ВыборкаДанные.Валюта = ТекДокумент.ВалютаДокумента Тогда
				СуммаОплатыФакт = СуммаОплатыФакт + ВыборкаДанные.СуммаРасход;
			ИначеЕсли ТекДокумент.ВалютаДокумента = ВалютаУпр Тогда
				СуммаОплатыФакт = СуммаОплатыФакт + ВыборкаДанные.СуммаРасходУпр;
			Иначе
				СуммаОплатыФакт = СуммаОплатыФакт + уатОбщегоНазначенияТиповые.ПересчитатьИзВалютыВВалюту(
					ВыборкаДанные.СуммаРасход,
					ВыборкаДанные.Валюта, ТекДокумент.ВалютаДокумента,
					ТекДокумент.Дата, ТекДокумент.Дата,,,,ТекДокумент);
			КонецЕсли;
		КонецЦикла;
		
		Рез.СуммаОплатыФакт   = СуммаОплатыФакт;
		Рез.ПроцентОплатыФакт = Окр(?(СуммаВыставленныхУслуг = 0, 0, СуммаОплатыФакт / СуммаВыставленныхУслуг * 100), 2);
		Рез.Сумма             = СуммаВыставленныхУслуг;
	    Рез.СуммаПредоплаты   = Окр(СуммаВыставленныхУслуг * Рез.ПроцентПредоплаты / 100, 2);
		
		мсвРез.Добавить(Рез);
		
	КонецЦикла;
	
	// добавляем данные по пустому заказу, если он есть во входящем массиве
	Если флЕстьПустойЗаказ Тогда
		Рез = Новый Структура(
			"Документ, Сумма, ПроцентПредоплаты, СуммаПредоплаты, Валюта, СуммаОплатыФакт, ПроцентОплатыФакт",
			Документы.уатЗаказГрузоотправителя.ПустаяСсылка(), 0, 0, 0, Неопределено, 0, 0);
		мсвРез.Добавить(Рез);
	КонецЕсли;
	
	Возврат мсвРез;
	
КонецФункции

Функция НайтиСчетаНаОплатуПоставщикаПоРемонтномуЛисту(РемонтныйЛист) Экспорт
	мсвСчетаНаОплату = Новый Массив;
	
	Если ЗначениеЗаполнено(РемонтныйЛист.Сделка) Тогда
		мсвСчетаНаОплату.Добавить(РемонтныйЛист.Сделка);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	уатСчетНаОплатуПоставщика.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.уатСчетНаОплатуПоставщика КАК уатСчетНаОплатуПоставщика
	|ГДЕ
	|	НЕ уатСчетНаОплатуПоставщика.ПометкаУдаления
	|	И уатСчетНаОплатуПоставщика.ДокументОснование = &РЛ");
	Запрос.УстановитьПараметр("РЛ", РемонтныйЛист);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если мсвСчетаНаОплату.Найти(Выборка.Ссылка) = Неопределено Тогда
			мсвСчетаНаОплату.Добавить(Выборка.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат мсвСчетаНаОплату;
КонецФункции

Процедура ДобавитьЗаказыИзСчетаНакладной(ТекДокумент, мсвЗаказы, тблСвязанныеСделки = Неопределено)
	ТекДокументИмя = ТекДокумент.Метаданные().Имя;
	Если ТекДокументИмя = "уатПоступлениеТоваровУслуг" ИЛИ ТекДокументИмя = "уатСчетНаОплатуПоставщика" Тогда
		ИмяКолонкиЗаказ = "ЗаказНаТС";
	Иначе
		ИмяКолонкиЗаказ = "Заказ";
	КонецЕсли;
	
	Для Каждого ТекСтрока Из ТекДокумент.Услуги Цикл
		ТекЗаказ = ТекСтрока[ИмяКолонкиЗаказ];
		Если ЗначениеЗаполнено(ТекЗаказ) Тогда
			Если мсвЗаказы.Найти(ТекЗаказ) = Неопределено Тогда
				мсвЗаказы.Добавить(ТекЗаказ);
			КонецЕсли;
			
			Если тблСвязанныеСделки <> Неопределено Тогда
				мсвСтрокиПоиск = тблСвязанныеСделки.НайтиСтроки(Новый Структура("Документ, Сделка", ТекДокумент, ТекЗаказ));
				Если мсвСтрокиПоиск.Количество() = 0 Тогда
					НоваяСтрока = тблСвязанныеСделки.Добавить();
					НоваяСтрока.Документ = ТекДокумент;
					НоваяСтрока.Сделка   = ТекЗаказ;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Функция возвращает перечень документов "Поступление товаров и услуг" или "Реализация услуг"
// для указанного Счета на оплату поставщика или Счета на оплату покупателю соотвественно
//
// Параметры:
//  СчетНаОплату - ДокументСсылка - Счета на оплату поставщика или Счета на оплату покупателю
// 
// Возвращаемое значение:
//  Массив - массив документов "Поступление товаров и услуг" или "Реализация услуг"
//
Функция НакладныеДляСчетаНаОплату(СчетНаОплату) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Накладная.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.уатРеализацияУслуг КАК Накладная
	|ГДЕ
	|	Накладная.Проведен
	|	И (Накладная.Сделка = &Сделка ИЛИ Накладная.Ссылка = &ДокументОснование)");
	Если СчетНаОплату.Метаданные().Имя = "уатСчетНаОплатуПоставщика" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "уатРеализацияУслуг", "уатПоступлениеТоваровУслуг");
	КонецЕсли;
	Запрос.УстановитьПараметр("Сделка", СчетНаОплату);
	Запрос.УстановитьПараметр("ДокументОснование", СчетНаОплату.ДокументОснование);
	Рез = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	Возврат Рез;
КонецФункции

Процедура ДобавитьЭтапыМультимодальногоЗаказа(мсвЗаказы)
	ЗапросЭтапы = Новый Запрос(
	"ВЫБРАТЬ
	|	уатЗаказГрузоотправителя.РодительскийЗаказ КАК РодительскийЗаказ,
	|	уатЗаказГрузоотправителя.Ссылка КАК Этап
	|ИЗ
	|	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
	|ГДЕ
	|	уатЗаказГрузоотправителя.Проведен
	|	И уатЗаказГрузоотправителя.РодительскийЗаказ <> ЗНАЧЕНИЕ(Документ.уатЗаказГрузоотправителя.ПустаяСсылка)
	|	И уатЗаказГрузоотправителя.РодительскийЗаказ В (&мсвЗаказы)");
	ЗапросЭтапы.УстановитьПараметр("мсвЗаказы", мсвЗаказы);
	тблЭтапы = ЗапросЭтапы.Выполнить().Выгрузить();
	Для Каждого ТекЭтап Из тблЭтапы Цикл
		Если мсвЗаказы.Найти(ТекЭтап.Этап) = Неопределено Тогда
			мсвЗаказы.Добавить(ТекЭтап.Этап);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
			
#КонецОбласти

