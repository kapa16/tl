#Область ПрограммныйИнтерфейс

// Записывает замер операции бизнес-статистики в клиентский кэш замеров
//  для последующей передачи на сервер и сохранения.
//
// Параметры:
//  ИмяОперации  - Строка - Имя операции статистики, в случае отсутствия создается новое.
//  Значение     - Число  - Количественное значение операции статистики.
//  ТипЗаписи    - Число  - Идентификатор типа записи.
//  ПериодЗаписи - Дата   - Дата начала операции.
//
Процедура ЗаписатьОперациюБизнесСтатистики(ИмяОперации, Значение = 1, ТипЗаписи = 8, Знач ПериодЗаписи = '00010101') Экспорт
	
	// Определим время возникновения замеряемой операции.
	Если НЕ ЗначениеЗаполнено(ПериодЗаписи) Тогда
		ПериодЗаписи = ОбщегоНазначенияКлиент.ДатаУниверсальная();
	КонецЕсли;
	
	// Получим параметры подсистемы.
	ПараметрыПоддержки = ПараметрыПоддержкиНаКлиенте();
	
	// Если замеры не выполняются прерываем обработку.
	Если НЕ ПараметрыПоддержки.ВыполнятьЗамеры Тогда
		Возврат;
	КонецЕсли;
	
	// Регистрируем параметры операции.
	НовыйЗамер = Новый Структура("ПериодЗаписи,ТипЗаписи,Ключ,ИмяОперации,Значение,Замещать");
	НовыйЗамер.ПериодЗаписи = ПериодЗаписи;
	НовыйЗамер.ТипЗаписи    = ТипЗаписи;
	НовыйЗамер.Ключ         = Неопределено;
	НовыйЗамер.ИмяОперации  = ИмяОперации;
	НовыйЗамер.Значение     = Значение;
	НовыйЗамер.Замещать     = ЛОЖЬ;
	
	// Получаем коллекцию замеров текущего типа и внесем новый замер.
	Замеры = ПараметрыПоддержки.Замеры[ТипЗаписи];
	Если Замеры=Неопределено Тогда
		Замеры = Новый Массив();
		ПараметрыПоддержки.Замеры.Вставить(ТипЗаписи, Замеры);
	КонецЕсли;
	Замеры.Добавить(НовыйЗамер);
	
КонецПроцедуры // ЗаписатьОперациюБизнесСтатистики()

// Регистрирует начало замера длительности операции бизнес-статистики.
//
// Параметры:
//  ИмяОперации    - Строка - Имя операции статистики, в случае отсутствия создается новое.
//  АвтоЗавершение - Булево - Признак автоматического завершения операции.
//
Процедура НачатьЗамерОперацииБизнесСтатистики(ИмяОперации) Экспорт
	
	// Определим время начала замеряемой операции.
	ВремяНачала = ОбщегоНазначенияКлиент.ДатаУниверсальная();
	
	// Получим параметры подсистемы.
	ПараметрыПоддержки = ПараметрыПоддержкиНаКлиенте();
	
	// Если замеры не выполняются прерываем обработку.
	Если НЕ ПараметрыПоддержки.ВыполнятьЗамеры Тогда
		Возврат;
	КонецЕсли;
	
	// Помещаем новый замер в коллекцию начатых замеров.
	ПараметрыПоддержки.НачатыеЗамеры.Вставить(ИмяОперации, ВремяНачала);
	
КонецПроцедуры

// Обработка завершения замера длительности операции бизнес-статистики на клиенте.
//
// Параметры:
//  ИмяОперации		- Строка	- Имя операции статистики, в случае отсутствия создается новое.
//  ВремяОкончания	- Дата		- Дата окончания операции статистики.
//
Процедура ЗавершитьЗамерОперацииБизнесСтатистики(ИмяОперации, Знач ВремяОкончания = '00010101') Экспорт
	
	// Фиксируем время окончания пользовательского действия.
	Если НЕ ЗначениеЗаполнено(ВремяОкончания) Тогда
		ВремяОкончания = ОбщегоНазначенияКлиент.ДатаУниверсальная();
	КонецЕсли;
	
	// Получим параметры подсистемы.
	ПараметрыПоддержки = ПараметрыПоддержкиНаКлиенте();
	
	// Если замеры не выполняются прерываем обработку.
	Если НЕ ПараметрыПоддержки.ВыполнятьЗамеры Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем параметры с которыми замер был начат.
	ВремяНачала = ПараметрыПоддержки.НачатыеЗамеры[ИмяОперации];
	Если ВремяНачала = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Исключаем параметры текущего замера из коллекции начатых.
	ПараметрыПоддержки.НачатыеЗамеры.Удалить(ИмяОперации);
	
	// Рассчитаем длительность и произведем фиксацию замера.
	Длительность = ВремяОкончания - ВремяНачала;
	ТипЗаписи    = 9;
	ЗаписатьОперациюБизнесСтатистики(ИмяОперации, Длительность, ТипЗаписи, ВремяНачала);
	
КонецПроцедуры // ЗавершитьЗамерОперацииБизнесСтатистики()

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Вызывается из глобального обработчика ожидания каждые 60 сек
// для возможности централизованно передать данные с клиента на сервер.
// Например, для передачи статистики о количестве открытых окон.
// Не рекомендуется делать собственные глобальные обработчики ожидания,
// чтобы минимизировать общее количество серверных вызовов.
//
// Не рекомендуется передавать данные каждые 60 сек, а делать это реже
// в зависимости от реальной необходимости (ориентироваться на один раз в 20 минут).
// Не рекомендуется передавать избыточно большой объем данных,
// так как это уменьшает отзывчивость клиентского приложения.
//
// Для отправки данных с клиента на сервер заполните параметр Параметры,
// который затем будет передан в процедуру
// ОбщегоНазначенияПереопределяемый.ПриПериодическомПолученииДанныхКлиентаНаСервере.
//
// Параметры:
//  Параметры - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, передаваемого на сервер.
//    * Значение - Произвольный - значение параметра, передаваемого на сервер.
//
Процедура ПередПериодическойОтправкойДанныхКлиентаНаСервер(Параметры) Экспорт
	
	// Получим параметры подсистемы.
	ПараметрыПоддержки = ПараметрыПоддержкиНаКлиенте();
	
	// Определим наступило ли время обработки накопленных статистических данных.
	Если НЕ СерверныеОповещенияКлиент.ЗакончилосьВремяОжидания(КлючПараметров(), ПараметрыПоддержки.ПериодЗаписи, Истина) Тогда
		Возврат;
	КонецЕсли;
	
	// Передадим на сервер параметры подсистемы, как признак наступления события ожидания.
	Параметры.Вставить(КлючПараметров(), ПараметрыПоддержки);
	
КонецПроцедуры // ПередПериодическойОтправкойДанныхКлиентаНаСервер()

// Вызывается из глобального обработчика ожидания каждые 60 сек после возврата с сервера.
// Требуется, когда сервер возвращает результат для обработки на клиенте.
// Например, признак дальнейшей передачи статистики с клиента на сервер.
//
// Для получения результатов сервера на клиенте они должны быть заполнены
// в параметре Результаты в процедуре
// ОбщегоНазначенияПереопределяемый.ПриПериодическомПолученииДанныхКлиентаНаСервере.
//
// Параметры:
//  Результаты - Соответствие из КлючИЗначение:
//    * Ключ     - Строка       - имя параметра, возвращенного с сервера.
//    * Значение - Произвольный - значение параметра, возвращенного с сервера.
//
Процедура ПослеПериодическогоПолученияДанныхКлиентаНаСервере(Результаты) Экспорт
	
	// Обработаем в случае наличия ответа от сервера.
	Параметры = Результаты.Получить(КлючПараметров());
	Если Параметры = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Получим параметры подсистемы.
	ПараметрыПоддержки = ПараметрыПоддержкиНаКлиенте();
	
	// Замеры были переданы на сервер для записи, поэтому кеш можно очистить.
	ПараметрыПоддержки.Замеры.Очистить();
	
КонецПроцедуры // ПослеПериодическогоПолученияДанныхКлиентаНаСервере()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПараметрыПоддержкиНаКлиенте(ИмяПараметра=Неопределено) Экспорт
	
	// Найдем параметры подсистемы в кеше клиентского приложения
	ПараметрыПоддержки = ПараметрыПриложения[КлючПараметров()];
	
	// Если параметров в кеше нет, получим их
	Если ПараметрыПоддержки = Неопределено Тогда
		
		// Получаем параметры подсистемы переданные с сервера.
		ПараметрыПриЗапуске = СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиентаПриЗапуске();
		ПараметрыПоддержки  = Новый Структура(ПараметрыПриЗапуске[КлючПараметров()]);
		
		// Инициализируем обязательные клиентские параметры.
		ПараметрыПоддержки.Вставить("Замеры",        Новый Соответствие());
		ПараметрыПоддержки.Вставить("НачатыеЗамеры", Новый Соответствие());
		
		// Помещаем в кеш параметров клиентского приложения.
		ПараметрыПриложения.Вставить(КлючПараметров(), ПараметрыПоддержки);
		
	КонецЕсли;
	
	Если ИмяПараметра = Неопределено Тогда
		Возврат ПараметрыПоддержки;
	Иначе
		Возврат ПараметрыПоддержки[ИмяПараметра];
	КонецЕсли;
	
КонецФункции // ПараметрыПоддержкиНаКлиенте()

Функция КлючПараметров()
	
	Возврат "ПоддержкаОтраслевыхРешений";
	
КонецФункции // КлючПараметров()

#КонецОбласти
