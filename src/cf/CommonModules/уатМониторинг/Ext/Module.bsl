// Функция загружает координаты в регистр сведений "Координаты по мониторингу".
//
// Параметры:
//  ДатаНачала - Дата - дата, с которой необходимо получить данные;
//  ДатаОкончания - Дата - дата, до которой необходимо получить данные;
//  ПараметрыПроцедуры - Структура - см. функцию ПолучитьНастройкиМониторинга;
//  СтруктураПараметровУчетнойЗаписи - Структура - см. функцию ПолучитьСтруктуруПараметровДляРаботыССистемойМониторинга; 
//  ТаблицаДанных - Данные текущего местоположения;
//  ЕстьОшибки - Булево.
//
// Возвращаемое значение:
//  Булево - Истина, если загрузка данных выполнена без ошибок.
//
Функция ЗагрузитьТекущееМестоположениеТС(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ТаблицаДанных, ЕстьОшибки)
	
	ТекстОшибки = "";
	
	Если СтруктураПараметровУчетнойЗаписи.СистемаМониторинга = Справочники.уатВнешниеСистемы.Omnicomm Тогда
		
		Возврат Omnicomm_ЗагрузитьТекущееМестоположение(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ТаблицаДанных, ЕстьОшибки);
		
	ИначеЕсли СтруктураПараметровУчетнойЗаписи.СистемаМониторинга = Справочники.уатВнешниеСистемы.Wialon Тогда
		
		Возврат Wialon_ЗагрузитьТекущееМестоположение(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ТаблицаДанных, ЕстьОшибки);
		
	ИначеЕсли СтруктураПараметровУчетнойЗаписи.СистемаМониторинга = Справочники.уатВнешниеСистемы.АвтоГРАФ Тогда
		
		Возврат АвтоГРАФ_ЗагрузитьТекущееМестоположение(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ТаблицаДанных, ЕстьОшибки);
		
	ИначеЕсли СтруктураПараметровУчетнойЗаписи.СистемаМониторинга = Справочники.уатВнешниеСистемы.СКАУТ Тогда
		
		Возврат СКАУТ_ЗагрузитьТекущееМестоположение(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ТаблицаДанных, ЕстьОшибки);
		
	Иначе
		
		МассивТС = ПараметрыПроцедуры.МассивТС;
		КодВозврата = уатРаботаСРасширениями.ПСМ_ЗагрузитьТекущееМестоположениеТС(ДатаНачала, ДатаОкончания, МассивТС, ТекстОшибки, СтруктураПараметровУчетнойЗаписи);
		Возврат КодВозврата = 0;
		
	КонецЕсли;
	
	Возврат Истина;

КонецФункции

Процедура ЦСМ_ЗагрузкаТекущегоМестоположенияТС(МассивТС, ТаблицаДанных)
	ИспользоватьЦСМ = уатОбщегоНазначения_проф.ИспользованиеЦСМ();
	
	Если НЕ ИспользоватьЦСМ Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаАктальныхДанных = ItobИнтерфейсДанныхМониторинга.АктуальныеДанныеТерминаловОбъектовМониторинга(МассивТС);
	Для Каждого ТекСтрока Из ТаблицаАктальныхДанных Цикл
		
		ТекТС = ТаблицаДанных.Найти(ТекСтрока.Объект, "ТС"); 
		Если ТекТС <> Неопределено
			И ТекТС.Дата < ТекСтрока.Период Тогда
			СтрокаКоорд = ТекТС;
		ИначеЕсли ТекТС <> Неопределено
			И ТекТС.Дата >= ТекСтрока.Период Тогда
			Продолжить;
		Иначе
			СтрокаКоорд = ТаблицаДанных.Добавить();
		КонецЕсли;

		СтруктураДанных = Новый Структура();
		СтруктураДанных.Вставить("Дата",    ТекСтрока.Период);
		СтруктураДанных.Вставить("ТС",      ТекСтрока.Объект);
		СтруктураДанных.Вставить("Широта",  ТекСтрока.Широта);
		СтруктураДанных.Вставить("Долгота", ТекСтрока.Долгота);
		СтруктураДанных.Вставить("Долгота", ТекСтрока.Долгота);
		СтруктураДанных.Вставить("Скорость",ТекСтрока.Скорость);
		СтруктураДанных.Вставить("Курс",    ТекСтрока.Направление);
		СтруктураДанных.Вставить("УведомлениеОтправлено", Ложь);
		
		ЗаполнитьЗначенияСвойств(СтрокаКоорд, СтруктураДанных);
	КонецЦикла;

КонецПроцедуры

Процедура ОбновитьПробегМоточасыПриЗагрузке(МассивТС)
	
	// Получим ПЛ
	МассивДокументов = Новый Массив();

	АктальнаяДата = ТекущаяДатаСеанса() - 24 * 60 * 60; 
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("АктальнаяДата", АктальнаяДата);
	Запрос.УстановитьПараметр("МассивТС", МассивТС);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатПутевойЛист.Ссылка КАК Ссылка,
	               |	уатПутевойЛист.Организация КАК Организация,
	               |	уатПутевойЛист.Подразделение КАК Подразделение
	               |ИЗ
	               |	Справочник.уатТС КАК уатТС
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатПутевойЛист КАК уатПутевойЛист
	               |		ПО (уатПутевойЛист.ТранспортноеСредство = уатТС.Ссылка)
	               |ГДЕ
	               |	НЕ уатПутевойЛист.Рассчитан
	               |	И уатПутевойЛист.Проведен
	               |	И (уатТС.ИДвСистемеНавигации <> """"
	               |			ИЛИ уатТС.ИспользуемаяСистемаGPS = ЗНАЧЕНИЕ(Справочник.уатВнешниеСистемы._1СЦСМ))
	               |	И уатТС.Ссылка В(&МассивТС)
	               |	И уатПутевойЛист.ДатаВозвращения >= &АктальнаяДата
	               |ИТОГИ ПО
	               |	Организация,
	               |	Подразделение"; 
	ВыборкаОрганизация = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизация.Следующий() Цикл
		СтруктураОбъектовНастроек = Новый Структура;
		СтруктураОбъектовНастроек.Вставить("Организация", ВыборкаОрганизация.Организация);
		
		ВыборкаПодразделение = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		Пока ВыборкаПодразделение.Следующий() Цикл 
			СтруктураОбъектовНастроек.Вставить("Подразделение", ВыборкаПодразделение.Подразделение);
			ОбновлятьПробегМоточасыВПЛПриЗагрузке = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, 
				ПланыВидовХарактеристик.уатПраваИНастройки.ОбновлятьПробегМоточасыВПЛПриЗагрузке);
			Если ОбновлятьПробегМоточасыВПЛПриЗагрузке Тогда
				Выборка = ВыборкаПодразделение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Выборка.Следующий() Цикл
					МассивДокументов.Добавить(Выборка.Ссылка);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	Для Каждого ТекДокумент Из МассивДокументов Цикл  
		ОбновитьПробегВПутевыхЛистах(ТекДокумент);
	КонецЦикла;
	
	// Получим МЛ
	МассивДокументов = Новый Массив();
	
	Запрос = Новый Запрос();  
	Запрос.УстановитьПараметр("АктальнаяДата", АктальнаяДата);
	Запрос.УстановитьПараметр("МассивТС", МассивТС);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	уатМаршрутныйЛист.Ссылка КАК Ссылка,
	               |	уатМаршрутныйЛист.Организация КАК Организация,
	               |	уатМаршрутныйЛист.Подразделение КАК Подразделение
	               |ИЗ
	               |	Справочник.уатТС КАК уатТС
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатМаршрутныйЛист КАК уатМаршрутныйЛист
	               |			ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатМаршрутныйЛист.Заказы КАК уатМаршрутныйЛистЗаказы
	               |			ПО уатМаршрутныйЛист.Ссылка = уатМаршрутныйЛистЗаказы.Ссылка
	               |		ПО (уатМаршрутныйЛист.ТС = уатТС.Ссылка)
	               |ГДЕ
	               |	НЕ уатМаршрутныйЛист.Рассчитан
	               |	И уатМаршрутныйЛист.Проведен
	               |	И (уатТС.ИДвСистемеНавигации <> """"
	               |			ИЛИ уатТС.ИспользуемаяСистемаGPS = ЗНАЧЕНИЕ(Справочник.уатВнешниеСистемы._1СЦСМ))
	               |	И уатТС.Ссылка В(&МассивТС)
	               |	И ВЫБОР
	               |			КОГДА уатМаршрутныйЛистЗаказы.УбытиеФакт <> ДАТАВРЕМЯ(1, 1, 1)
	               |				ТОГДА уатМаршрутныйЛистЗаказы.УбытиеФакт >= &АктальнаяДата
	               |			ИНАЧЕ уатМаршрутныйЛистЗаказы.УбытиеПлан >= &АктальнаяДата
	               |		КОНЕЦ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	уатМаршрутныйЛист.Ссылка,
	               |	уатМаршрутныйЛист.Организация,
	               |	уатМаршрутныйЛист.Подразделение
	               |ИТОГИ ПО
	               |	Организация,
	               |	Подразделение"; 
	ВыборкаОрганизация = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизация.Следующий() Цикл
		СтруктураОбъектовНастроек = Новый Структура;
		СтруктураОбъектовНастроек.Вставить("Организация", ВыборкаОрганизация.Организация);
		
		ВыборкаПодразделение = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		Пока ВыборкаПодразделение.Следующий() Цикл 
			СтруктураОбъектовНастроек.Вставить("Подразделение", ВыборкаПодразделение.Подразделение);
			ОбновлятьПробегМоточасыВМЛПриЗагрузке = уатПраваИНастройки.уатПолучитьПраваИНастройкиПользователя(СтруктураОбъектовНастроек, 
				ПланыВидовХарактеристик.уатПраваИНастройки.ОбновлятьПробегМоточасыВМЛПриЗагрузке);
			Если ОбновлятьПробегМоточасыВМЛПриЗагрузке Тогда
				Выборка = ВыборкаПодразделение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Выборка.Следующий() Цикл
					МассивДокументов.Добавить(Выборка.Ссылка);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	Для Каждого ТекДокумент Из МассивДокументов Цикл  
		ОбновитьПробегВМаршрутныхЛистах(ТекДокумент);
	КонецЦикла;
	
	Если уатОбщегоНазначенияПовтИсп.ВариантПоставкиТакси() Тогда
		МодульОбщегоНазначенияСервер = ОбщегоНазначения.ОбщийМодуль("такОбщегоНазначенияСервер");
		МодульОбщегоНазначенияСервер.ОбновитьПробегМоточасыПриЗагрузке(МассивТС);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьПробегВМаршрутныхЛистах(МаршрутныйЛист)
	
	ДокОбъект = МаршрутныйЛист.ПолучитьОбъект(); 
	Если ЗаполнитьПробегВМаршрутныхЛистах(ДокОбъект) Тогда
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение 
			ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецПопытки; 
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбновитьПробегВПутевыхЛистах(ПутевойЛист)
	
	ОбъектСтруктура = Новый Структура;
	ОбъектСтруктура.Вставить("Организация",           ПутевойЛист.Организация);
	ОбъектСтруктура.Вставить("ТранспортноеСредство",  ПутевойЛист.ТранспортноеСредство);
	ОбъектСтруктура.Вставить("ДатаВыезда",            ПутевойЛист.ДатаВыезда);
	ОбъектСтруктура.Вставить("ДатаВозвращения",       ПутевойЛист.ДатаВозвращения);
	ОбъектСтруктура.Вставить("СпидометрВыезда",       ПутевойЛист.СпидометрВыезда);
	ОбъектСтруктура.Вставить("СпидометрВозвращения",  ПутевойЛист.СпидометрВозвращения);
	ОбъектСтруктура.Вставить("РасчетФактРасходаГСМ",  ПутевойЛист.РасчетФактРасходаГСМ);
	ОбъектСтруктура.Вставить("Прицепы",               Новый Массив());
	
	Для Каждого ТекПрицеп Из ПутевойЛист.Прицепы Цикл 
		СтрокаПрицепа = Новый Структура("ТС, СпидометрВыезда, СпидометрВозвращения",
		ТекПрицеп.ТС,
		ТекПрицеп.СчетчикМЧВыезда,
		ТекПрицеп.СчетчикМЧВозвращения);
		ОбъектСтруктура.Прицепы.Добавить(СтрокаПрицепа);
	КонецЦикла;
	
	РезультатСтруктура = Новый Структура;
	
	// РАСЧЕТ.
	уатМониторинг.РассчитатьСпидометрПоМониторингу(ОбъектСтруктура, РезультатСтруктура);  
	
	ДокОбъект = ПутевойЛист.ПолучитьОбъект(); 
	
	Если РезультатСтруктура.Свойство("ПробегПоGPS") Тогда
		ТС = ПутевойЛист.ТранспортноеСредство;
		КоличествоВыработки = Окр(РезультатСтруктура.ПробегПоGPS, 2, РежимОкругления.Окр15как20);
		ПараметрВыработки   = Справочники.уатПараметрыВыработки.ПробегОбщийПоДаннымGPS; 
		ДокОбъект.ЗаписатьСтрокуВыработкиТС(ТС, ПараметрВыработки, КоличествоВыработки,,,Истина);
	КонецЕсли;

	Если РезультатСтруктура.Свойство("МоточасыПоGPS") Тогда
		ТС = ПутевойЛист.ТранспортноеСредство;
		КоличествоВыработки = уатОбщегоНазначения.уатВремяВЧЧ_ММ(РезультатСтруктура.МоточасыПоGPS * 3600);
		ПараметрВыработки   = Справочники.уатПараметрыВыработки.ВремяВРаботеПоДаннымGPS; 
		ДокОбъект.ЗаписатьСтрокуВыработкиТС(ТС, ПараметрВыработки, уатОбщегоНазначения.уатВремяВСекунды(КоличествоВыработки),,,Истина);
	КонецЕсли;
	
	// Заполнение основных реквизитов.
	Если РезультатСтруктура.Свойство("СчетчикПоGPS") Тогда
		ДокОбъект.ПробегПоGPS = РезультатСтруктура.СчетчикПоGPS;
	КонецЕсли; 
	// Заполнение данных по прицепам.
	Для Каждого ТекПрицеп Из РезультатСтруктура.Прицепы Цикл  
		НайдСтроки = ДокОбъект.Прицепы.НайтиСтроки(Новый Структура("ТС", ТекПрицеп.ТС));
		Если НайдСтроки.Количество() Тогда
			НайдСтроки[0].СчетчикМЧGPS = ТекПрицеп.СчетчикПоGPS; 
			
			Если ТекПрицеп.Свойство("ПробегПоGPS") Тогда
				ТС = ТекПрицеп.ТС;
				КоличествоВыработки = Окр(ТекПрицеп.ПробегПоGPS, 2, РежимОкругления.Окр15как20);
				ПараметрВыработки = Справочники.уатПараметрыВыработки.ПробегОбщийПоДаннымGPS; 
				ДокОбъект.ЗаписатьСтрокуВыработкиТС(ТС, ПараметрВыработки, КоличествоВыработки,,,Истина);
			КонецЕсли;
			
			Если ТекПрицеп.Свойство("МоточасыПоGPS") Тогда
				ТС = ТекПрицеп.ТС;
				КоличествоВыработки = уатОбщегоНазначения.уатВремяВЧЧ_ММ(ТекПрицеп.МоточасыПоGPS * 3600);
				ПараметрВыработки   = Справочники.уатПараметрыВыработки.ВремяВРаботеПоДаннымGPS; 
				ДокОбъект.ЗаписатьСтрокуВыработкиТС(ТС, ПараметрВыработки, уатОбщегоНазначения.уатВремяВСекунды(КоличествоВыработки),,,Истина);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла; 
	ДокОбъект.ДатаОбновленияДанныхМониторинга = ТекущаяДатаСеанса();
	Попытка
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки; 
	
	
КонецПроцедуры

Процедура Пауза(Секунды)
	 
	ВремяОкончания = ТекущаяДатаСеанса() + Секунды;
	Пока ТекущаяДатаСеанса() <= ВремяОкончания Цикл
	КонецЦикла;
	
КонецПроцедуры

Функция РазделитьНаПериоды(ДатаНачала, ДатаОкончания, ЧастотаМинуты)
	МассивПериодов = Новый Массив;
	ЧастотаВСекундах = ЧастотаМинуты * 60;
	ТекДата = ДатаНачала;
	Пока ТекДата + ЧастотаВСекундах <= ДатаОкончания Цикл
		МассивПериодов.Добавить(Новый Структура("ДатаНачала, ДатаОкончания", 
			ТекДата, ТекДата + ЧастотаВСекундах));
		ТекДата = ТекДата + ЧастотаВСекундах;
	КонецЦикла;
	
	Возврат МассивПериодов;
КонецФункции

Процедура РасчитатьОдометрДляРегистра(ТаблицаДанных, ТСБезОдометра)
	Для каждого ТС Из ТСБезОдометра Цикл
		СтрокиДляТС = ТаблицаДанных.НайтиСтроки(Новый Структура("ТС", ТС));
		Если СтрокиДляТС.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		СрезПоследних = РегистрыСведений.уатПробегРасходПоМониторингу.СрезПоследних(СтрокиДляТС[0].Период, Новый Структура("ТС", ТС));
		Если СрезПоследних.Количество() = 0 Тогда
			ТекОдометр = 0;
		Иначе
			ТекОдометр = СрезПоследних[0].ЗначениеОдометра;
		КонецЕсли;
		Для каждого текПробегРасходДляТС Из СтрокиДляТС Цикл
			текПробегРасходДляТС.ЗначениеОдометра = ТекОдометр + текПробегРасходДляТС.Пробег;
			ТекОдометр = текПробегРасходДляТС.ЗначениеОдометра;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Процедура ОчиститьВыбранныеРегистры(СоответствиеРегистров, ДатаПо)
	
	РезультатУспешно = Истина;
	
	Для каждого ТекРегистр Из СоответствиеРегистров Цикл
		
		Если РезультатУспешно Тогда
			
			НазваниеРегистра = ТекРегистр.Ключ;
			
			Если НазваниеРегистра = "уатИсторияКоординатМП" Тогда
				ПолеВремени = "Дата";
			Иначе
				ПолеВремени = "Период";
			КонецЕсли;
			
			ДатаС = '00010101000000';
			
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ
			|	" + НазваниеРегистра + "." + ПолеВремени + " КАК " + ПолеВремени + "
			|ИЗ
			|	РегистрСведений." + НазваниеРегистра + " КАК " + НазваниеРегистра + "
			|ГДЕ
			|	" + НазваниеРегистра + "." + ПолеВремени + " МЕЖДУ &ДатаС И &ДатаПо";
			Запрос.УстановитьПараметр("ДатаС", ДатаС);
			Запрос.УстановитьПараметр("ДатаПо", ДатаПо);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НаборЗаписей = ТекРегистр.Значение;
				Если НазваниеРегистра = "уатИсторияКоординатМП" Тогда
					НаборЗаписей.Отбор.Дата.Установить(Выборка.Дата);
				Иначе
					НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
				КонецЕсли;
				Попытка
					НаборЗаписей.Записать(Истина);
				Исключение
					Возврат;
				КонецПопытки;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьРежимЗамещениеСлияние() 
	
	Попытка
		РежимЗамещения = Неопределено;
	Исключение
	КонецПопытки;
	
	Возврат РежимЗамещения.Слияние;
	
КонецФункции

Функция ЗаписатьДанныеВРегистр(ИмяРегистра, ТабДляРегистра, МассивТС, ДатаНачала, ДатаОкончания, ИмяСобытия, ТекстОшибки = "")
	
	// Выполним поиск дублей  
	Замещать         = Ложь;
	ОчиститьДанные   = Истина;
	СтруктураКолонок = "Период,ТС";
	Если ИмяРегистра = "уатКоординатыПоМониторингу" Тогда
		СистемнаяИнформация = Новый СистемнаяИнформация;
		Если ОбщегоНазначенияКлиентСервер.СравнитьВерсии(СистемнаяИнформация.ВерсияПриложения, "8.3.25.0") >= 0 Тогда
			Замещать       = ПолучитьРежимЗамещениеСлияние(); 
			ОчиститьДанные = Ложь;
		КонецЕсли;   
		
	ИначеЕсли ИмяРегистра = "уатДополнительныеСведенияПоGPS" Тогда 
		СтруктураКолонок = "Период,ТС,ТипСобытия";
	КонецЕсли;
	
	ТекДатаНачала     = ДатаНачала;
	ТекДатаОкончания  = ДатаОкончания;
	
	ТабДляРегистра.Сортировать(СтруктураКолонок);
	ТабДляРегистра.Колонки.Добавить("ЭтоДубль", Новый ОписаниеТипов("Булево"));
	Для Каждого ТекСтрока Из ТабДляРегистра Цикл
		Если ТекСтрока.ЭтоДубль Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураОтбора = Новый Структура(СтруктураКолонок);
		ЗаполнитьЗначенияСвойств(СтруктураОтбора, ТекСтрока); 
		
		НайденныеСтроки = ТабДляРегистра.НайтиСтроки(СтруктураОтбора);
		Если НайденныеСтроки.Количество() > 1 Тогда
			Для Сч = 1 По НайденныеСтроки.Количество() - 1 Цикл
				 НайденныеСтроки[Сч].ЭтоДубль = Истина;
			КонецЦикла;
		КонецЕсли;
		
		ТекДатаНачала    = Мин(ТекДатаНачала, ТекСтрока.Период);
		ТекДатаОкончания = Макс(ТекДатаОкончания, ТекСтрока.Период);
	КонецЦикла; 
	НайденныеДубли = ТабДляРегистра.НайтиСтроки(Новый Структура("ЭтоДубль", Истина));
	Для Каждого ТекСтрока Из НайденныеДубли Цикл
		ТабДляРегистра.Удалить(ТекСтрока);
	КонецЦикла;
	
	Если ОчиститьДанные Тогда
		Если НЕ ОчиститьДанныеРегистраСведенийВИнтервале(ИмяРегистра,
			МассивТС, ТекДатаНачала, ТекДатаОкончания, ТекстОшибки) Тогда 
			ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.ОбщиеМодули.уатМониторинг,
			,
			ТекстОшибки
			);
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	// Запишем новые данные.
	НаборЗап = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
	НаборЗап.Загрузить(ТабДляРегистра);
	НаборЗап.Записывать = Истина;
	Попытка
		НаборЗап.Записать(Замещать);
	Исключение
		ТекстОшибки = НСтр("en='Error occurred while saving set to register';ru='Возникла ошибка при записи набора в регистр.'") +  Символы.ПС + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.ОбщиеМодули.уатМониторинг,
			,
			ТекстОшибки
		);
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
КонецФункции

#КонецОбласти

#КонецОбласти
