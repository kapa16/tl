Функция СКАУТ_REST_ЗагрузитьСписокДатчиков(ИдентификаторТС, МассивДатчиков, ТекстОшибки, УчетнаяЗапись) Экспорт 
	
	СтруктураПараметровУчетнойЗаписи = ПолучитьСтруктуруПараметровДляРаботыССистемойМониторинга(УчетнаяЗапись);
	
	Если Не ЗначениеЗаполнено(уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи, "Login",, ТекстОшибки)) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"Login",, ТекстОшибки);
			Если Не ЗначениеЗаполнено(РезультатЗапроса) Тогда
				Возврат Ложь;
			КонецЕсли;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("ИдентификаторТС", ИдентификаторТС);

	РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
		"Sensors", ПараметрыЗапроса, ТекстОшибки);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"Sensors", ПараметрыЗапроса, ТекстОшибки);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				Возврат 1;
			КонецЕсли;
		Иначе
			Возврат 1;
		КонецЕсли;
	КонецЕсли;
	
	Если РезультатЗапроса <> Неопределено Или РезультатЗапроса.Количество <> 0 Тогда
		Для Каждого ТекСтрока Из РезультатЗапроса Цикл
			Активен = ТекСтрока.Получить("isEnabled");
			Если Не Активен Тогда
				Продолжить
			КонецЕсли;
			НазваниеДатчика = ТекСтрока.Получить("name");
			МассивДатчиков.Добавить(Новый Структура("Значение, Представление", 
			НазваниеДатчика, НазваниеДатчика));
		КонецЦикла;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

// Функция загружает пробег и расход ГСМ из системы СКАУТ (через ВебСервис REST) в регистр сведений "Пробег и расход по мониторингу"
//
// Параметры:
//  ДатаНачала - дата, с которой необходимо получить данные;
//  ДатаОкончания - дата, до которой необходимо получить данные;
//  ПараметрыПроцедуры - Структура - см. функцию ПолучитьНастройкиМониторинга;
//  СтруктураПараметровУчетнойЗаписи - Структура - см. функцию ПолучитьСтруктуруПараметровДляРаботыССистемойМониторинга;
//  ЕстьОшибки - Булево
//
// Возвращаемое значение:
//  Булево - Истина, если загрузка данных выполнена без ошибок.
//
Функция СКАУТ_REST_ЗагрузитьПробегИРасходГСМ(ДатаНачала, ДатаОкончания, ПараметрыПроцедуры, СтруктураПараметровУчетнойЗаписи, ЕстьОшибки)
	// Фиксация операции для статистики
	ИмяКлючевойОперации = "уатОперации.ЗагрузкаДанныхИзМониторинга.Местоположение.СКАУТ.ВебСервис";
	ЦентрМониторинга.ЗаписатьОперациюБизнесСтатистики(ИмяКлючевойОперации, ПараметрыПроцедуры.МассивТС.Количество());
	ТекстОшибки  = "";
	
	Если Не ЗначениеЗаполнено(уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи, "Login",, ТекстОшибки)) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"Login",, ТекстОшибки);
			Если Не ЗначениеЗаполнено(РезультатЗапроса) Тогда
				Возврат Ложь;
			КонецЕсли;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	МассивТС = ПараметрыПроцедуры.МассивТС;
	
	НаборЗаписей   = РегистрыСведений.уатПробегРасходПоМониторингу.СоздатьНаборЗаписей();
	ТабДляРегистра = НаборЗаписей.Выгрузить();
	ТабДляРегистра.Очистить();
	
	МассивИдентификаторовТС = Новый Массив();
	
	Для каждого текТС Из МассивТС Цикл
		МассивИдентификаторовТС.Добавить(Число(текТС.ИДвСистемеНавигации));
	КонецЦикла;
	ПараметрыЗапроса = Новый Структура();
	ТекстОшибки  = "";
	ДанныеПоВидуОтчета = Новый Структура("IDВидаОтчета, ТаргетВидаОтчета", "f2cd22bd-08ec-4687-b9f7-da97d17787f5", 1);
	ПараметрыЗапроса.Вставить("ДанныеПоВидуОтчета", ДанныеПоВидуОтчета);
	ПараметрыЗапроса.Вставить("МассивИдентификаторовТС", МассивИдентификаторовТС);
	ПараметрыЗапроса.Вставить("ЧасовойПояс", ПараметрыПроцедуры.ЧасовойПояс);
	
	Если ПараметрыПроцедуры.ЗагружатьДанныеПоВремениРаботыДвигателя Тогда
		
		ЧастотаФормированияПериодов = ПараметрыПроцедуры.ИнтервалЗагрузкиПробега;
		МассивПериодов = РазделитьНаПериоды(ДатаНачала, ДатаОкончания, ЧастотаФормированияПериодов);
		
		МассивРезультатовЗапросов = Новый Массив();
		Для Каждого ТекПериод Из МассивПериодов Цикл
			
			РезультатЗапроса = СКАУТ_REST_ВыполнитьЗапросПробегаИРасхода(ТекПериод.ДатаНачала, ТекПериод.ДатаОкончания, СтруктураПараметровУчетнойЗаписи, ПараметрыЗапроса, ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ЕстьОшибки = Истина;
				Возврат Ложь;
			КонецЕсли;
			
			Если РезультатЗапроса = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			МассивРезультатовЗапросов.Добавить(
			Новый Структура("ДатаНачала,ДатаОкончания,РезультатЗапроса",
				ТекПериод.ДатаНачала, ТекПериод.ДатаОкончания, РезультатЗапроса));
				
		КонецЦикла;
		СоответсвиеТС = ПараметрыПроцедуры.СоответсвиеТС;
		ТаблицаДанных = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_ПробегИРасходГСМСИтогами(
		МассивРезультатовЗапросов, СтруктураПараметровУчетнойЗаписи, СоответсвиеТС, ЕстьОшибки);
		
	Иначе
		
		РезультатЗапроса = СКАУТ_REST_ВыполнитьЗапросПробегаИРасхода(ДатаНачала, ДатаОкончания, СтруктураПараметровУчетнойЗаписи, ПараметрыЗапроса, ТекстОшибки);
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			ЕстьОшибки = Истина;
			Возврат Ложь;
		КонецЕсли;
		
		Если РезультатЗапроса = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СоответсвиеТС = ПараметрыПроцедуры.СоответсвиеТС;
		ТаблицаДанных = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_ПробегИРасходГСМ(
		РезультатЗапроса, СтруктураПараметровУчетнойЗаписи, СоответсвиеТС, ЕстьОшибки);
		
	КонецЕсли;
		
	Отбор = Новый Структура("Пробег,ВремяРаботыДвигателя,УровеньТоплива,РасходТоплива",0,0,0,0);
	МассивПустыхСтрок = ТаблицаДанных.НайтиСтроки(Отбор);
	Для Каждого СтрокаМассива из МассивПустыхСтрок Цикл
		ТаблицаДанных.Удалить(СтрокаМассива);
	КонецЦикла;
	
	ТССОдометром =  Новый Массив;
	ТСБезОдометра = Новый Массив;
	
 	СоответствиеТС = ПараметрыПроцедуры.СоответсвиеТС;
	
	Для каждого ТекТС Из СоответствиеТС Цикл
		Если ПустаяСтрока(ТекТС.Значение.Ссылка.ДатчикОдометр) Тогда
			ТСБезОдометра.Добавить(ТекТС.Значение.Ссылка);
		Иначе
			ТССОдометром.Добавить(ТекТС);
		КонецЕсли;
	КонецЦикла;
	
	Если ТСБезОдометра.Количество() > 0 Тогда
		РасчитатьОдометрДляРегистра(ТаблицаДанных, ТСБезОдометра);
	КонецЕсли;
	
	Если ТССОдометром.Количество() > 0 Тогда
		ИтоговаяТаблицаДанных = СКАУТ_REST_ПолучитьЗначенияОдометра(ТССОдометром, ТаблицаДанных, СтруктураПараметровУчетнойЗаписи, ПараметрыЗапроса, ТекстОшибки);
	Иначе
		ИтоговаяТаблицаДанных = ТаблицаДанных;
	КонецЕсли;
	
	Если НЕ ЗаписатьДанныеВРегистр("уатПробегРасходПоМониторингу",
		ИтоговаяТаблицаДанных, ПараметрыПроцедуры.МассивТС, ДатаНачала, ДатаОкончания, "Мониторинг. СКАУТ", ТекстОшибки) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;
	
КонецФункции

Функция СКАУТ_REST_ВыполнитьЗапросПробегаИРасхода(ДатаНачала, ДатаОкончания, СтруктураПараметровУчетнойЗаписи, ПараметрыЗапроса, ТекстОшибки)
	ПараметрыЗапроса.Вставить("ДатаНачала",    ДатаНачала);
	ПараметрыЗапроса.Вставить("ДатаОкончания", ДатаОкончания);
	
	ТекстОшибки  = "";
	РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
	"GetStatisticID", ПараметрыЗапроса, ТекстОшибки);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"GetStatisticID", ПараметрыЗапроса, ТекстОшибки);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ЕстьОшибки = Истина;
				Возврат Ложь;
			КонецЕсли;
		Иначе
			ЕстьОшибки = Истина;
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	IDОтчета = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_IDОтчета(РезультатЗапроса);
	СтруктураПараметровУчетнойЗаписи.Вставить("IDОтчета", IDОтчета);
	СтатусОтчета = Новый Структура("Статус, Путь", 0, "");
	Пока СтатусОтчета.Статус <> 4 Цикл
		ТекстОшибки  = "";
		Пауза(2);
		РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
		"GetStatisticStatus", ПараметрыЗапроса, ТекстОшибки);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
				РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
					"GetStatisticStatus", ПараметрыЗапроса, ТекстОшибки);
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					ЕстьОшибки = Истина;
					Прервать;
				КонецЕсли;
			Иначе
				ЕстьОшибки = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
		СтатусОтчета = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_СтатусОтчета(РезультатЗапроса);
		Если СтатусОтчета.ТекстОшибки = "Пустой отчёт" Тогда
			ТекстОшибки = НСтр("ru = 'Отчет с ID %1 является пустым.'");
			ЗаписьЖурналаРегистрации(
			"Мониторинг. СКАУТ",
			УровеньЖурналаРегистрации.Информация,
			Метаданные.ОбщиеМодули.уатМониторинг,
			,
			ТекстОшибки
			);
			Возврат Неопределено;
		КонецЕсли;
		Если СтатусОтчета.Ошибка <> Неопределено Тогда
			ТекстОшибки = СтатусОтчета.ТекстОшибки;
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если СтатусОтчета.Статус <> 4 Тогда
		ТекстОшибки = НСтр("ru = 'Возникла ошибка при формировании отчета по движениям и стоянкам.'; en = 'An error occurred while generating the movement and parking report.'") +  Символы.ПС + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(
		"Мониторинг. СКАУТ",
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.ОбщиеМодули.уатМониторинг,
		,
		ТекстОшибки
		);
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметровУчетнойЗаписи.Вставить("ПутьКОтчету", СтатусОтчета.Путь);
	РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
	"GetStatistic", ПараметрыЗапроса, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"GetStatistic", ПараметрыЗапроса, ТекстОшибки);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ЕстьОшибки = Истина;
				Возврат Ложь;
			КонецЕсли;
		Иначе
			ЕстьОшибки = Истина;
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
КонецФункции

Функция СКАУТ_REST_ПолучитьЗначенияОдометра(ТССОдометром, ТаблицаДанных, СтруктураПараметровУчетнойЗаписи, ПараметрыЗапроса, ТекстОшибки)
	
	Для каждого ТекТС Из ТССОдометром Цикл
		ТС = ТекТС.Значение.Ссылка;
		ТаблицаДанныхПоТС = ТаблицаДанных.НайтиСтроки(Новый Структура("ТС", ТС));
		IDТС = ТекТС.Ключ;
		ПараметрыЗапроса.Вставить("ИдентификаторТС", IDТС);
		ТекстОшибки = "";
		РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
		"Sensors", ПараметрыЗапроса, ТекстОшибки);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
				РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"Sensors", ПараметрыЗапроса, ТекстОшибки);
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					ЕстьОшибки = Истина;
					Возврат Ложь;
				КонецЕсли;
			Иначе
				ЕстьОшибки = Истина;
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
		НомерИТипДатчика = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_ДоступныеДатчики(
		РезультатЗапроса, СтруктураПараметровУчетнойЗаписи, ТС.ДатчикОдометр);
		Если НомерИТипДатчика = 1 Тогда
			Продолжить;
		КонецЕсли;
		Для каждого ТекЗапись Из ТаблицаДанныхПоТС Цикл
			Если Не ПараметрыЗапроса.Свойство("СводныеДанные") Тогда
				Период = ТекЗапись.Период;
				ПараметрыЗапроса.Вставить("ДатаНачала",    Период);
				ПараметрыЗапроса.Вставить("ДатаОкончания", Период + (3600*24*7));
			Иначе
				ПараметрыЗапроса.Вставить("ДатаНачала",    ПараметрыЗапроса.ДатаНачала);
				ПараметрыЗапроса.Вставить("ДатаОкончания", ПараметрыЗапроса.ДатаОкончания);
			КонецЕсли;
			ПараметрыЗапроса.Вставить("НомерИТипДатчика", НомерИТипДатчика);
			РезультатЗапроса = уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи,
			"Odometr", ПараметрыЗапроса, ТекстОшибки);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
					РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
					"Odometr", ПараметрыЗапроса, ТекстОшибки);
					Если ЗначениеЗаполнено(ТекстОшибки) Тогда
						ЕстьОшибки = Истина;
						Возврат Ложь;
					КонецЕсли;
				Иначе
					ЕстьОшибки = Истина;
					Возврат Ложь;
				КонецЕсли;
			КонецЕсли;
			уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьОбработкуРезультатаЗапроса_ДанныеОдометра(
			РезультатЗапроса, ТС, ТекЗапись, ПараметрыЗапроса);
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаДанных;
	
КонецФункции

// Процедура выполняет получение таблицы ТС из системы СКАУТ (через ВебСервис REST)
//
// Параметры:
//  ТаблицаТС - Колонки - Наименование, ИДвСистеме и ГаражныйНомер
//  СтруктураПараметровУчетнойЗаписи - Структура - см. функцию ПолучитьСтруктуруПараметровДляРаботыССистемойМониторинга;
//  ТекстОшибки - Строка
//
Процедура СКАУТ_REST_ПолучитьДанныеВсехТС(ТаблицаТС, СтруктураПараметровУчетнойЗаписи, ТекстОшибки)
	Если Не ЗначениеЗаполнено(уатИнтеграцияМониторингСКАУТ.СКАУТ_REST_ВыполнитьЗапросДанных(СтруктураПараметровУчетнойЗаписи, "Login",, ТекстОшибки)) Тогда
		Если СтрНайти(ТекстОшибки, "API calls quota exceeded!") <> 0 И СтрНайти(ТекстОшибки, "1h") = 0 Тогда
			РезультатЗапроса = ВыполнитьПовторныйЗапросПослеПаузы(СтруктураПараметровУчетнойЗаписи,
				"Login",, ТекстОшибки);
			Если Не ЗначениеЗаполнено(РезультатЗапроса) Тогда
				Возврат;
			КонецЕсли;
		Иначе
			Возврат;
