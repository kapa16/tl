		<query>ВЫБРАТЬ
	уатМестонахождениеТССрезПоследних.ТС КАК ТС,
	уатМестонахождениеТССрезПоследних.ТС.ГаражныйНомер КАК ИнвНомер,
	уатМестонахождениеТССрезПоследних.ТС.ГосударственныйНомер КАК ГосНомер,
	уатМестонахождениеТССрезПоследних.ТС.ГодВыпуска КАК ГодВыпуска,
	уатМестонахождениеТССрезПоследних.Подразделение КАК Подразделение,
	уатМестонахождениеТССрезПоследних.Колонна КАК Колонна
ПОМЕСТИТЬ МестонахождениеТС
ИЗ
	РегистрСведений.уатМестонахождениеТС.СрезПоследних(&amp;НаДату, ) КАК уатМестонахождениеТССрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	уатРемонтныйЛист.ДатаНачала КАК ДатаНачала,
	уатРемонтныйЛист.ДатаОкончания КАК ДатаОкончания,
	уатРемонтныйЛист.ТС КАК ТС,
	уатРемонтныйЛист.ПричинаОбращения КАК ПричинаОбращения,
	уатРемонтныйЛист.Номер КАК Номер,
	уатРемонтныйЛист.СуммаДокумента КАК СуммаДокумента,
	ВЫБОР
		КОГДА уатРемонтныйЛист.GDS_ВидОбслуживания5 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА уатРемонтныйЛист.GDS_ВидОбслуживания4 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
						ТОГДА ВЫБОР
								КОГДА уатРемонтныйЛист.ВидОбслуживания3 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
									ТОГДА ВЫБОР
											КОГДА уатРемонтныйЛист.ВидОбслуживания2 = ЗНАЧЕНИЕ(Справочник.уатВидыОбслуживанияТС.ПустаяСсылка)
												ТОГДА уатРемонтныйЛист.ВидОбслуживания
											ИНАЧЕ уатРемонтныйЛист.ВидОбслуживания.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания2.Наименование
										КОНЕЦ
								ИНАЧЕ уатРемонтныйЛист.ВидОбслуживания.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания2.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания3.Наименование
							КОНЕЦ
					ИНАЧЕ уатРемонтныйЛист.ВидОбслуживания.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания2.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания3.Наименование + ", " + уатРемонтныйЛист.GDS_ВидОбслуживания4.Наименование
				КОНЕЦ
		ИНАЧЕ уатРемонтныйЛист.ВидОбслуживания.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания2.Наименование + ", " + уатРемонтныйЛист.ВидОбслуживания3.Наименование + ", " + уатРемонтныйЛист.GDS_ВидОбслуживания4.Наименование + ", " + уатРемонтныйЛист.GDS_ВидОбслуживания5.Наименование
	КОНЕЦ КАК ВидыРемонта
ПОМЕСТИТЬ РемЛисты
ИЗ
	Документ.уатРемонтныйЛист КАК уатРемонтныйЛист
ГДЕ
	уатРемонтныйЛист.ДатаОкончания МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И НЕ уатРемонтныйЛист.ПометкаУдаления
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	МестонахождениеТС.ТС КАК ТС,
	МестонахождениеТС.ИнвНомер КАК ИнвНомер,
	МестонахождениеТС.ГосНомер КАК ГосНомер,
	МестонахождениеТС.ГодВыпуска КАК ГодВыпуска,
	МестонахождениеТС.Подразделение КАК Подразделение,
	МестонахождениеТС.Колонна КАК Колонна,
	РемЛисты.ДатаНачала КАК ДатаНачала,
	РемЛисты.ДатаОкончания КАК ДатаОкончания,
	РемЛисты.ПричинаОбращения КАК ПричинаОбращения,
	РемЛисты.Номер КАК Номер,
	РемЛисты.СуммаДокумента КАК СуммаДокумента,
	РемЛисты.ВидыРемонта КАК ВидыРемонта
ИЗ
	МестонахождениеТС КАК МестонахождениеТС
		ЛЕВОЕ СОЕДИНЕНИЕ РемЛисты КАК РемЛисты
		ПО МестонахождениеТС.ТС = РемЛисты.ТС
ГДЕ
	МестонахождениеТС.ТС.ДатаВыбытия = ДАТАВРЕМЯ(1, 1, 1)

УПОРЯДОЧИТЬ ПО
	ИнвНомер</query>
