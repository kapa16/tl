		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ОбщийПробег.СерияНоменклатуры КАК Шина,
	ОбщийПробег.СерияНоменклатуры.Модель КАК МодельШины,
	ОбщийПробег.СерияНоменклатуры.Модель.НормаПробега КАК НормаВыработки,
	ВЫБОР
		КОГДА ОбщийПробег.ТС ЕСТЬ NULL
			ТОГДА "Начальный пробег"
		ИНАЧЕ ОбщийПробег.ТС
	КОНЕЦ КАК ТСПробега,
	ОбщийПробег.ПробегОборот КАК Выработка,
	ОбщийПробег.ИзносОборот КАК Износ,
	ВЫБОР
		КОГДА ШиныТС.СостояниеАгрегата ЕСТЬ NULL ИЛИ ШиныТС.СостояниеАгрегата = ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято)
			ТОГДА ""
		ИНАЧЕ ШиныТС.МестоУстановки
	КОНЕЦ КАК ТекущееМестоУстановки,
	ВЫБОР
		КОГДА ШиныТС.СостояниеАгрегата ЕСТЬ NULL ИЛИ ШиныТС.СостояниеАгрегата = ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято)
			ТОГДА ""
		ИНАЧЕ ШиныТС.ТС
	КОНЕЦ КАК ТСТекущее,
	ВЫБОР
		КОГДА ШиныТС.СостояниеАгрегата ЕСТЬ NULL ИЛИ ШиныТС.СостояниеАгрегата = ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято)
			ТОГДА ""
		ИНАЧЕ ШиныТС.ТС.ГаражныйНомер
	КОНЕЦ КАК ТСТекущееГарНомер,
	ВЫБОР
		КОГДА ШиныТС.СостояниеАгрегата ЕСТЬ NULL ИЛИ ШиныТС.СостояниеАгрегата = ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято)
			ТОГДА ""
		ИНАЧЕ ШиныТС.ТС.ГосударственныйНомер
	КОНЕЦ КАК ТСТекущееГосНомер,
	ОбщийПробег.ТС.ГосударственныйНомер КАК ТСПробегаГосНомер,
	ОбщийПробег.ТС.ГаражныйНомер КАК ТСПробегаГарНомер,
	ОбщийПробег.СерияНоменклатуры.Модель.НормаПробега - ОбщийПробег.ПробегОборот КАК ВыработкаОсталось,
	1 КАК Количество,
	ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины КАК СрокСлужбы,
	ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины КАК ДатаПроизводства,
	ВЫБОР
		КОГДА ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
				И ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины &lt;&gt; 0
			ТОГДА ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины, МЕСЯЦ, ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины), ДЕНЬ, -1)
		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	КОНЕЦ КАК ГоденДо,
	ВЫБОР
		КОГДА ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
				И ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины &lt;&gt; 0
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(&amp;Период, ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины, МЕСЯЦ, ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины), ДЕНЬ, -1), ДЕНЬ) = 0
						ТОГДА 1
					ИНАЧЕ РАЗНОСТЬДАТ(&amp;Период, ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ОбщийПробег.СерияНоменклатуры.ДатаПроизводстваШины, МЕСЯЦ, ОбщийПробег.СерияНоменклатуры.СрокСлужбыШины), ДЕНЬ, -1), ДЕНЬ)
				КОНЕЦ
		ИНАЧЕ NULL
	КОНЕЦ КАК ДнейОсталось,
	ОбщийПробег.Регистратор КАК Регистратор,
	ВЫРАЗИТЬ(ЕСТЬNULL(ШиныТС.СтепеньИзноса, 0) КАК ЧИСЛО(15,1)) КАК СтепеньИзноса,
	ВЫРАЗИТЬ(ВЫБОР
		КОГДА ОбщийПробег.СерияНоменклатуры.Модель.ВариантНачисленияИзноса = ЗНАЧЕНИЕ(Перечисление.уатВариантыНачисленияИзносаАгрегатов.Период)
			ТОГДА ВЫБОР
					КОГДА ОбщийПробег.СерияНоменклатуры.ПервоначальнаяСтоимость &lt;&gt; 0
						ТОГДА ОбщийПробег.ИзносОборот / ОбщийПробег.СерияНоменклатуры.ПервоначальнаяСтоимость * 100
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ОбщийПробег.СерияНоменклатуры.Модель.НормаПробега &lt;&gt; 0
					ТОГДА ОбщийПробег.ПробегОборот / ОбщийПробег.СерияНоменклатуры.Модель.НормаПробега * 100
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК ЧИСЛО(15,1)) КАК СтепеньИзносаРасчетная
ИЗ
	РегистрНакопления.уатИзносАгрегатов.Обороты(&amp;ПустаяДата, &amp;Период, Регистратор, СерияНоменклатуры.ТипАгрегата = ЗНАЧЕНИЕ(Справочник.уатТипыАгрегатов.Шина)) КАК ОбщийПробег
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатАгрегатыТС.СрезПоследних(&amp;Период, СерияНоменклатуры.ТипАгрегата = ЗНАЧЕНИЕ(Справочник.уатТипыАгрегатов.Шина)) КАК ШиныТС
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.уатОстаткиАгрегатов.Остатки(&amp;Период, СерияНоменклатуры.ТипАгрегата = ЗНАЧЕНИЕ(Справочник.уатТипыАгрегатов.Шина)) КАК уатОстаткиАгрегатовОстатки
			ПО ШиныТС.СерияНоменклатуры = уатОстаткиАгрегатовОстатки.СерияНоменклатуры
		ПО ОбщийПробег.СерияНоменклатуры = ШиныТС.СерияНоменклатуры
			И (&amp;ОтображатьСнятыеШины
				ИЛИ ШиныТС.СостояниеАгрегата &lt;&gt; ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято))
			И (&amp;ОтображатьСписанныеШины
				ИЛИ ШиныТС.СостояниеАгрегата = ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято)
					И НЕ уатОстаткиАгрегатовОстатки.КоличествоОстаток ЕСТЬ NULL 
				ИЛИ ШиныТС.СостояниеАгрегата &lt;&gt; ЗНАЧЕНИЕ(Перечисление.уатСостоянияАгрегатов.Снято))		
ГДЕ
	&amp;ОтображатьВыбывшиеТС
		ИЛИ ОбщийПробег.ТС = ЗНАЧЕНИЕ(Справочник.уатТС.ПустаяСсылка)
		ИЛИ ОбщийПробег.ТС.ДатаВыбытия = ДАТАВРЕМЯ(1, 1, 1)</query>
	</dataSet>
