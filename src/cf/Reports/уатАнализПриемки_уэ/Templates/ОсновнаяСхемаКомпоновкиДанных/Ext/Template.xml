		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	уатАктПриемки_уэ.Дата КАК Дата,
	уатАктПриемки_уэ.Склад КАК Склад,
	уатАктПриемки_уэ.НачалоОперации КАК НачалоПриемки,
	уатАктПриемки_уэ.ОкончаниеОперации КАК ОкончаниеПриемки,
	уатАктПриемки_уэ.Ссылка КАК АктПриемки,
	уатАктПриемки_уэ.Грузы.(
		КоличествоПлан КАК КоличествоПлан,
		Количество КАК КоличествоФакт,
		ВесБруттоПлан КАК ВесПлан,
		ВесБрутто КАК ВесФакт,
		ОбъемПлан КАК ОбъемПлан,
		Объем КАК ОбъемФакт,
		КоличествоМестПлан КАК КоличествоМестПлан,
		КоличествоМест КАК КоличествоМестФакт,
		Статус КАК Статус,
		Состояние КАК Состояние,
		Заказ КАК ЗаказГрузоотправителя,
		ГрузовоеМесто КАК ГрузовоеМесто
	) КАК Грузы
ИЗ
	Документ.уатАктПриемки_уэ КАК уатАктПриемки_уэ
ГДЕ
	уатАктПриемки_уэ.Дата МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И уатАктПриемки_уэ.Проведен = ИСТИНА</query>
