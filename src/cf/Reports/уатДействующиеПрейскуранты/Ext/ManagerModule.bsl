Функция ПолучитьПериодДействияПрейскуранта(ДатаНачала, ДатаОкончания) Экспорт
	
	Возврат НСтр("en='from';ru='с'") + " " + Формат(ДатаНачала, "ДФ=dd.MM.yy") + " " + НСтр("en='till';ru='по'") + " " + Формат(ДатаОкончания, "ДФ=dd.MM.yy");
	
КонецФункции // ПолучитьПериодДействияПрейскуранта()

Функция ПолучитьСтоимость(ТарифСсылка, IDСтроки) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТарифСсылка) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТарифСсылка.СложныйТариф Тогда
		СтрокаСтоимости = "";
		ТЧЗначенияГруппировок = ?(ТарифСсылка.ТарифнаяСетка, ТарифСсылка.ЗначенияТарифнойСетки, ТарифСсылка.Тарифы);
		
		Для Каждого СтрокаТарифа Из ТЧЗначенияГруппировок Цикл 
			Если ТарифСсылка.ТарифнаяСетка И СтрокаТарифа.ID <> IDСтроки Тогда
				Продолжить;
			КонецЕсли;
			
			ЗнакГруппировки1 = ?(ТарифСсылка.ТарифнаяСетка, "<=", СтрокаТарифа.ЗнакГруппировки1);
			ЗнакГруппировки2 = ?(ТарифСсылка.ТарифнаяСетка, "<=", СтрокаТарифа.ЗнакГруппировки2);
			ЗнакГруппировки3 = ?(ТарифСсылка.ТарифнаяСетка, "<=", СтрокаТарифа.ЗнакГруппировки3);
			
			ПодстрокаСтоимости = "";
			Если ЗначениеЗаполнено(ЗнакГруппировки1) Тогда 
				ПодстрокаСтоимости = ПодстрокаСтоимости + ?(ПодстрокаСтоимости = "", "", " " + НСтр("en='and';ru='и'") + " ")
					+ ПолучитьПредставлениеГруппировки(ТарифСсылка.ГруппировкаТарифа1)
					+ ЗнакГруппировки1 + Формат(СтрокаТарифа.ЗначениеГруппировки1, "ЧН=0")
					+ ?(ТипЗнч(ТарифСсылка.ГруппировкаТарифа1) = Тип("СправочникСсылка.уатПараметрыВыработки"), " " + ТарифСсылка.ГруппировкаТарифа1.ЕдиницаИзмерения, "");
			КонецЕсли;
			Если ЗначениеЗаполнено(ЗнакГруппировки2) Тогда 
				ПодстрокаСтоимости = ПодстрокаСтоимости + ?(ПодстрокаСтоимости = "", "", " " + НСтр("en='and';ru='и'") + " ")
					+ ПолучитьПредставлениеГруппировки(ТарифСсылка.ГруппировкаТарифа2)
					+ ЗнакГруппировки2 + Формат(СтрокаТарифа.ЗначениеГруппировки2, "ЧН=0")
					+ ?(ТипЗнч(ТарифСсылка.ГруппировкаТарифа2) = Тип("СправочникСсылка.уатПараметрыВыработки"), " " + ТарифСсылка.ГруппировкаТарифа2.ЕдиницаИзмерения, "");
			КонецЕсли;
			Если ЗначениеЗаполнено(ЗнакГруппировки3) Тогда 
				ПодстрокаСтоимости = ПодстрокаСтоимости + ?(ПодстрокаСтоимости = "", "", " " + НСтр("en='and';ru='и'") + " ")
					+ ПолучитьПредставлениеГруппировки(ТарифСсылка.ГруппировкаТарифа3)
					+ ЗнакГруппировки3 + Формат(СтрокаТарифа.ЗначениеГруппировки3, "ЧН=0")
					+ ?(ТипЗнч(ТарифСсылка.ГруппировкаТарифа3) = Тип("СправочникСсылка.уатПараметрыВыработки"), " " + ТарифСсылка.ГруппировкаТарифа3.ЕдиницаИзмерения, "");
			КонецЕсли;
			
			//СтрокаСтоимости = СтрокаСтоимости + ?(СтрокаСтоимости = "", "", Символы.ПС) + ПодстрокаСтоимости + " - " + Строка(СтрокаТарифа.Тариф) + ";";
			СтрокаСтоимости = СтрокаСтоимости + ?(СтрокаСтоимости = "", "", Символы.ПС) + Строка(СтрокаТарифа.Тариф) + ", при " + ПодстрокаСтоимости + ";";
		КонецЦикла;
	Иначе
		Если ТарифСсылка.ТарифнаяСетка Тогда
			ТекСтрокаСетки = ТарифСсылка.СтрокиТарифнойСетки.Найти(IDСтроки, "ID");
			Если ТекСтрокаСетки <> Неопределено Тогда
				СтрокаСтоимости = "" + Строка(ТекСтрокаСетки.Тариф);
			КонецЕсли;
		Иначе
			СтрокаСтоимости = "" + Строка(ТарифСсылка.Тариф);
		КонецЕсли;
	КонецЕсли;
	
	//Если ТарифСсылка.ТарифнаяСетка Тогда 
	//	СтрокаСтоимости = НСтр("en='Determined by tariff scale';ru='Определяется по тарифной сетке'");
	//	
	//ИначеЕсли ТарифСсылка.СложныйТариф Тогда 
	//	Для Каждого СтрокаТарифа Из ТарифСсылка.Тарифы Цикл 
	//		ПодстрокаСтоимости = "";
	//		Если ЗначениеЗаполнено(СтрокаТарифа.ЗнакГруппировки1) Тогда 
