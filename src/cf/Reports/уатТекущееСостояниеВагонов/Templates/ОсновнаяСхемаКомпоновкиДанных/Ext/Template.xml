		<query>ВЫБРАТЬ
	уатСостояниеТССрезПоследних.Состояние КАК Состояние,
	уатСостояниеТССрезПоследних.Период КАК Начало,
	уатСостояниеТССрезПоследних.ДатаОкончания КАК Окончание,
	ВЫРАЗИТЬ(уатСостояниеТССрезПоследних.Местоположение КАК Справочник.уатПунктыНазначения) КАК Станция,
	уатСостояниеТССрезПоследних.Заказ КАК ЗаказНаТС,
	уатСостояниеТССрезПоследних.Контрагент КАК Контрагент,
	уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто КАК Груз,
	ЕСТЬNULL(уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто.КодЕТСНГ, уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто.КодГНГ) КАК КодГруза,
	уатСостояниеТССрезПоследних.Состояние КАК СостояниеКоличество,
	уатСостояниеТССрезПоследних.ТС КАК ТС
ПОМЕСТИТЬ втТекущееСостояние
ИЗ
	РегистрСведений.уатСостояниеТС.СрезПоследних(&amp;Период, ТС.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМОделейТС.ЖДТранспорт)) КАК уатСостояниеТССрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатЗаказГрузоотправителя.ГрузовойСостав КАК уатЗаказГрузоотправителяГрузовойСостав
		ПО уатСостояниеТССрезПоследних.Заказ.Ссылка = уатЗаказГрузоотправителяГрузовойСостав.Ссылка
ГДЕ
	уатЗаказГрузоотправителяГрузовойСостав.НомерСтроки = 1
	И уатЗаказГрузоотправителяГрузовойСостав.Ссылка = ЕСТЬNULL(уатСостояниеТССрезПоследних.Заказ, ЗНАЧЕНИЕ(Документ.уатЗаказГрузоотправителя.ПустаяСсылка))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	уатТС.Ссылка КАК Вагон,
	уатТС.ВладелецТС КАК Владелец,
	уатТС.Модель КАК Модель,
	уатТС.ТипТС КАК ТипТС,
	ЕСТЬNULL(втТекущееСостояние.Состояние, "1") КАК Состояние,
	ЕСТЬNULL(втТекущееСостояние.Начало, ДАТАВРЕМЯ(1, 1, 1)) КАК Начало,
	ЕСТЬNULL(втТекущееСостояние.Окончание, ДАТАВРЕМЯ(1, 1, 1)) КАК Окончание,
	ЕСТЬNULL(втТекущееСостояние.Станция, ЗНАЧЕНИЕ(Справочник.уатПунктыНазначения.ПустаяСсылка)) КАК Станция,
	ЕСТЬNULL(втТекущееСостояние.ЗаказНаТС, ЗНАЧЕНИЕ(Документ.уатЗаказГрузоотправителя.ПустаяСсылка)) КАК ЗаказНаТС,
	ЕСТЬNULL(втТекущееСостояние.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяССылка)) КАК Контрагент,
	ЕСТЬNULL(втТекущееСостояние.Груз, ЗНАЧЕНИЕ(Справочник.уатГрузовыеМеста_уэ.ПустаяСсылка)) КАК Груз,
	втТекущееСостояние.КодГруза КАК КодГруза,
	ЕСТЬNULL(втТекущееСостояние.СостояниеКоличество, ЗНАЧЕНИЕ(Справочник.уатСостояниеТС.ПустаяСсылка)) КАК СостояниеКоличество
ИЗ
	Справочник.уатТС КАК уатТС
		ЛЕВОЕ СОЕДИНЕНИЕ втТекущееСостояние КАК втТекущееСостояние
		ПО уатТС.Ссылка = втТекущееСостояние.ТС
ГДЕ
	уатТС.ВидМоделиТС = ЗНАЧЕНИЕ(Перечисление.уатВидыМоделейТС.ЖДтранспорт)</query>
