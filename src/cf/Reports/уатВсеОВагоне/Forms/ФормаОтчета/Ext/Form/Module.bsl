&НаСервере
Процедура ПодобратьЗаказыНаТСНаСервере(ПодборПоКоманде = Ложь)
	
	Если Не ПодборПоКоманде И ЗначениеЗаполнено(ЗаказНаТСПрибытие) И ЗначениеЗаполнено(ЗаказНаТСУбытие) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПоСтанции Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС КАК ЗаказНаТС,
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС КАК ЗаказНаТСОтправлениеС
		|ИЗ
		|	РегистрСведений.уатОбеспечениеЗаказовНаТСВагонами КАК уатОбеспечениеЗаказовНаТСВагонами
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА НЕ(&ДатаНачала > уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ДоставкаПо
		|							ИЛИ &ДатаОкончания < уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И уатОбеспечениеЗаказовНаТСВагонами.Вагон = &Вагон
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказНаТСОтправлениеС УБЫВ";
		Запрос.УстановитьПараметр("ДатаНачала", ПериодДатаНач);
		Запрос.УстановитьПараметр("ДатаОкончания", ПериодДатаКон);
		Запрос.УстановитьПараметр("Вагон", Вагон);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЗаказНаТСПрибытие = Выборка.ЗаказНаТС;
			ЗаказНаТСУбытие = Выборка.ЗаказНаТС;
		Иначе
			ЗаказНаТСПрибытие = Неопределено;
			ЗаказНаТСУбытие = Неопределено;
			
			ТекстНСтр = НСтр("ru='В указанный период не найдены Заказы на ТС обеспеченные вагоном ""%1""'");
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", Вагон);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			Возврат;
		КонецЕсли;
		
	Иначе
		
		ВыборкаЗаказНаТСПрибытие = Неопределено;
		ВыборкаЗаказНаТСУбытие = Неопределено;
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС КАК ЗаказНаТС,
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС КАК ЗаказНаТСОтправлениеС,
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.АдресНазначения КАК ЗаказНаТСАдресОтправления
		|ИЗ
		|	РегистрСведений.уатОбеспечениеЗаказовНаТСВагонами КАК уатОбеспечениеЗаказовНаТСВагонами
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА НЕ(&ДатаНачала > уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ДоставкаПо
		|							ИЛИ &ДатаОкончания < уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И уатОбеспечениеЗаказовНаТСВагонами.Вагон = &Вагон
		|	И уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.АдресНазначения = &Станция
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказНаТСОтправлениеС УБЫВ";
		Запрос.УстановитьПараметр("ДатаНачала", ПериодДатаНач);
		Запрос.УстановитьПараметр("ДатаОкончания", ПериодДатаКон);
		Запрос.УстановитьПараметр("Вагон", Вагон);
		Запрос.УстановитьПараметр("Станция", Станция);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ВыборкаЗаказНаТСПрибытие = Выборка.ЗаказНаТС;
		КонецЕсли;
		
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС КАК ЗаказНаТС,
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС КАК ЗаказНаТСОтправлениеС,
		|	уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.АдресОтправления КАК ЗаказНаТСАдресОтправления
		|ИЗ
		|	РегистрСведений.уатОбеспечениеЗаказовНаТСВагонами КАК уатОбеспечениеЗаказовНаТСВагонами
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА НЕ(&ДатаНачала > уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ДоставкаПо
		|							ИЛИ &ДатаОкончания < уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.ОтправлениеС)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И уатОбеспечениеЗаказовНаТСВагонами.Вагон = &Вагон
		|	И уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС.АдресОтправления = &Станция
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказНаТСОтправлениеС УБЫВ";
		Запрос.УстановитьПараметр("ДатаНачала", ПериодДатаНач);
		Запрос.УстановитьПараметр("ДатаОкончания", ПериодДатаКон);
		Запрос.УстановитьПараметр("Вагон", Вагон);
		Запрос.УстановитьПараметр("Станция", Станция);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ВыборкаЗаказНаТСУбытие = Выборка.ЗаказНаТС;
		КонецЕсли;
		
		Если Не (ЗначениеЗаполнено(ВыборкаЗаказНаТСПрибытие) Или ЗначениеЗаполнено(ВыборкаЗаказНаТСУбытие)) Тогда
			ТекстНСтр = НСтр("ru='В указанный период не найдены Заказы на ТС обеспеченные вагоном ""%1""'");
			Если ПоСтанции Тогда
				ТекстНСтр = ТекстНСтр + НСтр("ru=' и связанных со станцией ""%2""'");
				ТекстНСтр = СтрЗаменить(ТекстНСтр, "%2", Станция);
			КонецЕсли;
			ТекстНСтр = СтрЗаменить(ТекстНСтр, "%1", Вагон);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстНСтр);
			Возврат;
		КонецЕсли;
		
		ЗаказНаТСПрибытие = ?(ЗначениеЗаполнено(ВыборкаЗаказНаТСПрибытие), ВыборкаЗаказНаТСПрибытие, ВыборкаЗаказНаТСУбытие);
		ЗаказНаТСУбытие = ?(ЗначениеЗаполнено(ВыборкаЗаказНаТСУбытие), ВыборкаЗаказНаТСУбытие, ВыборкаЗаказНаТСПрибытие);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура НайтиОперацииРегистрирующиеПрибытиеУбытие(ОперацияПрибытие, ДатаПрибытия, ОперацияУбытие, ДатаУбытия, ТаблицаОпераций)
	
	Для каждого ТекОперация Из ТаблицаОпераций Цикл
		Если ТекОперация.Операция.ЭтоПрибытие Тогда
			ОперацияПрибытие = ТекОперация.Ссылка;
			ДатаПрибытия = ТекОперация.Дата;
		ИначеЕсли ТекОперация.Операция.ЭтоУбытие Тогда
			ОперацияУбытие = ТекОперация.Ссылка;
			ДатаУбытия = ТекОперация.Дата;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

