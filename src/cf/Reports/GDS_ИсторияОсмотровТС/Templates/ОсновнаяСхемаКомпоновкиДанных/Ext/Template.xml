		<query>ВЫБРАТЬ
	GDS_ЭлементыПроверкиСрезПоследних.ТС КАК ТС,
	GDS_ЭлементыПроверкиСрезПоследних.ЭлементПроверки КАК ЭлементПроверки,
	GDS_ЭлементыПроверкиСрезПоследних.Состояние КАК Состояние,
	ВЫРАЗИТЬ(GDS_ЭлементыПроверкиСрезПоследних.Замечания КАК СТРОКА(150)) КАК Замечания,
	МАКСИМУМ(GDS_ЭлементыПроверки.Период) КАК ПредПериод,
	GDS_ЭлементыПроверкиСрезПоследних.Период КАК Период
ПОМЕСТИТЬ ВТ_Осмотр
ИЗ
	РегистрСведений.GDS_ЭлементыПроверки.СрезПоследних(&amp;НаДату, ) КАК GDS_ЭлементыПроверкиСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_ЭлементыПроверки КАК GDS_ЭлементыПроверки
		ПО GDS_ЭлементыПроверкиСрезПоследних.ТС = GDS_ЭлементыПроверки.ТС
			И GDS_ЭлементыПроверкиСрезПоследних.ЭлементПроверки = GDS_ЭлементыПроверки.ЭлементПроверки
			И GDS_ЭлементыПроверкиСрезПоследних.Период &lt;&gt; GDS_ЭлементыПроверки.Период
			И (GDS_ЭлементыПроверки.Период &lt; &amp;НаДату)

СГРУППИРОВАТЬ ПО
	GDS_ЭлементыПроверкиСрезПоследних.Состояние,
	GDS_ЭлементыПроверкиСрезПоследних.ЭлементПроверки,
	GDS_ЭлементыПроверкиСрезПоследних.ТС,
	ВЫРАЗИТЬ(GDS_ЭлементыПроверкиСрезПоследних.Замечания КАК СТРОКА(150)),
	GDS_ЭлементыПроверкиСрезПоследних.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Осмотр.ТС КАК ТС,
	ВТ_Осмотр.ЭлементПроверки КАК ЭлементПроверки,
	ВТ_Осмотр.Период КАК Период,
	ВТ_Осмотр.Состояние КАК Состояние,
	ВТ_Осмотр.Замечания КАК Замечания,
	ВТ_Осмотр.ПредПериод КАК ПредПериод,
	GDS_ЭлементыПроверки.Состояние КАК ПредСостояние,
	ВЫРАЗИТЬ(GDS_ЭлементыПроверки.Замечания КАК СТРОКА(150)) КАК ПредЗамечания
ПОМЕСТИТЬ ВТ_Итог
ИЗ
	ВТ_Осмотр КАК ВТ_Осмотр
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.GDS_ЭлементыПроверки КАК GDS_ЭлементыПроверки
		ПО ВТ_Осмотр.ТС = GDS_ЭлементыПроверки.ТС
			И ВТ_Осмотр.ЭлементПроверки = GDS_ЭлементыПроверки.ЭлементПроверки
			И ВТ_Осмотр.ПредПериод = GDS_ЭлементыПроверки.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Итог.ТС.ГосударственныйНомер КАК ГосударственныйНомер,
	ВТ_Итог.ТС КАК ТС,
	ВТ_Итог.ЭлементПроверки КАК ЭлементПроверки,
	ВТ_Итог.Период КАК Период,
	ВТ_Итог.Состояние КАК Состояние,
	ВТ_Итог.Замечания КАК Замечания,
	ВТ_Итог.ПредПериод КАК ПредПериод,
	ВТ_Итог.ПредСостояние КАК ПредСостояние,
	ВТ_Итог.ПредЗамечания КАК ПредЗамечания,
	ВЫБОР
		КОГДА ВТ_Итог.Состояние = ЗНАЧЕНИЕ(Перечисление.GDS_СостоянияПроверкиАПП.Исправно)
				И ВТ_Итог.ПредСостояние = ЗНАЧЕНИЕ(Перечисление.GDS_СостоянияПроверкиАПП.Исправно)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК СостояниеИсправноБезИзменений,
	ВЫБОР
		КОГДА ВТ_Итог.Состояние &lt;&gt; ВТ_Итог.ПредСостояние
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ИзменениеСостояние,
	ВЫБОР
		КОГДА ВТ_Итог.Состояние = ЗНАЧЕНИЕ(Перечисление.GDS_СостоянияПроверкиАПП.Исправно)
				И ВТ_Итог.ПредСостояние &lt;&gt; ЗНАЧЕНИЕ(Перечисление.GDS_СостоянияПроверкиАПП.Исправно)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК СостояниеИсправноИзменено
ИЗ
	ВТ_Итог КАК ВТ_Итог</query>
