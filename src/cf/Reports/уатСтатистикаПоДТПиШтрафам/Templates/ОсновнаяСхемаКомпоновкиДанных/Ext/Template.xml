		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	уатДТП.ТС КАК ТС,
	уатДТП.ТС.Модель КАК ТСМодель,
	ВЫБОР
		КОГДА уатДТП.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Собственное)
			ТОГДА уатДТП.ТС.Организация
		ИНАЧЕ уатДТП.ТС.ВладелецТС
	КОНЕЦ КАК ТСОрганизация,
	уатДТП.ТС.Подразделение КАК ТСПодразделение
ПОМЕСТИТЬ втТС
ИЗ
	Справочник.уатТС КАК уатТС
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатДТП КАК уатДТП
		ПО уатТС.Ссылка = уатДТП.ТС
ГДЕ
	уатДТП.Дата &gt;= &amp;ДатаНачала
	И уатДТП.Дата &lt;= &amp;ДатаОкончания
	И уатДТП.ПометкаУдаления = ЛОЖЬ

ОБЪЕДИНИТЬ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	уатШтраф.ТС,
	уатШтраф.ТС.Модель,
	ВЫБОР
		КОГДА уатШтраф.ТС.ПринадлежностьТС = ЗНАЧЕНИЕ(Перечисление.уатПринадлежностьТС.Собственное)
			ТОГДА уатШтраф.ТС.Организация
		ИНАЧЕ уатШтраф.ТС.ВладелецТС
	КОНЕЦ,
	уатШтраф.ТС.Подразделение
ИЗ
	Справочник.уатТС КАК уатТС
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатШтраф КАК уатШтраф
		ПО уатТС.Ссылка = уатШтраф.ТС
ГДЕ
	уатШтраф.Дата &gt;= &amp;ДатаНачала
	И уатШтраф.Дата &lt;= &amp;ДатаОкончания
	И уатШтраф.ПометкаУдаления = ЛОЖЬ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	втТС.ТС КАК ТС,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ уатДТП.Ссылка) КАК КоличествоДТП,
	уатДТП.ПричинаДТП КАК ПричинаДТП,
	НАЧАЛОПЕРИОДА(уатДТП.Дата, МЕСЯЦ) КАК МесяцДТП
ПОМЕСТИТЬ втКоличествоДТП
ИЗ
	Документ.уатДТП КАК уатДТП
		ЛЕВОЕ СОЕДИНЕНИЕ втТС КАК втТС
		ПО уатДТП.ТС = втТС.ТС
ГДЕ
	уатДТП.Дата &gt;= &amp;ДатаНачала
	И уатДТП.Дата &lt;= &amp;ДатаОкончания
	И уатДТП.ПометкаУдаления = ЛОЖЬ

СГРУППИРОВАТЬ ПО
	втТС.ТС,
	уатДТП.ПричинаДТП,
	НАЧАЛОПЕРИОДА(уатДТП.Дата, МЕСЯЦ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	втТС.ТС КАК ТС,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ уатШтраф.Ссылка) КАК КоличествоШтрафов,
	уатШтраф.ХарактерНарушения КАК ХарактерНарушения,
	НАЧАЛОПЕРИОДА(уатШтраф.Дата, МЕСЯЦ) КАК МесяцШтраф
ПОМЕСТИТЬ втКоличествоШтрафов
ИЗ
	Документ.уатШтраф КАК уатШтраф
		ЛЕВОЕ СОЕДИНЕНИЕ втТС КАК втТС
		ПО уатШтраф.ТС = втТС.ТС
ГДЕ
	уатШтраф.Дата &gt;= &amp;ДатаНачала
	И уатШтраф.Дата &lt;= &amp;ДатаОкончания
	И уатШтраф.ПометкаУдаления = ЛОЖЬ

СГРУППИРОВАТЬ ПО
	втТС.ТС,
	уатШтраф.ХарактерНарушения,
	НАЧАЛОПЕРИОДА(уатШтраф.Дата, МЕСЯЦ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втТС.ТС КАК ТС,
	втТС.ТСМодель КАК ТСМодель,
	втТС.ТСОрганизация КАК ТСОрганизация,
	втТС.ТСПодразделение КАК ТСПодразделение,
	втКоличествоДТП.КоличествоДТП КАК КоличествоДТП,
	втКоличествоДТП.ПричинаДТП КАК ПричинаДТП,
	втКоличествоДТП.МесяцДТП КАК МесяцДТП,
	NULL КАК ХарактерНарушения,
	NULL КАК КоличествоШтрафов
ПОМЕСТИТЬ втКоличествоДТПИШтрафов
ИЗ
	втКоличествоДТП КАК втКоличествоДТП
		ЛЕВОЕ СОЕДИНЕНИЕ втТС КАК втТС
		ПО (втТС.ТС = втКоличествоДТП.ТС)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	втТС.ТС,
	втТС.ТСМодель,
	втТС.ТСОрганизация,
	втТС.ТСПодразделение,
	NULL,
	NULL,
	втКоличествоШтрафов.МесяцШтраф,
	втКоличествоШтрафов.ХарактерНарушения,
	втКоличествоШтрафов.КоличествоШтрафов
ИЗ
	втКоличествоШтрафов КАК втКоличествоШтрафов
		ЛЕВОЕ СОЕДИНЕНИЕ втТС КАК втТС
		ПО (втТС.ТС = втКоличествоШтрафов.ТС)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТВТ.ТС КАК ТС,
	ВТВТ.ТСМодель КАК ТСМодель,
	ВТВТ.ТСОрганизация КАК ТСОрганизация,
	ВТВТ.ТСПодразделение КАК ТСПодразделение,
	ПробегНаКонец.Значение - ЕСТЬNULL(ПробегНаНачало.Значение, 0) КАК ПробегЗаПериод,
	ВЫРАЗИТЬ(ВТВТ.КоличествоДТП * 1000000 / (ПробегНаКонец.Значение - ЕСТЬNULL(ПробегНаНачало.Значение, 0)) КАК ЧИСЛО(10, 3)) КАК ДТПНаПробег,
	ВЫРАЗИТЬ(ВТВТ.КоличествоШтрафов * 1000000 / (ПробегНаКонец.Значение - ЕСТЬNULL(ПробегНаНачало.Значение, 0)) КАК ЧИСЛО(10, 3)) КАК ШтрафовНаПробег,
	ВТВТ.КоличествоДТП КАК КоличествоДТП,
	ВТВТ.КоличествоШтрафов КАК КоличествоШтрафов,
	ЕСТЬNULL(ВТВТ.ПричинаДТП, ВТВТ.ХарактерНарушения) КАК ПричинаДТПХарактерНарушения,
	ВТВТ.МесяцДТП КАК Месяц
ИЗ
	втКоличествоДТПИШтрафов КАК ВТВТ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСчетчикиТС.СрезПоследних(&amp;ДатаОкончания {(&amp;ДатаОкончания)}, ТипСчетчика = ЗНАЧЕНИЕ(Перечисление.уатТипыСчетчиковТС.Спидометр)) КАК ПробегНаКонец
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСчетчикиТС.СрезПоследних(&amp;ДатаНачала {(&amp;ДатаНачала)}, ТипСчетчика = ЗНАЧЕНИЕ(Перечисление.уатТипыСчетчиковТС.Спидометр)) КАК ПробегНаНачало
			ПО ПробегНаКонец.ТС = ПробегНаНачало.ТС
		ПО ВТВТ.ТС = ПробегНаКонец.ТС
ГДЕ
	ЕСТЬNULL(ПробегНаКонец.Значение, 0) - ЕСТЬNULL(ПробегНаНачало.Значение, 0) &lt;&gt; 0</query>
