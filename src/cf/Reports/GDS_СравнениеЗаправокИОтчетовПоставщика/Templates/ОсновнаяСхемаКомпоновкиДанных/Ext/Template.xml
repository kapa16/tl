		<query>ВЫБРАТЬ
	НАЧАЛОПЕРИОДА(уатОборотыПоЗаправкамГСМ.Период, ДЕНЬ) КАК Период,
	уатОборотыПоЗаправкамГСМ.ГСМ КАК ГСМ,
	уатОборотыПоЗаправкамГСМ.ТС КАК ТС,
	уатОборотыПоЗаправкамГСМ.Количество КАК Количество,
	уатОборотыПоЗаправкамГСМ.Регистратор КАК Регистратор,
	уатОборотыПоЗаправкамГСМ.АЗС КАК АЗС
ПОМЕСТИТЬ ВТ_Заправки
ИЗ
	РегистрНакопления.уатОборотыПоЗаправкамГСМ КАК уатОборотыПоЗаправкамГСМ
ГДЕ
	уатОборотыПоЗаправкамГСМ.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
{ГДЕ
	(уатОборотыПоЗаправкамГСМ.ТС = &amp;ТС)}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	уатОборотыПоОтчетамПоставщиковПЦ.ТС КАК ТС,
	уатОборотыПоОтчетамПоставщиковПЦ.Количество КАК Количество,
	уатОборотыПоОтчетамПоставщиковПЦ.Регистратор КАК Регистратор,
	уатОборотыПоОтчетамПоставщиковПЦ.АЗС КАК АЗС,
	НАЧАЛОПЕРИОДА(уатОборотыПоОтчетамПоставщиковПЦ.Период, ДЕНЬ) КАК Период,
	уатОборотыПоОтчетамПоставщиковПЦ.Номенклатура КАК Номенклатура
ПОМЕСТИТЬ ВТ_Поставщик
ИЗ
	РегистрНакопления.уатОборотыПоОтчетамПоставщиковПЦ КАК уатОборотыПоОтчетамПоставщиковПЦ
ГДЕ
	уатОборотыПоОтчетамПоставщиковПЦ.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
{ГДЕ
	(уатОборотыПоОтчетамПоставщиковПЦ.ТС = &amp;ТС)}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Заправки.Период КАК Период,
	ВТ_Заправки.Регистратор КАК Регистратор,
	ВТ_Заправки.ТС КАК ТС,
	ВТ_Заправки.Количество КАК Количество,
	ВТ_Поставщик.Период КАК Период1,
	ВТ_Поставщик.Регистратор КАК Регистратор1,
	ВТ_Поставщик.ТС КАК ТС1,
	ВТ_Поставщик.Количество КАК Количество1
ИЗ
	ВТ_Заправки КАК ВТ_Заправки
		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Поставщик КАК ВТ_Поставщик
		ПО ВТ_Заправки.ТС = ВТ_Поставщик.ТС
			И ВТ_Заправки.Период = ВТ_Поставщик.Период
			И ВТ_Заправки.Количество = ВТ_Поставщик.Количество

СГРУППИРОВАТЬ ПО
	ВТ_Заправки.Период,
	ВТ_Заправки.Регистратор,
	ВТ_Заправки.ТС,
	ВТ_Заправки.Количество,
	ВТ_Поставщик.Период,
	ВТ_Поставщик.Регистратор,
	ВТ_Поставщик.ТС,
	ВТ_Поставщик.Количество</query>
