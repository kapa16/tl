		<query>ВЫБРАТЬ
	уатЗаправкаГСМЗаправки.ТС КАК ТС,
	уатЗаправкаГСМЗаправки.ПутевойЛист КАК ПЛ,
	СУММА(уатЗаправкаГСМЗаправки.Количество) КАК Количество,
	уатЗаправкаГСМЗаправки.ГСМ КАК ГСМ,
	уатЗаправкаГСМЗаправки.Ссылка.АЗС КАК АЗС
ПОМЕСТИТЬ ВыборкаЗаправок
ИЗ
	Документ.уатЗаправкаГСМ.Заправки КАК уатЗаправкаГСМЗаправки
ГДЕ
	уатЗаправкаГСМЗаправки.Ссылка.Проведен
	И уатЗаправкаГСМЗаправки.Ссылка.Дата МЕЖДУ &amp;ДатаНач И &amp;ДатаКон
	И уатЗаправкаГСМЗаправки.Ссылка.ВидДвиженияГСМ = &amp;ВидДвиженияГСМ

СГРУППИРОВАТЬ ПО
	уатЗаправкаГСМЗаправки.ТС,
	уатЗаправкаГСМЗаправки.ПутевойЛист,
	уатЗаправкаГСМЗаправки.ГСМ,
	уатЗаправкаГСМЗаправки.Ссылка.АЗС
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	GDS_ЗаправочнаяВедомостьЗаправки.ТС КАК ТС,
	GDS_ЗаправочнаяВедомостьЗаправки.ПЛ КАК ПЛ,
	СУММА(GDS_ЗаправочнаяВедомостьЗаправки.Количество) КАК Количество,
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка КАК Ссылка,
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.ГСМ КАК ГСМ,
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.АЗС КАК АЗС
ПОМЕСТИТЬ ВыборкаВедомостьЗаправок
ИЗ
	Документ.GDS_ЗаправочнаяВедомость.Заправки КАК GDS_ЗаправочнаяВедомостьЗаправки
ГДЕ
	НЕ GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.ПометкаУдаления
	И GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.Дата МЕЖДУ &amp;ДатаНач И &amp;ДатаКон

СГРУППИРОВАТЬ ПО
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.ГСМ,
	GDS_ЗаправочнаяВедомостьЗаправки.ПЛ,
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка.АЗС,
	GDS_ЗаправочнаяВедомостьЗаправки.ТС,
	GDS_ЗаправочнаяВедомостьЗаправки.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЕСТЬNULL(ВыборкаЗаправок.ТС, ВыборкаВедомостьЗаправок.ТС) КАК ТС,
	ЕСТЬNULL(ВыборкаЗаправок.ПЛ, ВыборкаВедомостьЗаправок.ПЛ) КАК ПЛ,
	СУММА(ЕСТЬNULL(ВыборкаЗаправок.Количество, 0)) КАК КоличествоЗаправкаГСМ,
	ЕСТЬNULL(ВыборкаЗаправок.ГСМ, ВыборкаВедомостьЗаправок.ГСМ) КАК ГСМ,
	ЕСТЬNULL(ВыборкаЗаправок.АЗС, ВыборкаВедомостьЗаправок.АЗС) КАК АЗС,
	СУММА(ЕСТЬNULL(ВыборкаВедомостьЗаправок.Количество, 0)) КАК КоличествоПоВедомости,
	ЕСТЬNULL(ВыборкаВедомостьЗаправок.Ссылка, "") КАК Ведомость
ПОМЕСТИТЬ ВыборкаИтоговая
ИЗ
	ВыборкаЗаправок КАК ВыборкаЗаправок
		ПОЛНОЕ СОЕДИНЕНИЕ ВыборкаВедомостьЗаправок КАК ВыборкаВедомостьЗаправок
		ПО ВыборкаЗаправок.ТС = ВыборкаВедомостьЗаправок.ТС
			И ВыборкаЗаправок.ПЛ = ВыборкаВедомостьЗаправок.ПЛ
			И ВыборкаЗаправок.ГСМ = ВыборкаВедомостьЗаправок.ГСМ
			И ВыборкаЗаправок.АЗС = ВыборкаВедомостьЗаправок.АЗС

СГРУППИРОВАТЬ ПО
	ЕСТЬNULL(ВыборкаЗаправок.ТС, ВыборкаВедомостьЗаправок.ТС),
	ЕСТЬNULL(ВыборкаЗаправок.ПЛ, ВыборкаВедомостьЗаправок.ПЛ),
	ЕСТЬNULL(ВыборкаЗаправок.ГСМ, ВыборкаВедомостьЗаправок.ГСМ),
	ЕСТЬNULL(ВыборкаЗаправок.АЗС, ВыборкаВедомостьЗаправок.АЗС),
	ЕСТЬNULL(ВыборкаВедомостьЗаправок.Ссылка, "")
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВыборкаИтоговая.КоличествоЗаправкаГСМ КАК КоличествоЗаправкаГСМ,
	ВыборкаИтоговая.ТС КАК ТС,
	ВыборкаИтоговая.ПЛ КАК ПЛ,
	ВыборкаИтоговая.ГСМ КАК ГСМ,
	ВыборкаИтоговая.АЗС КАК АЗС,
	СУММА(ВыборкаИтоговая.КоличествоПоВедомости) КАК КоличествоПоВедомости,
	ВыборкаИтоговая.Ведомость КАК Ведомость,
	СУММА(ВыборкаИтоговая.КоличествоЗаправкаГСМ - ВыборкаИтоговая.КоличествоПоВедомости) КАК Разница
ИЗ
	ВыборкаИтоговая КАК ВыборкаИтоговая

СГРУППИРОВАТЬ ПО
	ВыборкаИтоговая.ТС,
	ВыборкаИтоговая.ПЛ,
	ВыборкаИтоговая.КоличествоЗаправкаГСМ,
	ВыборкаИтоговая.ГСМ,
	ВыборкаИтоговая.АЗС,
	ВыборкаИтоговая.Ведомость

УПОРЯДОЧИТЬ ПО
	АЗС,
	ТС</query>
