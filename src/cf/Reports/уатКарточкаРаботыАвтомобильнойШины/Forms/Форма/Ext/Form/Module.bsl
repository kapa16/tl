// Заполнение частичной строки (только изменяемые поля)
&НаСервере
Процедура ЗаполнитьЧастичнуюСтроку(Строка, ИсточникДанных)
	ПустаяСтрока = Новый Структура;
	ПустаяСтрока.Вставить("ПредставлениеТС", "");
	ПустаяСтрока.Вставить("ПоказанияОдометра", 0);
	ПустаяСтрока.Вставить("ДатаУстановкиШиныНаТС", 0);
	ПустаяСтрока.Вставить("ДатаСнятияШиныСТС", 0);
	ПустаяСтрока.Вставить("РегистраторПричинаОбращения", 0);
	
	Строка.Параметры.Заполнить(ПустаяСтрока);
	Строка.Параметры.ЗаМесяц = ИсточникДанных.ПробегЗаМесяц/1000;
	Строка.Параметры.ПробегОбщий = ИсточникДанных.ПробегОбщий/1000;
	Строка.Параметры.ПредставлениеПериода = Строка(Формат(ИсточникДанных.Период, "ДФ=MM.yyyy")) + "г.";
	
КонецПроцедуры

// Установка дат установки/снятия в зависимости от состояния
&НаСервере
Процедура УстановитьДатыВСтроке(Строка, ИсточникДанных)
	
	Если Строка.Параметры.СостояниеАгрегата = Перечисления.уатСостоянияАгрегатов.УстановленоВРаботе Тогда
		Строка.Параметры.ДатаУстановкиШиныНаТС = ИсточникДанных.ДатаУстановкиШиныНаТС;
		Строка.Параметры.ДатаСнятияШиныСТС = 0;
	ИначеЕсли Строка.Параметры.СостояниеАгрегата = Перечисления.уатСостоянияАгрегатов.Снято Тогда
		Строка.Параметры.ДатаУстановкиШиныНаТС = 0;
		Строка.Параметры.ДатаСнятияШиныСТС = ИсточникДанных.ДатаСнятияШиныСТС;
	КонецЕсли;
	
КонецПроцедуры

// Обработка случая: установка и снятие в одном месяце
&НаСервере
Процедура ОбработатьУстановкуИСнятиеВМесяце(ТекНайденнаяСтрока, Шина, Запрос, Строка, ДокументРезультат, Сч, НайдСтроки, Выборка)
	
	// Первая запись - установка
	Запрос.УстановитьПараметр("Период", ТекНайденнаяСтрока.ДатаУстановкиШиныНаТС);
	Запрос.УстановитьПараметр("СерияНоменклатуры", Шина);
	СостояниеАгрегата = ПолучитьСостояниеАгрегата(Запрос, ТекНайденнаяСтрока.ДатаУстановкиШиныНаТС, Шина, ТекНайденнаяСтрока.ТС);
	ЗаполнитьСостояниеВСтроке(Строка, СостояниеАгрегата);
	
	НачальноеЗначениеОдометра = ПолучитьНачальноеЗначениеОдометра(ТекНайденнаяСтрока.МодельТС, ТекНайденнаяСтрока.ТС, ТекНайденнаяСтрока.Период);
	
	Строка.Параметры.Заполнить(ТекНайденнаяСтрока);
	Строка.Параметры.ПредставлениеТС = ТекНайденнаяСтрока.ГосударственныйНомер + ", " + ТекНайденнаяСтрока.МодельТС + ", " + ТекНайденнаяСтрока.ИнвНомерТС;
	Строка.Параметры.ТС = ТекНайденнаяСтрока.ТС;
	Строка.Параметры.ПредставлениеПериода = Строка(Формат(ТекНайденнаяСтрока.Период, "ДФ=MM.yyyy")) + "г.";
	Строка.Параметры.ЗаМесяц = "⬇";
	Строка.Параметры.ПробегОбщий = ТекНайденнаяСтрока.ПробегОбщий/1000;
	Строка.Параметры.ПоказанияОдометра = НачальноеЗначениеОдометра;
	Строка.Параметры.ДатаУстановкиШиныНаТС = ТекНайденнаяСтрока.ДатаУстановкиШиныНаТС;
	Строка.Параметры.ДатаСнятияШиныСТС = 0;
	ДокументРезультат.Вывести(Строка);
	
	// Вторая запись - снятие
	Запрос.УстановитьПараметр("Период", ТекНайденнаяСтрока.ДатаСнятияШиныСТС - 1);
	Запрос.УстановитьПараметр("СерияНоменклатуры", Шина);
	СостояниеАгрегата = ПолучитьСостояниеАгрегата(Запрос, ТекНайденнаяСтрока.ДатаСнятияШиныСТС - 1, Шина, ТекНайденнаяСтрока.ТС);
	ЗаполнитьСостояниеВСтроке(Строка, СостояниеАгрегата);
	
	НачальноеЗначениеОдометра = ПолучитьНачальноеЗначениеОдометра(ТекНайденнаяСтрока.МодельТС, ТекНайденнаяСтрока.ТС, ТекНайденнаяСтрока.Период);
	
	Строка.Параметры.Заполнить(ТекНайденнаяСтрока);
	Строка.Параметры.ПредставлениеТС = ТекНайденнаяСтрока.ГосударственныйНомер + ", " + ТекНайденнаяСтрока.МодельТС + ", " + ТекНайденнаяСтрока.ИнвНомерТС;
	Строка.Параметры.ТС = ТекНайденнаяСтрока.ТС;
	Строка.Параметры.ПредставлениеПериода = Строка(Формат(ТекНайденнаяСтрока.Период, "ДФ=MM.yyyy")) + "г.";
	
	Если Сч = НайдСтроки.Количество() Тогда
		Строка.Параметры.ЗаМесяц = ТекНайденнаяСтрока.ПробегЗаМесяц/1000;
	Иначе
		Выборка.Следующий();
		Строка.Параметры.ЗаМесяц = "⬇";
	КонецЕсли;
	
	Строка.Параметры.ПробегОбщий = ТекНайденнаяСтрока.ПробегОбщий/1000;
	Строка.Параметры.ПоказанияОдометра = НачальноеЗначениеОдометра;
	Строка.Параметры.ДатаУстановкиШиныНаТС = 0;
	Строка.Параметры.ДатаСнятияШиныСТС = ТекНайденнаяСтрока.ДатаСнятияШиныСТС;
	ДокументРезультат.Вывести(Строка);
	
КонецПроцедуры

