		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	уатПланРаботыТСОбороты.ДетализацияПланирования КАК ТС,
	уатПланРаботыТСОбороты.ПараметрВыработки КАК ПараметрВыработки,
	уатВыработкаТСОбороты.КоличествоОборот КАК НачальнаяВыработка,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(уатПланРаботыТСОбороты.ДетализацияПланирования) = ТИП(Справочник.уатМоделиТС)
			ТОГДА уатПланРаботыТСОбороты.ДетализацияПланирования
		ИНАЧЕ ВЫРАЗИТЬ(уатПланРаботыТСОбороты.ДетализацияПланирования КАК Справочник.уатТС).Модель
	КОНЕЦ КАК МодельТС
ПОМЕСТИТЬ втНачальнаяВыработкаТС
ИЗ
	РегистрНакопления.уатПланРаботыТС.Обороты(&amp;НачалоПериода, &amp;КонецПериода, , Сценарий = &amp;СценарийСПлановойВыработкой) КАК уатПланРаботыТСОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.уатВыработкаТС.Обороты(&amp;НачалоВремен {(&amp;НачалоВремен)}, &amp;НачалоПериода {(&amp;НачалоПериода)}, , ) КАК уатВыработкаТСОбороты
		ПО уатПланРаботыТСОбороты.ДетализацияПланирования = уатВыработкаТСОбороты.ТС
			И уатПланРаботыТСОбороты.ПараметрВыработки = уатВыработкаТСОбороты.ПараметрВыработки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втНачальнаяВыработкаТС.ТС КАК ТС,
	втНачальнаяВыработкаТС.ПараметрВыработки КАК ПараметрВыработки,
	втНачальнаяВыработкаТС.НачальнаяВыработка КАК НачальнаяВыработка,
	втНачальнаяВыработкаТС.МодельТС КАК МодельТС,
	уатМоделиТСНормативыОбслуживания.ВидОбслуживания КАК ВидОбслуживания,
	уатМоделиТСНормативыОбслуживания.ПериодичностьОбслуживания КАК ПериодичностьОбслуживания,
	уатТС.ДатаВводаВЭксплуатацию КАК ДатаВводаВЭксплуатацию
ПОМЕСТИТЬ втНормативыТО
ИЗ
	втНачальнаяВыработкаТС КАК втНачальнаяВыработкаТС
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатМоделиТС.НормативыОбслуживания КАК уатМоделиТСНормативыОбслуживания
		ПО втНачальнаяВыработкаТС.МодельТС = уатМоделиТСНормативыОбслуживания.Ссылка
			И втНачальнаяВыработкаТС.ПараметрВыработки = уатМоделиТСНормативыОбслуживания.ПараметрВыработки
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТС КАК уатТС
		ПО втНачальнаяВыработкаТС.ТС = уатТС.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втНормативыТО.ТС КАК ТС,
	втНормативыТО.ПараметрВыработки КАК ПараметрВыработки,
	втНормативыТО.НачальнаяВыработка КАК НачальнаяВыработка,
	втНормативыТО.МодельТС КАК МодельТС,
	втНормативыТО.ВидОбслуживания КАК ВидОбслуживания,
	втНормативыТО.ПериодичностьОбслуживания КАК ПериодичностьОбслуживания,
	ЕСТЬNULL(уатПрохождениеТОСрезПоследних.Период, втНормативыТО.ДатаВводаВЭксплуатацию) КАК ДатаПоследнегоТО
ИЗ
	втНормативыТО КАК втНормативыТО
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатПрохождениеТО.СрезПоследних({(&amp;НачалоПериода)}, ) КАК уатПрохождениеТОСрезПоследних
		ПО втНормативыТО.ТС = уатПрохождениеТОСрезПоследних.ТС
			И втНормативыТО.ВидОбслуживания = уатПрохождениеТОСрезПоследних.ВидТО
			И втНормативыТО.ПараметрВыработки = уатПрохождениеТОСрезПоследних.ПараметрВыработки</query>
	</dataSet>
