		<dataPath>Норма</dataPath>
		<expression>Сумма(Норма)</expression>
	</totalField>
	<totalField>
		<dataPath>ДатаВыдачи</dataPath>
		<expression>Минимум(ДатаВыдачи)</expression>
	</totalField>
	<totalField>
		<dataPath>ДатаОкончанияЭксплуатации</dataPath>
		<expression>Минимум(ДатаОкончанияЭксплуатации)</expression>
	</totalField>
	<totalField>
