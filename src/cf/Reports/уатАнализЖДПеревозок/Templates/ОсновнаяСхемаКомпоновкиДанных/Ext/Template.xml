	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Вагон</dataPath>
			<field>Вагон</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Заказ</dataPath>
			<field>Заказ</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГрузовоеМесто</dataPath>
			<field>ГрузовоеМесто</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Объем</dataPath>
			<field>Объем</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВесБрутто</dataPath>
			<field>ВесБрутто</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Статус</dataPath>
			<field>Статус</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусЗаказа</dataPath>
			<field>СтатусЗаказа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Статус заказа</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Order status</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	уатЗаказГрузоотправителя.Ссылка КАК Заказ,
	уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто КАК ГрузовоеМесто,
	СУММА(уатЗаказГрузоотправителяГрузовойСостав.ВесБрутто) КАК ВесБрутто,
	СУММА(уатЗаказГрузоотправителяГрузовойСостав.Объем) КАК Объем,
	ЕСТЬNULL(уатОбеспечениеЗаказовНаТСВагонами.Вагон, ЗНАЧЕНИЕ(Справочник.уатТС.ПустаяСсылка)) КАК Вагон
ПОМЕСТИТЬ втГрузовыеМеста
ИЗ
	Документ.уатЗаказГрузоотправителя КАК уатЗаказГрузоотправителя
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.уатЗаказГрузоотправителя.ГрузовойСостав КАК уатЗаказГрузоотправителяГрузовойСостав
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатОбеспечениеЗаказовНаТСВагонами КАК уатОбеспечениеЗаказовНаТСВагонами
			ПО уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто = уатОбеспечениеЗаказовНаТСВагонами.Груз
				И уатЗаказГрузоотправителяГрузовойСостав.Ссылка = уатОбеспечениеЗаказовНаТСВагонами.ЗаказНаТС
		ПО уатЗаказГрузоотправителя.Ссылка = уатЗаказГрузоотправителяГрузовойСостав.Ссылка
ГДЕ
	уатЗаказГрузоотправителя.ВидПеревозки = ЗНАЧЕНИЕ(Справочник.уатВидыПеревозок.Железнодорожная)
	И уатЗаказГрузоотправителя.Дата &gt;= &amp;ПериодНачало
	И уатЗаказГрузоотправителя.ДетализацияЗакрытия = ЗНАЧЕНИЕ(Перечисление.уатДетализацияЗаказаГрузоотправителя_уэ.ПоГрузовымМестам)

СГРУППИРОВАТЬ ПО
	уатЗаказГрузоотправителяГрузовойСостав.ГрузовоеМесто,
	уатЗаказГрузоотправителя.Ссылка,
	ЕСТЬNULL(уатОбеспечениеЗаказовНаТСВагонами.Вагон, ЗНАЧЕНИЕ(Справочник.уатТС.ПустаяСсылка))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втГрузовыеМеста.Заказ КАК Заказ,
	ВЫБОР
		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый))) &gt; 1
			ТОГДА ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Составной)
		ИНАЧЕ МАКСИМУМ(ЕСТЬNULL(уатСтатусыГрузов_уэСрезПоследних.Статус, ЗНАЧЕНИЕ(Справочник.уатСтатусы_уэ.Новый)))
	КОНЕЦ КАК СтатусЗаказа
ПОМЕСТИТЬ втСтатусЗаказа
ИЗ
	втГрузовыеМеста КАК втГрузовыеМеста
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСтатусыГрузов_уэ.СрезПоследних(
				,
				Заказ В
					(ВЫБРАТЬ
						втГрузовыеМеста.Заказ КАК Заказ
					ИЗ
						втГрузовыеМеста КАК втГрузовыеМеста)) КАК уатСтатусыГрузов_уэСрезПоследних
		ПО втГрузовыеМеста.Заказ = уатСтатусыГрузов_уэСрезПоследних.Заказ

СГРУППИРОВАТЬ ПО
	втГрузовыеМеста.Заказ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втГрузовыеМеста.Заказ КАК Заказ,
	втГрузовыеМеста.ГрузовоеМесто КАК ГрузовоеМесто,
	втГрузовыеМеста.ВесБрутто КАК ВесБрутто,
	втГрузовыеМеста.Объем КАК Объем,
	уатСтатусыГрузов_уэСрезПоследних.Статус КАК Статус,
	втСтатусЗаказа.СтатусЗаказа КАК СтатусЗаказа,
	втГрузовыеМеста.Вагон КАК Вагон
ИЗ
	втГрузовыеМеста КАК втГрузовыеМеста
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатСтатусыГрузов_уэ.СрезПоследних(
				&amp;Период,
				(Заказ, ГрузовоеМесто) В
					(ВЫБРАТЬ
						втГрузовыеМеста.Заказ КАК Заказ,
						втГрузовыеМеста.ГрузовоеМесто КАК ГрузовоеМесто
					ИЗ
						втГрузовыеМеста КАК втГрузовыеМеста)) КАК уатСтатусыГрузов_уэСрезПоследних
		ПО втГрузовыеМеста.Заказ = уатСтатусыГрузов_уэСрезПоследних.Заказ
			И втГрузовыеМеста.ГрузовоеМесто = уатСтатусыГрузов_уэСрезПоследних.ГрузовоеМесто
		ЛЕВОЕ СОЕДИНЕНИЕ втСтатусЗаказа КАК втСтатусЗаказа
		ПО втГрузовыеМеста.Заказ = втСтатусЗаказа.Заказ

СГРУППИРОВАТЬ ПО
	втГрузовыеМеста.Заказ,
	втГрузовыеМеста.ГрузовоеМесто,
	втГрузовыеМеста.ВесБрутто,
	втГрузовыеМеста.Объем,
	уатСтатусыГрузов_уэСрезПоследних.Статус,
	втСтатусЗаказа.СтатусЗаказа,
	втГрузовыеМеста.Вагон</query>
