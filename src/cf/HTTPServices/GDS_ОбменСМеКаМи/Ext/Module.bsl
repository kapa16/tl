
Функция ПолучитьДокументПолучить(Запрос)
	Сообщение = Запрос.ПолучитьТелоКакСтроку("UTF-8");
	
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(Сообщение);
    ДанныеДругойБазы = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();
	
	РезультатЗаписи = GDS_ФункцииОбмена.ОбработатьВходящийJSONОбъект(ДанныеДругойБазы);
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, РезультатЗаписи.Ответ);
    СтрокаДляОтвета = ЗаписьJSON.Закрыть();
	
	Ответ = Новый HTTPСервисОтвет(РезультатЗаписи.КодОтвета);
    Ответ.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Возврат Ответ;
КонецФункции
